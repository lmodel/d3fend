       ) ;
       rdf:type [ <AccessControlList> ] ?
    )
}

<AccessDeniedEvent> CLOSED {
    (  $<AccessDeniedEvent_tes> (  &<AccessMediationEvent_tes> ;
          rdf:type [ <AccessMediationEvent> ] ?
       ) ;
       rdf:type [ <AccessDeniedEvent> ] ?
