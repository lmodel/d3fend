       ) ;
       rdf:type [ <AccessGrantedEvent> ] ?
    )
}

<AccessMediation>  (
    CLOSED {
       (  $<AccessMediation_tes> (  &<DefensiveTechnique_tes> ;
             rdf:type [ <DefensiveTechnique> ] ?
          ) ;
          rdf:type [ <AccessMediation> ] ?
       )
    } OR @<CredentialTransmissionScoping> OR @<IOPortRestriction> OR @<NetworkAccessMediation> OR @<NetworkResourceAccessMediation>
    OR @<OTVariableAccessRestriction> OR @<OperatingModeRestriction> OR @<PhysicalAccessMediation> OR @<SystemCallFiltering>
)

<AccessMediationEvent>  (
    CLOSED {
       (  $<AccessMediationEvent_tes> (  &<AccessControlEvent_tes> ;
