    skos:editorialNote "Threat actor is trying to establish resources they can use to support operations." ;
    skos:exactMatch d3f:ST0002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ST0003 a owl:Class ;
    rdfs:label "ST0003" ;
    d3f:display-order "3" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Initial Access" ;
    rdfs:seeAlso <https://sparta.aerospace.org/tactic/ST0003> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SPARTATactic ],
        d3f:OffensiveTactic,
        d3f:SPARTATacticEnum,
        linkml:PermissibleValue ;
