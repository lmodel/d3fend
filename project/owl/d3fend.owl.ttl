d3f:HardwareComponentInventory a owl:Class ;
    rdfs:label "HardwareComponentInventory" ;
    d3f:d3fend-id "D3-HCI" ;
    d3f:kb-article "## How it works Administrators collect information on hardware devices such as peripherals, NICs, processors, and memory devices that are components of the computers in their architecture using a variety of administrative and management tools that query for this information. In some cases, where su" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Hardware Component Discovery" ;
    dcterms:title "Hardware Component Inventory" ;
    rdfs:subClassOf d3f:AssetInventory ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DiscoveryTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:T1052,
        d3f:T1056,
        d3f:T1195 ;
    skos:definition "Hardware component inventorying identifies and records the hardware items in the organization's architecture." ;
    skos:exactMatch d3f:HardwareComponentInventory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1025,
        mitre-attack:T1052.001,
        mitre-attack:T1056.001,
        mitre-attack:T1091,
        mitre-attack:T1092,
        mitre-attack:T1111,
        mitre-attack:T1123,
        mitre-attack:T1125,
        mitre-attack:T1195.003,
        mitre-attack:T1200,
        mitre-attack:T1619 .

d3f:HardwareDeviceBindEvent a owl:Class ;
    rdfs:label "HardwareDeviceBindEvent" ;
    dcterms:title "Hardware Device Bind Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event where a device is logically bound to a system or process, typically for exclusive use or integration with specific software components." ;
    skos:exactMatch d3f:HardwareDeviceBindEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceConnectionEvent a owl:Class ;
    rdfs:label "HardwareDeviceConnectionEvent" ;
    dcterms:title "Hardware Device Connection Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event representing the physical or logical attachment of a device to a system, enabling its operational functionality." ;
    skos:exactMatch d3f:HardwareDeviceConnectionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceDisabledEvent a owl:Class ;
    rdfs:label "HardwareDeviceDisabledEvent" ;
    dcterms:title "Hardware Device Disabled Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event where a device transitions to an inactive or unavailable state, often due to deactivation, failure, or maintenance." ;
    skos:exactMatch d3f:HardwareDeviceDisabledEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceDisconnectionEvent a owl:Class ;
    rdfs:label "HardwareDeviceDisconnectionEvent" ;
    dcterms:title "Hardware Device Disconnection Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event representing the removal of a device from a system, ceasing its operational functionality or availability." ;
    skos:exactMatch d3f:HardwareDeviceDisconnectionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceEnabledEvent a owl:Class ;
    rdfs:label "HardwareDeviceEnabledEvent" ;
    dcterms:title "Hardware Device Enabled Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event where a device becomes operational and available for use, typically following initialization, activation, or repair." ;
    skos:exactMatch d3f:HardwareDeviceEnabledEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceMoveEvent a owl:Class ;
    rdfs:label "HardwareDeviceMoveEvent" ;
    dcterms:title "Hardware Device Move Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event where a device is relocated or reassigned within a system or network, potentially affecting its operational scope or connectivity." ;
    skos:exactMatch d3f:HardwareDeviceMoveEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceUnbindEvent a owl:Class ;
    rdfs:label "HardwareDeviceUnbindEvent" ;
    dcterms:title "Hardware Device Unbind Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event where a device is logically unbound from a system or process, releasing it from exclusive use or integration." ;
    skos:exactMatch d3f:HardwareDeviceUnbindEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceUpdateEvent a owl:Class ;
    rdfs:label "HardwareDeviceUpdateEvent" ;
    dcterms:title "Hardware Device Update Event" ;
    rdfs:subClassOf d3f:HardwareDeviceStateEvent ;
    skos:definition "An event capturing updates or changes to a device's configuration, properties, or state, including firmware updates, reconfigurations, or optimizations." ;
    skos:exactMatch d3f:HardwareDeviceUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareTimerConfigurationEvent a owl:Class ;
    rdfs:label "HardwareTimerConfigurationEvent" ;
    dcterms:title "Hardware Timer Configuration Event" ;
    rdfs:subClassOf d3f:HardwareTimerEvent ;
    skos:definition "An event in which a hardware timer's registers or operational parameters are programmed or modified." ;
    skos:exactMatch d3f:HardwareTimerConfigurationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareTimerDeviceDriver a owl:Class ;
    rdfs:label "HardwareTimerDeviceDriver" ;
    dcterms:title "Hardware Timer Device Driver" ;
    rdfs:seeAlso <https://www.intel.com/content/www/us/en/docs/programmable/743810/25-1/timer-device-drivers.html> ;
    rdfs:subClassOf d3f:HardwareDriver ;
    skos:definition "A device driver for a hardware timer." ;
    skos:exactMatch d3f:HardwareTimerDeviceDriver ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareTimerInterruptEvent a owl:Class ;
    rdfs:label "HardwareTimerInterruptEvent" ;
    dcterms:title "Hardware Timer Interrupt Event" ;
    rdfs:subClassOf d3f:HardwareTimerEvent ;
    skos:definition "An event in which a hardware timer generates an interrupt signal upon expiration or interval completion." ;
    skos:exactMatch d3f:HardwareTimerInterruptEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareWatchdogTimer a owl:Class ;
    rdfs:label "HardwareWatchdogTimer" ;
    dcterms:title "Hardware Watchdog Timer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:WatchdogTimer ],
        d3f:HardwareTimer ;
    skos:definition "A hardware watchdog timer is a watchdog timer implemented using electronic components." ;
    skos:exactMatch d3f:HardwareWatchdogTimer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HarmonicMean a owl:Class ;
    rdfs:label "HarmonicMean" ;
    d3f:d3fend-id "D3A-HM" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Harmonic Mean" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "The reciprocal of the arithmetic mean of the reciprocals of the data values. This measure too is valid only for data that are measured absolutely on a strictly positive scale." ;
    skos:exactMatch d3f:HarmonicMean ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HeapSegment a owl:Class ;
    rdfs:label "HeapSegment" ;
    dcterms:title "Heap Segment" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Memory_management#HEAP> ;
    rdfs:subClassOf d3f:ProcessSegment ;
    skos:definition "The heap segment (or free store) is a large pool of memory from which dynamic memory requests of a process are allocated and satisfied." ;
    skos:exactMatch d3f:HeapSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HierarchicalDomainDenylisting a owl:Class ;
    rdfs:label "HierarchicalDomainDenylisting" ;
    d3f:d3fend-id "D3-HDDL" ;
    d3f:kb-article "## How it works This technique is used to block DNS queries from related domains and subdomains that are unauthorized. Hierarchical domain blacklisting considers the blacklisting of second level domains and additional sub-domains and specific hosts for a given query value. A denylist is maintained" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Hierarchical Domain Blacklisting" ;
    dcterms:title "Hierarchical Domain Denylisting" ;
    rdfs:subClassOf d3f:ForwardResolutionDomainDenylisting ;
    skos:definition "Blocking the resolution of any subdomain of a specified domain name." ;
    skos:exactMatch d3f:HierarchicalDomainDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Histogramming a owl:Class ;
    rdfs:label "Histogramming" ;
    rdfs:subClassOf d3f:Summarizing ;
    skos:exactMatch d3f:Histogramming ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HomoglyphDenylisting a owl:Class ;
    rdfs:label "HomoglyphDenylisting" ;
    d3f:d3fend-id "D3-HDL" ;
    d3f:kb-article "## How it works Homoglyph domain blacklisting considers the domain and subdomain structure of a lookup and compares the named components to blacklisted named components. The blacklisted named components are typically crafted modifications of known good domains, e.g., gooogle.com versus google.com." ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Homoglyph Blacklisting" ;
    dcterms:title "Homoglyph Denylisting" ;
    rdfs:subClassOf d3f:ForwardResolutionDomainDenylisting ;
    skos:definition "Blocking DNS queries that are deceptively similar to legitimate domain names." ;
    skos:exactMatch d3f:HomoglyphDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HomoglyphDetection a owl:Class ;
    rdfs:label "HomoglyphDetection" ;
    d3f:d3fend-id "D3-HD" ;
    d3f:kb-article "## How it works A homoglyph, in this context, is a deceptive string or word which looks like a trusted word, but is composed of different characters, for example: goooogle.com versus google.com. This is commonly found in phishing and typo squatting attacks where a human exploiting through a social e" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Homoglyph Detection" ;
    rdfs:subClassOf d3f:IdentifierAnalysis ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:T1114,
        d3f:T1204,
        d3f:T1566 ;
    skos:definition "Comparing strings using a variety of techniques to determine if a deceptive or malicious string is being presented to a user." ;
    skos:exactMatch d3f:HomoglyphDetection ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.001,
        mitre-attack:T1189,
        mitre-attack:T1204.001,
        mitre-attack:T1534,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002,
        mitre-attack:T1566.003 .

d3f:HostConfigurationSensor a owl:Class ;
    rdfs:label "HostConfigurationSensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Host Configuration Sensor" ;
    rdfs:subClassOf d3f:EndpointSensor ;
    skos:definition "Collects the configuration data on an endpoint." ;
    skos:exactMatch d3f:HostConfigurationSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HostGroup a owl:Class ;
    rdfs:label "HostGroup" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Host Group" ;
    rdfs:subClassOf d3f:AccessControlGroup ;
    skos:definition "A collection of Hosts used to allow operations such as access control to be applied to the entire group." ;
    skos:exactMatch d3f:HostGroup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HostReboot a owl:Class ;
    rdfs:label "HostReboot" ;
    d3f:d3fend-id "D3-HR" ;
    d3f:kb-article "## How It Works Host reboot can either be initiated in the physical presence of the device using the power functions or remotely using the provided user interface or an installed EDR agent (with the available function). This process may allow for the removal of specific types of malware, such as fi" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Host Reboot" ;
    rdfs:subClassOf d3f:HostShutdown ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1505,
        d3f:T1546,
        d3f:T1562 ;
    skos:definition "Initiating a host's reboot sequence to terminate all running processes." ;
    skos:exactMatch d3f:HostReboot ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1033,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1212,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1546.007,
        mitre-attack:T1550,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:HumanInputDeviceFirmware a owl:Class ;
    rdfs:label "HumanInputDeviceFirmware" ;
    dcterms:title "Human Input Device Firmware" ;
    rdfs:seeAlso d3f:Firmware,
        dbr:Human_interface_device ;
    rdfs:subClassOf d3f:PeripheralFirmware ;
    skos:definition "Firmware that is installed on an HCI device such as a mouse or keyboard." ;
    skos:exactMatch d3f:HumanInputDeviceFirmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ID3 a owl:Class ;
    rdfs:label "ID3" ;
    d3f:d3fend-id "D3A-ID3" ;
    d3f:kb-article "## Addtional Consiterations ID3 is the basis of C4.5, and is best used in natural language processing. ## References Decision Trees for Classification: ID3 Algorithm Explained. Towards Data Science. [Link](https://towardsdatascience.com/decision-trees-for-classification-id3-algorithm-explained-89df" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DecisionTree ;
    skos:definition "ID3 stands for Iterative Dichotomiser 3 and is named such because the algorithm iteratively (repeatedly) dichotomizes(divides) features into two or more groups at each step." ;
    skos:exactMatch d3f:ID3 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IOPortRestriction a owl:Class ;
    rdfs:label "IOPortRestriction" ;
    d3f:d3fend-id "D3-IOPR" ;
    d3f:kb-article "## How It works Software-based restriction uses agent software installed on a computer system. The agent software monitors all IO port system traffic. The agent software is configurable to limit the use of certain devices connected to IO ports. The restriction software can also be configured to lim" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "IO Port Restriction" ;
    rdfs:subClassOf d3f:AccessMediation ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:T1052,
        d3f:T1056 ;
    skos:definition "Limiting access to computer input/output (IO) ports to restrict unauthorized devices." ;
    skos:exactMatch d3f:IOPortRestriction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1025,
        mitre-attack:T1052.001,
        mitre-attack:T1056.001,
        mitre-attack:T1091,
        mitre-attack:T1092,
        mitre-attack:T1123,
        mitre-attack:T1125 .

d3f:IPAddress a owl:Class ;
    rdfs:label "IPAddress" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "IP Address" ;
    rdfs:seeAlso dbr:IP_address ;
    rdfs:subClassOf d3f:Identifier ;
    skos:closeMatch stix:Ipv4Addr ;
    skos:definition "An Internet Protocol address (IP address) is a numerical label assigned to each device connected to a computer network that uses the Internet Protocol for communication.An IP address serves two main functions: host or network interface identification and location addressing. Internet Protocol version 4 (IPv4) defines an IP address as a 32-bit number. However, because of the growth of the Internet and the depletion of available IPv4 addresses, a new version of IP (IPv6), using 128 bits for the IP address, was standardized in 1998. IPv6 deployment has been ongoing since the mid-2000s." ;
    skos:exactMatch d3f:IPAddress,
        unified_cyber_ontology:IPAddress ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IPCTrafficAnalysis a owl:Class ;
    rdfs:label "IPCTrafficAnalysis" ;
    d3f:d3fend-id "D3-IPCTA" ;
    d3f:kb-article "## How it works Inter process communication enables applications or threads to share data. This can involve one or more computers. Monitoring IPC in your environment can reveal abnormal or malicious activity. IPC can occur within a single computer or between multiple computers remotely through netwo" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "IPC Analysis" ;
    dcterms:title "IPC Traffic Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:PersistenceTechnique ;
    skos:definition "Analyzing standard inter process communication (IPC) protocols to detect deviations from normal protocol activity." ;
    skos:exactMatch d3f:IPCTrafficAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1197 .

d3f:IPPhone a owl:Class ;
    rdfs:label "IPPhone" ;
    dcterms:title "IP Phone" ;
    rdfs:seeAlso dbr:VoIP_phone ;
    rdfs:subClassOf d3f:PersonalComputer ;
    skos:altLabel "VoIP Phone" ;
    skos:definition "A VoIP phone or IP phone uses voice over IP technologies for placing and transmitting telephone calls over an IP network, such as the Internet, instead of the traditional public switched telephone network (PSTN). Digital IP-based telephone service uses control protocols such as the Session Initiation Protocol (SIP), Skinny Client Control Protocol (SCCP) or various other proprietary protocols." ;
    skos:exactMatch d3f:IPPhone ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IPReputationAnalysis a owl:Class ;
    rdfs:label "IPReputationAnalysis" ;
    d3f:d3fend-id "D3-IPRA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "IP Reputation Analysis" ;
    rdfs:subClassOf d3f:IdentifierReputationAnalysis ;
    skos:definition "Analyzing the reputation of an IP address." ;
    skos:exactMatch d3f:IPReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IdentifierActivityAnalysis a owl:Class ;
    rdfs:label "IdentifierActivityAnalysis" ;
    d3f:d3fend-id "D3-IAA" ;
    d3f:kb-article "## How it works Identifier activity analysis is the process of taking identifiers--typically known malicious identifiers--and determining the artifacts that have interacted with those identifiers. There are many open and closed source repositories of identifiers that represent indicators of compro" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Identifier Activity Analysis" ;
    rdfs:subClassOf d3f:IdentifierAnalysis ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:T1204,
        d3f:T1566 ;
    skos:definition "Taking known malicious identifiers and determining if they are present in a system." ;
    skos:exactMatch d3f:IdentifierActivityAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1189,
        mitre-attack:T1204.001,
        mitre-attack:T1566.002,
        mitre-attack:T1566.003 .

d3f:ImportLibraryFunction a owl:Class ;
    rdfs:label "ImportLibraryFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Import Library Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Loads an external software library to enable the invocations of its methods." ;
    skos:exactMatch d3f:ImportLibraryFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundInternetDNSResponseTraffic a owl:Class ;
    rdfs:label "InboundInternetDNSResponseTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inbound Internet DNS Response Traffic" ;
    rdfs:seeAlso <https://schema.ocsf.io/objects/dns_answer> ;
    rdfs:subClassOf d3f:InboundInternetNetworkTraffic ;
    skos:definition "Inbound internet DNS response traffic is DNS response traffic from a host outside a given network initiated on an incoming connection to a host inside that network." ;
    skos:exactMatch d3f:InboundInternetDNSResponseTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundInternetEncryptedWebTraffic a owl:Class ;
    rdfs:label "InboundInternetEncryptedWebTraffic" ;
    dcterms:title "Inbound Internet Encrypted Web Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InboundInternetWebTraffic ],
        d3f:InboundInternetEncryptedTraffic ;
    skos:definition "Inbound internet web traffic is network traffic that is: (a) on an incoming connection initiated from a host outside the network to a host within a network, and (b) using a standard web encryption protocol." ;
    skos:exactMatch d3f:InboundInternetEncryptedWebTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundInternetMailTraffic a owl:Class ;
    rdfs:label "InboundInternetMailTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inbound Internet Mail Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InboundNetworkTraffic ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:MailNetworkTraffic ],
        d3f:InboundInternetNetworkTraffic ;
    skos:definition "Inbound internet mail traffic is network traffic that is: (a) coming from a host outside a given network via an incoming connection to a host inside that same network, and (b) using a standard protocol for email." ;
    skos:exactMatch d3f:InboundInternetMailTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundSessionVolumeAnalysis a owl:Class ;
    rdfs:label "InboundSessionVolumeAnalysis" ;
    d3f:d3fend-id "D3-ISVA" ;
    d3f:kb-article "## How it works Network appliances are configured to alert on certain packets that typically are involved in DoS attacks. Typical packets include ICMP packets and SYN requests that are commonly used to flood networks. A sampling period is used to define a time window in which collected counts of the" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inbound Session Volume Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:T1498,
        d3f:T1499,
        d3f:T1566 ;
    skos:definition "Analyzing inbound network session or connection attempt volume." ;
    skos:exactMatch d3f:InboundSessionVolumeAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1190,
        mitre-attack:T1498.001,
        mitre-attack:T1498.002,
        mitre-attack:T1499.002,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002 .

d3f:IndirectBranchCallAnalysis a owl:Class ;
    rdfs:label "IndirectBranchCallAnalysis" ;
    d3f:d3fend-id "D3-IBCA" ;
    d3f:kb-article "## How it works This technique is used to detect an attacker attempting to exploit and execute code on a target system's call stack using return-oriented programming (ROP). Modern processors that have the ability to maintain a list of the branching calls, e.g., Intel's Last Branch Recording (LBR)," ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Indirect Branch Call Analysis" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:definition "Analyzing vendor specific branch call recording in order to detect ROP style attacks." ;
    skos:exactMatch d3f:IndirectBranchCallAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InputDeviceAnalysis a owl:Class ;
    rdfs:label "InputDeviceAnalysis" ;
    d3f:d3fend-id "D3-IDA" ;
    d3f:kb-article "## How it works Input Device Hardening techniques filter certain commands, or disable related operating system functionality. ### Analytics All of these values can be analyzed and compared to a baseline: * Amount of input * Duration of a single input * Durations between inputs * Value of input" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Input Device Analysis" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:T1056 ;
    skos:definition "Operating system level mechanisms to prevent abusive input device exploitation." ;
    skos:exactMatch d3f:InputDeviceAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1056.001,
        mitre-attack:T1123,
        mitre-attack:T1125 .

d3f:InputDeviceEvent a owl:Class ;
    rdfs:label "InputDeviceEvent" ;
    dcterms:title "Input Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event involving human-machine interface devices, such as keyboards, mice, or touchscreens." ;
    skos:exactMatch d3f:InputDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InstantMessagingClient a owl:Class ;
    rdfs:label "InstantMessagingClient" ;
    dcterms:title "Instant Messaging Client" ;
    rdfs:seeAlso <https://dbpedia.org/wiki/Instant_messaging> ;
    rdfs:subClassOf d3f:CollaborativeSoftware ;
    skos:definition "Client software used to engage in Instant Messaging, a type of online chat that offers real-time text transmission over the Internet. A LAN messenger operates in a similar way over a local area network. Short messages are typically transmitted between two parties, when each user chooses to complete a thought and select \"send\". Some IM applications can use push technology to provide real-time text, which transmits messages character by character, as they are composed. More advanced instant messaging can add file transfer, clickable hyperlinks, Voice over IP, or video chat." ;
    skos:exactMatch d3f:InstantMessagingClient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntegerRangeValidation a owl:Class ;
    rdfs:label "IntegerRangeValidation" ;
    d3f:d3fend-id "D3-IRV" ;
    d3f:kb-article "## How it Works Integer Range Validation can be done by programmatically checking the value of an integer before or after an operation to determine if the resulting value will be valid. Checking the value of an integer to ensure it is in a valid range helps prevent integer overflow, wraparound, and" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Integer Range Validation" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:definition "Ensuring that an integer is within a valid range." ;
    skos:exactMatch d3f:IntegerRangeValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntegratedHoneynet a owl:Class ;
    rdfs:label "IntegratedHoneynet" ;
    d3f:d3fend-id "D3-IHN" ;
    d3f:kb-article "## How it works Integrated honeynets use full production environments connected to the enterprise network, that utilize computing resources or software that attract attackers, and allow full interaction and access that provides a complete view of an attack. ## Considerations An attacker with contro" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Integrated Honeynet" ;
    rdfs:subClassOf d3f:DecoyEnvironment ;
    skos:definition "The practice of setting decoys in a production environment to entice interaction from attackers." ;
    skos:exactMatch d3f:IntegratedHoneynet ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntegrationTestExecutionTool a owl:Class ;
    rdfs:label "IntegrationTestExecutionTool" ;
    dcterms:title "Integration Test Execution Tool" ;
    rdfs:seeAlso dbr:Integration_testing ;
    rdfs:subClassOf d3f:TestExecutionTool ;
    skos:definition "An integration test execution tool automatically performs integration testing.  Integration testing (sometimes called integration and testing, abbreviated I&T) is the phase in software testing in which individual software modules are combined and tested as a group." ;
    skos:exactMatch d3f:IntegrationTestExecutionTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetArticleReference a owl:Class ;
    rdfs:label "InternetArticleReference" ;
    d3f:pref-label "Internet Article" ;
    dcterms:title "Internet Article Reference" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:altLabel "Internet Blog Reference" ;
    skos:exactMatch d3f:InternetArticleReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetBasedAttacker a owl:Class ;
    rdfs:label "InternetBasedAttacker" ;
    dcterms:title "Internet-based Attacker" ;
    rdfs:subClassOf d3f:RemoteAttacker ;
    skos:definition "A remote attacker who leverages the internet to conduct attacks, such as through phishing, malware, or direct network attacks." ;
    skos:exactMatch d3f:InternetBasedAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetDNSLookup a owl:Class ;
    rdfs:label "InternetDNSLookup" ;
    dcterms:title "Internet DNS Lookup" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf d3f:DNSLookup ;
    skos:definition "An internet Domain Name System (DNS) lookup is a DNS lookup made from a host on a network that is resolved after querying a DNS name server hosted on a different network." ;
    skos:exactMatch d3f:InternetDNSLookup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetFileTransferTraffic a owl:Class ;
    rdfs:label "InternetFileTransferTraffic" ;
    dcterms:title "Internet File Transfer Traffic" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InternetNetworkTraffic ],
        d3f:FileTransferNetworkTraffic ;
    skos:definition "Internet file transfer network traffic is network traffic related to file transfers between network nodes that crosses a boundary between networks. This includes only network traffic conforming to standard file transfer protocols, not custom transfer protocols." ;
    skos:exactMatch d3f:InternetFileTransferTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetNetwork a owl:Class ;
    rdfs:label "InternetNetwork" ;
    dcterms:title "Internet Network" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf d3f:Network ;
    skos:altLabel "Interconnected Network",
        "Internet",
        "Internetwork" ;
    skos:definition "A network of multiple, connected networks. Internetworking is the practice of connecting a computer network with other networks through the use of gateways that provide a common method of routing information packets between the networks. The resulting system of interconnected networks are called an internetwork, or simply an internet. Internetworking is a combination of the words inter (\"between\") and networking; not internet-working or international-network." ;
    skos:exactMatch d3f:InternetNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetPersona a owl:Class ;
    rdfs:label "InternetPersona" ;
    dcterms:title "Internet Persona" ;
    rdfs:seeAlso dbr:Online_identity,
        <https://en.wikipedia.org/wiki/Online_identity> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Online Identity",
        "Online Persona",
        "Online Personality" ;
    skos:definition "A social identity that an Internet user establishes in online communities and websites. It may also be an actively constructed presentation of oneself." ;
    skos:exactMatch d3f:InternetPersona ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InterprocessCommunication a owl:Class ;
    rdfs:label "InterprocessCommunication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Interprocess Communication" ;
    rdfs:seeAlso dbr:Inter-process_communication ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In computer science, inter-process communication or inter-process communication (IPC) refers specifically to the mechanisms an operating system provides to allow processes it manages to share data. Typically, applications can use IPC categorized as clients and servers, where the client requests data and the server responds to client requests. Many applications are both clients and servers, as commonly seen in distributed computing. Methods for achieving IPC are divided into categories which vary based on software requirements, such as performance and modularity requirements, and system circumstances, such as network bandwidth and latency." ;
    skos:exactMatch d3f:InterprocessCommunication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InterquartileRange a owl:Class ;
    rdfs:label "InterquartileRange" ;
    d3f:d3fend-id "D3A-IR" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Interquartile range. [Link](https://en.wikipedia.org/wiki/Interquartile_range)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "IQR" ;
    dcterms:title "Interquartile Range" ;
    rdfs:subClassOf d3f:Variability ;
    skos:definition "The interquartile range (IQR) is a measure of statistical dispersion, which is the spread of the data and is defined as the difference between the 75th and 25th percentiles of the data." ;
    skos:exactMatch d3f:InterquartileRange ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntervalEstimation a owl:Class ;
    rdfs:label "IntervalEstimation" ;
    d3f:d3fend-id "D3A-IE" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Interval estimation. [Link](https://en.wikipedia.org/wiki/Interval_estimation)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Interval Estimation" ;
    rdfs:subClassOf d3f:Estimation ;
    skos:definition "Interval estimation is the use of sample data to estimate an interval of possible values of a parameter of interest." ;
    skos:exactMatch d3f:IntervalEstimation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetAdministrativeNetworkTraffic a owl:Class ;
    rdfs:label "IntranetAdministrativeNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet Administrative Network Traffic" ;
    rdfs:seeAlso dbr:Intranet ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:IntranetNetworkTraffic ],
        d3f:AdministrativeNetworkTraffic ;
    skos:definition "Intranet administrative network traffic is administrative network traffic that does not cross a given network's boundaries and uses a standard administrative protocol." ;
    skos:exactMatch d3f:IntranetAdministrativeNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetDNSLookup a owl:Class ;
    rdfs:label "IntranetDNSLookup" ;
    dcterms:title "Intranet DNS Lookup" ;
    rdfs:seeAlso dbr:Intranet ;
    rdfs:subClassOf d3f:DNSLookup ;
    skos:definition "An Intranet Domain Name System (DNS) lookup is a DNS lookup made from a host on a network that is resolved after querying a DNS name server hosted on a that same network." ;
    skos:exactMatch d3f:IntranetDNSLookup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetFileTransferTraffic a owl:Class ;
    rdfs:label "IntranetFileTransferTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet File Transfer Traffic" ;
    rdfs:seeAlso dbr:File_transfer,
        dbr:Intranet ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:IntranetNetworkTraffic ],
        d3f:FileTransferNetworkTraffic ;
    skos:definition "Intranet file transfer traffic is file transfer traffic that does not cross a given network's boundaries and uses a standard file transfer protocol." ;
    skos:exactMatch d3f:IntranetFileTransferTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetIPCNetworkTraffic a owl:Class ;
    rdfs:label "IntranetIPCNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet IPC Network Traffic" ;
    rdfs:seeAlso dbr:Inter-process_communication,
        dbr:Intranet ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:IntranetNetworkTraffic ],
        d3f:IPCNetworkTraffic ;
    skos:definition "Intranet IPC network traffic is network traffic that does not cross a given network's boundaries and uses a standard inter-process communication (IPC) networking protocol." ;
    skos:exactMatch d3f:IntranetIPCNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetMulticastNetworkTraffic a owl:Class ;
    rdfs:label "IntranetMulticastNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet Multicast Network Traffic" ;
    rdfs:seeAlso dbr:Multicast ;
    rdfs:subClassOf d3f:IntranetNetworkTraffic ;
    skos:definition "Intranet IPC network traffic is multicast network traffic that does not cross a given network's boundaries." ;
    skos:exactMatch d3f:IntranetMulticastNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetRPCNetworkTraffic a owl:Class ;
    rdfs:label "IntranetRPCNetworkTraffic" ;
    dcterms:title "Intranet RPC Network Traffic" ;
    rdfs:seeAlso dbr:Intranet,
        dbr:Remote_procedure_call ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:RPCNetworkTraffic ],
        d3f:IntranetNetworkTraffic ;
    skos:definition "Intranet RPC network traffic is network traffic that does not cross a given network's boundaries and uses a standard remote procedure call (e.g., RFC 1050) protocol." ;
    skos:exactMatch d3f:IntranetRPCNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetWebNetworkTraffic a owl:Class ;
    rdfs:label "IntranetWebNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet Web Network Traffic" ;
    rdfs:seeAlso dbr:Intranet ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:WebNetworkTraffic ],
        d3f:IntranetNetworkTraffic ;
    skos:definition "Intranet web network traffic is network traffic that does not cross a given network's boundaries and uses a standard web protocol." ;
    skos:exactMatch d3f:IntranetWebNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntrusionPreventionSystem a owl:Class ;
    rdfs:label "IntrusionPreventionSystem" ;
    dcterms:title "Intrusion Prevention System" ;
    rdfs:seeAlso dbr:Intrusion_detection_system,
        <http://dbpedia.org/resource/Intrusion_detection_system#Intrusion_prevention> ;
    rdfs:subClassOf d3f:IntrusionDetectionSystem ;
    skos:altLabel "IDPS",
        "IPS",
        "Intrusion Detection and Prevention System" ;
    skos:definition """Intrusion prevention systems (IPS), also known as intrusion detection and prevention systems (IDPS), are network security appliances that monitor network or system activities for malicious activity. The main functions of intrusion prevention systems are to identify malicious activity, log information about this activity, report it and attempt to block or stop it.

Intrusion prevention systems are considered extensions of intrusion detection systems because they both monitor network traffic and/or system activities for malicious activity. The main differences are, unlike intrusion detection systems, intrusion prevention systems are placed in-line and are able to actively prevent or block intrusions that are detected. IPS can take such actions as sending an alarm, dropping detected malicious packets, resetting a connection or blocking traffic from the offending IP address. An IPS also can correct cyclic redundancy check (CRC) errors, defragment packet streams, mitigate TCP sequencing issues, and clean up unwanted transport and network layer options.""" ;
    skos:exactMatch d3f:IntrusionPreventionSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IsolationEvent a owl:Class ;
    rdfs:label "IsolationEvent" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Isolation Event" ;
    rdfs:subClassOf d3f:SecurityEvent ;
    skos:definition "An event involving actions to create logical or physical barriers that isolate compromised components, preventing adversary movement and reducing attack surfaces." ;
    skos:exactMatch d3f:IsolationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:JavaArchive a owl:Class ;
    rdfs:label "JavaArchive" ;
    dcterms:title "Java Archive" ;
    rdfs:seeAlso <https://dbpedia.org/page/JAR_(file_format)> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SoftwarePackage ],
        d3f:ArchiveFile ;
    skos:definition "A JAR (Java ARchive) is a package file format typically used to aggregate many Java class files and associated metadata and resources (text, images, etc.) into one file for distribution." ;
    skos:exactMatch d3f:JavaArchive ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:JavaScriptBlob a owl:Class ;
    rdfs:label "JavaScriptBlob" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "JavaScript Blob" ;
    rdfs:subClassOf d3f:BinaryLargeObject ;
    skos:definition "A JavaScript Blob is a Blob that was created by a JavaScript Blob() constructor call or equivalent function." ;
    skos:exactMatch d3f:JavaScriptBlob ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:JobFunctionAccessPatternAnalysis a owl:Class ;
    rdfs:label "JobFunctionAccessPatternAnalysis" ;
    d3f:d3fend-id "D3-JFAPA" ;
    d3f:kb-article "## How it works Peer group analysis identifies functionally similar groups of actors (users or resources) based on categorizations such as job title, organizational hierarchy, or other attribute that indicates similarity of job function. Current user access activity is then compared to the appropria" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Job Function Access Pattern Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Detecting anomalies in user access patterns by comparing user access activity to behavioral profiles that categorize users by role such as job title, function, department." ;
    skos:exactMatch d3f:JobFunctionAccessPatternAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:JobSchedule a owl:Class ;
    rdfs:label "JobSchedule" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Task Schedule" ;
    dcterms:title "Job Schedule" ;
    rdfs:seeAlso dbr:Cron,
        dbr:Windows_Task_Scheduler ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "A job schedule contains specification of tasks to be executed at particular times or time intervals.  The schedule is a plan that enacted by a task scheduling process. In Windows, the schedule can be accessed at 'C:\\Windows\\System32\\Tasks' or in the registry. In Linux, the schedule is located at '/etc/crontab'" ;
    skos:exactMatch d3f:JobSchedule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:JobSchedulerSoftware a owl:Class ;
    rdfs:label "JobSchedulerSoftware" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Task Scheduler Software" ;
    dcterms:title "Job Scheduler Software" ;
    rdfs:seeAlso d3f:ScheduledJob,
        dbr:Cron,
        dbr:Windows_Task_Scheduler ;
    rdfs:subClassOf d3f:SystemServiceSoftware ;
    skos:definition "A job scheduler software is operating system software that when run executes scheduled tasks (time-scheduling in the sense of wall clock time; not operating system scheduling of processes for multitasking). Processes running such software are task scheduler processes. In Windows, Scheduled Tasks are created and managed by the Task Scheduler. In Unix-like OSes, the `cron` utitility serves a similar role." ;
    skos:exactMatch d3f:JobSchedulerSoftware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KendallsRankCorrelationCoefficient a owl:Class ;
    rdfs:label "KendallsRankCorrelationCoefficient" ;
    d3f:d3fend-id "D3A-KRCC" ;
    d3f:kb-article "## References 1. Wolfram Research. (2012). KendallTau. Wolfram Language function. [Link](https://reference.wolfram.com/language/ref/KendallTau.html) 1. Kendall's Tau. (2023, May 23). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Kendall_rank_correlation_coefficient]\"\"\"," ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Kendall's Tau Coefficient" ;
    dcterms:title "Kendall's Rank Correlation Coefficient" ;
    rdfs:seeAlso <https://reference.wolfram.com/language/ref/KendallTau.html> ;
    rdfs:subClassOf d3f:RankCorrelationCoefficient ;
    skos:definition "Kendall's $\\\\tau$ between and is given by $(n_c - n_d) / \\\\sqrt((n_c+n_d+n_x)(n_c+n_d+n_y)$, where is the number of concordant pairs of observations, is the number of discordant pairs, is the number of ties involving only the variable, and is the number of ties involving only the variable.\" ;" ;
    skos:exactMatch d3f:KendallsRankCorrelationCoefficient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KerberosTicketGrantingServiceTicket a owl:Class ;
    rdfs:label "KerberosTicketGrantingServiceTicket" ;
    dcterms:title "Kerberos Ticket Granting Service Ticket" ;
    rdfs:subClassOf d3f:KerberosTicket ;
    skos:altLabel "TGS Ticket" ;
    skos:definition "A Kerberos ticket-granting service (TGS) ticket is given in response to requesting a Kerberos TGS request." ;
    skos:exactMatch d3f:KerberosTicketGrantingServiceTicket ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KerberosTicketGrantingTicket a owl:Class ;
    rdfs:label "KerberosTicketGrantingTicket" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kerberos Ticket Granting Ticket" ;
    rdfs:seeAlso dbr:Ticket_Granting_Ticket ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:TicketGrantingTicket ],
        d3f:KerberosTicket ;
    skos:definition "A ticket granting ticket issued by a Kerberos system; that is, a ticket that grants a user domain admin access." ;
    skos:exactMatch d3f:KerberosTicketGrantingTicket ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KerberosTicketGrantingTicketAccount a owl:Class ;
    rdfs:label "KerberosTicketGrantingTicketAccount" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "krbtgt" ;
    dcterms:title "Kerberos Ticket Granting Ticket Account" ;
    rdfs:seeAlso <https://blog.quest.com/what-is-krbtgt-and-why-should-you-change-the-password/> ;
    rdfs:subClassOf d3f:ServiceAccount ;
    skos:definition "KRBTGT is an account used by Key Distribution Center (KDC) service to issue Ticket Granting Tickets (TGTs) as part of the Kerberos authentication protocol." ;
    skos:exactMatch d3f:KerberosTicketGrantingTicketAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelAPISensor a owl:Class ;
    rdfs:label "KernelAPISensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kernel API Sensor" ;
    rdfs:subClassOf d3f:EndpointSensor ;
    skos:definition "Monitors system calls (operating system api functions)." ;
    skos:exactMatch d3f:KernelAPISensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelModule a owl:Class ;
    rdfs:label "KernelModule" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kernel Module" ;
    rdfs:seeAlso dbr:Loadable_kernel_module,
        <https://schema.ocsf.io/objects/kernel_driver> ;
    rdfs:subClassOf d3f:ObjectFile ;
    skos:altLabel "LKM",
        "Loadable Kernel Module" ;
    skos:definition """A loadable kernel module (LKM) is an object file that contains code to extend the running kernel, or so-called base kernel, of an operating system. LKMs are typically used to add support for new hardware (as device drivers) and/or filesystems, or for adding system calls. When the functionality provided by a LKM is no longer required, it can be unloaded in order to free memory and other resources.

Most current Unix-like systems and Microsoft Windows support loadable kernel modules, although they might use a different name for them, such as kernel loadable module (kld) in FreeBSD, kernel extension (kext) in macOS,[1] kernel extension module in AIX, kernel-mode driver in Windows NT[2] and downloadable kernel module (DKM) in VxWorks. They are also known as kernel loadable modules (or KLM), and simply as kernel modules (KMOD).""" ;
    skos:exactMatch d3f:KernelModule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelModuleLoadEvent a owl:Class ;
    rdfs:label "KernelModuleLoadEvent" ;
    dcterms:title "Kernel Module Load Event" ;
    rdfs:subClassOf d3f:KernelModuleEvent ;
    skos:definition "An event representing the loading of a kernel module, such as a device driver or dynamically linked extension, into the operating system kernel to extend or modify its capabilities." ;
    skos:exactMatch d3f:KernelModuleLoadEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelModuleUnloadEvent a owl:Class ;
    rdfs:label "KernelModuleUnloadEvent" ;
    dcterms:title "Kernel Module Unload Event" ;
    rdfs:subClassOf d3f:KernelModuleEvent ;
    skos:definition "An event representing the removal of a kernel module from the operating system kernel, deallocating resources and potentially altering system functionality." ;
    skos:exactMatch d3f:KernelModuleUnloadEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelProcessTable a owl:Class ;
    rdfs:label "KernelProcessTable" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kernel Process Table" ;
    rdfs:seeAlso dbr:Process_\(computing\),
        <https://encyclopedia2.thefreedictionary.com/process+table>,
        <https://www.geeksforgeeks.org/process-table-and-process-control-block-pcb/> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A data structure in the kernel which is a table containing all of the information that must be saved when the CPU switches from running one process to another in a multitasking system. It allows the operating system to track all the process's execution status, and contains the For every process managed by the kernel, there is a process control block (PCB) in the process table." ;
    skos:exactMatch d3f:KernelProcessTable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KeyboardInputDevice a owl:Class ;
    rdfs:label "KeyboardInputDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Keyboard Input Device" ;
    rdfs:seeAlso dbr:Computer_keyboard ;
    rdfs:subClassOf d3f:InputDevice ;
    skos:altLabel "Computer Keyboard",
        "Keyboard" ;
    skos:definition "A computer keyboard is a typewriter-style device which uses an arrangement of buttons or keys to act as mechanical levers or electronic switches. Following the decline of punch cards and paper tape, interaction via teleprinter-style keyboards became the main input method for computers. A keyboard is also used to give commands to the operating system of a computer, such as Windows' Control-Alt-Delete combination. Although on Pre-Windows 95 Microsoft operating systems this forced a re-boot, now it brings up a system security options screen." ;
    skos:exactMatch d3f:KeyboardInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KioskComputer a owl:Class ;
    rdfs:label "KioskComputer" ;
    dcterms:title "Kiosk Computer" ;
    rdfs:seeAlso dbr:Interactive_kiosk ;
    rdfs:subClassOf d3f:SharedComputer ;
    skos:altLabel "Interactive Kiosk" ;
    skos:definition "An interactive kiosk is a computer terminal featuring specialized hardware and software that provides access to information and applications for communication, commerce, entertainment, or education. Early interactive kiosks sometimes resembled telephone booths, but have been embraced by retail, food service and hospitality to improve customer service and streamline operations. Interactive kiosks are typically placed in high foot traffic settings such as shops, hotel lobbies or airports." ;
    skos:exactMatch d3f:KioskComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Kurtosis a owl:Class ;
    rdfs:label "Kurtosis" ;
    d3f:d3fend-id "D3A-KUR" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Probability distribution. [Link](https://en.wikipedia.org/wiki/Probability_distribution)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DistributionProperties ;
    skos:definition "The measure of the \"fatness\" of the tails of a pmf or pdf. The fourth standardized moment of the distribution." ;
    skos:exactMatch d3f:Kurtosis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LANAccessMediation a owl:Class ;
    rdfs:label "LANAccessMediation" ;
    d3f:d3fend-id "D3-LAMED" ;
    d3f:kb-article "## How it works LAN Access Mediation is a network security approach that manages and controls access to a Local Area Network by using key components such as Access Control Lists (ACLs) to specify which devices are allowed or denied access, Port Security to restrict device connections to specific sw" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "LAN Access Mediation" ;
    rdfs:seeAlso <https://dodcio.defense.gov/Portals/0/Documents/Library/(U)ZT_RA_v2.0(U)_Sep22.pdf> ;
    rdfs:subClassOf d3f:NetworkAccessMediation ;
    skos:definition "LAN access mediation encompasses the application of strict access control policies, systematic verification of devices, and authentication mechanisms to govern connectivity to a Local Area Network." ;
    skos:exactMatch d3f:LANAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "Layer 2 Enforcement" .

d3f:LM0006 a owl:Class ;
    rdfs:label "LM_0006" ;
    d3f:attack-id "LM-0006" ;
    dcterms:title "Launch Vehicle Interface" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/LM-0006/> ;
    rdfs:subClassOf d3f:SPARTALateralMovementTechnique ;
    skos:altLabel "LM-0006" ;
    skos:definition "Threat actors may attempt to exploit reduced protections placed on the interfaces between launch vehicles and payloads in order to move from one to the other." ;
    skos:exactMatch d3f:LM-0006,
        mitre-attack:LM-0006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LaptopComputer a owl:Class ;
    rdfs:label "LaptopComputer" ;
    dcterms:title "Laptop Computer" ;
    rdfs:seeAlso dbr:Laptop ;
    rdfs:subClassOf d3f:PersonalComputer ;
    skos:altLabel "Laptop",
        "Notebook" ;
    skos:definition "A laptop computer (also laptop), is a small, portable personal computer (PC) with a \"clamshell\" form factor, typically having a thin LCD or LED computer screen mounted on the inside of the upper lid of the clamshell and an alphanumeric keyboard on the inside of the lower lid. The clamshell is opened up to use the computer. Laptops are folded shut for transportation, and thus are suitable for mobile use. Its name comes from lap, as it was deemed to be placed on a person's lap when being used. Although originally there was a distinction between laptops and notebooks (the former being bigger and heavier than the latter), as of 2014, there is often no longer any difference. Today, laptops are commonly used in a variety of settings, such as at work, in education, for playing games, web browsing" ;
    skos:exactMatch d3f:LaptopComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LegacySystem a owl:Class ;
    rdfs:label "LegacySystem" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Legacy Digital System" ;
    dcterms:title "Legacy System" ;
    rdfs:seeAlso dbr:Legacy_system ;
    rdfs:subClassOf d3f:DigitalSystem ;
    skos:definition "In computing, a legacy system is an old method, technology, computer system, or application program, \"of, relating to, or being a previous or outdated computer system,\" yet still in use. Often referencing a system as \"legacy\" means that it paved the way for the standards that would follow it. This can also imply that the system is out of date or in need of replacement." ;
    skos:exactMatch d3f:LegacySystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LevenshteinMatching a owl:Class ;
    rdfs:label "LevenshteinMatching" ;
    d3f:d3fend-id "D3A-LM" ;
    d3f:kb-article "## References 1. Navarro, G. (2001). A guided tour to approximate string matching. _ACM Computing Surveys_, 33(1), 31-88. [Link](https://doi.org/10.1145/375360.375365)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Edit Distance" ;
    dcterms:title "Levenschtein Matching" ;
    rdfs:subClassOf d3f:ApproximateStringMatching ;
    skos:definition "The Levenshtein distance (LD) is a metric for measuring the differences between two sequences - or strings. Informally, the LD is the number of individual edits one would have to make to turn one sequence into another." ;
    skos:exactMatch d3f:LevenshteinMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LinearClassifier a owl:Class ;
    rdfs:label "LinearClassifier" ;
    d3f:d3fend-id "D3A-LC" ;
    d3f:kb-article "## References A Look at the Maths Behind Linear Classification. Towards Data Science. [Link](https://towardsdatascience.com/a-look-at-the-maths-behind-linear-classification-166e99a9e5fb)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Linear Classifier" ;
    rdfs:subClassOf d3f:Classification ;
    skos:definition "A linear classifier is a model that makes a decision to categories a set of data points to a discrete class based on a linear combination of its explanatory variables" ;
    skos:exactMatch d3f:LinearClassifier ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LinearLogicProgramming a owl:Class ;
    rdfs:label "LinearLogicProgramming" ;
    d3f:d3fend-id "D3A-LLP" ;
    d3f:kb-article "## References 1. Cosmo, R. and Miller D. (2019, May 24). _Linear logic_. Stanford Encyclopedia of Philosophy. [Link](https://plato.stanford.edu/entries/logic-linear/#LinLogComSci) 2. Linear logic programming. (2023, May 16). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Logic_programming#Line" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Linear Logic Programming" ;
    rdfs:subClassOf d3f:LogicProgramming ;
    skos:definition "Linear logic programming is a form of logic programming that uses linear logic, that is, it emphasizes the use of formulas as resources." ;
    skos:exactMatch d3f:LinearLogicProgramming ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LinearRegressionLearning a owl:Class ;
    rdfs:label "LinearRegressionLearning" ;
    d3f:d3fend-id "D3A-LRL" ;
    d3f:kb-article "## References - Gawali, Suvarna. “Linear Regression Algorithm to Make Predictions Easily.” Analytics Vidhya, 22 July 2022, https://www.analyticsvidhya.com/blog/2021/06/linear-regression-in-machine-learning/. - Nau, Robert. “Statistical Forecasting: Notes On Regression and Time Series Analysis.” Intr" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Linear Regression Learning" ;
    rdfs:seeAlso d3f:LinearRegression ;
    rdfs:subClassOf d3f:RegressionAnalysisLearning ;
    skos:definition "A supervised learning method that builds a linear regression model using training data." ;
    skos:exactMatch d3f:LinearRegressionLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LinuxClone a owl:Class ;
    rdfs:label "LinuxClone" ;
    dcterms:title "Linux Clone" ;
    rdfs:seeAlso <https://man7.org/linux/man-pages/man2/clone.2.html> ;
    rdfs:subClassOf d3f:OSAPICreateProcess ;
    skos:definition "Creates a child process and provides more precise control over the data shared between the parent and child processes." ;
    skos:exactMatch d3f:LinuxClone ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LinuxClone3 a owl:Class ;
    rdfs:label "LinuxClone3" ;
    dcterms:title "Linux Clone3" ;
    rdfs:seeAlso <https://man7.org/linux/man-pages/man2/clone3.2.html> ;
