d3f:SingularValueDecomposition a owl:Class ;
    rdfs:label "SingularValueDecomposition" ;
    d3f:d3fend-id "D3A-SVD" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Singular value decomposition. [Link](https://en.wikipedia.org/wiki/Singular_value_decomposition)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Singular Value Decomposition" ;
    rdfs:subClassOf d3f:DimensionReduction ;
    skos:definition "Singular Value Decomposition (SVD) is an algorithm that represents a matrix as a linear series of data and to find the set of factors that will best predict an outcome" ;
    skos:exactMatch d3f:SingularValueDecomposition ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Skewness a owl:Class ;
    rdfs:label "Skewness" ;
    d3f:d3fend-id "D3A-SKE" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Skewness. [Link](https://en.wikipedia.org/wiki/Skewness)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DistributionProperties ;
    skos:definition "Skewness is a measure of the asymmetry of the probability distribution of a real-valued random variable about its mean. The standardized moment of a probability distribution function." ;
    skos:exactMatch d3f:Skewness ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareArtifactServer a owl:Class ;
    rdfs:label "SoftwareArtifactServer" ;
    dcterms:title "Software Artifact Server" ;
    rdfs:seeAlso dbr:Artifact_\(software_development\),
        dbr:Software_repository ;
    rdfs:subClassOf d3f:ArtifactServer ;
    skos:definition "A software artifact server provides access to the software artifacts in a software repository. A software repository, or \"repo\" for short, is a storage location for software packages. Often a table of contents is stored, as well as metadata. Repositories group packages. Sometimes the grouping is for a programming language, such as CPAN for the Perl programming language, sometimes for an entire operating system, sometimes the license of the contents is the criteria. At client side, a package manager helps installing from and updating the repositories." ;
    skos:exactMatch d3f:SoftwareArtifactServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadio a owl:Class ;
    rdfs:label "Software_definedRadio" ;
    d3f:synonym "SDR" ;
    dcterms:title "Software-defined Radio" ;
    rdfs:seeAlso dbr:Software-defined_radio ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:altLabel "Software-definedRadio" ;
    skos:definition "Software-defined radio (SDR) is a radio communication system where components that conventionally have been implemented in analog hardware (e.g. mixers, filters, amplifiers, modulators/demodulators, detectors, etc.) are instead implemented by means of software on a computer or embedded system." ;
    skos:exactMatch d3f:Software-definedRadio ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDeploymentTool a owl:Class ;
    rdfs:label "SoftwareDeploymentTool" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Deployment Tool" ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "Software that coordinates the deployment process of software to systems, typically remotely." ;
    skos:exactMatch d3f:SoftwareDeploymentTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareInventory a owl:Class ;
    rdfs:label "SoftwareInventory" ;
    d3f:d3fend-id "D3-SWI" ;
    d3f:kb-article "## How it works Administrators collect information on software items in their architecture using a variety of administrative and management tools that query network nodes for information. In limited cases, where such queries are not supported or provide specific information of interest, an administ" ;
    d3f:owl_named_individual "true" ;
