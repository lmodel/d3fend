d3f:RemovableMediaDevice a owl:Class ;
    rdfs:label "RemovableMediaDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Removable Media Device" ;
    rdfs:seeAlso dbr:Removable_media ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A removable media device is a hardware device used for computer storage and that is designed to be inserted and removed from the system.  It is distinct from other removable media in that all the hardware required to read the data are built into the device.  So USB flash drives and external hard drives are removable media devices, whereas tapes and disks are not, as they require additional hardware to perform read/write operations." ;
    skos:exactMatch d3f:RemovableMediaDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RemoveUserFromGroupEvent a owl:Class ;
    rdfs:label "RemoveUserFromGroupEvent" ;
    dcterms:title "Remove User from Group Event" ;
    rdfs:subClassOf d3f:GroupManagementEvent ;
    skos:definition "An event where a user is removed from a group, revoking the permissions and privileges associated with the group from the user." ;
    skos:exactMatch d3f:RemoveUserFromGroupEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ResidualNeuralNetwork a owl:Class ;
    rdfs:label "ResidualNeuralNetwork" ;
    d3f:d3fend-id "D3A-RNN" ;
    d3f:kb-article "## References Wikipedia contributors. (2021, August 23). Residual neural network. In Wikipedia, The Free Encyclopedia. [Link](https://en.wikipedia.org/wiki/Residual_neural_network)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Residual Neural Network" ;
    rdfs:subClassOf d3f:ConvolutionalNeuralNetwork ;
    skos:definition "A residual neural network (ResNet) is an artificial neural network (ANN). It is a gateless or open-gated variant of the HighwayNet, the first working very deep feedforward neural network with hundreds of layers, much deeper than previous neural networks." ;
    skos:exactMatch d3f:ResidualNeuralNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ResourceAccessPatternAnalysis a owl:Class ;
    rdfs:label "ResourceAccessPatternAnalysis" ;
    d3f:d3fend-id "D3-RAPA" ;
    d3f:kb-article "## How it works This technique analyzes a user's resource accesses by comparing the user's recent activity against a baseline activity model. Major differences between the current activity and the baseline model might indicate unauthorized activity if they are severe enough. ## Considerations * Po" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resource Access Pattern Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Analyzing the resources accessed by a user to identify unauthorized activity." ;
    skos:exactMatch d3f:ResourceAccessPatternAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ResourceFork a owl:Class ;
    rdfs:label "ResourceFork" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resource Fork" ;
    rdfs:seeAlso dbr:Resource_fork ;
    rdfs:subClassOf d3f:FileSection ;
    skos:definition "The resource fork is a fork or section of a file on Apple's classic Mac OS operating system, which was also carried over to the modern macOS for compatibility, used to store structured data along with the unstructured data stored within the data fork." ;
    skos:exactMatch d3f:ResourceFork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RestorationEvent a owl:Class ;
    rdfs:label "RestorationEvent" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Restoration Event" ;
    rdfs:subClassOf d3f:SecurityEvent ;
    skos:definition "An event representing actions to return a compromised system or resource to a trusted operational state, such as through backup restoration, system reinstallation, or repair." ;
    skos:exactMatch d3f:RestorationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RestoreConfiguration a owl:Class ;
    rdfs:label "RestoreConfiguration" ;
    d3f:d3fend-id "D3-RC" ;
