    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that pauses the execution of a thread." ;
    skos:exactMatch d3f:OSAPISuspendThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPITraceProcess a owl:Class ;
