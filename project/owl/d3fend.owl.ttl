    d3f:cwe-id "CWE-156" ;
    d3f:synonym "White space" ;
    dcterms:title "Improper Neutralization of Whitespace" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-156" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as whitespace when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-156,
