d3f:CredentialEviction a owl:Class ;
    rdfs:label "CredentialEviction" ;
    d3f:d3fend-id "D3-CE" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Eviction" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Credential Eviction techniques disable or remove compromised credentials from a computer network." ;
    skos:exactMatch d3f:CredentialEviction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CyberTechnique a owl:Class ;
    rdfs:label "CyberTechnique" ;
    dcterms:title "Cyber Technique" ;
    rdfs:subClassOf d3f:Technique ;
    skos:exactMatch d3f:CyberTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSDenylisting a owl:Class ;
    rdfs:label "DNSDenylisting" ;
    d3f:d3fend-id "D3-DNSDL" ;
    d3f:kb-article "## How it works Rules are implemented that filter DNS queries using criteria such as: - Client subnet - Type of network protocol used in query - Fully qualified domain name (FQDN) of record in the query - DNS Server IP address that received the DNS request - Type of DNS record being queried - Time o" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "DNS Blacklisting" ;
    dcterms:title "DNS Denylisting" ;
    rdfs:subClassOf d3f:NetworkIsolation ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:T1071 ;
    skos:definition "Blocking DNS Network Traffic based on criteria such as IP address, domain name, or DNS query type." ;
    skos:exactMatch d3f:DNSDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1071.004,
        mitre-attack:T1568 .

d3f:DecoyEnvironment a owl:Class ;
    rdfs:label "DecoyEnvironment" ;
    d3f:d3fend-id "D3-DE" ;
    d3f:kb-article "## Technique Overview Systems in a decoy environment are typically configured so that some detectable means of communication does not have any legitimate business purpose. Any communication via these means should be logged and analyzed to find potential indicators of compromise for a possible past" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Honeypot" ;
    dcterms:title "Decoy Environment" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:broadMatch d3f:DiscoveryTechnique ;
    skos:definition "A Decoy Environment comprises hosts and networks for the purposes of deceiving an attacker." ;
    skos:exactMatch d3f:DecoyEnvironment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1082 .

d3f:DigitalArtifact a owl:Class ;
    rdfs:label "DigitalArtifact" ;
    d3f:display-baseurl "/dao/artifact/" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Digital Asset" ;
    dcterms:title "Digital Artifact" ;
    rdfs:seeAlso dbr:Digital_artifactual_value,
        dbr:Virtual_artifact,
        <https://www.iso.org/obp/ui/#iso:std:iso-iec:19770:-1:ed-3:v1:en> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty d3f:d3fend_artifact_data_property ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:d3fend_artifact_data_property ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty d3f:d3fend_artifact_data_property ],
        d3f:Artifact ;
    skos:broadMatch oscal:Resource ;
    skos:closeMatch unified_cyber_ontology:Item ;
    skos:definition "An information-bearing artifact (object) that is, or is encoded to be used with, a digital computer system. This concept is broad to include the literal instances of an artifact, or an implicit summarization of changes to or properties of other artifacts." ;
    skos:exactMatch d3f:DigitalArtifact ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalMessage a owl:Class ;
    rdfs:label "DigitalMessage" ;
    dcterms:title "Digital Message" ;
    rdfs:seeAlso dbr:Message_\(computing\) ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A discrete unit of digital communication created by a sender for one or more intended recipients. Encoded in an application-layer format, a digital message conveys semantics such as commands, data, or status and is transported inside lower-layer containers like network frames or packets." ;
    skos:exactMatch d3f:DigitalMessage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DimensionReduction a owl:Class ;
    rdfs:label "DimensionReduction" ;
    d3f:d3fend-id "D3A-DR" ;
    d3f:kb-article "## References O'Reilly Media. (n.d.). Chapter 7. Machine Learning and Security: Protecting Systems with Data and Algorithms. [Link](https://www.oreilly.com/library/view/machine-learning-and/9781492073048/ch07.html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Dimension Reduction" ;
    rdfs:subClassOf d3f:UnsupervisedLearning ;
    skos:definition "Dimensionality reduction is a key technique within unsupervised learning. It compresses the data by finding a smaller, different set of variables that capture what matters most in the original features, while minimizing the loss of information." ;
    skos:exactMatch d3f:DimensionReduction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DistributionProperties a owl:Class ;
    rdfs:label "DistributionProperties" ;
    d3f:d3fend-id "D3A-DP" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Probability distribution. [Link](https://en.wikipedia.org/wiki/Probability_distribution)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Distribution Properties" ;
    rdfs:subClassOf d3f:DescriptiveStatistics ;
    skos:definition "The properties derived from a probability distribution." ;
    skos:exactMatch d3f:DistributionProperties ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainNameEnum a owl:Class ;
    rdfs:label "DomainNameEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:ASCIIDomainName d3f:FQDNDomainName d3f:Hostname d3f:InternationalizedDomainName ) ;
    skos:definition "Enumeration of DomainName values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A domain name is an identification string that defines a realm of administrative autonomy, authority or control within the Internet. Domain names are formed by the rules and procedures of the Domain Name System (DNS). Any name registered in the DNS is a domain name.Domain names are used in various n" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:ASCIIDomainName,
        d3f:FQDNDomainName,
        d3f:Hostname,
        d3f:InternationalizedDomainName .

d3f:EX0010 a owl:Class ;
    rdfs:label "EX_0010" ;
    d3f:attack-id "EX-0010" ;
    dcterms:title "Malicious Code" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0010/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0010" ;
    skos:definition "Threat actors may rely on other tactics and techniques in order to execute malicious code on the victim spacecraft. This can be done via compromising the supply chain or development environment in some capacity or taking advantage of known commands. However, once malicious code has been uploaded to the victim spacecraft, the threat actor can then trigger the code to run via a specific command or wait for a legitimate user to trigger it accidently. The code itself can do a number of different things to the hosted payload, subsystems, or underlying OS." ;
    skos:exactMatch d3f:EX-0010,
        mitre-attack:EX-0010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmailEvent a owl:Class ;
    rdfs:label "EmailEvent" ;
    dcterms:title "Email Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/email_activity>,
        <https://schema.ocsf.io/classes/email_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:TCPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving email communication, including sending, receiving, and processing emails. Email events encapsulate activities essential to the transmission and analysis of email messages in a networked environment." ;
    skos:exactMatch d3f:EmailEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLog a owl:Class ;
    rdfs:label "EventLog" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Digital Event Log" ;
    dcterms:title "Event Log" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Log_file#Event_logs> ;
    rdfs:subClassOf d3f:Log ;
    skos:definition "Event logs record events taking place in the execution of a system in order to provide an audit trail that can be used to understand the activity of the system and to diagnose problems. They are essential to understand the activities of complex systems, particularly in the case of applications with little user interaction (such as server applications)." ;
    skos:exactMatch d3f:EventLog,
        unified_cyber_ontology:EventLog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutableBinaryEnum a owl:Class ;
    rdfs:label "ExecutableBinaryEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:LinuxELFFile32bit d3f:LinuxELFFile64bit d3f:PE32ExecutableFile d3f:PE32PLUSExecutableFile ) ;
    skos:definition "Enumeration of ExecutableBinary values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "An executable binary contains machine code instructions for a physical CPU. D3FEND also considers byte code for a virtual machine to be binary code. This is in contrast to executable scripts written in a scripting language." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:LinuxELFFile32bit,
        d3f:LinuxELFFile64bit,
        d3f:PE32ExecutableFile,
        d3f:PE32PLUSExecutableFile .

d3f:ExternalThing a owl:Class ;
    rdfs:label "ExternalThing" ;
    dcterms:title "External Thing" ;
    rdfs:subClassOf linkml:ClassDefinition ;
    skos:exactMatch d3f:ExternalThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileTransferNetworkTraffic a owl:Class ;
    rdfs:label "FileTransferNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Transfer Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "File transfer network traffic is network traffic related to file transfers between network nodes. This includes only network traffic conforming to standard file transfer protocols, not custom transfer protocols." ;
    skos:exactMatch d3f:FileTransferNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GenerativeAdversarialNetwork a owl:Class ;
    rdfs:label "GenerativeAdversarialNetwork" ;
    d3f:d3fend-id "D3A-GAN" ;
    d3f:kb-article "## References Brownlee, J. (2019). What Are Generative Adversarial Networks (GANs)? Machine Learning Mastery. [Link](https://machinelearningmastery.com/what-are-generative-adversarial-networks-gans/)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "GAN" ;
    dcterms:title "Generative Adversarial Network" ;
    rdfs:subClassOf d3f:UnsupervisedLearning ;
    skos:definition "Generative Adversarial Networks (GAN) are an approach to generative modeling using deep learning methods, such as convolutional neural networks." ;
    skos:exactMatch d3f:GenerativeAdversarialNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDriver a owl:Class ;
    rdfs:label "HardwareDriver" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hardware Driver" ;
    rdfs:seeAlso dbr:Device_driver ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Device Driver" ;
    skos:definition "In computing, a device driver (commonly referred to simply as a driver) is a computer program that operates or controls a particular type of device that is attached to a computer. A driver provides a software interface to hardware devices, enabling operating systems and other computer programs to access hardware functions without needing to know precise details of the hardware being used. A driver communicates with the device through the computer bus or communications subsystem to which the hardware connects. When a calling program invokes a routine in the driver, the driver issues commands to the device. Once the device sends data back to the driver, the driver may invoke routines in the original calling program. Drivers are hardware dependent and operating-system-specific. They usually provide the interrupt handling required for any necessary asynchronous time-dependent hardware interface." ;
    skos:exactMatch d3f:HardwareDriver ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HighDimensionClustering a owl:Class ;
    rdfs:label "High_dimensionClustering" ;
    d3f:d3fend-id "D3A-HDC" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Clustering high-dimensional data. [Link](https://en.wikipedia.org/wiki/Clustering_high-dimensional_data)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "High-dimension Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:altLabel "High-dimensionClustering" ;
    skos:definition "The cluster analysis of data with anywhere from a few dozen to many thousands of dimensions." ;
    skos:exactMatch d3f:High-dimensionClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Host a owl:Class ;
    rdfs:label "Host" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Host_\(network\),
        <https://schema.ocsf.io/objects/device>,
        <https://schema.ocsf.io/objects/endpoint> ;
    rdfs:subClassOf d3f:ComputerNetworkNode ;
    skos:altLabel "Network Host" ;
    skos:definition "A host is a computer or other device, typically connected to a computer network. A network host may offer information resources, services, and applications to users or other nodes on the network. A network host is a network node that is assigned a network layer host address. Network hosts that participate in applications that use the client-server model of computing, are classified as server or client systems. Network hosts may also function as nodes in peer-to-peer applications, in which all nodes share and consume resources in an equipotent manner." ;
    skos:exactMatch d3f:Host ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HostShutdown a owl:Class ;
    rdfs:label "HostShutdown" ;
    d3f:d3fend-id "D3-HS" ;
    d3f:kb-article "## How It Works Host shutdown can either be initiated in the physical presence of the device using the power functions or remotely using the provided user interface or an installed EDR agent (with the available function). This process may allow for the removal of specific types of malware, such as" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Host Shutdown" ;
    rdfs:subClassOf d3f:ProcessEviction,
        d3f:ProcessTerminationEnum,
        linkml:PermissibleValue ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1505,
        d3f:T1546,
        d3f:T1562 ;
    skos:definition "Host Shutdown",
        "Initiating a host's shutdown sequence to terminate all running processes." ;
    skos:editorialNote "Initiating a host's shutdown sequence to terminate all running processes." ;
    skos:exactMatch d3f:HostShutdown ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1033,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1212,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1546.007,
        mitre-attack:T1550,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:ImageSynthesisGAN a owl:Class ;
    rdfs:label "ImageSynthesisGAN" ;
    d3f:d3fend-id "D3A-ISG" ;
    d3f:kb-article "## References Zhang, Q., Wang, H., Lu, H., Won, D., & Yoon, S. W. (2018). Medical Image Synthesis with Generative Adversarial Networks for Tissue Recognition. 2018 IEEE International Conference on Healthcare Informatics (ICHI), 199-207. doi: 10.1109/ICHI.2018.00030. [Link](https://ieeexplore.ieee.o" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Image Synthesis GAN" ;
    rdfs:subClassOf d3f:GenerativeAdversarialNetwork ;
    skos:definition "Image synthesis thorugh the application of Generative Adversarial Networks." ;
    skos:exactMatch d3f:ImageSynthesisGAN ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternetNetworkTraffic a owl:Class ;
    rdfs:label "InternetNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Internet Network Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "Internet network traffic is network traffic that crosses a boundary between networks. [This is the general sense of inter-networking; It may or may not cross to or from the Internet]" ;
    skos:exactMatch d3f:InternetNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntrinsicallySemiSupervisedLearning a owl:Class ;
    rdfs:label "IntrinsicallySemi_supervisedLearning" ;
    d3f:d3fend-id "D3A-ISSL" ;
    d3f:kb-article "## References Beginner's Guide to Semi-Supervised Learning. Jashish Blog. [Link](http://jashish.com.np/blog/posts/beginners-guide-to-semi-supervised-learning/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intrinsically Semi-supervised Learning" ;
    rdfs:subClassOf d3f:SemiSupervisedLearning ;
    skos:altLabel "IntrinsicallySemi-supervisedLearning" ;
    skos:definition "These methods directly optimize an objective function with components for labeled and unlabeled samples and do not rely on any intermediate steps or supervised base learners. Basically, these methods are extension of existing supervised methods to include the effect of unlabeled data samples in the objective function." ;
    skos:exactMatch d3f:IntrinsicallySemi-supervisedLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogicalRules a owl:Class ;
    rdfs:label "LogicalRules" ;
    d3f:d3fend-id "D3A-LR" ;
    d3f:kb-article "## How it works Logic rules define a set of patterns that in some patterns must match input data. If the the conditions are met, then the rule will \"fire\" and some action will be taken, usually notifying a person or another system that the event being monitored needs further processing or attention" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logical Rules" ;
    rdfs:subClassOf d3f:SymbolicLogic ;
    skos:definition "A logical rule matches event data or set of values to a conditional expression and results in the determination of a truth value, which may be used to determine the next action or step to take." ;
    skos:exactMatch d3f:LogicalRules ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryExtent a owl:Class ;
    rdfs:label "MemoryExtent" ;
    dcterms:title "Memory Extent" ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "A memory extent is a defined, contiguous region of memory within a computing system, characterized by its size, location, and purpose. It represents an abstraction of physical or virtual memory used for storing data, instructions, or other computational artifacts." ;
    skos:exactMatch d3f:MemoryExtent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MessageHardening a owl:Class ;
    rdfs:label "MessageHardening" ;
    d3f:d3fend-id "D3-MH" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Email Or Messaging Hardening" ;
    dcterms:title "Message Hardening" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Email or Messaging Hardening includes measures taken to ensure the confidentiality and integrity of user to user computer messages." ;
    skos:exactMatch d3f:MessageHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ModelFreeReinforcementLearning a owl:Class ;
    rdfs:label "Model_freeReinforcementLearning" ;
    d3f:d3fend-id "D3A-MFRL" ;
    d3f:kb-article "## References Model-free (reinforcement learning). Wikipedia. [Link](https://en.wikipedia.org/wiki/Model-free_(reinforcement_learning)).)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Model-free Reinforcement Learning" ;
    rdfs:subClassOf d3f:ReinforcementLearning ;
    skos:altLabel "Model-freeReinforcementLearning" ;
    skos:definition "In reinforcement learning (RL), a model-free algorithm (as opposed to a model-based one) is an algorithm which does not use the transition probability distribution (and the reward function) associated with the Markov decision process (MDP),which, in RL, represents the problem to be solved. The transition probability distribution (or transition model) and the reward function are often collectively called the \"model\" of the environment (or MDP), hence the name \"model-free\". A model-free RL algorithm can be thought of as an \"explicit\" trial-and-error algorithm. An example of a model-free algorithm is Q-learning." ;
    skos:exactMatch d3f:Model-freeReinforcementLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Modem a owl:Class ;
    rdfs:label "Modem" ;
    rdfs:seeAlso dbr:Modem ;
    rdfs:subClassOf d3f:ComputerNetworkNode ;
    skos:definition "A modem -- a portmanteau of \"modulator-demodulator\" -- is a hardware device that converts data into a format suitable for a transmission medium so that it can be transmitted from one computer to another (historically along telephone wires). A modem modulates one or more carrier wave signals to encode digital information for transmission and demodulates signals to decode the transmitted information. The goal is to produce a signal that can be transmitted easily and decoded reliably to reproduce the original digital data. Modems can be used with almost any means of transmitting analog signals from light-emitting diodes to radio. A common type of modem is one that turns the digital data of a computer into modulated electrical signal for transmission over telephone lines and demodulated by another modem at the receiver side to recover the digital data." ;
    skos:exactMatch d3f:Modem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NIST_SP_800-53_R5 a owl:Class ;
    rdfs:label "NIST_SP_800_53_R5" ;
    rdfs:subClassOf d3f:NISTSP80053ControlCatalogEnum,
        linkml:PermissibleValue ;
    skos:definition "NIST SP 800-53 R5" .

d3f:NTFSLink a owl:Class ;
    rdfs:label "NTFSLink" ;
    dcterms:title "NTFS Link" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:FileSystemLink ],
        d3f:File ;
    skos:definition "The NTFS filesystem defines various ways to link files, i.e. to make a file point to another file or its contents. The object being pointed to is called the target. There are three classes of NTFS links: (a) Hard links, which have files share the same MFT entry (inode), in the same filesystem; (b) Symbolic links, which record the path of another file that the links contents should show and can accept relative paths; and (c) Junction points, which are similar to symlinks but defined only for directories and only accepts local absolute paths" ;
    skos:exactMatch d3f:NTFSLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkMediaStreamingResource a owl:Class ;
    rdfs:label "NetworkMediaStreamingResource" ;
    dcterms:title "Network Media Streaming Resource" ;
    rdfs:subClassOf d3f:NetworkResource ;
    skos:definition "A server that provides digital media content to users." ;
    skos:exactMatch d3f:NetworkMediaStreamingResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkSession a owl:Class ;
    rdfs:label "NetworkSession" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Session" ;
    rdfs:seeAlso dbr:OSI_model,
        dbr:Session_\(computer_science\),
        <https://schema.ocsf.io/objects/network_connection_info> ;
    rdfs:subClassOf d3f:Session ;
    skos:definition "A network session is a temporary and interactive information interchange between two or more devices communicating over a network. A session is established at a certain point in time, and then 'torn down' - brought to an end - at some later point. An established communication session may involve more than one message in each direction. A session is typically stateful, meaning that at least one of the communicating parties needs to hold current state information and save information about the session history in order to be able to communicate, as opposed to stateless communication, where the communication consists of independent requests with responses. Network sessions may be established and implemented as part of protocols and services at the application, session, or transport layers of the OSI model." ;
    skos:exactMatch d3f:NetworkSession ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIFreeMemory a owl:Class ;
    rdfs:label "OSAPIFreeMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Free Memory" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that releases or deallocates memory that was previously allocated by the program." ;
    skos:exactMatch d3f:OSAPIFreeMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIGetSystemTime a owl:Class ;
