    dcterms:title "Password Database" ;
    rdfs:subClassOf d3f:Database ;
    skos:definition "A password database is a database that holds passwords for user accounts and is usually encrypted (i.e.., the passwords are hashed). Password databases are found supporting system services (such as SAM) or part of user applications such as password managers." ;
    skos:exactMatch d3f:PasswordDatabase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalAccessAlarmEvent a owl:Class ;
    rdfs:label "PhysicalAccessAlarmEvent" ;
    dcterms:title "Physical Access Alarm Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:exactMatch d3f:PhysicalAccessAlarmEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "An event occuring when a physical threshold is crossed." .

d3f:Processor a owl:Class ;
    rdfs:label "Processor" ;
    d3f:synonym "Computer Processor" ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A processor is a hardware component or integrated circuit that performs computations, executes instructions, and processes data to carry out tasks within a computing system." ;
    skos:exactMatch d3f:Processor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Provider a owl:Class ;
    rdfs:label "Provider" ;
    rdfs:subClassOf d3f:Organization ;
    skos:definition "Providers are entities that intentionally offer, supply, or facilitate goods, services, or resources through actions of their agents." ;
    skos:exactMatch d3f:Provider ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD0001 a owl:Class ;
    rdfs:label "RD_0001" ;
    d3f:attack-id "RD-0001" ;
    dcterms:title "Acquire Infrastructure" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0001/> ;
    rdfs:subClassOf d3f:SPARTAResourceDevelopmentTechnique ;
    skos:altLabel "RD-0001" ;
    skos:definition "Threat actors may buy, lease, or rent infrastructure that can be used for future campaigns or to perpetuate other techniques. A wide variety of infrastructure exists for threat actors to connect to and communicate with target spacecraft. Infrastructure can include:" ;
    skos:exactMatch d3f:RD-0001,
        mitre-attack:RD-0001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD0005 a owl:Class ;
    rdfs:label "RD_0005" ;
    d3f:attack-id "RD-0005" ;
    dcterms:title "Obtain Non-Cyber Capabilities" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0005/> ;
    rdfs:subClassOf d3f:SPARTAResourceDevelopmentTechnique ;
    skos:altLabel "RD-0005" ;
    skos:definition """Threat actors may obtain non-cyber capabilities, primarily physical counterspace weapons or systems. These counterspace capabilities vary significantly in the types of effects they create, the level of technological sophistication required, and the level of resources needed to develop and deploy them. These diverse capabilities also differ in how they are employed and how easy they are to detect and attribute and the permanence of the effects they have on their target.*

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:RD-0005,
        mitre-attack:RD-0005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0003 a owl:Class ;
    rdfs:label "REC_0003" ;
    d3f:attack-id "REC-0003" ;
    dcterms:title "Gather Spacecraft Communications Information" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0003/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0003" ;
    skos:definition "Threat actors may obtain information on the victim spacecraft's communication channels in order to determine specific commands, protocols, and types. Information gathered can include commanding patterns, antenna shape and location, beacon frequency and polarization, and various transponder information." ;
    skos:exactMatch d3f:REC-0003,
        mitre-attack:REC-0003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0005 a owl:Class ;
    rdfs:label "REC_0005" ;
    d3f:attack-id "REC-0005" ;
    dcterms:title "Eavesdropping" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0005/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0005" ;
    skos:definition "Threat actors may seek to capture network communications throughout the ground station and radio frequency (RF) communication used for uplink and downlink communications. RF communication frequencies vary between 30MHz and 60 GHz. Threat actors may capture RF communications using specialized hardware, such as software defined radio (SDR), handheld radio, or a computer with radio demodulator turned to the communication frequency. Network communications may be captured using packet capture software while the threat actor is on the target network." ;
    skos:exactMatch d3f:REC-0005,
        mitre-attack:REC-0005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0008 a owl:Class ;
    rdfs:label "REC_0008" ;
    d3f:attack-id "REC-0008" ;
    dcterms:title "Gather Supply Chain Information" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0008/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0008" ;
    skos:definition "Threat actors may gather information about a mission's supply chain or product delivery mechanisms that can be used for future campaigns or to help perpetuate other techniques." ;
    skos:exactMatch d3f:REC-0008,
        mitre-attack:REC-0008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ResamplingEnsemble a owl:Class ;
    rdfs:label "ResamplingEnsemble" ;
    d3f:d3fend-id "D3A-RE" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning). Torgo, L. (2014). A resampling ensemble algorithm for improved accuracy. *Neurocomputing*, 134, 55-66. [Link](https://www.sciencedirect.com/science/article/pii/S0925231214007644#:~:text=A%20resampl" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resampling Ensemble" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "In the method, the small classes are oversampled and large classes are undersampled. The resampling scale is determined by the ratio of the min class number and max class number. And multiple machine learning methods are selected to construct the ensemble" ;
    skos:exactMatch d3f:ResamplingEnsemble ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RestoreAccess a owl:Class ;
    rdfs:label "RestoreAccess" ;
    d3f:d3fend-id "D3-RA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Restore Access" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Restoring an entity's access to resources." ;
    skos:exactMatch d3f:RestoreAccess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SecondaryStorage a owl:Class ;
    rdfs:label "SecondaryStorage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Secondary Storage" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Computer_data_storage#Secondary_storage>,
        <https://whatis.techtarget.com/definition/memory> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Storage ],
        d3f:HardwareDevice ;
    skos:definition "Secondary memory (storage, hard disk) is the computer component holding information that does not need to be accessed quickly and that needs to be retained long-term." ;
    skos:exactMatch d3f:SecondaryStorage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwarePackage a owl:Class ;
    rdfs:label "SoftwarePackage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Package" ;
    rdfs:seeAlso <https://schema.ocsf.io/objects/package> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:closeMatch spdx:Package,
        unified_cyber_ontology:Software ;
    skos:definition "A Software Package is a bundled collection of files, code, and metadata that provides functionality, libraries, or applications." ;
    skos:exactMatch d3f:SoftwarePackage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareTimerEvent a owl:Class ;
    rdfs:label "SoftwareTimerEvent" ;
    dcterms:title "Software Timer Event" ;
    rdfs:subClassOf d3f:TimerEvent ;
    skos:definition "A clock event involving a software-based timekeeping mechanism maintained by an operating system or application." ;
    skos:exactMatch d3f:SoftwareTimerEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StackComponent a owl:Class ;
    rdfs:label "StackComponent" ;
    dcterms:title "Stack Component" ;
    rdfs:seeAlso dbr:Call_stack ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A stack component is any component of a call stack used for stack-based memory allocation in a running process.  Examples include saved instruction pointers, stack frames, and stack frame canaries." ;
    skos:exactMatch d3f:StackComponent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StorageImage a owl:Class ;
    rdfs:label "StorageImage" ;
    dcterms:title "Storage Image" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:File ],
        d3f:ComputingImage ;
    skos:definition "A storage image is a complete, encapsulated representation of a storage medium or system environment. It contains all the data, files, and configurations necessary to replicate or deploy a specific system state or software setup." ;
    skos:exactMatch d3f:StorageImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Summarizing a owl:Class ;
    rdfs:label "Summarizing" ;
    rdfs:subClassOf d3f:AnalyticalPurpose ;
    skos:exactMatch d3f:Summarizing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemConfigurationDatabaseRecord a owl:Class ;
    rdfs:label "SystemConfigurationDatabaseRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Configuration Database Record" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OperatingSystemConfigurationComponent ],
        d3f:ConfigurationDatabaseRecord ;
    skos:definition "A database record holding information used to configure the services, parameters, and initial settings for an operating system." ;
    skos:exactMatch d3f:SystemConfigurationDatabaseRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemConfigurationInitResource a owl:Class ;
    rdfs:label "SystemConfigurationInitResource" ;
    dcterms:title "System Configuration Init Resource" ;
    rdfs:subClassOf d3f:LocalResource ;
    skos:altLabel "System Init Resource" ;
    skos:definition "A system configuration initialization resource has information for initializing (booting) a system." ;
    skos:exactMatch d3f:SystemConfigurationInitResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemInitConfiguration a owl:Class ;
    rdfs:label "SystemInitConfiguration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Init Configuration" ;
    rdfs:subClassOf d3f:OperatingSystemConfigurationComponent ;
    skos:altLabel "Autoruns" ;
    skos:definition "System initialization configuration information is configuration information used to configure the services, parameters, and initial settings for an operating system at startup." ;
    skos:exactMatch d3f:SystemInitConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1001 a owl:Class ;
    rdfs:label "T1001" ;
    d3f:attack-id "T1001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data Obfuscation" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may obfuscate command and control traffic to make it more difficult to detect.(Citation: Bitdefender FunnyDream Campaign November 2020) Command and control (C2) communications are hidden (but not necessarily encrypted) in an attempt to make the content more difficult to discover or decipher and to make the communication less conspicuous and hide commands from being seen. This encompasses many methods, such as adding junk data to protocol traffic, using steganography, or impersonating legitimate protocols." ;
    skos:exactMatch d3f:T1001,
        mitre-attack:T1001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1052 a owl:Class ;
    rdfs:label "T1052" ;
    d3f:attack-id "T1052" ;
    dcterms:title "Exfiltration Over Physical Medium" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may attempt to exfiltrate data via a physical medium, such as a removable drive. In certain circumstances, such as an air-gapped network compromise, exfiltration could occur via a physical medium or device introduced by a user. Such media could be an external hard drive, USB drive, cellular phone, MP3 player, or other removable storage and processing device. The physical medium or device could be used as the final exfiltration point or to hop between otherwise disconnected systems." ;
    skos:exactMatch d3f:T1052,
        mitre-attack:T1052 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1069 a owl:Class ;
    rdfs:label "T1069" ;
    d3f:attack-id "T1069" ;
    dcterms:title "Permission Groups Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to discover group and permission settings. This information can help adversaries determine which user accounts and groups are available, the membership of users in particular groups, and which users and groups have elevated permissions." ;
    skos:exactMatch d3f:T1069,
        mitre-attack:T1069 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1102 a owl:Class ;
    rdfs:label "T1102" ;
    d3f:attack-id "T1102" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Service" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may use an existing, legitimate external Web service as a means for relaying data to/from a compromised system. Popular websites and social media acting as a mechanism for C2 may give a significant amount of cover due to the likelihood that hosts within a network are already communicating with them prior to a compromise. Using common services, such as those offered by Google or Twitter, makes it easier for adversaries to hide in expected noise. Web service providers commonly use SSL/TLS encryption, giving adversaries an added level of protection." ;
    skos:exactMatch d3f:T1102,
        mitre-attack:T1102 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1219 a owl:Class ;
    rdfs:label "T1219" ;
    d3f:attack-id "T1219" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Access Tools" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "An adversary may use legitimate desktop support and remote access software to establish an interactive command and control channel to target systems within networks. These services, such as `VNC`, `Team Viewer`, `AnyDesk`, `ScreenConnect`, `LogMein`, `AmmyyAdmin`, and other remote monitoring and management (RMM) tools, are commonly used as legitimate technical support software and may be allowed by application control within a target environment.(Citation: Symantec Living off the Land)(Citation: CrowdStrike 2015 Global Threat Report)(Citation: CrySyS Blog TeamSpy)" ;
    skos:exactMatch d3f:T1219,
        mitre-attack:T1219 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1474 a owl:Class ;
    rdfs:label "T1474" ;
    d3f:attack-id "T1474" ;
    dcterms:title "Supply Chain Compromise" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Adversaries may manipulate products or product delivery mechanisms prior to receipt by a final consumer for the purpose of data or system compromise." ;
    skos:exactMatch d3f:T1474,
        mitre-attack:T1474 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1481 a owl:Class ;
    rdfs:label "T1481" ;
    d3f:attack-id "T1481" ;
    dcterms:title "Web Service" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may use an existing, legitimate external Web service as a means for relaying data to/from a compromised system. Popular websites and social media, acting as a mechanism for C2, may give a significant amount of cover. This is due to the likelihood that hosts within a network are already communicating with them prior to a compromise. Using common services, such as those offered by Google or Twitter, makes it easier for adversaries to hide in expected noise. Web service providers commonly use SSL/TLS encryption, giving adversaries an added level of protection." ;
    skos:exactMatch d3f:T1481,
        mitre-attack:T1481 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1521 a owl:Class ;
    rdfs:label "T1521" ;
    d3f:attack-id "T1521" ;
    dcterms:title "Encrypted Channel" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may explicitly employ a known encryption algorithm to conceal command and control traffic rather than relying on any inherent protections provided by a communication protocol. Despite the use of a secure algorithm, these implementations may be vulnerable to reverse engineering if necessary secret keys are encoded and/or generated within malware samples/configuration files." ;
    skos:exactMatch d3f:T1521,
        mitre-attack:T1521 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1559 a owl:Class ;
    rdfs:label "T1559" ;
    d3f:attack-id "T1559" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inter-Process Communication" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse inter-process communication (IPC) mechanisms for local code or command execution. IPC is typically used by processes to share data, communicate with each other, or synchronize execution. IPC is also commonly used to avoid situations such as deadlocks, which occurs when processes are stuck in a cyclic waiting pattern." ;
    skos:exactMatch d3f:T1559,
        mitre-attack:T1559 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1561 a owl:Class ;
    rdfs:label "T1561" ;
    d3f:attack-id "T1561" ;
    dcterms:title "Disk Wipe" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may wipe or corrupt raw disk data on specific systems or in large numbers in a network to interrupt availability to system and network resources. With direct write access to a disk, adversaries may attempt to overwrite portions of disk data. Adversaries may opt to wipe arbitrary portions of disk data and/or wipe disk structures like the master boot record (MBR). A complete wipe of all disk sectors may be attempted." ;
    skos:exactMatch d3f:T1561,
        mitre-attack:T1561 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1563 a owl:Class ;
    rdfs:label "T1563" ;
    d3f:attack-id "T1563" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Service Session Hijacking" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Adversaries may take control of preexisting sessions with remote services to move laterally in an environment. Users may use valid credentials to log into a service specifically designed to accept remote connections, such as telnet, SSH, and RDP. When a user logs into a service, a session will be established that will allow them to maintain a continuous interaction with that service." ;
    skos:exactMatch d3f:T1563,
        mitre-attack:T1563 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1568 a owl:Class ;
    rdfs:label "T1568" ;
    d3f:attack-id "T1568" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Dynamic Resolution" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may dynamically establish connections to command and control infrastructure to evade common detections and remediations. This may be achieved by using malware that shares a common algorithm with the infrastructure the adversary uses to receive the malware's communications. These calculations can be used to dynamically adjust parameters such as the domain name, IP address, or port number the malware uses for command and control." ;
    skos:exactMatch d3f:T1568,
        mitre-attack:T1568 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1569 a owl:Class ;
    rdfs:label "T1569" ;
    d3f:attack-id "T1569" ;
    dcterms:title "System Services" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "This technique has been deprecated." ;
    skos:exactMatch d3f:T1569,
        mitre-attack:T1569 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1585 a owl:Class ;
    rdfs:label "T1585" ;
    d3f:attack-id "T1585" ;
    dcterms:title "Establish Accounts" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may create and cultivate accounts with services that can be used during targeting. Adversaries can create accounts that can be used to build a persona to further operations. Persona development consists of the development of public information, presence, history and appropriate affiliations. This development could be applied to social media, website, or other publicly available information that could be referenced and scrutinized for legitimacy over the course of an operation using that persona or identity.(Citation: NEWSCASTER2014)(Citation: BlackHatRobinSage)" ;
    skos:exactMatch d3f:T1585,
        mitre-attack:T1585 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1586 a owl:Class ;
    rdfs:label "T1586" ;
    d3f:attack-id "T1586" ;
    dcterms:title "Compromise Accounts" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may compromise accounts with services that can be used during targeting. For operations incorporating social engineering, the utilization of an online persona may be important. Rather than creating and cultivating accounts (i.e. [Establish Accounts](https://attack.mitre.org/techniques/T1585)), adversaries may compromise existing accounts. Utilizing an existing persona may engender a level of trust in a potential victim if they have a relationship, or knowledge of, the compromised persona." ;
    skos:exactMatch d3f:T1586,
        mitre-attack:T1586 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1589 a owl:Class ;
    rdfs:label "T1589" ;
    d3f:attack-id "T1589" ;
    dcterms:title "Gather Victim Identity Information" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may gather information about the victim's identity that can be used during targeting. Information about identities may include a variety of details, including personal data (ex: employee names, email addresses, security question responses, etc.) as well as sensitive details such as credentials or multi-factor authentication (MFA) configurations." ;
    skos:exactMatch d3f:T1589,
        mitre-attack:T1589 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1593 a owl:Class ;
    rdfs:label "T1593" ;
    d3f:attack-id "T1593" ;
    dcterms:title "Search Open Websites/Domains" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may search freely available websites and/or domains for information about victims that can be used during targeting. Information about victims may be available in various online sites, such as social media, new sites, or those hosting information about business operations such as hiring or requested/rewarded contracts.(Citation: Cyware Social Media)(Citation: SecurityTrails Google Hacking)(Citation: ExploitDB GoogleHacking)" ;
    skos:exactMatch d3f:T1593,
        mitre-attack:T1593 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1595 a owl:Class ;
    rdfs:label "T1595" ;
    d3f:attack-id "T1595" ;
    dcterms:title "Active Scanning" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may execute active reconnaissance scans to gather information that can be used during targeting. Active scans are those where the adversary probes victim infrastructure via network traffic, as opposed to other forms of reconnaissance that do not involve direct interaction." ;
    skos:exactMatch d3f:T1595,
        mitre-attack:T1595 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1628 a owl:Class ;
    rdfs:label "T1628" ;
    d3f:attack-id "T1628" ;
    dcterms:title "Hide Artifacts" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to hide artifacts associated with their behaviors to evade detection. Mobile operating systems have features and developer APIs to hide various artifacts, such as an application’s launcher icon. These APIs have legitimate usages, such as hiding an icon to avoid application drawer clutter when an application does not have a usable interface. Adversaries may abuse these features and APIs to hide artifacts from the user to evade detection." ;
    skos:exactMatch d3f:T1628,
        mitre-attack:T1628 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1629 a owl:Class ;
    rdfs:label "T1629" ;
    d3f:attack-id "T1629" ;
    dcterms:title "Impair Defenses" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may maliciously modify components of a victim environment in order to hinder or disable defensive mechanisms. This not only involves impairing preventative defenses, such as anti-virus, but also detection capabilities that defenders can use to audit activity and identify malicious behavior. This may span both native defenses as well as supplemental capabilities installed by users or mobile endpoint administrators." ;
    skos:exactMatch d3f:T1629,
        mitre-attack:T1629 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1630 a owl:Class ;
    rdfs:label "T1630" ;
    d3f:attack-id "T1630" ;
    dcterms:title "Indicator Removal on Host" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may delete, alter, or hide generated artifacts on a device, including files, jailbreak status, or the malicious application itself. These actions may interfere with event collection, reporting, or other notifications used to detect intrusion activity. This may compromise the integrity of mobile security solutions by causing notable events or information to go unreported." ;
    skos:exactMatch d3f:T1630,
        mitre-attack:T1630 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1643 a owl:Class ;
    rdfs:label "T1643" ;
    d3f:attack-id "T1643" ;
    dcterms:title "Generate Traffic from Victim" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may generate outbound traffic from devices. This is typically performed to manipulate external outcomes, such as to achieve carrier billing fraud or to manipulate app store rankings or ratings. Outbound traffic is typically generated as SMS messages or general web traffic, but may take other forms as well." ;
    skos:exactMatch d3f:T1643,
        mitre-attack:T1643 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Timer a owl:Class ;
    rdfs:label "Timer" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Timer> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:RuntimeVariable ],
        d3f:Clock ;
    skos:definition "A timer or countdown timer is a type of clock that starts from a specified time duration and stops upon reaching 00:00. It can also usually be stopped manually before the whole duration has elapsed. An example of a simple timer is an hourglass. Commonly, a timer triggers an alarm when it ends. A timer can be implemented through hardware or software." ;
    skos:exactMatch d3f:Timer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimerEvent a owl:Class ;
    rdfs:label "TimerEvent" ;
    dcterms:title "Timer Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event involving a timer artifact, characterized by the initiation, expiration, modification, or cancellation of a countdown or interval-based temporal mechanism." ;
    skos:exactMatch d3f:TimerEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TunnelEvent a owl:Class ;
    rdfs:label "TunnelEvent" ;
    dcterms:title "Tunnel Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/classes/tunnel_activity> ;
    rdfs:subClassOf d3f:NetworkEvent ;
    skos:definition "An event involving the establishment, usage, or termination of a network tunnel. Tunnels provide encapsulated communication pathways across various layers, enabling secure, isolated, or virtualized transport of data." ;
    skos:exactMatch d3f:TunnelEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnsupervisedPreprocessing a owl:Class ;
    rdfs:label "UnsupervisedPreprocessing" ;
    d3f:d3fend-id "D3A-UP" ;
    d3f:kb-article "## References SAS Institute Inc. (n.d.). Decision Trees. In SAS® Visual Data Mining and Machine Learning.[Link](https://documentation.sas.com/doc/en/vdmmlcdc/8.4/vdmmladvug/n1e4spzcnv1f0fn1vsxhbzgdp1bb.htm)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Unsupervised Preprocessing" ;
    rdfs:subClassOf d3f:SemiSupervisedLearning ;
    skos:definition "When performing unsupervised learning, the machine is presented with unlabeled data. (Unlabeled data has no target.) Unsupervised learning algorithms seek to discover intrinsic patterns that underlie the data, such as a clustering parameter or a redundant parameter (dimension) that can be reduced." ;
    skos:exactMatch d3f:UnsupervisedPreprocessing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:X86CodeSegment a owl:Class ;
    rdfs:label "X86CodeSegment" ;
    rdfs:subClassOf d3f:ImageCodeSegmentEnum,
        d3f:ProcessCodeSegmentEnum,
        linkml:PermissibleValue ;
    skos:definition "X86 Code Segment" .

d3f:accesses a owl:DatatypeProperty ;
    rdfs:label "accesses" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02673854-n> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x accesses y: An subject x takes the action of reading from, writing into, or executing the stored information in the object y. Reads, writes, and executes are specific cases of accesses." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_participant a owl:DatatypeProperty ;
    rdfs:label "has-participant" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000057> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x has-participant y: The event x involves an object y as a participant, indicating that y plays some role in the event, whether actively, passively, or otherwise." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_counter_attack a owl:DatatypeProperty ;
    rdfs:label "may-counter-attack" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_tactically_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_data_property a owl:DatatypeProperty ;
    rdfs:label "process-data-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_artifact_data_property ;
    skos:definition "x process-data-property y: The process x has the data property y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0008 a owl:Class ;
    rdfs:label "AML_T0008" ;
    d3f:attack-id "AML.T0008" ;
    dcterms:title "Acquire Infrastructure" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0008> ;
    rdfs:subClassOf d3f:ATLASResourceDevelopmentTechnique ;
    skos:altLabel "AML.T0008" ;
    skos:definition """Adversaries may buy, lease, or rent infrastructure for use throughout their operation.
A wide variety of infrastructure exists for hosting and orchestrating adversary operations.
Infrastructure solutions include physical or cloud servers, domains, mobile devices, and third-party web services.
Free resources may also be used, but they are typically limited.
Infrastructure can also include physical components such as countermeasures that degrade or disrupt AI components or sensors, including printed materials, wearables, or disguises.

Use of these infrastructure solutions allows an adversary to stage, launch, and execute an operation.
Solutions may help adversary operations blend in with traffic that is seen as normal, such as contact to third-party web services.
Depending on the implementation, adversaries may use infrastructure that makes it difficult to physically tie back to them as well as utilize infrastructure that can be rapidly provisioned, modified, and shut down.""" ;
    skos:exactMatch d3f:AML.T0008,
        atlas:AML.T0008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0010 a owl:Class ;
    rdfs:label "AML_T0010" ;
    d3f:attack-id "AML.T0010" ;
    dcterms:title "AI Supply Chain Compromise" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0010> ;
    rdfs:subClassOf d3f:ATLASInitialAccessTechnique ;
    skos:altLabel "AML.T0010" ;
    skos:definition """Adversaries may gain initial access to a system by compromising the unique portions of the AI supply chain.
This could include [Hardware](/techniques/AML.T0010.000), [Data](/techniques/AML.T0010.002) and its annotations, parts of the AI [AI Software](/techniques/AML.T0010.001) stack, or the [Model](/techniques/AML.T0010.003) itself.
In some instances the attacker will need secondary access to fully carry out an attack using compromised components of the supply chain.""" ;
    skos:exactMatch d3f:AML.T0010,
        atlas:AML.T0010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0043 a owl:Class ;
    rdfs:label "AML_T0043" ;
    d3f:attack-id "AML.T0043" ;
    dcterms:title "Craft Adversarial Data" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0043> ;
    rdfs:subClassOf d3f:ATLASAIAttackStagingTechnique ;
    skos:altLabel "AML.T0043" ;
    skos:definition """Adversarial data are inputs to an AI model that have been modified such that they cause the adversary's desired effect in the target model.
Effects can range from misclassification, to missed detections, to maximizing energy consumption.
Typically, the modification is constrained in magnitude or location so that a human still perceives the data as if it were unmodified, but human perceptibility may not always be a concern depending on the adversary's intended effect.
For example, an adversarial input for an image classification task is an image the AI model would misclassify, but a human would still recognize as containing the correct class.

Depending on the adversary's knowledge of and access to the target model, the adversary may use different classes of algorithms to develop the adversarial example such as [White-Box Optimization](/techniques/AML.T0043.000), [Black-Box Optimization](/techniques/AML.T0043.001), [Black-Box Transfer](/techniques/AML.T0043.002), or [Manual Modification](/techniques/AML.T0043.003).

The adversary may [Verify Attack](/techniques/AML.T0042) their approach works if they have white-box or inference API access to the model.
This allows the adversary to gain confidence their attack is effective "live" environment where their attack may be noticed.
They can then use the attack at a later time to accomplish their goals.
An adversary may optimize adversarial examples for [Evade AI Model](/techniques/AML.T0015), or to [Erode AI Model Integrity](/techniques/AML.T0031).""" ;
    skos:exactMatch d3f:AML.T0043,
        atlas:AML.T0043 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0048 a owl:Class ;
    rdfs:label "AML_T0048" ;
    d3f:attack-id "AML.T0048" ;
    dcterms:title "External Harms" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0048> ;
    rdfs:subClassOf d3f:ATLASImpactTechnique ;
    skos:altLabel "AML.T0048" ;
    skos:definition """Adversaries may abuse their access to a victim system and use its resources or capabilities to further their goals by causing harms external to that system.
These harms could affect the organization (e.g. Financial Harm, Reputational Harm), its users (e.g. User Harm), or the general public (e.g. Societal Harm).""" ;
    skos:exactMatch d3f:AML.T0048,
        atlas:AML.T0048 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASAIModelAccessTechnique a owl:Class ;
    rdfs:label "ATLASAIModelAccessTechnique" ;
    dcterms:title "AI Model Access Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASAIModelAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASCollectionTechnique a owl:Class ;
    rdfs:label "ATLASCollectionTechnique" ;
    dcterms:title "Collection Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASCollectionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASCredentialAccessTechnique a owl:Class ;
    rdfs:label "ATLASCredentialAccessTechnique" ;
    dcterms:title "Credential Access Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASCredentialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASExecutionTechnique a owl:Class ;
    rdfs:label "ATLASExecutionTechnique" ;
    dcterms:title "Execution Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASExecutionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKEnterpriseThing a owl:Class ;
    rdfs:label "ATTACKEnterpriseThing" ;
    dcterms:title "ATTACK Enterprise Thing" ;
    rdfs:subClassOf d3f:ATTACKThing ;
    skos:exactMatch d3f:ATTACKEnterpriseThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKThing a owl:Class ;
    rdfs:label "ATTACKThing" ;
    dcterms:title "ATTACK Thing" ;
    rdfs:subClassOf d3f:ExternalThreatModelThing ;
    skos:definition "ATTACK things are concepts defined in the ATT&CK Framework." ;
    skos:exactMatch d3f:ATTACKThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessPolicyAdministration a owl:Class ;
    rdfs:label "AccessPolicyAdministration" ;
    d3f:d3fend-id "D3-APA" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Access Control Administration" ;
    dcterms:title "Access Policy Administration" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Access policy administration is the systematic process of defining, implementing, and managing access control policies that dictate user permissions to resources." ;
    skos:exactMatch d3f:AccessPolicyAdministration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Agent a owl:Class ;
    rdfs:label "Agent" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <https://schema.ocsf.io/objects/actor> ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:definition "An entity capable of performing intentional actions." ;
    skos:exactMatch d3f:Agent,
        spdx:Agent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Attacker a owl:Class ;
    rdfs:label "Attacker" ;
    rdfs:subClassOf d3f:Agent ;
    skos:closeMatch stix:ThreatActor ;
    skos:definition "An agent that attempts to exploit vulnerabilities to gain unauthorized access to data or systems." ;
    skos:exactMatch d3f:Attacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch unified_cyber_ontology:Identity .

d3f:CWE1059 a owl:Class ;
    rdfs:label "CWE_1059" ;
    d3f:cwe-id "CWE-1059" ;
    dcterms:title "Insufficient Technical Documentation" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1059" ;
    skos:definition "The product does not contain sufficient technical or engineering documentation (whether on paper or in electronic form) that contains descriptions of all the relevant software/hardware elements of the product, such as its usage, structure, architectural components, interfaces, design, implementation, configuration, operation, etc." ;
    skos:exactMatch d3f:CWE-1059,
        cwe:CWE-1059 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1164 a owl:Class ;
    rdfs:label "CWE_1164" ;
    d3f:cwe-id "CWE-1164" ;
    dcterms:title "Irrelevant Code" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1164" ;
    skos:definition "The product contains code that is not essential for execution, i.e. makes no state changes and has no side effects that alter data or control flow, such that removal of the code would have no impact to functionality or correctness." ;
    skos:exactMatch d3f:CWE-1164,
        cwe:CWE-1164 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1176 a owl:Class ;
    rdfs:label "CWE_1176" ;
    d3f:cwe-id "CWE-1176" ;
    dcterms:title "Inefficient CPU Computation" ;
    rdfs:subClassOf d3f:CWE405 ;
    skos:altLabel "CWE-1176" ;
    skos:definition "The product performs CPU computations using algorithms that are not as efficient as they could be for the needs of the developer, i.e., the computations can be optimized further." ;
    skos:exactMatch d3f:CWE-1176,
        cwe:CWE-1176 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1419 a owl:Class ;
    rdfs:label "CWE_1419" ;
    d3f:cwe-id "CWE-1419" ;
    dcterms:title "Incorrect Initialization of Resource" ;
    rdfs:subClassOf d3f:CWE665 ;
    skos:altLabel "CWE-1419" ;
    skos:definition "The product attempts to initialize a resource but does not correctly do so, which might leave the resource in an unexpected, incorrect, or insecure state when it is accessed." ;
    skos:exactMatch d3f:CWE-1419,
        cwe:CWE-1419 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE162 a owl:Class ;
    rdfs:label "CWE_162" ;
    d3f:cwe-id "CWE-162" ;
    dcterms:title "Improper Neutralization of Trailing Special Elements" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-162" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes trailing special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-162,
        cwe:CWE-162 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE172 a owl:Class ;
    rdfs:label "CWE_172" ;
    d3f:cwe-id "CWE-172" ;
    dcterms:title "Encoding Error" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-172" ;
    skos:definition "The product does not properly encode or decode the data, resulting in unexpected values." ;
    skos:exactMatch d3f:CWE-172,
        cwe:CWE-172 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE203 a owl:Class ;
    rdfs:label "CWE_203" ;
    d3f:cwe-id "CWE-203" ;
    d3f:synonym "Side Channel Attack" ;
    dcterms:title "Observable Discrepancy" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-203" ;
    skos:definition "The product behaves differently or sends different responses under different circumstances in a way that is observable to an unauthorized actor, which exposes security-relevant information about the state of the product, such as whether a particular operation was successful or not." ;
    skos:exactMatch d3f:CWE-203,
        cwe:CWE-203 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE226 a owl:Class ;
    rdfs:label "CWE_226" ;
    d3f:cwe-id "CWE-226" ;
    dcterms:title "Sensitive Information in Resource Not Removed Before Reuse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE459 ],
        d3f:CWE212 ;
    skos:altLabel "CWE-226" ;
    skos:definition "The product releases a resource such as memory or a file so that it can be made available for reuse, but it does not clear or \"zeroize\" the information contained in the resource before the product performs a critical state transition or makes the resource available for reuse by other entities." ;
    skos:exactMatch d3f:CWE-226,
        cwe:CWE-226 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE295 a owl:Class ;
    rdfs:label "CWE_295" ;
    d3f:cwe-id "CWE-295" ;
    dcterms:title "Improper Certificate Validation" ;
    rdfs:subClassOf d3f:CWE287 ;
    skos:altLabel "CWE-295" ;
    skos:definition "The product does not validate, or incorrectly validates, a certificate." ;
    skos:exactMatch d3f:CWE-295,
        cwe:CWE-295 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE404 a owl:Class ;
    rdfs:label "CWE_404" ;
    d3f:cwe-id "CWE-404" ;
    dcterms:title "Improper Resource Shutdown or Release" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-404" ;
    skos:definition "The product does not release or incorrectly releases a resource before it is made available for re-use." ;
    skos:exactMatch d3f:CWE-404,
        cwe:CWE-404 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE59 a owl:Class ;
    rdfs:label "CWE_59" ;
    d3f:cwe-id "CWE-59" ;
    d3f:synonym "Zip Slip" ;
    dcterms:title "Improper Link Resolution Before File Access ('Link Following')" ;
    rdfs:subClassOf d3f:CWE706 ;
    skos:altLabel "CWE-59" ;
    skos:definition "The product attempts to access a file based on the filename, but it does not properly prevent that filename from identifying a link or shortcut that resolves to an unintended resource." ;
    skos:exactMatch d3f:CWE-59,
        cwe:CWE-59 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE628 a owl:Class ;
    rdfs:label "CWE_628" ;
    d3f:cwe-id "CWE-628" ;
    dcterms:title "Function Call with Incorrectly Specified Arguments" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-628" ;
    skos:definition "The product calls a function, procedure, or routine with arguments that are not correctly specified, leading to always-incorrect behavior and resultant weaknesses." ;
    skos:exactMatch d3f:CWE-628,
        cwe:CWE-628 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE642 a owl:Class ;
    rdfs:label "CWE_642" ;
    d3f:cwe-id "CWE-642" ;
    dcterms:title "External Control of Critical State Data" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-642" ;
    skos:definition "The product stores security-critical state information about its users, or the product itself, in a location that is accessible to unauthorized actors." ;
    skos:exactMatch d3f:CWE-642,
        cwe:CWE-642 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE662 a owl:Class ;
    rdfs:label "CWE_662" ;
    d3f:cwe-id "CWE-662" ;
    dcterms:title "Improper Synchronization" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE691 ],
        d3f:CWE664 ;
    skos:altLabel "CWE-662" ;
    skos:definition "The product utilizes multiple threads or processes to allow temporary access to a shared resource that can only be exclusive to one process at a time, but it does not properly synchronize these actions, which might cause simultaneous accesses of this resource by multiple threads or processes." ;
    skos:exactMatch d3f:CWE-662,
        cwe:CWE-662 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE666 a owl:Class ;
    rdfs:label "CWE_666" ;
    d3f:cwe-id "CWE-666" ;
    dcterms:title "Operation on Resource in Wrong Phase of Lifetime" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-666" ;
    skos:definition "The product performs an operation on a resource at the wrong phase of the resource's lifecycle, which can lead to unexpected behaviors." ;
    skos:exactMatch d3f:CWE-666,
        cwe:CWE-666 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE672 a owl:Class ;
    rdfs:label "CWE_672" ;
    d3f:cwe-id "CWE-672" ;
    dcterms:title "Operation on a Resource after Expiration or Release" ;
    rdfs:subClassOf d3f:CWE666 ;
    skos:altLabel "CWE-672" ;
    skos:definition "The product uses, accesses, or otherwise operates on a resource after that resource has been expired, released, or revoked." ;
    skos:exactMatch d3f:CWE-672,
        cwe:CWE-672 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE675 a owl:Class ;
    rdfs:label "CWE_675" ;
    d3f:cwe-id "CWE-675" ;
    dcterms:title "Multiple Operations on Resource in Single-Operation Context" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-675" ;
    skos:definition "The product performs the same operation on a resource two or more times, when the operation should only be applied once." ;
    skos:exactMatch d3f:CWE-675,
        cwe:CWE-675 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE681 a owl:Class ;
    rdfs:label "CWE_681" ;
    d3f:cwe-id "CWE-681" ;
    dcterms:title "Incorrect Conversion between Numeric Types" ;
    rdfs:subClassOf d3f:CWE704 ;
    skos:altLabel "CWE-681" ;
    skos:definition "When converting from one data type to another, such as long to integer, data can be omitted or translated in a way that produces unexpected values. If the resulting values are used in a sensitive context, then dangerous behaviors may occur." ;
    skos:exactMatch d3f:CWE-681,
        cwe:CWE-681 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE77 a owl:Class ;
    rdfs:label "CWE_77" ;
    d3f:cwe-id "CWE-77" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Command injection" ;
    dcterms:title "Improper Neutralization of Special Elements used in a Command ('Command Injection')" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-77" ;
    skos:definition "The product constructs all or part of a command using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended command when it is sent to a downstream component." ;
    skos:exactMatch d3f:CWE-77,
        cwe:CWE-77 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE787 a owl:Class ;
    rdfs:label "CWE_787" ;
    d3f:cwe-id "CWE-787" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Memory Corruption" ;
    dcterms:title "Out-of-bounds Write" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-787" ;
    skos:definition "The product writes data past the end, or before the beginning, of the intended buffer." ;
    skos:exactMatch d3f:CWE-787,
        cwe:CWE-787 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE913 a owl:Class ;
    rdfs:label "CWE_913" ;
    d3f:cwe-id "CWE-913" ;
    dcterms:title "Improper Control of Dynamically-Managed Code Resources" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-913" ;
    skos:definition "The product does not properly restrict reading from or writing to dynamically-managed code resources such as variables, objects, classes, attributes, functions, or executable instructions or statements." ;
    skos:exactMatch d3f:CWE-913,
        cwe:CWE-913 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ClientComputer a owl:Class ;
    rdfs:label "ClientComputer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Client Computer" ;
    rdfs:seeAlso dbr:Client_\(computing\),
        dbr:Host_\(network\) ;
    rdfs:subClassOf d3f:Host ;
    skos:definition "A client computer is a host that accesses a service made available by a server. The server is often (but not always) on another computer system, in which case the client accesses the service by way of a network." ;
    skos:exactMatch d3f:ClientComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

