    skos:exactMatch d3f:CWE-560,
        cwe:CWE-560 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE561 a owl:Class ;
    rdfs:label "CWE_561" ;
    d3f:cwe-id "CWE-561" ;
    dcterms:title "Dead Code" ;
    rdfs:subClassOf d3f:CWE1164 ;
    skos:altLabel "CWE-561" ;
