    skos:exactMatch d3f:CWE-550,
        cwe:CWE-550 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE551 a owl:Class ;
    rdfs:label "CWE_551" ;
    d3f:cwe-id "CWE-551" ;
    dcterms:title "Incorrect Behavior Order: Authorization Before Parsing and Canonicalization" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE863 ],
        d3f:CWE696 ;
    skos:altLabel "CWE-551" ;
