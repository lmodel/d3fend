    rdfs:label "AssociationRuleLearning" ;
    d3f:d3fend-id "D3A-ARL" ;
    d3f:kb-article "## References Association rule learning. (n.d.). Wikipedia. [Link](https://en.wikipedia.org/wiki/Association_rule_learning)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Association Rule Learning" ;
    rdfs:subClassOf d3f:UnsupervisedLearning ;
