d3f:WindowsRegistry a owl:Class ;
    rdfs:label "WindowsRegistry" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows Registry" ;
    rdfs:seeAlso dbr:Windows_Registry,
        <https://learn.microsoft.com/en-us/troubleshoot/windows-server/performance/windows-registry-advanced-users> ;
    rdfs:subClassOf d3f:SystemConfigurationDatabase ;
    skos:definition "The Windows Registry is a hierarchical database that stores low-level settings for the Microsoft Windows operating system and for applications that opt to use the registry. The kernel, device drivers, services, Security Accounts Manager, and user interface can all use the registry. The registry also allows access to counters for profiling system performance." ;
    skos:exactMatch d3f:WindowsRegistry ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKey a owl:Class ;
    rdfs:label "WindowsRegistryKey" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows Registry Key" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Windows_Registry#Keys_and_values>,
        <https://learn.microsoft.com/en-us/windows/win32/sysinfo/registry-hives>,
        <https://learn.microsoft.com/en-us/windows/win32/sysinfo/structure-of-the-registry>,
        <https://schema.ocsf.io/objects/registry_key> ;
    rdfs:subClassOf d3f:SystemConfigurationDatabaseRecord ;
    skos:definition "Windows Registry Keys are container objects similar to folders that contain subkeys and/or data entries called values. A key can be a 'Registry Hive' when it is root key of a logical group of keys, subkeys, and values that has a set of supporting files loaded into memory when the operating system is started or a user logs in." ;
    skos:exactMatch d3f:WindowsRegistryKey,
        stix:WindowsRegistryKey,
        unified_cyber_ontology:WindowsRegistryKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyCreationEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyCreationEvent" ;
    dcterms:title "Windows Registry Key Creation Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event where a new registry key is added to the Windows Registry, establishing a new hierarchical node for configuration." ;
    skos:exactMatch d3f:WindowsRegistryKeyCreationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyDeletionEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyDeletionEvent" ;
    dcterms:title "Windows Registry Key Deletion Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event representing the removal of a registry key from the Windows Registry, including its hierarchical structure and associated metadata." ;
    skos:exactMatch d3f:WindowsRegistryKeyDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyExportEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyExportEvent" ;
    dcterms:title "Windows Registry Key Export Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event representing the export of registry key data from the Windows Registry to an external file or format." ;
    skos:exactMatch d3f:WindowsRegistryKeyExportEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyImportEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyImportEvent" ;
    dcterms:title "Windows Registry Key Import Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event where registry key data is imported into the Windows Registry from an external source." ;
    skos:exactMatch d3f:WindowsRegistryKeyImportEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyReadEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyReadEvent" ;
    dcterms:title "Windows Registry Key Read Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event where a registry key is accessed to query its structure, properties, or associated metadata without modifying its state." ;
    skos:exactMatch d3f:WindowsRegistryKeyReadEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyRenamingEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyRenamingEvent" ;
    dcterms:title "Windows Registry Key Renaming Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event where the name of a registry key is changed, altering its identifier within the registry hierarchy." ;
    skos:exactMatch d3f:WindowsRegistryKeyRenamingEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyRestoreEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyRestoreEvent" ;
    dcterms:title "Windows Registry Key Restore Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event where a registry key is restored to a previous state using a backup or recovery mechanism." ;
    skos:exactMatch d3f:WindowsRegistryKeyRestoreEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeySetSecurityEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeySetSecurityEvent" ;
    dcterms:title "Windows Registry Key Set Security Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event representing the application or modification of access controls or security settings to a registry key." ;
    skos:exactMatch d3f:WindowsRegistryKeySetSecurityEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyUpdateEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyUpdateEvent" ;
    dcterms:title "Windows Registry Key Update Event" ;
    rdfs:subClassOf d3f:WindowsRegistryKeyEvent ;
    skos:definition "An event where an existing registry key is updated or reconfigured, reflecting changes to its metadata or properties." ;
    skos:exactMatch d3f:WindowsRegistryKeyUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryValue a owl:Class ;
    rdfs:label "WindowsRegistryValue" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows Registry Value" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/winreg/ns-winreg-valentw>,
        <https://learn.microsoft.com/en-us/windows/win32/sysinfo/structure-of-the-registry>,
        <https://schema.ocsf.io/objects/registry_value> ;
    rdfs:subClassOf d3f:SystemConfigurationDatabaseRecord ;
    skos:definition "A Windows Registry Value is a data structure consisting of a name, type, data (as a pointer), and the length. Windows Registry Values are always associated with a Windows Registry Key. They store the actual configuration data for the operating system and the programs that run on the system." ;
    skos:exactMatch d3f:WindowsRegistryValue,
        stix:WindowsRegistryValue,
        unified_cyber_ontology:WindowsRegistryValue ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryValueDeletionEvent a owl:Class ;
    rdfs:label "WindowsRegistryValueDeletionEvent" ;
    dcterms:title "Windows Registry Value Deletion Event" ;
    rdfs:subClassOf d3f:WindowsRegistryValueEvent ;
    skos:definition "An event where a registry value is deleted from the Windows Registry, permanently removing its associated data." ;
    skos:exactMatch d3f:WindowsRegistryValueDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryValueGetEvent a owl:Class ;
    rdfs:label "WindowsRegistryValueGetEvent" ;
    dcterms:title "Windows Registry Value Get Event" ;
    rdfs:subClassOf d3f:WindowsRegistryValueEvent ;
    skos:definition "An event where the data of a registry value is retrieved, typically to read its configuration or state." ;
    skos:exactMatch d3f:WindowsRegistryValueGetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryValueSetEvent a owl:Class ;
    rdfs:label "WindowsRegistryValueSetEvent" ;
    dcterms:title "Windows Registry Value Set Event" ;
    rdfs:subClassOf d3f:WindowsRegistryValueEvent ;
    skos:definition "An event where data is assigned to a registry value, either creating it or updating its existing content." ;
    skos:exactMatch d3f:WindowsRegistryValueSetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryValueUpdateEvent a owl:Class ;
    rdfs:label "WindowsRegistryValueUpdateEvent" ;
    dcterms:title "Windows Registry Value Update Event" ;
    rdfs:subClassOf d3f:WindowsRegistryValueEvent ;
    skos:definition "An event indicating changes to the data or configuration of an existing registry value within the Windows Registry." ;
    skos:exactMatch d3f:WindowsRegistryValueUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsResumeThread a owl:Class ;
    rdfs:label "WindowsResumeThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows ResumeThread" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-resumethread> ;
    rdfs:subClassOf d3f:OSAPIResumeThread ;
    skos:definition "Decrements a thread's suspend count. When the suspend count is decremented to zero, the execution of the thread is resumed." ;
    skos:exactMatch d3f:WindowsResumeThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsSetThreadContext a owl:Class ;
