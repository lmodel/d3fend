d3f:Actuator a owl:Class ;
    rdfs:label "Actuator" ;
    rdfs:seeAlso dbr:Actuator ;
    rdfs:subClassOf d3f:OutputDevice ;
    skos:definition "An actuator is a mechanical or electromechanical device that, upon receiving a relatively low-energy control signal (e.g., electrical voltage, fluid pressure, or human force), translates its primary energy source (electric, hydraulic, or pneumatic) into targeted mechanical motion or adjustment. It typically works in conjunction with a control device (like a valve or logic driver) and is central to automation, enabling machines or systems to move, open, close, or otherwise manipulate their components or environment. By amplifying or redirecting energy from one form to another, the actuator executes control commands, thereby automating processes in industrial, automotive, aerospace, and other domains where precise mechanical action is essential." ;
    skos:exactMatch d3f:Actuator ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AddressSpace a owl:Class ;
    rdfs:label "AddressSpace" ;
    dcterms:title "Address Space" ;
    rdfs:seeAlso <https://dbpedia.org/page/Address_space> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "An address space defines a range of discrete addresses, each of which may correspond to a network host, peripheral device, disk sector, a memory cell or other logical or physical entity. For software programs to save and retrieve stored data, each unit of data must have an address where it can be located. The number of address spaces available depends on the underlying address structure, which is usually limited by the computer architecture being used." ;
    skos:exactMatch d3f:AddressSpace ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AdministrativeNetworkTraffic a owl:Class ;
    rdfs:label "AdministrativeNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Administrative Network Traffic" ;
    rdfs:seeAlso dbr:Remote_administration ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "Administrative network traffic is network traffic related to the remote administration or control of hosts or devices through a standard remote administrative protocol.  Remote shells, terminals, RDP, and VNC are examples of these protocols, which are typically only used by administrators." ;
    skos:exactMatch d3f:AdministrativeNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AdobePDFFile1.3 a owl:Class ;
    rdfs:label "AdobePDFFile1_3" ;
    rdfs:subClassOf d3f:DocumentFileEnum,
        linkml:PermissibleValue ;
    skos:definition "Adobe PDF File 1.3" .

d3f:ApplicationConfigurationDatabase a owl:Class ;
    rdfs:label "ApplicationConfigurationDatabase" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Configuration Database" ;
    rdfs:subClassOf d3f:ConfigurationDatabase ;
    skos:definition "A database used to hold application configuration data." ;
    skos:exactMatch d3f:ApplicationConfigurationDatabase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationConfigurationHardening a owl:Class ;
    rdfs:label "ApplicationConfigurationHardening" ;
    d3f:d3fend-id "D3-ACH" ;
    d3f:kb-article "## How it works Application configuration settings can be configured to limit the permissions on an application or disable certain vulnerable application features. Hardening an application's configuration involves analyzing not only the application but also the environment in which the application" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Configuration Hardening" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:broadMatch d3f:T1114,
        d3f:T1562,
        d3f:T1564 ;
    skos:definition "Modifying an application's configuration to reduce its attack surface." ;
    skos:exactMatch d3f:ApplicationConfigurationHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.003,
        mitre-attack:T1562.002,
        mitre-attack:T1562.003,
        mitre-attack:T1564.008 .

d3f:ApplicationDeletionEvent a owl:Class ;
    rdfs:label "ApplicationDeletionEvent" ;
    dcterms:title "Application Deletion Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event capturing the removal of an application from a system, ensuring its binaries, configuration files, and registry entries are deleted or deactivated." ;
    skos:exactMatch d3f:ApplicationDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationDisableEvent a owl:Class ;
    rdfs:label "ApplicationDisableEvent" ;
    dcterms:title "Application Disable Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event capturing the disabling of an application, preventing it from being operational or accessed until re-enabled." ;
    skos:exactMatch d3f:ApplicationDisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationEnableEvent a owl:Class ;
    rdfs:label "ApplicationEnableEvent" ;
    dcterms:title "Application Enable Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event representing the enabling of an application, allowing it to be started or accessed when required." ;
    skos:exactMatch d3f:ApplicationEnableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationInstallationEvent a owl:Class ;
    rdfs:label "ApplicationInstallationEvent" ;
    dcterms:title "Application Installation Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event representing the installation of an application onto a system, making it available for use and interaction." ;
    skos:exactMatch d3f:ApplicationInstallationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationLayerFirewall a owl:Class ;
    rdfs:label "ApplicationLayerFirewall" ;
    dcterms:title "Application Layer Firewall" ;
    rdfs:seeAlso dbr:Application_firewall ;
    rdfs:subClassOf d3f:Firewall ;
    skos:altLabel "Application Firewall" ;
    skos:definition "An application firewall is a form of firewall that controls input, output, and/or access from, to, or by an application or service. It operates by monitoring and potentially blocking the input, output, or system service calls that do not meet the configured policy of the firewall. The application firewall is typically built to control all network traffic on any OSI layer up to the application layer. It is able to control applications or services specifically, unlike a stateful network firewall, which is - without additional software - unable to control network traffic regarding a specific application. There are two primary categories of application firewalls, network-based application firewalls and host-based application firewalls." ;
    skos:exactMatch d3f:ApplicationLayerFirewall ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationPerformanceMonitoring a owl:Class ;
    rdfs:label "ApplicationPerformanceMonitoring" ;
    d3f:d3fend-id "D3-APM" ;
    d3f:kb-article "## How it works Keeping track of the controller cycle time by logging it, setting alarms, and correlating with other events. Changes to cycle time can be indicative of injecting new logic, deleting logic, or system failures." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Performance Monitoring" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:definition "Monitoring the count and duration of the application or program cycle." ;
    skos:exactMatch d3f:ApplicationPerformanceMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationProtocolCommandAnalysis a owl:Class ;
    rdfs:label "ApplicationProtocolCommandAnalysis" ;
    d3f:d3fend-id "D3-APCA" ;
    d3f:kb-article "## How it works This technique requires the ability to parse application layer protocols to understand the commands being sent to a remote service. Signature-based or statistical analysis may be employed to identify unauthorized commands being sent. These commands can be observed by monitoring netwo" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Protocol Command Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:ExfiltrationTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1003,
        d3f:T1021,
        d3f:T1048,
        d3f:T1071,
        d3f:T1090,
        d3f:T1098,
