    rdfs:subPropertyOf d3f:attack_may_be_countered_by ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_hardened_against_by a owl:DatatypeProperty ;
    rdfs:label "may-be-hardened-against-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:attack_may_be_countered_by ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_invoked_by a owl:DatatypeProperty ;
    rdfs:label "may-be-invoked-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_isolated_by a owl:DatatypeProperty ;
    rdfs:label "may-be-isolated-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:attack_may_be_countered_by ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_modified_by a owl:DatatypeProperty ;
    rdfs:label "may-be-modified-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_block a owl:DatatypeProperty ;
    rdfs:label "may-block" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-block y: They entity x may block the thing y; that is, 'x blocks y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_contain a owl:DatatypeProperty ;
    rdfs:label "may-contain" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "to potentially have as contents or constituent parts; comprise; include." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_corrupt a owl:DatatypeProperty ;
