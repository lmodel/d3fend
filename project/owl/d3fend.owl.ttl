    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:ImageToImageTranslationGAN ;
    skos:definition "Pix2Pix is based on condtional GAN architecture and are trained on paired set of images or scenes from two domains to be used for translation." ;
    skos:exactMatch d3f:Pix2Pix ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PlatformUptime a owl:Class ;
    rdfs:label "PlatformUptime" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Platform Uptime" ;
    rdfs:subClassOf d3f:SystemPlatformVariable ;
    skos:definition "A variable that notes the amount of time a platform has been running since its last power cycle or reset." ;
    skos:exactMatch d3f:PlatformUptime ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "In OT controllers this may not be a default tag rather something that should be defined using other system tags." .

d3f:PlatformUptimeMonitoring a owl:Class ;
    rdfs:label "PlatformUptimeMonitoring" ;
    d3f:d3fend-id "D3-PUM" ;
    d3f:kb-article "## How it works Monitoring the time since the last power cycle or restart alerts operators to unexpected restarts and their frequency. This can indicate potential issues or malicious activity, and provides valuable information for forensic investigations. ## Considerations The source of the variabl" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Platform Uptime Monitoring" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:definition "Monitor the amount of time since the last power cycle or restart." ;
    skos:exactMatch d3f:PlatformUptimeMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PointEstimation a owl:Class ;
    rdfs:label "PointEstimation" ;
    d3f:d3fend-id "D3A-PE" ;
    d3f:kb-article "## References Pennsylvania State University. (n.d.). Statistical Inference and Estimation. [Link](https://online.stat.psu.edu/stat504/lesson/statistical-inference-and-estimation)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Point Estimation" ;
    rdfs:subClassOf d3f:Estimation ;
    skos:definition "A point estimation is a single value that estimates the parameter. Point estimates are single values calculated from the sample" ;
    skos:exactMatch d3f:PointEstimation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PointerAuthentication a owl:Class ;
    rdfs:label "PointerAuthentication" ;
    d3f:d3fend-id "D3-PAN" ;
    d3f:kb-article "## How It Works Pointer Authentication (frequently referred to as PAC, although the technique is properly Pointer Authentication) is a security feature to provide protection against attackers with memory read/write access. A Pointer Authentication Code (PAC) is a cryptographic hash or derivative c" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pointer Authentication" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:definition "Comparing the cryptographic hash or derivative of a pointer's value to an expected value." ;
    skos:exactMatch d3f:PointerAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PointerDereferencingFunction a owl:Class ;
    rdfs:label "PointerDereferencingFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pointer Dereferencing Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "A function which has an operation which dereferences a pointer." ;
    skos:exactMatch d3f:PointerDereferencingFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "Note, this is not the actual code which performs the dereferencing operation internal to an application runtime." .

d3f:PowerAndThermalDeviceEvent a owl:Class ;
    rdfs:label "PowerAndThermalDeviceEvent" ;
    dcterms:title "Power and Thermal Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event involving power supplies, batteries, or thermal management devices. These events represent changes in power states, temperature thresholds, or cooling system activity." ;
    skos:exactMatch d3f:PowerAndThermalDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PowerShellProfileScript a owl:Class ;
    rdfs:label "PowerShellProfileScript" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "PowerShell Profile Script" ;
    rdfs:seeAlso <https://docs.microsoft.com/en-us/powershell/module/microsoft.powershell.core/about/about_profiles?view=powershell-7.1> ;
    rdfs:subClassOf d3f:UserInitScript ;
    skos:definition "A PowerShell profile script is a script that runs when PowerShell starts and can be used as a logon script to customize user environments." ;
    skos:exactMatch d3f:PowerShellProfileScript ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PreAuthenticationEvent a owl:Class ;
    rdfs:label "PreAuthenticationEvent" ;
    dcterms:title "Pre-Authentication Event" ;
    rdfs:subClassOf d3f:AuthenticationEvent ;
    skos:definition "An event representing preparatory steps or processes conducted prior to the primary authentication operation. Pre-authentication often involves initial protocol exchanges, cryptographic challenges, or the validation of supplemental factors (e.g., pre-shared keys) to ensure the readiness and security of the authentication workflow." ;
    skos:exactMatch d3f:PreAuthenticationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrincipalComponentAnalysis a owl:Class ;
    rdfs:label "PrincipalComponentAnalysis" ;
    d3f:d3fend-id "D3A-PCA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Multivariate statistics. [Link](https://en.wikipedia.org/wiki/Multivariate_statistics)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "PCA" ;
    dcterms:title "Principal Component Analysis" ;
    rdfs:subClassOf d3f:MultivariateAnalysis ;
    skos:definition "Principal components analysis (PCA) creates a new set of orthogonal variables that contain the same information as the original set. It rotates the axes of variation to give a new set of orthogonal axes, ordered so that they summarize decreasing proportions of the variation." ;
    skos:exactMatch d3f:PrincipalComponentAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrincipalComponentsAnalysis a owl:Class ;
    rdfs:label "PrincipalComponentsAnalysis" ;
    d3f:d3fend-id "D3A-PCA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Principal component analysis. [Link](https://en.wikipedia.org/wiki/Principal_component_analysis)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Principal Components Analysis" ;
    rdfs:subClassOf d3f:DimensionReduction ;
    skos:definition "Principal Component Analysis (PCA) is a statistic-based method of identifying patterns in a large dataset while increasing interpretability and preserving information." ;
    skos:exactMatch d3f:PrincipalComponentsAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrintServer a owl:Class ;
    rdfs:label "PrintServer" ;
    dcterms:title "Print Server" ;
    rdfs:seeAlso dbr:Print_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A print server, or printer server, is a device that connects printers to client computers over a network. It accepts print jobs from the computers and sends the jobs to the appropriate printers, queuing the jobs locally to accommodate the fact that work may arrive more quickly than the printer can actually handle." ;
    skos:exactMatch d3f:PrintServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrivateKey a owl:Class ;
    rdfs:label "PrivateKey" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Private Key" ;
    rdfs:seeAlso dbr:Public-key_cryptography ;
    rdfs:subClassOf d3f:AsymmetricKey ;
    skos:definition "A private key can be used to decrypt messages encrypted using the corresponding public key, or used to sign a message that can be authenticated with the corresponding public key." ;
    skos:exactMatch d3f:PrivateKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrivilegedUserAccount a owl:Class ;
    rdfs:label "PrivilegedUserAccount" ;
    dcterms:title "Privileged User Account" ;
    rdfs:seeAlso <https://www.cyberark.com/resources/blog/7-types-of-privileged-accounts-service-accounts-and-more>,
        <https://www.ssh.com/iam/user/privileged-account> ;
    rdfs:subClassOf d3f:UserAccount ;
    skos:definition "A privileged account is a user account that has more privileges than ordinary users. Privileged accounts might, for example, be able to install or remove software, upgrade the operating system, or modify system or application configurations. They might also have access to files that are not normally accessible to standard users. Typical examples are root and administrator accounts. But there also service accounts, system accounts, etc. Privileged accounts are especially powerful, and should be monitored especially closely." ;
    skos:exactMatch d3f:PrivilegedUserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProbabilisticLogic a owl:Class ;
    rdfs:label "ProbabilisticLogic" ;
    d3f:d3fend-id "D3A-PL" ;
    d3f:kb-article "## References 1. Probabilistic logic. (2023, June 5). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Probabilistic_logic)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Probabilistic Logic" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "Probabilistic logic extends traditional logic truth tables with probabilistic expressions." ;
    skos:exactMatch d3f:ProbabilisticLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessAccessEvent a owl:Class ;
    rdfs:label "ProcessAccessEvent" ;
    dcterms:title "Process Access Event" ;
    rdfs:subClassOf d3f:ProcessEvent ;
    skos:definition "An event where one process interacts with another, such as reading memory, inspecting state, or altering behavior." ;
    skos:exactMatch d3f:ProcessAccessEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessCodeSegmentVerification a owl:Class ;
    rdfs:label "ProcessCodeSegmentVerification" ;
    d3f:d3fend-id "D3-PCSV" ;
    d3f:kb-article "## How it works A process code segment is an executable portion of computer memory allocated to a particular process. Process Code Segment Verification implements verification to compare a process code segment to some expected value. ### Verification logic Verification can occur during application" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Code Segment Verification" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1055,
        d3f:T1056 ;
    skos:definition "Comparing the \"text\" or \"code\" memory segments to a source of truth." ;
    skos:exactMatch d3f:ProcessCodeSegmentVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1055.012,
        mitre-attack:T1056.004,
        mitre-attack:T1068,
        mitre-attack:T1203,
        mitre-attack:T1210,
        mitre-attack:T1211,
        mitre-attack:T1212 .

