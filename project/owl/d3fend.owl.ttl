d3f:TA0107 a owl:Class ;
    rdfs:label "TA0107" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inhibit Response Function" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTactic ],
        d3f:ATTACKICSTactic,
        d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Inhibit Response Function" ;
    skos:exactMatch d3f:TA0107 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TA0108 a owl:Class ;
    rdfs:label "TA0108" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Initial Access" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTactic ],
        d3f:ATTACKICSTactic,
        d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Initial Access" ;
    skos:exactMatch d3f:TA0108 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TA0109 a owl:Class ;
    rdfs:label "TA0109" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Lateral Movement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTactic ],
        d3f:ATTACKICSTactic,
        d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Lateral Movement" ;
    skos:exactMatch d3f:TA0109 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TA0110 a owl:Class ;
    rdfs:label "TA0110" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Persistence" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTactic ],
        d3f:ATTACKICSTactic,
        d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Persistence" ;
    skos:exactMatch d3f:TA0110 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TA0111 a owl:Class ;
    rdfs:label "TA0111" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Privilege Escalation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTactic ],
        d3f:ATTACKICSTactic,
        d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Privilege Escalation" ;
    skos:exactMatch d3f:TA0111 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Technique a owl:Class ;
    rdfs:label "Technique" ;
    rdfs:subClassOf d3f:Plan ;
    skos:exactMatch d3f:Technique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TestExecutionTool a owl:Class ;
    rdfs:label "TestExecutionTool" ;
    dcterms:title "Test Execution Tool" ;
    rdfs:seeAlso dbr:Test_execution_engine ;
    rdfs:subClassOf d3f:DeveloperApplication ;
    skos:altLabel "Test Execution Engine",
        "Test Executive",
        "Test Manager" ;
    skos:definition "A test execution tool is a type of software used to test software, hardware or complete systems.  Synonyms of test execution tool include test execution engine, test executive, test manager, test sequencer.  Two common forms in which a test execution engine may appear are as a: (a) module of a test software suite (test bench) or an integrated development environment, or (b) stand-alone application software." ;
    skos:exactMatch d3f:TestExecutionTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Time a owl:Class ;
    rdfs:label "Time" ;
    rdfs:seeAlso dbr:Time_in_physics ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:definition "Time is the one-dimensional continuum of temporal regions within which all processes unfold and at which all continuants exist. A temporal region is a specific portion of this continuum that may be either zero-dimensional (a temporal instant) or one-dimensional (a temporal interval). Temporal regions serve as the temporal boundaries and extents for occurrents (processes, events) and provide the temporal indexing for the existence of continuants (entities that persist through time)." ;
    skos:exactMatch d3f:Time ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TransferLearning a owl:Class ;
    rdfs:label "TransferLearning" ;
    d3f:d3fend-id "D3A-TL" ;
    d3f:kb-article "## References Transfer learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Transfer_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Transfer Learning" ;
    rdfs:seeAlso <https://arxiv.org/abs/1808.01974>,
        <https://arxiv.org/abs/1911.02685>,
        <https://journalofbigdata.springeropen.com/articles/10.1186/s40537-016-0043-6> ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:definition "Transfer learning (TL) is a research problem in machine learning (ML) that focuses on storing knowledge gained while solving one problem and applying it to a different but related problem." ;
    skos:exactMatch d3f:TransferLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TransformerBasedLearning a owl:Class ;
    rdfs:label "Transformer_basedLearning" ;
    d3f:d3fend-id "D3A-TBL" ;
    d3f:kb-article "## References \"Transformer (machine learning model).\" Wikipedia. [Link](https://en.wikipedia.org/wiki/Transformer_(machine_learning_model))." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Transformer-based Learning" ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:altLabel "Transformer-basedLearning" ;
    skos:definition "A transformer is a deep learning model. It is distinguished by its adoption of self-attention, differentially weighting the significance of each part of the input (which includes the recursive output) data." ;
    skos:exactMatch d3f:Transformer-basedLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TransportLayerEvent a owl:Class ;
    rdfs:label "TransportLayerEvent" ;
    dcterms:title "Transport Layer Event" ;
    rdfs:subClassOf d3f:NetworkEvent ;
    skos:definition "An event occurring at the transport layer, responsible for end-to-end communication and data transfer management." ;
    skos:exactMatch d3f:TransportLayerEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TrustedAttacker a owl:Class ;
    rdfs:label "TrustedAttacker" ;
    dcterms:title "Trusted Attacker" ;
    rdfs:subClassOf d3f:Attacker ;
    skos:definition "An individual who exploits their authorized access to conduct unauthorized actions, either intentionally or through negligence." ;
    skos:exactMatch d3f:TrustedAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UDPEvent a owl:Class ;
    rdfs:label "UDPEvent" ;
    dcterms:title "UDP Event" ;
    rdfs:subClassOf d3f:TransportLayerEvent ;
    skos:definition "An event involving the User Datagram Protocol (UDP), providing a connectionless datagram service with minimal protocol mechanisms." ;
    skos:exactMatch d3f:UDPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:URLEnum a owl:Class ;
    rdfs:label "URLEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:HTTPSURL d3f:HTTPURL d3f:WebSocketURL ) ;
    skos:definition "Enumeration of URL values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A Uniform Resource Locator (URL), commonly informally termed a web address (a term which is not defined identically) is a reference to a web resource that specifies its location on a computer network and a mechanism for retrieving it.A URL is a specific type of Uniform Resource Identifier (URI), alt" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:HTTPSURL,
        d3f:HTTPURL,
        d3f:WebSocketURL .

d3f:UserInterface a owl:Class ;
    rdfs:label "UserInterface" ;
    dcterms:title "User Interface" ;
    rdfs:seeAlso dbr:User_interface ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "UI" ;
    skos:definition "The user interface (UI), in the industrial design field of human-machine interaction, is the space where interactions between humans and machines occur. The goal of this interaction is to allow effective operation and control of the machine from the human end, whilst the machine simultaneously feeds back information that aids the operators' decision-making process. Examples of this broad concept of user interfaces include the interactive aspects of computer operating systems, hand tools, heavy machinery operator controls, and process controls. The design considerations applicable when creating user interfaces are related to or involve such disciplines as ergonomics and psychology." ;
    skos:exactMatch d3f:UserInterface ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VolumeSnapshot a owl:Class ;
    rdfs:label "VolumeSnapshot" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Volume Snapshot" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Shadow_Copy>,
        <https://kubernetes-csi.github.io/docs/snapshot-restore-feature.html> ;
    rdfs:subClassOf d3f:StorageSnapshot ;
    skos:definition "A volume snapshot is a point-in-time copy of a storage volume." ;
    skos:exactMatch d3f:VolumeSnapshot ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WatchdogTimer a owl:Class ;
    rdfs:label "WatchdogTimer" ;
    d3f:synonym "Watchdog" ;
    dcterms:title "Watchdog Timer" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Watchdog_timer> ;
    rdfs:subClassOf d3f:Timer ;
    skos:definition "A watchdog timer (WDT, or simply a watchdog) is an electronic or software timer that is used to detect and recover from computer malfunctions." ;
    skos:exactMatch d3f:WatchdogTimer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebNetworkTraffic a owl:Class ;
    rdfs:label "WebNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "Web network traffic is network traffic that uses a standard web protocol." ;
    skos:exactMatch d3f:WebNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebResource a owl:Class ;
    rdfs:label "WebResource" ;
    dcterms:title "Web Resource" ;
    rdfs:seeAlso dbr:Web_resource,
        <https://schema.ocsf.io/objects/web_resource> ;
    rdfs:subClassOf d3f:NetworkResource ;
    skos:definition "A web resource is a resource identified by a Uniform Resource Identifier (URI) and made available from one host to another host via a web protocol and across a network or networks." ;
    skos:exactMatch d3f:WebResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebServer a owl:Class ;
    rdfs:label "WebServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Server" ;
    rdfs:seeAlso dbr:Web_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A web server is server software, or hardware dedicated to running this software, that can satisfy client requests on the World Wide Web. A web server can, in general, contain one or more websites. A web server processes incoming network requests over HTTP and several other related protocols. While the major function is to serve content, a full implementation of HTTP also includes ways of receiving content from clients. This feature is used for submitting web forms, including uploading of files." ;
    skos:exactMatch d3f:WebServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebSessionAccessMediation a owl:Class ;
    rdfs:label "WebSessionAccessMediation" ;
    d3f:d3fend-id "D3-WSAM" ;
    d3f:kb-article "## How it works Web Session Access Mediation involves managing user access to web applications and services, ensuring secure and authorized sessions. This includes authenticating users, maintaining session integrity, and protecting against threats like session hijacking. Examples include accessing" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Session Access Mediation" ;
    rdfs:subClassOf d3f:NetworkResourceAccessMediation ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1003,
        d3f:T1505 ;
    skos:definition "Web session access mediation secures user sessions in web applications by employing robust authentication and integrity validation, along with adaptive threat mitigation techniques, to ensure that access to web resources is authorized and protected from session-related attacks." ;
    skos:exactMatch d3f:WebSessionAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1033,
        mitre-attack:T1212,
        mitre-attack:T1505.002,
        mitre-attack:T1550,
        mitre-attack:T1556 .

d3f:WindowsRegistryEvent a owl:Class ;
    rdfs:label "WindowsRegistryEvent" ;
    dcterms:title "Windows Registry Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "Events involving interactions with the Windows Registry, including keys, values, and associated security configurations." ;
    skos:exactMatch d3f:WindowsRegistryEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_use_case_object_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-use-case-object-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:executes a owl:DatatypeProperty ;
    rdfs:label "executes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02569242-v> ;
    rdfs:subPropertyOf d3f:accesses ;
    skos:definition "x executes y: The subject x takes the action of carrying out (executing) y, which is a single software module, function, or instruction." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_weakness_of a owl:ObjectProperty ;
    rdfs:label "may-be-weakness-of" ;
    rdfs:range d3f:Artifact ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_have_weakness a owl:ObjectProperty ;
    rdfs:label "may-have-weakness" ;
    rdfs:range d3f:Weakness ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_property a owl:DatatypeProperty ;
    rdfs:label "process-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x process-property y: Process x has the a process-property y.  This is generalization for specific process object properties." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_security_context a owl:DatatypeProperty ;
    rdfs:label "process-security-context" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_data_property ;
    skos:definition "x process-security-context y: The process x has the process security context data y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMD64CodeSegment a owl:Class ;
    rdfs:label "AMD64CodeSegment" ;
    rdfs:subClassOf d3f:ImageCodeSegmentEnum,
        d3f:ProcessCodeSegmentEnum,
        linkml:PermissibleValue ;
    skos:definition "AMD64 Code Segment" .

d3f:ARM32CodeSegment a owl:Class ;
    rdfs:label "ARM32CodeSegment" ;
    rdfs:subClassOf d3f:ImageCodeSegmentEnum,
        d3f:ProcessCodeSegmentEnum,
        linkml:PermissibleValue ;
    skos:definition "ARM32 Code Segment" .

d3f:ATTACKICSCommandAndControlTechnique a owl:Class ;
    rdfs:label "ATTACKICSCommandAndControlTechnique" ;
    dcterms:title "Command and Control Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSCommandAndControlTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileExfiltrationTechnique a owl:Class ;
    rdfs:label "ATTACKMobileExfiltrationTechnique" ;
    dcterms:title "Exfiltration Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileExfiltrationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileLateralMovementTechnique a owl:Class ;
    rdfs:label "ATTACKMobileLateralMovementTechnique" ;
    dcterms:title "Lateral Movement Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileLateralMovementTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessControlConfiguration a owl:Class ;
    rdfs:label "AccessControlConfiguration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Access Control Configuration" ;
    rdfs:seeAlso dbr:Access-control_list ;
    rdfs:subClassOf d3f:ConfigurationResource ;
    skos:definition "Information about what access permissions are granted to particular users for particular objects." ;
    skos:exactMatch d3f:AccessControlConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessToken a owl:Class ;
    rdfs:label "AccessToken" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Access Token" ;
    rdfs:seeAlso dbr:Access_token ;
    rdfs:subClassOf d3f:Credential ;
    skos:altLabel "Ticket",
        "Token" ;
    skos:definition "In computer systems, an access token contains the security credentials for a login session and identifies the user, the user's groups, the user's privileges, and, in some cases, a particular application. Typically one may be asked to enter the access token (e.g. 40 random characters) rather than the usual password (it therefore should be kept secret just like a password)." ;
    skos:exactMatch d3f:AccessToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Action a owl:Class ;
    rdfs:label "Action" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:Event ;
    skos:definition "An Action is a deliberate operation or activity performed by an entity." ;
    skos:exactMatch d3f:Action,
        oscal:Action,
        unified_cyber_ontology:Action ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AnalyticTechnique a owl:Class ;
    rdfs:label "AnalyticTechnique" ;
    dcterms:title "Analytic Technique" ;
    rdfs:seeAlso <https://dictionary.cambridge.org/us/dictionary/english/analytics> ;
    rdfs:subClassOf d3f:Technique ;
    skos:definition "A process in which a computer examines information using mathematical methods in order to find useful patterns." ;
    skos:exactMatch d3f:AnalyticTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationProcess a owl:Class ;
    rdfs:label "ApplicationProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Process" ;
    rdfs:seeAlso dbr:Application_software ;
    rdfs:subClassOf d3f:UserProcess ;
    skos:definition "An application process is an instance of an application computer program that is being executed." ;
    skos:exactMatch d3f:ApplicationProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthenticationEvent a owl:Class ;
    rdfs:label "AuthenticationEvent" ;
    dcterms:title "Authentication Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/authentication>,
        <https://schema.ocsf.io/classes/authentication> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:altLabel "Agent Authentication Event" ;
    skos:definition "An event capturing the systematic process of verifying an agent's identity within a system, involving credential validation and identity confirmation." ;
    skos:exactMatch d3f:AuthenticationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1023 a owl:Class ;
    rdfs:label "CWE_1023" ;
    d3f:cwe-id "CWE-1023" ;
    dcterms:title "Incomplete Comparison with Missing Factors" ;
    rdfs:subClassOf d3f:CWE697 ;
    skos:altLabel "CWE-1023" ;
    skos:definition "The product performs a comparison between entities that must consider multiple factors or characteristics of each entity, but the comparison does not include one or more of these factors." ;
    skos:exactMatch d3f:CWE-1023,
        cwe:CWE-1023 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1093 a owl:Class ;
    rdfs:label "CWE_1093" ;
    d3f:cwe-id "CWE-1093" ;
    dcterms:title "Excessively Complex Data Representation" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1093" ;
    skos:definition "The product uses an unnecessarily complex internal representation for its data structures or interrelationships between those structures." ;
    skos:exactMatch d3f:CWE-1093,
        cwe:CWE-1093 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1384 a owl:Class ;
    rdfs:label "CWE_1384" ;
    d3f:cwe-id "CWE-1384" ;
    dcterms:title "Improper Handling of Physical or Environmental Conditions" ;
    rdfs:subClassOf d3f:CWE703 ;
    skos:altLabel "CWE-1384" ;
    skos:definition "The product does not properly handle unexpected physical or environmental conditions that occur naturally or are artificially induced." ;
    skos:exactMatch d3f:CWE-1384,
        cwe:CWE-1384 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE266 a owl:Class ;
    rdfs:label "CWE_266" ;
    d3f:cwe-id "CWE-266" ;
    dcterms:title "Incorrect Privilege Assignment" ;
    rdfs:subClassOf d3f:CWE269 ;
    skos:altLabel "CWE-266" ;
    skos:definition "A product incorrectly assigns a privilege to a particular actor, creating an unintended sphere of control for that actor." ;
    skos:exactMatch d3f:CWE-266,
        cwe:CWE-266 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE287 a owl:Class ;
    rdfs:label "CWE_287" ;
    d3f:cwe-id "CWE-287" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "AuthC" ;
    dcterms:title "Improper Authentication" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-287" ;
    skos:definition "When an actor claims to have a given identity, the product does not prove or insufficiently proves that the claim is correct." ;
    skos:exactMatch d3f:CWE-287,
        cwe:CWE-287 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE327 a owl:Class ;
    rdfs:label "CWE_327" ;
    d3f:cwe-id "CWE-327" ;
    dcterms:title "Use of a Broken or Risky Cryptographic Algorithm" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-327" ;
    skos:definition "The product uses a broken or risky cryptographic algorithm or protocol." ;
    skos:exactMatch d3f:CWE-327,
        cwe:CWE-327 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE36 a owl:Class ;
    rdfs:label "CWE_36" ;
    d3f:cwe-id "CWE-36" ;
    dcterms:title "Absolute Path Traversal" ;
    rdfs:subClassOf d3f:CWE22 ;
    skos:altLabel "CWE-36" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize absolute path sequences such as \"/abs/path\" that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-36,
        cwe:CWE-36 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE435 a owl:Class ;
    rdfs:label "CWE_435" ;
    d3f:cwe-id "CWE-435" ;
    d3f:synonym "Emergent Fault" ;
    dcterms:title "Improper Interaction Between Multiple Correctly-Behaving Entities" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-435" ;
    skos:definition "An interaction error occurs when two entities have correct behavior when running independently of each other, but when they are integrated as components in a larger system or process, they introduce incorrect behaviors that may cause resultant weaknesses." ;
    skos:exactMatch d3f:CWE-435,
        cwe:CWE-435 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE471 a owl:Class ;
    rdfs:label "CWE_471" ;
    d3f:cwe-id "CWE-471" ;
    dcterms:title "Modification of Assumed-Immutable Data (MAID)" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-471" ;
    skos:definition "The product does not properly protect an assumed-immutable element from being modified by an attacker." ;
    skos:exactMatch d3f:CWE-471,
        cwe:CWE-471 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE506 a owl:Class ;
    rdfs:label "CWE_506" ;
    d3f:cwe-id "CWE-506" ;
    dcterms:title "Embedded Malicious Code" ;
    rdfs:subClassOf d3f:CWE912 ;
    skos:altLabel "CWE-506" ;
    skos:definition "The product contains code that appears to be malicious in nature." ;
    skos:exactMatch d3f:CWE-506,
        cwe:CWE-506 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE704 a owl:Class ;
    rdfs:label "CWE_704" ;
    d3f:cwe-id "CWE-704" ;
    dcterms:title "Incorrect Type Conversion or Cast" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-704" ;
    skos:definition "The product does not correctly convert an object, resource, or structure from one type to a different type." ;
    skos:exactMatch d3f:CWE-704,
        cwe:CWE-704 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE821 a owl:Class ;
    rdfs:label "CWE_821" ;
    d3f:cwe-id "CWE-821" ;
    dcterms:title "Incorrect Synchronization" ;
    rdfs:subClassOf d3f:CWE662 ;
    skos:altLabel "CWE-821" ;
    skos:definition "The product utilizes a shared resource in a concurrent manner, but it does not correctly synchronize access to the resource." ;
    skos:exactMatch d3f:CWE-821,
        cwe:CWE-821 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE862 a owl:Class ;
    rdfs:label "CWE_862" ;
    d3f:cwe-id "CWE-862" ;
    d3f:synonym "AuthZ" ;
    dcterms:title "Missing Authorization" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-862" ;
    skos:definition "The product does not perform an authorization check when an actor attempts to access a resource or perform an action." ;
    skos:exactMatch d3f:CWE-862,
        cwe:CWE-862 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "Broad and could apply to all resource accesses." .

d3f:CWE943 a owl:Class ;
    rdfs:label "CWE_943" ;
    d3f:cwe-id "CWE-943" ;
    d3f:synonym "NoSQL Injection, NoSQLi" ;
    dcterms:title "Improper Neutralization of Special Elements in Data Query Logic" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-943" ;
    skos:definition "The product generates a query intended to access or manipulate data in a data store such as a database, but it does not neutralize or incorrectly neutralizes special elements that can modify the intended logic of the query." ;
    skos:exactMatch d3f:CWE-943,
        cwe:CWE-943 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Clock a owl:Class ;
    rdfs:label "Clock" ;
    rdfs:seeAlso <https://csrc.nist.gov/glossary/term/clock> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A mechanism that generates periodic, accurately spaced signals for timekeeping applications. Clocks may be implemented in hardware or software and are essential for system operations, synchronization, and event ordering." ;
    skos:exactMatch d3f:Clock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CollaborativeSoftware a owl:Class ;
    rdfs:label "CollaborativeSoftware" ;
    dcterms:title "Collaborative Software" ;
    rdfs:seeAlso dbr:Collaborative_software ;
    rdfs:subClassOf d3f:UserApplication ;
    skos:definition "Collaborative software or groupware is application software designed to help people working on a common task to attain their goals. One of the earliest definitions of groupware is \"intentional group processes plus software to support them\". Collaborative software is a broad concept that overlaps considerably with computer-supported cooperative work (CSCW). According to Carstensen and Schmidt (1999) groupware is part of CSCW. The authors claim that CSCW, and thereby groupware, addresses \"how collaborative activities and their coordination can be supported by means of computer systems.\"" ;
    skos:exactMatch d3f:CollaborativeSoftware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Command a owl:Class ;
    rdfs:label "Command" ;
    rdfs:seeAlso dbr:Command_\(computing\) ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "A directive (i.e., an instruction specifying a procedure) which, when issued to a computer system, software, or hardware component, causes that entity to execute a specific action, operation, or computation." ;
    skos:exactMatch d3f:Command ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputingImage a owl:Class ;
    rdfs:label "ComputingImage" ;
    dcterms:title "Computing Image" ;
    rdfs:seeAlso <http://dbpedia.org/resource/System_image#Process_images> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A computing image captures the full state or contents of a computing entity, such as a process or volume." ;
    skos:exactMatch d3f:ComputingImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConfidenceEnum a owl:Class ;
    rdfs:label "ConfidenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#Low> <http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#Medium> <http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#High> ) ;
    skos:definition "Confidence level. Open enum: arbitrary string values also accepted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values <http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#High>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#Low>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#Medium> .

d3f:ConfigurationModificationEvent a owl:Class ;
    rdfs:label "ConfigurationModificationEvent" ;
    dcterms:title "Configuration Modification Event" ;
    rdfs:subClassOf d3f:ConfigurationEvent ;
    skos:definition "An event that changes the persisted state of configuration resources by adding, updating, or removing parameters, impacting the target component's behavior." ;
    skos:exactMatch d3f:ConfigurationModificationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ContentFiltering a owl:Class ;
    rdfs:label "ContentFiltering" ;
    d3f:d3fend-id "D3-CF" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Content Filtering" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:ExfiltrationTechnique,
        d3f:LateralMovementTechnique,
        d3f:T1003,
        d3f:T1027,
        d3f:T1036,
        d3f:T1037,
        d3f:T1048,
        d3f:T1053,
        d3f:T1055,
        d3f:T1070,
        d3f:T1071,
        d3f:T1074,
        d3f:T1114,
        d3f:T1127,
        d3f:T1137,
        d3f:T1204,
        d3f:T1218,
        d3f:T1505,
        d3f:T1543,
        d3f:T1546,
        d3f:T1547,
        d3f:T1548,
