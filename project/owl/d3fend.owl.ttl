    skos:exactMatch d3f:CWE-1126,
        cwe:CWE-1126 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1127 a owl:Class ;
    rdfs:label "CWE_1127" ;
    d3f:cwe-id "CWE-1127" ;
    dcterms:title "Compilation with Insufficient Warnings or Errors" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1127" ;
    skos:definition "The code is compiled without sufficient warnings enabled, which may prevent the detection of subtle bugs or quality issues." ;
    skos:exactMatch d3f:CWE-1127,
        cwe:CWE-1127 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE113 a owl:Class ;
    rdfs:label "CWE_113" ;
    d3f:cwe-id "CWE-113" ;
    d3f:synonym "HTTP Request Splitting" ;
    dcterms:title "Improper Neutralization of CRLF Sequences in HTTP Headers ('HTTP Request/Response Splitting')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE93 ],
        d3f:CWE436 ;
    skos:altLabel "CWE-113" ;
    skos:definition "The product receives data from an HTTP agent/component (e.g., web server, proxy, browser, etc.), but it does not neutralize or incorrectly neutralizes CR and LF characters before the data is included in outgoing HTTP headers." ;
    skos:exactMatch d3f:CWE-113,
        cwe:CWE-113 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE114 a owl:Class ;
    rdfs:label "CWE_114" ;
    d3f:cwe-id "CWE-114" ;
    dcterms:title "Process Control" ;
    rdfs:subClassOf d3f:CWE73 ;
    skos:altLabel "CWE-114" ;
    skos:definition "Executing commands or loading libraries from an untrusted source or in an untrusted environment can cause an application to execute malicious commands (and payloads) on behalf of an attacker." ;
    skos:exactMatch d3f:CWE-114,
        cwe:CWE-114 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE115 a owl:Class ;
    rdfs:label "CWE_115" ;
    d3f:cwe-id "CWE-115" ;
    dcterms:title "Misinterpretation of Input" ;
    rdfs:subClassOf d3f:CWE436 ;
    skos:altLabel "CWE-115" ;
    skos:definition "The product misinterprets an input, whether from an attacker or another product, in a security-relevant fashion." ;
    skos:exactMatch d3f:CWE-115,
        cwe:CWE-115 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE117 a owl:Class ;
    rdfs:label "CWE_117" ;
    d3f:cwe-id "CWE-117" ;
    d3f:synonym "Log forging" ;
    dcterms:title "Improper Output Neutralization for Logs" ;
    rdfs:subClassOf d3f:CWE116 ;
    skos:altLabel "CWE-117" ;
    skos:definition "The product constructs a log message from external input, but it does not neutralize or incorrectly neutralizes special elements when the message is written to a log file." ;
    skos:exactMatch d3f:CWE-117,
        cwe:CWE-117 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1174 a owl:Class ;
    rdfs:label "CWE_1174" ;
    d3f:cwe-id "CWE-1174" ;
    dcterms:title "ASP.NET Misconfiguration: Improper Model Validation" ;
    rdfs:subClassOf d3f:CWE1173 ;
    skos:altLabel "CWE-1174" ;
    skos:definition "The ASP.NET application does not use, or incorrectly uses, the model validation framework." ;
    skos:exactMatch d3f:CWE-1174,
        cwe:CWE-1174 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1190 a owl:Class ;
    rdfs:label "CWE_1190" ;
    d3f:cwe-id "CWE-1190" ;
    dcterms:title "DMA Device Enabled Too Early in Boot Phase" ;
    rdfs:subClassOf d3f:CWE696 ;
    skos:altLabel "CWE-1190" ;
    skos:definition "The product enables a Direct Memory Access (DMA) capable device before the security configuration settings are established, which allows an attacker to extract data from or gain privileges on the product." ;
    skos:exactMatch d3f:CWE-1190,
        cwe:CWE-1190 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1191 a owl:Class ;
    rdfs:label "CWE_1191" ;
    d3f:cwe-id "CWE-1191" ;
    dcterms:title "On-Chip Debug and Test Interface With Improper Access Control" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1191" ;
    skos:definition "The chip does not implement or does not correctly perform access control to check whether users are authorized to access internal registers and test modes through the physical debug/test interface." ;
    skos:exactMatch d3f:CWE-1191,
        cwe:CWE-1191 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1192 a owl:Class ;
    rdfs:label "CWE_1192" ;
    d3f:cwe-id "CWE-1192" ;
    dcterms:title "Improper Identifier for IP Block used in System-On-Chip (SOC)" ;
    rdfs:subClassOf d3f:CWE657 ;
    skos:altLabel "CWE-1192" ;
    skos:definition "The System-on-Chip (SoC) does not have unique, immutable identifiers for each of its components." ;
    skos:exactMatch d3f:CWE-1192,
        cwe:CWE-1192 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1193 a owl:Class ;
    rdfs:label "CWE_1193" ;
    d3f:cwe-id "CWE-1193" ;
    dcterms:title "Power-On of Untrusted Execution Core Before Enabling Fabric Access Control" ;
    rdfs:subClassOf d3f:CWE696 ;
    skos:altLabel "CWE-1193" ;
    skos:definition "The product enables components that contain untrusted firmware before memory and fabric access controls have been enabled." ;
    skos:exactMatch d3f:CWE-1193,
        cwe:CWE-1193 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE12 a owl:Class ;
    rdfs:label "CWE_12" ;
    d3f:cwe-id "CWE-12" ;
    dcterms:title "ASP.NET Misconfiguration: Missing Custom Error Page" ;
    rdfs:subClassOf d3f:CWE756 ;
    skos:altLabel "CWE-12" ;
    skos:definition "An ASP .NET application must enable custom error pages in order to prevent attackers from mining information from the framework's built-in responses." ;
    skos:exactMatch d3f:CWE-12,
        cwe:CWE-12 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1209 a owl:Class ;
    rdfs:label "CWE_1209" ;
    d3f:cwe-id "CWE-1209" ;
    dcterms:title "Failure to Disable Reserved Bits" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1209" ;
    skos:definition "The reserved bits in a hardware design are not disabled prior to production. Typically, reserved bits are used for future capabilities and should not support any functional logic in the design. However, designers might covertly use these bits to debug or further develop new capabilities in production hardware. Adversaries with access to these bits will write to them in hopes of compromising hardware state." ;
    skos:exactMatch d3f:CWE-1209,
        cwe:CWE-1209 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE121 a owl:Class ;
    rdfs:label "CWE_121" ;
    d3f:cwe-id "CWE-121" ;
    d3f:synonym "Stack Overflow" ;
    dcterms:title "Stack-based Buffer Overflow" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE788 ],
        d3f:CWE787 ;
    skos:altLabel "CWE-121" ;
    skos:definition "A stack-based buffer overflow condition is a condition where the buffer being overwritten is allocated on the stack (i.e., is a local variable or, rarely, a parameter to a function)." ;
    skos:exactMatch d3f:CWE-121,
        cwe:CWE-121 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE122 a owl:Class ;
    rdfs:label "CWE_122" ;
    d3f:cwe-id "CWE-122" ;
    dcterms:title "Heap-based Buffer Overflow" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE788 ],
        d3f:CWE787 ;
    skos:altLabel "CWE-122" ;
    skos:definition "A heap overflow condition is a buffer overflow, where the buffer that can be overwritten is allocated in the heap portion of memory, generally meaning that the buffer was allocated using a routine such as malloc()." ;
    skos:exactMatch d3f:CWE-122,
        cwe:CWE-122 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1221 a owl:Class ;
    rdfs:label "CWE_1221" ;
    d3f:cwe-id "CWE-1221" ;
    dcterms:title "Incorrect Register Defaults or Module Parameters" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE665 ],
        d3f:CWE1419 ;
    skos:altLabel "CWE-1221" ;
    skos:definition "Hardware description language code incorrectly defines register defaults or hardware Intellectual Property (IP) parameters to insecure values." ;
    skos:exactMatch d3f:CWE-1221,
        cwe:CWE-1221 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1222 a owl:Class ;
    rdfs:label "CWE_1222" ;
    d3f:cwe-id "CWE-1222" ;
    dcterms:title "Insufficient Granularity of Address Regions Protected by Register Locks" ;
    rdfs:subClassOf d3f:CWE1220 ;
    skos:altLabel "CWE-1222" ;
    skos:definition "The product defines a large address region protected from modification by the same register lock control bit. This results in a conflict between the functional requirement that some addresses need to be writable by software during operation and the security requirement that the system configuration lock bit must be set during the boot process." ;
    skos:exactMatch d3f:CWE-1222,
        cwe:CWE-1222 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1223 a owl:Class ;
    rdfs:label "CWE_1223" ;
    d3f:cwe-id "CWE-1223" ;
    dcterms:title "Race Condition for Write-Once Attributes" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-1223" ;
    skos:definition "A write-once register in hardware design is programmable by an untrusted software component earlier than the trusted software component, resulting in a race condition issue." ;
    skos:exactMatch d3f:CWE-1223,
        cwe:CWE-1223 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1224 a owl:Class ;
    rdfs:label "CWE_1224" ;
    d3f:cwe-id "CWE-1224" ;
    dcterms:title "Improper Restriction of Write-Once Bit Fields" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1224" ;
    skos:definition "The hardware design control register \"sticky bits\" or write-once bit fields are improperly implemented, such that they can be reprogrammed by software." ;
    skos:exactMatch d3f:CWE-1224,
        cwe:CWE-1224 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE123 a owl:Class ;
    rdfs:label "CWE_123" ;
    d3f:cwe-id "CWE-123" ;
    dcterms:title "Write-what-where Condition" ;
    rdfs:subClassOf d3f:CWE787 ;
    skos:altLabel "CWE-123" ;
    skos:definition "Any condition where the attacker has the ability to write an arbitrary value to an arbitrary location, often as the result of a buffer overflow." ;
    skos:exactMatch d3f:CWE-123,
        cwe:CWE-123 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1231 a owl:Class ;
    rdfs:label "CWE_1231" ;
    d3f:cwe-id "CWE-1231" ;
    dcterms:title "Improper Prevention of Lock Bit Modification" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1231" ;
    skos:definition "The product uses a trusted lock bit for restricting access to registers, address regions, or other resources, but the product does not prevent the value of the lock bit from being modified after it has been set." ;
    skos:exactMatch d3f:CWE-1231,
        cwe:CWE-1231 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1232 a owl:Class ;
    rdfs:label "CWE_1232" ;
    d3f:cwe-id "CWE-1232" ;
    dcterms:title "Improper Lock Behavior After Power State Transition" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-1232" ;
    skos:definition "Register lock bit protection disables changes to system configuration once the bit is set. Some of the protected registers or lock bits become programmable after power state transitions (e.g., Entry and wake from low power sleep modes) causing the system configuration to be changeable." ;
    skos:exactMatch d3f:CWE-1232,
        cwe:CWE-1232 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1233 a owl:Class ;
    rdfs:label "CWE_1233" ;
    d3f:cwe-id "CWE-1233" ;
    dcterms:title "Security-Sensitive Hardware Controls with Missing Lock Bit Protection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE667 ],
        d3f:CWE284 ;
    skos:altLabel "CWE-1233" ;
    skos:definition "The product uses a register lock bit protection mechanism, but it does not ensure that the lock bit prevents modification of system registers or controls that perform changes to important hardware system configuration." ;
    skos:exactMatch d3f:CWE-1233,
        cwe:CWE-1233 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1234 a owl:Class ;
    rdfs:label "CWE_1234" ;
    d3f:cwe-id "CWE-1234" ;
    dcterms:title "Hardware Internal or Debug Modes Allow Override of Locks" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-1234" ;
    skos:definition "System configuration protection may be bypassed during debug mode." ;
    skos:exactMatch d3f:CWE-1234,
        cwe:CWE-1234 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1235 a owl:Class ;
    rdfs:label "CWE_1235" ;
    d3f:cwe-id "CWE-1235" ;
    dcterms:title "Incorrect Use of Autoboxing and Unboxing for Performance Critical Operations" ;
    rdfs:subClassOf d3f:CWE400 ;
    skos:altLabel "CWE-1235" ;
    skos:definition "The code uses boxed primitives, which may introduce inefficiencies into performance-critical operations." ;
    skos:exactMatch d3f:CWE-1235,
        cwe:CWE-1235 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1236 a owl:Class ;
    rdfs:label "CWE_1236" ;
    d3f:cwe-id "CWE-1236" ;
    d3f:synonym "CSV Injection" ;
    dcterms:title "Improper Neutralization of Formula Elements in a CSV File" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-1236" ;
    skos:definition "The product saves user-provided information into a Comma-Separated Value (CSV) file, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as a command when the file is opened by a spreadsheet product." ;
    skos:exactMatch d3f:CWE-1236,
        cwe:CWE-1236 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1239 a owl:Class ;
    rdfs:label "CWE_1239" ;
    d3f:cwe-id "CWE-1239" ;
    dcterms:title "Improper Zeroization of Hardware Register" ;
    rdfs:subClassOf d3f:CWE226 ;
    skos:altLabel "CWE-1239" ;
    skos:definition "The hardware product does not properly clear sensitive information from built-in registers when the user of the hardware block changes." ;
    skos:exactMatch d3f:CWE-1239,
        cwe:CWE-1239 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE124 a owl:Class ;
    rdfs:label "CWE_124" ;
    d3f:cwe-id "CWE-124" ;
    d3f:synonym "buffer underrun" ;
    dcterms:title "Buffer Underwrite ('Buffer Underflow')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE787 ],
        d3f:CWE786 ;
    skos:altLabel "CWE-124" ;
    skos:definition "The product writes to a buffer using an index or pointer that references a memory location prior to the beginning of the buffer." ;
    skos:exactMatch d3f:CWE-124,
        cwe:CWE-124 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1240 a owl:Class ;
    rdfs:label "CWE_1240" ;
    d3f:cwe-id "CWE-1240" ;
    dcterms:title "Use of a Cryptographic Primitive with a Risky Implementation" ;
    rdfs:subClassOf d3f:CWE327 ;
    skos:altLabel "CWE-1240" ;
    skos:definition "To fulfill the need for a cryptographic primitive, the product implements a cryptographic algorithm using a non-standard, unproven, or disallowed/non-compliant cryptographic implementation." ;
    skos:exactMatch d3f:CWE-1240,
        cwe:CWE-1240 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1241 a owl:Class ;
    rdfs:label "CWE_1241" ;
    d3f:cwe-id "CWE-1241" ;
    dcterms:title "Use of Predictable Algorithm in Random Number Generator" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-1241" ;
    skos:definition "The device uses an algorithm that is predictable and generates a pseudo-random number." ;
    skos:exactMatch d3f:CWE-1241,
        cwe:CWE-1241 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1242 a owl:Class ;
    rdfs:label "CWE_1242" ;
    d3f:cwe-id "CWE-1242" ;
    dcterms:title "Inclusion of Undocumented Features or Chicken Bits" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE912 ],
        d3f:CWE284 ;
    skos:altLabel "CWE-1242" ;
    skos:definition "The device includes chicken bits or undocumented features that can create entry points for unauthorized actors." ;
    skos:exactMatch d3f:CWE-1242,
        cwe:CWE-1242 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1243 a owl:Class ;
    rdfs:label "CWE_1243" ;
    d3f:cwe-id "CWE-1243" ;
    dcterms:title "Sensitive Non-Volatile Information Not Protected During Debug" ;
    rdfs:subClassOf d3f:CWE1263 ;
    skos:altLabel "CWE-1243" ;
    skos:definition "Access to security-sensitive information stored in fuses is not limited during debug." ;
    skos:exactMatch d3f:CWE-1243,
        cwe:CWE-1243 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1244 a owl:Class ;
    rdfs:label "CWE_1244" ;
    d3f:cwe-id "CWE-1244" ;
    dcterms:title "Internal Asset Exposed to Unsafe Debug Access Level or State" ;
    rdfs:subClassOf d3f:CWE863 ;
    skos:altLabel "CWE-1244" ;
    skos:definition "The product uses physical debug or test interfaces with support for multiple access levels, but it assigns the wrong debug access level to an internal asset, providing unintended access to the asset from untrusted debug agents." ;
    skos:exactMatch d3f:CWE-1244,
        cwe:CWE-1244 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1245 a owl:Class ;
    rdfs:label "CWE_1245" ;
    d3f:cwe-id "CWE-1245" ;
    dcterms:title "Improper Finite State Machines (FSMs) in Hardware Logic" ;
    rdfs:subClassOf d3f:CWE684 ;
    skos:altLabel "CWE-1245" ;
    skos:definition "Faulty finite state machines (FSMs) in the hardware logic allow an attacker to put the system in an undefined state, to cause a denial of service (DoS) or gain privileges on the victim's system." ;
    skos:exactMatch d3f:CWE-1245,
        cwe:CWE-1245 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1246 a owl:Class ;
    rdfs:label "CWE_1246" ;
    d3f:cwe-id "CWE-1246" ;
    dcterms:title "Improper Write Handling in Limited-write Non-Volatile Memories" ;
    rdfs:subClassOf d3f:CWE400 ;
    skos:altLabel "CWE-1246" ;
    skos:definition "The product does not implement or incorrectly implements wear leveling operations in limited-write non-volatile memories." ;
    skos:exactMatch d3f:CWE-1246,
        cwe:CWE-1246 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1247 a owl:Class ;
    rdfs:label "CWE_1247" ;
    d3f:cwe-id "CWE-1247" ;
    dcterms:title "Improper Protection Against Voltage and Clock Glitches" ;
    rdfs:subClassOf d3f:CWE1384 ;
    skos:altLabel "CWE-1247" ;
    skos:definition "The device does not contain or contains incorrectly implemented circuitry or sensors to detect and mitigate voltage and clock glitches and protect sensitive information or software contained on the device." ;
    skos:exactMatch d3f:CWE-1247,
        cwe:CWE-1247 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1248 a owl:Class ;
    rdfs:label "CWE_1248" ;
    d3f:cwe-id "CWE-1248" ;
    dcterms:title "Semiconductor Defects in Hardware Logic with Security-Sensitive Implications" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1248" ;
    skos:definition "The security-sensitive hardware module contains semiconductor defects." ;
    skos:exactMatch d3f:CWE-1248,
        cwe:CWE-1248 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1249 a owl:Class ;
    rdfs:label "CWE_1249" ;
    d3f:cwe-id "CWE-1249" ;
    d3f:synonym "Ghost in the Shell" ;
    dcterms:title "Application-Level Admin Tool with Inconsistent View of Underlying Operating System" ;
    rdfs:subClassOf d3f:CWE1250 ;
    skos:altLabel "CWE-1249" ;
    skos:definition "The product provides an application for administrators to manage parts of the underlying operating system, but the application does not accurately identify all of the relevant entities or resources that exist in the OS; that is, the application's model of the OS's state is inconsistent with the OS's actual state." ;
    skos:exactMatch d3f:CWE-1249,
        cwe:CWE-1249 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1251 a owl:Class ;
    rdfs:label "CWE_1251" ;
    d3f:cwe-id "CWE-1251" ;
    dcterms:title "Mirrored Regions with Different Values" ;
    rdfs:subClassOf d3f:CWE1250 ;
    skos:altLabel "CWE-1251" ;
    skos:definition "The product's architecture mirrors regions without ensuring that their contents always stay in sync." ;
    skos:exactMatch d3f:CWE-1251,
        cwe:CWE-1251 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1252 a owl:Class ;
    rdfs:label "CWE_1252" ;
    d3f:cwe-id "CWE-1252" ;
    dcterms:title "CPU Hardware Not Configured to Support Exclusivity of Write and Execute Operations" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1252" ;
    skos:definition "The CPU is not configured to provide hardware support for exclusivity of write and execute operations on memory. This allows an attacker to execute data from all of memory." ;
    skos:exactMatch d3f:CWE-1252,
        cwe:CWE-1252 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1253 a owl:Class ;
    rdfs:label "CWE_1253" ;
    d3f:cwe-id "CWE-1253" ;
    dcterms:title "Incorrect Selection of Fuse Values" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1253" ;
    skos:definition "The logic level used to set a system to a secure state relies on a fuse being unblown. An attacker can set the system to an insecure state merely by blowing the fuse." ;
    skos:exactMatch d3f:CWE-1253,
        cwe:CWE-1253 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1254 a owl:Class ;
    rdfs:label "CWE_1254" ;
    d3f:cwe-id "CWE-1254" ;
    dcterms:title "Incorrect Comparison Logic Granularity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE697 ],
        d3f:CWE208 ;
    skos:altLabel "CWE-1254" ;
    skos:definition "The product's comparison logic is performed over a series of steps rather than across the entire string in one operation. If there is a comparison logic failure on one of these steps, the operation may be vulnerable to a timing attack that can result in the interception of the process for nefarious purposes." ;
    skos:exactMatch d3f:CWE-1254,
        cwe:CWE-1254 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1255 a owl:Class ;
    rdfs:label "CWE_1255" ;
    d3f:cwe-id "CWE-1255" ;
    dcterms:title "Comparison Logic is Vulnerable to Power Side-Channel Attacks" ;
    rdfs:subClassOf d3f:CWE1300 ;
    skos:altLabel "CWE-1255" ;
    skos:definition "A device's real time power consumption may be monitored during security token evaluation and the information gleaned may be used to determine the value of the reference token." ;
    skos:exactMatch d3f:CWE-1255,
        cwe:CWE-1255 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1256 a owl:Class ;
    rdfs:label "CWE_1256" ;
    d3f:cwe-id "CWE-1256" ;
    dcterms:title "Improper Restriction of Software Interfaces to Hardware Features" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-1256" ;
    skos:definition "The product provides software-controllable device functionality for capabilities such as power and clock management, but it does not properly limit functionality that can lead to modification of hardware memory or register bits, or the ability to observe physical side channels." ;
    skos:exactMatch d3f:CWE-1256,
        cwe:CWE-1256 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1257 a owl:Class ;
    rdfs:label "CWE_1257" ;
    d3f:cwe-id "CWE-1257" ;
    dcterms:title "Improper Access Control Applied to Mirrored or Aliased Memory Regions" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1257" ;
    skos:definition "Aliased or mirrored memory regions in hardware designs may have inconsistent read/write permissions enforced by the hardware. A possible result is that an untrusted agent is blocked from accessing a memory region but is not blocked from accessing the corresponding aliased memory region." ;
    skos:exactMatch d3f:CWE-1257,
        cwe:CWE-1257 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1258 a owl:Class ;
    rdfs:label "CWE_1258" ;
    d3f:cwe-id "CWE-1258" ;
    dcterms:title "Exposure of Sensitive System Information Due to Uncleared Debug Information" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE212 ],
        d3f:CWE200 ;
    skos:altLabel "CWE-1258" ;
    skos:definition "The hardware does not fully clear security-sensitive values, such as keys and intermediate values in cryptographic operations, when debug mode is entered." ;
    skos:exactMatch d3f:CWE-1258,
        cwe:CWE-1258 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1259 a owl:Class ;
    rdfs:label "CWE_1259" ;
    d3f:cwe-id "CWE-1259" ;
    dcterms:title "Improper Restriction of Security Token Assignment" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1259" ;
    skos:definition "The System-On-A-Chip (SoC) implements a Security Token mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. However, the Security Tokens are improperly protected." ;
    skos:exactMatch d3f:CWE-1259,
        cwe:CWE-1259 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE126 a owl:Class ;
    rdfs:label "CWE_126" ;
    d3f:cwe-id "CWE-126" ;
    dcterms:title "Buffer Over-read" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE788 ],
        d3f:CWE125 ;
    skos:altLabel "CWE-126" ;
    skos:definition "The product reads from a buffer using buffer access mechanisms such as indexes or pointers that reference memory locations after the targeted buffer." ;
    skos:exactMatch d3f:CWE-126,
        cwe:CWE-126 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1260 a owl:Class ;
    rdfs:label "CWE_1260" ;
    d3f:cwe-id "CWE-1260" ;
    dcterms:title "Improper Handling of Overlap Between Protected Memory Ranges" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1260" ;
    skos:definition "The product allows address regions to overlap, which can result in the bypassing of intended memory protection." ;
    skos:exactMatch d3f:CWE-1260,
        cwe:CWE-1260 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1261 a owl:Class ;
    rdfs:label "CWE_1261" ;
    d3f:cwe-id "CWE-1261" ;
    dcterms:title "Improper Handling of Single Event Upsets" ;
    rdfs:subClassOf d3f:CWE1384 ;
    skos:altLabel "CWE-1261" ;
    skos:definition "The hardware logic does not effectively handle when single-event upsets (SEUs) occur." ;
    skos:exactMatch d3f:CWE-1261,
        cwe:CWE-1261 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1262 a owl:Class ;
    rdfs:label "CWE_1262" ;
    d3f:cwe-id "CWE-1262" ;
    dcterms:title "Improper Access Control for Register Interface" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1262" ;
    skos:definition "The product uses memory-mapped I/O registers that act as an interface to hardware functionality from software, but there is improper access control to those registers." ;
    skos:exactMatch d3f:CWE-1262,
        cwe:CWE-1262 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1264 a owl:Class ;
    rdfs:label "CWE_1264" ;
    d3f:cwe-id "CWE-1264" ;
    dcterms:title "Hardware Logic with Insecure De-Synchronization between Control and Data Channels" ;
    rdfs:subClassOf d3f:CWE821 ;
    skos:altLabel "CWE-1264" ;
    skos:definition "The hardware logic for error handling and security checks can incorrectly forward data before the security check is complete." ;
    skos:exactMatch d3f:CWE-1264,
        cwe:CWE-1264 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1265 a owl:Class ;
    rdfs:label "CWE_1265" ;
    d3f:cwe-id "CWE-1265" ;
    dcterms:title "Unintended Reentrant Invocation of Non-reentrant Code Via Nested Calls" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-1265" ;
    skos:definition "During execution of non-reentrant code, the product performs a call that unintentionally produces a nested invocation of the non-reentrant code." ;
    skos:exactMatch d3f:CWE-1265,
        cwe:CWE-1265 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1266 a owl:Class ;
    rdfs:label "CWE_1266" ;
    d3f:cwe-id "CWE-1266" ;
    dcterms:title "Improper Scrubbing of Sensitive Data from Decommissioned Device" ;
    rdfs:subClassOf d3f:CWE404 ;
    skos:altLabel "CWE-1266" ;
    skos:definition "The product does not properly provide a capability for the product administrator to remove sensitive data at the time the product is decommissioned. A scrubbing capability could be missing, insufficient, or incorrect." ;
    skos:exactMatch d3f:CWE-1266,
        cwe:CWE-1266 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1267 a owl:Class ;
    rdfs:label "CWE_1267" ;
    d3f:cwe-id "CWE-1267" ;
    dcterms:title "Policy Uses Obsolete Encoding" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1267" ;
    skos:definition "The product uses an obsolete encoding mechanism to implement access controls." ;
    skos:exactMatch d3f:CWE-1267,
        cwe:CWE-1267 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1268 a owl:Class ;
    rdfs:label "CWE_1268" ;
    d3f:cwe-id "CWE-1268" ;
    dcterms:title "Policy Privileges are not Assigned Consistently Between Control and Data Agents" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1268" ;
    skos:definition "The product's hardware-enforced access control for a particular resource improperly accounts for privilege discrepancies between control and write policies." ;
    skos:exactMatch d3f:CWE-1268,
        cwe:CWE-1268 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1269 a owl:Class ;
    rdfs:label "CWE_1269" ;
    d3f:cwe-id "CWE-1269" ;
    dcterms:title "Product Released in Non-Release Configuration" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1269" ;
    skos:definition "The product released to market is released in pre-production or manufacturing configuration." ;
    skos:exactMatch d3f:CWE-1269,
        cwe:CWE-1269 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE127 a owl:Class ;
    rdfs:label "CWE_127" ;
    d3f:cwe-id "CWE-127" ;
    dcterms:title "Buffer Under-read" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE786 ],
        d3f:CWE125 ;
    skos:altLabel "CWE-127" ;
    skos:definition "The product reads from a buffer using buffer access mechanisms such as indexes or pointers that reference memory locations prior to the targeted buffer." ;
    skos:exactMatch d3f:CWE-127,
        cwe:CWE-127 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1270 a owl:Class ;
    rdfs:label "CWE_1270" ;
    d3f:cwe-id "CWE-1270" ;
    dcterms:title "Generation of Incorrect Security Tokens" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1270" ;
    skos:definition "The product implements a Security Token mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. However, the Security Tokens generated in the system are incorrect." ;
    skos:exactMatch d3f:CWE-1270,
        cwe:CWE-1270 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1271 a owl:Class ;
    rdfs:label "CWE_1271" ;
    d3f:cwe-id "CWE-1271" ;
    dcterms:title "Uninitialized Value on Reset for Registers Holding Security Settings" ;
    rdfs:subClassOf d3f:CWE909 ;
    skos:altLabel "CWE-1271" ;
    skos:definition "Security-critical logic is not set to a known value on reset." ;
    skos:exactMatch d3f:CWE-1271,
        cwe:CWE-1271 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1272 a owl:Class ;
    rdfs:label "CWE_1272" ;
    d3f:cwe-id "CWE-1272" ;
    dcterms:title "Sensitive Information Uncleared Before Debug/Power State Transition" ;
    rdfs:subClassOf d3f:CWE226 ;
    skos:altLabel "CWE-1272" ;
    skos:definition "The product performs a power or debug state transition, but it does not clear sensitive information that should no longer be accessible due to changes to information access restrictions." ;
    skos:exactMatch d3f:CWE-1272,
        cwe:CWE-1272 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1273 a owl:Class ;
    rdfs:label "CWE_1273" ;
    d3f:cwe-id "CWE-1273" ;
    dcterms:title "Device Unlock Credential Sharing" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-1273" ;
    skos:definition "The credentials necessary for unlocking a device are shared across multiple parties and may expose sensitive information." ;
    skos:exactMatch d3f:CWE-1273,
        cwe:CWE-1273 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1274 a owl:Class ;
    rdfs:label "CWE_1274" ;
    d3f:cwe-id "CWE-1274" ;
    dcterms:title "Improper Access Control for Volatile Memory Containing Boot Code" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1274" ;
    skos:definition "The product conducts a secure-boot process that transfers bootloader code from Non-Volatile Memory (NVM) into Volatile Memory (VM), but it does not have sufficient access control or other protections for the Volatile Memory." ;
    skos:exactMatch d3f:CWE-1274,
        cwe:CWE-1274 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1275 a owl:Class ;
    rdfs:label "CWE_1275" ;
    d3f:cwe-id "CWE-1275" ;
    dcterms:title "Sensitive Cookie with Improper SameSite Attribute" ;
    rdfs:subClassOf d3f:CWE923 ;
    skos:altLabel "CWE-1275" ;
    skos:definition "The SameSite attribute for sensitive cookies is not set, or an insecure value is used." ;
    skos:exactMatch d3f:CWE-1275,
        cwe:CWE-1275 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1276 a owl:Class ;
    rdfs:label "CWE_1276" ;
    d3f:cwe-id "CWE-1276" ;
    dcterms:title "Hardware Child Block Incorrectly Connected to Parent System" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1276" ;
    skos:definition "Signals between a hardware IP and the parent system design are incorrectly connected causing security risks." ;
    skos:exactMatch d3f:CWE-1276,
        cwe:CWE-1276 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1277 a owl:Class ;
    rdfs:label "CWE_1277" ;
    d3f:cwe-id "CWE-1277" ;
    dcterms:title "Firmware Not Updateable" ;
    rdfs:subClassOf d3f:CWE1329 ;
    skos:altLabel "CWE-1277" ;
    skos:definition "The product does not provide its users with the ability to update or patch its firmware to address any vulnerabilities or weaknesses that may be present." ;
    skos:exactMatch d3f:CWE-1277,
        cwe:CWE-1277 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1278 a owl:Class ;
    rdfs:label "CWE_1278" ;
    d3f:cwe-id "CWE-1278" ;
    dcterms:title "Missing Protection Against Hardware Reverse Engineering Using Integrated Circuit (IC) Imaging Techniques" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1278" ;
    skos:definition "Information stored in hardware may be recovered by an attacker with the capability to capture and analyze images of the integrated circuit using techniques such as scanning electron microscopy." ;
    skos:exactMatch d3f:CWE-1278,
        cwe:CWE-1278 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1279 a owl:Class ;
    rdfs:label "CWE_1279" ;
    d3f:cwe-id "CWE-1279" ;
    dcterms:title "Cryptographic Operations are run Before Supporting Units are Ready" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE696 ],
        d3f:CWE665 ;
    skos:altLabel "CWE-1279" ;
    skos:definition "Performing cryptographic operations without ensuring that the supporting inputs are ready to supply valid data may compromise the cryptographic result." ;
    skos:exactMatch d3f:CWE-1279,
        cwe:CWE-1279 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE128 a owl:Class ;
    rdfs:label "CWE_128" ;
    d3f:cwe-id "CWE-128" ;
    dcterms:title "Wrap-around Error" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-128" ;
    skos:definition "Wrap around errors occur whenever a value is incremented past the maximum value for its type and therefore \"wraps around\" to a very small, negative, or undefined value." ;
    skos:exactMatch d3f:CWE-128,
        cwe:CWE-128 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1280 a owl:Class ;
    rdfs:label "CWE_1280" ;
    d3f:cwe-id "CWE-1280" ;
    dcterms:title "Access Control Check Implemented After Asset is Accessed" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE696 ],
        d3f:CWE284 ;
    skos:altLabel "CWE-1280" ;
    skos:definition "A product's hardware-based access control check occurs after the asset has been accessed." ;
    skos:exactMatch d3f:CWE-1280,
        cwe:CWE-1280 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1281 a owl:Class ;
    rdfs:label "CWE_1281" ;
    d3f:cwe-id "CWE-1281" ;
    dcterms:title "Sequence of Processor Instructions Leads to Unexpected Behavior" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-1281" ;
    skos:definition "Specific combinations of processor instructions lead to undesirable behavior such as locking the processor until a hard reset performed." ;
    skos:exactMatch d3f:CWE-1281,
        cwe:CWE-1281 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1282 a owl:Class ;
    rdfs:label "CWE_1282" ;
    d3f:cwe-id "CWE-1282" ;
    dcterms:title "Assumed-Immutable Data is Stored in Writable Memory" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-1282" ;
    skos:definition "Immutable data, such as a first-stage bootloader, device identifiers, and \"write-once\" configuration settings are stored in writable memory that can be re-programmed or updated in the field." ;
    skos:exactMatch d3f:CWE-1282,
        cwe:CWE-1282 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1283 a owl:Class ;
    rdfs:label "CWE_1283" ;
    d3f:cwe-id "CWE-1283" ;
    dcterms:title "Mutable Attestation or Measurement Reporting Data" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1283" ;
    skos:definition "The register contents used for attestation or measurement reporting data to verify boot flow are modifiable by an adversary." ;
    skos:exactMatch d3f:CWE-1283,
        cwe:CWE-1283 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1287 a owl:Class ;
    rdfs:label "CWE_1287" ;
    d3f:cwe-id "CWE-1287" ;
    dcterms:title "Improper Validation of Specified Type of Input" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1287" ;
    skos:definition "The product receives input that is expected to be of a certain type, but it does not validate or incorrectly validates that the input is actually of the expected type." ;
    skos:exactMatch d3f:CWE-1287,
        cwe:CWE-1287 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1288 a owl:Class ;
    rdfs:label "CWE_1288" ;
    d3f:cwe-id "CWE-1288" ;
    dcterms:title "Improper Validation of Consistency within Input" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1288" ;
    skos:definition "The product receives a complex input with multiple elements or fields that must be consistent with each other, but it does not validate or incorrectly validates that the input is actually consistent." ;
    skos:exactMatch d3f:CWE-1288,
        cwe:CWE-1288 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1289 a owl:Class ;
    rdfs:label "CWE_1289" ;
    d3f:cwe-id "CWE-1289" ;
    dcterms:title "Improper Validation of Unsafe Equivalence in Input" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1289" ;
    skos:definition "The product receives an input value that is used as a resource identifier or other type of reference, but it does not validate or incorrectly validates that the input is equivalent to a potentially-unsafe value." ;
    skos:exactMatch d3f:CWE-1289,
        cwe:CWE-1289 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE129 a owl:Class ;
    rdfs:label "CWE_129" ;
    d3f:cwe-id "CWE-129" ;
    d3f:synonym "array index underflow" ;
    dcterms:title "Improper Validation of Array Index" ;
    rdfs:subClassOf d3f:CWE1285 ;
    skos:altLabel "CWE-129" ;
    skos:definition "The product uses untrusted input when calculating or using an array index, but the product does not validate or incorrectly validates the index to ensure the index references a valid position within the array." ;
    skos:exactMatch d3f:CWE-129,
        cwe:CWE-129 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1290 a owl:Class ;
    rdfs:label "CWE_1290" ;
    d3f:cwe-id "CWE-1290" ;
    dcterms:title "Incorrect Decoding of Security Identifiers" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1290" ;
    skos:definition "The product implements a decoding mechanism to decode certain bus-transaction signals to security identifiers. If the decoding is implemented incorrectly, then untrusted agents can now gain unauthorized access to the asset." ;
    skos:exactMatch d3f:CWE-1290,
        cwe:CWE-1290 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1291 a owl:Class ;
    rdfs:label "CWE_1291" ;
    d3f:cwe-id "CWE-1291" ;
    dcterms:title "Public Key Re-Use for Signing both Debug and Production Code" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1291" ;
    skos:definition "The same public key is used for signing both debug and production code." ;
    skos:exactMatch d3f:CWE-1291,
        cwe:CWE-1291 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1292 a owl:Class ;
    rdfs:label "CWE_1292" ;
    d3f:cwe-id "CWE-1292" ;
    dcterms:title "Incorrect Conversion of Security Identifiers" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1292" ;
    skos:definition "The product implements a conversion mechanism to map certain bus-transaction signals to security identifiers. However, if the conversion is incorrectly implemented, untrusted agents can gain unauthorized access to the asset." ;
    skos:exactMatch d3f:CWE-1292,
        cwe:CWE-1292 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1293 a owl:Class ;
    rdfs:label "CWE_1293" ;
    d3f:cwe-id "CWE-1293" ;
    dcterms:title "Missing Source Correlation of Multiple Independent Data" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-1293" ;
    skos:definition "The product relies on one source of data, preventing the ability to detect if an adversary has compromised a data source." ;
    skos:exactMatch d3f:CWE-1293,
        cwe:CWE-1293 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1295 a owl:Class ;
    rdfs:label "CWE_1295" ;
    d3f:cwe-id "CWE-1295" ;
    dcterms:title "Debug Messages Revealing Unnecessary Information" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-1295" ;
    skos:definition "The product fails to adequately prevent the revealing of unnecessary and potentially sensitive system information within debugging messages." ;
    skos:exactMatch d3f:CWE-1295,
        cwe:CWE-1295 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1296 a owl:Class ;
    rdfs:label "CWE_1296" ;
    d3f:cwe-id "CWE-1296" ;
    dcterms:title "Incorrect Chaining or Granularity of Debug Components" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1296" ;
    skos:definition "The product's debug components contain incorrect chaining or granularity of debug components." ;
    skos:exactMatch d3f:CWE-1296,
        cwe:CWE-1296 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1297 a owl:Class ;
    rdfs:label "CWE_1297" ;
    d3f:cwe-id "CWE-1297" ;
    dcterms:title "Unprotected Confidential Information on Device is Accessible by OSAT Vendors" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-1297" ;
    skos:definition "The product does not adequately protect confidential information on the device from being accessed by Outsourced Semiconductor Assembly and Test (OSAT) vendors." ;
    skos:exactMatch d3f:CWE-1297,
        cwe:CWE-1297 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1298 a owl:Class ;
    rdfs:label "CWE_1298" ;
    d3f:cwe-id "CWE-1298" ;
    dcterms:title "Hardware Logic Contains Race Conditions" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-1298" ;
    skos:definition "A race condition in the hardware logic results in undermining security guarantees of the system." ;
    skos:exactMatch d3f:CWE-1298,
        cwe:CWE-1298 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1299 a owl:Class ;
    rdfs:label "CWE_1299" ;
    d3f:cwe-id "CWE-1299" ;
    dcterms:title "Missing Protection Mechanism for Alternate Hardware Interface" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE420 ],
        d3f:CWE288 ;
    skos:altLabel "CWE-1299" ;
    skos:definition "The lack of protections on alternate paths to access control-protected assets (such as unprotected shadow registers and other external facing unguarded interfaces) allows an attacker to bypass existing protections to the asset that are only performed against the primary path." ;
    skos:exactMatch d3f:CWE-1299,
        cwe:CWE-1299 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE13 a owl:Class ;
    rdfs:label "CWE_13" ;
    d3f:cwe-id "CWE-13" ;
    dcterms:title "ASP.NET Misconfiguration: Password in Configuration File" ;
    rdfs:subClassOf d3f:CWE260 ;
    skos:altLabel "CWE-13" ;
    skos:definition "Storing a plaintext password in a configuration file allows anyone who can read the file access to the password-protected resource making them an easy target for attackers." ;
    skos:exactMatch d3f:CWE-13,
        cwe:CWE-13 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE130 a owl:Class ;
    rdfs:label "CWE_130" ;
    d3f:cwe-id "CWE-130" ;
    d3f:synonym "length manipulation" ;
    dcterms:title "Improper Handling of Length Parameter Inconsistency" ;
    rdfs:subClassOf d3f:CWE240 ;
    skos:altLabel "CWE-130" ;
    skos:definition "The product parses a formatted message or structure, but it does not handle or incorrectly handles a length field that is inconsistent with the actual length of the associated data." ;
    skos:exactMatch d3f:CWE-130,
        cwe:CWE-130 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1302 a owl:Class ;
    rdfs:label "CWE_1302" ;
    d3f:cwe-id "CWE-1302" ;
    dcterms:title "Missing Security Identifier" ;
    rdfs:subClassOf d3f:CWE1294 ;
    skos:altLabel "CWE-1302" ;
    skos:definition "The product implements a security identifier mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. A transaction is sent without a security identifier." ;
    skos:exactMatch d3f:CWE-1302,
        cwe:CWE-1302 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1303 a owl:Class ;
    rdfs:label "CWE_1303" ;
    d3f:cwe-id "CWE-1303" ;
    dcterms:title "Non-Transparent Sharing of Microarchitectural Resources" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE203 ],
        d3f:CWE1189 ;
    skos:altLabel "CWE-1303" ;
    skos:definition "Hardware structures shared across execution contexts (e.g., caches and branch predictors) can violate the expected architecture isolation between contexts." ;
    skos:exactMatch d3f:CWE-1303,
        cwe:CWE-1303 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1304 a owl:Class ;
    rdfs:label "CWE_1304" ;
    d3f:cwe-id "CWE-1304" ;
    dcterms:title "Improperly Preserved Integrity of Hardware Configuration State During a Power Save/Restore Operation" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1304" ;
    skos:definition "The product performs a power save/restore operation, but it does not ensure that the integrity of the configuration state is maintained and/or verified between the beginning and ending of the operation." ;
    skos:exactMatch d3f:CWE-1304,
        cwe:CWE-1304 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1310 a owl:Class ;
    rdfs:label "CWE_1310" ;
    d3f:cwe-id "CWE-1310" ;
    dcterms:title "Missing Ability to Patch ROM Code" ;
    rdfs:subClassOf d3f:CWE1329 ;
    skos:altLabel "CWE-1310" ;
    skos:definition "Missing an ability to patch ROM code may leave a System or System-on-Chip (SoC) in a vulnerable state." ;
    skos:exactMatch d3f:CWE-1310,
        cwe:CWE-1310 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1311 a owl:Class ;
    rdfs:label "CWE_1311" ;
    d3f:cwe-id "CWE-1311" ;
    dcterms:title "Improper Translation of Security Attributes by Fabric Bridge" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1311" ;
    skos:definition "The bridge incorrectly translates security attributes from either trusted to untrusted or from untrusted to trusted when converting from one fabric protocol to another." ;
    skos:exactMatch d3f:CWE-1311,
        cwe:CWE-1311 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1312 a owl:Class ;
    rdfs:label "CWE_1312" ;
    d3f:cwe-id "CWE-1312" ;
    dcterms:title "Missing Protection for Mirrored Regions in On-Chip Fabric Firewall" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1312" ;
    skos:definition "The firewall in an on-chip fabric protects the main addressed region, but it does not protect any mirrored memory or memory-mapped-IO (MMIO) regions." ;
    skos:exactMatch d3f:CWE-1312,
        cwe:CWE-1312 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1313 a owl:Class ;
    rdfs:label "CWE_1313" ;
    d3f:cwe-id "CWE-1313" ;
    dcterms:title "Hardware Allows Activation of Test or Debug Logic at Runtime" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1313" ;
    skos:definition "During runtime, the hardware allows for test or debug logic (feature) to be activated, which allows for changing the state of the hardware. This feature can alter the intended behavior of the system and allow for alteration and leakage of sensitive data by an adversary." ;
    skos:exactMatch d3f:CWE-1313,
        cwe:CWE-1313 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1314 a owl:Class ;
    rdfs:label "CWE_1314" ;
    d3f:cwe-id "CWE-1314" ;
    dcterms:title "Missing Write Protection for Parametric Data Values" ;
    rdfs:subClassOf d3f:CWE862 ;
    skos:altLabel "CWE-1314" ;
    skos:definition "The device does not write-protect the parametric data values for sensors that scale the sensor value, allowing untrusted software to manipulate the apparent result and potentially damage hardware or cause operational failure." ;
    skos:exactMatch d3f:CWE-1314,
        cwe:CWE-1314 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1315 a owl:Class ;
    rdfs:label "CWE_1315" ;
    d3f:cwe-id "CWE-1315" ;
    dcterms:title "Improper Setting of Bus Controlling Capability in Fabric End-point" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1315" ;
    skos:definition "The bus controller enables bits in the fabric end-point to allow responder devices to control transactions on the fabric." ;
    skos:exactMatch d3f:CWE-1315,
        cwe:CWE-1315 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1316 a owl:Class ;
    rdfs:label "CWE_1316" ;
    d3f:cwe-id "CWE-1316" ;
    dcterms:title "Fabric-Address Map Allows Programming of Unwarranted Overlaps of Protected and Unprotected Ranges" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1316" ;
    skos:definition "The address map of the on-chip fabric has protected and unprotected regions overlapping, allowing an attacker to bypass access control to the overlapping portion of the protected region." ;
    skos:exactMatch d3f:CWE-1316,
        cwe:CWE-1316 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1317 a owl:Class ;
    rdfs:label "CWE_1317" ;
    d3f:cwe-id "CWE-1317" ;
    dcterms:title "Improper Access Control in Fabric Bridge" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1317" ;
    skos:definition "The product uses a fabric bridge for transactions between two Intellectual Property (IP) blocks, but the bridge does not properly perform the expected privilege, identity, or other access control checks between those IP blocks." ;
    skos:exactMatch d3f:CWE-1317,
        cwe:CWE-1317 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1318 a owl:Class ;
    rdfs:label "CWE_1318" ;
    d3f:cwe-id "CWE-1318" ;
    dcterms:title "Missing Support for Security Features in On-chip Fabrics or Buses" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1318" ;
    skos:definition "On-chip fabrics or buses either do not support or are not configured to support privilege separation or other security features, such as access control." ;
    skos:exactMatch d3f:CWE-1318,
        cwe:CWE-1318 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1319 a owl:Class ;
    rdfs:label "CWE_1319" ;
    d3f:cwe-id "CWE-1319" ;
    dcterms:title "Improper Protection against Electromagnetic Fault Injection (EM-FI)" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1319" ;
    skos:definition "The device is susceptible to electromagnetic fault injection attacks, causing device internal information to be compromised or security mechanisms to be bypassed." ;
    skos:exactMatch d3f:CWE-1319,
        cwe:CWE-1319 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1320 a owl:Class ;
    rdfs:label "CWE_1320" ;
    d3f:cwe-id "CWE-1320" ;
    dcterms:title "Improper Protection for Outbound Error Messages and Alert Signals" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1320" ;
    skos:definition "Untrusted agents can disable alerts about signal conditions exceeding limits or the response mechanism that handles such alerts." ;
    skos:exactMatch d3f:CWE-1320,
        cwe:CWE-1320 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1321 a owl:Class ;
    rdfs:label "CWE_1321" ;
    d3f:cwe-id "CWE-1321" ;
    dcterms:title "Improperly Controlled Modification of Object Prototype Attributes ('Prototype Pollution')" ;
    rdfs:subClassOf d3f:CWE915 ;
    skos:altLabel "CWE-1321" ;
    skos:definition "The product receives input from an upstream component that specifies attributes that are to be initialized or updated in an object, but it does not properly control modifications of attributes of the object prototype." ;
    skos:exactMatch d3f:CWE-1321,
        cwe:CWE-1321 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1322 a owl:Class ;
    rdfs:label "CWE_1322" ;
    d3f:cwe-id "CWE-1322" ;
    dcterms:title "Use of Blocking Code in Single-threaded, Non-blocking Context" ;
    rdfs:subClassOf d3f:CWE834 ;
    skos:altLabel "CWE-1322" ;
    skos:definition "The product uses a non-blocking model that relies on a single threaded process for features such as scalability, but it contains code that can block when it is invoked." ;
    skos:exactMatch d3f:CWE-1322,
        cwe:CWE-1322 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1323 a owl:Class ;
    rdfs:label "CWE_1323" ;
    d3f:cwe-id "CWE-1323" ;
    dcterms:title "Improper Management of Sensitive Trace Data" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1323" ;
    skos:definition "Trace data collected from several sources on the System-on-Chip (SoC) is stored in unprotected locations or transported to untrusted agents." ;
    skos:exactMatch d3f:CWE-1323,
        cwe:CWE-1323 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1325 a owl:Class ;
    rdfs:label "CWE_1325" ;
    d3f:cwe-id "CWE-1325" ;
    d3f:synonym "Stack Exhaustion" ;
    dcterms:title "Improperly Controlled Sequential Memory Allocation" ;
    rdfs:subClassOf d3f:CWE770 ;
    skos:altLabel "CWE-1325" ;
    skos:definition "The product manages a group of objects or resources and performs a separate memory allocation for each object, but it does not properly limit the total amount of memory that is consumed by all of the combined objects." ;
    skos:exactMatch d3f:CWE-1325,
        cwe:CWE-1325 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1326 a owl:Class ;
    rdfs:label "CWE_1326" ;
    d3f:cwe-id "CWE-1326" ;
    dcterms:title "Missing Immutable Root of Trust in Hardware" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1326" ;
    skos:definition "A missing immutable root of trust in the hardware results in the ability to bypass secure boot or execute untrusted or adversarial boot code." ;
    skos:exactMatch d3f:CWE-1326,
        cwe:CWE-1326 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1327 a owl:Class ;
    rdfs:label "CWE_1327" ;
    d3f:cwe-id "CWE-1327" ;
    dcterms:title "Binding to an Unrestricted IP Address" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-1327" ;
    skos:definition "The product assigns the address 0.0.0.0 for a database server, a cloud service/instance, or any computing resource that communicates remotely." ;
    skos:exactMatch d3f:CWE-1327,
        cwe:CWE-1327 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1328 a owl:Class ;
    rdfs:label "CWE_1328" ;
    d3f:cwe-id "CWE-1328" ;
    dcterms:title "Security Version Number Mutable to Older Versions" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-1328" ;
    skos:definition "Security-version number in hardware is mutable, resulting in the ability to downgrade (roll-back) the boot firmware to vulnerable code versions." ;
    skos:exactMatch d3f:CWE-1328,
        cwe:CWE-1328 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1330 a owl:Class ;
    rdfs:label "CWE_1330" ;
    d3f:cwe-id "CWE-1330" ;
    dcterms:title "Remanent Data Readable after Memory Erase" ;
    rdfs:subClassOf d3f:CWE1301 ;
    skos:altLabel "CWE-1330" ;
    skos:definition "Confidential information stored in memory circuits is readable or recoverable after being cleared or erased." ;
    skos:exactMatch d3f:CWE-1330,
        cwe:CWE-1330 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1331 a owl:Class ;
    rdfs:label "CWE_1331" ;
    d3f:cwe-id "CWE-1331" ;
    dcterms:title "Improper Isolation of Shared Resources in Network On Chip (NoC)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE668 ],
        d3f:CWE653 ;
    skos:altLabel "CWE-1331" ;
    skos:definition "The Network On Chip (NoC) does not isolate or incorrectly isolates its on-chip-fabric and internal resources such that they are shared between trusted and untrusted agents, creating timing channels." ;
    skos:exactMatch d3f:CWE-1331,
        cwe:CWE-1331 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1332 a owl:Class ;
    rdfs:label "CWE_1332" ;
    d3f:cwe-id "CWE-1332" ;
    dcterms:title "Improper Handling of Faults that Lead to Instruction Skips" ;
    rdfs:subClassOf d3f:CWE1384 ;
    skos:altLabel "CWE-1332" ;
    skos:definition "The device is missing or incorrectly implements circuitry or sensors that detect and mitigate the skipping of security-critical CPU instructions when they occur." ;
    skos:exactMatch d3f:CWE-1332,
        cwe:CWE-1332 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1333 a owl:Class ;
    rdfs:label "CWE_1333" ;
    d3f:cwe-id "CWE-1333" ;
    d3f:synonym "Catastrophic backtracking" ;
    dcterms:title "Inefficient Regular Expression Complexity" ;
    rdfs:subClassOf d3f:CWE407 ;
    skos:altLabel "CWE-1333" ;
    skos:definition "The product uses a regular expression with an inefficient, possibly exponential worst-case computational complexity that consumes excessive CPU cycles." ;
    skos:exactMatch d3f:CWE-1333,
        cwe:CWE-1333 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1334 a owl:Class ;
    rdfs:label "CWE_1334" ;
    d3f:cwe-id "CWE-1334" ;
    dcterms:title "Unauthorized Error Injection Can Degrade Hardware Redundancy" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1334" ;
    skos:definition "An unauthorized agent can inject errors into a redundant block to deprive the system of redundancy or put the system in a degraded operating mode." ;
    skos:exactMatch d3f:CWE-1334,
        cwe:CWE-1334 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1335 a owl:Class ;
    rdfs:label "CWE_1335" ;
    d3f:cwe-id "CWE-1335" ;
    dcterms:title "Incorrect Bitwise Shift of Integer" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-1335" ;
    skos:definition "An integer value is specified to be shifted by a negative amount or an amount greater than or equal to the number of bits contained in the value causing an unexpected or indeterminate result." ;
    skos:exactMatch d3f:CWE-1335,
        cwe:CWE-1335 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1336 a owl:Class ;
    rdfs:label "CWE_1336" ;
    d3f:cwe-id "CWE-1336" ;
    d3f:synonym "Client-Side Template Injection / CSTI" ;
    dcterms:title "Improper Neutralization of Special Elements Used in a Template Engine" ;
    rdfs:subClassOf d3f:CWE94 ;
    skos:altLabel "CWE-1336" ;
    skos:definition "The product uses a template engine to insert or process externally-influenced input, but it does not neutralize or incorrectly neutralizes special elements or syntax that can be interpreted as template expressions or other code directives when processed by the engine." ;
    skos:exactMatch d3f:CWE-1336,
        cwe:CWE-1336 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1338 a owl:Class ;
    rdfs:label "CWE_1338" ;
    d3f:cwe-id "CWE-1338" ;
    dcterms:title "Improper Protections Against Hardware Overheating" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-1338" ;
    skos:definition "A hardware device is missing or has inadequate protection features to prevent overheating." ;
    skos:exactMatch d3f:CWE-1338,
        cwe:CWE-1338 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1339 a owl:Class ;
    rdfs:label "CWE_1339" ;
    d3f:cwe-id "CWE-1339" ;
    dcterms:title "Insufficient Precision or Accuracy of a Real Number" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-1339" ;
    skos:definition "The product processes a real number with an implementation in which the number's representation does not preserve required accuracy and precision in its fractional part, causing an incorrect result." ;
    skos:exactMatch d3f:CWE-1339,
        cwe:CWE-1339 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE134 a owl:Class ;
    rdfs:label "CWE_134" ;
    d3f:cwe-id "CWE-134" ;
    dcterms:title "Use of Externally-Controlled Format String" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-134" ;
    skos:definition "The product uses a function that accepts a format string as an argument, but the format string originates from an external source." ;
    skos:exactMatch d3f:CWE-134,
        cwe:CWE-134 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1342 a owl:Class ;
    rdfs:label "CWE_1342" ;
    d3f:cwe-id "CWE-1342" ;
    dcterms:title "Information Exposure through Microarchitectural State after Transient Execution" ;
    rdfs:subClassOf d3f:CWE226 ;
    skos:altLabel "CWE-1342" ;
    skos:definition "The processor does not properly clear microarchitectural state after incorrect microcode assists or speculative execution, resulting in transient execution." ;
    skos:exactMatch d3f:CWE-1342,
        cwe:CWE-1342 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE135 a owl:Class ;
    rdfs:label "CWE_135" ;
    d3f:cwe-id "CWE-135" ;
    dcterms:title "Incorrect Calculation of Multi-Byte String Length" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-135" ;
    skos:definition "The product does not correctly calculate the length of strings that can contain wide or multi-byte characters." ;
    skos:exactMatch d3f:CWE-135,
        cwe:CWE-135 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1351 a owl:Class ;
    rdfs:label "CWE_1351" ;
    d3f:cwe-id "CWE-1351" ;
    dcterms:title "Improper Handling of Hardware Behavior in Exceptionally Cold Environments" ;
    rdfs:subClassOf d3f:CWE1384 ;
    skos:altLabel "CWE-1351" ;
    skos:definition "A hardware device, or the firmware running on it, is missing or has incorrect protection features to maintain goals of security primitives when the device is cooled below standard operating temperatures." ;
    skos:exactMatch d3f:CWE-1351,
        cwe:CWE-1351 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1385 a owl:Class ;
    rdfs:label "CWE_1385" ;
    d3f:cwe-id "CWE-1385" ;
    d3f:synonym "Cross-Site WebSocket hijacking (CSWSH)" ;
    dcterms:title "Missing Origin Validation in WebSockets" ;
    rdfs:subClassOf d3f:CWE346 ;
    skos:altLabel "CWE-1385" ;
    skos:definition "The product uses a WebSocket, but it does not properly verify that the source of data or communication is valid." ;
    skos:exactMatch d3f:CWE-1385,
        cwe:CWE-1385 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1386 a owl:Class ;
    rdfs:label "CWE_1386" ;
    d3f:cwe-id "CWE-1386" ;
    dcterms:title "Insecure Operation on Windows Junction / Mount Point" ;
    rdfs:subClassOf d3f:CWE59 ;
    skos:altLabel "CWE-1386" ;
    skos:definition "The product opens a file or directory, but it does not properly prevent the name from being associated with a junction or mount point to a destination that is outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-1386,
        cwe:CWE-1386 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1389 a owl:Class ;
    rdfs:label "CWE_1389" ;
    d3f:cwe-id "CWE-1389" ;
    dcterms:title "Incorrect Parsing of Numbers with Different Radices" ;
    rdfs:subClassOf d3f:CWE704 ;
    skos:altLabel "CWE-1389" ;
    skos:definition "The product parses numeric input assuming base 10 (decimal) values, but it does not account for inputs that use a different base number (radix)." ;
    skos:exactMatch d3f:CWE-1389,
        cwe:CWE-1389 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1393 a owl:Class ;
    rdfs:label "CWE_1393" ;
    d3f:cwe-id "CWE-1393" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Use of Default Password" ;
    rdfs:subClassOf d3f:CWE1392 ;
    skos:altLabel "CWE-1393" ;
    skos:definition "The product uses default passwords for potentially critical functionality." ;
    skos:exactMatch d3f:CWE-1393,
        cwe:CWE-1393 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1394 a owl:Class ;
    rdfs:label "CWE_1394" ;
    d3f:cwe-id "CWE-1394" ;
    dcterms:title "Use of Default Cryptographic Key" ;
    rdfs:subClassOf d3f:CWE1392 ;
    skos:altLabel "CWE-1394" ;
    skos:definition "The product uses a default cryptographic key for potentially critical functionality." ;
    skos:exactMatch d3f:CWE-1394,
        cwe:CWE-1394 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1395 a owl:Class ;
    rdfs:label "CWE_1395" ;
    d3f:cwe-id "CWE-1395" ;
    dcterms:title "Dependency on Vulnerable Third-Party Component" ;
    rdfs:subClassOf d3f:CWE657 ;
    skos:altLabel "CWE-1395" ;
    skos:definition "The product has a dependency on a third-party component that contains one or more known vulnerabilities." ;
    skos:exactMatch d3f:CWE-1395,
        cwe:CWE-1395 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE14 a owl:Class ;
    rdfs:label "CWE_14" ;
    d3f:cwe-id "CWE-14" ;
    dcterms:title "Compiler Removal of Code to Clear Buffers" ;
    rdfs:subClassOf d3f:CWE733 ;
    skos:altLabel "CWE-14" ;
    skos:definition "Sensitive memory is cleared according to the source code, but compiler optimizations leave the memory untouched when it is not read from again, aka \"dead store removal.\"" ;
    skos:exactMatch d3f:CWE-14,
        cwe:CWE-14 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE141 a owl:Class ;
    rdfs:label "CWE_141" ;
    d3f:cwe-id "CWE-141" ;
    dcterms:title "Improper Neutralization of Parameter/Argument Delimiters" ;
    rdfs:subClassOf d3f:CWE140 ;
    skos:altLabel "CWE-141" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as parameter or argument delimiters when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-141,
        cwe:CWE-141 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE142 a owl:Class ;
    rdfs:label "CWE_142" ;
    d3f:cwe-id "CWE-142" ;
    dcterms:title "Improper Neutralization of Value Delimiters" ;
    rdfs:subClassOf d3f:CWE140 ;
    skos:altLabel "CWE-142" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as value delimiters when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-142,
        cwe:CWE-142 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1421 a owl:Class ;
    rdfs:label "CWE_1421" ;
    d3f:cwe-id "CWE-1421" ;
    dcterms:title "Exposure of Sensitive Information in Shared Microarchitectural Structures during Transient Execution" ;
    rdfs:subClassOf d3f:CWE1420 ;
    skos:altLabel "CWE-1421" ;
    skos:definition "A processor event may allow transient operations to access architecturally restricted data (for example, in another address space) in a shared microarchitectural structure (for example, a CPU cache), potentially exposing the data over a covert channel." ;
    skos:exactMatch d3f:CWE-1421,
        cwe:CWE-1421 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1422 a owl:Class ;
    rdfs:label "CWE_1422" ;
    d3f:cwe-id "CWE-1422" ;
    dcterms:title "Exposure of Sensitive Information caused by Incorrect Data Forwarding during Transient Execution" ;
    rdfs:subClassOf d3f:CWE1420 ;
    skos:altLabel "CWE-1422" ;
    skos:definition "A processor event or prediction may allow incorrect or stale data to be forwarded to transient operations, potentially exposing data over a covert channel." ;
    skos:exactMatch d3f:CWE-1422,
        cwe:CWE-1422 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1423 a owl:Class ;
    rdfs:label "CWE_1423" ;
    d3f:cwe-id "CWE-1423" ;
    dcterms:title "Exposure of Sensitive Information caused by Shared Microarchitectural Predictor State that Influences Transient Execution" ;
    rdfs:subClassOf d3f:CWE1420 ;
    skos:altLabel "CWE-1423" ;
    skos:definition "Shared microarchitectural predictor state may allow code to influence transient execution across a hardware boundary, potentially exposing data that is accessible beyond the boundary over a covert channel." ;
    skos:exactMatch d3f:CWE-1423,
        cwe:CWE-1423 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1426 a owl:Class ;
    rdfs:label "CWE_1426" ;
    d3f:cwe-id "CWE-1426" ;
    dcterms:title "Improper Validation of Generative AI Output" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-1426" ;
    skos:definition "The product invokes a generative AI/ML component whose behaviors and outputs cannot be directly controlled, but the product does not validate or insufficiently validates the outputs to ensure that they align with the intended security, content, or privacy policy." ;
    skos:exactMatch d3f:CWE-1426,
        cwe:CWE-1426 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1427 a owl:Class ;
    rdfs:label "CWE_1427" ;
    d3f:cwe-id "CWE-1427" ;
    d3f:synonym "prompt injection" ;
    dcterms:title "Improper Neutralization of Input Used for LLM Prompting" ;
    rdfs:subClassOf d3f:CWE77 ;
    skos:altLabel "CWE-1427" ;
    skos:definition "The product uses externally-provided data to build prompts provided to large language models (LLMs), but the way these prompts are constructed causes the LLM to fail to distinguish between user-supplied inputs and developer provided system directives." ;
    skos:exactMatch d3f:CWE-1427,
        cwe:CWE-1427 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1428 a owl:Class ;
    rdfs:label "CWE_1428" ;
    d3f:cwe-id "CWE-1428" ;
    dcterms:title "Reliance on HTTP instead of HTTPS" ;
    rdfs:subClassOf d3f:CWE319 ;
    skos:altLabel "CWE-1428" ;
    skos:definition "The product provides or relies on use of HTTP communications when HTTPS is available." ;
    skos:exactMatch d3f:CWE-1428,
        cwe:CWE-1428 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1429 a owl:Class ;
    rdfs:label "CWE_1429" ;
    d3f:cwe-id "CWE-1429" ;
    dcterms:title "Missing Security-Relevant Feedback for Unexecuted Operations in Hardware Interface" ;
    rdfs:subClassOf d3f:CWE223 ;
    skos:altLabel "CWE-1429" ;
    skos:definition "The product has a hardware interface that silently discards operations in situations for which feedback would be security-relevant, such as the timely detection of failures or attacks." ;
    skos:exactMatch d3f:CWE-1429,
        cwe:CWE-1429 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE143 a owl:Class ;
    rdfs:label "CWE_143" ;
    d3f:cwe-id "CWE-143" ;
    dcterms:title "Improper Neutralization of Record Delimiters" ;
    rdfs:subClassOf d3f:CWE140 ;
    skos:altLabel "CWE-143" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as record delimiters when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-143,
        cwe:CWE-143 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1431 a owl:Class ;
    rdfs:label "CWE_1431" ;
    d3f:cwe-id "CWE-1431" ;
    dcterms:title "Driving Intermediate Cryptographic State/Results to Hardware Module Outputs" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-1431" ;
    skos:definition "The product uses a hardware module implementing a cryptographic algorithm that writes sensitive information about the intermediate state or results of its cryptographic operations via one of its output wires (typically the output port containing the final result)." ;
    skos:exactMatch d3f:CWE-1431,
        cwe:CWE-1431 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

