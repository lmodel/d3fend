    skos:exactMatch d3f:Projection-basedClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Prolog a owl:Class ;
    rdfs:label "Prolog" ;
    d3f:d3fend-id "D3A-PRO" ;
    d3f:kb-article "## How it works Prolog is intended primarily as a declarative programming language: the program logic is expressed in terms of relations, represented as facts and rules. A computation is initiated by running a query over these relations. ## References 1. Prolog. (2023, April 5). In _Wikipedia_. [Li" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:LogicProgramming ;
    skos:definition "Prolog has its roots in first-order logic, a formal logic, and unlike many other programming languages." ;
    skos:exactMatch d3f:Prolog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PropertyListFile a owl:Class ;
    rdfs:label "PropertyListFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Property List File" ;
    rdfs:seeAlso dbr:Property_list ;
    rdfs:subClassOf d3f:ConfigurationFile ;
    skos:altLabel "Plist File" ;
    skos:definition "In the OS X, iOS, NeXTSTEP, and GNUstep programming frameworks, property list files are files that store serialized objects. Property list files use the filename extension .plist, and thus are often referred to as p-list files. Property list files are often used to store a user's settings. They are also used to store information about bundles and applications, a task served by the resource fork in the old Mac OS." ;
    skos:exactMatch d3f:PropertyListFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PropositionalLogic a owl:Class ;
    rdfs:label "PropositionalLogic" ;
    d3f:d3fend-id "D3A-PL" ;
    d3f:kb-article "## How it works Compound propositions are formed by connecting propositions by logical connectives. Propositions that contain no logical connectives are called atomic propositions. ## References 1. Propositional Calculus. (2022, May 31). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Proposit" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Propositional Calculus" ;
    dcterms:title "Propositional Logic" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "Propositional logic deals with statements (i.e., propositions, which can be true or false) and relations between propositions, including the construction of arguments based on them." ;
    skos:exactMatch d3f:PropositionalLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

