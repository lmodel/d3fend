d3f:AuthenticationCacheInvalidation a owl:Class ;
    rdfs:label "AuthenticationCacheInvalidation" ;
    d3f:d3fend-id "D3-ANCI" ;
    d3f:kb-article "## How it works Applications can locally cache user authentication credentials for certain server connections. An application may attempt to use the cached credential for a connection. If the cached credentials exist then the user will not be typically prompted for new credentials. ## Consideratio" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Cache Invalidation" ;
    rdfs:subClassOf d3f:CredentialEviction ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1003,
        d3f:T1098,
        d3f:T1110,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "Removing tokens or credentials from an authentication cache to prevent further user associated account accesses." ;
    skos:exactMatch d3f:AuthenticationCacheInvalidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.003,
        mitre-attack:T1003.005,
        mitre-attack:T1003.008,
        mitre-attack:T1098.001,
        mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003,
        mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1142,
        mitre-attack:T1528,
        mitre-attack:T1539,
        mitre-attack:T1550.001,
        mitre-attack:T1550.004,
        mitre-attack:T1552,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:AuthenticationEventThresholding a owl:Class ;
    rdfs:label "AuthenticationEventThresholding" ;
    d3f:d3fend-id "D3-ANET" ;
    d3f:kb-article "## How it works Authentication event data is collected (logon information such as device id, time of day, day of week, geo-location, etc.) to create an activity baseline. Then, a threshold is determined either through a manually specified configuration, or a statistical analysis of deviations in his" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Event Thresholding" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Collecting authentication events, creating a baseline user profile, and determining whether authentication events are consistent with the baseline profile." ;
    skos:exactMatch d3f:AuthenticationEventThresholding ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthenticationFunction a owl:Class ;
    rdfs:label "AuthenticationFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Authenticates a user account by verifying a presented credential." ;
