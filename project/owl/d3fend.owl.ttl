d3f:CustomArchiveFile a owl:Class ;
    rdfs:label "CustomArchiveFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Custom Archive File" ;
    rdfs:subClassOf d3f:ArchiveFile ;
    skos:definition "A custom archive file is an archive file conforming to a custom format; that is, an archive file that does not conform to a common standard." ;
    skos:exactMatch d3f:CustomArchiveFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CycleGAN a owl:Class ;
    rdfs:label "CycleGAN" ;
    d3f:d3fend-id "D3A-CYC" ;
    d3f:kb-article "## References Esri. (n.d.). How CycleGAN Works. [Link](https://developers.arcgis.com/python/guide/how-cyclegan-works/)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:ImageToImageTranslationGAN ;
    skos:definition "The Cycle Generative Adversarial Network (CycleGAN) is an approach to training a deep convolutional neural network for image-to-image translation tasks by mapping between input and output images using unpaired dataset." ;
    skos:exactMatch d3f:CycleGAN ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DBSCAN a owl:Class ;
    rdfs:label "DBSCAN" ;
    d3f:d3fend-id "D3A-DBS" ;
    d3f:kb-article "## References Analytics Vidhya. (2020, September 15). How DBSCAN Clustering Works: A Comprehensive Guide with Implementations in Python. [Link](https://www.analyticsvidhya.com/blog/2020/09/how-dbscan-clustering-works/#:~:text=DBSCAN%20is%20a%20density%2Dbased,points%20into%20a%20single%20cluster.)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DensityBasedClustering ;
    skos:definition "A density-based clustering algorithm that works on the assumption that clusters are dense regions in space separated by regions of lower density." ;
    skos:exactMatch d3f:DBSCAN ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPAckEvent a owl:Class ;
    rdfs:label "DHCPAckEvent" ;
    dcterms:title "DHCP Ack Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPACK" ;
    skos:definition "An event where a DHCP server sends an ACK message to acknowledge a client's REQUEST, confirming the allocation of an IP address and associated network settings." ;
    skos:exactMatch d3f:DHCPAckEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPDiscoverEvent a owl:Class ;
    rdfs:label "DHCPDiscoverEvent" ;
    dcterms:title "DHCP Discover Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPDISCOVER" ;
    skos:definition "An event where a DHCP client broadcasts a DISCOVER message to identify available DHCP servers capable of providing IP configuration." ;
    skos:exactMatch d3f:DHCPDiscoverEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPInformEvent a owl:Class ;
    rdfs:label "DHCPInformEvent" ;
    dcterms:title "DHCP Inform Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPINFORM" ;
    skos:definition "An event where a DHCP client sends an INFORM message to request configuration parameters, such as DNS or gateway information, without requiring IP address assignment." ;
    skos:exactMatch d3f:DHCPInformEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPLeaseExpireEvent a owl:Class ;
    rdfs:label "DHCPLeaseExpireEvent" ;
    dcterms:title "DHCP Lease Expire Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPLEASEEXPIRE" ;
    skos:definition "An event indicating that a DHCP lease has expired, rendering the previously assigned IP address available for reassignment to other devices." ;
    skos:exactMatch d3f:DHCPLeaseExpireEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPNakEvent a owl:Class ;
    rdfs:label "DHCPNakEvent" ;
    dcterms:title "DHCP Nak Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPNAK" ;
    skos:definition "An event where a DHCP server sends a NAK message to reject a client's REQUEST, indicating that the requested configuration cannot be granted." ;
    skos:exactMatch d3f:DHCPNakEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPNetworkTraffic a owl:Class ;
    rdfs:label "DHCPNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DHCP Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "DHCP Network Traffic is network traffic related to the DHCP protocol, used by network nodes to negotiate and configure either IPv4 or IPv6 addresses." ;
    skos:exactMatch d3f:DHCPNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPOfferEvent a owl:Class ;
    rdfs:label "DHCPOfferEvent" ;
    dcterms:title "DHCP Offer Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPOFFER" ;
    skos:definition "An event where a DHCP server sends an OFFER message to a client in response to a DISCOVER request, proposing an IP address and associated configuration parameters." ;
    skos:exactMatch d3f:DHCPOfferEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPReleaseEvent a owl:Class ;
    rdfs:label "DHCPReleaseEvent" ;
    dcterms:title "DHCP Release Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPRELEASE" ;
    skos:definition "An event where a DHCP client sends a RELEASE message to relinquish its assigned IP address and cancel any remaining lease duration." ;
    skos:exactMatch d3f:DHCPReleaseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPRequestEvent a owl:Class ;
    rdfs:label "DHCPRequestEvent" ;
    dcterms:title "DHCP Request Event" ;
    rdfs:subClassOf d3f:DHCPEvent ;
    skos:altLabel "DHCPREQUEST" ;
    skos:definition "An event where a DHCP client sends a REQUEST message to confirm or renew its desired IP configuration with a specific DHCP server." ;
    skos:exactMatch d3f:DHCPRequestEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPServer a owl:Class ;
    rdfs:label "DHCPServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DHCP Server" ;
    rdfs:seeAlso dbr:Dynamic_Host_Configuration_Protocol ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A Dynamic Host Configuration Protocol (DHCP) server is a type of server that assigns IP addresses to computers.  DHCP servers are used to assign IP addresses to computers and other devices automatically.  The DHCP server is responsible for assigning the unique IP address to each device." ;
    skos:exactMatch d3f:DHCPServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPService a owl:Class ;
    rdfs:label "DHCPService" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DHCP Service" ;
    rdfs:subClassOf d3f:NetworkService ;
    skos:definition "A DHCP service assigns IP address and modifies network configurations." ;
    skos:exactMatch d3f:DHCPService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPServiceApplication a owl:Class ;
    rdfs:label "DHCPServiceApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DHCP Service Application" ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "An application that automates the assignment of IP addresses and other network configuration parameters to devices on a network" ;
    skos:exactMatch d3f:DHCPServiceApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSAllowlisting a owl:Class ;
    rdfs:label "DNSAllowlisting" ;
    d3f:d3fend-id "D3-DNSAL" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "DNS Whitelisting" ;
    dcterms:title "DNS Allowlisting" ;
    rdfs:subClassOf d3f:NetworkIsolation ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:T1071 ;
    skos:definition "Permitting only approved domains and their subdomains to be resolved." ;
    skos:exactMatch d3f:DNSAllowlisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1071.004,
        mitre-attack:T1568 .

d3f:DNSCacheEviction a owl:Class ;
    rdfs:label "DNSCacheEviction" ;
    d3f:d3fend-id "D3-DNSCE" ;
    d3f:kb-article "# How it works Flushing the DNS Cache will clear the IP addresses of websites you have visited recently. This can help remediate DNS Cache Poisoning attacks, which is a type of cyber attack where corrupted DNS data is inserted into the cache, causing redirects to malicious websites. On windows, th" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Flush DNS Cache" ;
    dcterms:title "DNS Cache Eviction" ;
    rdfs:subClassOf d3f:ObjectEviction ;
    skos:definition "Flushing DNS to clear any IP addresses or other DNS records from the cache." ;
    skos:exactMatch d3f:DNSCacheEviction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSQueryEvent a owl:Class ;
    rdfs:label "DNSQueryEvent" ;
    dcterms:title "DNS Query Event" ;
    rdfs:subClassOf d3f:DNSEvent ;
    skos:definition "An event where a DNS query is made to resolve a domain name." ;
    skos:exactMatch d3f:DNSQueryEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSRecord a owl:Class ;
    rdfs:label "DNSRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DNS Record" ;
    rdfs:seeAlso dbr:Domain_Name_System,
        dbr:List_of_DNS_record_types ;
    rdfs:subClassOf d3f:Record ;
    skos:definition "A Domain Name System (DNS) record is a record of information returned to clients seeking to find computers, services, and other resources connected to the Internet or a private network.  Record information is stored on a domain name server so it can respond to DNS queries from clients.There are a variety of record types, depending on the client's information needs. Common types include Start of Authority, IP addresses, SMTP mail exchangers, name servers, reverse DNS lookup pointers, etc." ;
    skos:exactMatch d3f:DNSRecord,
        unified_cyber_ontology:DNSRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSResponseEvent a owl:Class ;
    rdfs:label "DNSResponseEvent" ;
    dcterms:title "DNS Response Event" ;
    rdfs:subClassOf d3f:DNSEvent ;
    skos:definition "An event where a DNS server responds to a query with resolution data." ;
    skos:exactMatch d3f:DNSResponseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSServer a owl:Class ;
    rdfs:label "DNSServer" ;
    dcterms:title "DNS Server" ;
    rdfs:seeAlso dbr:Name_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition """A Domain Name System (DNS) name server is a kind of name server.  Domain names are one of the two principal namespaces of the Internet. The most important function of DNS servers is the translation (resolution) of human-memorable domain names and hostnames into the corresponding numeric Internet Protocol (IP) addresses, the second principal name space of the Internet which is used to identify and locate computer systems and resources on the Internet. (en).

More generally, a name server is a computer application that implements a network service for providing responses to queries against a directory service. It translates an often humanly meaningful, text-based identifier to a system-internal, often numeric identification or addressing component. This service is performed by the server in response to a service protocol request.""" ;
    skos:exactMatch d3f:DNSServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSTrafficAnalysis a owl:Class ;
    rdfs:label "DNSTrafficAnalysis" ;
    d3f:d3fend-id "D3-DNSTA" ;
    d3f:kb-article "## How it works This technique can be accomplished in a number of ways. * One example analytic determines whether or not a domain name was generated with an algorithm. Domain generation algorithms (DGAs) are sometimes used to create a domain name automatically that will resolve to C2 infrastructur" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Domain Name Analysis" ;
    dcterms:title "DNS Traffic Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DiscoveryTechnique,
        d3f:T1071 ;
    skos:definition "Analysis of domain name metadata, including name and DNS records, to determine whether the domain is likely to resolve to an undesirable host." ;
    skos:exactMatch d3f:DNSTrafficAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1040,
        mitre-attack:T1071.004,
        mitre-attack:T1568 .

d3f:DataAcquisitionAgent a owl:Class ;
    rdfs:label "DataAcquisitionAgent" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Data Gateway; Historian Collector" ;
    dcterms:title "Data Acquisition Agent" ;
    rdfs:seeAlso <https://attack.mitre.org/assets/A0009> ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "A software component which connects to data sources to gather raw, time-stamped data. It often connects to databases or historian gateways for storage and analysis." ;
    skos:exactMatch d3f:DataAcquisitionAgent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DataAcquisitionUnit a owl:Class ;
    rdfs:label "DataAcquisitionUnit" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data Acquisition Unit" ;
    rdfs:seeAlso <https://attack.mitre.org/assets/A0009> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "The hardware component which connects to data sources to gather raw, time-stamped data. It often connects to databases or historian gateways for storage and analysis." ;
    skos:exactMatch d3f:DataAcquisitionUnit ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DataArtifactServer a owl:Class ;
    rdfs:label "DataArtifactServer" ;
    dcterms:title "Data Artifact Server" ;
    rdfs:seeAlso dbr:Content_repository ;
    rdfs:subClassOf d3f:ArtifactServer ;
    skos:definition "A data artifact server provides access services to content in a content repository.  The content repository or content store is a database of digital content with an associated set of data management, search and access methods allowing application-independent access to the content, rather like a digital library, but with the ability to store and modify content in addition to searching and retrieving. The content repository acts as the storage engine for a larger application such as a content management system or a document management system, which adds a user interface on top of the repository's application programming interface." ;
    skos:exactMatch d3f:DataArtifactServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DataDependency a owl:Class ;
    rdfs:label "DataDependency" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Transactional Dependency" ;
    dcterms:title "Data Dependency" ;
    rdfs:subClassOf d3f:Dependency ;
    skos:definition "A Data Dependency exists when a process, operation, or system requires specific data in order to execute correctly." ;
    skos:exactMatch d3f:DataDependency ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DataExchangeMapping a owl:Class ;
