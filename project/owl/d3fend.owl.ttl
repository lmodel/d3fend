d3f:DecoyNetworkResource a owl:Class ;
    rdfs:label "DecoyNetworkResource" ;
    d3f:d3fend-id "D3-DNR" ;
    d3f:kb-article "## How it works Decoy network resources are deployed to web application servers, network file shares, or other network based sharing services. A \"honeypot\" may serve a variety of decoy network resources. ## Considerations * Developing a deployment and placement strategy for the decoy network reso" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy Network Resource" ;
    rdfs:subClassOf d3f:DecoyObject ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:LateralMovementTechnique,
        d3f:T1037,
        d3f:T1070,
        d3f:T1074,
        d3f:T1213,
        d3f:T1491 ;
    skos:definition "Deploying a network resource for the purposes of deceiving an adversary." ;
    skos:exactMatch d3f:DecoyNetworkResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1037.003,
        mitre-attack:T1039,
        mitre-attack:T1070.005,
        mitre-attack:T1074.002,
        mitre-attack:T1080,
        mitre-attack:T1213.001,
        mitre-attack:T1213.002,
        mitre-attack:T1491.002 .

d3f:DecoyPersona a owl:Class ;
    rdfs:label "DecoyPersona" ;
    d3f:d3fend-id "D3-DP" ;
    d3f:kb-article "## How it works A false online identity is created for the purposes of interacting with adversaries in a direct or indirect manner. This includes the associated email addresses, social media accounts, and other online communication profiles. ## Considerations * Include phone numbers and online soci" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy Persona" ;
    rdfs:subClassOf d3f:DecoyObject ;
    skos:definition "Establishing a fake online identity to misdirect, deceive, and or interact with adversaries." ;
    skos:exactMatch d3f:DecoyPersona ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoyPublicRelease a owl:Class ;
    rdfs:label "DecoyPublicRelease" ;
    d3f:d3fend-id "D3-DPR" ;
    d3f:kb-article "## How it works Publicly released media includes press release, videos, or other marketing collateral. The media may include URLs, points of contact, or other identifiers to entice interaction from adversaries. ## Considerations * Information used in decoy public released media must contain enough" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy Public Release" ;
    rdfs:subClassOf d3f:DecoyObject ;
    skos:definition "Issuing publicly released media to deceive adversaries." ;
    skos:exactMatch d3f:DecoyPublicRelease ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoySessionToken a owl:Class ;
    rdfs:label "DecoySessionToken" ;
    d3f:d3fend-id "D3-DST" ;
    d3f:kb-article "## How it works Usage of decoy session tokens may be monitored to track attacker behavior or otherwise control the beliefs of the attacker. ## Considerations * Interaction and activity with the decoy session token must be constantly monitored and analyzed to detect unauthorized activity. * Session" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy Session Token" ;
    rdfs:subClassOf d3f:DecoyObject ;
    skos:definition "An authentication token created for the purposes of deceiving an adversary." ;
    skos:exactMatch d3f:DecoySessionToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoyUserCredential a owl:Class ;
    rdfs:label "DecoyUserCredential" ;
    d3f:d3fend-id "D3-DUC" ;
    d3f:kb-article "## How it works A detection analytic is developed to determine when a user uses decoy credentials. Subsequent actions by that user may be monitored or controlled by the defender. A credential may be: * Domain username and password * Local system username and password ## Considerations * Decoy cr" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy User Credential" ;
    rdfs:subClassOf d3f:DecoyObject ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1003,
        d3f:T1098,
        d3f:T1110,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "A Credential created for the purpose of deceiving an adversary." ;
    skos:exactMatch d3f:DecoyUserCredential ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.003,
        mitre-attack:T1003.005,
        mitre-attack:T1003.008,
        mitre-attack:T1098.001,
        mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003,
        mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1142,
        mitre-attack:T1528,
        mitre-attack:T1539,
        mitre-attack:T1550.001,
        mitre-attack:T1550.004,
        mitre-attack:T1552,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:DeepConvolutionalGAN a owl:Class ;
    rdfs:label "DeepConvolutionalGAN" ;
    d3f:d3fend-id "D3A-DCG" ;
    d3f:kb-article "## References Analytics Vidhya. (2021). Deep Convolutional Generative Adversarial Network (DCGAN) for Beginners. [Link](https://www.analyticsvidhya.com/blog/2021/07/deep-convolutional-generative-adversarial-network-dcgan-for-beginners/)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "DCGAN" ;
    dcterms:title "Deep Convolutional GAN" ;
    rdfs:subClassOf d3f:ImageSynthesisGAN ;
    skos:definition "Deep Convolutional GAN (DCGAN) uses convolutional and convolutional-transpose layers in the generator and discriminator, respectively." ;
    skos:exactMatch d3f:DeepConvolutionalGAN ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DefaultUserAccount a owl:Class ;
    rdfs:label "DefaultUserAccount" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Default User Account" ;
    rdfs:seeAlso <https://docs.microsoft.com/en-us/windows/security/identity-protection/access-control/local-accounts> ;
    rdfs:subClassOf d3f:UserAccount ;
    skos:definition "Default accounts are those that are built-into an OS, such as the Guest or Administrator accounts on Windows systems or default factory/provider set accounts on other types of systems, software, or devices." ;
    skos:exactMatch d3f:DefaultUserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DeleteFile a owl:Class ;
    rdfs:label "DeleteFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Delete File" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "Remove a file from a machine." ;
    skos:exactMatch d3f:DeleteFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DensityBasedClustering a owl:Class ;
    rdfs:label "Density_basedClustering" ;
    d3f:d3fend-id "D3A-DBC" ;
    d3f:kb-article "## References Google Developers. (n.d.). Clustering algorithms. [Link](https://developers.google.com/machine-learning/clustering/clustering-algorithms)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Density-based Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:altLabel "Density-basedClustering" ;
    skos:definition "Density-based clustering connects areas of high example density into clusters. This allows for arbitrary-shaped distributions as long as dense areas can be connected." ;
    skos:exactMatch d3f:Density-basedClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DeonticLogic a owl:Class ;
    rdfs:label "DeonticLogic" ;
    d3f:d3fend-id "D3A-DL" ;
    d3f:kb-article "## References 1. Deontic logic. (2023, June 4). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Modal_logic#Deontic_logic)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Deontic Logic" ;
    rdfs:subClassOf d3f:ModalLogic ;
    skos:definition "Deontic logic addresses the modality of obligations and norms; i.e., the modality of morality." ;
    skos:exactMatch d3f:DeonticLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DeserializationFunction a owl:Class ;
    rdfs:label "DeserializationFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Deserialization Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Function with an input of serialized data which deserializes that data, usually with data parsing methods." ;
    skos:exactMatch d3f:DeserializationFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DesktopComputer a owl:Class ;
    rdfs:label "DesktopComputer" ;
    dcterms:title "Desktop Computer" ;
    rdfs:seeAlso dbr:Desktop_computer ;
    rdfs:subClassOf d3f:PersonalComputer ;
    skos:definition "A desktop computer is a personal computer designed for regular use at a single location on or near a desk or table due to its size and power requirements. The most common configuration has a case that houses the power supply, motherboard (a printed circuit board with a microprocessor as the central processing unit (CPU), memory, bus, and other electronic components, disk storage (usually one or more hard disk drives, solid state drives, optical disc drives, and in early models a floppy disk drive); a keyboard and mouse for input; and a computer monitor, speakers, and, often, a printer for output. The case may be oriented horizontally or vertically and placed either underneath, beside, or on top of a desk." ;
    skos:exactMatch d3f:DesktopComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DetectionEvent a owl:Class ;
    rdfs:label "DetectionEvent" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Detection Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/categories/findings>,
        <https://schema.ocsf.io/categories/findings> ;
    rdfs:subClassOf d3f:SecurityEvent ;
    skos:definition "An event capturing the identification of a potential security issue, such as unauthorized access attempts, policy violations, or anomalous activities. Detection events form the foundation of cybersecurity monitoring and response." ;
    skos:exactMatch d3f:DetectionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DialUpModem a owl:Class ;
    rdfs:label "DialUpModem" ;
    dcterms:title "Dial Up Modem" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Modem#Dial-up> ;
    rdfs:subClassOf d3f:Modem ;
    skos:definition "A dial-up modem transmits computer data over an ordinary switched telephone line that has not been designed for data use. This contrasts with leased line modems, which also operate over lines provided by a telephone company, but ones which are intended for data use and do not impose the same signaling constraints. The modulated data must fit the frequency constraints of a normal voice audio signal, and the modem must be able to perform the actions needed to connect a call through a telephone exchange, namely: picking up the line, dialing, understanding signals sent back by phone company equipment (dial tone, ringing, busy signal,) and on the far end of the call, the second modem in the connection must be able to recognize the incoming ring signal and answer the line." ;
    skos:exactMatch d3f:DialUpModem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DifferentialVolumeSnapshot a owl:Class ;
    rdfs:label "DifferentialVolumeSnapshot" ;
    dcterms:title "Differential Volume Snapshot" ;
    rdfs:seeAlso <https://aws.amazon.com/compare/the-difference-between-incremental-differential-and-other-backups/> ;
    rdfs:subClassOf d3f:VolumeSnapshot ;
    skos:definition "A differential volume snapshot is a point-in-time capture of the files and directories that were changed since the last full snapshot." ;
    skos:exactMatch d3f:DifferentialVolumeSnapshot ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalAccessBadge a owl:Class ;
    rdfs:label "DigitalAccessBadge" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "CAC" ;
    dcterms:title "Digital Access Badge" ;
    rdfs:seeAlso <https://dbpedia.org/page/Access_badge>,
        <https://nvlpubs.nist.gov/nistpubs/SpecialPublications/NIST.SP.800-116r1.pdf> ;
    rdfs:subClassOf d3f:Credential ;
    skos:definition "A credential used to gain entry to an area having automated access control entry points. Example media being magnetic stripe, proximity, barcode, or smart cards are examples." ;
    skos:exactMatch d3f:DigitalAccessBadge ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalAudio a owl:Class ;
    rdfs:label "DigitalAudio" ;
    dcterms:title "Digital Audio" ;
    rdfs:subClassOf d3f:DigitalMedia ;
    skos:definition "Digital audio is a representation of sound recorded in, or converted into, digital form." ;
    skos:exactMatch d3f:DigitalAudio ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalAudioVisualMedia a owl:Class ;
    rdfs:label "DigitalAudioVisualMedia" ;
    dcterms:title "Digital Audio Visual Media" ;
    rdfs:subClassOf d3f:DigitalMultimedia ;
    skos:definition "Audiovisual (AV) is electronic media possessing both a sound and a visual component." ;
    skos:exactMatch d3f:DigitalAudioVisualMedia ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalCamera a owl:Class ;
    rdfs:label "DigitalCamera" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital Camera" ;
    rdfs:seeAlso <https://dbpedia.org/page/Digital_camera> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "An optical instrument that can capture an image. A digital camera that captures photographs in digital memory." ;
    skos:exactMatch d3f:DigitalCamera,
        unified_cyber_ontology:DigitalCamera ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalDocument a owl:Class ;
    rdfs:label "DigitalDocument" ;
    dcterms:title "Digital Document" ;
    rdfs:subClassOf d3f:DigitalMedia ;
    skos:closeMatch oscal:OscalDocument,
        spdx:SpdxDocument,
        unified_cyber_ontology:File ;
    skos:definition "An digital document is any electronic media content (other than computer programs or system files) that is intended to be used in either an electronic form or as printed output." ;
    skos:exactMatch d3f:DigitalDocument ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalEventRecord a owl:Class ;
    rdfs:label "DigitalEventRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital Event Record" ;
    rdfs:subClassOf d3f:Record ;
    skos:definition "A digital event record is a structured representation of a digital event, encapsulating all relevant details about the occurrence for storage, analysis, and response. These records serve as the primary artifacts for cybersecurity operations, enabling threat detection, forensic investigations, and compliance reporting. Digital event records include metadata such as timestamps, origin, context, and associated resources, ensuring traceability and actionable intelligence in digital ecosystems." ;
    skos:exactMatch d3f:DigitalEventRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalIdentity a owl:Class ;
    rdfs:label "DigitalIdentity" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital Identity" ;
    rdfs:seeAlso <https://pages.nist.gov/800-63-3/sp800-63-3.html> ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:closeMatch stix:Identity,
        unified_cyber_ontology:Identity ;
    skos:definition "The unique representation of a subject engaged in an online transaction. A digital identity is always unique in the context of a digital service, but does not necessarily need to uniquely identify the subject in all contexts. In other words, accessing a digital service may not mean that the subject's real-life identity is known.  Note: There is no single, widely accepted definition for this term and context is important. This definition is specific to online transactions." ;
    skos:exactMatch d3f:DigitalIdentity ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "Variously describes or designates. Designation is not compete or definite without context. The representation generally can be identified by a unique identifier, though this may be private information." .

d3f:DigitalText a owl:Class ;
    rdfs:label "DigitalText" ;
    dcterms:title "Digital Text" ;
    rdfs:subClassOf d3f:DigitalMedia ;
    skos:definition "Digital text is written content encoded in a digital format, allowing for storage, retrieval, and manipulation by electronic devices." ;
    skos:exactMatch d3f:DigitalText ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalVideo a owl:Class ;
    rdfs:label "DigitalVideo" ;
    dcterms:title "Digital Video" ;
    rdfs:subClassOf d3f:DigitalMedia ;
    skos:definition "Digital video is an electronic representation of moving visual images (video) in the form of encoded digital data." ;
    skos:exactMatch d3f:DigitalVideo ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DirectPhysicalLinkMapping a owl:Class ;
    rdfs:label "DirectPhysicalLinkMapping" ;
    d3f:d3fend-id "D3-DPLM" ;
    d3f:kb-article "## How it works Direct Physical Link Mapping involves a manual process where a network engineer or administrator physically observes and documents the physical connections within the network infrastructure. ## Considerations * Constructing and maintaining physical topologies for extensive network" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Manual Physical Link Mapping" ;
    dcterms:title "Direct Physical Link Mapping" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Transmission_medium> ;
    rdfs:subClassOf d3f:PhysicalLinkMapping ;
    skos:definition "Direct physical link mapping creates a physical link map by direct observation and recording of the physical network links." ;
    skos:exactMatch d3f:DirectPhysicalLinkMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DirectionalNetworkLink a owl:Class ;
    rdfs:label "DirectionalNetworkLink" ;
    d3f:d3fend-id "D3-DNL" ;
    d3f:kb-article "## How it works Using a device such as a data diode, or otherwise enforcing unidirectional (one-way) network communication / data transfer, to physically prevent signals from traveling in the reverse direction. Unidirectional network link enforcement is a security measure used to separate control a" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Directional Network Link" ;
    rdfs:subClassOf d3f:NetworkIsolation ;
    skos:definition "Enforce one-way network communication by preventing two-way communication." ;
    skos:exactMatch d3f:DirectionalNetworkLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DirectoryService a owl:Class ;
    rdfs:label "DirectoryService" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Directory Service" ;
    rdfs:seeAlso dbr:Directory_service ;
    rdfs:subClassOf d3f:NetworkService ;
    skos:definition "In computing, directory service or name service maps the names of network resources to their respective network addresses. It is a shared information infrastructure for locating, managing, administering and organizing everyday items and network resources, which can include volumes, folders, files, printers, users, groups, devices, telephone numbers and other objects. A directory service is a critical component of a network operating system. A directory server or name server is a server which provides such a service. Each resource on the network is considered an object by the directory server. Information about a particular resource is stored as a collection of attributes associated with that resource or object." ;
    skos:exactMatch d3f:DirectoryService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DisableRemoteAccess a owl:Class ;
    rdfs:label "DisableRemoteAccess" ;
    d3f:d3fend-id "D3-DRA" ;
    d3f:kb-article "## How It Works There are several different methods of achieving remote access restriction. This could include: time-based controls, just-in-time authorization, and deny-by-default controls. This can be done on a Windows machine by unchecking an \"allow remote assistance\" or checking the \"don't allo" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disable Remote Access" ;
    rdfs:seeAlso <https://www.dragos.com/blog/industry-news/value-of-plc-key-switch-monitoring/#:~:text=Run%20mode%E2%80%94The%20controller%20is,in%20the%20Remote%20Program%20mode> ;
    rdfs:subClassOf d3f:ApplicationConfigurationHardening ;
    skos:broadMatch d3f:T1114,
        d3f:T1562,
        d3f:T1564 ;
    skos:definition "Limiting access to a computing device which is not required through or from a non-organization-controlled network." ;
    skos:exactMatch d3f:DisableRemoteAccess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.003,
        mitre-attack:T1562.002,
        mitre-attack:T1562.003,
        mitre-attack:T1564.008 .

d3f:DiscriminantAnalysis a owl:Class ;
    rdfs:label "DiscriminantAnalysis" ;
    d3f:d3fend-id "D3A-DA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Multivariate statistics. [Link](https://en.wikipedia.org/wiki/Multivariate_statistics)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Discriminant Analysis" ;
    rdfs:subClassOf d3f:MultivariateAnalysis ;
    skos:definition "Discriminant analysis attempts to establish whether a set of variables can be used to distinguish between two or more groups of cases." ;
    skos:exactMatch d3f:DiscriminantAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DiskEncryption a owl:Class ;
    rdfs:label "DiskEncryption" ;
    d3f:d3fend-id "D3-DENCR" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disk Encryption" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:broadMatch d3f:DiscoveryTechnique,
        d3f:T1564 ;
    skos:definition "Encrypting a hard disk partition to prevent cleartext access to a file system." ;
    skos:exactMatch d3f:DiskEncryption ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1564.005,
        mitre-attack:T1619 .

d3f:DiskErasure a owl:Class ;
    rdfs:label "DiskErasure" ;
    d3f:d3fend-id "D3-DKE" ;
    d3f:kb-article "### How it works Disk Erasure involves overwriting the existing data with random or specific patterns multiple times. Disk erasure is crucial for data sanitization, ensuring that sensitive information is completely removed from storage devices before they are repurposed, disposed of, or transferred" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disk Erasure" ;
    rdfs:subClassOf d3f:DiskFormatting ;
    skos:broadMatch d3f:DiscoveryTechnique ;
    skos:definition "Disk Erasure is the process of securely deleting all data on a disk to ensure that it cannot be recovered by any means." ;
    skos:exactMatch d3f:DiskErasure ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1619 .

d3f:DiskPartitioning a owl:Class ;
    rdfs:label "DiskPartitioning" ;
    d3f:d3fend-id "D3-DKP" ;
    d3f:kb-article "### How it works Each partition can be managed separately and can have its own file system. Disk partitioning can be used to segregate sensitive data from less critical data, improve system performance, and enhance data management and recovery processes. It can also help in isolating different oper" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disk Partitioning" ;
    rdfs:subClassOf d3f:DiskFormatting ;
    skos:broadMatch d3f:T1561 ;
    skos:definition "Disk Partitioning is the process of dividing a disk into multiple distinct sections, known as partitions." ;
    skos:exactMatch d3f:DiskPartitioning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1561.001,
        mitre-attack:T1561.002 .

d3f:DisplayAdapter a owl:Class ;
    rdfs:label "DisplayAdapter" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Display Adapter" ;
    rdfs:seeAlso dbr:Video_card ;
    rdfs:subClassOf d3f:OutputDevice ;
    skos:altLabel "Display Card",
        "Graphics Adapter",
        "Video Card" ;
    skos:definition "A graphics card (also called a display card, video card, display adapter, or graphics adapter) is an expansion card which generates a feed of output images to a display device (such as a computer monitor). Frequently, these are advertised as discrete or dedicated graphics cards, emphasizing the distinction between these and integrated graphics. At the core of both is the graphics processing unit (GPU), which is the main part that does the actual computations, but should not be confused with the video card as a whole, although \"GPU\" is often used to refer to video cards." ;
    skos:exactMatch d3f:DisplayAdapter ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DisplayDeviceDriver a owl:Class ;
    rdfs:label "DisplayDeviceDriver" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Display Device Driver" ;
    rdfs:seeAlso dbr:Device_driver,
        dbr:Display_adapter ;
    rdfs:subClassOf d3f:HardwareDriver ;
    skos:definition "A device driver for a display adapter." ;
    skos:exactMatch d3f:DisplayDeviceDriver ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DisplayServer a owl:Class ;
    rdfs:label "DisplayServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Display Server" ;
    rdfs:seeAlso dbr:Display_server ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Window Server" ;
    skos:definition "A display server or window server is a program whose primary task is to coordinate the input and output of its clients to and from the rest of the operating system, the hardware, and each other. The display server communicates with its clients over the display server protocol, a communications protocol, which can be network-transparent or simply network-capable. The display server is a key component in any graphical user interface, specifically the windowing system." ;
    skos:exactMatch d3f:DisplayServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DistributionBasedClustering a owl:Class ;
    rdfs:label "Distribution_basedClustering" ;
    d3f:d3fend-id "D3A-DBC" ;
    d3f:kb-article "## References AnalytixLabs. (n.d.). Types of Clustering Algorithms. [Link](https://www.analytixlabs.co.in/blog/types-of-clustering-algorithms/#:~:text=Distribution-Based)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Distribution-based Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:altLabel "Distribution-basedClustering" ;
    skos:definition "Distribution-based clustering creates and groups data points based on their likely hood of belonging to the same probability distribution (Gaussian, Binomial, etc.) in the data." ;
    skos:exactMatch d3f:Distribution-basedClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DivisiveClustering a owl:Class ;
    rdfs:label "DivisiveClustering" ;
