d3f:LocalResourceAccess a owl:Class ;
    rdfs:label "LocalResourceAccess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Resource Access" ;
    rdfs:subClassOf d3f:ResourceAccess ;
    skos:altLabel "Endpoint Resource Access" ;
    skos:definition "Ephemeral digital artifact comprising a request of a local resource and any response from that resource." ;
    skos:exactMatch d3f:LocalResourceAccess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LocalUserAccount a owl:Class ;
    rdfs:label "LocalUserAccount" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local User Account" ;
    rdfs:subClassOf d3f:UserAccount ;
    skos:definition "A user account on a given host is a local user account for that specific host." ;
    skos:exactMatch d3f:LocalUserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogMessageFunction a owl:Class ;
    rdfs:label "LogMessageFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Log Message Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Produces an entry in a log." ;
    skos:exactMatch d3f:LogMessageFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LoginSession a owl:Class ;
    rdfs:label "LoginSession" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Login Session" ;
    rdfs:seeAlso dbr:Login_session,
        <https://learn.microsoft.com/en-us/windows-server/security/windows-authentication/windows-logon-scenarios> ;
    rdfs:subClassOf d3f:Session ;
    skos:altLabel "Logon Session" ;
    skos:definition "In computing, a login session is the period of activity between a user logging in and logging out of a (multi-user) system. This includes local login sessions, where a user has direct physical access to a computer, as well as domain login sessions, where a user logs into a computer that is part of a network domain." ;
    skos:exactMatch d3f:LoginSession ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogististicRegressionLearning a owl:Class ;
    rdfs:label "LogististicRegressionLearning" ;
    d3f:d3fend-id "D3A-LRL" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Logistic regression. [Link](https://en.wikipedia.org/wiki/Logistic_regression)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logistic Regression Learning" ;
    rdfs:seeAlso d3f:LogisticRegression ;
    rdfs:subClassOf d3f:RegressionAnalysisLearning ;
    skos:definition "A supervised learning method that builds a logistic regression model using training data." ;
    skos:exactMatch d3f:LogististicRegressionLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogoffEvent a owl:Class ;
    rdfs:label "LogoffEvent" ;
    dcterms:title "Logoff Event" ;
    rdfs:subClassOf d3f:AuthenticationEvent ;
    skos:definition "An authentication event where an active session is conclusively terminated, resulting in the cessation of access and deallocation of resources associated with the session, ensuring that the connection to the system, application, or resource no longer exists." ;
    skos:exactMatch d3f:LogoffEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogonEvent a owl:Class ;
    rdfs:label "LogonEvent" ;
    dcterms:title "Logon Event" ;
    rdfs:subClassOf d3f:AuthenticationEvent ;
    skos:definition "An authentication event where a new session is initiated, signifying the successful validation of credentials and establishment of an authorized connection to a system, application, or resource. This marks the beginning of the subject’s authenticated interaction with the system." ;
    skos:exactMatch d3f:LogonEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogonUser a owl:Class ;
    rdfs:label "LogonUser" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logon User" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:LogonUser ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MACAddress a owl:Class ;
    rdfs:label "MACAddress" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "MAC Address" ;
    rdfs:seeAlso dbr:MAC_address ;
    rdfs:subClassOf d3f:Identifier ;
    skos:closeMatch stix:MacAddr ;
    skos:definition "A media access control address (MAC address) is a unique identifier assigned to a network interface controller (NIC) for use as a network address in communications within a network segment." ;
    skos:exactMatch d3f:MACAddress,
        unified_cyber_ontology:MACAddress ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MacOSKeychain a owl:Class ;
    rdfs:label "MacOSKeychain" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "MacOS Keychain" ;
    rdfs:seeAlso dbr:Keychain_\(software\) ;
    rdfs:subClassOf d3f:PasswordStore ;
    skos:altLabel "Keychain" ;
    skos:definition "Keychain is the password management system in macOS, developed by Apple. It was introduced with Mac OS 8.6, and has been included in all subsequent versions of the operating system, now known as macOS. A Keychain can contain various types of data: passwords (for websites, FTP servers, SSH accounts, network shares, wireless networks, groupware applications, encrypted disk images), private keys, certificates, and secure notes." ;
    skos:exactMatch d3f:MacOSKeychain ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MailServer a owl:Class ;
    rdfs:label "MailServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Mail Server" ;
    rdfs:seeAlso dbr:Message_transfer_agent ;
    rdfs:subClassOf d3f:Server ;
    skos:altLabel "Email Server Resource",
        "MTA",
        "MX Host",
        "Mail Exchanger",
        "Mail transfer agent",
        "Message transfer agent" ;
    skos:definition "Within the Internet email system, a message transfer agent or mail transfer agent (MTA) or mail relay is software that transfers electronic mail messages from one computer to another using SMTP. The terms mail server, mail exchanger, and MX host are also used in some contexts. Messages exchanged across networks are passed between mail servers, including any attached data files (such as images, multimedia or documents). These servers also often keep mailboxes for email. Access to this email by end users is typically either via webmail or an email client." ;
    skos:exactMatch d3f:MailServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Matching a owl:Class ;
    rdfs:label "Matching" ;
    rdfs:subClassOf d3f:AnalyticalPurpose ;
    skos:exactMatch d3f:Matching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MathematicalFunction a owl:Class ;
    rdfs:label "MathematicalFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Mathematical Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Computes mathematical expressions." ;
    skos:exactMatch d3f:MathematicalFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Mean a owl:Class ;
    rdfs:label "Mean" ;
    d3f:d3fend-id "D3A-MEA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "The sum of all measurements divided by the number of observations in the data set." ;
    skos:exactMatch d3f:Mean ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MeanAbsoluteDeviation a owl:Class ;
    rdfs:label "MeanAbsoluteDeviation" ;
    d3f:d3fend-id "D3A-MAD" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Average absolute deviation. [Link](https://en.wikipedia.org/wiki/Average_absolute_deviation)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "MAD" ;
    dcterms:title "Mean Absolute Deviation" ;
    rdfs:subClassOf d3f:AverageAbsoluteDeviation ;
    skos:definition "The mean absolute deviation (MAD), also referred to as the \"mean deviation\" or sometimes \"average absolute deviation\", is the mean of the data's absolute deviations around the data's mean: the average (absolute) distance from the mean." ;
    skos:exactMatch d3f:MeanAbsoluteDeviation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MediaGeneration a owl:Class ;
    rdfs:label "MediaGeneration" ;
    dcterms:title "Media Generation" ;
    rdfs:subClassOf d3f:Generation ;
    skos:exactMatch d3f:MediaGeneration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MediaServer a owl:Class ;
    rdfs:label "MediaServer" ;
    dcterms:title "Media Server" ;
    rdfs:seeAlso dbr:Media_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A media server is a computer appliance or an application software that stores digital media (video, audio or images) and makes it available over a network. Media servers range from servers that provide video on demand to smaller personal computers or NAS (Network Attached Storage) for the home." ;
    skos:exactMatch d3f:MediaServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Median a owl:Class ;
    rdfs:label "Median" ;
    d3f:d3fend-id "D3A-MED" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "The middle value that separates the higher half from the lower half of the data set. The median and the mode are the only measures of central tendency that can be used for ordinal data, in which values are ranked relative to each other but are not measured absolutely." ;
    skos:exactMatch d3f:Median ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MedianAbsoluteDeviation a owl:Class ;
    rdfs:label "MedianAbsoluteDeviation" ;
    d3f:d3fend-id "D3A-MAD" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Average absolute deviation. [Link](https://en.wikipedia.org/wiki/Average_absolute_deviation)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Median Absolute Deviation" ;
    rdfs:subClassOf d3f:AverageAbsoluteDeviation ;
    skos:definition "The median absolute deviation (also MAD) is the median of the absolute deviation from the median." ;
    skos:exactMatch d3f:MedianAbsoluteDeviation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryAllocationEvent a owl:Class ;
    rdfs:label "MemoryAllocationEvent" ;
    dcterms:title "Memory Allocation Event" ;
    rdfs:subClassOf d3f:MemoryEvent ;
    skos:definition "An event representing the allocation of memory resources to a process, providing it with the capacity to store data or execute instructions." ;
    skos:exactMatch d3f:MemoryAllocationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryAllocationFunction a owl:Class ;
    rdfs:label "MemoryAllocationFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Allocation Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Reserves memory for a running process to use." ;
    skos:exactMatch d3f:MemoryAllocationFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryBlockStartValidation a owl:Class ;
    rdfs:label "MemoryBlockStartValidation" ;
    d3f:d3fend-id "D3-MBSV" ;
    d3f:kb-article "## How it Works Ensure that a pointer is referencing the beginning of the intended block before using. ## Considerations Be careful with pointer arithmetic." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Block Start Validation" ;
    rdfs:subClassOf d3f:PointerValidation ;
    skos:definition "Ensuring that a pointer accurately references the beginning of a designated memory block." ;
    skos:exactMatch d3f:MemoryBlockStartValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryBoundaryTracking a owl:Class ;
    rdfs:label "MemoryBoundaryTracking" ;
    d3f:d3fend-id "D3-MBT" ;
    d3f:kb-article "## How it works This technique monitors for indicators of whether a return address is outside memory previously allocated for an object (i.e. function, module, process, or thread). If so, code that the return address points to is treated as malicious code. ## Considerations Kernel malware can manip" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Boundary Tracking" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1055,
        d3f:T1056 ;
    skos:definition "Analyzing a call stack for return addresses which point to unexpected memory locations." ;
    skos:exactMatch d3f:MemoryBoundaryTracking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1055.012,
        mitre-attack:T1056.004,
        mitre-attack:T1068,
        mitre-attack:T1203,
        mitre-attack:T1210,
        mitre-attack:T1211,
        mitre-attack:T1212 .

d3f:MemoryDeletionEvent a owl:Class ;
    rdfs:label "MemoryDeletionEvent" ;
    dcterms:title "Memory Deletion Event" ;
    rdfs:subClassOf d3f:MemoryEvent ;
    skos:definition "An event marking the release or deallocation of memory resources, reclaiming them for reuse within the system." ;
    skos:exactMatch d3f:MemoryDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryDeviceEvent a owl:Class ;
    rdfs:label "MemoryDeviceEvent" ;
    dcterms:title "Memory Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event describing activity in primary storage devices, such as DRAM or SRAM memory initialization, reconfiguration, or failures." ;
    skos:exactMatch d3f:MemoryDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryFreeFunction a owl:Class ;
    rdfs:label "MemoryFreeFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Free Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Releases previously reserved memory associated with a process." ;
    skos:exactMatch d3f:MemoryFreeFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryManagementUnit a owl:Class ;
    rdfs:label "MemoryManagementUnit" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Management Unit" ;
    rdfs:seeAlso <https://dbpedia.org/page/Memory_management_unit>,
        <https://www.techopedia.com/definition/4768/memory-management-unit-mmu> ;
    rdfs:subClassOf d3f:ProcessorComponent ;
    skos:definition "A computer’s memory management unit (MMU) is the physical hardware that handles its virtual memory and caching operations. The MMU is usually located within the computer’s central processing unit (CPU), but sometimes operates in a separate integrated chip (IC)." ;
    skos:exactMatch d3f:MemoryManagementUnit ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryMapEvent a owl:Class ;
    rdfs:label "MemoryMapEvent" ;
    dcterms:title "Memory Map Event" ;
    rdfs:subClassOf d3f:MemoryEvent ;
    skos:definition "An event representing the mapping of memory regions into a process's virtual address space, enabling efficient access to shared or reserved memory." ;
    skos:exactMatch d3f:MemoryMapEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryModificationEvent a owl:Class ;
    rdfs:label "MemoryModificationEvent" ;
    dcterms:title "Memory Modification Event" ;
    rdfs:subClassOf d3f:MemoryEvent ;
    skos:definition "An event where a process modifies allocated memory, potentially altering its content, behavior, or state." ;
    skos:exactMatch d3f:MemoryModificationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryPool a owl:Class ;
    rdfs:label "MemoryPool" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Pool" ;
    rdfs:seeAlso <https://dbpedia.org/page/Memory_pool> ;
    rdfs:subClassOf d3f:MemoryExtent ;
    skos:definition "Memory pools, also called fixed-size blocks allocation, is the use of pools for memory management… preallocating a number of memory blocks with the same size called the memory pool. The application can allocate, access, and free blocks represented by handles at run time." ;
    skos:exactMatch d3f:MemoryPool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryProtectionUnit a owl:Class ;
    rdfs:label "MemoryProtectionUnit" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "MPU" ;
    dcterms:title "Memory Protection Unit" ;
    rdfs:subClassOf d3f:ProcessorComponent ;
    skos:definition "A Memory Protection Unit (MPU) is a processor component that enforces access control policies on memory regions to ensure the integrity, security, and proper operation of a computing system." ;
    skos:exactMatch d3f:MemoryProtectionUnit ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryReadEvent a owl:Class ;
    rdfs:label "MemoryReadEvent" ;
    dcterms:title "Memory Read Event" ;
    rdfs:subClassOf d3f:MemoryEvent ;
    skos:definition "An event where a process retrieves data from a specific memory address, either from its own allocated space or that of another process." ;
    skos:exactMatch d3f:MemoryReadEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryWord a owl:Class ;
    rdfs:label "MemoryWord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Word" ;
    rdfs:seeAlso <https://dbpedia.org/page/Word_(computer_architecture)> ;
    rdfs:subClassOf d3f:MemoryExtent ;
    skos:definition "A memory word is the natural unit of data used by a particular computer processor design; a fixed-size piece of data handled as a unit by the instruction set or the hardware of the processor." ;
    skos:exactMatch d3f:MemoryWord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryWriteEvent a owl:Class ;
    rdfs:label "MemoryWriteEvent" ;
    dcterms:title "Memory Write Event" ;
    rdfs:subClassOf d3f:MemoryEvent ;
    skos:definition "An event where a process writes data to a memory address, storing new information or updating existing content." ;
    skos:exactMatch d3f:MemoryWriteEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MessageEncryption a owl:Class ;
    rdfs:label "MessageEncryption" ;
    d3f:d3fend-id "D3-MENCR" ;
    d3f:kb-article "## How it works ### Asymmetric Cryptography Asymmetric encryption is typically accomplished using public and private key certificates based on the X.509 standard. The sender encrypts messages using the recipient's public key and the receipt decrypts the message using their private key. Standards th" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Message Encryption" ;
    rdfs:subClassOf d3f:MessageHardening ;
    skos:definition "Encrypting a message body using a cryptographic key." ;
    skos:exactMatch d3f:MessageEncryption ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MessageTransferAgent a owl:Class ;
    rdfs:label "MessageTransferAgent" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Message Transfer Agent" ;
    rdfs:seeAlso dbr:Message_transfer_agent ;
    rdfs:subClassOf d3f:MailService ;
    skos:altLabel "MTA",
        "Mail Transfer Agent" ;
    skos:definition "A message transfer agent or mail transfer agent (MTA) or mail relay is software that transfers electronic mail messages from one computer to another using a client-server application architecture. An MTA implements both the client (sending) and server (receiving) portions of the Simple Mail Transfer Protocol." ;
    skos:exactMatch d3f:MessageTransferAgent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Microcode a owl:Class ;
    rdfs:label "Microcode" ;
    rdfs:seeAlso dbr:Microcode ;
    rdfs:subClassOf d3f:Firmware ;
    skos:definition "Microcode is a computer hardware technique that interposes a layer of organization between the CPU hardware and the programmer-visible instruction set architecture of the computer. As such, the microcode is a layer of hardware-level instructions that implement higher-level machine code instructions or internal state machine sequencing in many digital processing elements." ;
    skos:exactMatch d3f:Microcode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MicrosoftHTMLApplication a owl:Class ;
    rdfs:label "MicrosoftHTMLApplication" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "HTA" ;
    dcterms:title "Microsoft HTML Application" ;
    rdfs:seeAlso dbr:HTML_Application ;
    rdfs:subClassOf d3f:HTMLFile ;
    skos:definition "An HTML Application (HTA) is a Microsoft Windows program whose source code consists of HTML, Dynamic HTML, and one or more scripting languages supported by Internet Explorer, such as VBScript or JScript." ;
    skos:exactMatch d3f:MicrosoftHTMLApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MobilePhone a owl:Class ;
    rdfs:label "MobilePhone" ;
    dcterms:title "Mobile Phone" ;
    rdfs:seeAlso dbr:Mobile_phone ;
    rdfs:subClassOf d3f:PersonalComputer ;
    skos:altLabel "Cellphone",
        "Cellular Phone" ;
    skos:definition "A mobile phone, cellular phone, cell phone, cellphone or hand phone, sometimes shortened to simply mobile, cell or just phone, is a portable telephone that can make and receive calls over a radio frequency link while the user is moving within a telephone service area. The radio frequency link establishes a connection to the switching systems of a mobile phone operator, which provides access to the public switched telephone network (PSTN). Modern mobile telephone services use a cellular network architecture and, therefore, mobile telephones are called cellular telephones or cell phones in North America. In addition to telephony, digital mobile phones (2G) support a variety of other services, such as text messaging, MMS, email, Internet access, short-range wireless communications (infrared," ;
    skos:exactMatch d3f:MobilePhone,
        unified_cyber_ontology:MobilePhone ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Mode a owl:Class ;
    rdfs:label "Mode" ;
    d3f:d3fend-id "D3A-MOD" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "The most frequent value in the data set. This is the only central tendency measure that can be used with nominal data, which have purely qualitative category assignments." ;
    skos:exactMatch d3f:Mode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Moments a owl:Class ;
    rdfs:label "Moments" ;
    d3f:d3fend-id "D3A-MOM" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Moment (mathematics). [Link](https://en.wikipedia.org/wiki/Moment_(mathematics))" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DistributionProperties ;
    skos:definition "With a probability distribution function, the the first moment is the expected value, the second central moment is the variance, the third standardized moment is the skewness, and the fourth standardized moment is the kurtosis." ;
    skos:exactMatch d3f:Moments ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MotionDetectedEvent a owl:Class ;
    rdfs:label "MotionDetectedEvent" ;
    dcterms:title "Motion Detected Event" ;
    rdfs:subClassOf d3f:PhysicalAccessAlarmEvent ;
    skos:exactMatch d3f:MotionDetectedEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MotionDetector a owl:Class ;
    rdfs:label "MotionDetector" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Motion Detector" ;
    rdfs:seeAlso <https://dbpedia.org/page/Motion_detector> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Sensor ],
        d3f:HardwareDevice ;
    skos:definition "An electrical device that utilizes a sensor to detect nearby motion." ;
    skos:exactMatch d3f:MotionDetector ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MotionSensorMonitoring a owl:Class ;
    rdfs:label "MotionSensorMonitoring" ;
    d3f:d3fend-id "D3-MSM" ;
    d3f:kb-article "## How it works Motion sensors generate events when movement is detected within their coverage pattern. Alarm panels or PACS correlate motion with arming schedules, door openings, and other sensors; video systems can use motion to trigger recording or bookmarks. Cross-zoning and sensitivity/pulse-c" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Motion Alarm Monitoring" ;
    dcterms:title "Motion Sensor Monitoring" ;
    rdfs:subClassOf d3f:PhysicalAccessMonitoring ;
    skos:definition "Monitoring events from motion detectors (e.g., passive IR, microwave, dual-technology) to detect presence or movement within protected areas." ;
    skos:exactMatch d3f:MotionSensorMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MouseInputDevice a owl:Class ;
    rdfs:label "MouseInputDevice" ;
    dcterms:title "Mouse Input Device" ;
    rdfs:seeAlso dbr:Computer_mouse,
        dbr:Pointing_device ;
    rdfs:subClassOf d3f:InputDevice ;
    skos:altLabel "Computer Mouse" ;
    skos:definition "A computer mouse (plural mice or mouses) is a hand-held pointing device that detects two-dimensional motion relative to a surface. This motion is typically translated into the motion of a pointer on a display, which allows a smooth control of the graphical user interface of a computer. In addition to moving a cursor, computer mice have one or more buttons to allow operations such as selection of a menu item on a display. Mice often also feature other elements, such as touch surfaces and scroll wheels, which enable additional control and dimensional input." ;
    skos:exactMatch d3f:MouseInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MoveFile a owl:Class ;
    rdfs:label "MoveFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Move File" ;
    rdfs:seeAlso <https://man7.org/linux/man-pages/man2/rename.2.html> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:altLabel "Rename File" ;
    skos:definition "A system call to rename or move a file.  Linux's rename() is an example of this kind of system call. Another way of handling it is to call a copy file system call followed by a delete file system call." ;
    skos:exactMatch d3f:MoveFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MovingAverageModel a owl:Class ;
    rdfs:label "MovingAverageModel" ;
    d3f:d3fend-id "D3A-MAM" ;
    d3f:kb-article "## Refrences Wikipedia. (n.d.). Moving average model. [Link](https://en.wikipedia.org/wiki/Moving_average_model)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "MA Model" ;
    dcterms:title "Moving Average Model" ;
    rdfs:subClassOf d3f:TimeSeriesAnalysis ;
    skos:definition "the moving-average model (MA model) is an approach for modeling univariate time series and specifies that the output variable is cross-correlated with a non-identical to itself random-variable." ;
    skos:exactMatch d3f:MovingAverageModel ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MulticlassClassification a owl:Class ;
    rdfs:label "MulticlassClassification" ;
    dcterms:title "Multiclass Classification" ;
    rdfs:subClassOf d3f:Classifying ;
    skos:exactMatch d3f:MulticlassClassification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MultilayerPerceptronClassification a owl:Class ;
    rdfs:label "MultilayerPerceptronClassification" ;
    d3f:d3fend-id "D3A-MPC" ;
    d3f:kb-article "## References Multilayer perceptron. Wikipedia. [Link](https://en.wikipedia.org/wiki/Multilayer_perceptron)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multilayer Perceptron Classification" ;
    rdfs:subClassOf d3f:ArtificialNeuralNetClassification ;
    skos:definition "A multilayer perceptron (MLP) is a fully connected class of feedforward artificial neural network (ANN).An MLP consists of at least three layers of nodes: an input layer, a hidden layer and an output layer." ;
    skos:exactMatch d3f:MultilayerPerceptronClassification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MultimediaDocumentFile a owl:Class ;
    rdfs:label "MultimediaDocumentFile" ;
    dcterms:title "Multimedia Document File" ;
    rdfs:seeAlso <https://dbpedia.org/page/Multimedia> ;
    rdfs:subClassOf d3f:DocumentFile ;
    skos:definition "Digital video files which often contain audio." ;
    skos:exactMatch d3f:MultimediaDocumentFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MultimediaFile a owl:Class ;
    rdfs:label "MultimediaFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multimedia File" ;
    rdfs:subClassOf d3f:File ;
    skos:definition "A file that contains digital multimedia." ;
    skos:exactMatch d3f:MultimediaFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MultipleRegressionLearning a owl:Class ;
    rdfs:label "MultipleRegressionLearning" ;
    d3f:d3fend-id "D3A-MRL" ;
    d3f:kb-article "## References Yale University Department of Statistics. (1997-98). Linear regression and multivariate analysis. [Link](http://www.stat.yale.edu/Courses/1997-98/101/linmult.htm)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multiple Regression Learning" ;
    rdfs:seeAlso d3f:MultipleRegression ;
    rdfs:subClassOf d3f:RegressionAnalysisLearning ;
    skos:definition "A supervised learning method that builds a multiple regression model using training data." ;
    skos:exactMatch d3f:MultipleRegressionLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NISTControl a owl:Class ;
    rdfs:label "NISTControl" ;
    dcterms:title "NIST Control" ;
    rdfs:subClassOf d3f:ExternalControl ;
    skos:exactMatch d3f:NISTControl ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTFSHardLink a owl:Class ;
    rdfs:label "NTFSHardLink" ;
    dcterms:title "NTFS Hard Link" ;
    rdfs:seeAlso dbr:Hard_link,
        dbr:NTFS_links ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:NTFSLink ],
        d3f:HardLink ;
    skos:definition "An NTFS hard link points to another file, and files share the same MFT entry (inode), in the same filesystem." ;
    skos:exactMatch d3f:NTFSHardLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTFSJunctionPoint a owl:Class ;
    rdfs:label "NTFSJunctionPoint" ;
    dcterms:title "NTFS Junction Point" ;
    rdfs:seeAlso dbr:NTFS_links ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SymbolicLink ],
        d3f:NTFSLink ;
    skos:altLabel "Junction Point" ;
    skos:definition "NTFS junction points are are similar to NTFS symlinks but are defined only for directories. Only accepts local absolute paths." ;
    skos:exactMatch d3f:NTFSJunctionPoint ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTFSSymbolicLink a owl:Class ;
    rdfs:label "NTFSSymbolicLink" ;
    dcterms:title "NTFS Symbolic Link" ;
    rdfs:seeAlso dbr:NTFS_links ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SymbolicLink ],
        d3f:NTFSLink ;
    skos:altLabel "NTFS Symlink" ;
    skos:definition "An NTFS symbolic link records the path of another file that the links contents should show. Can accept relative paths. SMB networking (UNC path) and directory support added in NTFS 3.1." ;
    skos:exactMatch d3f:NTFSSymbolicLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPBroadcastEvent a owl:Class ;
    rdfs:label "NTPBroadcastEvent" ;
    dcterms:title "NTP Broadcast Event" ;
    rdfs:subClassOf d3f:NTPEvent ;
    skos:definition "An event where an NTP server broadcasts time synchronization messages to multiple clients simultaneously, enabling synchronization without individual request-response cycles." ;
    skos:exactMatch d3f:NTPBroadcastEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPClientSyncEvent a owl:Class ;
    rdfs:label "NTPClientSyncEvent" ;
    dcterms:title "NTP Client Synchronization Event" ;
    rdfs:subClassOf d3f:NTPEvent ;
    skos:definition "An event where an NTP client requests and adjusts its clock based on time synchronization data provided by an NTP server, ensuring alignment with a standard time source." ;
    skos:exactMatch d3f:NTPClientSyncEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPControlMessageEvent a owl:Class ;
    rdfs:label "NTPControlMessageEvent" ;
    dcterms:title "NTP Control Message Event" ;
    rdfs:subClassOf d3f:NTPEvent ;
    skos:definition "An event where an NTP client or server exchanges control messages used for diagnostic, monitoring, or administrative management of the NTP protocol, rather than time synchronization." ;
    skos:exactMatch d3f:NTPControlMessageEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPServerResponseEvent a owl:Class ;
    rdfs:label "NTPServerResponseEvent" ;
    dcterms:title "NTP Server Response Event" ;
    rdfs:subClassOf d3f:NTPEvent ;
    skos:definition "An event where an NTP server sends time synchronization data to a client, enabling the client to align its local clock with the server's reference time." ;
    skos:exactMatch d3f:NTPServerResponseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPSymmetricActiveExchangeEvent a owl:Class ;
    rdfs:label "NTPSymmetricActiveExchangeEvent" ;
    dcterms:title "NTP Symmetric Active Exchange Event" ;
    rdfs:subClassOf d3f:NTPEvent ;
    skos:definition "An event where an NTP peer operating in symmetric active mode initiates clock synchronization messages to a peer in symmetric passive mode, enabling time synchronization between equal-status systems." ;
    skos:exactMatch d3f:NTPSymmetricActiveExchangeEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPSymmetricPassiveExchangeEvent a owl:Class ;
    rdfs:label "NTPSymmetricPassiveExchangeEvent" ;
    dcterms:title "NTP Symmetric Passive Exchange Event" ;
    rdfs:subClassOf d3f:NTPEvent ;
    skos:definition "An event where an NTP peer operating in symmetric passive mode responds to clock synchronization messages initiated by a symmetric active peer, facilitating mutual timekeeping." ;
    skos:exactMatch d3f:NTPSymmetricPassiveExchangeEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NaiveBayesClassifier a owl:Class ;
    rdfs:label "NaiveBayesClassifier" ;
    d3f:d3fend-id "D3A-NBC" ;
    d3f:kb-article "## References Naive Bayes. IBM. [Link](https://www.ibm.com/topics/naive-bayes?mhsrc=ibmsearch_a&mhq=naive%20bayes)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Naive Bayes Classifier" ;
    rdfs:subClassOf d3f:Classification ;
    skos:definition "The Naïve Bayes classifier is a supervised machine learning algorithm, which is used for classification tasks, like text classification. It is also part of a family of generative learning algorithms, meaning that it seeks to model the distribution of inputs of a given class or category." ;
    skos:exactMatch d3f:NaiveBayesClassifier ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NamedPipe a owl:Class ;
    rdfs:label "NamedPipe" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Named Pipe" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Named_pipe>,
        <https://en.wikipedia.org/wiki/Named_pipe> ;
    rdfs:subClassOf d3f:Pipe ;
    skos:definition "In computing, a named pipe (also known as a FIFO for its behavior) is an extension to the traditional pipe concept on Unix and Unix-like systems, and is one of the methods of inter-process communication (IPC). The concept is also found in OS/2 and Microsoft Windows, although the semantics differ substantially. A traditional pipe is 'unnamed' and lasts only as long as the process. A named pipe, however, can last as long as the system is up, beyond the life of the process. It can be deleted if no longer used. Usually a named pipe appears as a file, and generally processes attach to it for IPC." ;
    skos:exactMatch d3f:NamedPipe,
        unified_cyber_ontology:NamedPipe ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkAudioStreamingResource a owl:Class ;
    rdfs:label "NetworkAudioStreamingResource" ;
    dcterms:title "Network Audio Streaming Resource" ;
    rdfs:subClassOf d3f:NetworkMediaStreamingResource ;
    skos:definition "A server that provides digital audio media content to users." ;
    skos:exactMatch d3f:NetworkAudioStreamingResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkCardFirmware a owl:Class ;
    rdfs:label "NetworkCardFirmware" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Card Firmware" ;
    rdfs:seeAlso dbr:Network_interface_controller ;
    rdfs:subClassOf d3f:PeripheralFirmware ;
    skos:altLabel "Network Controller Firmware" ;
    skos:definition "Firmware that is installed on a network card (network interface controller)." ;
    skos:exactMatch d3f:NetworkCardFirmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkDirectoryResource a owl:Class ;
    rdfs:label "NetworkDirectoryResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Directory Resource" ;
    rdfs:subClassOf d3f:NetworkFileShareResource ;
    skos:definition "A directory resource made available from one host to other hosts on a computer network." ;
    skos:exactMatch d3f:NetworkDirectoryResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkFlow a owl:Class ;
    rdfs:label "NetworkFlow" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Flow" ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:closeMatch stix:NetworkTraffic ;
    skos:definition "A summarization of network transactions between a client and server. It often summarizes bytes sent, bytes received, and protocol flags." ;
    skos:exactMatch d3f:NetworkFlow,
        unified_cyber_ontology:NetworkFlow ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkFlowSensor a owl:Class ;
    rdfs:label "NetworkFlowSensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Flow Sensor" ;
    rdfs:subClassOf d3f:NetworkSensor ;
    skos:definition "Monitors network traffic and produces summaries of data flows traversing the network." ;
    skos:exactMatch d3f:NetworkFlowSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkInitScriptFileResource a owl:Class ;
    rdfs:label "NetworkInitScriptFileResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Init Script File Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:NetworkFileResource ],
        d3f:InitScript ;
    skos:definition "A computer file resource made available from one host to other hosts on a computer network that is also an initialization script." ;
    skos:exactMatch d3f:NetworkInitScriptFileResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkInterfaceCard a owl:Class ;
    rdfs:label "NetworkInterfaceCard" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Network Interface Controller" ;
    dcterms:title "Network Interface Card" ;
    rdfs:seeAlso <https://dbpedia.org/page/Network_interface_controller>,
        <https://schema.ocsf.io/objects/network_interface> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A network interface card (NIC, also known as a network interface controller, network adapter, LAN adapter or physical network interface, and by similar terms) is a computer hardware component that connects a computer to a computer network." ;
    skos:exactMatch d3f:NetworkInterfaceCard ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkLink a owl:Class ;
    rdfs:label "NetworkLink" ;
    d3f:synonym "Layer-3 Link" ;
    dcterms:title "Network Link" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Network_layer>,
        <https://www.techtarget.com/searchnetworking/definition/Network-layer> ;
    rdfs:subClassOf d3f:LogicalLink ;
    skos:definition "A network link is a link within the network layer, which is responsible for packet forwarding including routing through intermediate routers." ;
    skos:exactMatch d3f:NetworkLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkNodeInventory a owl:Class ;
    rdfs:label "NetworkNodeInventory" ;
    d3f:d3fend-id "D3-NNI" ;
    d3f:kb-article "## How it works Administrators collect information on network nodes in their architecture using a variety of administrative and management tools that query network devices and nodes for information. In some cases, where such queries are not supported or provide specific information of interest, an" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "System Discovery" ;
    dcterms:title "Network Node Inventory" ;
    rdfs:subClassOf d3f:AssetInventory ;
    skos:broadMatch d3f:T1114,
        d3f:T1505 ;
    skos:definition "Network node inventorying identifies and records all the network nodes (hosts, routers, switches, firewalls, etc.) in the organization's architecture." ;
    skos:exactMatch d3f:NetworkNodeInventory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.002,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003 .

d3f:NetworkPacket a owl:Class ;
    rdfs:label "NetworkPacket" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Packet" ;
    rdfs:seeAlso dbr:Network_packet ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A network packet is a formatted unit of data carried by a packet-switched network. Computer communications links that do not support packets, such as traditional point-to-point telecommunications links, simply transmit data as a bit stream. When data is formatted into packets, packet switching is possible and the bandwidth of the communication medium can be better shared among users than with circuit switching." ;
    skos:exactMatch d3f:NetworkPacket ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkPrinter a owl:Class ;
    rdfs:label "NetworkPrinter" ;
    dcterms:title "Network Printer" ;
    rdfs:seeAlso dbr:Printer_\(computing\) ;
    rdfs:subClassOf d3f:SharedComputer ;
    skos:definition "In computing, a network printer is a device that can be accessed over a network which makes a persistent representation of graphics or text, usually on paper. While most output is human-readable, bar code printers are an example of an expanded use for printers. The different types of printers include 3D printer, inkjet printer, laser printer, thermal printer, etc.  Note that not all printers are networked and the digital information to be printed must be passed either by removable media or as directly connecting the printer to a computer (e.g., by USB.)" ;
    skos:exactMatch d3f:NetworkPrinter ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkProtocolAnalyzer a owl:Class ;
    rdfs:label "NetworkProtocolAnalyzer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Protocol Analyzer" ;
    rdfs:subClassOf d3f:NetworkSensor ;
    skos:definition "Monitors and parses network protocols to extract values from various network protocol layers." ;
    skos:exactMatch d3f:NetworkProtocolAnalyzer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkScanner a owl:Class ;
    rdfs:label "NetworkScanner" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Scanner" ;
    rdfs:seeAlso <https://dbpedia.org/page/Network_enumeration>,
        <https://en.wikipedia.org/wiki/Network_enumeration#Software> ;
    rdfs:subClassOf d3f:CyberSensor ;
    skos:altLabel "Network Enumerator" ;
    skos:definition "A network scanner is a computer program used to retrieve usernames and info on groups, shares, and services of networked computers. This type of program scans networks for vulnerabilities in the security of that network. If there is a vulnerability with the security of the network, it will send a report back to a hacker who may use this info to exploit that network glitch to gain entry to the network or for other malicious activities. Ethical hackers often also use the information to remove the glitches and strengthen their network." ;
    skos:exactMatch d3f:NetworkScanner ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkTimeServer a owl:Class ;
    rdfs:label "NetworkTimeServer" ;
    dcterms:title "Network Time Server" ;
    rdfs:seeAlso dbr:Time_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A network time server is a server computer that reads the actual time from a reference clock and distributes this information to its clients using a computer network. The time server may be a local network time server or an internet time server. The time server may also be a stand-alone hardware device. It can use NTP (RFC5905) or other protocols." ;
    skos:exactMatch d3f:NetworkTimeServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkTrafficAnalysisSoftware a owl:Class ;
    rdfs:label "NetworkTrafficAnalysisSoftware" ;
    d3f:synonym "Network Sniffer" ;
    dcterms:title "Network Traffic Analysis Software" ;
    rdfs:subClassOf d3f:DeveloperApplication ;
    skos:definition "A packet analyzer, also known as packet sniffer, protocol analyzer, or network analyzer, is a computer program or computer hardware such as a packet capture appliance, that can intercept and log traffic that passes over a computer network or part of a network.\"" ;
    skos:exactMatch d3f:NetworkTrafficAnalysisSoftware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

