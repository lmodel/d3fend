        d3f:T1558,
        d3f:T1565,
        d3f:T1566,
        d3f:T1567,
        d3f:T1573 ;
    skos:definition "Analyzing application protocol level remote commands to detect unauthorized activity." ;
    skos:exactMatch d3f:ApplicationProtocolCommandAnalysis ;
