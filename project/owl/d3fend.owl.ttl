    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that moves or renames a file or directory from one location to another within the file system." ;
    skos:exactMatch d3f:OSAPIMoveFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPISuspendProcess a owl:Class ;
    rdfs:label "OSAPISuspendProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Suspend Process" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that pauses the execution of a process." ;
    skos:exactMatch d3f:OSAPISuspendProcess ;
