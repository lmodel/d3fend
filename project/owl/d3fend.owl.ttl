    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_execute a owl:DatatypeProperty ;
    rdfs:label "may-execute" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may execute y: The subject x might take the action of carrying out (executing) y, which is a single software module, function, or instruction." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

