d3f:OTVariableAccessRestriction a owl:Class ;
    rdfs:label "OTVariableAccessRestriction" ;
    d3f:d3fend-id "D3-OVAR" ;
    d3f:kb-article "## How it works Many OT Controllers and OT Communication Modules enable Read-Only or Read/Write access on a per-tag basis. As an example, when configuring OT process tags which can be accessed using the Modbus protocol, configure the tag to a Modbus Input Register to leverage the protocol's regist" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "OT Variable Access Policy" ;
    dcterms:title "OT Variable Access Restriction" ;
    rdfs:subClassOf d3f:AccessMediation ;
    skos:definition "Assign read/write access controls on designated registers or data tags to prevent unauthorized writes." ;
    skos:exactMatch d3f:OTVariableAccessRestriction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTWatchdogTimer a owl:Class ;
    rdfs:label "OTWatchdogTimer" ;
    dcterms:title "OT Watchdog Timer" ;
    rdfs:seeAlso <https://literature.rockwellautomation.com/idc/groups/literature/documents/pm/1756-pm005_-en-p.pdf> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SoftwareWatchdogTimer ],
        d3f:OTProcessVariable ;
    skos:definition "An OT Watchdog Timer is a software-based monitoring mechanism used in operational technology (OT) environments to continuously supervise the execution and responsiveness of critical control applications, devices, or communication links. It operates by requiring periodic “heartbeat” signals or status updates from monitored processes within a defined time window; if these signals are not received on time (indicating a hang, fault, or abnormal delay) the OT Watchdog Timer automatically triggers predefined safety or recovery actions, such as placing equipment in a fail-safe state, restarting services, generating alarms, or initiating controlled shutdowns." ;
    skos:exactMatch d3f:OTWatchdogTimer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OWL a owl:Class ;
    rdfs:label "OWL" ;
    d3f:d3fend-id "D3A-OWL" ;
    d3f:kb-article "## How it works Ontologies are a formal way to describe taxonomies and classification networks, essentially defining the structure of knowledge for various domains: the nouns representing classes of objects and the verbs representing relations between the objects. The OWL languages are characterize" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Web Ontology Language" ;
    rdfs:subClassOf d3f:DescriptionLogic ;
    skos:definition "The Web Ontology Language (OWL) is a family of knowledge representation languages for authoring ontologies." ;
    skos:exactMatch d3f:OWL ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OffensiveAction a owl:Class ;
    rdfs:label "OffensiveAction" ;
    dcterms:title "Offensive Action" ;
    rdfs:subClassOf d3f:CyberAction ;
    skos:exactMatch d3f:OffensiveAction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OfficeApplicationFile a owl:Class ;
    rdfs:label "OfficeApplicationFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Office Application File" ;
    rdfs:seeAlso d3f:OfficeApplication ;
    rdfs:subClassOf d3f:DocumentFile ;
    skos:definition "A document file in a format associated with an d3f:OfficeApplication." ;
    skos:exactMatch d3f:OfficeApplicationFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OnboardComputer a owl:Class ;
    rdfs:label "OnboardComputer" ;
    d3f:synonym "OBC" ;
    dcterms:title "Onboard Computer" ;
    rdfs:seeAlso <https://blog.satsearch.co/2020-03-11-an-overview-of-on-board-computer-obc-systems-available-on-the-global-space-marketplace>,
        <https://www.esa.int/Enabling_Support/Space_Engineering_Technology/Onboard_Computers_and_Data_Handling/Onboard_Computers> ;
    rdfs:subClassOf d3f:OTEmbeddedComputer ;
    skos:definition "A self-contained, embedded computing unit installed within a vehicle or other autonomous platform that executes real-time control, data-handling, and mission-management software. It interfaces directly with the platform's sensors, actuators, and communication links, processes and stores operational data, and issues commands to subsystems, enabling the system to function independently of external computing resources." ;
    skos:exactMatch d3f:OnboardComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OpenFile a owl:Class ;
    rdfs:label "OpenFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Open File" ;
    rdfs:seeAlso dbr:Open_\(system_call\) ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "For most file systems, a program initializes access to a file in a file system using the open system call. This allocates resources associated to the file (the file descriptor), and returns a handle that the process will use to refer to that file. In some cases the open is performed by the first access. During the open, the filesystem may allocate memory for buffers, or it may wait until the first operation. Various other errors which may occur during the open include directory update failures, un-permitted multiple connections, media failures, communication link failures and device failures." ;
    skos:exactMatch d3f:OpenFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingModeMonitoring a owl:Class ;
    rdfs:label "OperatingModeMonitoring" ;
    d3f:d3fend-id "D3-OMM" ;
    d3f:kb-article "## How it works Many OT Controllers have key switches to change the controller into various modes of operation. These modes of operation can include Program, Run, Remote, or Stop. The key switch position is often available as a system diagnostic function block of the programming logic. ## Consider" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating Mode Monitoring" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:definition "Detects operating modes such as Program, Run, Remote, or Stop." ;
    skos:exactMatch d3f:OperatingModeMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingModeRestriction a owl:Class ;
    rdfs:label "OperatingModeRestriction" ;
    d3f:d3fend-id "D3-OPR" ;
    d3f:kb-article "## How it works Many OT Controllers use key switches to change the controller into different modes of operation. These modes of operation can include Program, Run, Remote, or Stop. The key switch should be left in the appropriate key switch position, e.g., run or remote during normal operations. I" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating Mode Restriction" ;
    rdfs:subClassOf d3f:AccessMediation ;
    skos:definition "Restricting unauthorized changes to the operating mode prevents devices from switching into inappropriate or vulnerable states during normal use." ;
    skos:exactMatch d3f:OperatingModeRestriction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemClock a owl:Class ;
    rdfs:label "OperatingSystemClock" ;
    dcterms:title "Operating System Clock" ;
    rdfs:seeAlso <https://linux.die.net/sag/hw-sw-clocks.html> ;
    rdfs:subClassOf d3f:SoftwareClock ;
    skos:definition "An operating system clock is the primary software clock maintained by the operating system, representing the system's current time. It is used for timestamping files, scheduling tasks, and synchronizing processes." ;
    skos:exactMatch d3f:OperatingSystemClock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemConfigurationFile a owl:Class ;
    rdfs:label "OperatingSystemConfigurationFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Configuration File" ;
    rdfs:seeAlso d3f:ConfigurationFile,
        d3f:OperatingSystem,
        dbr:Configuration_file ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OperatingSystemFile ],
        d3f:ConfigurationFile ;
    skos:altLabel "System Configuration File" ;
    skos:definition "An operating system configuration file is a file used to configure the operating system." ;
    skos:exactMatch d3f:OperatingSystemConfigurationFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemConfigurationModificationEvent a owl:Class ;
    rdfs:label "OperatingSystemConfigurationModificationEvent" ;
    dcterms:title "Operating System Configuration Modification Event" ;
    rdfs:subClassOf d3f:ConfigurationModificationEvent ;
    skos:definition "An event that alters persistent operating-system configuration resources such as kernel options, registry keys, service definitions, or security policies; affecting system startup, hardware interfaces, or global security enforcement." ;
    skos:exactMatch d3f:OperatingSystemConfigurationModificationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemExecutableFile a owl:Class ;
    rdfs:label "OperatingSystemExecutableFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Executable File" ;
    rdfs:subClassOf d3f:OperatingSystemFile ;
    skos:definition "An operating system executable is a critical executable that is part of the operating system, and without which, the operating system may not operate correctly." ;
    skos:exactMatch d3f:OperatingSystemExecutableFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemLogFile a owl:Class ;
    rdfs:label "OperatingSystemLogFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Log File" ;
    rdfs:seeAlso dbr:Log_file ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OperatingSystemFile ],
        d3f:LogFile ;
    skos:definition "An operating system log file records events that occur in an operating system." ;
    skos:exactMatch d3f:OperatingSystemLogFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemPackagingTool a owl:Class ;
    rdfs:label "OperatingSystemPackagingTool" ;
    dcterms:title "Operating System Packaging Tool" ;
    rdfs:subClassOf d3f:SoftwarePackagingTool ;
    skos:definition "A software packaging tool oriented on building a software package for a particular operating system (e.g. rpmbuild.)" ;
    skos:exactMatch d3f:OperatingSystemPackagingTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemSharedLibraryFile a owl:Class ;
    rdfs:label "OperatingSystemSharedLibraryFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Shared Library File" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Library_(computing)#Shared_libraries> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SharedLibraryFile ],
        d3f:OperatingSystemFile ;
    skos:definition "An operating system shared library file is a shared library file that is part of the operating system and that incorporates common operating system code for use by any application or to provide operating system services." ;
    skos:exactMatch d3f:OperatingSystemSharedLibraryFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationalActivityPlan a owl:Class ;
    rdfs:label "OperationalActivityPlan" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Business Process" ;
    dcterms:title "Operational Activity Plan" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00408356-n>,
        <https://en.wikipedia.org/wiki/Business_Process_Model_and_Notation>,
        <https://en.wikipedia.org/wiki/IDEF0>,
        <https://enterpriseintegrationlab.github.io/icity/Activity/doc/index-en.html> ;
    rdfs:subClassOf d3f:Plan ;
    skos:definition "An activity is a specific behavior representing a set of actions that may be accomplished by an agent." ;
    skos:exactMatch d3f:OperationalActivityPlan ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationalDependencyMapping a owl:Class ;
    rdfs:label "OperationalDependencyMapping" ;
    d3f:d3fend-id "D3-ODM" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operational Dependency Mapping" ;
    rdfs:subClassOf d3f:OperationalActivityMapping ;
    skos:definition "Operational dependency mapping identifies and models the dependencies of the organization's activities on each other and on the organization's performers (people, systems, and services.)  This may include modeling the higher- and lower-level activities of an organization forming a hierarchy, or layering, of the dependencies in an organization's activities." ;
    skos:exactMatch d3f:OperationalDependencyMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationalEvent a owl:Class ;
    rdfs:label "OperationalEvent" ;
    d3f:synonym "Business Event" ;
    dcterms:title "Operational Event" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Event_(BPMN)>,
        <https://en.wikipedia.org/wiki/Unified_Architecture_Framework>,
        <https://www.omg.org/spec/UAF/> ;
    rdfs:subClassOf d3f:Action ;
    skos:definition "An Operational Event is an action or occurrence within an organization's mission or business operations that happens over a period of time." ;
    skos:exactMatch d3f:OperationalEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationalLogicValidation a owl:Class ;
    rdfs:label "OperationalLogicValidation" ;
    d3f:d3fend-id "D3-OLV" ;
    d3f:kb-article "## How it works Validates the type, value, and/or range of a variable taking into account the local operational logic and operational state. For example, if a controller has a restricted range when in a specified state, this may crosscheck the value against the state in addition to a more general r" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operational Logic Validation" ;
    rdfs:subClassOf d3f:DomainLogicValidation ;
    skos:definition "Validation of variable state in the context of the control logic of the operational application." ;
    skos:exactMatch d3f:OperationalLogicValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationalProcessMonitoring a owl:Class ;
    rdfs:label "OperationalProcessMonitoring" ;
    d3f:d3fend-id "D3-OPM" ;
    d3f:kb-article "## How it works While some Operational Technology systems are designed to operate without human intervention, most systems are designed with the ability to monitor and modify the physical process with user input. This technique detects adversarial risks to operational processes by observing physic" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Supervisory Control Monitoring" ;
    dcterms:title "Operational Process Monitoring" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:T1003,
        d3f:T1070,
        d3f:T1110,
        d3f:T1134,
        d3f:T1546,
        d3f:T1548 ;
    skos:definition "Monitoring physical parameters and operator actions related to an operational environment." ;
    skos:exactMatch d3f:OperationalProcessMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.006,
        mitre-attack:T1070.001,
        mitre-attack:T1070.003,
        mitre-attack:T1110.001,
        mitre-attack:T1110.003,
        mitre-attack:T1110.004,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1140,
        mitre-attack:T1187,
        mitre-attack:T1546.003,
        mitre-attack:T1546.005,
        mitre-attack:T1548.003 .

d3f:OperationalRiskAssessment a owl:Class ;
    rdfs:label "OperationalRiskAssessment" ;
    d3f:d3fend-id "D3-ORA" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Mission Risk Assessment" ;
    dcterms:title "Operational Risk Assessment" ;
    rdfs:subClassOf d3f:OperationalActivityMapping ;
    skos:definition "Operational risk assessment identifies and models the vulnerabilities of, and risks to, an organization's activities individually and as a whole." ;
    skos:exactMatch d3f:OperationalRiskAssessment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationsCenterComputer a owl:Class ;
    rdfs:label "OperationsCenterComputer" ;
    dcterms:title "Operations Center Computer" ;
    rdfs:seeAlso dbr:Mainframe_computer,
        dbr:Time-sharing ;
    rdfs:subClassOf d3f:SharedComputer ;
    skos:altLabel "Mainframe" ;
    skos:definition "Mainframe computers or mainframes (colloquially referred to as \"big iron\") are computers used primarily by large organizations for critical applications; bulk data processing, such as census, industry and consumer statistics, and enterprise resource planning; and transaction processing. They are larger and have more processing power than some other classes of computers: minicomputers, servers, workstations, and personal computers." ;
    skos:exactMatch d3f:OperationsCenterComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OpticalDiscImage a owl:Class ;
    rdfs:label "OpticalDiscImage" ;
    dcterms:title "Optical Disc Image" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Optical_disc_image>,
        <https://en.wikipedia.org/wiki/Optical_disc_image> ;
    rdfs:subClassOf d3f:DiskImage ;
    skos:definition "An optical disc image (or ISO image, from the ISO 9660 file system used with CD-ROM media) is a disk image that contains everything that would be written to an optical disc, disk sector by disc sector, including the optical disc file system." ;
    skos:exactMatch d3f:OpticalDiscImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OpticalModem a owl:Class ;
    rdfs:label "OpticalModem" ;
    dcterms:title "Optical Modem" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Modem#Optical_modem> ;
    rdfs:subClassOf d3f:Modem ;
    skos:definition "A modem that connects to a fiber optic network is known as an optical network terminal (ONT) or optical network unit (ONU). These are commonly used in fiber to the home installations, installed inside or outside a house to convert the optical medium to a copper Ethernet interface, after which a router or gateway is often installed to perform authentication, routing, NAT, and other typical consumer internet functions, in addition to \"triple play\" features such as telephony and television service." ;
    skos:exactMatch d3f:OpticalModem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OrchestrationWorker a owl:Class ;
    rdfs:label "OrchestrationWorker" ;
    dcterms:title "Orchestration Worker" ;
    rdfs:seeAlso d3f:OrchestrationController ;
    rdfs:subClassOf d3f:OrchestrationServer ;
    skos:definition "A d3f:Server which receives commands from a d3f:OrchestrationController to execute workloads." ;
    skos:exactMatch d3f:OrchestrationWorker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OrganizationMapping a owl:Class ;
    rdfs:label "OrganizationMapping" ;
    d3f:d3fend-id "D3-OM" ;
    d3f:display-order "4" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Organization Mapping" ;
    rdfs:subClassOf d3f:OperationalActivityMapping ;
    skos:definition "Organization mapping identifies and models the people, roles, and groups with an organization and the relations between them." ;
    skos:exactMatch d3f:OrganizationMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetDNSLookupTraffic a owl:Class ;
    rdfs:label "OutboundInternetDNSLookupTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet DNS Lookup Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundInternetNetworkTraffic ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundNetworkTraffic ],
        d3f:DNSNetworkTraffic ;
    skos:definition "Outbound internet DNS lookup traffic is network traffic using the DNS protocol on an outgoing connection initiated from a host within a network to a host outside the network." ;
    skos:exactMatch d3f:OutboundInternetDNSLookupTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetEncryptedRemoteTerminalTraffic a owl:Class ;
    rdfs:label "OutboundInternetEncryptedRemoteTerminalTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet Encrypted Remote Terminal Traffic" ;
    rdfs:subClassOf d3f:OutboundInternetEncryptedTraffic ;
    skos:altLabel "Outbound Internet Encrypted RDP Traffic",
        "Outbound Internet Encrypted SSH Traffic" ;
    skos:definition "Outbound internet encrypted remote terminal traffic is encrypted network traffic for a standard remote terminal protocol on an outgoing connection initiated from a host within a network to a host outside the network." ;
    skos:exactMatch d3f:OutboundInternetEncryptedRemoteTerminalTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetEncryptedWebTraffic a owl:Class ;
    rdfs:label "OutboundInternetEncryptedWebTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet Encrypted Web Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundInternetWebTraffic ],
        d3f:OutboundInternetEncryptedTraffic ;
    skos:definition "Outbound internet encrypted web traffic is network traffic using a standard web protocol on an outgoing connection initiated from a host within a network to a host outside the network." ;
    skos:exactMatch d3f:OutboundInternetEncryptedWebTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetFileTransferTraffic a owl:Class ;
    rdfs:label "OutboundInternetFileTransferTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet File Transfer Traffic" ;
    rdfs:seeAlso dbr:File_transfer,
        dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundInternetNetworkTraffic ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundNetworkTraffic ],
        d3f:FileTransferNetworkTraffic ;
    skos:definition "Outbound internet file transfer traffic is file transfer traffic that is: (a) on an outgoing connection initiated from a host within a network to a host outside the network, and (b) using a standard file transfer protocol." ;
    skos:exactMatch d3f:OutboundInternetFileTransferTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetMailTraffic a owl:Class ;
    rdfs:label "OutboundInternetMailTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet Mail Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf d3f:OutboundInternetNetworkTraffic ;
    skos:altLabel "Outbound Internet Email Traffic" ;
    skos:definition "Outbound internet DNS lookup traffic is network traffic using a standard email protocol on an outgoing connection initiated from a host within a network to a host outside the network." ;
    skos:exactMatch d3f:OutboundInternetMailTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetRPCTraffic a owl:Class ;
    rdfs:label "OutboundInternetRPCTraffic" ;
    dcterms:title "Outbound Internet RPC Traffic" ;
    rdfs:seeAlso dbr:Internetworking,
        dbr:Remote_procedure_call ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:RPCNetworkTraffic ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundNetworkTraffic ],
        d3f:OutboundInternetNetworkTraffic ;
    skos:definition "Outbound internet RPC traffic is RPC traffic that is: (a) on an outgoing connection initiated from a host within a network to a host outside the network, and (b) using a standard RPC protocol." ;
    skos:exactMatch d3f:OutboundInternetRPCTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundTrafficFiltering a owl:Class ;
    rdfs:label "OutboundTrafficFiltering" ;
    d3f:d3fend-id "D3-OTF" ;
    d3f:kb-article "## How it works Outbound traffic, in this context, is network traffic originating from a private host or enclave destined towards untrusted networks. For example: * An enterprise desktop intranet user connecting to www.example.com * An internal mail server connecting to an external mail server, ma" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Traffic Filtering" ;
    rdfs:subClassOf d3f:NetworkTrafficFiltering ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:ExfiltrationTechnique,
        d3f:InitialAccessTechnique,
        d3f:PersistenceTechnique,
        d3f:T1048,
        d3f:T1071,
        d3f:T1090,
        d3f:T1204,
        d3f:T1567,
        d3f:T1573 ;
    skos:definition "Restricting network traffic originating from a private host or enclave destined towards untrusted networks." ;
    skos:exactMatch d3f:OutboundTrafficFiltering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1001,
        mitre-attack:T1008,
        mitre-attack:T1048.001,
        mitre-attack:T1048.002,
        mitre-attack:T1048.003,
        mitre-attack:T1071,
