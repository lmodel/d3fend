d3f:DataLinkLink a owl:Class ;
    rdfs:label "DataLinkLink" ;
    d3f:synonym "Data Link Layer Link" ;
    dcterms:title "Data Link Link" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Link_layer> ;
    rdfs:subClassOf d3f:LogicalLink ;
    skos:definition "A communication link between two network devices connected directly at the physical layer and on the same network segment; i.e., an OSI Layer 2 link." ;
    skos:exactMatch d3f:DataLinkLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DatabaseFile a owl:Class ;
    rdfs:label "DatabaseFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database File" ;
    rdfs:subClassOf d3f:File ;
    skos:definition "A file that stores data and metadata in an organized format, managed by a database management system." ;
    skos:exactMatch d3f:DatabaseFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DatabaseQueryStringAnalysis a owl:Class ;
    rdfs:label "DatabaseQueryStringAnalysis" ;
    d3f:d3fend-id "D3-DQSA" ;
    d3f:kb-article "## How it works Some implementations use software hooks to intercept function calls related to database query operations. Other implementations might intercept or collect network traffic. The database query string is then extracted and analyzed with various methods, for example: * Detecting specifi" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database Query String Analysis" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:broadMatch d3f:InitialAccessTechnique ;
    skos:definition "Analyzing database queries to detect [SQL Injection](https://capec.mitre.org/data/definitions/66.html)." ;
    skos:exactMatch d3f:DatabaseQueryStringAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1190 .

d3f:DatabaseServer a owl:Class ;
    rdfs:label "DatabaseServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database Server" ;
    rdfs:seeAlso dbr:Database_server ;
    rdfs:subClassOf d3f:Server ;
    skos:altLabel "Network Database Resource" ;
    skos:definition "A database server is a server which uses a database application that provides database services to other computer programs or to computers, as defined by the client-server model. Database management systems (DBMSs) frequently provide database-server functionality, and some database management systems (such as MySQL) rely exclusively on the client-server model for database access (while others e.g. SQLite are meant for using as an embedded database). For clarification, a database server is simply a server that maintains services related to clients via database applications." ;
    skos:exactMatch d3f:DatabaseServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DatabaseService a owl:Class ;
    rdfs:label "DatabaseService" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database Service" ;
    rdfs:subClassOf d3f:ServiceApplicationProcess ;
    skos:definition "A database service interacts with a database, either retrieving data through queries or making modifications to its contents." ;
    skos:exactMatch d3f:DatabaseService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Datalog a owl:Class ;
    rdfs:label "Datalog" ;
    d3f:d3fend-id "D3A-DAT" ;
    d3f:kb-article "## How it works Datalog generally uses a bottom-up rather than top-down evaluation model. This difference yields significantly different behavior and properties from Prolog. It is often used as a query language for deductive databases. Datalog has been applied to problems in data integration, networ" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:LogicProgramming ;
    skos:definition "Datalog is a declarative logic programming language that is a syntactically a subset of Prolog." ;
    skos:exactMatch d3f:Datalog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DeadCodeElimination a owl:Class ;
    rdfs:label "DeadCodeElimination" ;
    d3f:d3fend-id "D3-DCE" ;
    d3f:kb-article "## How it works Dead code is code that is considered unreachable by normal program execution. Dead code can be created by adding code under a condition that never evaluates to true. Dead code should be removed since this type of code can produce unexpected results, if accidentally or maliciously fo" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Dead Code Elimination" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:definition "Removing unreachable or \"dead code\" from compiled source code." ;
    skos:exactMatch d3f:DeadCodeElimination ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecisionTreeRegression a owl:Class ;
    rdfs:label "DecisionTreeRegression" ;
    d3f:d3fend-id "D3A-DTR" ;
    d3f:kb-article "## References scikit-learn. (n.d.). Decision Trees. [Link](https://scikit-learn.org/stable/modules/tree.html#tree)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decision Tree Regression" ;
    rdfs:subClassOf d3f:RegressionAnalysisLearning ;
    skos:definition "Decision Trees Regression is asupervised learning method with the goal  to create a model that predicts the value of a target variable by learning simple decision rules inferred from the data features" ;
    skos:exactMatch d3f:DecisionTreeRegression ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoderApplication a owl:Class ;
    rdfs:label "DecoderApplication" ;
    dcterms:title "Decoder Application" ;
    rdfs:subClassOf d3f:CodecApplication ;
    skos:definition "An application that decodes digital data." ;
    skos:exactMatch d3f:DecoderApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoyArtifact a owl:Class ;
    rdfs:label "DecoyArtifact" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy Artifact" ;
    rdfs:seeAlso dbr:Deception_technology,
        <https://doi.org/10.1007/978-3-319-25133-2>,
        <https://shield.mitre.org/> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Decoy",
        "Decoy Object",
        "Lure",
        "Trap" ;
    skos:definition "A decoy is an imitation digital artifact in any sense of a digital artifact, object, or phenomenon that is intended to deceive a cyber attacker's surveillance devices or mislead their evaluation.  Examples include fake files, accounts, hosts (honeypots), and network segments (honeynets)." ;
    skos:exactMatch d3f:DecoyArtifact ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoyFile a owl:Class ;
    rdfs:label "DecoyFile" ;
    d3f:d3fend-id "D3-DF" ;
    d3f:kb-article "## How it works The decoy file is made available as a local or network resource. Accesses to the file may be monitored. The files may be configurations, documents, executables, or other file types. ## Considerations Properties of the file such as cryptographic checksums, file creation date, file m" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Decoy File" ;
    rdfs:subClassOf d3f:DecoyObject ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:ExfiltrationTechnique,
        d3f:LateralMovementTechnique,
