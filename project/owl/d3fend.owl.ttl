d3f:ProximitySensor a owl:Class ;
    rdfs:label "ProximitySensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Proximity Sensor" ;
    rdfs:seeAlso <https://dbpedia.org/page/Proximity_sensor> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Sensor ],
        d3f:HardwareDevice ;
    skos:definition "A sensor able to detect the presence of nearby objects without any physical contact." ;
    skos:exactMatch d3f:ProximitySensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProximitySensorEvent a owl:Class ;
    rdfs:label "ProximitySensorEvent" ;
    dcterms:title "Proximity Sensor Event" ;
    rdfs:subClassOf d3f:PhysicalAccessAlarmEvent ;
    skos:exactMatch d3f:ProximitySensorEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProximitySensorMonitoring a owl:Class ;
    rdfs:label "ProximitySensorMonitoring" ;
    d3f:d3fend-id "D3-PSM" ;
    d3f:kb-article "## How it works Proximity readers and sensors detect credentials or tagged assets within their read field, then report presence and, when applicable, authenticate to a controller for access decisions. Systems may use RSSI, dwell time, or time-of-flight to enforce zones and policies such as anti-pas" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Proximity Reader Monitoring" ;
    dcterms:title "Proximity Sensor Monitoring" ;
    rdfs:subClassOf d3f:PhysicalAccessMonitoring ;
    skos:definition "Monitoring events from proximity sensors that indicate a credential or tagged asset is within the sensor’s read range or a defined zone. Common enabling technologies include RFID, Bluetooth Low Energy (BLE), and Ultra-Wideband (UWB)." ;
    skos:exactMatch d3f:ProximitySensorMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PublicKey a owl:Class ;
    rdfs:label "PublicKey" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Public Key" ;
    rdfs:seeAlso dbr:Public-key_cryptography ;
    rdfs:subClassOf d3f:AsymmetricKey ;
    skos:definition "A public key can be disseminated widely as part of an asymmetric cryptography framework and be used to encrypt messages to send to the public key's owner or to authenticate signed messages from that sender." ;
    skos:exactMatch d3f:PublicKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PythonPackage a owl:Class ;
    rdfs:label "PythonPackage" ;
    dcterms:title "Python Package" ;
    rdfs:seeAlso <https://packaging.python.org/> ;
    rdfs:subClassOf d3f:SoftwarePackage ;
    skos:definition "A Python package is an aggregation of many Python files - either in source code or in bytecode - and associated metadata and resources (text, images, etc.). Python packages can be distributed in different file formats." ;
    skos:exactMatch d3f:PythonPackage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PythonScriptFile a owl:Class ;
    rdfs:label "PythonScriptFile" ;
    d3f:synonym "A script file written in the Python programming language." ;
    dcterms:title "Python Script File" ;
    rdfs:subClassOf d3f:ExecutableScript ;
    skos:exactMatch d3f:PythonScriptFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:QLearning a owl:Class ;
    rdfs:label "Q_Learning" ;
    d3f:d3fend-id "D3A-QL" ;
    d3f:kb-article "## References Q-learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Q-learning)." ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:ModelFreeReinforcementLearning ;
    skos:altLabel "Q-Learning" ;
    skos:definition "Q-learning is a model-free reinforcement learning algorithm to learn the value of an action in a particular state. It does not require a model of the environment (hence \"model-free\"), and it can handle problems with stochastic transitions and rewards without requiring adaptations." ;
    skos:exactMatch d3f:Q-Learning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:QueryByCommittee a owl:Class ;
    rdfs:label "QueryByCommittee" ;
    d3f:d3fend-id "D3A-QBC" ;
    d3f:kb-article "## References Intro to Active Learning. inovex Blog. [Link](https://www.inovex.de/de/blog/intro-to-active-learning/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Query By Committee" ;
    rdfs:subClassOf d3f:ActiveLearning ;
    skos:definition "Query by Committee (QBC) takes inspiration from ensemble methods. Instead of just one classifier, it takes into account the decision of a committee C=ℎ1,…,ℎc of classifiers ℎi. Each classifier has the same target classes, but a different underlying model or a different view on the data." ;
    skos:exactMatch d3f:QueryByCommittee ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RAM a owl:Class ;
    rdfs:label "RAM" ;
    d3f:synonym "Random-access Memory" ;
    rdfs:seeAlso <https://dbpedia.org/page/Random-access_memory> ;
    rdfs:subClassOf d3f:PrimaryStorage ;
    skos:definition "Random-access memory (RAM) is a form of computer memory that can be read and changed in any order, typically used to store working data and machine code." ;
    skos:exactMatch d3f:RAM ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPConnectRequestEvent a owl:Class ;
    rdfs:label "RDPConnectRequestEvent" ;
    dcterms:title "RDP Connect Request Event" ;
    rdfs:subClassOf d3f:RDPEvent ;
    skos:definition "An event where an RDP client sends a connection request specifying session parameters, such as display settings, compression preferences, and security requirements, to prepare for an interactive session." ;
    skos:exactMatch d3f:RDPConnectRequestEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPConnectResponseEvent a owl:Class ;
    rdfs:label "RDPConnectResponseEvent" ;
    dcterms:title "RDP Connect Response Event" ;
    rdfs:subClassOf d3f:RDPEvent ;
    skos:definition "An event where an RDP server acknowledges a connection request, finalizing session parameters and confirming the transition to an interactive remote session." ;
    skos:exactMatch d3f:RDPConnectResponseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPInitialRequestEvent a owl:Class ;
    rdfs:label "RDPInitialRequestEvent" ;
    dcterms:title "RDP Initial Request Event" ;
    rdfs:subClassOf d3f:RDPEvent ;
    skos:definition "An event where an RDP client initiates communication with a server by sending a request to establish a session and negotiate protocol capabilities for remote interaction." ;
    skos:exactMatch d3f:RDPInitialRequestEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPInitialResponseEvent a owl:Class ;
    rdfs:label "RDPInitialResponseEvent" ;
    dcterms:title "RDP Initial Response Event" ;
    rdfs:subClassOf d3f:RDPEvent ;
    skos:definition "An event where an RDP server responds to an initial request from a client, presenting its supported capabilities and agreeing to proceed with session negotiation." ;
    skos:exactMatch d3f:RDPInitialResponseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPSession a owl:Class ;
    rdfs:label "RDPSession" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "RDP Session" ;
    rdfs:seeAlso dbr:Remote_Desktop_Protocol,
        dbr:Remote_Desktop_Services ;
    rdfs:subClassOf d3f:RemoteSession ;
    skos:altLabel "Remote Desktop Session",
        "Terminal Services" ;
    skos:definition "A Remote Desktop Protocol (RDP) session is a session established using the RDP protocol to access Remove Desktop Services (RDS)." ;
    skos:exactMatch d3f:RDPSession ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPTLSHandshakeEvent a owl:Class ;
    rdfs:label "RDPTLSHandshakeEvent" ;
    dcterms:title "RDP TLS Handshake Event" ;
    rdfs:subClassOf d3f:RDPEvent ;
    skos:definition "An event representing the cryptographic exchange of keys and certificates between an RDP client and server to establish a secure communication channel. The handshake ensures encryption, integrity, and authentication for the session." ;
    skos:exactMatch d3f:RDPTLSHandshakeEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0004 a owl:Class ;
    rdfs:label "REC_0004" ;
    d3f:attack-id "REC-0004" ;
    dcterms:title "Gather Launch Information" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0004/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0004" ;
    skos:definition "Threat actors may gather the launch date and time, location of the launch (country & specific site), organizations involved, launch vehicle, etc. This information can provide insight into protocols, regulations, and provide further targets for the threat actor, including specific vulnerabilities with the launch vehicle itself." ;
    skos:exactMatch d3f:REC-0004,
        mitre-attack:REC-0004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RFShielding a owl:Class ;
    rdfs:label "RFShielding" ;
    d3f:d3fend-id "D3-RFS" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "RF Shielding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ElectromagneticRadiationHardening ],
        d3f:PlatformHardening ;
    skos:definition "Adding physical barriers to a platform to prevent undesired radio interference." ;
    skos:exactMatch d3f:RFShielding ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RPCTrafficAnalysis a owl:Class ;
    rdfs:label "RPCTrafficAnalysis" ;
    d3f:d3fend-id "D3-RTA" ;
    d3f:kb-article "## How it works A remote procedure call (RPC) enables one computer to execute a specific function on another computer, as if it were a local application process. There are numerous RPC specifications and implementations. RPC capabilities can be abused by attackers in order to achieve a variety of ta" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "RPC Protocol Analysis" ;
    dcterms:title "RPC Traffic Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:T1558 ;
    skos:definition "Monitoring the activity of remote procedure calls in communication traffic to establish standard protocol operations and potential attacker activities." ;
    skos:exactMatch d3f:RPCTrafficAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1558.003 .

d3f:RTCUpdateEvent a owl:Class ;
    rdfs:label "RTCUpdateEvent" ;
    dcterms:title "RTC Update Event" ;
    rdfs:subClassOf d3f:HardwareClockEvent ;
    skos:definition "An event in which a Real-Time Clock's stored time value is read from or written to its battery-backed storage." ;
    skos:exactMatch d3f:RTCUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RTSPServer a owl:Class ;
    rdfs:label "RTSPServer" ;
    dcterms:title "RTSP Server" ;
    rdfs:subClassOf d3f:NetworkAudioVisualStreamingResource ;
    skos:definition "A streaming server that utilizes the real-time streaming protocol." ;
    skos:exactMatch d3f:RTSPServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RadioModem a owl:Class ;
    rdfs:label "RadioModem" ;
    dcterms:title "Radio Modem" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Modem#Radio> ;
    rdfs:subClassOf d3f:Modem ;
    skos:definition "A radio modem provides the means to send digital data wirelessly.  Radio modems are used to communicate by direct broadcast satellite, WiFi, WiMax, mobile phones, GPS, Bluetooth and NFC. Modern telecommunications and data networks also make extensive use of radio modems where long distance data links are required. Such systems are an important part of the PSTN, and are also in common use for high-speed computer network links to outlying areas where fiber optic is not economical." ;
    skos:exactMatch d3f:RadioModem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RandomForest a owl:Class ;
    rdfs:label "RandomForest" ;
    d3f:d3fend-id "D3A-RF" ;
    d3f:kb-article "## References Random forest. Wikipedia. [Link](https://en.wikipedia.org/wiki/Random_forest)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Random Forest" ;
    rdfs:subClassOf d3f:BootstrapAggregating ;
    skos:definition "Random Forest is a ML method that combines several other ML methods. At its core, Random Forest is an ensemble method of multiple bootstrapped decision trees filled with training data and random feature selection." ;
    skos:exactMatch d3f:RandomForest ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RandomSplits a owl:Class ;
    rdfs:label "RandomSplits" ;
    d3f:d3fend-id "D3A-RS" ;
    d3f:kb-article "## References How to Create a Random Split Cross-Validation and Bagging Ensemble for Deep Learning in Keras.\"*Machine Learning Mastery*. [Link](https://machinelearningmastery.com/how-to-create-a-random-split-cross-validation-and-bagging-ensemble-for-deep-learning-in-keras/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Random Splits" ;
    rdfs:subClassOf d3f:ResamplingEnsemble ;
    skos:definition "The dataset is repeatedly sampled with a random split of the data into train and test sets." ;
    skos:exactMatch d3f:RandomSplits ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Range a owl:Class ;
    rdfs:label "Range" ;
    d3f:d3fend-id "D3A-RAN" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Range (statistics). [Link](https://en.wikipedia.org/wiki/Range_(statistics))" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:Variability ;
    skos:definition "The range of a set of data is the difference between the largest and smallest value." ;
    skos:exactMatch d3f:Range ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RangeMatching a owl:Class ;
    rdfs:label "RangeMatching" ;
    d3f:d3fend-id "D3A-RM" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Range Matching" ;
    rdfs:subClassOf d3f:NumericPatternMatching ;
    skos:definition "Numeric Range Matching determines if a value lies with an interval of values (i.e., within the range of values.)" ;
    skos:exactMatch d3f:RangeMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

<http://d3fend.mitre.org/ontologies/d3fend.owl#RatingEnum#Unspecified> a owl:Class ;
    rdfs:label "Unspecified" ;
    rdfs:subClassOf d3f:RatingEnum,
        linkml:PermissibleValue ;
    skos:definition "Unspecified" .

d3f:RawMemoryAccessFunction a owl:Class ;
    rdfs:label "RawMemoryAccessFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Raw Memory Access Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "A function which accesses raw memory, usually using memory addresses." ;
    skos:exactMatch d3f:RawMemoryAccessFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ReadFile a owl:Class ;
    rdfs:label "ReadFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Read File" ;
    rdfs:seeAlso dbr:Read_\(system_call\) ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "A program that needs to access data from a file stored in a file system uses the read system call. The file is identified by a file descriptor that is normally obtained from a previous call to open. This system call reads in data in bytes, the number of which is specified by the caller, from the file and stores then into a buffer supplied by the calling process." ;
    skos:exactMatch d3f:ReadFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ReadMemory a owl:Class ;
    rdfs:label "ReadMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Read Memory" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:ReadMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RealtimeClock a owl:Class ;
    rdfs:label "RealtimeClock" ;
    d3f:synonym "RTC" ;
    dcterms:title "Real-time Clock" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Real-time_clock> ;
    rdfs:subClassOf d3f:HardwareClock ;
    skos:definition "A real-time clock (RTC) is an electronic device (most often in the form of an integrated circuit) that measures the passage of time." ;
    skos:exactMatch d3f:RealtimeClock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ReferenceNullification a owl:Class ;
    rdfs:label "ReferenceNullification" ;
    d3f:d3fend-id "D3-RN" ;
    d3f:kb-article "## How it Works Nullifying references to memory blocks makes those blocks no longer accessible. This is critical to prevent use-after-free errors. ## Considerations * If a memory block is freed, all other references to that block should be nullified. * This is particularly relevant when manually ma" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Reference Nullification" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:definition "Invalidating all pointers that reference a specific memory block, ensuring that the block cannot be accessed or modified after deallocation." ;
    skos:exactMatch d3f:ReferenceNullification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RegexMatching a owl:Class ;
    rdfs:label "RegexMatching" ;
    d3f:d3fend-id "D3A-RM" ;
    d3f:kb-article "## How it works A regular expression (shortened as regex or regexp) is a sequence of characters that specifies a match pattern in text. Usually such patterns are used by string-searching algorithms for \"find\" or \"find and replace\" operations on strings, or for input validation. ## Key Test Conside" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Regex" ;
    dcterms:title "Regex Matching" ;
    rdfs:subClassOf d3f:PartialMatching ;
