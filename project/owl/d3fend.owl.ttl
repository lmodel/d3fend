        d3f:T1562,
        d3f:T1564,
        d3f:T1565,
        d3f:T1566,
        d3f:T1574 ;
    skos:definition "Executing or opening a file in a synthetic \"sandbox\" environment to determine if the file is a malicious program or if the file exploits another program such as a document reader." ;
    skos:exactMatch d3f:DynamicAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1016,
        mitre-attack:T1027.001,
        mitre-attack:T1027.002,
        mitre-attack:T1027.004,
        mitre-attack:T1036.001,
        mitre-attack:T1036.003,
        mitre-attack:T1037.001,
        mitre-attack:T1037.002,
        mitre-attack:T1037.003,
        mitre-attack:T1037.004,
        mitre-attack:T1055.003,
        mitre-attack:T1059,
        mitre-attack:T1114.001,
        mitre-attack:T1137.001,
        mitre-attack:T1137.003,
        mitre-attack:T1140,
        mitre-attack:T1204.002,
        mitre-attack:T1218.005,
        mitre-attack:T1220,
        mitre-attack:T1505.003,
