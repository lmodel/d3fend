d3f:Authentication a owl:Class ;
    rdfs:label "Authentication" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Authentication,
        <http://wordnet-rdf.princeton.edu/id/00155053-n> ;
    rdfs:subClassOf d3f:DefensiveAction ;
    skos:definition "A request-response comprising a user credential presentation to a system and a verification response." ;
    skos:exactMatch d3f:Authentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Authorization a owl:Class ;
    rdfs:label "Authorization" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Authorization ;
    rdfs:subClassOf d3f:DefensiveAction ;
    skos:definition "Authorization is the function of specifying access rights to resources related to information security and computer security in general and to access control in particular. More formally, \"to authorize\" is to define an access policy. For example, human resources staff is normally authorized to access employee records and this policy is usually formalized as access control rules in a computer system. During operation, the system uses the access control rules to decide whether access requests from (authenticated) consumers shall be approved (granted) or disapproved (rejected). Resources include individual files or an item's data, computer programs, computer devices and functionality provided by computer applications. Examples of consumers are computer users, computer program" ;
    skos:exactMatch d3f:Authorization ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthorizationEvent a owl:Class ;
    rdfs:label "AuthorizationEvent" ;
    dcterms:title "Authorization Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/classes/authorize_session> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event reflecting the decision-making process and actions concerning access control, recording whether agents are permitted or denied access to resources based on pre-defined access control policies." ;
    skos:exactMatch d3f:AuthorizationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BSDProcess a owl:Class ;
    rdfs:label "BSDProcess" ;
    rdfs:subClassOf d3f:ProcessEnum,
        linkml:PermissibleValue ;
    skos:definition "BSD Process" .

d3f:BashScriptFile a owl:Class ;
    rdfs:label "BashScriptFile" ;
    rdfs:subClassOf d3f:ExecutableScriptEnum,
        linkml:PermissibleValue ;
    skos:definition "Bash Script File" .

d3f:BayesianLinearRegression a owl:Class ;
    rdfs:label "BayesianLinearRegression" ;
    d3f:d3fend-id "D3A-BLR" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Bayesian linear regression. [Link](https://en.wikipedia.org/wiki/Bayesian_linear_regression)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Linear Regression" ;
    rdfs:subClassOf d3f:RegressionAnalysis ;
    skos:definition "Bayesian linear regression is a type of conditional modeling in which the mean of one variable is described by a linear combination of other variables, with the goal of obtaining the posterior probability of the regression coefficients." ;
    skos:exactMatch d3f:BayesianLinearRegression ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BinaryLargeObject a owl:Class ;
    rdfs:label "BinaryLargeObject" ;
    dcterms:title "Binary Large Object" ;
    rdfs:seeAlso dbr:Binary_large_object ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "BLOB",
        "Blob" ;
    skos:definition "A binary large object (BLOB) is a collection of binary data stored as a single entity. Blobs are typically images, audio or other multimedia objects, though sometimes binary executable code is stored as a blob." ;
    skos:exactMatch d3f:BinaryLargeObject ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BookReferenceEnum a owl:Class ;
    rdfs:label "BookReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-IntroductoryComputerForensics d3f:Reference-OrganizationalManagementInSAPERPHCM ) ;
    skos:definition "Enumeration of BookReference values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:Reference-IntroductoryComputerForensics,
        d3f:Reference-OrganizationalManagementInSAPERPHCM .

d3f:BootstrapAggregating a owl:Class ;
    rdfs:label "BootstrapAggregating" ;
    d3f:d3fend-id "D3A-BA" ;
    d3f:kb-article "## References Bootstrap aggregating. Wikipedia. [Link](https://en.wikipedia.org/wiki/Bootstrap_aggregating)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bootstrap Aggregating" ;
    rdfs:subClassOf d3f:ResamplingEnsemble ;
    skos:definition "Bootstrap aggregating, also called bagging (from bootstrap aggregating), is a machine learning ensemble meta-algorithm designed to improve the stability and accuracy of machine learning algorithms used in statistical classification and regression. It also reduces variance and helps to avoid overfitting. Although it is usually applied to decision tree methods, it can be used with any type of method. Bagging is a special case of the model averaging approach." ;
    skos:exactMatch d3f:BootstrapAggregating ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CAPECThing a owl:Class ;
    rdfs:label "CAPECThing" ;
    dcterms:title "CAPEC Thing" ;
    rdfs:subClassOf d3f:ExternalThreatModelThing ;
    skos:exactMatch d3f:CAPECThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CART a owl:Class ;
    rdfs:label "CART" ;
    d3f:d3fend-id "D3A-CAR" ;
    d3f:kb-article "## References Classification and Regression Tree (CART) Algorithm. Analytics Steps. [Link](https://www.analyticssteps.com/blogs/classification-and-regression-tree-cart-algorithm)." ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DecisionTree ;
    skos:definition "The CART algorithm is a type of classification algorithm that is required to build a decision tree on the basis of Gini’s impurity index." ;
    skos:exactMatch d3f:CART ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1025 a owl:Class ;
    rdfs:label "CWE_1025" ;
    d3f:cwe-id "CWE-1025" ;
    dcterms:title "Comparison Using Wrong Factors" ;
    rdfs:subClassOf d3f:CWE697 ;
    skos:altLabel "CWE-1025" ;
    skos:definition "The code performs a comparison between two entities, but the comparison examines the wrong factors or characteristics of the entities, which can lead to incorrect results and resultant weaknesses." ;
    skos:exactMatch d3f:CWE-1025,
        cwe:CWE-1025 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1038 a owl:Class ;
    rdfs:label "CWE_1038" ;
    d3f:cwe-id "CWE-1038" ;
    dcterms:title "Insecure Automated Optimizations" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE758 ],
        d3f:CWE435 ;
    skos:altLabel "CWE-1038" ;
    skos:definition "The product uses a mechanism that automatically optimizes code, e.g. to improve a characteristic such as performance, but the optimizations can have an unintended side effect that might violate an intended security assumption." ;
    skos:exactMatch d3f:CWE-1038,
        cwe:CWE-1038 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1071 a owl:Class ;
    rdfs:label "CWE_1071" ;
    d3f:cwe-id "CWE-1071" ;
    dcterms:title "Empty Code Block" ;
    rdfs:subClassOf d3f:CWE1164 ;
    skos:altLabel "CWE-1071" ;
    skos:definition "The source code contains a block that does not contain any code, i.e., the block is empty." ;
    skos:exactMatch d3f:CWE-1071,
        cwe:CWE-1071 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1177 a owl:Class ;
    rdfs:label "CWE_1177" ;
    d3f:cwe-id "CWE-1177" ;
    dcterms:title "Use of Prohibited Code" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1177" ;
    skos:definition "The product uses a function, library, or third party component that has been explicitly prohibited, whether by the developer or the customer." ;
    skos:exactMatch d3f:CWE-1177,
        cwe:CWE-1177 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1230 a owl:Class ;
    rdfs:label "CWE_1230" ;
    d3f:cwe-id "CWE-1230" ;
    dcterms:title "Exposure of Sensitive Information Through Metadata" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-1230" ;
    skos:definition "The product prevents direct access to a resource containing sensitive information, but it does not sufficiently limit access to metadata that is derived from the original, sensitive information." ;
    skos:exactMatch d3f:CWE-1230,
        cwe:CWE-1230 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE125 a owl:Class ;
    rdfs:label "CWE_125" ;
    d3f:cwe-id "CWE-125" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "OOB read" ;
    dcterms:title "Out-of-bounds Read" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-125" ;
    skos:definition "The product reads data past the end, or before the beginning, of the intended buffer." ;
    skos:exactMatch d3f:CWE-125,
        cwe:CWE-125 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1250 a owl:Class ;
    rdfs:label "CWE_1250" ;
    d3f:cwe-id "CWE-1250" ;
    dcterms:title "Improper Preservation of Consistency Between Independent Representations of Shared State" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-1250" ;
    skos:definition "The product has or supports multiple distributed components or sub-systems that are each required to keep their own local copy of shared data - such as state or cache - but the product does not ensure that all local copies remain consistent with each other." ;
    skos:exactMatch d3f:CWE-1250,
        cwe:CWE-1250 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1284 a owl:Class ;
    rdfs:label "CWE_1284" ;
    d3f:cwe-id "CWE-1284" ;
    dcterms:title "Improper Validation of Specified Quantity in Input" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1284" ;
    skos:definition "The product receives input that is expected to specify a quantity (such as size or length), but it does not validate or incorrectly validates that the quantity has the required properties." ;
    skos:exactMatch d3f:CWE-1284,
        cwe:CWE-1284 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1285 a owl:Class ;
    rdfs:label "CWE_1285" ;
    d3f:cwe-id "CWE-1285" ;
    dcterms:title "Improper Validation of Specified Index, Position, or Offset in Input" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1285" ;
    skos:definition "The product receives input that is expected to specify an index, position, or offset into an indexable resource such as a buffer or file, but it does not validate or incorrectly validates that the specified index/position/offset has the required properties." ;
    skos:exactMatch d3f:CWE-1285,
        cwe:CWE-1285 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1329 a owl:Class ;
    rdfs:label "CWE_1329" ;
    d3f:cwe-id "CWE-1329" ;
    dcterms:title "Reliance on Component That is Not Updateable" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE664 ],
        d3f:CWE1357 ;
    skos:altLabel "CWE-1329" ;
    skos:definition "The product contains a component that cannot be updated or patched in order to remove vulnerabilities or significant bugs." ;
    skos:exactMatch d3f:CWE-1329,
        cwe:CWE-1329 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1357 a owl:Class ;
    rdfs:label "CWE_1357" ;
    d3f:cwe-id "CWE-1357" ;
    dcterms:title "Reliance on Insufficiently Trustworthy Component" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1357" ;
    skos:definition "The product is built from multiple separate components, but it uses a component that is not sufficiently trusted to meet expectations for security, reliability, updateability, and maintainability." ;
    skos:exactMatch d3f:CWE-1357,
        cwe:CWE-1357 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1392 a owl:Class ;
    rdfs:label "CWE_1392" ;
    d3f:cwe-id "CWE-1392" ;
    dcterms:title "Use of Default Credentials" ;
    rdfs:subClassOf d3f:CWE1391 ;
    skos:altLabel "CWE-1392" ;
    skos:definition "The product uses default credentials (such as passwords or cryptographic keys) for potentially critical functionality." ;
    skos:exactMatch d3f:CWE-1392,
        cwe:CWE-1392 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE160 a owl:Class ;
    rdfs:label "CWE_160" ;
    d3f:cwe-id "CWE-160" ;
    dcterms:title "Improper Neutralization of Leading Special Elements" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-160" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes leading special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-160,
        cwe:CWE-160 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE163 a owl:Class ;
    rdfs:label "CWE_163" ;
    d3f:cwe-id "CWE-163" ;
    dcterms:title "Improper Neutralization of Multiple Trailing Special Elements" ;
    rdfs:subClassOf d3f:CWE162 ;
    skos:altLabel "CWE-163" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes multiple trailing special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-163,
        cwe:CWE-163 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE165 a owl:Class ;
    rdfs:label "CWE_165" ;
    d3f:cwe-id "CWE-165" ;
    dcterms:title "Improper Neutralization of Multiple Internal Special Elements" ;
    rdfs:subClassOf d3f:CWE164 ;
    skos:altLabel "CWE-165" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes multiple internal special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-165,
        cwe:CWE-165 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE179 a owl:Class ;
    rdfs:label "CWE_179" ;
    d3f:cwe-id "CWE-179" ;
    dcterms:title "Incorrect Behavior Order: Early Validation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE696 ],
        d3f:CWE20 ;
    skos:altLabel "CWE-179" ;
    skos:definition "The product validates input before applying protection mechanisms that modify the input, which could allow an attacker to bypass the validation via dangerous inputs that only arise after the modification." ;
    skos:exactMatch d3f:CWE-179,
        cwe:CWE-179 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE185 a owl:Class ;
    rdfs:label "CWE_185" ;
    d3f:cwe-id "CWE-185" ;
    dcterms:title "Incorrect Regular Expression" ;
    rdfs:subClassOf d3f:CWE697 ;
    skos:altLabel "CWE-185" ;
    skos:definition "The product specifies a regular expression in a way that causes data to be improperly matched or compared." ;
    skos:exactMatch d3f:CWE-185,
        cwe:CWE-185 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE205 a owl:Class ;
    rdfs:label "CWE_205" ;
    d3f:cwe-id "CWE-205" ;
    dcterms:title "Observable Behavioral Discrepancy" ;
    rdfs:subClassOf d3f:CWE203 ;
    skos:altLabel "CWE-205" ;
    skos:definition "The product's behaviors indicate important differences that may be observed by unauthorized actors in a way that reveals (1) its internal state or decision process, or (2) differences from other products with equivalent functionality." ;
    skos:exactMatch d3f:CWE-205,
        cwe:CWE-205 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE212 a owl:Class ;
    rdfs:label "CWE_212" ;
    d3f:cwe-id "CWE-212" ;
    dcterms:title "Improper Removal of Sensitive Information Before Storage or Transfer" ;
    rdfs:subClassOf d3f:CWE669 ;
    skos:altLabel "CWE-212" ;
    skos:definition "The product stores, transfers, or shares a resource that contains sensitive information, but it does not properly remove that information before the product makes the resource available to unauthorized actors." ;
    skos:exactMatch d3f:CWE-212,
        cwe:CWE-212 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE22 a owl:Class ;
    rdfs:label "CWE_22" ;
    d3f:cwe-id "CWE-22" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Directory traversal" ;
    dcterms:title "Improper Limitation of a Pathname to a Restricted Directory ('Path Traversal')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE706 ],
        d3f:CWE668 ;
    skos:altLabel "CWE-22" ;
    skos:definition "The product uses external input to construct a pathname that is intended to identify a file or directory that is located underneath a restricted parent directory, but the product does not properly neutralize special elements within the pathname that can cause the pathname to resolve to a location that is outside of the restricted directory." ;
    skos:exactMatch d3f:CWE-22,
        cwe:CWE-22 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE223 a owl:Class ;
    rdfs:label "CWE_223" ;
    d3f:cwe-id "CWE-223" ;
    dcterms:title "Omission of Security-relevant Information" ;
    rdfs:subClassOf d3f:CWE221 ;
    skos:altLabel "CWE-223" ;
    skos:definition "The product does not record or display information that would be important for identifying the source or nature of an attack, or determining if an action is safe." ;
    skos:exactMatch d3f:CWE-223,
        cwe:CWE-223 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE271 a owl:Class ;
    rdfs:label "CWE_271" ;
    d3f:cwe-id "CWE-271" ;
    dcterms:title "Privilege Dropping / Lowering Errors" ;
    rdfs:subClassOf d3f:CWE269 ;
    skos:altLabel "CWE-271" ;
    skos:definition "The product does not drop privileges before passing control of a resource to an actor that does not have those privileges." ;
    skos:exactMatch d3f:CWE-271,
        cwe:CWE-271 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE282 a owl:Class ;
    rdfs:label "CWE_282" ;
    d3f:cwe-id "CWE-282" ;
    dcterms:title "Improper Ownership Management" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-282" ;
    skos:definition "The product assigns the wrong ownership, or does not properly verify the ownership, of an object or resource." ;
    skos:exactMatch d3f:CWE-282,
        cwe:CWE-282 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE288 a owl:Class ;
    rdfs:label "CWE_288" ;
    d3f:cwe-id "CWE-288" ;
    dcterms:title "Authentication Bypass Using an Alternate Path or Channel" ;
    rdfs:subClassOf d3f:CWE306 ;
    skos:altLabel "CWE-288" ;
    skos:definition "The product requires authentication, but the product has an alternate path or channel that does not require authentication." ;
    skos:exactMatch d3f:CWE-288,
        cwe:CWE-288 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE306 a owl:Class ;
    rdfs:label "CWE_306" ;
    d3f:cwe-id "CWE-306" ;
    dcterms:title "Missing Authentication for Critical Function" ;
    rdfs:subClassOf d3f:CWE287 ;
    skos:altLabel "CWE-306" ;
    skos:definition "The product does not perform any authentication for functionality that requires a provable user identity or consumes a significant amount of resources." ;
    skos:exactMatch d3f:CWE-306,
        cwe:CWE-306 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE311 a owl:Class ;
    rdfs:label "CWE_311" ;
    d3f:cwe-id "CWE-311" ;
    dcterms:title "Missing Encryption of Sensitive Data" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-311" ;
    skos:definition "The product does not encrypt sensitive or critical information before storage or transmission." ;
    skos:exactMatch d3f:CWE-311,
        cwe:CWE-311 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE331 a owl:Class ;
    rdfs:label "CWE_331" ;
    d3f:cwe-id "CWE-331" ;
    dcterms:title "Insufficient Entropy" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-331" ;
    skos:definition "The product uses an algorithm or scheme that produces insufficient entropy, leaving patterns or clusters of values that are more likely to occur than others." ;
    skos:exactMatch d3f:CWE-331,
        cwe:CWE-331 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE346 a owl:Class ;
    rdfs:label "CWE_346" ;
    d3f:cwe-id "CWE-346" ;
    dcterms:title "Origin Validation Error" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE345 ],
        d3f:CWE284 ;
    skos:altLabel "CWE-346" ;
    skos:definition "The product does not properly verify that the source of data or communication is valid." ;
    skos:exactMatch d3f:CWE-346,
        cwe:CWE-346 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE377 a owl:Class ;
    rdfs:label "CWE_377" ;
    d3f:cwe-id "CWE-377" ;
    dcterms:title "Insecure Temporary File" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-377" ;
    skos:definition "Creating and using insecure temporary files can leave application and system data vulnerable to attack." ;
    skos:exactMatch d3f:CWE-377,
        cwe:CWE-377 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE402 a owl:Class ;
    rdfs:label "CWE_402" ;
    d3f:cwe-id "CWE-402" ;
    d3f:synonym "Resource Leak" ;
    dcterms:title "Transmission of Private Resources into a New Sphere ('Resource Leak')" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-402" ;
    skos:definition "The product makes resources available to untrusted parties when those resources are only intended to be accessed by the product." ;
    skos:exactMatch d3f:CWE-402,
        cwe:CWE-402 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE441 a owl:Class ;
    rdfs:label "CWE_441" ;
    d3f:cwe-id "CWE-441" ;
    d3f:synonym "Confused Deputy" ;
    dcterms:title "Unintended Proxy or Intermediary ('Confused Deputy')" ;
    rdfs:subClassOf d3f:CWE610 ;
    skos:altLabel "CWE-441" ;
    skos:definition "The product receives a request, message, or directive from an upstream component, but the product does not sufficiently preserve the original source of the request before forwarding the request to an external actor that is outside of the product's control sphere. This causes the product to appear to be the source of the request, leading it to act as a proxy or other intermediary between the upstream component and the external actor." ;
    skos:exactMatch d3f:CWE-441,
        cwe:CWE-441 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE451 a owl:Class ;
    rdfs:label "CWE_451" ;
    d3f:cwe-id "CWE-451" ;
    dcterms:title "User Interface (UI) Misrepresentation of Critical Information" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE684 ],
        d3f:CWE221 ;
    skos:altLabel "CWE-451" ;
    skos:definition "The user interface (UI) does not properly represent critical information to the user, allowing the information - or its source - to be obscured or spoofed. This is often a component in phishing attacks." ;
    skos:exactMatch d3f:CWE-451,
        cwe:CWE-451 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE497 a owl:Class ;
    rdfs:label "CWE_497" ;
    d3f:cwe-id "CWE-497" ;
    dcterms:title "Exposure of Sensitive System Information to an Unauthorized Control Sphere" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-497" ;
    skos:definition "The product does not properly prevent sensitive system-level information from being accessed by unauthorized actors who do not have the same level of access to the underlying system as the product does." ;
    skos:exactMatch d3f:CWE-497,
        cwe:CWE-497 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE507 a owl:Class ;
    rdfs:label "CWE_507" ;
    d3f:cwe-id "CWE-507" ;
    dcterms:title "Trojan Horse" ;
    rdfs:subClassOf d3f:CWE506 ;
    skos:altLabel "CWE-507" ;
    skos:definition "The product appears to contain benign or useful functionality, but it also contains code that is hidden from normal operation that violates the intended security policy of the user or the system administrator." ;
    skos:exactMatch d3f:CWE-507,
        cwe:CWE-507 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE514 a owl:Class ;
    rdfs:label "CWE_514" ;
    d3f:cwe-id "CWE-514" ;
    dcterms:title "Covert Channel" ;
    rdfs:subClassOf d3f:CWE1229 ;
    skos:altLabel "CWE-514" ;
    skos:definition "A covert channel is a path that can be used to transfer information in a way not intended by the system's designers." ;
    skos:exactMatch d3f:CWE-514,
        cwe:CWE-514 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE602 a owl:Class ;
    rdfs:label "CWE_602" ;
    d3f:cwe-id "CWE-602" ;
    dcterms:title "Client-Side Enforcement of Server-Side Security" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-602" ;
    skos:definition "The product is composed of a server that relies on the client to implement a mechanism that is intended to protect the server." ;
    skos:exactMatch d3f:CWE-602,
        cwe:CWE-602 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE653 a owl:Class ;
    rdfs:label "CWE_653" ;
    d3f:cwe-id "CWE-653" ;
    d3f:synonym "Separation of Privilege" ;
    dcterms:title "Improper Isolation or Compartmentalization" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE657 ;
    skos:altLabel "CWE-653" ;
    skos:definition "The product does not properly compartmentalize or isolate functionality, processes, or resources that require different privilege levels, rights, or permissions." ;
    skos:exactMatch d3f:CWE-653,
        cwe:CWE-653 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE654 a owl:Class ;
    rdfs:label "CWE_654" ;
    d3f:cwe-id "CWE-654" ;
    d3f:synonym "Separation of Privilege" ;
    dcterms:title "Reliance on a Single Factor in a Security Decision" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE657 ;
    skos:altLabel "CWE-654" ;
    skos:definition "A protection mechanism relies exclusively, or to a large extent, on the evaluation of a single condition or the integrity of a single object or entity in order to make a decision about granting access to restricted resources or functionality." ;
    skos:exactMatch d3f:CWE-654,
        cwe:CWE-654 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE663 a owl:Class ;
    rdfs:label "CWE_663" ;
    d3f:cwe-id "CWE-663" ;
    dcterms:title "Use of a Non-reentrant Function in a Concurrent Context" ;
    rdfs:subClassOf d3f:CWE662 ;
    skos:altLabel "CWE-663" ;
    skos:definition "The product calls a non-reentrant function in a concurrent context in which a competing code sequence (e.g. thread or signal handler) may have an opportunity to call the same function or otherwise influence its state." ;
    skos:exactMatch d3f:CWE-663,
        cwe:CWE-663 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE671 a owl:Class ;
    rdfs:label "CWE_671" ;
    d3f:cwe-id "CWE-671" ;
    dcterms:title "Lack of Administrator Control over Security" ;
    rdfs:subClassOf d3f:CWE657 ;
    skos:altLabel "CWE-671" ;
    skos:definition "The product uses security features in a way that prevents the product's administrator from tailoring security settings to reflect the environment in which the product is being used. This introduces resultant weaknesses or prevents it from operating at a level of security that is desired by the administrator." ;
    skos:exactMatch d3f:CWE-671,
        cwe:CWE-671 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE694 a owl:Class ;
    rdfs:label "CWE_694" ;
    d3f:cwe-id "CWE-694" ;
    dcterms:title "Use of Multiple Resources with Duplicate Identifier" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE99 ],
        d3f:CWE573 ;
    skos:altLabel "CWE-694" ;
    skos:definition "The product uses multiple resources that can have the same identifier, in a context in which unique identifiers are required." ;
    skos:exactMatch d3f:CWE-694,
        cwe:CWE-694 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE749 a owl:Class ;
    rdfs:label "CWE_749" ;
    d3f:cwe-id "CWE-749" ;
    dcterms:title "Exposed Dangerous Method or Function" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-749" ;
    skos:definition "The product provides an Applications Programming Interface (API) or similar interface for interaction with external actors, but the interface includes a dangerous method or function that is not properly restricted." ;
    skos:exactMatch d3f:CWE-749,
        cwe:CWE-749 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE756 a owl:Class ;
    rdfs:label "CWE_756" ;
    d3f:cwe-id "CWE-756" ;
    dcterms:title "Missing Custom Error Page" ;
    rdfs:subClassOf d3f:CWE755 ;
    skos:altLabel "CWE-756" ;
    skos:definition "The product does not return custom error pages to the user, possibly exposing sensitive information." ;
    skos:exactMatch d3f:CWE-756,
        cwe:CWE-756 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE763 a owl:Class ;
    rdfs:label "CWE_763" ;
    d3f:cwe-id "CWE-763" ;
    dcterms:title "Release of Invalid Pointer or Reference" ;
    rdfs:subClassOf d3f:CWE404 ;
    skos:altLabel "CWE-763" ;
    skos:definition "The product attempts to return a memory resource to the system, but it calls the wrong release function or calls the appropriate release function incorrectly." ;
    skos:exactMatch d3f:CWE-763,
        cwe:CWE-763 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE786 a owl:Class ;
    rdfs:label "CWE_786" ;
    d3f:cwe-id "CWE-786" ;
    dcterms:title "Access of Memory Location Before Start of Buffer" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-786" ;
    skos:definition "The product reads or writes to a buffer using an index or pointer that references a memory location prior to the beginning of the buffer." ;
    skos:exactMatch d3f:CWE-786,
        cwe:CWE-786 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE791 a owl:Class ;
    rdfs:label "CWE_791" ;
    d3f:cwe-id "CWE-791" ;
    dcterms:title "Incomplete Filtering of Special Elements" ;
    rdfs:subClassOf d3f:CWE790 ;
    skos:altLabel "CWE-791" ;
    skos:definition "The product receives data from an upstream component, but does not completely filter special elements before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-791,
        cwe:CWE-791 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE792 a owl:Class ;
    rdfs:label "CWE_792" ;
    d3f:cwe-id "CWE-792" ;
    dcterms:title "Incomplete Filtering of One or More Instances of Special Elements" ;
    rdfs:subClassOf d3f:CWE791 ;
    skos:altLabel "CWE-792" ;
    skos:definition "The product receives data from an upstream component, but does not completely filter one or more instances of special elements before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-792,
        cwe:CWE-792 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE795 a owl:Class ;
    rdfs:label "CWE_795" ;
    d3f:cwe-id "CWE-795" ;
    dcterms:title "Only Filtering Special Elements at a Specified Location" ;
    rdfs:subClassOf d3f:CWE791 ;
    skos:altLabel "CWE-795" ;
    skos:definition "The product receives data from an upstream component, but only accounts for special elements at a specified location, thereby missing remaining special elements that may exist before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-795,
        cwe:CWE-795 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE798 a owl:Class ;
    rdfs:label "CWE_798" ;
    d3f:cwe-id "CWE-798" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Use of Hard-coded Credentials" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE344 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE671 ],
        d3f:CWE1391 ;
    skos:altLabel "CWE-798" ;
    skos:definition "The product contains hard-coded credentials, such as a password or cryptographic key." ;
    skos:exactMatch d3f:CWE-798,
        cwe:CWE-798 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE799 a owl:Class ;
    rdfs:label "CWE_799" ;
    d3f:cwe-id "CWE-799" ;
    d3f:synonym "Brute force" ;
    dcterms:title "Improper Control of Interaction Frequency" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-799" ;
    skos:definition "The product does not properly limit the number or frequency of interactions that it has with an actor, such as the number of incoming requests." ;
    skos:exactMatch d3f:CWE-799,
        cwe:CWE-799 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE825 a owl:Class ;
    rdfs:label "CWE_825" ;
    d3f:cwe-id "CWE-825" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Dangling pointer" ;
    dcterms:title "Expired Pointer Dereference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE672 ],
        d3f:CWE119 ;
    skos:altLabel "CWE-825" ;
    skos:definition "The product dereferences a pointer that contains a location for memory that was previously valid, but is no longer valid." ;
    skos:exactMatch d3f:CWE-825,
        cwe:CWE-825 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE909 a owl:Class ;
    rdfs:label "CWE_909" ;
    d3f:cwe-id "CWE-909" ;
    dcterms:title "Missing Initialization of Resource" ;
    rdfs:subClassOf d3f:CWE665 ;
    skos:altLabel "CWE-909" ;
    skos:definition "The product does not initialize a critical resource." ;
    skos:exactMatch d3f:CWE-909,
        cwe:CWE-909 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE91 a owl:Class ;
    rdfs:label "CWE_91" ;
    d3f:cwe-id "CWE-91" ;
    dcterms:title "XML Injection (aka Blind XPath Injection)" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-91" ;
    skos:definition "The product does not properly neutralize special elements that are used in XML, allowing attackers to modify the syntax, content, or commands of the XML before it is processed by an end system." ;
    skos:exactMatch d3f:CWE-91,
        cwe:CWE-91 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE912 a owl:Class ;
    rdfs:label "CWE_912" ;
    d3f:cwe-id "CWE-912" ;
    dcterms:title "Hidden Functionality" ;
    rdfs:subClassOf d3f:CWE684 ;
    skos:altLabel "CWE-912" ;
    skos:definition "The product contains functionality that is not documented, not part of the specification, and not accessible through an interface or command sequence that is obvious to the product's users or administrators." ;
    skos:exactMatch d3f:CWE-912,
        cwe:CWE-912 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE914 a owl:Class ;
    rdfs:label "CWE_914" ;
    d3f:cwe-id "CWE-914" ;
    dcterms:title "Improper Control of Dynamically-Identified Variables" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE99 ],
        d3f:CWE913 ;
    skos:altLabel "CWE-914" ;
    skos:definition "The product does not properly restrict reading from or writing to dynamically-identified variables." ;
    skos:exactMatch d3f:CWE-914,
        cwe:CWE-914 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE916 a owl:Class ;
    rdfs:label "CWE_916" ;
    d3f:cwe-id "CWE-916" ;
    dcterms:title "Use of Password Hash With Insufficient Computational Effort" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE328 ],
        d3f:CWE327 ;
    skos:altLabel "CWE-916" ;
    skos:definition "The product generates a hash for a password, but it uses a scheme that does not provide a sufficient level of computational effort that would make password cracking attacks infeasible or expensive." ;
    skos:exactMatch d3f:CWE-916,
        cwe:CWE-916 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE922 a owl:Class ;
    rdfs:label "CWE_922" ;
    d3f:cwe-id "CWE-922" ;
    dcterms:title "Insecure Storage of Sensitive Information" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-922" ;
    skos:definition "The product stores sensitive information without properly limiting read or write access by unauthorized actors." ;
    skos:exactMatch d3f:CWE-922,
        cwe:CWE-922 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CertificateFile a owl:Class ;
    rdfs:label "CertificateFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Certificate File" ;
    rdfs:seeAlso dbr:Public_key_certificate ;
    rdfs:subClassOf d3f:File ;
    skos:closeMatch stix:X509Certificate,
        unified_cyber_ontology:X509Certificate ;
    skos:definition "A file containing a digital certificate. In cryptography, a public key certificate (also known as a digital certificate or identity certificate) is an electronic document used to prove the ownership of a public key. The certificate includes information about the key, information about its owner's identity, and the digital signature of an entity that has verified the certificate's contents are correct. If the signature is valid, and the person examining the certificate trusts the signer, then they know they can use that key to communicate with its owner." ;
    skos:exactMatch d3f:CertificateFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudConfiguration a owl:Class ;
    rdfs:label "CloudConfiguration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Configuration" ;
    rdfs:subClassOf d3f:ConfigurationResource ;
    skos:altLabel "Cloud Configuration Information" ;
    skos:definition "Information used to configure the services, parameters, and initial settings for a virtual server instance running in a cloud service." ;
    skos:exactMatch d3f:CloudConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CombinationLock a owl:Class ;
    rdfs:label "CombinationLock" ;
    dcterms:title "Combination Lock" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Combination_lock> ;
    rdfs:subClassOf d3f:PhysicalLock ;
    skos:definition "A combination lock is a type of locking device in which a sequence of symbols, usually numbers, is used to open the lock." ;
    skos:exactMatch d3f:CombinationLock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CommandLineInterface a owl:Class ;
    rdfs:label "CommandLineInterface" ;
    dcterms:title "Command Line Interface" ;
    rdfs:seeAlso dbr:Command-line_interface ;
    rdfs:subClassOf d3f:UserInterface ;
    skos:altLabel "CLI",
        "CUI",
        "Command-line Interface" ;
    skos:definition "A command-line interface or command language interpreter (CLI), also known as command-line user interface, console user interface, and character user interface (CUI), is a means of interacting with a computer program where the user (or client) issues commands to the program in the form of successive lines of text (command lines). Command-line interfaces to computer operating systems are less widely used by casual computer users, who favor graphical user interfaces. Programs with command-line interfaces are generally easier to automate via scripting." ;
    skos:exactMatch d3f:CommandLineInterface ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CommonAttackPattern a owl:Class ;
    rdfs:label "CommonAttackPattern" ;
    dcterms:title "Common Attack Pattern" ;
    rdfs:subClassOf d3f:CAPECThing ;
    skos:definition "A common attack pattern that is in the CAPEC knowledge base." ;
    skos:exactMatch d3f:CommonAttackPattern ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputingSnapshot a owl:Class ;
    rdfs:label "ComputingSnapshot" ;
    dcterms:title "Computing Snapshot" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Snapshot_(computer_storage)> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Snapshot" ;
    skos:definition "In computer systems, a snapshot is the state of a system at a particular point in time." ;
    skos:exactMatch d3f:ComputingSnapshot ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

<http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#High> a owl:Class ;
    rdfs:label "High" ;
    rdfs:subClassOf d3f:ConfidenceEnum,
        linkml:PermissibleValue ;
    skos:definition "High" .

<http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#Low> a owl:Class ;
    rdfs:label "Low" ;
    rdfs:subClassOf d3f:ConfidenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Low" .

<http://d3fend.mitre.org/ontologies/d3fend.owl#ConfidenceEnum#Medium> a owl:Class ;
    rdfs:label "Medium" ;
    rdfs:subClassOf d3f:ConfidenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Medium" .

d3f:ConfigurationEvent a owl:Class ;
    rdfs:label "ConfigurationEvent" ;
    dcterms:title "Configuration Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "A discrete event that creates, applies, modifies, or deletes configuration resources to determine or alter the function of a system, device, application, or service." ;
    skos:exactMatch d3f:ConfigurationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ContainerImage a owl:Class ;
    rdfs:label "ContainerImage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Container Image" ;
    rdfs:seeAlso <https://schema.ocsf.io/objects/image>,
        <https://www.docker.com/resources/what-container> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SoftwarePackage ],
        d3f:ComputingImage ;
    skos:definition """A container is a standard unit of software that packages up code and all its dependencies so the application runs quickly and reliably from one computing environment to another. A Docker container image is a lightweight, standalone, executable package of software that includes everything needed to run an application: code, runtime, system tools, system libraries and settings.

Container images become containers at runtime and in the case of Docker containers - images become containers when they run on Docker Engine. Available for both Linux and Windows-based applications, containerized software will always run the same, regardless of the infrastructure. Containers isolate software from its environment and ensure that it works uniformly despite differences for instance between development and staging.""" ;
    skos:exactMatch d3f:ContainerImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ContainerProcess a owl:Class ;
    rdfs:label "ContainerProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Container Process" ;
    rdfs:seeAlso d3f:ContainerImage,
        <https://schema.ocsf.io/objects/container> ;
    rdfs:subClassOf d3f:ApplicationProcess ;
    skos:definition "A running instance of a container image." ;
    skos:exactMatch d3f:ContainerProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ContentValidation a owl:Class ;
    rdfs:label "ContentValidation" ;
    d3f:d3fend-id "D3-CV" ;
    d3f:kb-article "## How it works To ensure that content is safe, it's composition must be validated according to its content policy." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Content Validation" ;
    rdfs:subClassOf d3f:ContentFiltering ;
    skos:definition "Verify and validate contents complies with policy" ;
    skos:exactMatch d3f:ContentValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ControlFlowGraph a owl:Class ;
    rdfs:label "ControlFlowGraph" ;
    dcterms:title "Control Flow Graph" ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "A control flow graph is a representation of all possible control flow transfers within a program, typically computed at compile-time or link-time, including calls, jumps, and returns. The control flow graph can be used to compute a control flow policy that permits only the expected control flow transfers during process execution via control flow integrity mechanisms." ;
    skos:exactMatch d3f:ControlFlowGraph ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CorrelationClustering a owl:Class ;
    rdfs:label "CorrelationClustering" ;
    d3f:d3fend-id "D3A-CC" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Correlation clustering. [Link](https://en.wikipedia.org/wiki/Correlation_clustering)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Correlation Clustering" ;
    rdfs:subClassOf d3f:HighDimensionClustering ;
    skos:definition "Correlation clustering provides a method for clustering a set of objects into the optimum number of clusters without specifying that number in advance." ;
    skos:exactMatch d3f:CorrelationClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:D3FENDKBThing a owl:Class ;
    rdfs:label "D3FENDKBThing" ;
    dcterms:title "D3FEND KB Thing" ;
    rdfs:subClassOf linkml:ClassDefinition ;
    skos:broadMatch stix:StixEntity ;
    skos:exactMatch d3f:D3FENDKBThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch spdx:Element,
        unified_cyber_ontology:UcoObject .

d3f:DNSNetworkTraffic a owl:Class ;
    rdfs:label "DNSNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DNS Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "DNS network traffic is network traffic related to queries and responses involving the Domain Name System. DNS traffic can involve clients, servers such as relays or resolvers. This includes only network traffic conforming to standard DNS protocol; not custom protocols." ;
    skos:exactMatch d3f:DNSNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DS0001 a owl:Class ;
    rdfs:label "DS0001" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Firmware (ATT&CK DS)" ;
    skos:editorialNote "Computer software that provides low-level control for the hardware and device(s) of a host, such as BIOS or UEFI/EFI" .

d3f:DS0002 a owl:Class ;
    rdfs:label "DS0002" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "User Account (ATT&CK DS)" ;
    skos:editorialNote "A profile representing a user, device, service, or application used to authenticate and access resources" .

d3f:DS0003 a owl:Class ;
    rdfs:label "DS0003" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Scheduled Job (ATT&CK DS)" ;
    skos:editorialNote "Automated tasks that can be executed at a specific time or on a recurring schedule running in the background (ex: Cron daemon, task scheduler, BITS)" .

d3f:DS0004 a owl:Class ;
    rdfs:label "DS0004" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Malware Repository (ATT&CK DS)" ;
    skos:editorialNote "Information obtained (via shared or submitted samples) regarding malicious software (droppers, backdoors, etc.) used by adversaries" .

d3f:DS0005 a owl:Class ;
    rdfs:label "DS0005" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "WMI (ATT&CK DS)" ;
    skos:editorialNote "The infrastructure for management data and operations that enables local and remote management of Windows personal computers and servers" .

d3f:DS0006 a owl:Class ;
    rdfs:label "DS0006" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Web Credential (ATT&CK DS)" ;
    skos:editorialNote "Credential material, such as session cookies or tokens, used to authenticate to web applications and services" .

d3f:DS0007 a owl:Class ;
    rdfs:label "DS0007" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Image (ATT&CK DS)" ;
    skos:editorialNote "A single file used to deploy a virtual machine/bootable disk into an on-premise or third-party cloud environment" .

d3f:DS0008 a owl:Class ;
    rdfs:label "DS0008" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Kernel (ATT&CK DS)" ;
    skos:editorialNote "A computer program, at the core of a computer OS, that resides in memory and facilitates interactions between hardware and software components" .

d3f:DS0009 a owl:Class ;
    rdfs:label "DS0009" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Process (ATT&CK DS)" ;
    skos:editorialNote "Instances of computer programs that are being executed by at least one thread. Processes have memory space for process executables, loaded modules (DLLs or shared libraries), and allocated memory regions containing everything from user input to application-specific data structures" .

d3f:DS0010 a owl:Class ;
    rdfs:label "DS0010" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Cloud Storage (ATT&CK DS)" ;
    skos:editorialNote "Data object storage infrastructure hosted on-premise or by third-party providers, made available to users through network connections and/or APIs" .

d3f:DS0011 a owl:Class ;
    rdfs:label "DS0011" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Module (ATT&CK DS)" ;
    skos:editorialNote "Executable files consisting of one or more shared classes and interfaces, such as portable executable (PE) format binaries/dynamic link libraries (DLL), executable and linkable format (ELF) binaries/shared libraries, and Mach-O format binaries/shared libraries" .

d3f:DS0012 a owl:Class ;
    rdfs:label "DS0012" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Script (ATT&CK DS)" ;
    skos:editorialNote "A file or stream containing a list of commands, allowing them to be launched in sequence" .

d3f:DS0013 a owl:Class ;
    rdfs:label "DS0013" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Sensor Health (ATT&CK DS)" ;
    skos:editorialNote "Information from host telemetry providing insights about system status, errors, or other notable functional activity" .

d3f:DS0014 a owl:Class ;
    rdfs:label "DS0014" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Pod (ATT&CK DS)" ;
    skos:editorialNote "A single unit of shared resources within a cluster, comprised of one or more containers" .

d3f:DS0015 a owl:Class ;
    rdfs:label "DS0015" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Application Log (ATT&CK DS)" ;
    skos:editorialNote "Events collected by third-party services such as mail servers, web applications, or other appliances (not by the native OS or platform)" .

d3f:DS0016 a owl:Class ;
    rdfs:label "DS0016" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Drive (ATT&CK DS)" ;
    skos:editorialNote "A non-volatile data storage device (hard drive, floppy disk, USB flash drive) with at least one formatted partition, typically mounted to the file system and/or assigned a drive letter" .

d3f:DS0017 a owl:Class ;
    rdfs:label "DS0017" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Command (ATT&CK DS)" ;
    skos:editorialNote "A directive given to a computer program, acting as an interpreter of some kind, in order to perform a specific task" .

d3f:DS0018 a owl:Class ;
    rdfs:label "DS0018" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Firewall (ATT&CK DS)" ;
    skos:editorialNote "A network security system, running locally on an endpoint or remotely as a service (ex: cloud environment), that monitors and controls incoming/outgoing network traffic based on predefined rules" .

d3f:DS0019 a owl:Class ;
    rdfs:label "DS0019" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Service (ATT&CK DS)" ;
    skos:editorialNote "A computer process that is configured to execute continuously in the background and perform system tasks, in some cases before any user has logged in" .

d3f:DS0020 a owl:Class ;
    rdfs:label "DS0020" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Snapshot (ATT&CK DS)" ;
    skos:editorialNote "A point-in-time copy of cloud volumes (files, settings, etc.) that can be created and/or deployed in cloud environments" .

d3f:DS0021 a owl:Class ;
    rdfs:label "DS0021" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Persona (ATT&CK DS)" ;
    skos:editorialNote "A malicious online profile representing a user commonly used by adversaries to social engineer or otherwise target victims" .

d3f:DS0022 a owl:Class ;
    rdfs:label "DS0022" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "File (ATT&CK DS)" ;
    skos:editorialNote "A computer resource object, managed by the I/O system, for storing data (such as images, text, videos, computer programs, or any wide variety of other media)" .

d3f:DS0023 a owl:Class ;
    rdfs:label "DS0023" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Named Pipe (ATT&CK DS)" ;
    skos:editorialNote "Mechanisms that allow inter-process communication locally or over the network. A named pipe is usually found as a file and processes attach to it" .

d3f:DS0024 a owl:Class ;
    rdfs:label "DS0024" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Windows Registry (ATT&CK DS)" ;
    skos:editorialNote "A Windows OS hierarchical database that stores much of the information and settings for software programs, hardware devices, user preferences, and operating-system configurations" .

d3f:DS0025 a owl:Class ;
    rdfs:label "DS0025" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Cloud Service (ATT&CK DS)" ;
    skos:editorialNote "Infrastructure, platforms, or software that are hosted on-premise or by third-party providers, made available to users through network connections and/or APIs" .

d3f:DS0026 a owl:Class ;
    rdfs:label "DS0026" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Active Directory (ATT&CK DS)" ;
    skos:editorialNote "A database and set of services that allows administrators to manage permissions, access to network resources, and stored data objects (user, group, application, or devices)" .

d3f:DS0027 a owl:Class ;
    rdfs:label "DS0027" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Driver (ATT&CK DS)" ;
    skos:editorialNote "A computer program that operates or controls a particular type of device that is attached to a computer. Provides a software interface to hardware devices, enabling operating systems and other computer programs to access hardware functions without needing to know precise details about the hardware being used" .

d3f:DS0028 a owl:Class ;
    rdfs:label "DS0028" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Logon Session (ATT&CK DS)" ;
    skos:editorialNote "Logon occurring on a system or resource (local, domain, or cloud) to which a user/device is gaining access after successful authentication and authorization" .

d3f:DS0029 a owl:Class ;
    rdfs:label "DS0029" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Network Traffic (ATT&CK DS)" ;
    skos:editorialNote "Data transmitted across a network (ex: Web, DNS, Mail, File, etc.), that is either summarized (ex: Netflow) and/or captured as raw data in an analyzable format (ex: PCAP)" .

d3f:DS0030 a owl:Class ;
    rdfs:label "DS0030" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Instance (ATT&CK DS)" ;
    skos:editorialNote "A virtual server environment which runs workloads, hosted on-premise or by third-party cloud providers" .

d3f:DS0032 a owl:Class ;
    rdfs:label "DS0032" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Container (ATT&CK DS)" ;
    skos:editorialNote "A standard unit of virtualized software that packages up code and all its dependencies so the application runs quickly and reliably from one computing environment to another" .

d3f:DS0033 a owl:Class ;
    rdfs:label "DS0033" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Network Share (ATT&CK DS)" ;
    skos:editorialNote "A storage resource (typically a folder or drive) made available from one host to others using network protocols, such as Server Message Block (SMB) or Network File System (NFS)" .

d3f:DS0034 a owl:Class ;
    rdfs:label "DS0034" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Volume (ATT&CK DS)" ;
    skos:editorialNote "Block object storage hosted on-premise or by third-party providers, typically made available to resources as virtualized hard drives" .

d3f:DS0035 a owl:Class ;
    rdfs:label "DS0035" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Internet Scan (ATT&CK DS)" ;
    skos:editorialNote "Information obtained (commonly via active network traffic probes or web crawling) regarding various types of resources and servers connected to the public Internet" .

d3f:DS0036 a owl:Class ;
    rdfs:label "DS0036" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Group (ATT&CK DS)" ;
    skos:editorialNote "A collection of multiple user accounts that share the same access rights to the computer and/or network resources and have common security rights" .

d3f:DS0037 a owl:Class ;
    rdfs:label "DS0037" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Certificate (ATT&CK DS)" ;
    skos:editorialNote "A digital document, which highlights information such as the owner's identity, used to instill trust in public keys used while encrypting network communications" .

d3f:DS0038 a owl:Class ;
    rdfs:label "DS0038" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Domain Name (ATT&CK DS)" ;
    skos:editorialNote "Information obtained (commonly through registration or activity logs) regarding one or more IP addresses registered with human readable names (ex: mitre.org)" .

d3f:DS0039 a owl:Class ;
    rdfs:label "DS0039" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Asset (ATT&CK DS)" ;
    skos:editorialNote "Data sources with information about the set of devices found within the network, along with their current software and configurations" .

d3f:DS0040 a owl:Class ;
    rdfs:label "DS0040" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Operational Database (ATT&CK DS)" ;
    skos:editorialNote "Operational databases contain information about the status of the operational process and associated devices, including any measurements, events, history, or alarms that have occurred" .

d3f:DS0041 a owl:Class ;
    rdfs:label "DS0041" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "Application Vetting (ATT&CK DS)" ;
    skos:editorialNote "Application vetting report generated by an external cloud service." .

d3f:DS0042 a owl:Class ;
    rdfs:label "DS0042" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseDataSourceEnum,
        linkml:PermissibleValue ;
    skos:definition "User Interface (ATT&CK DS)" ;
    skos:editorialNote "Visual activity on the device that could alert the user to potentially malicious behavior." .

d3f:DatabaseQuery a owl:Class ;
    rdfs:label "DatabaseQuery" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database Query" ;
    rdfs:subClassOf d3f:Command ;
    skos:definition "A specific query expressed in SQL, SPARQL, or similar language against a database." ;
    skos:exactMatch d3f:DatabaseQuery ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DatabaseRecord a owl:Class ;
    rdfs:label "DatabaseRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database Record" ;
    rdfs:subClassOf d3f:Record ;
    skos:definition "A single, implicitly structured data item in a table in a database." ;
    skos:exactMatch d3f:DatabaseRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DatabaseServiceApplication a owl:Class ;
    rdfs:label "DatabaseServiceApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Database Service Application" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceApplication ],
        d3f:DatabaseApplication ;
    skos:definition "A software application that interacts with a database management system (DBMS) hosted as a separate, standalone service or server." ;
    skos:exactMatch d3f:DatabaseServiceApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DescriptionLogic a owl:Class ;
    rdfs:label "DescriptionLogic" ;
    d3f:d3fend-id "D3A-DL" ;
    d3f:kb-article "## How it works The core reasoning problems for description logics (DLs) are (usually) decidable, and efficient decision procedures have been designed and implemented for these problems. There are general, spatial, temporal, spatiotemporal, and fuzzy description logics, and each description logic fe" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Description Logic" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "A description logic (DL) is a form of logic usually more expressive than propositional logic but less expressive than first-order logic." ;
    skos:exactMatch d3f:DescriptionLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalFingerprint a owl:Class ;
    rdfs:label "DigitalFingerprint" ;
    dcterms:title "Digital Fingerprint" ;
    rdfs:seeAlso <https://csrc.nist.gov/glossary/term/digital_fingerprint>,
        <https://schema.ocsf.io/objects/fingerprint> ;
    rdfs:subClassOf d3f:Identifier ;
    skos:definition "A digital signature uniquely identifies data and has the property that changing a single bit in the data will cause a completely different message digest to be generated." ;
    skos:exactMatch d3f:DigitalFingerprint ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalMultimedia a owl:Class ;
    rdfs:label "DigitalMultimedia" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital Multimedia" ;
    rdfs:subClassOf d3f:DigitalMedia ;
    skos:definition "Digital Multimedia refers to content that combines text, audio, images, animations, and video in a digital format for interactive applications." ;
    skos:exactMatch d3f:DigitalMultimedia ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalSignalProcessingApplication a owl:Class ;
    rdfs:label "DigitalSignalProcessingApplication" ;
    d3f:synonym "DSP Application" ;
    dcterms:title "Digital Signal Processing Application" ;
    rdfs:seeAlso dbr:Digital_signal_processing ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "A Digital Signal Processing (DSP) application is a software system that ingests discrete-time or discrete-space signals (from sensors, ADCs, or files) and applies digital signal processing algorithms to analyze, transform, synthesize, or make decisions about those signals, often under real-time throughput and latency constraints. It encompasses capabilities such as filtering, spectral analysis, modulation/demodulation, channelization, synchronization, detection and estimation, compression, beamforming, and reconstruction, and spans domains including software-defined radio (e.g., waveform generation and physical-layer stacks), audio and speech, image and video, radar/sonar/LiDAR, biomedical signals, instrumentation, and control." ;
    skos:exactMatch d3f:DigitalSignalProcessingApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalSystem a owl:Class ;
    rdfs:label "DigitalSystem" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital System" ;
    rdfs:seeAlso dbr:System ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:System ],
        d3f:DigitalInformationBearer ;
    skos:definition "A digital system is a group of interacting or interrelated digital artifacts that act according to a set of rules to form a unified whole. A digital system, surrounded and influenced by its environment, is described by its boundaries, structure and purpose and expressed in its functioning. Systems are the subjects of study of systems theory." ;
    skos:exactMatch d3f:DigitalSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DiskImage a owl:Class ;
    rdfs:label "DiskImage" ;
    dcterms:title "Disk Image" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Disk_image>,
        <https://en.wikipedia.org/wiki/Disk_image> ;
    rdfs:subClassOf d3f:StorageImage ;
    skos:closeMatch unified_cyber_ontology:Image ;
    skos:definition "A disk image is a snapshot of a storage device's structure and data typically stored in one or more computer files on another storage device." ;
    skos:exactMatch d3f:DiskImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainLogicValidation a owl:Class ;
    rdfs:label "DomainLogicValidation" ;
    d3f:d3fend-id "D3-DLV" ;
    d3f:kb-article "## How it works Validates the type, value, and/or range of an variable taking into context the current application in the business domain." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Logic Validation" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:broadMatch d3f:T1505 ;
    skos:definition "Validation of variable state in the context of the domain application." ;
    skos:exactMatch d3f:DomainLogicValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1505.001 .

d3f:DomainUserAccount a owl:Class ;
    rdfs:label "DomainUserAccount" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain User Account" ;
    rdfs:seeAlso <https://networkencyclopedia.com/global-user-account> ;
    rdfs:subClassOf d3f:UserAccount ;
    skos:definition "A domain user account in Microsoft Windows (2000) defines that user's access to a logical group of network objects (computers, users, devices) that share the same Active Directory databases; that is, a user's access to a domain." ;
    skos:exactMatch d3f:DomainUserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0001 a owl:Class ;
    rdfs:label "EX_0001" ;
    d3f:attack-id "EX-0001" ;
    dcterms:title "Replay" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0001/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0001" ;
    skos:definition "Replay attacks involve threat actors recording previously recorded data streams and then resending them at a later time. This attack can be used to fingerprint systems, gain elevated privileges, or even cause a denial of service." ;
    skos:exactMatch d3f:EX-0001,
        mitre-attack:EX-0001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0005 a owl:Class ;
    rdfs:label "EX_0005" ;
    d3f:attack-id "EX-0005" ;
    dcterms:title "Exploit Hardware/Firmware Corruption" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0005/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0005" ;
    skos:definition "Threat actors can target the underlying hardware and/or firmware using various TTPs that will be dependent on the specific hardware/firmware. Typically, software tools (e.g., antivirus, antimalware, intrusion detection) can protect a system from threat actors attempting to take advantage of those vulnerabilities to inject  malicious code. However, there exist security gaps that cannot be closed by the above-mentioned software tools since they are not stationed on software applications, drivers or the operating system but rather on the hardware itself. Hardware components, like memory modules and caches, can be exploited under specific circumstances thus enabling backdoor access to potential threat actors. In addition to hardware, the firmware itself which often is thought to be software in its own right also provides an attack surface for threat actors. Firmware is programming that's written to a hardware device's non-volatile memory where the content is saved when a hardware device is turned off or loses its external power source. Firmware is written directly onto a piece of hardware during manufacturing and it is used to run on the device and can be thought of as the software that enables hardware to run. In the spacecraft context, firmware and field programmable gate array (FPGA)/application-specific integrated circuit (ASIC) logic/code is considered equivalent to firmware." ;
    skos:exactMatch d3f:EX-0005,
        mitre-attack:EX-0005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0008 a owl:Class ;
    rdfs:label "EX_0008" ;
    d3f:attack-id "EX-0008" ;
    dcterms:title "Time Synchronized Execution" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0008/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0008" ;
    skos:definition "Threat actors may develop payloads or insert malicious logic to be executed at a specific time." ;
    skos:exactMatch d3f:EX-0008,
        mitre-attack:EX-0008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0013 a owl:Class ;
    rdfs:label "EX_0013" ;
    d3f:attack-id "EX-0013" ;
    dcterms:title "Flooding" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0013/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0013" ;
    skos:definition "Threat actors use flooding attacks to disrupt communications by injecting unexpected noise or messages into a transmission channel. There are several types of attacks that are consistent with this method of exploitation, and they can produce various outcomes. Although, the most prominent of the impacts are denial of service or data corruption. Several elements of the spacecraft may be targeted by jamming and flooding attacks, and depending on the time of the attack, it can have devastating results to the availability of the system." ;
    skos:exactMatch d3f:EX-0013,
        mitre-attack:EX-0013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0017 a owl:Class ;
    rdfs:label "EX_0017" ;
    d3f:attack-id "EX-0017" ;
    dcterms:title "Kinetic Physical Attack" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0017/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0017" ;
    skos:definition """Kinetic physical attacks attempt to damage or destroy space- or land-based space assets. They typically are organized into three categories: direct-ascent, co-orbital, and ground station attacks [beyond the focus of SPARTA at this time]. The nature of these attacks makes them easier to attribute and allow for better confirmation of success on the part of the attacker.*

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:EX-0017,
        mitre-attack:EX-0017 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EXF0003 a owl:Class ;
    rdfs:label "EXF_0003" ;
    d3f:attack-id "EXF-0003" ;
    dcterms:title "Signal Interception" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EXF-0003/> ;
    rdfs:subClassOf d3f:SPARTAExfiltrationTechnique ;
    skos:altLabel "EXF-0003" ;
    skos:definition "Threat actors may seek to capture network communications throughout the ground station and communication channel (i.e. radio frequency, optical) used for uplink and downlink communications" ;
    skos:exactMatch d3f:EXF-0003,
        mitre-attack:EXF-0003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EXF0006 a owl:Class ;
    rdfs:label "EXF_0006" ;
    d3f:attack-id "EXF-0006" ;
    dcterms:title "Modify Communications Configuration" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EXF-0006/> ;
    rdfs:subClassOf d3f:SPARTAExfiltrationTechnique ;
    skos:altLabel "EXF-0006" ;
    skos:definition "Threat actors can manipulate communications equipment, modifying the existing software, hardware, or the transponder configuration to exfiltrate data via unintentional channels the mission has no control over." ;
    skos:exactMatch d3f:EXF-0006,
        mitre-attack:EXF-0006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ElectromagneticRadiationHardening a owl:Class ;
    rdfs:label "ElectromagneticRadiationHardening" ;
    d3f:d3fend-id "D3-EMH" ;
    d3f:kb-article "## How it works EM hardening operates on the principle of controlling the coupling path between an electromagnetic threat and the sensitive electronics it could affect. At the most fundamental level, this involves creating barriers that reflect, absorb, or redirect unwanted electromagnetic energy be" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "EM Hardening" ;
    dcterms:title "Electromagnetic Radiation Hardening" ;
    rdfs:seeAlso <https://patents.google.com/patent/US20070105445A1> ;
    rdfs:subClassOf d3f:RadiationHardening ;
    skos:altLabel "Electromagnetic Hardening" ;
    skos:definition "The application of physical and material-level design measures to electronic systems, components, or facilities to reduce their susceptibility to damage or disruption from electromagnetic threats." ;
    skos:exactMatch d3f:ElectromagneticRadiationHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ElectromagneticSignal a owl:Class ;
    rdfs:label "ElectromagneticSignal" ;
    dcterms:title "Electromagnetic Signal" ;
    rdfs:seeAlso dbr:Signal ;
    rdfs:subClassOf d3f:Signal ;
    skos:definition "An electromagnetic wave that carries information." ;
    skos:exactMatch d3f:ElectromagneticSignal ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmbeddedComputer a owl:Class ;
    rdfs:label "EmbeddedComputer" ;
    dcterms:title "Embedded Computer" ;
    rdfs:seeAlso dbr:Embedded_system ;
    rdfs:subClassOf d3f:ClientComputer ;
    skos:altLabel "Embedded System" ;
    skos:definition "An embedded computer is a computer system -- a combination of a computer processor, computer memory, and input/output peripheral devices-that has a dedicated function within a larger mechanical or electrical system. It is embedded as part of a complete device often including electrical or electronic hardware and mechanical parts. Because an embedded system typically controls physical operations of the machine that it is embedded within, it often has real-time computing constraints. Embedded systems control many devices in common use today. Ninety-eight percent of all microprocessors manufactured are used in embedded systems." ;
    skos:exactMatch d3f:EmbeddedComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EncryptedCredential a owl:Class ;
    rdfs:label "EncryptedCredential" ;
    d3f:owl_named_individual "true" ;
