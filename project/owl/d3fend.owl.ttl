    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-invoke y: They entity x may invoke the thing y; that is, 'x invokes y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_isolate a owl:DatatypeProperty ;
