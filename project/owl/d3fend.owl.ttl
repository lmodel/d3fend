d3f:ActiveCertificateAnalysis a owl:Class ;
    rdfs:label "ActiveCertificateAnalysis" ;
    d3f:d3fend-id "D3-ACA" ;
    d3f:kb-article "## How it works Analysis of server certificates using active methods to detect if certificates have been misconfigured or spoofed by using elements of the certificate, certificate authorities and signatures. ### Certificate validity analysis This can be accomplished by verifying the digital signatu" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Active Certificate Analysis" ;
    rdfs:subClassOf d3f:CertificateAnalysis ;
    skos:definition "Actively collecting PKI certificates by connecting to the server and downloading its server certificates for analysis." ;
    skos:exactMatch d3f:ActiveCertificateAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ActiveLogicalLinkMapping a owl:Class ;
    rdfs:label "ActiveLogicalLinkMapping" ;
    d3f:d3fend-id "D3-ALLM" ;
    d3f:kb-article "## How it works Active logical link mapping establishes awareness of logical links in the network by sending data over the network to gather information about logical connections in the network. Typically this will be achieved through network telemetry coordinated for network management and monito" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Active Logical Link Mapping" ;
    rdfs:subClassOf d3f:LogicalLinkMapping ;
    skos:definition "Active logical link mapping sends and receives network traffic as a means to map the whole data link layer, where the links represent logical data flows rather than physical connection" ;
    skos:exactMatch d3f:ActiveLogicalLinkMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ActivePhysicalLinkMapping a owl:Class ;
