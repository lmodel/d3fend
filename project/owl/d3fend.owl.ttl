        d3f:LateralMovementTechnique,
        d3f:T1037,
        d3f:T1070,
        d3f:T1074,
        d3f:T1213,
        d3f:T1491 ;
    skos:definition "Control of access to organizational systems and services by users or processes over a network." ;
    skos:exactMatch d3f:NetworkResourceAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1037.003,
