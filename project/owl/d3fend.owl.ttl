    skos:exactMatch d3f:CWE-551,
        cwe:CWE-551 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE553 a owl:Class ;
    rdfs:label "CWE_553" ;
    d3f:cwe-id "CWE-553" ;
    dcterms:title "Command Shell in Externally Accessible Directory" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-553" ;
    skos:definition "A possible shell file exists in /cgi-bin/ or other accessible directories. This is extremely dangerous and can be used by an attacker to execute commands on the web server." ;
    skos:exactMatch d3f:CWE-553,
        cwe:CWE-553 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE554 a owl:Class ;
    rdfs:label "CWE_554" ;
    d3f:cwe-id "CWE-554" ;
