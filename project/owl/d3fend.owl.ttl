    rdfs:seeAlso <https://csrc.nist.gov/glossary/term/controller> ;
    rdfs:subClassOf d3f:OTEmbeddedComputer ;
    skos:definition "An OT Controller is an industrial control device that automatically regulates one or more controlled variables in response to command inputs and real-time feedback signals." ;
    skos:exactMatch d3f:OTController ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTControllerOperatingMode a owl:Class ;
