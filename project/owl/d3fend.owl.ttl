d3f:Enclave a owl:Class ;
    rdfs:label "Enclave" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Network_enclave ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Network Enclave" ;
    skos:definition "Network enclaves consist of standalone assets that do not interact with other information systems or networks. A major difference between a DMZ or demilitarized zone and a network enclave is a DMZ allows inbound and outbound traffic access, where firewall boundaries are traversed. In an enclave, firewall boundaries are not traversed. Enclave protection tools can be used to provide protection within specific security domains. These mechanisms are installed as part of an Intranet to connect networks that have similar security requirements." ;
    skos:exactMatch d3f:Enclave ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EncoderApplication a owl:Class ;
    rdfs:label "EncoderApplication" ;
    dcterms:title "Encoder Application" ;
    rdfs:subClassOf d3f:CodecApplication ;
    skos:definition "An application that encodes digital data." ;
    skos:exactMatch d3f:EncoderApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EncryptedPassword a owl:Class ;
    rdfs:label "EncryptedPassword" ;
    dcterms:title "Encrypted Password" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Password ],
        d3f:EncryptedCredential ;
    skos:definition "A password that is encrypted." ;
    skos:exactMatch d3f:EncryptedPassword ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EncryptedTunnels a owl:Class ;
    rdfs:label "EncryptedTunnels" ;
    d3f:d3fend-id "D3-ET" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Encrypted Tunnels" ;
    rdfs:subClassOf d3f:NetworkIsolation ;
    skos:definition "Encrypted encapsulation of routable network traffic." ;
    skos:exactMatch d3f:EncryptedTunnels ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EndpointHealthBeacon a owl:Class ;
    rdfs:label "EndpointHealthBeacon" ;
    d3f:d3fend-id "D3-EHB" ;
    d3f:kb-article "## How it works Endpoints are configured to periodically generate and transmit a secure heartbeat that is delivered on a configured schedule and provides endpoint status information. Status information can include software details (version, configuration, etc), endpoint identification (MAC, IP addre" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Endpoint Health Telemetry" ;
    dcterms:title "Endpoint Health Beacon" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:T1114,
        d3f:T1505 ;
    skos:definition "Monitoring the security status of an endpoint by sending periodic messages with health status, where absence of a response may indicate that the endpoint has been compromised." ;
    skos:exactMatch d3f:EndpointHealthBeacon ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.002,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003 .

d3f:EpistemicLogic a owl:Class ;
    rdfs:label "EpistemicLogic" ;
    d3f:d3fend-id "D3A-EL" ;
    d3f:kb-article "## References 1. Epistemic logic. (2023, June 4). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Modal_logic#Epistemic_logic)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Epistemic Modal Logic" ;
    dcterms:title "Epistemic Logic" ;
    rdfs:subClassOf d3f:ModalLogic ;
    skos:definition "Epistemic logic addresses modalities of knowledge; i.e., the certainty of sentences." ;
    skos:exactMatch d3f:EpistemicLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EvalFunction a owl:Class ;
    rdfs:label "EvalFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Eval Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Takes inputs of strings and evaluations them as expressions." ;
    skos:exactMatch d3f:EvalFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogArchiveEvent a owl:Class ;
    rdfs:label "EventLogArchiveEvent" ;
    dcterms:title "Event Log Archive Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event involving the archiving of event log data, typically to preserve historical records in a compressed or secure format." ;
    skos:exactMatch d3f:EventLogArchiveEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogClearEvent a owl:Class ;
    rdfs:label "EventLogClearEvent" ;
    dcterms:title "Event Log Clear Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event where the event log data is cleared from the system, often as part of log maintenance or potentially to cover tracks." ;
    skos:exactMatch d3f:EventLogClearEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogDeleteEvent a owl:Class ;
    rdfs:label "EventLogDeleteEvent" ;
    dcterms:title "Event Log Delete Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event where the event log database, file, or cache is deleted from the system, removing the log's historical records." ;
    skos:exactMatch d3f:EventLogDeleteEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogDisableEvent a owl:Class ;
    rdfs:label "EventLogDisableEvent" ;
    dcterms:title "Event Log Disable Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event indicating that the event logging service has been disabled, preventing it from collecting or recording logs." ;
    skos:exactMatch d3f:EventLogDisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogEnableEvent a owl:Class ;
    rdfs:label "EventLogEnableEvent" ;
    dcterms:title "Event Log Enable Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event where the event logging service is enabled, allowing it to actively collect and record logs." ;
    skos:exactMatch d3f:EventLogEnableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogExportEvent a owl:Class ;
    rdfs:label "EventLogExportEvent" ;
    dcterms:title "Event Log Export Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event representing the export of event log data to a file or external system for backup or analysis purposes." ;
    skos:exactMatch d3f:EventLogExportEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogRestartEvent a owl:Class ;
    rdfs:label "EventLogRestartEvent" ;
    dcterms:title "Event Log Restart Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event representing the restarting of the event logging service, often performed during system maintenance or troubleshooting." ;
    skos:exactMatch d3f:EventLogRestartEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogRotateEvent a owl:Class ;
    rdfs:label "EventLogRotateEvent" ;
    dcterms:title "Event Log Rotate Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event where the event log is rotated, often as part of log rotation policies to manage storage and ensure continuity." ;
    skos:exactMatch d3f:EventLogRotateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogStartEvent a owl:Class ;
    rdfs:label "EventLogStartEvent" ;
    dcterms:title "Event Log Start Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event where the event logging service is started, enabling the collection and recording of system events." ;
    skos:exactMatch d3f:EventLogStartEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogStopEvent a owl:Class ;
    rdfs:label "EventLogStopEvent" ;
    dcterms:title "Event Log Stop Event" ;
    rdfs:subClassOf d3f:EventLogEvent ;
    skos:definition "An event indicating that the event logging service has been stopped, halting the recording of system events." ;
    skos:exactMatch d3f:EventLogStopEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EvictionEvent a owl:Class ;
    rdfs:label "EvictionEvent" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Eviction Event" ;
    rdfs:subClassOf d3f:SecurityEvent ;
    skos:definition "An event describing actions to remove adversaries or malicious resources from a system, re-establishing security and operational integrity." ;
    skos:exactMatch d3f:EvictionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExactMatching a owl:Class ;
    rdfs:label "ExactMatching" ;
    d3f:d3fend-id "D3A-EM" ;
    d3f:kb-article "## References 1. Equality (mathematics). (2023, May 31). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Equality_(mathematics)]" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Numeric Equivalence Matching" ;
    dcterms:title "Exact Matching" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:NumericPatternMatching ],
        d3f:EquivalenceMatching ;
    skos:definition "Exact matching for numeric types is just the simple test for mathematical equivalence of the values being matched." ;
    skos:exactMatch d3f:ExactMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExceptionHandler a owl:Class ;
    rdfs:label "ExceptionHandler" ;
    dcterms:title "Exception Handler" ;
    rdfs:seeAlso dbr:Exception_handling ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "An exception handler is a code segment that processes an exception." ;
    skos:exactMatch d3f:ExceptionHandler ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExceptionHandlerPointerValidation a owl:Class ;
    rdfs:label "ExceptionHandlerPointerValidation" ;
    d3f:d3fend-id "D3-EHPV" ;
    d3f:kb-article "## How It Works When a process encounters an exception, it calls an exception handler to deal with the exception. The method by which this exception handler is determined varies by the operating system. The exception handler is called, even if it is the default exception handler to terminate the p" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Exception Handler Validation" ;
    dcterms:title "Exception Handler Pointer Validation" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:definition "Validates that a referenced exception handler pointer is a valid exception handler." ;
    skos:exactMatch d3f:ExceptionHandlerPointerValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Exec a owl:Class ;
    rdfs:label "Exec" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <https://dbpedia.org/page/Exec> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:Exec ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutableBinary a owl:Class ;
    rdfs:label "ExecutableBinary" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Executable Binary" ;
    rdfs:seeAlso dbr:Executable ;
    rdfs:subClassOf d3f:ExecutableFile ;
    skos:definition "An executable binary contains machine code instructions for a physical CPU. D3FEND also considers byte code for a virtual machine to be binary code.  This is in contrast to executable scripts written in a scripting language." ;
    skos:exactMatch d3f:ExecutableBinary ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutableDenylisting a owl:Class ;
    rdfs:label "ExecutableDenylisting" ;
    d3f:d3fend-id "D3-EDL" ;
    d3f:kb-article "## How it works #### Criteria A policy-enforcing application can register an application for denylisting based on conditions including the following: * File attributes * file name * file path * file hash * file publisher, as obtained from the digital signature * permissions of" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Executable Blacklisting" ;
    dcterms:title "Executable Denylisting" ;
    rdfs:subClassOf d3f:ExecutionIsolation ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1027,
        d3f:T1036,
        d3f:T1037,
        d3f:T1055,
        d3f:T1134,
