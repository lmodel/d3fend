d3f:FileEncryptionEvent a owl:Class ;
    rdfs:label "FileEncryptionEvent" ;
    dcterms:title "File Encryption Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event involving the application of cryptographic techniques to a file, ensuring its content is securely encoded and inaccessible without proper decryption keys." ;
    skos:exactMatch d3f:FileEncryptionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileFooterBlock a owl:Class ;
    rdfs:label "FileFooterBlock" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Footer Block" ;
    rdfs:subClassOf d3f:FileSection ;
    skos:definition "A section at the end of a file that contains metadata or control information." ;
    skos:exactMatch d3f:FileFooterBlock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileFooterBlockContent a owl:Class ;
    rdfs:label "FileFooterBlockContent" ;
    dcterms:title "File Footer Block Content" ;
    rdfs:subClassOf d3f:FileMetadata ;
    skos:definition "The content of a footer block not including the signature." ;
    skos:exactMatch d3f:FileFooterBlockContent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileFooterBlockSignature a owl:Class ;
    rdfs:label "FileFooterBlockSignature" ;
    dcterms:title "File Footer Block Signature" ;
    rdfs:subClassOf d3f:FileMetadata ;
    skos:definition "A sequence of bytes used to identify and validate the footer section within a file." ;
    skos:exactMatch d3f:FileFooterBlockSignature ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileGetAttributesEvent a owl:Class ;
    rdfs:label "FileGetAttributesEvent" ;
    dcterms:title "File Get Attributes Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file's metadata attributes, such as size, creation date, or type, are queried or retrieved without altering its content." ;
    skos:exactMatch d3f:FileGetAttributesEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileGetPermissionsEvent a owl:Class ;
    rdfs:label "FileGetPermissionsEvent" ;
    dcterms:title "File Get Permissions Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file's security settings or access control list (ACL) is retrieved, detailing permissions granted to users or processes." ;
    skos:exactMatch d3f:FileGetPermissionsEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileHash a owl:Class ;
    rdfs:label "FileHash" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Hash" ;
    rdfs:subClassOf d3f:DigitalFingerprint ;
    skos:definition "A File Hash is a fixed-length, unique digital fingerprint generated by applying a cryptographic hash function to the contents of a file." ;
    skos:exactMatch d3f:FileHash ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileHashReputationAnalysis a owl:Class ;
    rdfs:label "FileHashReputationAnalysis" ;
    d3f:d3fend-id "D3-FHRA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Hash Reputation Analysis" ;
    rdfs:subClassOf d3f:IdentifierReputationAnalysis ;
    skos:definition "Analyzing the reputation of a file hash." ;
    skos:exactMatch d3f:FileHashReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileHashing a owl:Class ;
    rdfs:label "FileHashing" ;
    d3f:d3fend-id "D3-FH" ;
    d3f:kb-article "## How it works This technique requires a list of hashes to compare a file against. ## Considerations Performance on large files or very large numbers of files." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Hashing" ;
    rdfs:subClassOf d3f:FileAnalysis ;
    skos:definition "Employing file hash comparisons to detect known malware." ;
    skos:exactMatch d3f:FileHashing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileHeaderBlock a owl:Class ;
    rdfs:label "FileHeaderBlock" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Header Block" ;
    rdfs:subClassOf d3f:FileSection ;
    skos:definition "Headers are sections of a file that organize and provide information about specific sections or components of the file. Typically found at the beginning of a file, they often contain file type identification, version information, and metadata such as size, format, and encoding." ;
    skos:exactMatch d3f:FileHeaderBlock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileHeaderBlockContent a owl:Class ;
    rdfs:label "FileHeaderBlockContent" ;
    dcterms:title "File Header Block Content" ;
    rdfs:subClassOf d3f:FileMetadata ;
    skos:definition "The content of a header block not including the signature." ;
    skos:exactMatch d3f:FileHeaderBlockContent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileIntegrityMonitoring a owl:Class ;
    rdfs:label "FileIntegrityMonitoring" ;
    d3f:d3fend-id "D3-FIM" ;
    d3f:kb-article "## How it Works There are a number of tools in Windows and Unix that can monitor specific files in a system and generate alerts if any artifacts have been created, modified, or removed. They accomplish this by comparing the current artifacts to a previous snapshot. Unix - Unix systems have a file i" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Integrity Monitoring" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
