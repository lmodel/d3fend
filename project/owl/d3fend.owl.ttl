d3f:SomersD a owl:Class ;
    rdfs:label "SomersD" ;
    d3f:d3fend-id "D3A-SD" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Somers' D" ;
    rdfs:subClassOf d3f:RankCorrelationCoefficient ;
    skos:exactMatch d3f:SomersD ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoundexMatching a owl:Class ;
    rdfs:label "SoundexMatching" ;
    d3f:d3fend-id "D3A-SM" ;
    d3f:kb-article "## How it works The goal is for homophones to be encoded to the same representation so that they can be matched despite minor differences in spelling. The algorithm mainly encodes consonants; a vowel will not be encoded unless it is the first letter. Soundex is the most widely known of all phonetic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Soundex Matching" ;
    rdfs:subClassOf d3f:PartialMatching ;
    skos:definition "Soundex is a phonetic algorithm for indexing names by sound, as pronounced in English." ;
    skos:exactMatch d3f:SoundexMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SourceCodeAnalyzerTool a owl:Class ;
    rdfs:label "SourceCodeAnalyzerTool" ;
    dcterms:title "Source Code Analyzer Tool" ;
    rdfs:seeAlso dbr:Static_program_analysis ;
    rdfs:subClassOf d3f:StaticAnalysisTool ;
    skos:definition "A source code analyzer tool is a static analysis tool that operates specifically on source code, but not object code." ;
    skos:exactMatch d3f:SourceCodeAnalyzerTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SourceCodeReference a owl:Class ;
    rdfs:label "SourceCodeReference" ;
    d3f:pref-label "Source Code" ;
    dcterms:title "Source Code Reference" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:exactMatch d3f:SourceCodeReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SpacecraftSafeMode a owl:Class ;
    rdfs:label "SpacecraftSafeMode" ;
    dcterms:title "Spacecraft Safe Mode" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Safe_mode_in_spacecraft> ;
    rdfs:subClassOf d3f:SafeMode ;
    skos:definition "Safe mode is an operating mode of a modern uncrewed spacecraft during which all non-essential systems are shut down and only essential functions such as thermal management, radio reception and attitude control are active." ;
    skos:exactMatch d3f:SpacecraftSafeMode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SpearmansRankCorrelationCoefficient a owl:Class ;
    rdfs:label "SpearmansRankCorrelationCoefficient" ;
    d3f:d3fend-id "D3A-SRCC" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Spearman's Rho" ;
    dcterms:title "Spearman's Rank Correlation Coefficient" ;
    rdfs:subClassOf d3f:RankCorrelationCoefficient ;
    skos:exactMatch d3f:SpearmansRankCorrelationCoefficient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SpecificationReference a owl:Class ;
    rdfs:label "SpecificationReference" ;
