d3f:T1564 a owl:Class ;
    rdfs:label "T1564" ;
    d3f:attack-id "T1564" ;
    dcterms:title "Hide Artifacts" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to hide artifacts associated with their behaviors to evade detection. Operating systems may have features to hide various artifacts, such as important system files and administrative task execution, to avoid disrupting user work environments and prevent users from changing files or features on the system. Adversaries may abuse these features to hide artifacts such as files, directories, user accounts, or other system activity to evade detection.(Citation: Sofacy Komplex Trojan)(Citation: Cybereason OSX Pirrit)(Citation: MalwareBytes ADS July 2015)" ;
    skos:exactMatch d3f:T1564,
        mitre-attack:T1564 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CollectionTechnique a owl:Class ;
    rdfs:label "CollectionTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Collection Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to gather data of interest to their goal." ;
    skos:exactMatch d3f:CollectionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InitialAccessTechnique a owl:Class ;
    rdfs:label "InitialAccessTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Initial Access Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to get into your network." ;
    skos:exactMatch d3f:InitialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562 a owl:Class ;
    rdfs:label "T1562" ;
    d3f:attack-id "T1562" ;
    dcterms:title "Impair Defenses" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may maliciously modify components of a victim environment in order to hinder or disable defensive mechanisms. This not only involves impairing preventative defenses, such as firewalls and anti-virus, but also detection capabilities that defenders can use to audit activity and identify malicious behavior. This may also span both native defenses as well as supplemental capabilities installed by users and administrators." ;
    skos:exactMatch d3f:T1562,
        mitre-attack:T1562 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505 a owl:Class ;
    rdfs:label "T1505" ;
    d3f:attack-id "T1505" ;
    dcterms:title "Server Software Component" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may abuse legitimate extensible development features of servers to establish persistent access to systems. Enterprise server applications may include features that allow developers to write and install software or scripts to extend the functionality of the main application. Adversaries may install malicious components to extend and abuse server applications.(Citation: volexity_0day_sophos_FW)" ;
    skos:exactMatch d3f:T1505,
        mitre-attack:T1505 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OffensiveTacticEnum a owl:Class ;
    rdfs:label "OffensiveTacticEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:AML.TA0000 d3f:AML.TA0001 d3f:AML.TA0002 d3f:AML.TA0003 d3f:AML.TA0004 d3f:AML.TA0005 d3f:AML.TA0006 d3f:AML.TA0007 d3f:AML.TA0008 d3f:AML.TA0009 d3f:AML.TA0010 d3f:AML.TA0011 d3f:AML.TA0012 d3f:AML.TA0013 d3f:AML.TA0014 d3f:AML.TA0015 d3f:TA0001 d3f:TA0002 d3f:TA0003 d3f:TA0004 d3f:TA0005 d3f:TA0006 d3f:TA0007 d3f:TA0008 d3f:TA0009 d3f:TA0010 d3f:TA0011 d3f:TA0027 d3f:TA0028 d3f:TA0029 d3f:TA0030 d3f:TA0031 d3f:TA0032 d3f:TA0033 d3f:TA0034 d3f:TA0035 d3f:TA0036 d3f:TA0037 d3f:TA0040 d3f:TA0041 d3f:TA0042 d3f:TA0043 d3f:TA0100 d3f:TA0101 d3f:TA0102 d3f:TA0103 d3f:TA0104 d3f:TA0105 d3f:TA0106 d3f:TA0107 d3f:TA0108 d3f:TA0109 d3f:TA0110 d3f:TA0111 ) ;
    skos:definition "Enumeration of OffensiveTactic values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "Per ATT&CK, these are defined as Tactical Goals, not Tactics per se. Many children also fit definition of tactics. Some are neither tactics or tactical goals really (e.g., Execution, which is a useful grouping, but an action, not really a tactic or technique." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:AML.TA0000,
        d3f:AML.TA0001,
        d3f:AML.TA0002,
        d3f:AML.TA0003,
        d3f:AML.TA0004,
        d3f:AML.TA0005,
        d3f:AML.TA0006,
        d3f:AML.TA0007,
        d3f:AML.TA0008,
        d3f:AML.TA0009,
        d3f:AML.TA0010,
        d3f:AML.TA0011,
        d3f:AML.TA0012,
        d3f:AML.TA0013,
        d3f:AML.TA0014,
        d3f:AML.TA0015,
        d3f:TA0001,
        d3f:TA0002,
        d3f:TA0003,
        d3f:TA0004,
        d3f:TA0005,
        d3f:TA0006,
        d3f:TA0007,
        d3f:TA0008,
        d3f:TA0009,
        d3f:TA0010,
        d3f:TA0011,
        d3f:TA0027,
        d3f:TA0028,
        d3f:TA0029,
        d3f:TA0030,
        d3f:TA0031,
        d3f:TA0032,
        d3f:TA0033,
        d3f:TA0034,
        d3f:TA0035,
        d3f:TA0036,
        d3f:TA0037,
        d3f:TA0040,
        d3f:TA0041,
        d3f:TA0042,
        d3f:TA0043,
        d3f:TA0100,
        d3f:TA0101,
        d3f:TA0102,
        d3f:TA0103,
        d3f:TA0104,
        d3f:TA0105,
