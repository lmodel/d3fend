    skos:exactMatch d3f:AuthenticationLog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthenticationServer a owl:Class ;
    rdfs:label "AuthenticationServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Server" ;
    rdfs:seeAlso dbr:Authentication_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "An authentication server provides a network service that applications use to authenticate the credentials, usually account names and passwords, of their users. When a client submits a valid set of credentials, it receives a cryptographic ticket that it can subsequently use to access various services. Major authentication algorithms include passwords, Kerberos, and public key encryption." ;
    skos:exactMatch d3f:AuthenticationServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthenticationServiceApplication a owl:Class ;
    rdfs:label "AuthenticationServiceApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Service Application" ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "A software application designed to verify the identity of users or devices." ;
    skos:exactMatch d3f:AuthenticationServiceApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthorizationEventThresholding a owl:Class ;
    rdfs:label "AuthorizationEventThresholding" ;
    d3f:d3fend-id "D3-AZET" ;
    d3f:kb-article "## How it works Authorization event data is collected to create a baseline user profile. Authorization events that deviate from the baseline and exceed a static or dynamic threshold are identified for further action. Authorization events can include successful and failed authorization attempts as w" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authorization Event Thresholding" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Collecting authorization events, creating a baseline user profile, and determining whether authorization events are consistent with the baseline profile." ;
    skos:exactMatch d3f:AuthorizationEventThresholding ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthorizationLog a owl:Class ;
    rdfs:label "AuthorizationLog" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authorization Log" ;
    rdfs:seeAlso dbr:Authorization,
        <http://wordnet-rdf.princeton.edu/id/00155053-n> ;
    rdfs:subClassOf d3f:EventLog ;
    skos:definition "A log of authorization events." ;
    skos:exactMatch d3f:AuthorizationLog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Autoencoding a owl:Class ;
    rdfs:label "Autoencoding" ;
    d3f:d3fend-id "D3A-AUT" ;
    d3f:kb-article "## References SOCR. (n.d.). ABIDE Autoencoder. [Link](https://socr.umich.edu/HTML5/ABIDE_Autoencoder/#:~:text=In%20simple%20words%2C%20autoencoders%20are,layer%20at%20its%20output%20layer.)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DimensionReduction ;
    skos:definition "Autoencoders are specific type of deep learning architecture used for learning representation of data, typically for the purpose of dimensionality reduction. This is achieved by designing deep learning architecture that aims that copying input layer at its output layer." ;
    skos:exactMatch d3f:Autoencoding ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AutoregressiveModel a owl:Class ;
    rdfs:label "AutoregressiveModel" ;
    d3f:d3fend-id "D3A-AM" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Autoregressive model. [Link](https://en.wikipedia.org/wiki/Autoregressive_model)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "AR Model" ;
    dcterms:title "Autoregressive Model" ;
    rdfs:subClassOf d3f:TimeSeriesAnalysis ;
    skos:definition "An autoregressive (AR) model is a representation of a type of random process; as such, it is used to describe certain time-varying processes in nature, economics, behavior, etc." ;
    skos:exactMatch d3f:AutoregressiveModel ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BERT a owl:Class ;
    rdfs:label "BERT" ;
    d3f:d3fend-id "D3A-BER" ;
    d3f:kb-article "## References BERT (language model). (n.d.). In TechTarget. [Link](https://www.techtarget.com/searchenterpriseai/definition/BERT-language-model) BERT (language model). (n.d.). In Wikipedia. [Link](https://en.wikipedia.org/wiki/BERT_(language_model))" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Bidirectional Encoder Representations from Transformers" ;
    rdfs:subClassOf d3f:TransformerBasedLearning ;
    skos:definition "Bidirectional Encoder Representations from Transformers (BERT) is based on a deep learning model in which every output element is connected to every input element, and the weightings between them are dynamically calculated based upon their connection." ;
    skos:exactMatch d3f:BERT ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BarcodeScannerInputDevice a owl:Class ;
    rdfs:label "BarcodeScannerInputDevice" ;
    dcterms:title "Barcode Scanner Input Device" ;
    rdfs:seeAlso dbr:Barcode_reader ;
    rdfs:subClassOf d3f:ImageScannerInputDevice ;
    skos:altLabel "Barcode Reader" ;
    skos:definition "A barcode reader (or barcode scanner) is an optical scanner that can read printed barcodes, decode the data contained in the barcode and send the data to a computer. Like a flatbed scanner, it consists of a light source, a lens and a light sensor translating for optical impulses into electrical signals. Additionally, nearly all barcode readers contain decoder circuitry that can analyze the barcode's image data provided by the sensor and sending the barcode's content to the scanner's output port." ;
    skos:exactMatch d3f:BarcodeScannerInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesOptimalClassifier a owl:Class ;
    rdfs:label "BayesOptimalClassifier" ;
    d3f:d3fend-id "D3A-BOC" ;
    d3f:kb-article "## References Bayes Optimal Classifier. Machine Learning Mastery. [Link](https://machinelearningmastery.com/bayes-optimal-classifier/). Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayes Optimal Classifier" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "A probabilistic model that makes the most probable prediction for a new example." ;
    skos:exactMatch d3f:BayesOptimalClassifier ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesianEstimation a owl:Class ;
    rdfs:label "BayesianEstimation" ;
    d3f:d3fend-id "D3A-BE" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Bayes estimator. [Link](https://en.wikipedia.org/wiki/Bayes_estimator)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Estimation" ;
    rdfs:subClassOf d3f:BayesianMethod ;
    skos:definition "A Bayes estimator or a Bayes action is an estimator or decision rule that minimizes the posterior expected value of a loss function (i.e., the posterior expected loss)." ;
    skos:exactMatch d3f:BayesianEstimation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesianHypothesisTesting a owl:Class ;
    rdfs:label "BayesianHypothesisTesting" ;
    d3f:d3fend-id "D3A-BHT" ;
    d3f:kb-article "## How it works Given two competing hypotheses and some relevant data, Bayesian hypothesis testing begins by specifying separate prior distributions to quantitatively describe each hypothesis. The combination of the likelihood function for the observed data with each of the prior distributions yield" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Hypothesis Testing" ;
    rdfs:subClassOf d3f:BayesianMethod ;
    skos:definition "Bayesian hypothesis testing can be framed as a special case of model comparison where a model refers to a likelihood function and a prior distribution." ;
    skos:exactMatch d3f:BayesianHypothesisTesting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesianLinearRegressionLearning a owl:Class ;
    rdfs:label "BayesianLinearRegressionLearning" ;
    d3f:d3fend-id "D3A-BLRL" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Bayesian linear regression. [Link](https://en.wikipedia.org/wiki/Bayesian_linear_regression)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Linear Regression Learning" ;
    rdfs:seeAlso d3f:BayesianLinearRegression ;
    rdfs:subClassOf d3f:RegressionAnalysisLearning ;
    skos:definition "A supervised learning method that builds a Bayesian linear regression model using training data." ;
    skos:exactMatch d3f:BayesianLinearRegressionLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesianModelAveraging a owl:Class ;
    rdfs:label "BayesianModelAveraging" ;
    d3f:d3fend-id "D3A-BMA" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning). Bayesian model average: A parameter estimation approach to model agnostic ensemble learning. (2019). Journal of Machine Learning for Modeling and Computing, 1(2), 61-70. [Link](https://journals.sa" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Model Averaging" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "A parameter estimate (or a prediction of new observations) obtained by averaging the estimates (or predictions) of the different models under consideration, each weighted by its model probability." ;
    skos:exactMatch d3f:BayesianModelAveraging ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesianModelCombination a owl:Class ;
    rdfs:label "BayesianModelCombination" ;
    d3f:d3fend-id "D3A-BMC" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning). Shultz, K. M., & Peterson, L. E. (2011). Model-averaged confidence intervals for ensemble learning. In *International Joint Conference on Neural Networks* (pp. 2677-2684). [Link](https://axon.cs.b" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Model Combination" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "Bayesian model combination (BMC) is an algorithmic correction to Bayesian model averaging (BMA). Instead of sampling each model in the ensemble individually, it samples from the space of possible ensembles (with model weights drawn randomly from a Dirichlet distribution having uniform parameters)" ;
    skos:exactMatch d3f:BayesianModelCombination ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BinaryClassification a owl:Class ;
    rdfs:label "BinaryClassification" ;
    dcterms:title "Binary Classification" ;
    rdfs:subClassOf d3f:Classifying ;
    skos:exactMatch d3f:BinaryClassification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BiometricAuthentication a owl:Class ;
    rdfs:label "BiometricAuthentication" ;
    d3f:d3fend-id "D3-BAN" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Biometric Authentication" ;
    rdfs:subClassOf d3f:AgentAuthentication ;
    skos:definition "Using biological measures in order to authenticate a user." ;
    skos:exactMatch d3f:BiometricAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BitmapImage a owl:Class ;
    rdfs:label "BitmapImage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bitmap Image" ;
    rdfs:subClassOf d3f:DigitalImage ;
    skos:definition "A graphical image whose data is stored in a grid format." ;
    skos:exactMatch d3f:BitmapImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BitmapImageFile a owl:Class ;
    rdfs:label "BitmapImageFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bitmap Image File" ;
    rdfs:subClassOf d3f:ImageFile ;
    skos:definition "A file that contains graphics data represented in a bitmap." ;
    skos:exactMatch d3f:BitmapImageFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BlockDevice a owl:Class ;
    rdfs:label "BlockDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Block Device" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Device_file#BLOCKDEV>,
        <https://pubs.opengroup.org/onlinepubs/9699919799/basedefs/V1_chap03.html#tag_03_79> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Block Special File" ;
    skos:definition """A block device (or block special file) provides buffered access to hardware devices, and provides some abstraction from their specifics.

IEEE Std 1003.1-2017: A file that refers to a device. A block special file is normally distinguished from a character special file by providing access to the device in a manner such that the hardware characteristics of the device are not visible.""" ;
    skos:exactMatch d3f:BlockDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BookReference a owl:Class ;
    rdfs:label "BookReference" ;
    d3f:pref-label "Book" ;
    dcterms:title "Book Reference" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:exactMatch d3f:BookReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BooleanExpressionMatching a owl:Class ;
    rdfs:label "BooleanExpressionMatching" ;
    d3f:d3fend-id "D3A-BEM" ;
    d3f:kb-article "## How it works A Boolean expression is an expression used in programming languages that produces a Boolean value when evaluated. A Boolean value is either true or false. A Boolean expression may be composed of a combination of the Boolean constants true or false, Boolean-typed variables, Boolean-va" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Boolean Expression Matching" ;
    rdfs:subClassOf d3f:LogicalRules ;
    skos:definition "Boolean expression matching produces a Boolean truth value for a given boolean expression and assignment of values to variables in the expression." ;
    skos:exactMatch d3f:BooleanExpressionMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Boosting a owl:Class ;
    rdfs:label "Boosting" ;
    d3f:d3fend-id "D3A-BOO" ;
    d3f:kb-article "## How it works Boosting consists of using sequentially weak learners where each iteration’s training focuses on previously misclassified instances in order to improve on the previous iteration. This process is continued iteratively until the final prediction is made by aggregating the previous pred" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "Boosting is a sequential process where each subsequent model attempts to correct the errors of the previous model" ;
    skos:exactMatch d3f:Boosting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BootROM a owl:Class ;
    rdfs:label "BootROM" ;
    d3f:synonym "Boot Read-only Memory" ;
    dcterms:title "Boot ROM" ;
    rdfs:seeAlso <https://dbpedia.org/page/Boot_ROM> ;
    rdfs:subClassOf d3f:ROM ;
    skos:definition "Boot ROM is a piece of read-only memory (ROM) that is used for booting a computer system. It contains instructions that are run after the CPU is reset to the reset vector, and it typically loads a bootloader." ;
    skos:exactMatch d3f:BootROM ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BootSector a owl:Class ;
    rdfs:label "BootSector" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Boot Sector" ;
    rdfs:seeAlso dbr:Boot_sector ;
    rdfs:subClassOf d3f:BootRecord ;
    skos:definition "A boot record [boot sector] is the sector of a persistent data storage device (e.g., hard disk, floppy disk, optical disc, etc.) which contains machine code to be loaded into random-access memory (RAM) and then executed by a computer system's built-in firmware (e.g., the BIOS, Das U-Boot, etc.)." ;
    skos:exactMatch d3f:BootSector ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BootloaderAuthentication a owl:Class ;
    rdfs:label "BootloaderAuthentication" ;
    d3f:d3fend-id "D3-BA" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Secure Boot" ;
    dcterms:title "Bootloader Authentication" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:broadMatch d3f:T1542 ;
    skos:definition "Cryptographically authenticating the bootloader software before system boot." ;
    skos:exactMatch d3f:BootloaderAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1542.003 .

d3f:BroadcastDomainIsolation a owl:Class ;
    rdfs:label "BroadcastDomainIsolation" ;
    d3f:d3fend-id "D3-BDI" ;
    d3f:kb-article "## How it works Software Defined Networking, or other network encapsulation technologies intercept host broadcast traffic then route it to a specified destination per a configured policy. This can be implemented within hypervisors, networking hardware (WAPs, switches, routers), or virutal hardware." ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Network Segmentation" ;
    dcterms:title "Broadcast Domain Isolation" ;
    rdfs:subClassOf d3f:NetworkIsolation ;
    skos:definition "Broadcast isolation restricts the number of computers a host can contact on their LAN." ;
    skos:exactMatch d3f:BroadcastDomainIsolation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Browser a owl:Class ;
    rdfs:label "Browser" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Web_browser,
        <http://wordnet-rdf.princeton.edu/id/13376000-n> ;
    rdfs:subClassOf d3f:UserApplication ;
    skos:definition "A web browser (commonly referred to as a browser) is a software application for retrieving, presenting, and traversing information resources on the World Wide Web. An information resource is identified by a Uniform Resource Identifier (URI/URL) and may be a web page, image, video or other piece of content. Hyperlinks present in resources enable users easily to navigate their browsers to related resources. Although browsers are primarily intended to use the World Wide Web, they can also be used to access information provided by web servers in private networks or files in file systems." ;
    skos:exactMatch d3f:Browser ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BrowserExtension a owl:Class ;
    rdfs:label "BrowserExtension" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Browser Extension" ;
    rdfs:seeAlso dbr:Browser_extension ;
    rdfs:subClassOf d3f:UserApplication ;
    skos:definition "A browser extension is a plug-in that extends the functionality of a web browser in some way. Some extensions are authored using web technologies such as HTML, JavaScript, and CSS. Browser extensions can change the user interface of the web browser without directly affecting viewable content of a web page; for example, by adding a \"toolbar.\"" ;
    skos:exactMatch d3f:BrowserExtension ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BucketOfModels a owl:Class ;
    rdfs:label "BucketOfModels" ;
    d3f:d3fend-id "D3A-BOM" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bucket of Models" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "A \"bucket of models\" is an ensemble technique in which a model selection algorithm is used to choose the best model for each problem. When tested with only one problem, a bucket of models can produce no better results than the best model in the set, but when evaluated across many problems, it will typically produce much better results, on average, than any model in the set." ;
    skos:exactMatch d3f:BucketOfModels ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusMessage a owl:Class ;
    rdfs:label "BusMessage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bus Message" ;
    rdfs:subClassOf d3f:DigitalMessage ;
    skos:definition "A digital message potentially containing commands, telemetry, or status signals, encoded in a bus protocol and conveyed over a bus within one or more frames." ;
    skos:exactMatch d3f:BusMessage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusMessageAuthentication a owl:Class ;
    rdfs:label "BusMessageAuthentication" ;
    d3f:d3fend-id "D3-BMA" ;
    d3f:kb-article "## How it works Bus Message Authentication functions as a continuous validation layer that operates between the physical transmission of a signal and the application layer's processing of data. Every node on a bus network is provisioned with a cryptographic key and a synchronized 'freshness' state (" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bus Message Authentication" ;
    rdfs:subClassOf d3f:MessageAuthentication ;
    skos:definition "Applies cryptographic primitives to individual bus frames to verify the sender's identity and ensure the integrity of the data payload." ;
    skos:exactMatch d3f:BusMessageAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusNetwork a owl:Class ;
    rdfs:label "BusNetwork" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bus Network" ;
    rdfs:seeAlso dbr:Bus_\(computing\) ;
    rdfs:subClassOf d3f:Network ;
    skos:altLabel "Bus",
        "Data Highway" ;
    skos:definition "An electronic communication system that links multiple components through one shared transmission medium, together with the interface hardware and link-layer signalling that govern access to that medium." ;
    skos:exactMatch d3f:BusNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusNetworkFrame a owl:Class ;
    rdfs:label "BusNetworkFrame" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bus Network Frame" ;
    rdfs:subClassOf d3f:NetworkFrame ;
    skos:altLabel "Bus Frame" ;
    skos:definition "A network frame whose layout and timing follow a bus protocol, allowing data to be exchanged across the shared bus medium." ;
    skos:exactMatch d3f:BusNetworkFrame ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusNetworkNode a owl:Class ;
    rdfs:label "BusNetworkNode" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bus Network Node" ;
    rdfs:subClassOf d3f:Host ;
    skos:definition "A device or logical endpoint whose interface is directly connected to a bus and exchanges data over the shared medium using the protocol implemented on that interface." ;
    skos:exactMatch d3f:BusNetworkNode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusNetworkTraffic a owl:Class ;
    rdfs:label "BusNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bus Network Traffic" ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "The ordered flow of frames, structured by a bus protocol, that traverses the shared bus medium during operation." ;
    skos:exactMatch d3f:BusNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BusinessCommunicationPlatformClient a owl:Class ;
    rdfs:label "BusinessCommunicationPlatformClient" ;
    dcterms:title "Business Communication Platform Client" ;
    rdfs:seeAlso dbr:Business_communication ;
    rdfs:subClassOf d3f:CollaborativeSoftware ;
    skos:definition "Client software to enable the process of sharing information between employees within and outside a company.  Business communication encompasses topics such as marketing, brand management, customer relations, consumer behavior, advertising, public relations, corporate communication, community engagement, reputation management, interpersonal communication, employee engagement, and event management. It is closely related to the fields of professional communication and technical communication." ;
    skos:exactMatch d3f:BusinessCommunicationPlatformClient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ByteSequenceEmulation a owl:Class ;
    rdfs:label "ByteSequenceEmulation" ;
    d3f:d3fend-id "D3-BSE" ;
    d3f:kb-article "## How it works Bytes are analyzed as if they are machine code instructions, and such instructions that are a common component of known shellcode are noted, such as stack pivots, reads from a Memory Address Table, and system calls for functions that disable protections or execute code. For example" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Shellcode Transmission Detection" ;
    dcterms:title "Byte Sequence Emulation" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:definition "Analyzing sequences of bytes and determining if they likely represent malicious shellcode." ;
    skos:exactMatch d3f:ByteSequenceEmulation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CACertificateFile a owl:Class ;
    rdfs:label "CACertificateFile" ;
    dcterms:title "CA Certificate File" ;
    rdfs:seeAlso dbr:Certificate_authority,
        dbr:Public_key_infrastructure ;
    rdfs:subClassOf d3f:CertificateFile ;
    skos:definition "A file containing a digital certificate issued by a certificate authority (CA).  Certificate authorities store, issue, and sign digital certificates used as part of the public key infrastructure." ;
    skos:exactMatch d3f:CACertificateFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CCIControl a owl:Class ;
    rdfs:label "CCIControl" ;
    dcterms:title "CCI Control" ;
    rdfs:subClassOf d3f:ExternalControl ;
    skos:exactMatch d3f:CCIControl ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1105 a owl:Class ;
    rdfs:label "CWE_1105" ;
    d3f:cwe-id "CWE-1105" ;
    dcterms:title "Insufficient Encapsulation of Machine-Dependent Functionality" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE758 ],
        d3f:CWE1061 ;
    skos:altLabel "CWE-1105" ;
    skos:definition "The product or code uses machine-dependent functionality, but it does not sufficiently encapsulate or isolate this functionality from the rest of the code." ;
    skos:exactMatch d3f:CWE-1105,
        cwe:CWE-1105 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE118 a owl:Class ;
    rdfs:label "CWE_118" ;
    d3f:cwe-id "CWE-118" ;
    dcterms:title "Incorrect Access of Indexable Resource ('Range Error')" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-118" ;
    skos:definition "The product does not restrict or incorrectly restricts operations within the boundaries of a resource that is accessed using an index or pointer, such as memory or files." ;
    skos:exactMatch d3f:CWE-118,
        cwe:CWE-118 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1188 a owl:Class ;
    rdfs:label "CWE_1188" ;
    d3f:cwe-id "CWE-1188" ;
    dcterms:title "Initialization of a Resource with an Insecure Default" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE665 ],
        d3f:CWE1419 ;
    skos:altLabel "CWE-1188" ;
    skos:definition "The product initializes or sets a resource with a default that is intended to be changed by the administrator, but the default is not secure." ;
    skos:exactMatch d3f:CWE-1188,
        cwe:CWE-1188 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1189 a owl:Class ;
    rdfs:label "CWE_1189" ;
    d3f:cwe-id "CWE-1189" ;
    dcterms:title "Improper Isolation of Shared Resources on System-on-a-Chip (SoC)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE668 ],
        d3f:CWE653 ;
    skos:altLabel "CWE-1189" ;
    skos:definition "The System-On-a-Chip (SoC) does not properly isolate shared resources between trusted and untrusted agents." ;
    skos:exactMatch d3f:CWE-1189,
        cwe:CWE-1189 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE120 a owl:Class ;
    rdfs:label "CWE_120" ;
    d3f:cwe-id "CWE-120" ;
    d3f:synonym "Classic Buffer Overflow" ;
    dcterms:title "Buffer Copy without Checking Size of Input ('Classic Buffer Overflow')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE787 ],
        d3f:CWE119 ;
    skos:altLabel "CWE-120" ;
    skos:definition "The product copies an input buffer to an output buffer without verifying that the size of the input buffer is less than the size of the output buffer, leading to a buffer overflow." ;
    skos:exactMatch d3f:CWE-120,
        cwe:CWE-120 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1204 a owl:Class ;
    rdfs:label "CWE_1204" ;
    d3f:cwe-id "CWE-1204" ;
    dcterms:title "Generation of Weak Initialization Vector (IV)" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-1204" ;
    skos:definition "The product uses a cryptographic primitive that uses an Initialization Vector (IV), but the product does not generate IVs that are sufficiently unpredictable or unique according to the expected cryptographic requirements for that primitive." ;
    skos:exactMatch d3f:CWE-1204,
        cwe:CWE-1204 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1220 a owl:Class ;
    rdfs:label "CWE_1220" ;
    d3f:cwe-id "CWE-1220" ;
    dcterms:title "Insufficient Granularity of Access Control" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1220" ;
    skos:definition "The product implements access controls via a policy or other feature with the intention to disable or restrict accesses (reads and/or writes) to assets in a system from untrusted agents. However, implemented access controls lack required granularity, which renders the control policy too broad because it allows accesses from unauthorized agents to the security-sensitive assets." ;
    skos:exactMatch d3f:CWE-1220,
        cwe:CWE-1220 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1229 a owl:Class ;
    rdfs:label "CWE_1229" ;
    d3f:cwe-id "CWE-1229" ;
    dcterms:title "Creation of Emergent Resource" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-1229" ;
    skos:definition "The product manages resources or behaves in a way that indirectly creates a new, distinct resource that can be used by attackers in violation of the intended policy." ;
    skos:exactMatch d3f:CWE-1229,
        cwe:CWE-1229 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1263 a owl:Class ;
    rdfs:label "CWE_1263" ;
    d3f:cwe-id "CWE-1263" ;
    dcterms:title "Improper Physical Access Control" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1263" ;
    skos:definition "The product is designed with access restricted to certain information, but it does not sufficiently protect against an unauthorized actor with physical access to these areas." ;
    skos:exactMatch d3f:CWE-1263,
        cwe:CWE-1263 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1286 a owl:Class ;
    rdfs:label "CWE_1286" ;
    d3f:cwe-id "CWE-1286" ;
    dcterms:title "Improper Validation of Syntactic Correctness of Input" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1286" ;
    skos:definition "The product receives input that is expected to be well-formed - i.e., to comply with a certain syntax - but it does not validate or incorrectly validates that the input complies with the syntax." ;
    skos:exactMatch d3f:CWE-1286,
        cwe:CWE-1286 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1294 a owl:Class ;
    rdfs:label "CWE_1294" ;
    d3f:cwe-id "CWE-1294" ;
    dcterms:title "Insecure Security Identifier Mechanism" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-1294" ;
    skos:definition "The System-on-Chip (SoC) implements a Security Identifier mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. However, the Security Identifiers are not correctly implemented." ;
    skos:exactMatch d3f:CWE-1294,
        cwe:CWE-1294 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1300 a owl:Class ;
    rdfs:label "CWE_1300" ;
    d3f:cwe-id "CWE-1300" ;
    dcterms:title "Improper Protection of Physical Side Channels" ;
    rdfs:subClassOf d3f:CWE203 ;
    skos:altLabel "CWE-1300" ;
    skos:definition "The device does not contain sufficient protection mechanisms to prevent physical side channels from exposing sensitive information due to patterns in physically observable phenomena such as variations in power consumption, electromagnetic emissions (EME), or acoustic emissions." ;
    skos:exactMatch d3f:CWE-1300,
        cwe:CWE-1300 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1301 a owl:Class ;
    rdfs:label "CWE_1301" ;
    d3f:cwe-id "CWE-1301" ;
    dcterms:title "Insufficient or Incomplete Data Removal within Hardware Component" ;
    rdfs:subClassOf d3f:CWE226 ;
    skos:altLabel "CWE-1301" ;
    skos:definition "The product's data removal process does not completely delete all data and potentially sensitive information within hardware components." ;
    skos:exactMatch d3f:CWE-1301,
        cwe:CWE-1301 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE131 a owl:Class ;
    rdfs:label "CWE_131" ;
    d3f:cwe-id "CWE-131" ;
    dcterms:title "Incorrect Calculation of Buffer Size" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-131" ;
    skos:definition "The product does not correctly calculate the size to be used when allocating a buffer, which could lead to a buffer overflow." ;
    skos:exactMatch d3f:CWE-131,
        cwe:CWE-131 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1341 a owl:Class ;
    rdfs:label "CWE_1341" ;
    d3f:cwe-id "CWE-1341" ;
    dcterms:title "Multiple Releases of Same Resource or Handle" ;
    rdfs:subClassOf d3f:CWE675 ;
    skos:altLabel "CWE-1341" ;
    skos:definition "The product attempts to close or release a resource or handle more than once, without any successful open between the close operations." ;
    skos:exactMatch d3f:CWE-1341,
        cwe:CWE-1341 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE147 a owl:Class ;
    rdfs:label "CWE_147" ;
    d3f:cwe-id "CWE-147" ;
    dcterms:title "Improper Neutralization of Input Terminators" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-147" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as input terminators when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-147,
        cwe:CWE-147 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE155 a owl:Class ;
    rdfs:label "CWE_155" ;
    d3f:cwe-id "CWE-155" ;
    dcterms:title "Improper Neutralization of Wildcards or Matching Symbols" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-155" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as wildcards or matching symbols when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-155,
        cwe:CWE-155 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE161 a owl:Class ;
    rdfs:label "CWE_161" ;
    d3f:cwe-id "CWE-161" ;
    dcterms:title "Improper Neutralization of Multiple Leading Special Elements" ;
    rdfs:subClassOf d3f:CWE160 ;
    skos:altLabel "CWE-161" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes multiple leading special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-161,
        cwe:CWE-161 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE164 a owl:Class ;
    rdfs:label "CWE_164" ;
    d3f:cwe-id "CWE-164" ;
    dcterms:title "Improper Neutralization of Internal Special Elements" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-164" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes internal special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-164,
        cwe:CWE-164 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE183 a owl:Class ;
    rdfs:label "CWE_183" ;
    d3f:cwe-id "CWE-183" ;
    d3f:synonym "Allowlist / Allow List" ;
    dcterms:title "Permissive List of Allowed Inputs" ;
    rdfs:subClassOf d3f:CWE697 ;
    skos:altLabel "CWE-183" ;
    skos:definition "The product implements a protection mechanism that relies on a list of inputs (or properties of inputs) that are explicitly allowed by policy because the inputs are assumed to be safe, but the list is too permissive - that is, it allows an input that is unsafe, leading to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-183,
        cwe:CWE-183 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE184 a owl:Class ;
    rdfs:label "CWE_184" ;
    d3f:cwe-id "CWE-184" ;
    d3f:synonym "Blacklist / Black List" ;
    dcterms:title "Incomplete List of Disallowed Inputs" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE1023 ;
    skos:altLabel "CWE-184" ;
    skos:definition "The product implements a protection mechanism that relies on a list of inputs (or properties of inputs) that are not allowed by policy or otherwise require other action to neutralize before additional processing takes place, but the list is incomplete." ;
    skos:exactMatch d3f:CWE-184,
        cwe:CWE-184 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE188 a owl:Class ;
    rdfs:label "CWE_188" ;
    d3f:cwe-id "CWE-188" ;
    dcterms:title "Reliance on Data/Memory Layout" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE435 ],
        d3f:CWE1105 ;
    skos:altLabel "CWE-188" ;
    skos:definition "The product makes invalid assumptions about how protocol data or memory is organized at a lower level, resulting in unintended program behavior." ;
    skos:exactMatch d3f:CWE-188,
        cwe:CWE-188 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE190 a owl:Class ;
    rdfs:label "CWE_190" ;
    d3f:cwe-id "CWE-190" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Overflow" ;
    dcterms:title "Integer Overflow or Wraparound" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-190" ;
    skos:definition "The product performs a calculation that can produce an integer overflow or wraparound when the logic assumes that the resulting value will always be larger than the original value. This occurs when an integer value is incremented to a value that is too large to store in the associated representation. When this occurs, the value may become a very small or negative number." ;
    skos:exactMatch d3f:CWE-190,
        cwe:CWE-190 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE201 a owl:Class ;
    rdfs:label "CWE_201" ;
    d3f:cwe-id "CWE-201" ;
    dcterms:title "Insertion of Sensitive Information Into Sent Data" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-201" ;
    skos:definition "The code transmits data to another actor, but a portion of the data includes sensitive information that should not be accessible to that actor." ;
    skos:exactMatch d3f:CWE-201,
        cwe:CWE-201 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE208 a owl:Class ;
    rdfs:label "CWE_208" ;
    d3f:cwe-id "CWE-208" ;
    dcterms:title "Observable Timing Discrepancy" ;
    rdfs:subClassOf d3f:CWE203 ;
    skos:altLabel "CWE-208" ;
    skos:definition "Two separate operations in a product require different amounts of time to complete, in a way that is observable to an actor and reveals security-relevant information about the state of the product, such as whether a particular operation was successful or not." ;
    skos:exactMatch d3f:CWE-208,
        cwe:CWE-208 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE219 a owl:Class ;
    rdfs:label "CWE_219" ;
    d3f:cwe-id "CWE-219" ;
    dcterms:title "Storage of File with Sensitive Data Under Web Root" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-219" ;
    skos:definition "The product stores sensitive data under the web document root with insufficient access control, which might make it accessible to untrusted parties." ;
    skos:exactMatch d3f:CWE-219,
        cwe:CWE-219 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE240 a owl:Class ;
    rdfs:label "CWE_240" ;
    d3f:cwe-id "CWE-240" ;
    dcterms:title "Improper Handling of Inconsistent Structural Elements" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE707 ],
        d3f:CWE237 ;
    skos:altLabel "CWE-240" ;
    skos:definition "The product does not handle or incorrectly handles when two or more structural elements should be consistent, but are not." ;
    skos:exactMatch d3f:CWE-240,
        cwe:CWE-240 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE248 a owl:Class ;
    rdfs:label "CWE_248" ;
    d3f:cwe-id "CWE-248" ;
    dcterms:title "Uncaught Exception" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE705 ],
        d3f:CWE703 ;
    skos:altLabel "CWE-248" ;
    skos:definition "An exception is thrown from a function, but it is not caught." ;
    skos:exactMatch d3f:CWE-248,
        cwe:CWE-248 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE252 a owl:Class ;
    rdfs:label "CWE_252" ;
    d3f:cwe-id "CWE-252" ;
    dcterms:title "Unchecked Return Value" ;
    rdfs:subClassOf d3f:CWE754 ;
    skos:altLabel "CWE-252" ;
    skos:definition "The product does not check the return value from a method or function, which can prevent it from detecting unexpected states and conditions." ;
    skos:exactMatch d3f:CWE-252,
        cwe:CWE-252 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE267 a owl:Class ;
    rdfs:label "CWE_267" ;
    d3f:cwe-id "CWE-267" ;
    dcterms:title "Privilege Defined With Unsafe Actions" ;
    rdfs:subClassOf d3f:CWE269 ;
    skos:altLabel "CWE-267" ;
    skos:definition "A particular privilege, role, capability, or right can be used to perform unsafe actions that were not intended, even when it is assigned to the correct entity." ;
    skos:exactMatch d3f:CWE-267,
        cwe:CWE-267 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE286 a owl:Class ;
    rdfs:label "CWE_286" ;
    d3f:cwe-id "CWE-286" ;
    dcterms:title "Incorrect User Management" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-286" ;
    skos:definition "The product does not properly manage a user within its environment." ;
    skos:exactMatch d3f:CWE-286,
        cwe:CWE-286 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE299 a owl:Class ;
    rdfs:label "CWE_299" ;
    d3f:cwe-id "CWE-299" ;
    dcterms:title "Improper Check for Certificate Revocation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE404 ],
        d3f:CWE295 ;
    skos:altLabel "CWE-299" ;
    skos:definition "The product does not check or incorrectly checks the revocation status of a certificate, which may cause it to use a certificate that has been compromised." ;
    skos:exactMatch d3f:CWE-299,
        cwe:CWE-299 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE303 a owl:Class ;
    rdfs:label "CWE_303" ;
    d3f:cwe-id "CWE-303" ;
    dcterms:title "Incorrect Implementation of Authentication Algorithm" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-303" ;
    skos:definition "The requirements for the product dictate the use of an established authentication algorithm, but the implementation of the algorithm is incorrect." ;
    skos:exactMatch d3f:CWE-303,
        cwe:CWE-303 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE326 a owl:Class ;
    rdfs:label "CWE_326" ;
    d3f:cwe-id "CWE-326" ;
    dcterms:title "Inadequate Encryption Strength" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-326" ;
    skos:definition "The product stores or transmits sensitive data using an encryption scheme that is theoretically sound, but is not strong enough for the level of protection required." ;
    skos:exactMatch d3f:CWE-326,
        cwe:CWE-326 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE328 a owl:Class ;
    rdfs:label "CWE_328" ;
    d3f:cwe-id "CWE-328" ;
    dcterms:title "Use of Weak Hash" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE327 ],
        d3f:CWE326 ;
    skos:altLabel "CWE-328" ;
    skos:definition "The product uses an algorithm that produces a digest (output value) that does not meet security expectations for a hash function that allows an adversary to reasonably determine the original input (preimage attack), find another input that can produce the same hash (2nd preimage attack), or find multiple inputs that evaluate to the same hash (birthday attack)." ;
    skos:exactMatch d3f:CWE-328,
        cwe:CWE-328 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE334 a owl:Class ;
    rdfs:label "CWE_334" ;
    d3f:cwe-id "CWE-334" ;
    dcterms:title "Small Space of Random Values" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-334" ;
    skos:definition "The number of possible random values is smaller than needed by the product, making it more susceptible to brute force attacks." ;
    skos:exactMatch d3f:CWE-334,
        cwe:CWE-334 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE357 a owl:Class ;
    rdfs:label "CWE_357" ;
    d3f:cwe-id "CWE-357" ;
    dcterms:title "Insufficient UI Warning of Dangerous Operations" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-357" ;
    skos:definition "The user interface provides a warning to a user regarding dangerous or sensitive operations, but the warning is not noticeable enough to warrant attention." ;
    skos:exactMatch d3f:CWE-357,
        cwe:CWE-357 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE360 a owl:Class ;
    rdfs:label "CWE_360" ;
    d3f:cwe-id "CWE-360" ;
    dcterms:title "Trust of System Event Data" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-360" ;
    skos:definition "Security based on event locations are insecure and can be spoofed." ;
    skos:exactMatch d3f:CWE-360,
        cwe:CWE-360 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE367 a owl:Class ;
    rdfs:label "CWE_367" ;
    d3f:cwe-id "CWE-367" ;
    d3f:synonym "TOCCTOU" ;
    dcterms:title "Time-of-check Time-of-use (TOCTOU) Race Condition" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-367" ;
    skos:definition "The product checks the state of a resource before using that resource, but the resource's state can change between the check and the use in a way that invalidates the results of the check. This can cause the product to perform invalid actions when the resource is in an unexpected state." ;
    skos:exactMatch d3f:CWE-367,
        cwe:CWE-367 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE407 a owl:Class ;
    rdfs:label "CWE_407" ;
    d3f:cwe-id "CWE-407" ;
    d3f:synonym "Quadratic Complexity" ;
    dcterms:title "Inefficient Algorithmic Complexity" ;
    rdfs:subClassOf d3f:CWE405 ;
    skos:altLabel "CWE-407" ;
    skos:definition "An algorithm in a product has an inefficient worst-case computational complexity that may be detrimental to system performance and can be triggered by an attacker, typically using crafted manipulations that ensure that the worst case is being reached." ;
    skos:exactMatch d3f:CWE-407,
        cwe:CWE-407 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE413 a owl:Class ;
    rdfs:label "CWE_413" ;
    d3f:cwe-id "CWE-413" ;
    dcterms:title "Improper Resource Locking" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-413" ;
    skos:definition "The product does not lock or does not correctly lock a resource when the product must have exclusive access to the resource." ;
    skos:exactMatch d3f:CWE-413,
        cwe:CWE-413 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE42 a owl:Class ;
    rdfs:label "CWE_42" ;
    d3f:cwe-id "CWE-42" ;
    dcterms:title "Path Equivalence: 'filename.' (Trailing Dot)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE162 ;
    skos:altLabel "CWE-42" ;
    skos:definition "The product accepts path input in the form of trailing dot ('filedir.') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-42,
        cwe:CWE-42 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE424 a owl:Class ;
    rdfs:label "CWE_424" ;
    d3f:cwe-id "CWE-424" ;
    dcterms:title "Improper Protection of Alternate Path" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE638 ;
    skos:altLabel "CWE-424" ;
    skos:definition "The product does not sufficiently protect all possible paths that a user can take to access restricted functionality or resources." ;
    skos:exactMatch d3f:CWE-424,
        cwe:CWE-424 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE44 a owl:Class ;
    rdfs:label "CWE_44" ;
    d3f:cwe-id "CWE-44" ;
    dcterms:title "Path Equivalence: 'file.name' (Internal Dot)" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-44" ;
    skos:definition "The product accepts path input in the form of internal dot ('file.ordir') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-44,
        cwe:CWE-44 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE474 a owl:Class ;
    rdfs:label "CWE_474" ;
    d3f:cwe-id "CWE-474" ;
    dcterms:title "Use of Function with Inconsistent Implementations" ;
    rdfs:subClassOf d3f:CWE758 ;
    skos:altLabel "CWE-474" ;
    skos:definition "The code uses a function that has inconsistent implementations across operating systems and versions." ;
    skos:exactMatch d3f:CWE-474,
        cwe:CWE-474 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE476 a owl:Class ;
    rdfs:label "CWE_476" ;
    d3f:cwe-id "CWE-476" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "NPD" ;
    dcterms:title "NULL Pointer Dereference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE754 ],
        d3f:CWE710 ;
    skos:altLabel "CWE-476" ;
    skos:definition "The product dereferences a pointer that it expects to be valid but is NULL." ;
    skos:exactMatch d3f:CWE-476,
        cwe:CWE-476 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE489 a owl:Class ;
    rdfs:label "CWE_489" ;
    d3f:cwe-id "CWE-489" ;
    d3f:synonym "Leftover debug code" ;
    dcterms:title "Active Debug Code" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-489" ;
    skos:definition "The product is deployed to unauthorized actors with debugging code still enabled or active, which can create unintended entry points or expose sensitive information." ;
    skos:exactMatch d3f:CWE-489,
        cwe:CWE-489 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE493 a owl:Class ;
    rdfs:label "CWE_493" ;
    d3f:cwe-id "CWE-493" ;
    dcterms:title "Critical Public Variable Without Final Modifier" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-493" ;
    skos:definition "The product has a critical public variable that is not final, which allows the variable to be modified to contain unexpected values." ;
    skos:exactMatch d3f:CWE-493,
        cwe:CWE-493 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE521 a owl:Class ;
    rdfs:label "CWE_521" ;
    d3f:cwe-id "CWE-521" ;
    dcterms:title "Weak Password Requirements" ;
    rdfs:subClassOf d3f:CWE1391 ;
    skos:altLabel "CWE-521" ;
    skos:definition "The product does not require that users should have strong passwords, which makes it easier for attackers to compromise user accounts." ;
    skos:exactMatch d3f:CWE-521,
        cwe:CWE-521 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE524 a owl:Class ;
    rdfs:label "CWE_524" ;
    d3f:cwe-id "CWE-524" ;
    dcterms:title "Use of Cache Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-524" ;
    skos:definition "The code uses a cache that contains sensitive information, but the cache can be read by an actor outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-524,
        cwe:CWE-524 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE565 a owl:Class ;
    rdfs:label "CWE_565" ;
    d3f:cwe-id "CWE-565" ;
    dcterms:title "Reliance on Cookies without Validation and Integrity Checking" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE642 ],
        d3f:CWE602 ;
    skos:altLabel "CWE-565" ;
    skos:definition "The product relies on the existence or values of cookies when performing security-critical operations, but it does not properly ensure that the setting is valid for the associated user." ;
    skos:exactMatch d3f:CWE-565,
        cwe:CWE-565 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE595 a owl:Class ;
    rdfs:label "CWE_595" ;
    d3f:cwe-id "CWE-595" ;
    dcterms:title "Comparison of Object References Instead of Object Contents" ;
    rdfs:subClassOf d3f:CWE1025 ;
    skos:altLabel "CWE-595" ;
    skos:definition "The product compares object references instead of the contents of the objects themselves, preventing it from detecting equivalent objects." ;
    skos:exactMatch d3f:CWE-595,
        cwe:CWE-595 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE625 a owl:Class ;
    rdfs:label "CWE_625" ;
    d3f:cwe-id "CWE-625" ;
    dcterms:title "Permissive Regular Expression" ;
    rdfs:subClassOf d3f:CWE185 ;
    skos:altLabel "CWE-625" ;
    skos:definition "The product uses a regular expression that does not sufficiently restrict the set of allowed values." ;
    skos:exactMatch d3f:CWE-625,
        cwe:CWE-625 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE636 a owl:Class ;
    rdfs:label "CWE_636" ;
    d3f:cwe-id "CWE-636" ;
    d3f:synonym "Failing Open" ;
    dcterms:title "Not Failing Securely ('Failing Open')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        d3f:CWE657 ;
    skos:altLabel "CWE-636" ;
    skos:definition "When the product encounters an error condition or failure, its design requires it to fall back to a state that is less secure than other options that are available, such as selecting the weakest encryption algorithm or using the most permissive access control restrictions." ;
    skos:exactMatch d3f:CWE-636,
        cwe:CWE-636 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE638 a owl:Class ;
    rdfs:label "CWE_638" ;
    d3f:cwe-id "CWE-638" ;
    dcterms:title "Not Using Complete Mediation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE862 ],
        d3f:CWE657 ;
    skos:altLabel "CWE-638" ;
    skos:definition "The product does not perform access checks on a resource every time the resource is accessed by an entity, which can create resultant weaknesses if that entity's rights or privileges change over time." ;
    skos:exactMatch d3f:CWE-638,
        cwe:CWE-638 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE639 a owl:Class ;
    rdfs:label "CWE_639" ;
    d3f:cwe-id "CWE-639" ;
    d3f:synonym "Broken Object Level Authorization / BOLA" ;
    dcterms:title "Authorization Bypass Through User-Controlled Key" ;
    rdfs:subClassOf d3f:CWE863 ;
    skos:altLabel "CWE-639" ;
    skos:definition "The system's authorization functionality does not prevent one user from gaining access to another user's data or record by modifying the key value identifying the data." ;
    skos:exactMatch d3f:CWE-639,
        cwe:CWE-639 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE673 a owl:Class ;
    rdfs:label "CWE_673" ;
    d3f:cwe-id "CWE-673" ;
    dcterms:title "External Influence of Sphere Definition" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-673" ;
    skos:definition "The product does not prevent the definition of control spheres from external actors." ;
    skos:exactMatch d3f:CWE-673,
        cwe:CWE-673 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE674 a owl:Class ;
    rdfs:label "CWE_674" ;
    d3f:cwe-id "CWE-674" ;
    d3f:synonym "Stack Exhaustion" ;
    dcterms:title "Uncontrolled Recursion" ;
    rdfs:subClassOf d3f:CWE834 ;
    skos:altLabel "CWE-674" ;
    skos:definition "The product does not properly control the amount of recursion that takes place, consuming excessive resources, such as allocated memory or the program stack." ;
    skos:exactMatch d3f:CWE-674,
        cwe:CWE-674 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE676 a owl:Class ;
    rdfs:label "CWE_676" ;
    d3f:cwe-id "CWE-676" ;
    dcterms:title "Use of Potentially Dangerous Function" ;
    rdfs:subClassOf d3f:CWE1177 ;
    skos:altLabel "CWE-676" ;
    skos:definition "The product invokes a potentially dangerous function that could introduce a vulnerability if it is used incorrectly, but the function can also be used safely." ;
    skos:exactMatch d3f:CWE-676,
        cwe:CWE-676 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE687 a owl:Class ;
    rdfs:label "CWE_687" ;
    d3f:cwe-id "CWE-687" ;
    dcterms:title "Function Call With Incorrectly Specified Argument Value" ;
    rdfs:subClassOf d3f:CWE628 ;
    skos:altLabel "CWE-687" ;
    skos:definition "The product calls a function, procedure, or routine, but the caller specifies an argument that contains the wrong value, which may lead to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-687,
        cwe:CWE-687 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE73 a owl:Class ;
    rdfs:label "CWE_73" ;
    d3f:cwe-id "CWE-73" ;
    dcterms:title "External Control of File Name or Path" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE642 ],
        d3f:CWE610 ;
    skos:altLabel "CWE-73" ;
    skos:definition "The product allows user input to control or influence paths or file names that are used in filesystem operations." ;
    skos:exactMatch d3f:CWE-73,
        cwe:CWE-73 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE733 a owl:Class ;
    rdfs:label "CWE_733" ;
    d3f:cwe-id "CWE-733" ;
    dcterms:title "Compiler Optimization Removal or Modification of Security-critical Code" ;
    rdfs:subClassOf d3f:CWE1038 ;
    skos:altLabel "CWE-733" ;
    skos:definition "The developer builds a security-critical protection mechanism into the software, but the compiler optimizes the program such that the mechanism is removed or modified." ;
    skos:exactMatch d3f:CWE-733,
        cwe:CWE-733 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE75 a owl:Class ;
    rdfs:label "CWE_75" ;
    d3f:cwe-id "CWE-75" ;
    dcterms:title "Failure to Sanitize Special Elements into a Different Plane (Special Element Injection)" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-75" ;
    skos:definition "The product does not adequately filter user-controlled input for special elements with control implications." ;
    skos:exactMatch d3f:CWE-75,
        cwe:CWE-75 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE762 a owl:Class ;
    rdfs:label "CWE_762" ;
    d3f:cwe-id "CWE-762" ;
    dcterms:title "Mismatched Memory Management Routines" ;
    rdfs:subClassOf d3f:CWE763 ;
    skos:altLabel "CWE-762" ;
    skos:definition "The product attempts to return a memory resource to the system, but it calls a release function that is not compatible with the function that was originally used to allocate that resource." ;
    skos:exactMatch d3f:CWE-762,
        cwe:CWE-762 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE771 a owl:Class ;
    rdfs:label "CWE_771" ;
    d3f:cwe-id "CWE-771" ;
    dcterms:title "Missing Reference to Active Allocated Resource" ;
    rdfs:subClassOf d3f:CWE400 ;
    skos:altLabel "CWE-771" ;
    skos:definition "The product does not properly maintain a reference to a resource that has been allocated, which prevents the resource from being reclaimed." ;
    skos:exactMatch d3f:CWE-771,
        cwe:CWE-771 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE790 a owl:Class ;
    rdfs:label "CWE_790" ;
    d3f:cwe-id "CWE-790" ;
    dcterms:title "Improper Filtering of Special Elements" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-790" ;
    skos:definition "The product receives data from an upstream component, but does not filter or incorrectly filters special elements before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-790,
        cwe:CWE-790 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE805 a owl:Class ;
    rdfs:label "CWE_805" ;
    d3f:cwe-id "CWE-805" ;
    dcterms:title "Buffer Access with Incorrect Length Value" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-805" ;
    skos:definition "The product uses a sequential operation to read or write a buffer, but it uses an incorrect length value that causes it to access memory that is outside of the bounds of the buffer." ;
    skos:exactMatch d3f:CWE-805,
        cwe:CWE-805 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE828 a owl:Class ;
    rdfs:label "CWE_828" ;
    d3f:cwe-id "CWE-828" ;
    dcterms:title "Signal Handler with Functionality that is not Asynchronous-Safe" ;
    rdfs:subClassOf d3f:CWE364 ;
    skos:altLabel "CWE-828" ;
    skos:definition "The product defines a signal handler that contains code sequences that are not asynchronous-safe, i.e., the functionality is not reentrant, or it can be interrupted." ;
    skos:exactMatch d3f:CWE-828,
        cwe:CWE-828 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE83 a owl:Class ;
    rdfs:label "CWE_83" ;
    d3f:cwe-id "CWE-83" ;
    dcterms:title "Improper Neutralization of Script in Attributes in a Web Page" ;
    rdfs:subClassOf d3f:CWE79 ;
    skos:altLabel "CWE-83" ;
    skos:definition "The product does not neutralize or incorrectly neutralizes \"javascript:\" or other URIs from dangerous attributes within tags, such as onmouseover, onload, onerror, or style." ;
    skos:exactMatch d3f:CWE-83,
        cwe:CWE-83 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE89 a owl:Class ;
    rdfs:label "CWE_89" ;
    d3f:cwe-id "CWE-89" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "SQL injection" ;
    dcterms:title "Improper Neutralization of Special Elements used in an SQL Command ('SQL Injection')" ;
    rdfs:subClassOf d3f:CWE943 ;
    skos:altLabel "CWE-89" ;
    skos:definition "The product constructs all or part of an SQL command using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended SQL command when it is sent to a downstream component. Without sufficient removal or quoting of SQL syntax in user-controllable inputs, the generated SQL query can cause those inputs to be interpreted as SQL instead of ordinary user data." ;
    skos:exactMatch d3f:CWE-89,
        cwe:CWE-89 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE908 a owl:Class ;
    rdfs:label "CWE_908" ;
    d3f:cwe-id "CWE-908" ;
    dcterms:title "Use of Uninitialized Resource" ;
    rdfs:subClassOf d3f:CWE665 ;
    skos:altLabel "CWE-908" ;
    skos:definition "The product uses or accesses a resource that has not been initialized." ;
    skos:exactMatch d3f:CWE-908,
        cwe:CWE-908 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE915 a owl:Class ;
    rdfs:label "CWE_915" ;
    d3f:cwe-id "CWE-915" ;
    d3f:synonym "AutoBinding" ;
    dcterms:title "Improperly Controlled Modification of Dynamically-Determined Object Attributes" ;
    rdfs:subClassOf d3f:CWE913 ;
    skos:altLabel "CWE-915" ;
    skos:definition "The product receives input from an upstream component that specifies multiple attributes, properties, or fields that are to be initialized or updated in an object, but it does not properly control which attributes can be modified." ;
    skos:exactMatch d3f:CWE-915,
        cwe:CWE-915 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE93 a owl:Class ;
    rdfs:label "CWE_93" ;
    d3f:cwe-id "CWE-93" ;
    dcterms:title "Improper Neutralization of CRLF Sequences ('CRLF Injection')" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-93" ;
    skos:definition "The product uses CRLF (carriage return line feeds) as a special element, e.g. to separate lines or records, but it does not neutralize or incorrectly neutralizes CRLF sequences from inputs." ;
    skos:exactMatch d3f:CWE-93,
        cwe:CWE-93 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE940 a owl:Class ;
    rdfs:label "CWE_940" ;
    d3f:cwe-id "CWE-940" ;
    dcterms:title "Improper Verification of Source of a Communication Channel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE923 ],
        d3f:CWE346 ;
    skos:altLabel "CWE-940" ;
    skos:definition "The product establishes a communication channel to handle an incoming request that has been initiated by an actor, but it does not properly verify that the request is coming from the expected origin." ;
    skos:exactMatch d3f:CWE-940,
        cwe:CWE-940 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE96 a owl:Class ;
    rdfs:label "CWE_96" ;
    d3f:cwe-id "CWE-96" ;
    dcterms:title "Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')" ;
    rdfs:subClassOf d3f:CWE94 ;
    skos:altLabel "CWE-96" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes code syntax before inserting the input into an executable resource, such as a library, configuration file, or template." ;
    skos:exactMatch d3f:CWE-96,
        cwe:CWE-96 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CacheMemory a owl:Class ;
    rdfs:label "CacheMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Processor Cache Memory" ;
    rdfs:seeAlso <https://dbpedia.org/page/CPU_cache>,
        <https://whatis.techtarget.com/definition/memory> ;
    rdfs:subClassOf d3f:PrimaryStorage ;
    skos:definition "Cache memory is temporary storage that is more readily available to the processor than the computer's main memory source, located between the main memory and the processor.  It is typically either integrated directly into the CPU chip (level 1 cache) or placed on a separate chip with a bus interconnect with the CPU (level 2 cache)." ;
    skos:exactMatch d3f:CacheMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CallStack a owl:Class ;
    rdfs:label "CallStack" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Call Stack" ;
    rdfs:seeAlso dbr:Call_stack ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In computer science, a call stack is a stack data structure that stores information about the active subroutines of a computer program. This kind of stack is also known as an execution stack, program stack, control stack, run-time stack, or machine stack, and is often shortened to just \"the stack\". Although maintenance of the call stack is important for the proper functioning of most software, the details are normally hidden and automatic in high-level programming languages. Many computer instruction sets provide special instructions for manipulating stacks." ;
    skos:exactMatch d3f:CallStack ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CanopyClustering a owl:Class ;
    rdfs:label "CanopyClustering" ;
    d3f:d3fend-id "D3A-CC" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Canopy clustering algorithm. [Link](https://en.wikipedia.org/wiki/Canopy_clustering_algorithm)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Canopy Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:definition "The canopy clustering algorithm is an unsupervised pre-clustering algorithm  often used as preprocessing step for the K-means algorithm or the Hierarchical clustering algorithm. It is intended to speed up clustering operations on large data sets." ;
    skos:exactMatch d3f:CanopyClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Capability a owl:Class ;
    rdfs:label "Capability" ;
    rdfs:seeAlso dbr:Capability_\(systems_engineering\),
        <https://web.archive.org/web/20081123014953/http://www.dtic.mil/doctrine/jel/new_pubs/jp1_02.pdf> ;
    rdfs:subClassOf d3f:ExternalThing ;
    skos:exactMatch d3f:Capability,
        oscal:Capability ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CentralProcessingUnit a owl:Class ;
    rdfs:label "CentralProcessingUnit" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "CPU" ;
    dcterms:title "Central Processing Unit" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Central_processing_unit> ;
    rdfs:subClassOf d3f:Processor ;
    skos:definition "A central processing unit (CPU), also called a central processor, main processor or just processor, is the electronic circuitry that executes instructions comprising a computer program. The CPU performs basic arithmetic, logic, controlling, and input/output (I/O) operations specified by the instructions in the program. This contrasts with external components such as main memory and I/O circuitry, and specialized processors such as graphics" ;
    skos:exactMatch d3f:CentralProcessingUnit ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CentroidBasedClustering a owl:Class ;
    rdfs:label "Centroid_basedClustering" ;
    d3f:d3fend-id "D3A-CBC" ;
    d3f:kb-article "## References Google Developers. (n.d.). Clustering Algorithms. [Link](https://developers.google.com/machine-learning/clustering/clustering-algorithms)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Centroid-based Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:altLabel "Centroid-basedClustering" ;
    skos:definition "Centroid-based clustering organizes the data into non-hierarchical clusters, in contrast to hierarchical clustering defined below. K-means is the most widely-used centroid-based clustering algorithm. Centroid-based algorithms are efficient but sensitive to initial conditions and outliers." ;
    skos:exactMatch d3f:Centroid-basedClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Certificate a owl:Class ;
    rdfs:label "Certificate" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Public_key_certificate,
        <https://schema.ocsf.io/objects/certificate> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Public Key Certificate" ;
    skos:closeMatch stix:X509Certificate,
        unified_cyber_ontology:X509Certificate ;
    skos:definition "In cryptography, a public key certificate, also known as a digital certificate or identity certificate, is an electronic document used to prove the ownership of a public key. The certificate includes information about the key, information about the identity of its owner (called the subject), and the digital signature of an entity that has verified the certificate's contents (called the issuer). If the signature is valid, and the software examining the certificate trusts the issuer, then it can use that key to communicate securely with the certificate's subject. In email encryption, code signing, and e-signature systems, a certificate's subject is typically a person or organization. However, in Transport Layer Security (TLS) a certificate's subject is typically a computer or other device." ;
    skos:exactMatch d3f:Certificate ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CertificatePinning a owl:Class ;
    rdfs:label "CertificatePinning" ;
    d3f:d3fend-id "D3-CP" ;
    d3f:kb-article "## How it works Pinning allows for a trusted copy of a certificate or public key to be associated with a server and thus reducing the likelihood of frequently visited sites being subjected to man-in-the-middle attacks. Certificates or public keys can be pinned after a trusted connection has been est" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Certificate Pinning" ;
    rdfs:subClassOf d3f:CredentialHardening ;
    skos:definition "Persisting either a server's X.509 certificate or their public key and comparing that to server's presented identity to allow for greater client confidence in the remote server's identity for SSL connections." ;
    skos:exactMatch d3f:CertificatePinning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CertificateRotation a owl:Class ;
    rdfs:label "CertificateRotation" ;
    d3f:d3fend-id "D3-CERO" ;
    d3f:kb-article "## How it works Certificate rotation should be performed when: - Any certificate expires. - A new CA authority is substituted for the old, thus requiring a replacement root certificate. - New or modified constraints need to be imposed on one or more certificates. - A security breach has occurred." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Certificate Rotation" ;
    rdfs:seeAlso <https://docs.couchbase.com/server/7.0/manage/manage-security/rotate-server-certificates.html> ;
    rdfs:subClassOf d3f:CredentialRotation ;
    skos:definition "Certificate rotation involves replacing digital certificates and their private keys to maintain cryptographic integrity and trust, mitigating key compromise risks and ensuring continuous secure communications." ;
    skos:exactMatch d3f:CertificateRotation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CertificateTrustStore a owl:Class ;
    rdfs:label "CertificateTrustStore" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Certificate Trust Store" ;
    rdfs:seeAlso dbr:Public_key_certificate,
        <https://www.educative.io/edpresso/keystore-vs-truststore> ;
    rdfs:subClassOf d3f:TrustStore ;
    skos:definition "A certificate truststore is used to store public certificates used to authenticate clients by the server for an SSL connection." ;
    skos:exactMatch d3f:CertificateTrustStore ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ChangeDefaultPassword a owl:Class ;
    rdfs:label "ChangeDefaultPassword" ;
    d3f:d3fend-id "D3-CDP" ;
    d3f:kb-article "## How it works Change the default password as soon as a new device is received. The default credentials are normally documented in an instruction manual that is either packaged with the device, published online through official means, or published online through unofficial means. ## Considerations" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Change Default Password" ;
    rdfs:subClassOf d3f:StrongPasswordPolicy ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:ImpactTechnique,
        d3f:InitialAccessTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1078,
        d3f:T1087,
        d3f:T1098,
        d3f:T1110,
        d3f:T1136 ;
    skos:definition "Changing the default password means replacing the factory-set credentials with a strong, unique password before the device is deployed, preventing unauthorized access." ;
    skos:exactMatch d3f:ChangeDefaultPassword ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1078,
        mitre-attack:T1078.001,
        mitre-attack:T1078.002,
        mitre-attack:T1078.003,
        mitre-attack:T1078.004,
        mitre-attack:T1087.001,
        mitre-attack:T1087.002,
        mitre-attack:T1087.004,
        mitre-attack:T1098,
        mitre-attack:T1098.002,
        mitre-attack:T1098.003,
        mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003,
        mitre-attack:T1136,
        mitre-attack:T1136.001,
        mitre-attack:T1136.002,
        mitre-attack:T1136.003,
        mitre-attack:T1531 .

d3f:ChatroomClient a owl:Class ;
    rdfs:label "ChatroomClient" ;
    dcterms:title "Chatroom Client" ;
    rdfs:seeAlso dbr:Chat_room ;
    rdfs:subClassOf d3f:CollaborativeSoftware ;
    skos:altLabel "Chat Room Client" ;
    skos:definition "Client software used to describe conduct any form of synchronous conferencing, occasionally even asynchronous conferencing. The term can thus mean any technology ranging from real-time online chat and online interaction with strangers (e.g., online forums) to fully immersive graphical social environments." ;
    skos:exactMatch d3f:ChatroomClient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ChildProcess a owl:Class ;
    rdfs:label "ChildProcess" ;
    dcterms:title "Child Process" ;
    rdfs:seeAlso dbr:Child_process,
        dbr:Parent_process ;
    rdfs:subClassOf d3f:Process ;
    skos:definition "A child process in computing is a process created by another process (the parent process). This technique pertains to multitasking operating systems, and is sometimes called a subprocess or traditionally a subtask. There are two major procedures for creating a child process: the fork system call (preferred in Unix-like systems and the POSIX standard) and the spawn (preferred in the modern (NT) kernel of Microsoft Windows, as well as in some historical operating systems)." ;
    skos:exactMatch d3f:ChildProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ClientApplication a owl:Class ;
    rdfs:label "ClientApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Client Application" ;
    rdfs:seeAlso d3f:T1554,
        dbr:Client_\(computing\) ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "A client application is software that accesses a service made available by a server. The server is often (but not always) on another computer system, in which case the client accesses the service by way of a network. The term applies to the role that programs or devices play in the client-server model" ;
    skos:exactMatch d3f:ClientApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Clipboard a owl:Class ;
    rdfs:label "Clipboard" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Clipboard_\(computing\) ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "The clipboard is a buffer that some operating systems provide for short-term storage and transfer within and between application programs. The clipboard is usually temporary and unnamed, and its contents reside in the computer's RAM. The clipboard is sometimes called the paste buffer. Windows, Linux and macOS support a single clipboard transaction. Each cut or copy overwrites the previous contents. Normally, paste operations copy the contents, leaving the contents available in the clipboard for further pasting." ;
    skos:exactMatch d3f:Clipboard ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ClockSynchronizationEvent a owl:Class ;
    rdfs:label "ClockSynchronizationEvent" ;
    dcterms:title "Clock Synchronization Event" ;
    rdfs:subClassOf d3f:SoftwareClockEvent ;
    skos:definition "An event in which a software clock adjusts its value based on an external time reference (e.g., NTP server, GPS time signal)." ;
    skos:exactMatch d3f:ClockSynchronizationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudConfigurationModificationEvent a owl:Class ;
    rdfs:label "CloudConfigurationModificationEvent" ;
    dcterms:title "Cloud Configuration Modification Event" ;
    rdfs:subClassOf d3f:ConfigurationModificationEvent ;
    skos:definition "An event that updates cloud-hosted resource configurations such as IAM policies, virtual network constructs, storage settings, or managed-service parameters; impacting resource provisioning, access control, functionality, or compliance." ;
    skos:exactMatch d3f:CloudConfigurationModificationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudInstanceMetadata a owl:Class ;
    rdfs:label "CloudInstanceMetadata" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Instance Metadata" ;
    rdfs:seeAlso <https://isc.sans.edu/forums/diary/Cloud+Metadata+Urls/22046> ;
    rdfs:subClassOf d3f:CloudConfiguration ;
    skos:definition "Cloud instance metadata is configuration information on the instance and users of the instance.  This includes such information as security groups, public ip addresses, and private addresses, public keys configured, and event rotating security keys. User data can contain initialization scripts, variables, passwords, and more." ;
    skos:exactMatch d3f:CloudInstanceMetadata ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudServiceAuthentication a owl:Class ;
    rdfs:label "CloudServiceAuthentication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Service Authentication" ;
    rdfs:subClassOf d3f:WebAuthentication ;
    skos:definition "A request-response comprising a user credential presentation to a system and a verification response where the verifying party is a cloud service." ;
    skos:exactMatch d3f:CloudServiceAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudServiceAuthorization a owl:Class ;
    rdfs:label "CloudServiceAuthorization" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Service Authorization" ;
    rdfs:subClassOf d3f:Authorization ;
    skos:definition "Cloud authorization is the function of specifying access rights to cloud resources." ;
    skos:exactMatch d3f:CloudServiceAuthorization ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudServiceProvider a owl:Class ;
    rdfs:label "CloudServiceProvider" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Service Provider" ;
    rdfs:subClassOf d3f:ServiceProvider ;
    skos:definition "A cloud service provider delivers scalable and distributed computing resources over a network, enabling clients to access infrastructure, platforms, and applications remotely." ;
    skos:exactMatch d3f:CloudServiceProvider ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudServiceSensor a owl:Class ;
    rdfs:label "CloudServiceSensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Service Sensor" ;
    rdfs:subClassOf d3f:CyberSensor ;
    skos:definition "Senses data from cloud service platforms. Including data from cloud service  authentications, authorizations, and other activities." ;
    skos:exactMatch d3f:CloudServiceSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudStorage a owl:Class ;
    rdfs:label "CloudStorage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Storage" ;
    rdfs:seeAlso dbr:Cloud_computing,
        dbr:Cloud_storage,
        <https://schema.ocsf.io/objects/databucket> ;
    rdfs:subClassOf d3f:SecondaryStorage ;
    skos:definition "Cloud storage is storage held within a computing cloud." ;
    skos:exactMatch d3f:CloudStorage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CloudUserAccount a owl:Class ;
    rdfs:label "CloudUserAccount" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud User Account" ;
    rdfs:subClassOf d3f:UserAccount ;
    skos:definition "A user account on a given host is a local user account for a given cloud and specified resources within that cloud." ;
    skos:exactMatch d3f:CloudUserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Clustering a owl:Class ;
    rdfs:label "Clustering" ;
    rdfs:subClassOf d3f:Summarizing ;
    skos:exactMatch d3f:Clustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CodeRepository a owl:Class ;
    rdfs:label "CodeRepository" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Code Repository" ;
    rdfs:seeAlso dbr:Repository_\(version_control\) ;
    rdfs:subClassOf d3f:Database ;
    skos:altLabel "Repository",
        "Version Control Repository" ;
    skos:definition "A code repository is a form of database where code, typically source code, is stored and managed.  In revision control systems, a repository is a data structure that stores metadata for a set of files or directory structure. Depending on whether the version control system in use is distributed like (Git or Mercurial) or centralized like (Subversion, CVS, or Perforce), the whole set of information in the repository may be duplicated on every user's system or may be maintained on a single server." ;
    skos:exactMatch d3f:CodeRepository ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CodecLibrary a owl:Class ;
    rdfs:label "CodecLibrary" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Codec Library" ;
    rdfs:subClassOf d3f:SoftwareLibrary ;
    skos:definition "A software component that encodes or decodes a data stream of signal." ;
    skos:exactMatch d3f:CodecLibrary ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CoefficientOfVariation a owl:Class ;
    rdfs:label "CoefficientOfVariation" ;
    d3f:d3fend-id "D3A-COV" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Coefficient of variation. [Link](https://en.wikipedia.org/wiki/Coefficient_of_variation)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "RSD" ;
    dcterms:title "Coefficient of Variation" ;
    rdfs:subClassOf d3f:Variability ;
    skos:definition """The coefficient of variation (CV), also known as relative standard deviation (RSD), is a standardized measure of dispersion of a probability distribution or frequency distribution.

The coefficient of variation (CV) is defined as the ratio of the standard deviation to the mean .""" ;
    skos:exactMatch d3f:CoefficientOfVariation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CommandHistoryLog a owl:Class ;
    rdfs:label "CommandHistoryLog" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Command History Log" ;
    rdfs:seeAlso d3f:CommandLineInterface,
        dbr:Command_history ;
    rdfs:subClassOf d3f:EventLog ;
    skos:definition "A log of commands run in an operating system shell." ;
    skos:exactMatch d3f:CommandHistoryLog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CommandHistoryLogFile a owl:Class ;
    rdfs:label "CommandHistoryLogFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Command History Log File" ;
    rdfs:seeAlso dbr:Command_history ;
    rdfs:subClassOf d3f:LogFile ;
    skos:definition "A command history log file is a file containing a command history, which the history of commands run in an operating system shell." ;
    skos:exactMatch d3f:CommandHistoryLogFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Compiler a owl:Class ;
    rdfs:label "Compiler" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Compiler ;
    rdfs:subClassOf d3f:BuildTool ;
    skos:definition "In computing, a compiler is a computer program that translates computer code written in one programming language (the source language) into another language (the target language). The name \"compiler\" is primarily used for programs that translate source code from a high-level programming language to a lower level language (e.g., assembly language, object code, or machine code) to create an executable program." ;
    skos:exactMatch d3f:Compiler ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CompilerConfigurationFile a owl:Class ;
    rdfs:label "CompilerConfigurationFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compiler Configuration File" ;
    rdfs:subClassOf d3f:ApplicationConfigurationFile ;
    skos:definition "A file containing Information used to configure the parameters and initial settings for a compiler." ;
    skos:exactMatch d3f:CompilerConfigurationFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputeDeviceEvent a owl:Class ;
    rdfs:label "ComputeDeviceEvent" ;
    dcterms:title "Compute Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event capturing the operation, state, or performance of computational hardware, such as CPUs, GPUs, or accelerators. These events reflect processing capacity changes, utilization anomalies, or device health." ;
    skos:exactMatch d3f:ComputeDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputerCabinet a owl:Class ;
    rdfs:label "ComputerCabinet" ;
    dcterms:title "Computer Cabinet" ;
    rdfs:subClassOf d3f:ComputerEnclosure ;
    skos:definition "A computer cabinet houses one or more computers and can range in size and material." ;
    skos:exactMatch d3f:ComputerCabinet ;
