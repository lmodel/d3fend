    rdfs:label "PerHostDownload_UploadRatioAnalysis" ;
    d3f:d3fend-id "D3-PHDURA" ;
    d3f:kb-article "## How it works Aggregate pull vs. push ratios from metadata are used to develop a baseline for a given host over a specific time period, e.g., over a three-hour period, one day, one week, etc. Anomalies identified over a threshold produce an alert. ## Considerations Collection and analysis of larg" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Per Host Download-Upload Ratio Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:altLabel "PerHostDownload-UploadRatioAnalysis" ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
