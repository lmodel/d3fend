d3f:ElectronicCombinationLock a owl:Class ;
    rdfs:label "ElectronicCombinationLock" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Electronic Combination Lock" ;
    rdfs:seeAlso dbr:Electronic_lock ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:HardwareDevice ],
        d3f:CombinationLock ;
    skos:definition "A system comprised of an automatic door closer on the door, an input device, a controlling device, and a lock, usually mechanical, which is released or activated when the correct combination is entered or correct token is presented." ;
    skos:exactMatch d3f:ElectronicCombinationLock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ElectronicCombinationLockEvent a owl:Class ;
    rdfs:label "ElectronicCombinationLockEvent" ;
    dcterms:title "Electronic Combination Lock Event" ;
    rdfs:subClassOf d3f:PhysicalAccessAlarmEvent ;
    skos:exactMatch d3f:ElectronicCombinationLockEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "An event occuring when combination lock's bolt changes position." .

d3f:ElectronicLockMonitoring a owl:Class ;
    rdfs:label "ElectronicLockMonitoring" ;
    d3f:d3fend-id "D3-ELM" ;
    d3f:kb-article "## How it works Electronic lock monitoring collects status and events from door controllers, readers (badge/PIV, keypad), and door hardware (door position switch, request-to-exit, bolt/latch, tamper). The physical access control system (PACS) logs access decisions, correlates door-held/forced condi" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Door Lock Monitoring" ;
    dcterms:title "Electronic Lock Monitoring" ;
    rdfs:subClassOf d3f:PhysicalAccessMonitoring ;
    skos:definition "Monitoring electronic lock and door hardware states and access events (e.g., locked/unlocked, access granted/denied, door forced/held, tamper) to detect and respond to unauthorized entry." ;
    skos:exactMatch d3f:ElectronicLockMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Email a owl:Class ;
    rdfs:label "Email" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Email,
        <https://schema.ocsf.io/objects/email> ;
    rdfs:subClassOf d3f:DocumentFile ;
    skos:closeMatch stix:EmailMessage,
        unified_cyber_ontology:EmailMessage ;
    skos:definition "An email, or email message, is a document that is sent between computer users across computer networks." ;
    skos:exactMatch d3f:Email ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmailAttachment a owl:Class ;
    rdfs:label "EmailAttachment" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Email Attachment" ;
    rdfs:seeAlso dbr:Email_attachment ;
    rdfs:subClassOf d3f:DocumentFile ;
    skos:definition "An email attachment is a computer file sent along with an email message. One or more files can be attached to any email message, and be sent along with it to the recipient. This is typically used as a simple method to share documents and images." ;
    skos:exactMatch d3f:EmailAttachment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmailFiltering a owl:Class ;
    rdfs:label "EmailFiltering" ;
    d3f:d3fend-id "D3-EF" ;
    d3f:kb-article "## How it works Mail filters can be implemented to scan inbound email messages at the initial SMTP connection stage to detect and reject email containing spam and malware. This technique is distinct from d3f:EmailDeletion because it prevents an email from reaching an user's inbox. This technique c" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Email Filtering" ;
    rdfs:subClassOf d3f:InboundTrafficFiltering ;
    skos:broadMatch d3f:LateralMovementTechnique,
        d3f:T1114,
        d3f:T1566 ;
    skos:definition "Filtering incoming email traffic based on specific criteria." ;
    skos:exactMatch d3f:EmailFiltering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.001,
        mitre-attack:T1534,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002 .

d3f:EmailReceiveEvent a owl:Class ;
    rdfs:label "EmailReceiveEvent" ;
    dcterms:title "Email Receive Event" ;
    rdfs:subClassOf d3f:EmailEvent ;
    skos:definition "An event where an email is delivered to a recipient's mail server or mailbox. This includes receiving messages from internal or external sources via protocols such as IMAP, POP3, or their secure variants." ;
    skos:exactMatch d3f:EmailReceiveEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmailRemoval a owl:Class ;
    rdfs:label "EmailRemoval" ;
    d3f:d3fend-id "D3-ER" ;
    d3f:kb-article "## How it works Email removal is a technique that can be used to prevent a user from executing malware or responding to phishing attempts. Security software or users themselves may detect malicious or suspicious email in a local or remote mail folder email and then employ this technique. ## Consid" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Email Deletion" ;
    dcterms:title "Email Removal" ;
    rdfs:subClassOf d3f:FileEviction ;
    skos:broadMatch d3f:LateralMovementTechnique,
        d3f:T1114,
        d3f:T1505,
        d3f:T1566 ;
    skos:definition "The email removal technique deletes email files from system storage." ;
    skos:exactMatch d3f:EmailRemoval ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.001,
        mitre-attack:T1114.002,
        mitre-attack:T1505.002,
        mitre-attack:T1534,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002 .

d3f:EmailRule a owl:Class ;
    rdfs:label "EmailRule" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Email Rule" ;
    rdfs:subClassOf d3f:ApplicationRule ;
    skos:definition "A configuration of an email application which is used to apply logical or data processing functions to data processed by the email  application." ;
    skos:exactMatch d3f:EmailRule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmailScanEvent a owl:Class ;
    rdfs:label "EmailScanEvent" ;
    dcterms:title "Email Scan Event" ;
    rdfs:subClassOf d3f:EmailEvent ;
    skos:definition "An event where an email is inspected or analyzed for content, security, or compliance purposes. Scanning often involves identifying spam, detecting malware, or ensuring policy adherence before delivery or after reception." ;
    skos:exactMatch d3f:EmailScanEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmailSendEvent a owl:Class ;
    rdfs:label "EmailSendEvent" ;
    dcterms:title "Email Send Event" ;
    rdfs:subClassOf d3f:EmailEvent ;
    skos:definition "An event where an email is transmitted from a client to a recipient via a mail server. This process often involves protocols such as SMTP or its secure variants, with potential authentication and encryption for secure delivery." ;
    skos:exactMatch d3f:EmailSendEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmbeddedDatabaseApplication a owl:Class ;
    rdfs:label "EmbeddedDatabaseApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Embedded Database Application" ;
    rdfs:subClassOf d3f:DatabaseApplication ;
    skos:definition "A software application that integrates a database management system (DBMS) directly within its own structure, rather than relying on a separate, standalone database server. Examples include SQLite and Berkeley DB." ;
    skos:exactMatch d3f:EmbeddedDatabaseApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EmulatedFileAnalysis a owl:Class ;
    rdfs:label "EmulatedFileAnalysis" ;
    d3f:d3fend-id "D3-EFA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Emulated File Analysis" ;
