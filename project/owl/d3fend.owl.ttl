    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Trace Process" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that enables a program to monitor, control, or interact with the execution of a process." ;
    skos:exactMatch d3f:OSAPITraceProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

