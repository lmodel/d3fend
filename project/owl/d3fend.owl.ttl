    d3f:owl_named_individual "true" ;
    d3f:synonym "Multiple Linear Regression" ;
    dcterms:title "Multiple Regression" ;
    rdfs:subClassOf d3f:RegressionAnalysis ;
    skos:definition "Multiple (linear) regression attempts to model the relationship between two or more explanatory variables and a response variable by fitting a linear equation to observed data." ;
