d3f:T1137 a owl:Class ;
    rdfs:label "T1137" ;
    d3f:attack-id "T1137" ;
    dcterms:title "Office Application Startup" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may leverage Microsoft Office-based applications for persistence between startups. Microsoft Office is a fairly common application suite on Windows-based operating systems within an enterprise network. There are multiple mechanisms that can be used with Office for persistence when an Office-based application is started; this can include the use of Office Template Macros and add-ins." ;
    skos:exactMatch d3f:T1137,
        mitre-attack:T1137 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileDefenseEvasionTechnique a owl:Class ;
    rdfs:label "ATTACKMobileDefenseEvasionTechnique" ;
    dcterms:title "Defense Evasion Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPISystemFunction a owl:Class ;
    rdfs:label "OSAPISystemFunction" ;
    d3f:synonym "Indirect System Call" ;
    dcterms:title "OS API System Function" ;
    rdfs:subClassOf d3f:OSAPIFunction ;
    skos:definition "Indirect System calls are made through an OS-specific library (like glibc in Linux) that provides a higher-level API for the system calls." ;
    skos:exactMatch d3f:OSAPISystemFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036 a owl:Class ;
    rdfs:label "T1036" ;
    d3f:attack-id "T1036" ;
    dcterms:title "Masquerading" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to manipulate features of their artifacts to make them appear legitimate or benign to users and/or security tools. Masquerading occurs when the name or location of an object, legitimate or malicious, is manipulated or abused for the sake of evading defenses and observation. This may include manipulating file metadata, tricking users into misidentifying the file type, and giving legitimate task or service names." ;
    skos:exactMatch d3f:T1036,
        mitre-attack:T1036 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1053 a owl:Class ;
    rdfs:label "T1053" ;
    d3f:attack-id "T1053" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Scheduled Task/Job" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "The sub-techniques of this are specific software implementations of scheduling capabilities." ;
    skos:exactMatch d3f:T1053,
        mitre-attack:T1053 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1110 a owl:Class ;
    rdfs:label "T1110" ;
    d3f:attack-id "T1110" ;
    dcterms:title "Brute Force" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may use brute force techniques to gain access to accounts when passwords are unknown or when password hashes are obtained.(Citation: TrendMicro Pawn Storm Dec 2020) Without knowledge of the password for an account or set of accounts, an adversary may systematically guess the password using a repetitive or iterative mechanism.(Citation: Dragos Crashoverride 2018) Brute forcing passwords can take place via interaction with a service that will check the validity of those credentials or offline against previously acquired credential data, such as password hashes." ;
    skos:exactMatch d3f:T1110,
        mitre-attack:T1110 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027 a owl:Class ;
    rdfs:label "T1027" ;
    d3f:attack-id "T1027" ;
    dcterms:title "Obfuscated Files or Information" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to make an executable or file difficult to discover or analyze by encrypting, encoding, or otherwise obfuscating its contents on the system or in transit. This is common behavior that can be used across different platforms and the network to evade defenses." ;
    skos:exactMatch d3f:T1027,
        mitre-attack:T1027 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1114 a owl:Class ;
    rdfs:label "T1114" ;
    d3f:attack-id "T1114" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Email Collection" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may target user email to collect sensitive information. Emails may contain sensitive data, including trade secrets or personal information, that can prove valuable to adversaries. Adversaries can collect or forward email from mail servers or clients." ;
    skos:exactMatch d3f:T1114,
        mitre-attack:T1114 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExfiltrationTechnique a owl:Class ;
    rdfs:label "ExfiltrationTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to steal data." ;
    skos:exactMatch d3f:ExfiltrationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1071 a owl:Class ;
    rdfs:label "T1071" ;
    d3f:attack-id "T1071" ;
    d3f:owl_named_individual "true" ;
    d3f:pref-label "Application Layer Protocol C2" ;
    dcterms:title "Application Layer Protocol" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may communicate using OSI application layer protocols to avoid detection/network filtering by blending in with existing traffic. Commands to the remote system, and often the results of those commands, will be embedded within the protocol traffic between the client and server." ;
    skos:exactMatch d3f:T1071,
        mitre-attack:T1071 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098 a owl:Class ;
    rdfs:label "T1098" ;
    d3f:attack-id "T1098" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Account Manipulation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may manipulate accounts to maintain and/or elevate access to victim systems. Account manipulation may consist of any action that preserves or modifies adversary access to a compromised account, such as modifying credentials or permission groups.(Citation: FireEye SMOKEDHAM June 2021) These actions could also include account activity designed to subvert security policies, such as performing iterative password updates to bypass password duration policies and preserve the life of compromised credentials." ;
    skos:exactMatch d3f:T1098,
        mitre-attack:T1098 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1204 a owl:Class ;
    rdfs:label "T1204" ;
    d3f:attack-id "T1204" ;
    dcterms:title "User Execution" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "An adversary may rely upon specific actions by a user in order to gain execution. Users may be subjected to social engineering to get them to execute malicious code by, for example, opening a malicious document file or link. These user actions will typically be observed as follow-on behavior from forms of [Phishing](https://attack.mitre.org/techniques/T1566)." ;
    skos:exactMatch d3f:T1204,
        mitre-attack:T1204 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548 a owl:Class ;
    rdfs:label "T1548" ;
    d3f:attack-id "T1548" ;
    dcterms:title "Abuse Elevation Control Mechanism" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may circumvent mechanisms designed to control elevate privileges to gain higher-level permissions. Most modern systems contain native elevation control mechanisms that are intended to limit privileges that a user can perform on a machine. Authorization has to be granted to specific users in order to perform tasks that can be considered of higher risk.(Citation: TechNet How UAC Works)(Citation: sudo man page 2018) An adversary can perform several methods to take advantage of built-in control mechanisms in order to escalate privileges on a system.(Citation: OSX Keydnap malware)(Citation: Fortinet Fareit)" ;
    skos:exactMatch d3f:T1548,
        mitre-attack:T1548 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055 a owl:Class ;
    rdfs:label "T1055" ;
    d3f:attack-id "T1055" ;
    dcterms:title "Process Injection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may inject code into processes in order to evade process-based defenses as well as possibly elevate privileges. Process injection is a method of executing arbitrary code in the address space of a separate live process. Running code in the context of another process may allow access to the process's memory, system/network resources, and possibly elevated privileges. Execution via process injection may also evade detection from security products since the execution is masked under a legitimate process." ;
    skos:exactMatch d3f:T1055,
        mitre-attack:T1055 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547 a owl:Class ;
    rdfs:label "T1547" ;
    d3f:attack-id "T1547" ;
    dcterms:title "Boot or Logon Autostart Execution" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may configure system settings to automatically execute a program during system boot or logon to maintain persistence or gain higher-level privileges on compromised systems. Operating systems may have mechanisms for automatically running a program on system boot or account logon.(Citation: Microsoft Run Key)(Citation: MSDN Authentication Packages)(Citation: Microsoft TimeProvider)(Citation: Cylance Reg Persistence Sept 2013)(Citation: Linux Kernel Programming) These mechanisms may include automatically executing programs that are placed in specially designated directories or are referenced by repositories that store configuration information, such as the Windows Registry. An adversary may achieve the same goal by modifying or extending features of the kernel." ;
    skos:exactMatch d3f:T1547,
        mitre-attack:T1547 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574 a owl:Class ;
    rdfs:label "T1574" ;
    d3f:attack-id "T1574" ;
    dcterms:title "Hijack Execution Flow" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the way operating systems run programs. Hijacking execution flow can be for the purposes of persistence, since this hijacked execution may reoccur over time. Adversaries may also use these mechanisms to elevate privileges or evade defenses, such as application control or other restrictions on execution." ;
    skos:exactMatch d3f:T1574,
        mitre-attack:T1574 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

