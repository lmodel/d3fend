d3f:NetworkDeviceEvent a owl:Class ;
    rdfs:label "NetworkDeviceEvent" ;
    dcterms:title "Network Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event capturing the activity or state of network devices, such as Ethernet adapters, Wi-Fi modules, or virtual interfaces. These events highlight connectivity, configuration, or performance changes." ;
    skos:exactMatch d3f:NetworkDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkFrame a owl:Class ;
    rdfs:label "NetworkFrame" ;
    dcterms:title "Network Frame" ;
    rdfs:seeAlso dbr:Frame_\(networking\) ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Frame" ;
    skos:definition "A finite, self-delimited sequence of bits exchanged as one unit over a single data link. Formed by link-layer encapsulation, a frame typically begins with synchronization and control fields, carries a payload, ends with an integrity check, and is bounded from adjacent frames by explicit timing or delimiter symbols." ;
    skos:exactMatch d3f:NetworkFrame ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkMultimediaStreamingResource a owl:Class ;
    rdfs:label "NetworkMultimediaStreamingResource" ;
    dcterms:title "Network Multimedia Streaming Resource" ;
    rdfs:subClassOf d3f:NetworkMediaStreamingResource ;
    skos:definition "A server that provides digital multimedia content to users." ;
    skos:exactMatch d3f:NetworkMultimediaStreamingResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkNode a owl:Class ;
    rdfs:label "NetworkNode" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Node" ;
    rdfs:seeAlso dbr:Node_\(networking\) ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In telecommunications networks, a node (Latin nodus, 'knot') is either a redistribution point or a communication endpoint. The definition of a node depends on the network and protocol layer referred to. A physical network node is an electronic device that is attached to a network, and is capable of creating, receiving, or transmitting information over a communications channel. A passive distribution point such as a distribution frame or patch panel is consequently not a node." ;
    skos:exactMatch d3f:NetworkNode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkResourceAccess a owl:Class ;
    rdfs:label "NetworkResourceAccess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Resource Access" ;
    rdfs:subClassOf d3f:ResourceAccess ;
    skos:definition "Ephemeral digital artifact comprising a request of a network resource and any response from that network resource." ;
    skos:exactMatch d3f:NetworkResourceAccess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NonlinearRegression a owl:Class ;
    rdfs:label "NonlinearRegression" ;
    d3f:d3fend-id "D3A-NR" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Nonlinear regression. [Link](https://en.wikipedia.org/wiki/Nonlinear_regression)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Nonlinear Regression" ;
    rdfs:subClassOf d3f:RegressionAnalysis ;
    skos:definition "Nonlinear regression is a form of regression analysis in which observational data are modeled by a function which is a nonlinear combination of the model parameters and depends on one or more independent variables." ;
    skos:exactMatch d3f:NonlinearRegression ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIAccessProcess a owl:Class ;
    rdfs:label "OSAPIAccessProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Access Process" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function for interacting with processes." ;
    skos:exactMatch d3f:OSAPIAccessProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIFunction a owl:Class ;
    rdfs:label "OSAPIFunction" ;
    dcterms:title "OS API Function" ;
    rdfs:seeAlso <http://dbpedia.org/page/Linux_kernel_interfaces>,
        dbr:Windows_API ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "A callable interface provided by an operating system that allows applications or other software components to interact with and utilize the underlying system resources, services, or functionalities." ;
    skos:exactMatch d3f:OSAPIFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPILoadModule a owl:Class ;
    rdfs:label "OSAPILoadModule" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Load Module" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that loads a module into memory and makes it available for execution." ;
    skos:exactMatch d3f:OSAPILoadModule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIReadMemory a owl:Class ;
    rdfs:label "OSAPIReadMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Read Memory" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that reads the contents of memory from a specific address or region." ;
    skos:exactMatch d3f:OSAPIReadMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPISaveRegisters a owl:Class ;
    rdfs:label "OSAPISaveRegisters" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Save Registers" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that retrieves and saves the values of CPU registers for a specific process or thread." ;
    skos:exactMatch d3f:OSAPISaveRegisters ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPISetRegisters a owl:Class ;
    rdfs:label "OSAPISetRegisters" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Set Registers" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that modifies the values of CPU registers." ;
    skos:exactMatch d3f:OSAPISetRegisters ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIUnloadModule a owl:Class ;
    rdfs:label "OSAPIUnloadModule" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Unload Module" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that removes a previously loaded module from memory." ;
    skos:exactMatch d3f:OSAPIUnloadModule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTProcessVariable a owl:Class ;
    rdfs:label "OTProcessVariable" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OT Process Variable" ;
    rdfs:seeAlso <https://isagca.org/hubfs/2023%20ISA%20Website%20Redesigns/ISAGCA/PDFs/Industrial%20Cybersecurity%20Knowledge%20FINAL.pdf?hsLang=en> ;
    rdfs:subClassOf d3f:OTLogicVariable ;
    skos:definition "Process variables are the current actual measurement of the physical characteristics of a system. Common process variables include but are not limited to Temperature, Pressure, Level, and Flow." ;
    skos:exactMatch d3f:OTProcessVariable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "If the current temperature in a home is 82 degrees Fahrenheit, the process variable is 82 degrees." .

d3f:OfficeApplication a owl:Class ;
    rdfs:label "OfficeApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Office Application" ;
    rdfs:subClassOf d3f:UserApplication ;
    skos:definition "An office application is one that is part of an application suite (e.g., Microsoft Office, Open Office)." ;
    skos:exactMatch d3f:OfficeApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemConfiguration a owl:Class ;
    rdfs:label "OperatingSystemConfiguration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Configuration" ;
    rdfs:subClassOf d3f:ConfigurationResource ;
    skos:definition "Information used to configure the services, parameters, and initial settings for an operating system." ;
    skos:exactMatch d3f:OperatingSystemConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OrchestrationController a owl:Class ;
    rdfs:label "OrchestrationController" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Orchestration Controller" ;
    rdfs:subClassOf d3f:OrchestrationServer ;
    skos:definition "An orchestration server provides orchestration services that automate the configuration, coordination, and management of computer systems and software." ;
    skos:exactMatch d3f:OrchestrationController ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Organization a owl:Class ;
    rdfs:label "Organization" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso d3f:NIST_SP_800-53_R5 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:NonPersonEntity ],
        d3f:AgentGroup ;
    skos:closeMatch oscal:Party ;
    skos:definition "An organization with a defined mission/goal and a defined boundary, using systems to execute that mission, and with responsibility for managing its own risks and performance. An enterprise may consist of all or some of the following business aspects: acquisition, program management, human resources, financial management, security, and systems, information and mission management" ;
    skos:exactMatch d3f:Organization,
        spdx:Organization,
        unified_cyber_ontology:Organization ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetWebTraffic a owl:Class ;
    rdfs:label "OutboundInternetWebTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet Web Traffic" ;
    rdfs:seeAlso dbr:Internetworking,
        <https://schema.ocsf.io/objects/http_request> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:WebNetworkTraffic ],
        d3f:OutboundInternetNetworkTraffic ;
    skos:definition "Outbound internet web traffic is network traffic that is: (a) on an outgoing connection initiated from a host within a network to a host outside the network, and (b) using a standard web protocol." ;
    skos:exactMatch d3f:OutboundInternetWebTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PE32ExecutableFile a owl:Class ;
    rdfs:label "PE32ExecutableFile" ;
    rdfs:subClassOf d3f:ExecutableBinaryEnum,
        linkml:PermissibleValue ;
    skos:definition "PE32 Executable File" .

d3f:PE32PLUSExecutableFile a owl:Class ;
    rdfs:label "PE32PLUSExecutableFile" ;
    rdfs:subClassOf d3f:ExecutableBinaryEnum,
        linkml:PermissibleValue ;
    skos:definition "PE32+ Executable File" .

d3f:PER0002 a owl:Class ;
    rdfs:label "PER_0002" ;
    d3f:attack-id "PER-0002" ;
    dcterms:title "Backdoor" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/PER-0002/> ;
    rdfs:subClassOf d3f:SPARTAPersistenceTechnique ;
    skos:altLabel "PER-0002" ;
    skos:definition "Threat actors may find and target various backdoors, or inject their own, within the victim spacecraft in the hopes of maintaining their attack." ;
    skos:exactMatch d3f:PER-0002,
        mitre-attack:PER-0002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Password a owl:Class ;
    rdfs:label "Password" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Password ;
    rdfs:subClassOf d3f:Credential ;
    skos:altLabel "Passcode" ;
    skos:definition "A password, sometimes called a passcode, is a memorized secret, typically a string of characters, usually used to confirm the identity of a user. Using the terminology of the NIST Digital Identity Guidelines, the secret is memorized by a party called the claimant while the party verifying the identity of the claimant is called the verifier. When the claimant successfully demonstrates knowledge of the password to the verifier through an established authentication protocol, the verifier is able to infer the claimant's identity." ;
    skos:exactMatch d3f:Password ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PasswordRotation a owl:Class ;
    rdfs:label "PasswordRotation" ;
    d3f:d3fend-id "D3-PR" ;
    d3f:kb-article "## How it works Users may be requested to change their passwords on a regular schedule. Management servers with enterprise policies for account management provide the ability to change or reset passwords for accounts. ## Considerations Requiring users to change their passwords frequently can resu" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Rotation" ;
    rdfs:seeAlso <https://pages.nist.gov/800-63-3/sp800-63-3.html>,
        <https://www.auditboard.com/blog/nist-password-guidelines/> ;
    rdfs:subClassOf d3f:CredentialRotation ;
    skos:broadMatch d3f:T1110 ;
    skos:definition "Password rotation is a security policy that mandates the periodic change of user account passwords to mitigate the risk of unauthorized access due to compromised credentials." ;
    skos:exactMatch d3f:PasswordRotation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003 .

d3f:PermissionGrantingEvent a owl:Class ;
    rdfs:label "PermissionGrantingEvent" ;
    dcterms:title "Permission Granting Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/classes/user_access> ;
    rdfs:subClassOf d3f:AccessControlAdministrationEvent ;
    skos:definition "An administrative event where authorization is given, allowing a subject to perform specific operations on a protected resource, effectuating a policy decision to allow access rights." ;
    skos:exactMatch d3f:PermissionGrantingEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PermissionRevokingEvent a owl:Class ;
    rdfs:label "PermissionRevokingEvent" ;
    dcterms:title "Permission Revoking Event" ;
    rdfs:subClassOf d3f:AccessControlAdministrationEvent ;
    skos:definition "An administrative event entailing the withdrawal of previously granted access rights, reconfiguring permissions to prevent a subject from performing specific actions on a resource, in accordance with updated access policies." ;
    skos:exactMatch d3f:PermissionRevokingEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalAccessMediation a owl:Class ;
    rdfs:label "PhysicalAccessMediation" ;
    d3f:d3fend-id "D3-PAM" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Physical Access Control" ;
    dcterms:title "Physical Access Mediation" ;
    rdfs:subClassOf d3f:AccessMediation ;
    skos:definition "Physical access mediation is the process of granting or denying specific requests to enter specific physical facilities (e.g., Federal buildings, military establishments, border crossing entrances.)" ;
    skos:exactMatch d3f:PhysicalAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Planning a owl:Class ;
    rdfs:label "Planning" ;
    rdfs:subClassOf d3f:AnalyticalPurpose ;
    skos:exactMatch d3f:Planning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PlatformHardeningEnum a owl:Class ;
    rdfs:label "PlatformHardeningEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:ExecutableAllowlisting d3f:PlatformHardening ) ;
    skos:definition "Enumeration of PlatformHardening values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "Hardening components of a Platform with the intention of making them more difficult to exploit. Platforms includes components such as: * BIOS UEFI Subsystems * Hardware security devices such as Trusted Platform Modules * Boot process logic or code * Kernel software components" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:ExecutableAllowlisting,
        d3f:PlatformHardening .

d3f:Pointer a owl:Class ;
    rdfs:label "Pointer" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Pointer_\(computer_programming\) ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "In computer science, a pointer is a programming language object, whose value refers to (or \"points to\") another value stored elsewhere in the computer memory using its memory address. A pointer references a location in memory, and obtaining the value stored at that location is known as dereferencing the pointer. As an analogy, a page number in a book's index could be considered a pointer to the corresponding page; dereferencing such a pointer would be done by flipping to the page with the given page number." ;
    skos:exactMatch d3f:Pointer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PolicyGradient a owl:Class ;
    rdfs:label "PolicyGradient" ;
    d3f:d3fend-id "D3A-PG" ;
    d3f:kb-article "## References Policy Gradients in a Nutshell. Towards Data Science. [Link](https://towardsdatascience.com/policy-gradients-in-a-nutshell-8b72f9743c5d)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Policy Gradient" ;
    rdfs:subClassOf d3f:ModelFreeReinforcementLearning ;
    skos:definition "The objective of a Reinforcement Learning Policy Gradient agent is to maximize the “expected” reward when following a policy" ;
    skos:exactMatch d3f:PolicyGradient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PolicyReference a owl:Class ;
    rdfs:label "PolicyReference" ;
    d3f:pref-label "Policy" ;
    dcterms:title "Policy Reference" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:exactMatch d3f:PolicyReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PowerSupply a owl:Class ;
    rdfs:label "PowerSupply" ;
    dcterms:title "Power Supply" ;
    rdfs:seeAlso dbr:Power_supply ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A power supply is an electrical device or module that converts and regulates energy from a source (e.g., the power grid or batteries) to an appropriate voltage, current, and frequency for one or more loads. It may stand alone or be integrated into its host appliance, often providing overcurrent protection, voltage regulation, or power conditioning for safe, stable operation." ;
    skos:exactMatch d3f:PowerSupply ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PowershellScriptFile a owl:Class ;
    rdfs:label "PowershellScriptFile" ;
    rdfs:subClassOf d3f:ExecutableScriptEnum,
        linkml:PermissibleValue ;
    skos:definition "Powershell Script File" .

d3f:Procedure a owl:Class ;
    rdfs:label "Procedure" ;
    rdfs:subClassOf d3f:Plan ;
    skos:exactMatch d3f:Procedure ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessCodeSegment a owl:Class ;
    rdfs:label "ProcessCodeSegment" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Code Segment" ;
    rdfs:seeAlso d3f:ImageCodeSegment,
        dbr:Code_segment ;
    rdfs:subClassOf d3f:ProcessSegment ;
    skos:altLabel "Process Text Segment" ;
    skos:definition "A process code segment, also known as a text segment or simply as text, is a portion of the program's virtual address space that contains executable instructions and corresponds to the loaded image code segment. Includes additional sections such as an import table." ;
    skos:exactMatch d3f:ProcessCodeSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessDataSegment a owl:Class ;
    rdfs:label "ProcessDataSegment" ;
    dcterms:title "Process Data Segment" ;
    rdfs:seeAlso d3f:ImageDataSegment,
        dbr:Data_segment ;
    rdfs:subClassOf d3f:ProcessSegment ;
    skos:definition "A process data segment, is a portion of the program's virtual address space that contains executable instructions and corresponds to the loaded image data segment." ;
    skos:exactMatch d3f:ProcessDataSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessTerminationEnum a owl:Class ;
    rdfs:label "ProcessTerminationEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:HostShutdown d3f:ProcessTermination ) ;
    skos:definition "Enumeration of ProcessTermination values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "Terminating a running application process on a computer system." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:HostShutdown,
        d3f:ProcessTermination .

d3f:ProductDeveloper a owl:Class ;
    rdfs:label "ProductDeveloper" ;
    dcterms:title "Product Developer" ;
    rdfs:subClassOf d3f:Provider ;
    skos:definition "A product developer intentionally designs, creates, or improves products, which may include physical goods, software, or other outputs." ;
    skos:exactMatch d3f:ProductDeveloper ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD0003 a owl:Class ;
    rdfs:label "RD_0003" ;
    d3f:attack-id "RD-0003" ;
    dcterms:title "Obtain Cyber Capabilities" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0003/> ;
    rdfs:subClassOf d3f:SPARTAResourceDevelopmentTechnique ;
    skos:altLabel "RD-0003" ;
    skos:definition "Threat actors may buy and/or steal cyber capabilities that can be used for future campaigns or to perpetuate other techniques. Rather than developing their own capabilities in-house, threat actors may purchase, download, or steal them. Activities may include the acquisition of malware, software, exploits, and information relating to vulnerabilities. Threat actors may obtain capabilities to support their operations throughout numerous phases of the campaign lifecycle." ;
    skos:exactMatch d3f:RD-0003,
        mitre-attack:RD-0003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD0004 a owl:Class ;
    rdfs:label "RD_0004" ;
    d3f:attack-id "RD-0004" ;
    dcterms:title "Stage Capabilities" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0004/> ;
    rdfs:subClassOf d3f:SPARTAResourceDevelopmentTechnique ;
    skos:altLabel "RD-0004" ;
    skos:definition "Threat actors may upload, install, or otherwise set up capabilities that can be used for future campaigns or to perpetuate other techniques. To support their operations, a threat actor may need to develop their own capabilities or obtain them in some way in order to stage them on infrastructure under their control. These capabilities may be staged on infrastructure that was previously purchased or rented by the threat actor or was otherwise compromised by them." ;
    skos:exactMatch d3f:RD-0004,
        mitre-attack:RD-0004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0006 a owl:Class ;
    rdfs:label "REC_0006" ;
    d3f:attack-id "REC-0006" ;
    dcterms:title "Gather FSW Development Information" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0006/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0006" ;
    skos:definition "Threat actors may obtain information regarding the flight software (FSW) development environment for the victim spacecraft. This information may include the development environment, source code, compiled binaries, testing tools, and fault management." ;
    skos:exactMatch d3f:REC-0006,
        mitre-attack:REC-0006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ROM a owl:Class ;
    rdfs:label "ROM" ;
    d3f:synonym "Read-only Memory" ;
    rdfs:seeAlso <https://dbpedia.org/page/Read-only_memory> ;
    rdfs:subClassOf d3f:PrimaryStorage ;
    skos:definition "Read-only memory (ROM) is a type of non-volatile memory used in computers and other electronic devices. Data stored in ROM cannot be electronically modified after the manufacture of the memory device. Read-only memory is useful for storing software that is rarely changed during the life of the system, also known as firmware." ;
    skos:exactMatch d3f:ROM ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RatingEnum a owl:Class ;
    rdfs:label "RatingEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    skos:definition "Generic rating. Open enum: arbitrary string values also accepted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values <http://d3fend.mitre.org/ontologies/d3fend.owl#RatingEnum#Unspecified> .

d3f:Receiver a owl:Class ;
    rdfs:label "Receiver" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <https://www.analog.com/en/resources/glossary/receiver.html> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A receiver is a device or system that acquires signals and converts them into usable information. It senses a physical carrier (such as electromagnetic fields, light, electrical currents, or acoustic waves), conditions the input, and extracts the intended content through operations like filtering, amplification, detection, synchronization, demodulation, decoding, and error correction. A receiver may be analog or digital, implemented in hardware, software, or both, and is designed to mitigate impairments such as noise, interference, and distortion while delivering recovered data or media to downstream processes." ;
    skos:exactMatch d3f:Receiver ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Reference-ARadiationHardenedSARADCWithDelayBasedDualFeedbackFlipFlopsForSensorReadoutSystems a owl:Class ;
    rdfs:label "Reference_ARadiationHardenedSARADCWithDelayBasedDualFeedbackFlipFlopsForSensorReadoutSystems" ;
    rdfs:subClassOf d3f:AcademicPaperReferenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Reference - A Radiation-Hardened SAR ADC with Delay-Based Dual Feedback Flip-Flops for Sensor Readout Systems" .

d3f:Reference-AnalysisOfTheWindowsVistaSecurityModel_SymantecCorporation a owl:Class ;
    rdfs:label "Reference_AnalysisOfTheWindowsVistaSecurityModel_SymantecCorporation" ;
    rdfs:subClassOf d3f:AcademicPaperReferenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Reference - Analysis of the Windows Vista Security Model - Symantec Corporation" .

d3f:Reference-AuditUserAccountManagement a owl:Class ;
    rdfs:label "Reference_AuditUserAccountManagement" ;
    rdfs:subClassOf d3f:GuidelineReferenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Reference - Audit User Account Management" .

d3f:Reference-CManualIntegerInitialization_GNU a owl:Class ;
    rdfs:label "Reference_CManualIntegerInitialization_GNU" ;
    rdfs:subClassOf d3f:UserManualReferenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Reference - Integer Initialization - GNU C Manual" .

d3f:Reference-CManualPointerArithmetic_GNU a owl:Class ;
    rdfs:label "Reference_CManualPointerArithmetic_GNU" ;
    rdfs:subClassOf d3f:UserManualReferenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Reference - Memory Block Start Validation - GNU C Manual" .

