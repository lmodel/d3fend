    rdfs:label "CWE_1113" ;
    d3f:cwe-id "CWE-1113" ;
    dcterms:title "Inappropriate Comment Style" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-1113" ;
