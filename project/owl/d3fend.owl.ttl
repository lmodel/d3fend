d3f:ProcessTree a owl:Class ;
    rdfs:label "ProcessTree" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Tree" ;
    rdfs:seeAlso d3f:ProcessSpawnAnalysis,
        dbr:Child_process,
        dbr:Parent_process ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A process tree is a tree structure representation of parent-child relationships established via process spawn operations." ;
    skos:exactMatch d3f:ProcessTree ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessorRegister a owl:Class ;
    rdfs:label "ProcessorRegister" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Processor Register" ;
    rdfs:seeAlso <https://dbpedia.org/page/Processor_register>,
        <https://www.techtarget.com/whatis/definition/register> ;
    rdfs:subClassOf d3f:PrimaryStorage ;
    skos:definition "A processor register is a quickly accessible location available to a computer's processor. Registers usually consist of a small amount of fast storage, although some registers have specific hardware functions, and may be read-only or write-only." ;
    skos:exactMatch d3f:ProcessorRegister ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProgressivelyGrowingGAN a owl:Class ;
    rdfs:label "ProgressivelyGrowingGAN" ;
    d3f:d3fend-id "D3A-PGG" ;
    d3f:kb-article "## References Machine Learning Mastery. (n.d.). Introduction to Progressive Growing Generative Adversarial Networks. [Link](https://machinelearningmastery.com/introduction-to-progressive-growing-generative-adversarial-networks/)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "ProGAN" ;
    dcterms:title "Progressively Growing GAN" ;
    rdfs:subClassOf d3f:ImageSynthesisGAN ;
