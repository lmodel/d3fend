    d3f:owl_named_individual "true" ;
    dcterms:title "Local Area Network Traffic" ;
    rdfs:seeAlso dbr:Intranet ;
    rdfs:subClassOf d3f:IntranetNetworkTraffic ;
    skos:definition "Intranet local area network (LAN) traffic is network traffic that does not cross a given network's boundaries; where that network is defined as a LAN." ;
    skos:exactMatch d3f:LocalAreaNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LocalAuthenticationService a owl:Class ;
