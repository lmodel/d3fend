d3f:SavedInstructionPointer a owl:Class ;
    rdfs:label "SavedInstructionPointer" ;
    dcterms:title "Saved Instruction Pointer" ;
    rdfs:seeAlso dbr:Exception_handling ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:StackComponent ],
        d3f:Pointer ;
    skos:definition "A saved instruction pointer points to the instruction that generated an exception (trap or fault)." ;
    skos:exactMatch d3f:SavedInstructionPointer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ScheduledJobAnalysis a owl:Class ;
    rdfs:label "ScheduledJobAnalysis" ;
    d3f:d3fend-id "D3-SJA" ;
    d3f:kb-article "## How it works Scheduled job execution can be utilized by adversaries for the purpose of persistence, conducting remote execution, or gaining privileges. Details of a scheduled job such as associated source files, processes, destination files, or destination servers are first identified and analyze" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Scheduled Job Execution" ;
    dcterms:title "Scheduled Job Analysis" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:ExecutionTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1036 ;
    skos:definition "Analysis of source files, processes, destination files, or destination servers associated with a scheduled job to detect unauthorized use of job scheduling." ;
    skos:exactMatch d3f:ScheduledJobAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1036.004,
        mitre-attack:T1053 .

d3f:ScheduledJobCreationEvent a owl:Class ;
    rdfs:label "ScheduledJobCreationEvent" ;
    dcterms:title "Scheduled Job Creation Event" ;
    rdfs:subClassOf d3f:ScheduledJobEvent ;
    skos:definition "An event representing the addition of a new task to the system's scheduler, defining its execution criteria and associated actions." ;
    skos:exactMatch d3f:ScheduledJobCreationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ScheduledJobDeletionEvent a owl:Class ;
    rdfs:label "ScheduledJobDeletionEvent" ;
    dcterms:title "Scheduled Job Deletion Event" ;
    rdfs:subClassOf d3f:ScheduledJobEvent ;
    skos:definition "An event marking the removal of a scheduled task from the system, terminating its execution schedule." ;
    skos:exactMatch d3f:ScheduledJobDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ScheduledJobDisableEvent a owl:Class ;
    rdfs:label "ScheduledJobDisableEvent" ;
    dcterms:title "Scheduled Job Disable Event" ;
    rdfs:subClassOf d3f:ScheduledJobEvent ;
    skos:definition "An event where a scheduled task is deactivated, preventing further execution until re-enabled." ;
    skos:exactMatch d3f:ScheduledJobDisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

