    rdfs:label "CWE_1115" ;
    d3f:cwe-id "CWE-1115" ;
    dcterms:title "Source Code Element without Standard Prologue" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-1115" ;
    skos:definition "The source code contains elements such as source files that do not consistently provide a prologue or header that has been standardized for the project." ;
    skos:exactMatch d3f:CWE-1115,
        cwe:CWE-1115 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1116 a owl:Class ;
    rdfs:label "CWE_1116" ;
    d3f:cwe-id "CWE-1116" ;
    dcterms:title "Inaccurate Comments" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-1116" ;
    skos:definition "The source code contains comments that do not accurately describe or explain aspects of the portion of the code with which the comment is associated." ;
    skos:exactMatch d3f:CWE-1116,
        cwe:CWE-1116 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

