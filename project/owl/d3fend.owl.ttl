d3f:ResumeThread a owl:Class ;
    rdfs:label "ResumeThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resume Thread" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-resumethread> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:ResumeThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ReverseProxyServer a owl:Class ;
    rdfs:label "ReverseProxyServer" ;
    dcterms:title "Reverse Proxy Server" ;
    rdfs:seeAlso dbr:Reverse_proxy ;
    rdfs:subClassOf d3f:ProxyServer ;
    skos:definition "In computer networks, a reverse proxy is a type of proxy server that retrieves resources on behalf of a client from one or more servers. These resources are then returned to the client, appearing as if they originated from the proxy server itself. Unlike a forward proxy, which is an intermediary for its associated clients to contact any server, a reverse proxy is an intermediary for its associated servers to be contacted by any client. In other words, a proxy acts on behalf of the client(s), while a reverse proxy acts on behalf of the server(s); a reverse proxy is usually an internal-facing proxy used as a 'front-end' to control and protect access to a server on a private network." ;
    skos:exactMatch d3f:ReverseProxyServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ReverseResolutionIPDenylisting a owl:Class ;
    rdfs:label "ReverseResolutionIPDenylisting" ;
    d3f:d3fend-id "D3-RRID" ;
    d3f:kb-article "## How it works This technique prevents a client from learning domains deemed to be potentially malicious, which would have been delivered via reverse resolution responses over the DNS protocol. Queries for reverse resolution requests (that is, requests where IP(s) are sent and a domain is returned" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Reverse Resolution IP Blacklisting" ;
    dcterms:title "Reverse Resolution IP Denylisting" ;
    rdfs:subClassOf d3f:DNSDenylisting ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:T1071 ;
    skos:definition "Blocking a reverse lookup based on the query's IP address value." ;
    skos:exactMatch d3f:ReverseResolutionIPDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1071.004,
        mitre-attack:T1568 .

d3f:RevokePrivilegesFromGroupEvent a owl:Class ;
    rdfs:label "RevokePrivilegesFromGroupEvent" ;
    dcterms:title "Revoke Privileges from Group Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PermissionRevokingEvent ],
        d3f:GroupManagementEvent ;
    skos:definition "An event where specific privileges or rights are removed from a group, restricting its members from performing actions or accessing resources previously allowed by those privileges." ;
    skos:exactMatch d3f:RevokePrivilegesFromGroupEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RoutingAccessMediation a owl:Class ;
    rdfs:label "RoutingAccessMediation" ;
    d3f:d3fend-id "D3-RAM" ;
    d3f:kb-article "## How it works Routing Access Mediation is a network security strategy focused on managing and controlling access at the network layer. It includes the use of VPNs for secure remote access, tunneling protocols for encapsulating data, firewall rules for filtering traffic, and advanced inspection te" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Routing Access Mediation" ;
    rdfs:seeAlso <https://www.geeksforgeeks.org/context-based-access-control-cbac/> ;
    rdfs:subClassOf d3f:NetworkAccessMediation ;
    skos:definition "Routing access mediation is a network security approach that manages and controls access at the network layer using VPNs, tunneling protocols, firewall rules, and traffic inspection to ensure secure and efficient data routing." ;
    skos:exactMatch d3f:RoutingAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SARSA a owl:Class ;
    rdfs:label "SARSA" ;
    d3f:d3fend-id "D3A-SAR" ;
    d3f:kb-article "## References State-action-reward-state-action. Wikipedia. [Link](https://en.wikipedia.org/wiki/State%E2%80%93action%E2%80%93reward%E2%80%93state%E2%80%93action)." ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <https://dbpedia.org/page/State%E2%80%93action%E2%80%93reward%E2%80%93state%E2%80%93action> ;
    rdfs:subClassOf d3f:ModelFreeReinforcementLearning ;
    skos:definition "State-action-reward-state-action (SARSA) is an algorithm for learning a Markov decision process policy, used in the reinforcement learning area of machine learning." ;
    skos:exactMatch d3f:SARSA ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBFileCreateEvent a owl:Class ;
    rdfs:label "SMBFileCreateEvent" ;
    dcterms:title "SMB File Create Event" ;
    rdfs:subClassOf d3f:SMBEvent ;
    skos:definition "An event where a file is created if it does not already exist, failing if the file is already present. This operation strictly enforces new file creation." ;
    skos:exactMatch d3f:SMBFileCreateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBFileOpenEvent a owl:Class ;
    rdfs:label "SMBFileOpenEvent" ;
    dcterms:title "SMB File Open Event" ;
    rdfs:subClassOf d3f:SMBEvent ;
    skos:definition "An event where a file is opened if it exists, failing otherwise. This operation is used to access or query the existing file." ;
    skos:exactMatch d3f:SMBFileOpenEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBFileOpenIfEvent a owl:Class ;
    rdfs:label "SMBFileOpenIfEvent" ;
    dcterms:title "SMB File Open If Event" ;
    rdfs:subClassOf d3f:SMBEvent ;
    skos:definition "An event where a file is opened if it exists, or created if it does not. This operation merges file creation and access behavior." ;
    skos:exactMatch d3f:SMBFileOpenIfEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBFileOverwriteEvent a owl:Class ;
    rdfs:label "SMBFileOverwriteEvent" ;
    dcterms:title "SMB File Overwrite Event" ;
    rdfs:subClassOf d3f:SMBEvent ;
    skos:definition "An event where a file is opened and truncated if it exists, failing if the file does not already exist. This operation is destructive and focuses on replacing the file's contents." ;
    skos:exactMatch d3f:SMBFileOverwriteEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBFileOverwriteIfEvent a owl:Class ;
    rdfs:label "SMBFileOverwriteIfEvent" ;
    dcterms:title "SMB File Overwrite If Event" ;
    rdfs:subClassOf d3f:SMBEvent ;
    skos:definition "An event where a file is opened and truncated if it exists, or created otherwise. This operation combines destructive overwrite and creation behaviors." ;
    skos:exactMatch d3f:SMBFileOverwriteIfEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBFileSupersedeEvent a owl:Class ;
    rdfs:label "SMBFileSupersedeEvent" ;
    dcterms:title "SMB File Supersede Event" ;
    rdfs:subClassOf d3f:SMBEvent ;
    skos:definition "An event where a file is overwritten if it exists or created if it does not. This operation combines file creation and modification semantics." ;
    skos:exactMatch d3f:SMBFileSupersedeEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHConnectionCloseEvent a owl:Class ;
    rdfs:label "SSHConnectionCloseEvent" ;
    dcterms:title "SSH Connection Close Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SSHEvent ],
        d3f:NetworkConnectionCloseEvent ;
    skos:definition "An event indicating the termination of an SSH connection, signaling the end of a secure session." ;
    skos:exactMatch d3f:SSHConnectionCloseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHConnectionFailEvent a owl:Class ;
    rdfs:label "SSHConnectionFailEvent" ;
    dcterms:title "SSH Connection Fail Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SSHEvent ],
        d3f:NetworkConnectionFailEvent ;
    skos:definition "An event indicating a failure to establish an SSH connection, often due to issues such as authentication errors, network timeouts, or server unavailability." ;
    skos:exactMatch d3f:SSHConnectionFailEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHConnectionOpenEvent a owl:Class ;
    rdfs:label "SSHConnectionOpenEvent" ;
    dcterms:title "SSH Connection Open Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SSHEvent ],
        d3f:NetworkConnectionOpenEvent ;
    skos:definition "An event indicating the successful establishment of an SSH connection between a client and a server, marking the initiation of a secure session." ;
    skos:exactMatch d3f:SSHConnectionOpenEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHConnectionRefuseEvent a owl:Class ;
    rdfs:label "SSHConnectionRefuseEvent" ;
    dcterms:title "SSH Connection Refuse Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SSHEvent ],
        d3f:NetworkConnectionRefuseEvent ;
    skos:definition "An event indicating that an SSH connection attempt was refused, typically due to server-side restrictions or closed ports." ;
    skos:exactMatch d3f:SSHConnectionRefuseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHConnectionResetEvent a owl:Class ;
    rdfs:label "SSHConnectionResetEvent" ;
    dcterms:title "SSH Connection Reset Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SSHEvent ],
        d3f:NetworkConnectionResetEvent ;
    skos:definition "An event indicating the abrupt termination of an SSH connection due to protocol errors, network disruptions, or administrative actions." ;
    skos:exactMatch d3f:SSHConnectionResetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHListenEvent a owl:Class ;
    rdfs:label "SSHListenEvent" ;
    dcterms:title "SSH Listen Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SSHEvent ],
        d3f:NetworkConnectionListenEvent ;
    skos:definition "An event indicating that an SSH server has started listening for incoming connection requests, enabling potential clients to initiate secure sessions." ;
    skos:exactMatch d3f:SSHListenEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHSession a owl:Class ;
    rdfs:label "SSHSession" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "SSH Session" ;
    rdfs:seeAlso dbr:Secure_Shell_Protocol ;
    rdfs:subClassOf d3f:RemoteSession ;
    skos:definition "A Secure Shell Protocol (SSH) session is a session over a secure channel established using SSH to connect a client to a server and establish the remote session." ;
    skos:exactMatch d3f:SSHSession ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SatelliteTransponder a owl:Class ;
    rdfs:label "SatelliteTransponder" ;
    dcterms:title "Satellite Transponder" ;
    rdfs:seeAlso dbr:Transponder_\(satellite_communications\) ;
    rdfs:subClassOf d3f:Transponder ;
    skos:definition "A communications satellite's transponder is the series of interconnected units that form a communications channel between the receiving and the transmitting antennas." ;
    skos:exactMatch d3f:SatelliteTransponder ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SaveRegister a owl:Class ;
    rdfs:label "SaveRegister" ;
    d3f:owl_named_individual "true" ;
