    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1003.008,
        mitre-attack:T1012,
        mitre-attack:T1033,
