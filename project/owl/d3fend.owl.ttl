        d3f:T1546,
        d3f:T1547,
        d3f:T1548,
        d3f:T1562,
        d3f:T1565,
        d3f:T1574 ;
    skos:definition "Blocking the execution of files on a host in accordance with defined application policy rules." ;
    skos:exactMatch d3f:ExecutableDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1007,
        mitre-attack:T1010,
        mitre-attack:T1016,
