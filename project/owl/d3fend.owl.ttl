    rdfs:subClassOf d3f:ApplicationConfiguration ;
    skos:altLabel "Environment Variable" ;
    skos:definition "An environment variable is a dynamic-named value that can affect the way running processes will behave on a computer. They are part of the environment in which a process runs." ;
    skos:exactMatch d3f:ProcessEnvironmentVariable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessImage a owl:Class ;
    rdfs:label "ProcessImage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Image" ;
    rdfs:seeAlso <http://dbpedia.org/resource/System_image#Process_images> ;
    rdfs:subClassOf d3f:ComputingImage ;
    skos:definition "A process image is a copy of a given process's state at a given point in time. It is often used to create persistence within an otherwise volatile system." ;
    skos:exactMatch d3f:ProcessImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessLineageAnalysis a owl:Class ;
    rdfs:label "ProcessLineageAnalysis" ;
    d3f:d3fend-id "D3-PLA" ;
    d3f:kb-article "## How it works Process tree analysis techniques gather information on how a process was initiated to determine if a process is malicious. For example, if a process was not initiated from boot or not initiated by another process, that process is identified as suspicious. Also, if a new process was s" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Process Tree Analysis" ;
    dcterms:title "Process Lineage Analysis" ;
    rdfs:subClassOf d3f:ProcessSpawnAnalysis ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1505,
        d3f:T1546,
        d3f:T1562 ;
    skos:definition "Identification of suspicious processes executing on an end-point device by examining the ancestry and siblings of a process, and the associated metadata of each node on the tree, such as process execution, duration, and order relative to siblings and ancestors." ;
    skos:exactMatch d3f:ProcessLineageAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1033,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1212,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1546.007,
        mitre-attack:T1550,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:ProcessSegmentExecutionPrevention a owl:Class ;
    rdfs:label "ProcessSegmentExecutionPrevention" ;
    d3f:d3fend-id "D3-PSEP" ;
    d3f:kb-article "## How it works During execution of a process, the instruction pointer register should only point to addresses in a code segment (also called the .text segment), as this is the sole segment which should contain program code. When this technique detects an attempt to execute something that has been" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Execute Disable" ;
    dcterms:title "Process Segment Execution Prevention" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1055,
        d3f:T1056,
        d3f:T1218 ;
    skos:definition "Preventing execution of any address in a memory region other than the code segment." ;
    skos:exactMatch d3f:ProcessSegmentExecutionPrevention ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1033,
        mitre-attack:T1055.012,
        mitre-attack:T1056.004,
        mitre-attack:T1068,
        mitre-attack:T1189,
        mitre-attack:T1190,
        mitre-attack:T1203,
        mitre-attack:T1210,
        mitre-attack:T1211,
        mitre-attack:T1212,
        mitre-attack:T1218.013,
        mitre-attack:T1620 .

