d3f:may_run a owl:DatatypeProperty ;
    rdfs:label "may-run" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-run y: They entity x may run the thing y; that is, 'x runs y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_transfer a owl:DatatypeProperty ;
    rdfs:label "may-transfer" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-transfer y: They entity x might send the thing y; that is, 'x transfers y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:mediates_access_to a owl:DatatypeProperty ;
    rdfs:label "mediates-access-to" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x mediates-access-to y: The entity x controls and brokers requests to reach entity y, enforcing the access rules that allow or deny it." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:member_of a owl:DatatypeProperty ;
    rdfs:label "member-of" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:modified a owl:DatatypeProperty ;
    rdfs:label "modified" ;
    dcterms:title "date modified" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:date_value ;
    skos:definition "Date on which the resource was changed." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:modified_by a owl:DatatypeProperty ;
    rdfs:label "modified-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x modified-by y: The entity x is changed by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:modifies_part a owl:DatatypeProperty ;
    rdfs:label "modifies-part" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_modify ;
    skos:definition "x modifies-part y: The entity x modifies a part of y.  [Note: This is a rolification property for the rule 'if one modifies a part of a whole, they modify the whole.'  Reasoning for this and similar semantics to come are under evaluation and not part of current d3fend inferences.]" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:monitors a owl:DatatypeProperty ;
    rdfs:label "monitors" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02167732-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x monitors y: The technique or agent x keep tabs on; keeps an eye on; or keep the digital artifact y under surveillance." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:narrower a owl:DatatypeProperty ;
    rdfs:label "narrower" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:semantic_relation ;
    skos:definition "x narrower y: The entity x represents a more specific or focused concept than entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:narrower_transitive a owl:DatatypeProperty ;
    rdfs:label "narrower-transitive" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:semantic_relation ;
    skos:definition "x narrower-transitive y: The entity x represents a more specific concept than entity y, including indirect or hierarchical relationships where x is a subset of y through intermediate entities." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:neutralizes a owl:DatatypeProperty ;
    rdfs:label "neutralizes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00471015-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x neutralizes y: The technique x makes the execution of actions of y ineffective by preventing or counterbalancing the effect of y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:next a owl:DatatypeProperty ;
    rdfs:label "next" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_process_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:obfuscates a owl:DatatypeProperty ;
    rdfs:label "obfuscates" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00942245-v> ;
    rdfs:subPropertyOf d3f:evicts ;
    skos:definition "x obfuscates y: The technique x makes the digital artifact y unclear or obscure.  Typically obfuscation is a way to hide a digital artifact from discovery, use, or both." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:operates a owl:DatatypeProperty ;
    rdfs:label "operates" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x operates y: The entity x enables, activates, or controls the functioning or behavior of object y (operated entity), typically in accordance with the design or intended use of the operated entity." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:operating_system a owl:DatatypeProperty ;
    rdfs:label "operating-system" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:definition "x operating-system y: The product x is supported on operating system y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:originates_from a owl:DatatypeProperty ;
    rdfs:label "originates-from" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02749218-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x originates-from y: The digital event or artifact x began its network transit from a physical location y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:powered_by a owl:DatatypeProperty ;
    rdfs:label "powered-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:depends_on ;
    skos:definition "x powered-by y: x obtains its essential energy or force from y to perform its function or remain active." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:powers a owl:DatatypeProperty ;
    rdfs:label "powers" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:has_dependent ;
    skos:definition "x powers y: x furnishes y with the energy or force required for y's functionality or operation." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:preceded_by a owl:DatatypeProperty ;
    rdfs:label "preceded-by" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000062> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x preceded-by y: The event or action x occurs after event or action y in time." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:precedes a owl:DatatypeProperty ;
    rdfs:label "precedes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000063> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x precedes y: The event or action x occurs before event or action y in time." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:pref_label a owl:DatatypeProperty ;
    rdfs:label "pref-label" ;
    rdfs:range xsd:string ;
    skos:definition "x pref-label y: The preferred display value for x is y in d3fend tools." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_command_line_arguments a owl:DatatypeProperty ;
    rdfs:label "process-command-line-arguments" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_data_property ;
    skos:definition "x process-command-line-arguments y: The process x has the process command line arguments data y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_environmental_variables a owl:DatatypeProperty ;
    rdfs:label "process-environmental-variables" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_data_property ;
    skos:altLabel "process-environmental-variable" ;
    skos:definition "x process-environment-variables y: The process x has the process environmental variables data y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_identifier a owl:DatatypeProperty ;
    rdfs:label "process-identifier" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_data_property ;
    skos:definition "x process-identifier y: The process x has the process identifier y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_image_path a owl:DatatypeProperty ;
    rdfs:label "process-image-path" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_property ;
    skos:altLabel "processImagePath" ;
    skos:definition "x process-image-path y: The filepath y is the process image path for the process x, indicating the path to the resource from which the process's image was loaded." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_parent a owl:DatatypeProperty ;
    rdfs:label "process-parent" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_ancestor ;
    skos:altLabel "processParent" ;
    skos:definition "x process-parent y: The process y created the process x (directly) with a create process event." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:process_user a owl:DatatypeProperty ;
    rdfs:label "process-user" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:process_property ;
    skos:altLabel "processUser" ;
    skos:definition "x process-user y: The process x has been executed by the user y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:produced_by a owl:DatatypeProperty ;
    rdfs:label "produced-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x produced-by y: The entity x is created by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:produces a owl:DatatypeProperty ;
    rdfs:label "produces" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01625832-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:altLabel "outputs" ;
    skos:definition "x produces y: The subject entity x or process produces a data object y, which may be discrete digital object or a stream (e.g., a stream such as network traffic.)" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:provider a owl:DatatypeProperty ;
    rdfs:label "provider" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/05901034-n> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x provider y: A provider y is an entity that supplies a service, system, or data resources to a dependent entity x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:published a owl:DatatypeProperty ;
    rdfs:label "published" ;
    dcterms:title "date published" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:date_value ;
    skos:definition "Date of publication of the resource." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:quarantines a owl:DatatypeProperty ;
    rdfs:label "quarantines" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x quarantines y: Technique x moves entity y to a place of isolation." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:queries a owl:DatatypeProperty ;
    rdfs:label "queries" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x queries y: The entity x requests information or data from entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:rating a owl:DatatypeProperty ;
    rdfs:label "rating" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( d3f:RatingEnum xsd:string ) ] ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:receives a owl:DatatypeProperty ;
    rdfs:label "receives" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x receives y: The subject x acquires object y from a communication medium and transfers y into its local context for storage or processing." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:recorded_in a owl:DatatypeProperty ;
    rdfs:label "recorded-in" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x recorded-in y: The event x is documented, logged, or otherwise preserved within the digital artifact y, which stores or encodes relevant data about the event." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:records a owl:DatatypeProperty ;
    rdfs:label "records" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01002259-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x records y: The digital artifact x makes a record of events y; set down in permanent form." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:regenerates a owl:DatatypeProperty ;
    rdfs:label "regenerates" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00167632-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x regenerates y: The entity x discards the current digital artifact y and creates a new version that serves the same function." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:related a owl:DatatypeProperty ;
    rdfs:label "related" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso skos:related ;
    rdfs:subPropertyOf d3f:semantic_relation ;
    skos:definition "x related y: x has a symmetric associative relation to y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:release_date a owl:DatatypeProperty ;
    rdfs:label "release-date" ;
    rdfs:range xsd:string ;
    skos:definition "x release-date y: The object x has the release-date y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:restores a owl:DatatypeProperty ;
    rdfs:label "restores" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x restores y: The entity x returns entity y to its known-good or previous state." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:restricted_by a owl:DatatypeProperty ;
    rdfs:label "restricted-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x restricted-by y: The entity x is limited, constrained, or regulated by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:resume a owl:DatatypeProperty ;
    rdfs:label "resume" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00350758-v> ;
    rdfs:subPropertyOf d3f:d3fend_process_object_property ;
    skos:definition "The agent or technique x continues a previous action on entity y. Usually occurs after suspension on y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:resumes a owl:DatatypeProperty ;
    rdfs:label "resumes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00350758-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "The agent or technique x continues a previous action on entity y. Usually occurs after suspension on y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:risk_impact a owl:DatatypeProperty ;
    rdfs:label "risk-impact" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( d3f:RiskImpactEnum xsd:string ) ] ;
    rdfs:seeAlso <https://www.cto.mil/wp-content/uploads/2024/05/RIO-2023-2-2.pdf> ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:definition "Risk impact rating, expressed on a numeric scale from 1 (lowest impact) to 5 (highest impact) in the context of a 5x5 risk matrix. Impact is used here as a synonym for consequence, another popular term used in risk analysis." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:risk_likelihood a owl:DatatypeProperty ;
    rdfs:label "risk-likelihood" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( d3f:RiskLikelihoodEnum xsd:string ) ] ;
    rdfs:seeAlso <https://www.cto.mil/wp-content/uploads/2024/05/RIO-2023-2-2.pdf> ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:definition "Risk likelihood rating, expressed on a numeric scale from 1 (lowest likelihood) to 5 (highest likelihood) in the context of a 5x5 risk matrix." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:runs a owl:DatatypeProperty ;
    rdfs:label "runs" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x runs y: To carry out a process or program y, as on a computer or a machine x; where y may be a large software assembly or a specific module or instruction.  Examples: \"run a new program on the Mac\"; \"the computer runs the application software\"." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:signed_by a owl:DatatypeProperty ;
    rdfs:label "signed-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:validated_by ;
    skos:definition "x signed-by y: The digital artifact x includes a signature generated by the entity y, certifying the authenticity and integrity of x. This relationship indicates that x has undergone a validation process by y, using cryptographic measures to ensure that x is trustworthy and unaltered since the signing by y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:signs a owl:DatatypeProperty ;
    rdfs:label "signs" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:validates ;
    skos:definition "x signs y: The entity x applies a digital signature to the digital artifact y, thereby asserting its validity, integrity, and authenticity. Typically, this involves cryptographic techniques to securely bind the signature to y, ensuring that y's contents have not been altered and are authentic as endorsed by x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:spoofs a owl:DatatypeProperty ;
    rdfs:label "spoofs" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x spoofs y: The technique x creates a fake instance of a digital artifact y; that is, y is a decoy, fake, or counterfeit." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:stage a owl:DatatypeProperty ;
    rdfs:label "stage" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( d3f:StageEnum xsd:string ) ] ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:start a owl:DatatypeProperty ;
    rdfs:label "start" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_process_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:strengthens a owl:DatatypeProperty ;
    rdfs:label "strengthens" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00165779-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x strengthens y: The technique x make digital artifact y resistant (to harm or misuse.)" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:summarizes a owl:DatatypeProperty ;
    rdfs:label "summarizes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02758570-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x summarizes y: The sensor x summarizes a set y of events concerning digital artifacts over time." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:suspends a owl:DatatypeProperty ;
    rdfs:label "suspends" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00543748-v> ;
    rdfs:subPropertyOf d3f:evicts ;
    skos:definition "x suspends y: The agent or technique x pauses entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:synonym a owl:DatatypeProperty ;
    rdfs:label "synonym" ;
    rdfs:range xsd:string ;
    skos:definition "an equivalent term." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:terminates a owl:DatatypeProperty ;
    rdfs:label "terminates" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00353480-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x terminates y: The technique x brings to an end or halt to some activity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:definition "The text of the document (i.e., terms of license.)" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:definition "A name given to the resource." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:todo a owl:DatatypeProperty ;
    rdfs:label "todo" ;
    rdfs:range xsd:string ;
    skos:definition "x todo y: The d3fend object x has a todo annotation y specific to the d3fend team. These may serve as a guide to implementing a low-level change; before work commences should be reflected in the tasks/issues.  Not for use external to the MITRE development team." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:transmits a owl:DatatypeProperty ;
    rdfs:label "transmits" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:altLabel "sends" ;
    skos:definition "x transmits y: The subject x actively emits object y onto a communication medium, rendering y observable and available for reception on that medium." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:unloads a owl:DatatypeProperty ;
    rdfs:label "unloads" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:evicts ;
    skos:definition "x unloads y: The technique or artifact performs the action of unloading some artifact (applications, kernel modules, or hardware drivers, etc.) from a computer's memory." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:unmounts a owl:DatatypeProperty ;
    rdfs:label "unmounts" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x unmounts y: An operation x removes the access via computer system's file system the availability of files and directories on a storage artifact y.  Unmounts reverse or undo prior mount operations." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:updates a owl:DatatypeProperty ;
    rdfs:label "updates" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:hardens ;
    skos:definition "x updates y: The technique x updates the software for component y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:use_limits a owl:DatatypeProperty ;
    rdfs:label "use-limits" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:limits ;
    skos:definition "x use-limits y: An entity x specifies a designated number of uses beyond which some entity y cannot function or must be terminated." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:used_by a owl:DatatypeProperty ;
    rdfs:label "used-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x used-by y: is inverse of y uses x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:valid a owl:DatatypeProperty ;
    rdfs:label "valid" ;
    dcterms:title "date valid" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:date_value ;
    skos:definition "Date (often a range) of validity of a resource." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:verifies a owl:DatatypeProperty ;
    rdfs:label "verifies" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00666401-v> ;
    rdfs:subPropertyOf d3f:analyzes ;
    skos:definition "x verifies y: A technique x confirms the truth of a digital artifact y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:definition "x version y: The product or service x has the version y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:weakness_of a owl:DatatypeProperty ;
    rdfs:label "weakness-of" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_weakness_of ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:windows_registry_key a owl:DatatypeProperty ;
    rdfs:label "windows-registry-key" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:windows_registry_data_property ;
    skos:altLabel "key" ;
    skos:definition "x value y: The key-value pair x has the key y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:windows_registry_value a owl:DatatypeProperty ;
    rdfs:label "windows-registry-value" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:windows_registry_data_property ;
    skos:altLabel "value" ;
    skos:definition "x value y: The key-value pair x has the data value y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:writes a owl:DatatypeProperty ;
    rdfs:label "writes" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:accesses ;
    skos:definition "x writes y: The subject x takes the action of writing to a digital artifact y to store data and placing it into persistent memory for later reference." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0017 a owl:Class ;
    rdfs:label "AML_T0017" ;
    d3f:attack-id "AML.T0017" ;
    dcterms:title "Develop Capabilities" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0017> ;
    rdfs:subClassOf d3f:ATLASResourceDevelopmentTechnique ;
    skos:altLabel "AML.T0017" ;
    skos:definition "Adversaries may develop their own capabilities to support operations. This process encompasses identifying requirements, building solutions, and deploying capabilities. Capabilities used to support attacks on AI-enabled systems are not necessarily AI-based themselves. Examples include setting up websites with adversarial information or creating Jupyter notebooks with obfuscated exfiltration code." ;
    skos:exactMatch d3f:AML.T0017,
        atlas:AML.T0017 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0052 a owl:Class ;
    rdfs:label "AML_T0052" ;
    d3f:attack-id "AML.T0052" ;
    dcterms:title "Phishing" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0052> ;
    rdfs:subClassOf d3f:ATLASInitialAccessTechnique ;
    skos:altLabel "AML.T0052" ;
    skos:definition """Adversaries may send phishing messages to gain access to victim systems. All forms of phishing are electronically delivered social engineering. Phishing can be targeted, known as spearphishing. In spearphishing, a specific individual, company, or industry will be targeted by the adversary. More generally, adversaries can conduct non-targeted phishing, such as in mass malware spam campaigns.

Generative AI, including LLMs that generate synthetic text, visual deepfakes of faces, and audio deepfakes of speech, is enabling adversaries to scale targeted phishing campaigns. LLMs can interact with users via text conversations and can be programmed with a meta prompt to phish for sensitive information. Deepfakes can be use in impersonation as an aid to phishing.""" ;
    skos:exactMatch d3f:AML.T0052,
        atlas:AML.T0052 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0067 a owl:Class ;
    rdfs:label "AML_T0067" ;
    d3f:attack-id "AML.T0067" ;
    dcterms:title "LLM Trusted Output Components Manipulation" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0067> ;
    rdfs:subClassOf d3f:ATLASDefenseEvasionTechnique ;
    skos:altLabel "AML.T0067" ;
    skos:definition """Adversaries may utilize prompts to a large language model (LLM) which manipulate various components of its response in order to make it appear trustworthy to the user. This helps the adversary continue to operate in the victim's environment and evade detection by the users it interacts with.

The LLM may be instructed to tailor its language to appear more trustworthy to the user or attempt to manipulate the user to take certain actions. Other response components that could be manipulated include links, recommended follow-up actions, retrieved document metadata, and [Citations](/techniques/AML.T0067.000).""" ;
    skos:exactMatch d3f:AML.T0067,
        atlas:AML.T0067 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0091 a owl:Class ;
    rdfs:label "AML_T0091" ;
    d3f:attack-id "AML.T0091" ;
    dcterms:title "Use Alternate Authentication Material" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0091> ;
    rdfs:subClassOf d3f:ATLASLateralMovementTechnique ;
    skos:altLabel "AML.T0091" ;
    skos:definition """Adversaries may use alternate authentication material, such as password hashes, Kerberos tickets, and application access tokens, in order to move laterally within an environment and bypass normal system access controls.

AI services commonly use alternate authentication material as a primary means for users to make queries, making them vulnerable to this technique.""" ;
    skos:exactMatch d3f:AML.T0091,
        atlas:AML.T0091 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ARIMAModel a owl:Class ;
    rdfs:label "ARIMAModel" ;
    d3f:d3fend-id "D3A-AM" ;
