    skos:exactMatch d3f:CWE-561,
        cwe:CWE-561 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE562 a owl:Class ;
    rdfs:label "CWE_562" ;
    d3f:cwe-id "CWE-562" ;
    dcterms:title "Return of Stack Variable Address" ;
    rdfs:subClassOf d3f:CWE758 ;
    skos:altLabel "CWE-562" ;
    skos:definition "A function returns the address of a stack variable, which will cause unintended program behavior, typically in the form of a crash." ;
    skos:exactMatch d3f:CWE-562,
        cwe:CWE-562 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE563 a owl:Class ;
    rdfs:label "CWE_563" ;
    d3f:cwe-id "CWE-563" ;
    d3f:synonym "Unused Variable" ;
    dcterms:title "Assignment to Variable without Use" ;
    rdfs:subClassOf d3f:CWE1164 ;
    skos:altLabel "CWE-563" ;
    skos:definition "The variable's value is assigned but never used, making it a dead store." ;
    skos:exactMatch d3f:CWE-563,
        cwe:CWE-563 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE564 a owl:Class ;
    rdfs:label "CWE_564" ;
    d3f:cwe-id "CWE-564" ;
    dcterms:title "SQL Injection: Hibernate" ;
    rdfs:subClassOf d3f:CWE89 ;
    skos:altLabel "CWE-564" ;
    skos:definition "Using Hibernate to execute a dynamic SQL statement built with user-controlled input can allow an attacker to modify the statement's meaning or to execute arbitrary SQL commands." ;
    skos:exactMatch d3f:CWE-564,
        cwe:CWE-564 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE566 a owl:Class ;
    rdfs:label "CWE_566" ;
    d3f:cwe-id "CWE-566" ;
    dcterms:title "Authorization Bypass Through User-Controlled SQL Primary Key" ;
    rdfs:subClassOf d3f:CWE639 ;
    skos:altLabel "CWE-566" ;
    skos:definition "The product uses a database table that includes records that should not be accessible to an actor, but it executes a SQL statement with a primary key that can be controlled by that actor." ;
    skos:exactMatch d3f:CWE-566,
        cwe:CWE-566 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE567 a owl:Class ;
    rdfs:label "CWE_567" ;
    d3f:cwe-id "CWE-567" ;
    dcterms:title "Unsynchronized Access to Shared Data in a Multithreaded Context" ;
    rdfs:subClassOf d3f:CWE820 ;
    skos:altLabel "CWE-567" ;
    skos:definition "The product does not properly synchronize shared data, such as static variables across threads, which can lead to undefined behavior and unpredictable data changes." ;
    skos:exactMatch d3f:CWE-567,
        cwe:CWE-567 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE568 a owl:Class ;
    rdfs:label "CWE_568" ;
    d3f:cwe-id "CWE-568" ;
    dcterms:title "finalize() Method Without super.finalize()" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE573 ],
        d3f:CWE459 ;
    skos:altLabel "CWE-568" ;
    skos:definition "The product contains a finalize() method that does not call super.finalize()." ;
    skos:exactMatch d3f:CWE-568,
        cwe:CWE-568 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE57 a owl:Class ;
    rdfs:label "CWE_57" ;
    d3f:cwe-id "CWE-57" ;
    dcterms:title "Path Equivalence: 'fakedir/../realdir/filename'" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-57" ;
    skos:definition "The product contains protection mechanisms to restrict access to 'realdir/filename', but it constructs pathnames using external input in the form of 'fakedir/../realdir/filename' that are not handled by those mechanisms. This allows attackers to perform unauthorized actions against the targeted file." ;
    skos:exactMatch d3f:CWE-57,
        cwe:CWE-57 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE570 a owl:Class ;
    rdfs:label "CWE_570" ;
    d3f:cwe-id "CWE-570" ;
    dcterms:title "Expression is Always False" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-570" ;
    skos:definition "The product contains an expression that will always evaluate to false." ;
    skos:exactMatch d3f:CWE-570,
        cwe:CWE-570 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE571 a owl:Class ;
    rdfs:label "CWE_571" ;
    d3f:cwe-id "CWE-571" ;
    dcterms:title "Expression is Always True" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-571" ;
    skos:definition "The product contains an expression that will always evaluate to true." ;
    skos:exactMatch d3f:CWE-571,
        cwe:CWE-571 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE572 a owl:Class ;
    rdfs:label "CWE_572" ;
    d3f:cwe-id "CWE-572" ;
    dcterms:title "Call to Thread run() instead of start()" ;
    rdfs:subClassOf d3f:CWE821 ;
    skos:altLabel "CWE-572" ;
    skos:definition "The product calls a thread's run() method instead of calling start(), which causes the code to run in the thread of the caller instead of the callee." ;
    skos:exactMatch d3f:CWE-572,
        cwe:CWE-572 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE574 a owl:Class ;
    rdfs:label "CWE_574" ;
    d3f:cwe-id "CWE-574" ;
    dcterms:title "EJB Bad Practices: Use of Synchronization Primitives" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE821 ],
        d3f:CWE695 ;
    skos:altLabel "CWE-574" ;
    skos:definition "The product violates the Enterprise JavaBeans (EJB) specification by using thread synchronization primitives." ;
    skos:exactMatch d3f:CWE-574,
        cwe:CWE-574 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE575 a owl:Class ;
    rdfs:label "CWE_575" ;
    d3f:cwe-id "CWE-575" ;
    dcterms:title "EJB Bad Practices: Use of AWT Swing" ;
    rdfs:subClassOf d3f:CWE695 ;
    skos:altLabel "CWE-575" ;
    skos:definition "The product violates the Enterprise JavaBeans (EJB) specification by using AWT/Swing." ;
    skos:exactMatch d3f:CWE-575,
        cwe:CWE-575 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE576 a owl:Class ;
    rdfs:label "CWE_576" ;
    d3f:cwe-id "CWE-576" ;
    dcterms:title "EJB Bad Practices: Use of Java I/O" ;
    rdfs:subClassOf d3f:CWE695 ;
    skos:altLabel "CWE-576" ;
    skos:definition "The product violates the Enterprise JavaBeans (EJB) specification by using the java.io package." ;
    skos:exactMatch d3f:CWE-576,
        cwe:CWE-576 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE577 a owl:Class ;
    rdfs:label "CWE_577" ;
    d3f:cwe-id "CWE-577" ;
    dcterms:title "EJB Bad Practices: Use of Sockets" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-577" ;
    skos:definition "The product violates the Enterprise JavaBeans (EJB) specification by using sockets." ;
    skos:exactMatch d3f:CWE-577,
        cwe:CWE-577 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE578 a owl:Class ;
    rdfs:label "CWE_578" ;
    d3f:cwe-id "CWE-578" ;
    dcterms:title "EJB Bad Practices: Use of Class Loader" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-578" ;
    skos:definition "The product violates the Enterprise JavaBeans (EJB) specification by using the class loader." ;
    skos:exactMatch d3f:CWE-578,
        cwe:CWE-578 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE579 a owl:Class ;
    rdfs:label "CWE_579" ;
    d3f:cwe-id "CWE-579" ;
    dcterms:title "J2EE Bad Practices: Non-serializable Object Stored in Session" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-579" ;
    skos:definition "The product stores a non-serializable object as an HttpSession attribute, which can hurt reliability." ;
    skos:exactMatch d3f:CWE-579,
        cwe:CWE-579 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE58 a owl:Class ;
    rdfs:label "CWE_58" ;
    d3f:cwe-id "CWE-58" ;
    dcterms:title "Path Equivalence: Windows 8.3 Filename" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-58" ;
    skos:definition "The product contains a protection mechanism that restricts access to a long filename on a Windows operating system, but it does not properly restrict access to the equivalent short \"8.3\" filename." ;
    skos:exactMatch d3f:CWE-58,
        cwe:CWE-58 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE580 a owl:Class ;
    rdfs:label "CWE_580" ;
    d3f:cwe-id "CWE-580" ;
    dcterms:title "clone() Method Without super.clone()" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE664 ],
        d3f:CWE573 ;
    skos:altLabel "CWE-580" ;
    skos:definition "The product contains a clone() method that does not call super.clone() to obtain the new object." ;
    skos:exactMatch d3f:CWE-580,
        cwe:CWE-580 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE581 a owl:Class ;
    rdfs:label "CWE_581" ;
    d3f:cwe-id "CWE-581" ;
    dcterms:title "Object Model Violation: Just One of Equals and Hashcode Defined" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE697 ],
        d3f:CWE573 ;
    skos:altLabel "CWE-581" ;
    skos:definition "The product does not maintain equal hashcodes for equal objects." ;
    skos:exactMatch d3f:CWE-581,
        cwe:CWE-581 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE582 a owl:Class ;
    rdfs:label "CWE_582" ;
    d3f:cwe-id "CWE-582" ;
    dcterms:title "Array Declared Public, Final, and Static" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-582" ;
    skos:definition "The product declares an array public, final, and static, which is not sufficient to prevent the array's contents from being modified." ;
    skos:exactMatch d3f:CWE-582,
        cwe:CWE-582 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE583 a owl:Class ;
    rdfs:label "CWE_583" ;
    d3f:cwe-id "CWE-583" ;
    dcterms:title "finalize() Method Declared Public" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-583" ;
    skos:definition "The product violates secure coding principles for mobile code by declaring a finalize() method public." ;
    skos:exactMatch d3f:CWE-583,
        cwe:CWE-583 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE584 a owl:Class ;
    rdfs:label "CWE_584" ;
    d3f:cwe-id "CWE-584" ;
    dcterms:title "Return Inside Finally Block" ;
    rdfs:subClassOf d3f:CWE705 ;
    skos:altLabel "CWE-584" ;
    skos:definition "The code has a return statement inside a finally block, which will cause any thrown exception in the try block to be discarded." ;
    skos:exactMatch d3f:CWE-584,
        cwe:CWE-584 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE585 a owl:Class ;
    rdfs:label "CWE_585" ;
    d3f:cwe-id "CWE-585" ;
    dcterms:title "Empty Synchronized Block" ;
    rdfs:subClassOf d3f:CWE1071 ;
    skos:altLabel "CWE-585" ;
    skos:definition "The product contains an empty synchronized block." ;
    skos:exactMatch d3f:CWE-585,
        cwe:CWE-585 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE586 a owl:Class ;
    rdfs:label "CWE_586" ;
    d3f:cwe-id "CWE-586" ;
    dcterms:title "Explicit Call to Finalize()" ;
    rdfs:subClassOf d3f:CWE1076 ;
    skos:altLabel "CWE-586" ;
    skos:definition "The product makes an explicit call to the finalize() method from outside the finalizer." ;
    skos:exactMatch d3f:CWE-586,
        cwe:CWE-586 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE587 a owl:Class ;
    rdfs:label "CWE_587" ;
    d3f:cwe-id "CWE-587" ;
    dcterms:title "Assignment of a Fixed Address to a Pointer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE758 ],
        d3f:CWE344 ;
    skos:altLabel "CWE-587" ;
    skos:definition "The product sets a pointer to a specific address other than NULL or 0." ;
    skos:exactMatch d3f:CWE-587,
        cwe:CWE-587 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE588 a owl:Class ;
    rdfs:label "CWE_588" ;
    d3f:cwe-id "CWE-588" ;
    dcterms:title "Attempt to Access Child of a Non-structure Pointer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE758 ],
        d3f:CWE704 ;
    skos:altLabel "CWE-588" ;
    skos:definition "Casting a non-structure type to a structure type and accessing a field can lead to memory access errors or data corruption." ;
    skos:exactMatch d3f:CWE-588,
        cwe:CWE-588 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE589 a owl:Class ;
    rdfs:label "CWE_589" ;
    d3f:cwe-id "CWE-589" ;
    dcterms:title "Call to Non-ubiquitous API" ;
    rdfs:subClassOf d3f:CWE474 ;
    skos:altLabel "CWE-589" ;
    skos:definition "The product uses an API function that does not exist on all versions of the target platform. This could cause portability problems or inconsistencies that allow denial of service or other consequences." ;
    skos:exactMatch d3f:CWE-589,
        cwe:CWE-589 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE590 a owl:Class ;
    rdfs:label "CWE_590" ;
    d3f:cwe-id "CWE-590" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Free of Memory not on the Heap" ;
    rdfs:subClassOf d3f:CWE762 ;
    skos:altLabel "CWE-590" ;
    skos:definition "The product calls free() on a pointer to memory that was not allocated using associated heap allocation functions such as malloc(), calloc(), or realloc()." ;
    skos:exactMatch d3f:CWE-590,
        cwe:CWE-590 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE591 a owl:Class ;
    rdfs:label "CWE_591" ;
    d3f:cwe-id "CWE-591" ;
    dcterms:title "Sensitive Data Storage in Improperly Locked Memory" ;
    rdfs:subClassOf d3f:CWE413 ;
    skos:altLabel "CWE-591" ;
    skos:definition "The product stores sensitive data in memory that is not locked, or that has been incorrectly locked, which might cause the memory to be written to swap files on disk by the virtual memory manager. This can make the data more accessible to external actors." ;
    skos:exactMatch d3f:CWE-591,
        cwe:CWE-591 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE593 a owl:Class ;
    rdfs:label "CWE_593" ;
    d3f:cwe-id "CWE-593" ;
    dcterms:title "Authentication Bypass: OpenSSL CTX Object Modified after SSL Objects are Created" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE666 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-593" ;
    skos:definition "The product modifies the SSL context after connection creation has begun." ;
    skos:exactMatch d3f:CWE-593,
        cwe:CWE-593 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE594 a owl:Class ;
    rdfs:label "CWE_594" ;
    d3f:cwe-id "CWE-594" ;
    dcterms:title "J2EE Framework: Saving Unserializable Objects to Disk" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE710 ],
        d3f:CWE1076 ;
    skos:altLabel "CWE-594" ;
    skos:definition "When the J2EE container attempts to write unserializable objects to disk there is no guarantee that the process will complete successfully." ;
    skos:exactMatch d3f:CWE-594,
        cwe:CWE-594 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE597 a owl:Class ;
    rdfs:label "CWE_597" ;
    d3f:cwe-id "CWE-597" ;
    dcterms:title "Use of Wrong Operator in String Comparison" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE595 ],
        d3f:CWE480 ;
    skos:altLabel "CWE-597" ;
    skos:definition "The product uses the wrong operator when comparing a string, such as using \"==\" when the .equals() method should be used instead." ;
    skos:exactMatch d3f:CWE-597,
        cwe:CWE-597 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE598 a owl:Class ;
    rdfs:label "CWE_598" ;
    d3f:cwe-id "CWE-598" ;
    dcterms:title "Use of GET Request Method With Sensitive Query Strings" ;
    rdfs:subClassOf d3f:CWE201 ;
    skos:altLabel "CWE-598" ;
    skos:definition "The web application uses the HTTP GET method to process a request and includes sensitive information in the query string of that request." ;
    skos:exactMatch d3f:CWE-598,
        cwe:CWE-598 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE599 a owl:Class ;
    rdfs:label "CWE_599" ;
    d3f:cwe-id "CWE-599" ;
    dcterms:title "Missing Validation of OpenSSL Certificate" ;
    rdfs:subClassOf d3f:CWE295 ;
    skos:altLabel "CWE-599" ;
    skos:definition "The product uses OpenSSL and trusts or uses a certificate without using the SSL_get_verify_result() function to ensure that the certificate satisfies all necessary security requirements." ;
    skos:exactMatch d3f:CWE-599,
        cwe:CWE-599 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE6 a owl:Class ;
    rdfs:label "CWE_6" ;
    d3f:cwe-id "CWE-6" ;
    dcterms:title "J2EE Misconfiguration: Insufficient Session-ID Length" ;
    rdfs:subClassOf d3f:CWE334 ;
    skos:altLabel "CWE-6" ;
    skos:definition "The J2EE application is configured to use an insufficient session ID length." ;
    skos:exactMatch d3f:CWE-6,
        cwe:CWE-6 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE600 a owl:Class ;
    rdfs:label "CWE_600" ;
    d3f:cwe-id "CWE-600" ;
    d3f:synonym "Missing Catch Block" ;
    dcterms:title "Uncaught Exception in Servlet" ;
    rdfs:subClassOf d3f:CWE248 ;
    skos:altLabel "CWE-600" ;
    skos:definition "The Servlet does not catch all exceptions, which may reveal sensitive debugging information." ;
    skos:exactMatch d3f:CWE-600,
        cwe:CWE-600 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE601 a owl:Class ;
    rdfs:label "CWE_601" ;
    d3f:cwe-id "CWE-601" ;
    d3f:synonym "Cross-domain Redirect" ;
    dcterms:title "URL Redirection to Untrusted Site ('Open Redirect')" ;
    rdfs:subClassOf d3f:CWE610 ;
    skos:altLabel "CWE-601" ;
    skos:definition "The web application accepts a user-controlled input that specifies a link to an external site, and uses that link in a redirect." ;
    skos:exactMatch d3f:CWE-601,
        cwe:CWE-601 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE603 a owl:Class ;
    rdfs:label "CWE_603" ;
    d3f:cwe-id "CWE-603" ;
    dcterms:title "Use of Client-Side Authentication" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE602 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-603" ;
    skos:definition "A client/server product performs authentication within client code but not in server code, allowing server-side authentication to be bypassed via a modified client that omits the authentication check." ;
    skos:exactMatch d3f:CWE-603,
        cwe:CWE-603 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE605 a owl:Class ;
    rdfs:label "CWE_605" ;
    d3f:cwe-id "CWE-605" ;
    dcterms:title "Multiple Binds to the Same Port" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE675 ],
        d3f:CWE666 ;
    skos:altLabel "CWE-605" ;
    skos:definition "When multiple sockets are allowed to bind to the same port, other services on that port may be stolen or spoofed." ;
    skos:exactMatch d3f:CWE-605,
        cwe:CWE-605 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE606 a owl:Class ;
    rdfs:label "CWE_606" ;
    d3f:cwe-id "CWE-606" ;
    dcterms:title "Unchecked Input for Loop Condition" ;
    rdfs:subClassOf d3f:CWE1284 ;
    skos:altLabel "CWE-606" ;
    skos:definition "The product does not properly check inputs that are used for loop conditions, potentially leading to a denial of service or other consequences because of excessive looping." ;
    skos:exactMatch d3f:CWE-606,
        cwe:CWE-606 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE607 a owl:Class ;
    rdfs:label "CWE_607" ;
    d3f:cwe-id "CWE-607" ;
    dcterms:title "Public Static Final Field References Mutable Object" ;
    rdfs:subClassOf d3f:CWE471 ;
    skos:altLabel "CWE-607" ;
    skos:definition "A public or protected static final field references a mutable object, which allows the object to be changed by malicious code, or accidentally from another package." ;
    skos:exactMatch d3f:CWE-607,
        cwe:CWE-607 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE608 a owl:Class ;
    rdfs:label "CWE_608" ;
    d3f:cwe-id "CWE-608" ;
    dcterms:title "Struts: Non-private Field in ActionForm Class" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-608" ;
    skos:definition "An ActionForm class contains a field that has not been declared private, which can be accessed without using a setter or getter." ;
    skos:exactMatch d3f:CWE-608,
        cwe:CWE-608 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE609 a owl:Class ;
    rdfs:label "CWE_609" ;
    d3f:cwe-id "CWE-609" ;
    dcterms:title "Double-Checked Locking" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-609" ;
    skos:definition "The product uses double-checked locking to access a resource without the overhead of explicit synchronization, but the locking is insufficient." ;
    skos:exactMatch d3f:CWE-609,
        cwe:CWE-609 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE61 a owl:Class ;
    rdfs:label "CWE_61" ;
    d3f:cwe-id "CWE-61" ;
    d3f:synonym "Symlink following" ;
    dcterms:title "UNIX Symbolic Link (Symlink) Following" ;
    rdfs:subClassOf d3f:CWE59 ;
    skos:altLabel "CWE-61" ;
    skos:definition "The product, when opening a file or directory, does not sufficiently account for when the file is a symbolic link that resolves to a target outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    skos:exactMatch d3f:CWE-61,
        cwe:CWE-61 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE611 a owl:Class ;
    rdfs:label "CWE_611" ;
    d3f:cwe-id "CWE-611" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "XXE" ;
    dcterms:title "Improper Restriction of XML External Entity Reference" ;
    rdfs:subClassOf d3f:CWE610 ;
    skos:altLabel "CWE-611" ;
    skos:definition "The product processes an XML document that can contain XML entities with URIs that resolve to documents outside of the intended sphere of control, causing the product to embed incorrect documents into its output." ;
    skos:exactMatch d3f:CWE-611,
        cwe:CWE-611 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE612 a owl:Class ;
    rdfs:label "CWE_612" ;
    d3f:cwe-id "CWE-612" ;
    dcterms:title "Improper Authorization of Index Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE1230 ;
    skos:altLabel "CWE-612" ;
    skos:definition "The product creates a search index of private or sensitive documents, but it does not properly limit index access to actors who are authorized to see the original information." ;
    skos:exactMatch d3f:CWE-612,
        cwe:CWE-612 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE613 a owl:Class ;
    rdfs:label "CWE_613" ;
    d3f:cwe-id "CWE-613" ;
    dcterms:title "Insufficient Session Expiration" ;
    rdfs:subClassOf d3f:CWE672 ;
    skos:altLabel "CWE-613" ;
    skos:definition "According to WASC, \"Insufficient Session Expiration is when a web site permits an attacker to reuse old session credentials or session IDs for authorization.\"" ;
    skos:exactMatch d3f:CWE-613,
        cwe:CWE-613 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE614 a owl:Class ;
    rdfs:label "CWE_614" ;
    d3f:cwe-id "CWE-614" ;
    dcterms:title "Sensitive Cookie in HTTPS Session Without 'Secure' Attribute" ;
    rdfs:subClassOf d3f:CWE319 ;
    skos:altLabel "CWE-614" ;
    skos:definition "The Secure attribute for sensitive cookies in HTTPS sessions is not set, which could cause the user agent to send those cookies in plaintext over an HTTP session." ;
    skos:exactMatch d3f:CWE-614,
        cwe:CWE-614 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE615 a owl:Class ;
    rdfs:label "CWE_615" ;
    d3f:cwe-id "CWE-615" ;
    dcterms:title "Inclusion of Sensitive Information in Source Code Comments" ;
    rdfs:subClassOf d3f:CWE540 ;
    skos:altLabel "CWE-615" ;
    skos:definition "While adding general comments is very useful, some programmers tend to leave important data, such as: filenames related to the web application, old links or links which were not meant to be browsed by users, old code fragments, etc." ;
    skos:exactMatch d3f:CWE-615,
        cwe:CWE-615 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE616 a owl:Class ;
    rdfs:label "CWE_616" ;
    d3f:cwe-id "CWE-616" ;
    dcterms:title "Incomplete Identification of Uploaded File Variables (PHP)" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-616" ;
    skos:definition "The PHP application uses an old method for processing uploaded files by referencing the four global variables that are set for each file (e.g. $varname, $varname_size, $varname_name, $varname_type). These variables could be overwritten by attackers, causing the application to process unauthorized files." ;
    skos:exactMatch d3f:CWE-616,
        cwe:CWE-616 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE617 a owl:Class ;
    rdfs:label "CWE_617" ;
    d3f:cwe-id "CWE-617" ;
    d3f:synonym "assertion failure" ;
    dcterms:title "Reachable Assertion" ;
    rdfs:subClassOf d3f:CWE670 ;
    skos:altLabel "CWE-617" ;
    skos:definition "The product contains an assert() or similar statement that can be triggered by an attacker, which leads to an application exit or other behavior that is more severe than necessary." ;
    skos:exactMatch d3f:CWE-617,
        cwe:CWE-617 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE618 a owl:Class ;
    rdfs:label "CWE_618" ;
    d3f:cwe-id "CWE-618" ;
    dcterms:title "Exposed Unsafe ActiveX Method" ;
    rdfs:subClassOf d3f:CWE749 ;
    skos:altLabel "CWE-618" ;
    skos:definition "An ActiveX control is intended for use in a web browser, but it exposes dangerous methods that perform actions that are outside of the browser's security model (e.g. the zone or domain)." ;
    skos:exactMatch d3f:CWE-618,
        cwe:CWE-618 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE619 a owl:Class ;
    rdfs:label "CWE_619" ;
    d3f:cwe-id "CWE-619" ;
    dcterms:title "Dangling Database Cursor ('Cursor Injection')" ;
    rdfs:subClassOf d3f:CWE402 ;
    skos:altLabel "CWE-619" ;
    skos:definition "If a database cursor is not closed properly, then it could become accessible to other users while retaining the same privileges that were originally assigned, leaving the cursor \"dangling.\"" ;
    skos:exactMatch d3f:CWE-619,
        cwe:CWE-619 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE62 a owl:Class ;
    rdfs:label "CWE_62" ;
    d3f:cwe-id "CWE-62" ;
    dcterms:title "UNIX Hard Link" ;
    rdfs:subClassOf d3f:CWE59 ;
    skos:altLabel "CWE-62" ;
    skos:definition "The product, when opening a file or directory, does not sufficiently account for when the name is associated with a hard link to a target that is outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    skos:exactMatch d3f:CWE-62,
        cwe:CWE-62 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE620 a owl:Class ;
    rdfs:label "CWE_620" ;
    d3f:cwe-id "CWE-620" ;
    dcterms:title "Unverified Password Change" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-620" ;
    skos:definition "When setting a new password for a user, the product does not require knowledge of the original password, or using another form of authentication." ;
    skos:exactMatch d3f:CWE-620,
        cwe:CWE-620 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE621 a owl:Class ;
    rdfs:label "CWE_621" ;
    d3f:cwe-id "CWE-621" ;
    d3f:synonym "Variable overwrite" ;
    dcterms:title "Variable Extraction Error" ;
    rdfs:subClassOf d3f:CWE914 ;
    skos:altLabel "CWE-621" ;
    skos:definition "The product uses external input to determine the names of variables into which information is extracted, without verifying that the names of the specified variables are valid. This could cause the program to overwrite unintended variables." ;
    skos:exactMatch d3f:CWE-621,
        cwe:CWE-621 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE622 a owl:Class ;
    rdfs:label "CWE_622" ;
    d3f:cwe-id "CWE-622" ;
    dcterms:title "Improper Validation of Function Hook Arguments" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-622" ;
    skos:definition "The product adds hooks to user-accessible API functions, but it does not properly validate the arguments. This could lead to resultant vulnerabilities." ;
    skos:exactMatch d3f:CWE-622,
        cwe:CWE-622 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE623 a owl:Class ;
    rdfs:label "CWE_623" ;
    d3f:cwe-id "CWE-623" ;
    dcterms:title "Unsafe ActiveX Control Marked Safe For Scripting" ;
    rdfs:subClassOf d3f:CWE267 ;
    skos:altLabel "CWE-623" ;
    skos:definition "An ActiveX control is intended for restricted use, but it has been marked as safe-for-scripting." ;
    skos:exactMatch d3f:CWE-623,
        cwe:CWE-623 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE624 a owl:Class ;
    rdfs:label "CWE_624" ;
    d3f:cwe-id "CWE-624" ;
    dcterms:title "Executable Regular Expression Error" ;
    rdfs:subClassOf d3f:CWE77 ;
    skos:altLabel "CWE-624" ;
    skos:definition "The product uses a regular expression that either (1) contains an executable component with user-controlled inputs, or (2) allows a user to enable execution by inserting pattern modifiers." ;
    skos:exactMatch d3f:CWE-624,
        cwe:CWE-624 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE626 a owl:Class ;
    rdfs:label "CWE_626" ;
    d3f:cwe-id "CWE-626" ;
    dcterms:title "Null Byte Interaction Error (Poison Null Byte)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE436 ],
        d3f:CWE147 ;
    skos:altLabel "CWE-626" ;
    skos:definition "The product does not properly handle null bytes or NUL characters when passing data between different representations or components." ;
    skos:exactMatch d3f:CWE-626,
        cwe:CWE-626 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE627 a owl:Class ;
    rdfs:label "CWE_627" ;
    d3f:cwe-id "CWE-627" ;
    d3f:synonym "Dynamic evaluation" ;
    dcterms:title "Dynamic Variable Evaluation" ;
    rdfs:subClassOf d3f:CWE914 ;
    skos:altLabel "CWE-627" ;
    skos:definition "In a language where the user can influence the name of a variable at runtime, if the variable names are not controlled, an attacker can read or write to arbitrary variables, or access arbitrary functions." ;
    skos:exactMatch d3f:CWE-627,
        cwe:CWE-627 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE637 a owl:Class ;
    rdfs:label "CWE_637" ;
    d3f:cwe-id "CWE-637" ;
    d3f:synonym "Unnecessary Complexity" ;
    dcterms:title "Unnecessary Complexity in Protection Mechanism (Not Using 'Economy of Mechanism')" ;
    rdfs:subClassOf d3f:CWE657 ;
    skos:altLabel "CWE-637" ;
    skos:definition "The product uses a more complex mechanism than necessary, which could lead to resultant weaknesses when the mechanism is not correctly understood, modeled, configured, implemented, or used." ;
    skos:exactMatch d3f:CWE-637,
        cwe:CWE-637 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE64 a owl:Class ;
    rdfs:label "CWE_64" ;
    d3f:cwe-id "CWE-64" ;
    d3f:synonym "Windows symbolic link following" ;
    dcterms:title "Windows Shortcut Following (.LNK)" ;
    rdfs:subClassOf d3f:CWE59 ;
    skos:altLabel "CWE-64" ;
    skos:definition "The product, when opening a file or directory, does not sufficiently handle when the file is a Windows shortcut (.LNK) whose target is outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    skos:exactMatch d3f:CWE-64,
        cwe:CWE-64 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE640 a owl:Class ;
    rdfs:label "CWE_640" ;
    d3f:cwe-id "CWE-640" ;
    dcterms:title "Weak Password Recovery Mechanism for Forgotten Password" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-640" ;
    skos:definition "The product contains a mechanism for users to recover or change their passwords without knowing the original password, but the mechanism is weak." ;
    skos:exactMatch d3f:CWE-640,
        cwe:CWE-640 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE641 a owl:Class ;
    rdfs:label "CWE_641" ;
    d3f:cwe-id "CWE-641" ;
    dcterms:title "Improper Restriction of Names for Files and Other Resources" ;
    rdfs:subClassOf d3f:CWE99 ;
    skos:altLabel "CWE-641" ;
    skos:definition "The product constructs the name of a file or other resource using input from an upstream component, but it does not restrict or incorrectly restricts the resulting name." ;
    skos:exactMatch d3f:CWE-641,
        cwe:CWE-641 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE643 a owl:Class ;
    rdfs:label "CWE_643" ;
    d3f:cwe-id "CWE-643" ;
    dcterms:title "Improper Neutralization of Data within XPath Expressions ('XPath Injection')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE943 ],
        d3f:CWE91 ;
    skos:altLabel "CWE-643" ;
    skos:definition "The product uses external input to dynamically construct an XPath expression used to retrieve data from an XML database, but it does not neutralize or incorrectly neutralizes that input. This allows an attacker to control the structure of the query." ;
    skos:exactMatch d3f:CWE-643,
        cwe:CWE-643 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE644 a owl:Class ;
    rdfs:label "CWE_644" ;
    d3f:cwe-id "CWE-644" ;
    dcterms:title "Improper Neutralization of HTTP Headers for Scripting Syntax" ;
    rdfs:subClassOf d3f:CWE116 ;
    skos:altLabel "CWE-644" ;
    skos:definition "The product does not neutralize or incorrectly neutralizes web scripting syntax in HTTP headers that can be used by web browser components that can process raw headers, such as Flash." ;
    skos:exactMatch d3f:CWE-644,
        cwe:CWE-644 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE645 a owl:Class ;
    rdfs:label "CWE_645" ;
    d3f:cwe-id "CWE-645" ;
    dcterms:title "Overly Restrictive Account Lockout Mechanism" ;
    rdfs:subClassOf d3f:CWE287 ;
    skos:altLabel "CWE-645" ;
    skos:definition "The product contains an account lockout protection mechanism, but the mechanism is too restrictive and can be triggered too easily, which allows attackers to deny service to legitimate users by causing their accounts to be locked out." ;
    skos:exactMatch d3f:CWE-645,
        cwe:CWE-645 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE646 a owl:Class ;
    rdfs:label "CWE_646" ;
    d3f:cwe-id "CWE-646" ;
    dcterms:title "Reliance on File Name or Extension of Externally-Supplied File" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-646" ;
    skos:definition "The product allows a file to be uploaded, but it relies on the file name or extension of the file to determine the appropriate behaviors. This could be used by attackers to cause the file to be misclassified and processed in a dangerous fashion." ;
    skos:exactMatch d3f:CWE-646,
        cwe:CWE-646 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE647 a owl:Class ;
    rdfs:label "CWE_647" ;
    d3f:cwe-id "CWE-647" ;
    dcterms:title "Use of Non-Canonical URL Paths for Authorization Decisions" ;
    rdfs:subClassOf d3f:CWE863 ;
    skos:altLabel "CWE-647" ;
    skos:definition "The product defines policy namespaces and makes authorization decisions based on the assumption that a URL is canonical. This can allow a non-canonical URL to bypass the authorization." ;
    skos:exactMatch d3f:CWE-647,
        cwe:CWE-647 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE648 a owl:Class ;
    rdfs:label "CWE_648" ;
    d3f:cwe-id "CWE-648" ;
    dcterms:title "Incorrect Use of Privileged APIs" ;
    rdfs:subClassOf d3f:CWE269 ;
    skos:altLabel "CWE-648" ;
    skos:definition "The product does not conform to the API requirements for a function call that requires extra privileges. This could allow attackers to gain privileges by causing the function to be called incorrectly." ;
    skos:exactMatch d3f:CWE-648,
        cwe:CWE-648 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE649 a owl:Class ;
    rdfs:label "CWE_649" ;
    d3f:cwe-id "CWE-649" ;
    dcterms:title "Reliance on Obfuscation or Encryption of Security-Relevant Inputs without Integrity Checking" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-649" ;
    skos:definition "The product uses obfuscation or encryption of inputs that should not be mutable by an external actor, but the product does not use integrity checks to detect if those inputs have been modified." ;
    skos:exactMatch d3f:CWE-649,
        cwe:CWE-649 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE65 a owl:Class ;
    rdfs:label "CWE_65" ;
    d3f:cwe-id "CWE-65" ;
    dcterms:title "Windows Hard Link" ;
    rdfs:subClassOf d3f:CWE59 ;
    skos:altLabel "CWE-65" ;
    skos:definition "The product, when opening a file or directory, does not sufficiently handle when the name is associated with a hard link to a target that is outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    skos:exactMatch d3f:CWE-65,
        cwe:CWE-65 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE650 a owl:Class ;
    rdfs:label "CWE_650" ;
    d3f:cwe-id "CWE-650" ;
    dcterms:title "Trusting HTTP Permission Methods on the Server Side" ;
    rdfs:subClassOf d3f:CWE436 ;
    skos:altLabel "CWE-650" ;
    skos:definition "The server contains a protection mechanism that assumes that any URI that is accessed using HTTP GET will not cause a state change to the associated resource. This might allow attackers to bypass intended access restrictions and conduct resource modification and deletion attacks, since some applications allow GET to modify state." ;
    skos:exactMatch d3f:CWE-650,
        cwe:CWE-650 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE651 a owl:Class ;
    rdfs:label "CWE_651" ;
    d3f:cwe-id "CWE-651" ;
    dcterms:title "Exposure of WSDL File Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE538 ;
    skos:altLabel "CWE-651" ;
    skos:definition "The Web services architecture may require exposing a Web Service Definition Language (WSDL) file that contains information on the publicly accessible services and how callers of these services should interact with them (e.g. what parameters they expect and what types they return)." ;
    skos:exactMatch d3f:CWE-651,
        cwe:CWE-651 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE652 a owl:Class ;
    rdfs:label "CWE_652" ;
    d3f:cwe-id "CWE-652" ;
    dcterms:title "Improper Neutralization of Data within XQuery Expressions ('XQuery Injection')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE943 ],
        d3f:CWE91 ;
    skos:altLabel "CWE-652" ;
    skos:definition "The product uses external input to dynamically construct an XQuery expression used to retrieve data from an XML database, but it does not neutralize or incorrectly neutralizes that input. This allows an attacker to control the structure of the query." ;
    skos:exactMatch d3f:CWE-652,
        cwe:CWE-652 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE655 a owl:Class ;
    rdfs:label "CWE_655" ;
    d3f:cwe-id "CWE-655" ;
    dcterms:title "Insufficient Psychological Acceptability" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE657 ;
    skos:altLabel "CWE-655" ;
    skos:definition "The product has a protection mechanism that is too difficult or inconvenient to use, encouraging non-malicious users to disable or bypass the mechanism, whether by accident or on purpose." ;
    skos:exactMatch d3f:CWE-655,
        cwe:CWE-655 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE656 a owl:Class ;
    rdfs:label "CWE_656" ;
    d3f:cwe-id "CWE-656" ;
    d3f:synonym "Never Assuming your secrets are safe" ;
    dcterms:title "Reliance on Security Through Obscurity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE657 ;
    skos:altLabel "CWE-656" ;
    skos:definition "The product uses a protection mechanism whose strength depends heavily on its obscurity, such that knowledge of its algorithms or key data is sufficient to defeat the mechanism." ;
    skos:exactMatch d3f:CWE-656,
        cwe:CWE-656 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE67 a owl:Class ;
    rdfs:label "CWE_67" ;
    d3f:cwe-id "CWE-67" ;
    dcterms:title "Improper Handling of Windows Device Names" ;
    rdfs:subClassOf d3f:CWE66 ;
    skos:altLabel "CWE-67" ;
    skos:definition "The product constructs pathnames from user input, but it does not handle or incorrectly handles a pathname containing a Windows device name such as AUX or CON. This typically leads to denial of service or an information exposure when the application attempts to process the pathname as a regular file." ;
    skos:exactMatch d3f:CWE-67,
        cwe:CWE-67 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE680 a owl:Class ;
    rdfs:label "CWE_680" ;
    d3f:cwe-id "CWE-680" ;
    dcterms:title "Integer Overflow to Buffer Overflow" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE190 ],
        d3f:CWE119 ;
    skos:altLabel "CWE-680" ;
    skos:definition "The product performs a calculation to determine how much memory to allocate, but an integer overflow can occur that causes less memory to be allocated than expected, leading to a buffer overflow." ;
    skos:exactMatch d3f:CWE-680,
        cwe:CWE-680 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE683 a owl:Class ;
    rdfs:label "CWE_683" ;
    d3f:cwe-id "CWE-683" ;
    dcterms:title "Function Call With Incorrect Order of Arguments" ;
    rdfs:subClassOf d3f:CWE628 ;
    skos:altLabel "CWE-683" ;
    skos:definition "The product calls a function, procedure, or routine, but the caller specifies the arguments in an incorrect order, leading to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-683,
        cwe:CWE-683 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE685 a owl:Class ;
    rdfs:label "CWE_685" ;
    d3f:cwe-id "CWE-685" ;
    dcterms:title "Function Call With Incorrect Number of Arguments" ;
    rdfs:subClassOf d3f:CWE628 ;
    skos:altLabel "CWE-685" ;
    skos:definition "The product calls a function, procedure, or routine, but the caller specifies too many arguments, or too few arguments, which may lead to undefined behavior and resultant weaknesses." ;
    skos:exactMatch d3f:CWE-685,
        cwe:CWE-685 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE686 a owl:Class ;
    rdfs:label "CWE_686" ;
    d3f:cwe-id "CWE-686" ;
    dcterms:title "Function Call With Incorrect Argument Type" ;
    rdfs:subClassOf d3f:CWE628 ;
    skos:altLabel "CWE-686" ;
    skos:definition "The product calls a function, procedure, or routine, but the caller specifies an argument that is the wrong data type, which may lead to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-686,
        cwe:CWE-686 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE688 a owl:Class ;
    rdfs:label "CWE_688" ;
    d3f:cwe-id "CWE-688" ;
    dcterms:title "Function Call With Incorrect Variable or Reference as Argument" ;
    rdfs:subClassOf d3f:CWE628 ;
    skos:altLabel "CWE-688" ;
    skos:definition "The product calls a function, procedure, or routine, but the caller specifies the wrong variable or reference as one of the arguments, which may lead to undefined behavior and resultant weaknesses." ;
    skos:exactMatch d3f:CWE-688,
        cwe:CWE-688 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE689 a owl:Class ;
    rdfs:label "CWE_689" ;
    d3f:cwe-id "CWE-689" ;
    dcterms:title "Permission Race Condition During Resource Copy" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-689" ;
    skos:definition "The product, while copying or cloning a resource, does not set the resource's permissions or access control until the copy is complete, leaving the resource exposed to other spheres while the copy is taking place." ;
    skos:exactMatch d3f:CWE-689,
        cwe:CWE-689 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE69 a owl:Class ;
    rdfs:label "CWE_69" ;
    d3f:cwe-id "CWE-69" ;
    dcterms:title "Improper Handling of Windows ::DATA Alternate Data Stream" ;
    rdfs:subClassOf d3f:CWE66 ;
    skos:altLabel "CWE-69" ;
    skos:definition "The product does not properly prevent access to, or detect usage of, alternate data streams (ADS)." ;
    skos:exactMatch d3f:CWE-69,
        cwe:CWE-69 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE690 a owl:Class ;
    rdfs:label "CWE_690" ;
    d3f:cwe-id "CWE-690" ;
    dcterms:title "Unchecked Return Value to NULL Pointer Dereference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE476 ],
        d3f:CWE252 ;
    skos:altLabel "CWE-690" ;
    skos:definition "The product does not check for an error after calling a function that can return with a NULL pointer if the function fails, which leads to a resultant NULL pointer dereference." ;
    skos:exactMatch d3f:CWE-690,
        cwe:CWE-690 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE692 a owl:Class ;
    rdfs:label "CWE_692" ;
    d3f:cwe-id "CWE-692" ;
    dcterms:title "Incomplete Denylist to Cross-Site Scripting" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE79 ],
        d3f:CWE184 ;
    skos:altLabel "CWE-692" ;
    skos:definition "The product uses a denylist-based protection mechanism to defend against XSS attacks, but the denylist is incomplete, allowing XSS variants to succeed." ;
    skos:exactMatch d3f:CWE-692,
        cwe:CWE-692 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE698 a owl:Class ;
    rdfs:label "CWE_698" ;
    d3f:cwe-id "CWE-698" ;
    d3f:synonym "Redirect Without Exit" ;
    dcterms:title "Execution After Redirect (EAR)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE705 ],
        d3f:CWE670 ;
    skos:altLabel "CWE-698" ;
    skos:definition "The web application sends a redirect to another location, but instead of exiting, it executes additional code." ;
    skos:exactMatch d3f:CWE-698,
        cwe:CWE-698 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE7 a owl:Class ;
    rdfs:label "CWE_7" ;
    d3f:cwe-id "CWE-7" ;
    dcterms:title "J2EE Misconfiguration: Missing Custom Error Page" ;
    rdfs:subClassOf d3f:CWE756 ;
    skos:altLabel "CWE-7" ;
    skos:definition "The default error page of a web application should not display sensitive information about the product." ;
    skos:exactMatch d3f:CWE-7,
        cwe:CWE-7 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE708 a owl:Class ;
    rdfs:label "CWE_708" ;
    d3f:cwe-id "CWE-708" ;
    dcterms:title "Incorrect Ownership Assignment" ;
    rdfs:subClassOf d3f:CWE282 ;
    skos:altLabel "CWE-708" ;
    skos:definition "The product assigns an owner to a resource, but the owner is outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-708,
        cwe:CWE-708 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE72 a owl:Class ;
    rdfs:label "CWE_72" ;
    d3f:cwe-id "CWE-72" ;
    dcterms:title "Improper Handling of Apple HFS+ Alternate Data Stream Path" ;
    rdfs:subClassOf d3f:CWE66 ;
    skos:altLabel "CWE-72" ;
    skos:definition "The product does not properly handle special paths that may identify the data or resource fork of a file on the HFS+ file system." ;
    skos:exactMatch d3f:CWE-72,
        cwe:CWE-72 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE757 a owl:Class ;
    rdfs:label "CWE_757" ;
    d3f:cwe-id "CWE-757" ;
    dcterms:title "Selection of Less-Secure Algorithm During Negotiation ('Algorithm Downgrade')" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-757" ;
    skos:definition "A protocol or its implementation supports interaction between multiple actors and allows those actors to negotiate which algorithm should be used as a protection mechanism such as encryption or authentication, but it does not select the strongest algorithm that is available to both parties." ;
    skos:exactMatch d3f:CWE-757,
        cwe:CWE-757 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE759 a owl:Class ;
    rdfs:label "CWE_759" ;
    d3f:cwe-id "CWE-759" ;
    dcterms:title "Use of a One-Way Hash without a Salt" ;
    rdfs:subClassOf d3f:CWE916 ;
    skos:altLabel "CWE-759" ;
    skos:definition "The product uses a one-way cryptographic hash against an input that should not be reversible, such as a password, but the product does not also use a salt as part of the input." ;
    skos:exactMatch d3f:CWE-759,
        cwe:CWE-759 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE76 a owl:Class ;
    rdfs:label "CWE_76" ;
    d3f:cwe-id "CWE-76" ;
    dcterms:title "Improper Neutralization of Equivalent Special Elements" ;
    rdfs:subClassOf d3f:CWE75 ;
    skos:altLabel "CWE-76" ;
    skos:definition "The product correctly neutralizes certain special elements, but it improperly neutralizes equivalent special elements." ;
    skos:exactMatch d3f:CWE-76,
        cwe:CWE-76 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE760 a owl:Class ;
    rdfs:label "CWE_760" ;
    d3f:cwe-id "CWE-760" ;
    dcterms:title "Use of a One-Way Hash with a Predictable Salt" ;
    rdfs:subClassOf d3f:CWE916 ;
    skos:altLabel "CWE-760" ;
    skos:definition "The product uses a one-way cryptographic hash against an input that should not be reversible, such as a password, but the product uses a predictable salt as part of the input." ;
    skos:exactMatch d3f:CWE-760,
        cwe:CWE-760 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE761 a owl:Class ;
    rdfs:label "CWE_761" ;
    d3f:cwe-id "CWE-761" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Free of Pointer not at Start of Buffer" ;
    rdfs:subClassOf d3f:CWE763 ;
    skos:altLabel "CWE-761" ;
    skos:definition "The product calls free() on a pointer to a memory resource that was allocated on the heap, but the pointer is not at the start of the buffer." ;
    skos:exactMatch d3f:CWE-761,
        cwe:CWE-761 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE764 a owl:Class ;
    rdfs:label "CWE_764" ;
    d3f:cwe-id "CWE-764" ;
    dcterms:title "Multiple Locks of a Critical Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE675 ],
        d3f:CWE667 ;
    skos:altLabel "CWE-764" ;
    skos:definition "The product locks a critical resource more times than intended, leading to an unexpected state in the system." ;
    skos:exactMatch d3f:CWE-764,
        cwe:CWE-764 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE765 a owl:Class ;
    rdfs:label "CWE_765" ;
    d3f:cwe-id "CWE-765" ;
    dcterms:title "Multiple Unlocks of a Critical Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE675 ],
        d3f:CWE667 ;
    skos:altLabel "CWE-765" ;
    skos:definition "The product unlocks a critical resource more times than intended, leading to an unexpected state in the system." ;
    skos:exactMatch d3f:CWE-765,
        cwe:CWE-765 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE766 a owl:Class ;
    rdfs:label "CWE_766" ;
    d3f:cwe-id "CWE-766" ;
    dcterms:title "Critical Data Element Declared Public" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE732 ],
        d3f:CWE1061 ;
    skos:altLabel "CWE-766" ;
    skos:definition "The product declares a critical variable, field, or member to be public when intended security policy requires it to be private." ;
    skos:exactMatch d3f:CWE-766,
        cwe:CWE-766 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE767 a owl:Class ;
    rdfs:label "CWE_767" ;
    d3f:cwe-id "CWE-767" ;
    dcterms:title "Access to Critical Private Variable via Public Method" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-767" ;
    skos:definition "The product defines a public method that reads or modifies a private variable." ;
    skos:exactMatch d3f:CWE-767,
        cwe:CWE-767 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE768 a owl:Class ;
    rdfs:label "CWE_768" ;
    d3f:cwe-id "CWE-768" ;
    dcterms:title "Incorrect Short Circuit Evaluation" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-768" ;
    skos:definition "The product contains a conditional statement with multiple logical expressions in which one of the non-leading expressions may produce side effects. This may lead to an unexpected state in the program after the execution of the conditional, because short-circuiting logic may prevent the side effects from occurring." ;
    skos:exactMatch d3f:CWE-768,
        cwe:CWE-768 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE773 a owl:Class ;
    rdfs:label "CWE_773" ;
    d3f:cwe-id "CWE-773" ;
    dcterms:title "Missing Reference to Active File Descriptor or Handle" ;
    rdfs:subClassOf d3f:CWE771 ;
    skos:altLabel "CWE-773" ;
    skos:definition "The product does not properly maintain references to a file descriptor or handle, which prevents that file descriptor/handle from being reclaimed." ;
    skos:exactMatch d3f:CWE-773,
        cwe:CWE-773 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE774 a owl:Class ;
    rdfs:label "CWE_774" ;
    d3f:cwe-id "CWE-774" ;
    d3f:synonym "File Descriptor Exhaustion" ;
    dcterms:title "Allocation of File Descriptors or Handles Without Limits or Throttling" ;
    rdfs:subClassOf d3f:CWE770 ;
    skos:altLabel "CWE-774" ;
    skos:definition "The product allocates file descriptors or handles on behalf of an actor without imposing any restrictions on how many descriptors can be allocated, in violation of the intended security policy for that actor." ;
    skos:exactMatch d3f:CWE-774,
        cwe:CWE-774 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE775 a owl:Class ;
    rdfs:label "CWE_775" ;
    d3f:cwe-id "CWE-775" ;
    dcterms:title "Missing Release of File Descriptor or Handle after Effective Lifetime" ;
    rdfs:subClassOf d3f:CWE772 ;
    skos:altLabel "CWE-775" ;
    skos:definition "The product does not release a file descriptor or handle after its effective lifetime has ended, i.e., after the file descriptor/handle is no longer needed." ;
    skos:exactMatch d3f:CWE-775,
        cwe:CWE-775 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE776 a owl:Class ;
    rdfs:label "CWE_776" ;
    d3f:cwe-id "CWE-776" ;
    d3f:synonym "Billion Laughs Attack" ;
    dcterms:title "Improper Restriction of Recursive Entity References in DTDs ('XML Entity Expansion')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE674 ],
        d3f:CWE405 ;
    skos:altLabel "CWE-776" ;
    skos:definition "The product uses XML documents and allows their structure to be defined with a Document Type Definition (DTD), but it does not properly control the number of recursive definitions of entities." ;
    skos:exactMatch d3f:CWE-776,
        cwe:CWE-776 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE777 a owl:Class ;
    rdfs:label "CWE_777" ;
    d3f:cwe-id "CWE-777" ;
    dcterms:title "Regular Expression without Anchors" ;
    rdfs:subClassOf d3f:CWE625 ;
    skos:altLabel "CWE-777" ;
    skos:definition "The product uses a regular expression to perform neutralization, but the regular expression is not anchored and may allow malicious or malformed data to slip through." ;
    skos:exactMatch d3f:CWE-777,
        cwe:CWE-777 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE778 a owl:Class ;
    rdfs:label "CWE_778" ;
    d3f:cwe-id "CWE-778" ;
    dcterms:title "Insufficient Logging" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE223 ;
    skos:altLabel "CWE-778" ;
    skos:definition "When a security-critical event occurs, the product either does not record the event or omits important details about the event when logging it." ;
    skos:exactMatch d3f:CWE-778,
        cwe:CWE-778 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE779 a owl:Class ;
    rdfs:label "CWE_779" ;
    d3f:cwe-id "CWE-779" ;
    dcterms:title "Logging of Excessive Data" ;
    rdfs:subClassOf d3f:CWE400 ;
    skos:altLabel "CWE-779" ;
    skos:definition "The product logs too much information, making log files hard to process and possibly hindering recovery efforts or forensic analysis after an attack." ;
    skos:exactMatch d3f:CWE-779,
        cwe:CWE-779 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE78 a owl:Class ;
    rdfs:label "CWE_78" ;
    d3f:cwe-id "CWE-78" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "OS Command Injection" ;
    dcterms:title "Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')" ;
    rdfs:subClassOf d3f:CWE77 ;
    skos:altLabel "CWE-78" ;
    skos:definition "The product constructs all or part of an OS command using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended OS command when it is sent to a downstream component." ;
    skos:exactMatch d3f:CWE-78,
        cwe:CWE-78 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE780 a owl:Class ;
    rdfs:label "CWE_780" ;
    d3f:cwe-id "CWE-780" ;
    dcterms:title "Use of RSA Algorithm without OAEP" ;
    rdfs:subClassOf d3f:CWE327 ;
    skos:altLabel "CWE-780" ;
    skos:definition "The product uses the RSA algorithm but does not incorporate Optimal Asymmetric Encryption Padding (OAEP), which might weaken the encryption." ;
    skos:exactMatch d3f:CWE-780,
        cwe:CWE-780 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE781 a owl:Class ;
    rdfs:label "CWE_781" ;
    d3f:cwe-id "CWE-781" ;
    dcterms:title "Improper Address Validation in IOCTL with METHOD_NEITHER I/O Control Code" ;
    rdfs:subClassOf d3f:CWE1285 ;
    skos:altLabel "CWE-781" ;
    skos:definition "The product defines an IOCTL that uses METHOD_NEITHER for I/O, but it does not validate or incorrectly validates the addresses that are provided." ;
    skos:exactMatch d3f:CWE-781,
        cwe:CWE-781 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE782 a owl:Class ;
    rdfs:label "CWE_782" ;
    d3f:cwe-id "CWE-782" ;
    dcterms:title "Exposed IOCTL with Insufficient Access Control" ;
    rdfs:subClassOf d3f:CWE749 ;
    skos:altLabel "CWE-782" ;
    skos:definition "The product implements an IOCTL with functionality that should be restricted, but it does not properly enforce access control for the IOCTL." ;
    skos:exactMatch d3f:CWE-782,
        cwe:CWE-782 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE783 a owl:Class ;
    rdfs:label "CWE_783" ;
    d3f:cwe-id "CWE-783" ;
    dcterms:title "Operator Precedence Logic Error" ;
    rdfs:subClassOf d3f:CWE670 ;
    skos:altLabel "CWE-783" ;
    skos:definition "The product uses an expression in which operator precedence causes incorrect logic to be used." ;
    skos:exactMatch d3f:CWE-783,
        cwe:CWE-783 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE784 a owl:Class ;
    rdfs:label "CWE_784" ;
    d3f:cwe-id "CWE-784" ;
    dcterms:title "Reliance on Cookies without Validation and Integrity Checking in a Security Decision" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE807 ],
        d3f:CWE565 ;
    skos:altLabel "CWE-784" ;
    skos:definition "The product uses a protection mechanism that relies on the existence or values of a cookie, but it does not properly ensure that the cookie is valid for the associated user." ;
    skos:exactMatch d3f:CWE-784,
        cwe:CWE-784 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE785 a owl:Class ;
    rdfs:label "CWE_785" ;
    d3f:cwe-id "CWE-785" ;
    dcterms:title "Use of Path Manipulation Function without Maximum-sized Buffer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE676 ],
        d3f:CWE120 ;
    skos:altLabel "CWE-785" ;
    skos:definition "The product invokes a function for normalizing paths or file names, but it provides an output buffer that is smaller than the maximum possible size, such as PATH_MAX." ;
    skos:exactMatch d3f:CWE-785,
        cwe:CWE-785 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE789 a owl:Class ;
    rdfs:label "CWE_789" ;
    d3f:cwe-id "CWE-789" ;
    d3f:synonym "Stack Exhaustion" ;
    dcterms:title "Memory Allocation with Excessive Size Value" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE770 ],
        d3f:CWE1284 ;
    skos:altLabel "CWE-789" ;
    skos:definition "The product allocates memory based on an untrusted, large size value, but it does not ensure that the size is within expected limits, allowing arbitrary amounts of memory to be allocated." ;
    skos:exactMatch d3f:CWE-789,
        cwe:CWE-789 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE793 a owl:Class ;
    rdfs:label "CWE_793" ;
    d3f:cwe-id "CWE-793" ;
    dcterms:title "Only Filtering One Instance of a Special Element" ;
    rdfs:subClassOf d3f:CWE792 ;
    skos:altLabel "CWE-793" ;
    skos:definition "The product receives data from an upstream component, but only filters a single instance of a special element before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-793,
        cwe:CWE-793 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE794 a owl:Class ;
    rdfs:label "CWE_794" ;
    d3f:cwe-id "CWE-794" ;
    dcterms:title "Incomplete Filtering of Multiple Instances of Special Elements" ;
    rdfs:subClassOf d3f:CWE792 ;
    skos:altLabel "CWE-794" ;
    skos:definition "The product receives data from an upstream component, but does not filter all instances of a special element before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-794,
        cwe:CWE-794 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE796 a owl:Class ;
    rdfs:label "CWE_796" ;
    d3f:cwe-id "CWE-796" ;
    dcterms:title "Only Filtering Special Elements Relative to a Marker" ;
    rdfs:subClassOf d3f:CWE795 ;
    skos:altLabel "CWE-796" ;
    skos:definition "The product receives data from an upstream component, but only accounts for special elements positioned relative to a marker (e.g. \"at the beginning/end of a string; the second argument\"), thereby missing remaining special elements that may exist before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-796,
        cwe:CWE-796 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE797 a owl:Class ;
    rdfs:label "CWE_797" ;
    d3f:cwe-id "CWE-797" ;
    dcterms:title "Only Filtering Special Elements at an Absolute Position" ;
    rdfs:subClassOf d3f:CWE795 ;
    skos:altLabel "CWE-797" ;
    skos:definition "The product receives data from an upstream component, but only accounts for special elements at an absolute position (e.g. \"byte number 10\"), thereby missing remaining special elements that may exist before sending it to a downstream component." ;
    skos:exactMatch d3f:CWE-797,
        cwe:CWE-797 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE8 a owl:Class ;
    rdfs:label "CWE_8" ;
    d3f:cwe-id "CWE-8" ;
    dcterms:title "J2EE Misconfiguration: Entity Bean Declared Remote" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-8" ;
    skos:definition "When an application exposes a remote interface for an entity bean, it might also expose methods that get or set the bean's data. These methods could be leveraged to read sensitive information, or to change data in ways that violate the application's expectations, potentially leading to other vulnerabilities." ;
    skos:exactMatch d3f:CWE-8,
        cwe:CWE-8 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE80 a owl:Class ;
    rdfs:label "CWE_80" ;
    d3f:cwe-id "CWE-80" ;
    dcterms:title "Improper Neutralization of Script-Related HTML Tags in a Web Page (Basic XSS)" ;
    rdfs:subClassOf d3f:CWE79 ;
    skos:altLabel "CWE-80" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters such as \"<\", \">\", and \"&\" that could be interpreted as web-scripting elements when they are sent to a downstream component that processes web pages." ;
    skos:exactMatch d3f:CWE-80,
        cwe:CWE-80 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE804 a owl:Class ;
    rdfs:label "CWE_804" ;
    d3f:cwe-id "CWE-804" ;
    dcterms:title "Guessable CAPTCHA" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE863 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-804" ;
    skos:definition "The product uses a CAPTCHA challenge, but the challenge can be guessed or automatically recognized by a non-human actor." ;
    skos:exactMatch d3f:CWE-804,
        cwe:CWE-804 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE806 a owl:Class ;
    rdfs:label "CWE_806" ;
    d3f:cwe-id "CWE-806" ;
    dcterms:title "Buffer Access Using Size of Source Buffer" ;
    rdfs:subClassOf d3f:CWE805 ;
    skos:altLabel "CWE-806" ;
    skos:definition "The product uses the size of a source buffer when reading from or writing to a destination buffer, which may cause it to access memory that is outside of the bounds of the buffer." ;
    skos:exactMatch d3f:CWE-806,
        cwe:CWE-806 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE81 a owl:Class ;
    rdfs:label "CWE_81" ;
    d3f:cwe-id "CWE-81" ;
    dcterms:title "Improper Neutralization of Script in an Error Message Web Page" ;
    rdfs:subClassOf d3f:CWE79 ;
    skos:altLabel "CWE-81" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters that could be interpreted as web-scripting elements when they are sent to an error page." ;
    skos:exactMatch d3f:CWE-81,
        cwe:CWE-81 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE82 a owl:Class ;
    rdfs:label "CWE_82" ;
    d3f:cwe-id "CWE-82" ;
    dcterms:title "Improper Neutralization of Script in Attributes of IMG Tags in a Web Page" ;
    rdfs:subClassOf d3f:CWE83 ;
    skos:altLabel "CWE-82" ;
    skos:definition "The web application does not neutralize or incorrectly neutralizes scripting elements within attributes of HTML IMG tags, such as the src attribute." ;
    skos:exactMatch d3f:CWE-82,
        cwe:CWE-82 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE822 a owl:Class ;
    rdfs:label "CWE_822" ;
    d3f:cwe-id "CWE-822" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Untrusted Pointer Dereference" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-822" ;
    skos:definition "The product obtains a value from an untrusted source, converts this value to a pointer, and dereferences the resulting pointer." ;
    skos:exactMatch d3f:CWE-822,
        cwe:CWE-822 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE823 a owl:Class ;
    rdfs:label "CWE_823" ;
    d3f:cwe-id "CWE-823" ;
    d3f:synonym "Untrusted pointer offset" ;
    dcterms:title "Use of Out-of-range Pointer Offset" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-823" ;
    skos:definition "The product performs pointer arithmetic on a valid pointer, but it uses an offset that can point outside of the intended range of valid memory locations for the resulting pointer." ;
    skos:exactMatch d3f:CWE-823,
        cwe:CWE-823 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE824 a owl:Class ;
    rdfs:label "CWE_824" ;
    d3f:cwe-id "CWE-824" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Access of Uninitialized Pointer" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-824" ;
    skos:definition "The product accesses or uses a pointer that has not been initialized." ;
    skos:exactMatch d3f:CWE-824,
        cwe:CWE-824 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE826 a owl:Class ;
    rdfs:label "CWE_826" ;
    d3f:cwe-id "CWE-826" ;
    dcterms:title "Premature Release of Resource During Expected Lifetime" ;
    rdfs:subClassOf d3f:CWE666 ;
    skos:altLabel "CWE-826" ;
    skos:definition "The product releases a resource that is still intended to be used by itself or another actor." ;
    skos:exactMatch d3f:CWE-826,
        cwe:CWE-826 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE827 a owl:Class ;
    rdfs:label "CWE_827" ;
    d3f:cwe-id "CWE-827" ;
    dcterms:title "Improper Control of Document Type Definition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE829 ],
        d3f:CWE706 ;
    skos:altLabel "CWE-827" ;
    skos:definition "The product does not restrict a reference to a Document Type Definition (DTD) to the intended control sphere. This might allow attackers to reference arbitrary DTDs, possibly causing the product to expose files, consume excessive system resources, or execute arbitrary http requests on behalf of the attacker." ;
    skos:exactMatch d3f:CWE-827,
        cwe:CWE-827 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE830 a owl:Class ;
    rdfs:label "CWE_830" ;
    d3f:cwe-id "CWE-830" ;
    dcterms:title "Inclusion of Web Functionality from an Untrusted Source" ;
    rdfs:subClassOf d3f:CWE829 ;
    skos:altLabel "CWE-830" ;
    skos:definition "The product includes web functionality (such as a web widget) from another domain, which causes it to operate within the domain of the product, potentially granting total access and control of the product to the untrusted source." ;
    skos:exactMatch d3f:CWE-830,
        cwe:CWE-830 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE831 a owl:Class ;
    rdfs:label "CWE_831" ;
    d3f:cwe-id "CWE-831" ;
    dcterms:title "Signal Handler Function Associated with Multiple Signals" ;
    rdfs:subClassOf d3f:CWE364 ;
    skos:altLabel "CWE-831" ;
    skos:definition "The product defines a function that is used as a handler for more than one signal." ;
    skos:exactMatch d3f:CWE-831,
        cwe:CWE-831 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE832 a owl:Class ;
    rdfs:label "CWE_832" ;
    d3f:cwe-id "CWE-832" ;
    dcterms:title "Unlock of a Resource that is not Locked" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-832" ;
    skos:definition "The product attempts to unlock a resource that is not locked." ;
    skos:exactMatch d3f:CWE-832,
        cwe:CWE-832 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE833 a owl:Class ;
    rdfs:label "CWE_833" ;
    d3f:cwe-id "CWE-833" ;
    dcterms:title "Deadlock" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-833" ;
    skos:definition "The product contains multiple threads or executable segments that are waiting for each other to release a necessary lock, resulting in deadlock." ;
    skos:exactMatch d3f:CWE-833,
        cwe:CWE-833 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE835 a owl:Class ;
    rdfs:label "CWE_835" ;
    d3f:cwe-id "CWE-835" ;
    dcterms:title "Loop with Unreachable Exit Condition ('Infinite Loop')" ;
    rdfs:subClassOf d3f:CWE834 ;
    skos:altLabel "CWE-835" ;
    skos:definition "The product contains an iteration or loop with an exit condition that cannot be reached, i.e., an infinite loop." ;
    skos:exactMatch d3f:CWE-835,
        cwe:CWE-835 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE836 a owl:Class ;
    rdfs:label "CWE_836" ;
    d3f:cwe-id "CWE-836" ;
    dcterms:title "Use of Password Hash Instead of Password for Authentication" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-836" ;
    skos:definition "The product records password hashes in a data store, receives a hash of a password from a client, and compares the supplied hash to the hash obtained from the data store." ;
    skos:exactMatch d3f:CWE-836,
        cwe:CWE-836 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE837 a owl:Class ;
    rdfs:label "CWE_837" ;
    d3f:cwe-id "CWE-837" ;
    dcterms:title "Improper Enforcement of a Single, Unique Action" ;
    rdfs:subClassOf d3f:CWE799 ;
    skos:altLabel "CWE-837" ;
    skos:definition "The product requires that an actor should only be able to perform an action once, or to have only one unique action, but the product does not enforce or improperly enforces this restriction." ;
    skos:exactMatch d3f:CWE-837,
        cwe:CWE-837 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE838 a owl:Class ;
    rdfs:label "CWE_838" ;
    d3f:cwe-id "CWE-838" ;
    dcterms:title "Inappropriate Encoding for Output Context" ;
    rdfs:subClassOf d3f:CWE116 ;
    skos:altLabel "CWE-838" ;
    skos:definition "The product uses or specifies an encoding when generating output to a downstream component, but the specified encoding is not the same as the encoding that is expected by the downstream component." ;
    skos:exactMatch d3f:CWE-838,
        cwe:CWE-838 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE839 a owl:Class ;
    rdfs:label "CWE_839" ;
    d3f:cwe-id "CWE-839" ;
    d3f:synonym "Signed comparison" ;
    dcterms:title "Numeric Range Comparison Without Minimum Check" ;
    rdfs:subClassOf d3f:CWE1023 ;
    skos:altLabel "CWE-839" ;
    skos:definition "The product checks a value to ensure that it is less than or equal to a maximum, but it does not also verify that the value is greater than or equal to the minimum." ;
    skos:exactMatch d3f:CWE-839,
        cwe:CWE-839 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE84 a owl:Class ;
    rdfs:label "CWE_84" ;
    d3f:cwe-id "CWE-84" ;
    dcterms:title "Improper Neutralization of Encoded URI Schemes in a Web Page" ;
    rdfs:subClassOf d3f:CWE79 ;
    skos:altLabel "CWE-84" ;
    skos:definition "The web application improperly neutralizes user-controlled input for executable script disguised with URI encodings." ;
    skos:exactMatch d3f:CWE-84,
        cwe:CWE-84 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE841 a owl:Class ;
    rdfs:label "CWE_841" ;
    d3f:cwe-id "CWE-841" ;
    dcterms:title "Improper Enforcement of Behavioral Workflow" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-841" ;
    skos:definition "The product supports a session in which more than one behavior must be performed by an actor, but it does not properly ensure that the actor performs the behaviors in the required sequence." ;
    skos:exactMatch d3f:CWE-841,
        cwe:CWE-841 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE842 a owl:Class ;
    rdfs:label "CWE_842" ;
    d3f:cwe-id "CWE-842" ;
    dcterms:title "Placement of User into Incorrect Group" ;
    rdfs:subClassOf d3f:CWE286 ;
    skos:altLabel "CWE-842" ;
    skos:definition "The product or the administrator places a user into an incorrect group." ;
    skos:exactMatch d3f:CWE-842,
        cwe:CWE-842 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE843 a owl:Class ;
    rdfs:label "CWE_843" ;
    d3f:cwe-id "CWE-843" ;
    d3f:synonym "Object Type Confusion" ;
    dcterms:title "Access of Resource Using Incompatible Type ('Type Confusion')" ;
    rdfs:subClassOf d3f:CWE704 ;
    skos:altLabel "CWE-843" ;
    skos:definition "The product allocates or initializes a resource such as a pointer, object, or variable using one type, but it later accesses that resource using a type that is incompatible with the original type." ;
    skos:exactMatch d3f:CWE-843,
        cwe:CWE-843 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE85 a owl:Class ;
    rdfs:label "CWE_85" ;
    d3f:cwe-id "CWE-85" ;
    dcterms:title "Doubled Character XSS Manipulations" ;
    rdfs:subClassOf d3f:CWE79 ;
    skos:altLabel "CWE-85" ;
    skos:definition "The web application does not filter user-controlled input for executable script disguised using doubling of the involved characters." ;
    skos:exactMatch d3f:CWE-85,
        cwe:CWE-85 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE86 a owl:Class ;
    rdfs:label "CWE_86" ;
    d3f:cwe-id "CWE-86" ;
    dcterms:title "Improper Neutralization of Invalid Characters in Identifiers in Web Pages" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE79 ],
        d3f:CWE436 ;
    skos:altLabel "CWE-86" ;
    skos:definition "The product does not neutralize or incorrectly neutralizes invalid characters or byte sequences in the middle of tag names, URI schemes, and other identifiers." ;
    skos:exactMatch d3f:CWE-86,
        cwe:CWE-86 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE87 a owl:Class ;
    rdfs:label "CWE_87" ;
    d3f:cwe-id "CWE-87" ;
    dcterms:title "Improper Neutralization of Alternate XSS Syntax" ;
    rdfs:subClassOf d3f:CWE79 ;
    skos:altLabel "CWE-87" ;
    skos:definition "The product does not neutralize or incorrectly neutralizes user-controlled input for alternate script syntax." ;
    skos:exactMatch d3f:CWE-87,
        cwe:CWE-87 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE88 a owl:Class ;
    rdfs:label "CWE_88" ;
    d3f:cwe-id "CWE-88" ;
    dcterms:title "Improper Neutralization of Argument Delimiters in a Command ('Argument Injection')" ;
    rdfs:subClassOf d3f:CWE77 ;
    skos:altLabel "CWE-88" ;
    skos:definition "The product constructs a string for a command to be executed by a separate component in another control sphere, but it does not properly delimit the intended arguments, options, or switches within that command string." ;
    skos:exactMatch d3f:CWE-88,
        cwe:CWE-88 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE9 a owl:Class ;
    rdfs:label "CWE_9" ;
    d3f:cwe-id "CWE-9" ;
    dcterms:title "J2EE Misconfiguration: Weak Access Permissions for EJB Methods" ;
    rdfs:subClassOf d3f:CWE266 ;
    skos:altLabel "CWE-9" ;
    skos:definition "If elevated access rights are assigned to EJB methods, then an attacker can take advantage of the permissions to exploit the product." ;
    skos:exactMatch d3f:CWE-9,
        cwe:CWE-9 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE90 a owl:Class ;
    rdfs:label "CWE_90" ;
    d3f:cwe-id "CWE-90" ;
    dcterms:title "Improper Neutralization of Special Elements used in an LDAP Query ('LDAP Injection')" ;
    rdfs:subClassOf d3f:CWE943 ;
    skos:altLabel "CWE-90" ;
    skos:definition "The product constructs all or part of an LDAP query using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended LDAP query when it is sent to a downstream component." ;
    skos:exactMatch d3f:CWE-90,
        cwe:CWE-90 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE910 a owl:Class ;
    rdfs:label "CWE_910" ;
    d3f:cwe-id "CWE-910" ;
    d3f:synonym "Stale file descriptor" ;
    dcterms:title "Use of Expired File Descriptor" ;
    rdfs:subClassOf d3f:CWE672 ;
    skos:altLabel "CWE-910" ;
    skos:definition "The product uses or accesses a file descriptor after it has been closed." ;
    skos:exactMatch d3f:CWE-910,
        cwe:CWE-910 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE911 a owl:Class ;
    rdfs:label "CWE_911" ;
    d3f:cwe-id "CWE-911" ;
    dcterms:title "Improper Update of Reference Count" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-911" ;
    skos:definition "The product uses a reference count to manage a resource, but it does not update or incorrectly updates the reference count." ;
    skos:exactMatch d3f:CWE-911,
        cwe:CWE-911 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE917 a owl:Class ;
    rdfs:label "CWE_917" ;
    d3f:cwe-id "CWE-917" ;
    d3f:synonym "EL Injection" ;
    dcterms:title "Improper Neutralization of Special Elements used in an Expression Language Statement ('Expression Language Injection')" ;
    rdfs:subClassOf d3f:CWE77 ;
    skos:altLabel "CWE-917" ;
    skos:definition "The product constructs all or part of an expression language (EL) statement in a framework such as a Java Server Page (JSP) using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended EL statement before it is executed." ;
    skos:exactMatch d3f:CWE-917,
        cwe:CWE-917 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE918 a owl:Class ;
    rdfs:label "CWE_918" ;
    d3f:cwe-id "CWE-918" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "SSRF" ;
    dcterms:title "Server-Side Request Forgery (SSRF)" ;
    rdfs:subClassOf d3f:CWE441 ;
    skos:altLabel "CWE-918" ;
    skos:definition "The web server receives a URL or similar request from an upstream component and retrieves the contents of this URL, but it does not sufficiently ensure that the request is being sent to the expected destination." ;
    skos:exactMatch d3f:CWE-918,
        cwe:CWE-918 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE920 a owl:Class ;
    rdfs:label "CWE_920" ;
    d3f:cwe-id "CWE-920" ;
    dcterms:title "Improper Restriction of Power Consumption" ;
    rdfs:subClassOf d3f:CWE400 ;
    skos:altLabel "CWE-920" ;
    skos:definition "The product operates in an environment in which power is a limited resource that cannot be automatically replenished, but the product does not properly restrict the amount of power that its operation consumes." ;
    skos:exactMatch d3f:CWE-920,
        cwe:CWE-920 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE921 a owl:Class ;
    rdfs:label "CWE_921" ;
    d3f:cwe-id "CWE-921" ;
    dcterms:title "Storage of Sensitive Data in a Mechanism without Access Control" ;
    rdfs:subClassOf d3f:CWE922 ;
    skos:altLabel "CWE-921" ;
    skos:definition "The product stores sensitive information in a file system or device that does not have built-in access control." ;
    skos:exactMatch d3f:CWE-921,
        cwe:CWE-921 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE924 a owl:Class ;
    rdfs:label "CWE_924" ;
    d3f:cwe-id "CWE-924" ;
    dcterms:title "Improper Enforcement of Message Integrity During Transmission in a Communication Channel" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-924" ;
    skos:definition "The product establishes a communication channel with an endpoint and receives a message from that endpoint, but it does not sufficiently ensure that the message was not modified during transmission." ;
    skos:exactMatch d3f:CWE-924,
        cwe:CWE-924 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE925 a owl:Class ;
    rdfs:label "CWE_925" ;
    d3f:cwe-id "CWE-925" ;
    d3f:synonym "Intent Spoofing" ;
    dcterms:title "Improper Verification of Intent by Broadcast Receiver" ;
    rdfs:subClassOf d3f:CWE940 ;
    skos:altLabel "CWE-925" ;
    skos:definition "The Android application uses a Broadcast Receiver that receives an Intent but does not properly verify that the Intent came from an authorized source." ;
    skos:exactMatch d3f:CWE-925,
        cwe:CWE-925 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE926 a owl:Class ;
    rdfs:label "CWE_926" ;
    d3f:cwe-id "CWE-926" ;
    dcterms:title "Improper Export of Android Application Components" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-926" ;
    skos:definition "The Android application exports a component for use by other applications, but does not properly restrict which applications can launch the component or access the data it contains." ;
    skos:exactMatch d3f:CWE-926,
        cwe:CWE-926 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE927 a owl:Class ;
    rdfs:label "CWE_927" ;
    d3f:cwe-id "CWE-927" ;
    dcterms:title "Use of Implicit Intent for Sensitive Communication" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE668 ],
        d3f:CWE285 ;
    skos:altLabel "CWE-927" ;
    skos:definition "The Android application uses an implicit intent for transmitting sensitive data to other applications." ;
    skos:exactMatch d3f:CWE-927,
        cwe:CWE-927 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE939 a owl:Class ;
    rdfs:label "CWE_939" ;
    d3f:cwe-id "CWE-939" ;
    dcterms:title "Improper Authorization in Handler for Custom URL Scheme" ;
    rdfs:subClassOf d3f:CWE862 ;
    skos:altLabel "CWE-939" ;
    skos:definition "The product uses a handler for a custom URL scheme, but it does not properly restrict which actors can invoke the handler using the scheme." ;
    skos:exactMatch d3f:CWE-939,
        cwe:CWE-939 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE941 a owl:Class ;
    rdfs:label "CWE_941" ;
    d3f:cwe-id "CWE-941" ;
    dcterms:title "Incorrectly Specified Destination in a Communication Channel" ;
    rdfs:subClassOf d3f:CWE923 ;
    skos:altLabel "CWE-941" ;
    skos:definition "The product creates a communication channel to initiate an outgoing request to an actor, but it does not correctly specify the intended destination for that actor." ;
    skos:exactMatch d3f:CWE-941,
        cwe:CWE-941 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE942 a owl:Class ;
    rdfs:label "CWE_942" ;
    d3f:cwe-id "CWE-942" ;
    dcterms:title "Permissive Cross-domain Policy with Untrusted Domains" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE863 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE923 ],
        d3f:CWE183 ;
    skos:altLabel "CWE-942" ;
    skos:definition "The product uses a cross-domain policy file that includes domains that should not be trusted." ;
    skos:exactMatch d3f:CWE-942,
        cwe:CWE-942 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE95 a owl:Class ;
    rdfs:label "CWE_95" ;
    d3f:cwe-id "CWE-95" ;
    dcterms:title "Improper Neutralization of Directives in Dynamically Evaluated Code ('Eval Injection')" ;
    rdfs:subClassOf d3f:CWE94 ;
    skos:altLabel "CWE-95" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes code syntax before using the input in a dynamic evaluation call (e.g. \"eval\")." ;
    skos:exactMatch d3f:CWE-95,
        cwe:CWE-95 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE97 a owl:Class ;
    rdfs:label "CWE_97" ;
    d3f:cwe-id "CWE-97" ;
    dcterms:title "Improper Neutralization of Server-Side Includes (SSI) Within a Web Page" ;
    rdfs:subClassOf d3f:CWE96 ;
    skos:altLabel "CWE-97" ;
    skos:definition "The product generates a web page, but does not neutralize or incorrectly neutralizes user-controllable input that could be interpreted as a server-side include (SSI) directive." ;
    skos:exactMatch d3f:CWE-97,
        cwe:CWE-97 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE98 a owl:Class ;
    rdfs:label "CWE_98" ;
    d3f:cwe-id "CWE-98" ;
    d3f:synonym "Local file inclusion" ;
    dcterms:title "Improper Control of Filename for Include/Require Statement in PHP Program ('PHP Remote File Inclusion')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE829 ],
        d3f:CWE706 ;
    skos:altLabel "CWE-98" ;
    skos:definition "The PHP application receives input from an upstream component, but it does not restrict or incorrectly restricts the input before its usage in \"require,\" \"include,\" or similar functions." ;
    skos:exactMatch d3f:CWE-98,
        cwe:CWE-98 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CertificateBasedAuthentication a owl:Class ;
    rdfs:label "Certificate_basedAuthentication" ;
    d3f:d3fend-id "D3-CBAN" ;
    d3f:kb-article "## How it works Certificate-based authentication is a security mechanism that uses digital certificates to verify the identity of a user, device, or server before granting access to a network or system. This method relies on a pair of cryptographic keys: a public key and a private key. ## Consider" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Certificate-based Authentication" ;
    rdfs:subClassOf d3f:AgentAuthentication ;
    skos:altLabel "Certificate-basedAuthentication" ;
    skos:definition "Requiring a digital certificate in order to authenticate a user." ;
    skos:exactMatch d3f:Certificate-basedAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ClientServerPayloadProfiling a owl:Class ;
    rdfs:label "Client_serverPayloadProfiling" ;
    d3f:d3fend-id "D3-CSPP" ;
    d3f:kb-article "## How it works Profiling request and response payloads across multiple clients to a single server to develop a baseline of their characteristics. May take into account request/response sizes, entropy, frequency, and rhythm. Finally, identify outliers as they may indicate a malicious payload deliver" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Client-server Payload Profiling" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:altLabel "Client-serverPayloadProfiling" ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:ExfiltrationTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1003,
        d3f:T1021,
        d3f:T1048,
        d3f:T1071,
        d3f:T1090,
        d3f:T1098,
        d3f:T1110,
        d3f:T1204,
        d3f:T1205,
        d3f:T1218,
        d3f:T1498,
        d3f:T1499,
        d3f:T1542,
        d3f:T1546,
