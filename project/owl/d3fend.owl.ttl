        d3f:TA0111 .

d3f:T1218 a owl:Class ;
    rdfs:label "T1218" ;
    d3f:attack-id "T1218" ;
    dcterms:title "System Binary Proxy Execution" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may bypass process and/or signature-based defenses by proxying execution of malicious content with signed, or otherwise trusted, binaries. Binaries used in this technique are often Microsoft-signed files, indicating that they have been either downloaded from Microsoft or are already native in the operating system.(Citation: LOLBAS Project) Binaries signed with trusted digital certificates can typically execute on Windows systems protected by digital signature validation. Several Microsoft signed binaries that are default on Windows installations can be used to proxy execution of other files or commands." ;
    skos:exactMatch d3f:T1218,
        mitre-attack:T1218 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003 a owl:Class ;
    rdfs:label "T1003" ;
    d3f:attack-id "T1003" ;
    dcterms:title "OS Credential Dumping" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may attempt to dump credentials to obtain account login and credential material, normally in the form of a hash or a clear text password. Credentials can be obtained from OS caches, memory, or structures.(Citation: Brining MimiKatz to Unix) Credentials can then be used to perform [Lateral Movement](https://attack.mitre.org/tactics/TA0008) and access restricted information." ;
    skos:exactMatch d3f:T1003,
        mitre-attack:T1003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CommandAndControlTechnique a owl:Class ;
    rdfs:label "CommandAndControlTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Command and Control Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to communicate with compromised systems to control them." ;
    skos:exactMatch d3f:CommandAndControlTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OffensiveTactic a owl:Class ;
    rdfs:label "OffensiveTactic" ;
    d3f:synonym "Tactical Objective" ;
    dcterms:title "Offensive Tactic" ;
    rdfs:seeAlso <https://attack.mitre.org/docs/ATTACK_Design_and_Philosophy_March_2020.pdf> ;
    rdfs:subClassOf d3f:Goal ;
    skos:definition "Per ATT&CK, these are defined as Tactical Goals, not Tactics per se. Many children also fit definition of tactics.  Some are neither tactics or tactical goals really (e.g., Execution, which is a useful grouping, but an action, not really a tactic or technique." ;
    skos:exactMatch d3f:OffensiveTactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalInformationBearer a owl:Class ;
    rdfs:label "DigitalInformationBearer" ;
    dcterms:title "Digital Information Bearer" ;
    rdfs:subClassOf d3f:DigitalArtifact ;
    skos:definition "A digital information bearer is a physical or virtual entity that stores, transmits, or processes digital information." ;
    skos:exactMatch d3f:DigitalInformationBearer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546 a owl:Class ;
    rdfs:label "T1546" ;
    d3f:attack-id "T1546" ;
    dcterms:title "Event Triggered Execution" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may establish persistence and/or elevate privileges using system mechanisms that trigger execution based on specific events. Various operating systems have means to monitor and subscribe to events such as logons or other user activity such as running specific applications/binaries. Cloud environments may also support various functions and services that monitor and can be invoked in response to specific cloud events.(Citation: Backdooring an AWS account)(Citation: Varonis Power Automate Data Exfiltration)(Citation: Microsoft DART Case Report 001)" ;
    skos:exactMatch d3f:T1546,
        mitre-attack:T1546 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrivilegeEscalationTechnique a owl:Class ;
    rdfs:label "PrivilegeEscalationTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Privilege Escalation Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to gain higher-level permissions." ;
    skos:exactMatch d3f:PrivilegeEscalationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LateralMovementTechnique a owl:Class ;
    rdfs:label "LateralMovementTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Lateral Movement Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to move through your environment." ;
    skos:exactMatch d3f:LateralMovementTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CredentialAccessTechnique a owl:Class ;
    rdfs:label "CredentialAccessTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Access Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:exactMatch d3f:CredentialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DiscoveryTechnique a owl:Class ;
    rdfs:label "DiscoveryTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Discovery Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to figure out your environment." ;
    skos:exactMatch d3f:DiscoveryTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutionTechnique a owl:Class ;
    rdfs:label "ExecutionTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Execution Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to run malicious code." ;
    skos:exactMatch d3f:ExecutionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:associated_with a owl:DatatypeProperty ;
    rdfs:label "associated-with" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x associated-with y: The subject x and object y are associated in some way.  This is the most general definite relationship in d3fend (i.e., most general relationship that is not prefixed by 'may-'.)" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PersistenceTechnique a owl:Class ;
    rdfs:label "PersistenceTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Persistence Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to maintain their foothold." ;
    skos:exactMatch d3f:PersistenceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DefenseEvasionTechnique a owl:Class ;
    rdfs:label "DefenseEvasionTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Defense Evasion Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to avoid being detected." ;
    skos:exactMatch d3f:DefenseEvasionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

<https://d3fend.mitre.org/ontologies/d3fend.owl> a owl:Ontology ;
    rdfs:label "d3fend" ;
    dcterms:license "MIT" ;
    dcterms:title "D3FEND™ - A knowledge graph of cybersecurity countermeasures" ;
    rdfs:seeAlso <https://d3fend.mitre.org/>,
        <https://github.com/d3fend/d3fend-ontology> ;
    skos:definition "D3FEND is a framework which encodes a countermeasure knowledge base as a knowledge graph. The graph contains the types and relations that define key concepts in the cybersecurity countermeasure domain and the relations necessary to link those concepts to each other. Each of these concepts and relations are linked to references in the cybersecurity literature." .

