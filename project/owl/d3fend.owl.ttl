d3f:OutputDeviceEvent a owl:Class ;
    rdfs:label "OutputDeviceEvent" ;
    dcterms:title "Output Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event describing the activity or state of output devices, including sound cards, display adapters, or media controllers. These events relate to audio, video, or graphics functionality." ;
    skos:exactMatch d3f:OutputDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:POSIXSymbolicLink a owl:Class ;
    rdfs:label "POSIXSymbolicLink" ;
    dcterms:title "POSIX Symbolic Link" ;
    rdfs:seeAlso dbr:Symbolic_link ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UnixLink ],
        d3f:SymbolicLink ;
    skos:definition "A POSIX-compliant symbolic link. These are often fast symbolic links, but need not be." ;
    skos:exactMatch d3f:POSIXSymbolicLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PackageURL a owl:Class ;
    rdfs:label "PackageURL" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Package URL" ;
    rdfs:seeAlso <https://github.com/package-url/purl-spec>,
        <https://github.com/package-url/purl-spec/blob/main/PURL-SPECIFICATION.rst> ;
    rdfs:subClassOf d3f:URL ;
    skos:altLabel "purl" ;
    skos:definition "A package URL, or purl, is a URL used to identify a software package in a mostly universal and uniform way across programming languages, package managers, packaging conventions, tools, APIs and databases." ;
    skos:exactMatch d3f:PackageURL ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PacketCaptureFile a owl:Class ;
    rdfs:label "PacketCaptureFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Packet Capture File" ;
    rdfs:subClassOf d3f:File ;
    skos:definition "A file which contains raw representations of collected packets." ;
    skos:exactMatch d3f:PacketCaptureFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PacketLog a owl:Class ;
    rdfs:label "PacketLog" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Packet Log" ;
    rdfs:seeAlso dbr:Packet_analyzer ;
    rdfs:subClassOf d3f:Log ;
    skos:definition "A log of all the network packet data captured from a network by a network sensor (i.e., packet analyzer)," ;
    skos:exactMatch d3f:PacketLog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Page a owl:Class ;
    rdfs:label "Page" ;
    rdfs:seeAlso <https://dbpedia.org/page/Page_(computer_memory)> ;
    rdfs:subClassOf d3f:MemoryBlock ;
    skos:definition "A page, memory page, logical page, or virtual page is a fixed-length contiguous block of virtual memory, described by a single entry in the page table. It is the smallest unit of data for memory management in a virtual memory operating system." ;
    skos:exactMatch d3f:Page ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PageFrame a owl:Class ;
    rdfs:label "PageFrame" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Page Frame" ;
    rdfs:seeAlso <https://dbpedia.org/page/Page_(computer_memory)> ;
    rdfs:subClassOf d3f:MemoryBlock ;
    skos:definition "A page frame is the smallest fixed-length contiguous block of physical memory into which memory pages are mapped by the operating system." ;
    skos:exactMatch d3f:PageFrame ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PageTable a owl:Class ;
    rdfs:label "PageTable" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Page Table" ;
    rdfs:seeAlso dbr:Page_table ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A page table  is the data structure used by the MMU in a virtual memory computer system  to store the mapping between virtual addresses (virtual pages) and physical addresses (page frames)." ;
    skos:exactMatch d3f:PageTable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ParametricTests a owl:Class ;
    rdfs:label "ParametricTests" ;
    d3f:d3fend-id "D3A-PT" ;
    d3f:kb-article "## References Newcastle University. (n.d.). Parametric Hypothesis Tests. [Link](https://www.ncl.ac.uk/webtemplate/ask-assets/external/maths-resources/psychology/parametric-hypothesis-tests.html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Parametric Tests" ;
    rdfs:subClassOf d3f:HypothesisTesting ;
    skos:definition "A parametric test relies upon the assumption that the data you want to test is (or approximately is) normally distributed." ;
    skos:exactMatch d3f:ParametricTests ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ParentProcess a owl:Class ;
    rdfs:label "ParentProcess" ;
    dcterms:title "Parent Process" ;
    rdfs:seeAlso dbr:Child_process,
        dbr:Parent_process ;
    rdfs:subClassOf d3f:Process ;
    skos:definition "In computing, a parent process is a process that has created one or more child processes." ;
    skos:exactMatch d3f:ParentProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ParticleRadiationHardening a owl:Class ;
    rdfs:label "ParticleRadiationHardening" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Ionizing Particle Hardening" ;
    dcterms:title "Particle Radiation Hardening" ;
    rdfs:seeAlso <https://www.mdpi.com/2079-9292/10/17/2144> ;
    rdfs:subClassOf d3f:RadiationHardening ;
    skos:definition "The application of material, process, layout, or circuit-level design measures to electronic systems and components to reduce susceptibility to total ionizing dose degradation and single-event effects caused by ionizing particles such as protons, heavy ions, neutrons, or electrons." ;
    skos:exactMatch d3f:ParticleRadiationHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Partition a owl:Class ;
    rdfs:label "Partition" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Disk_partitioning,
        dbr:Memory_management_\(operating_systems\),
        dbr:Partition_table ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Disk Partition",
        "Disk Slice" ;
    skos:definition "A partition is a region on secondary storage device created so that the region can be managed by itself; separate from any other regions (partitions) on that secondary storage device. Creating partitions is typically the first step of preparing a newly installed storage device, before any file system is created. The device stores the information about the partitions' locations and sizes in an area known as the partition table that the operating system reads before any other part of the disk. Each partition then appears to the operating system as a distinct \"logical\" storage device that uses part of the actual device. System administrators use a program called a partition editor to create, resize, delete, and manipulate the partitions. Partitioning allows the use of different filesystems to be installed for different kinds of files. Separating user data from system data can prevent the system partition from becoming full and rendering the system unusable. Partitioning can also make backing up easier. [Definition adapted as generalization from definition of disk partitioning and distinct from in-memory partitions.]" ;
    skos:exactMatch d3f:Partition ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PartitionTable a owl:Class ;
    rdfs:label "PartitionTable" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Partition Table" ;
    rdfs:seeAlso dbr:Partition_table ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A partition is a fixed-size subset of a storage device which is treated as a unit by the operating system. A partition table is a table maintained on the storage device by the operating system describing the partitions on that device. The terms partition table and partition map are most commonly associated with the MBR partition table of a Master Boot Record (MBR) in IBM PC compatibles, but it may be used generically to refer to other \"formats\" that divide a disk drive into partitions, such as: GUID Partition Table (GPT), Apple partition map (APM), or BSD disklabel." ;
    skos:exactMatch d3f:PartitionTable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PassiveCertificateAnalysis a owl:Class ;
    rdfs:label "PassiveCertificateAnalysis" ;
    d3f:d3fend-id "D3-PCA" ;
    d3f:kb-article "## How it works Certificates are analyzed outside of a TLS server connection using third-party secure update logs, domain name analysis and analytics. ### Secure update certificate logs * Certificate Logs The key enabling feature is a secure service that maintains record logs of certificate activit" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Passive Certificate Analysis" ;
    rdfs:subClassOf d3f:CertificateAnalysis ;
    skos:definition "Collecting host certificates from network traffic or other passive sources like a certificate transparency log and analyzing them for unauthorized activity." ;
    skos:exactMatch d3f:PassiveCertificateAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PassiveLogicalLinkMapping a owl:Class ;
    rdfs:label "PassiveLogicalLinkMapping" ;
    d3f:d3fend-id "D3-PLLM" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Passive Logical Layer Mapping" ;
    dcterms:title "Passive Logical Link Mapping" ;
    rdfs:subClassOf d3f:LogicalLinkMapping ;
    skos:definition "Passive logical link mapping only listens to network traffic as a means to map the the whole data link layer, where the links represent logical data flows rather than physical connections." ;
    skos:exactMatch d3f:PassiveLogicalLinkMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PasswordAuthentication a owl:Class ;
    rdfs:label "PasswordAuthentication" ;
    d3f:d3fend-id "D3-PWA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Authentication" ;
    rdfs:subClassOf d3f:AgentAuthentication ;
    skos:broadMatch d3f:T1110 ;
    skos:definition "Password authentication is a security mechanism used to verify the identity of a user or entity attempting to access a system or resource by requiring the input of a secret string of characters, known as a password, that is associated with the user or entity." ;
    skos:exactMatch d3f:PasswordAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003 .

d3f:PasswordFile a owl:Class ;
    rdfs:label "PasswordFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password File" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PasswordDatabase ],
        d3f:File ;
    skos:definition "Simple form of password database held in a single file (e.g., /etc/password)" ;
    skos:exactMatch d3f:PasswordFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PasswordManager a owl:Class ;
    rdfs:label "PasswordManager" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Manager" ;
    rdfs:seeAlso dbr:Password_manager ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "A password manager is a software application or hardware that helps a user store and organize passwords. Password managers usually store passwords encrypted, requiring the user to create a master password: a single, ideally very strong password which grants the user access to their entire password database. Some password managers store passwords on the user's computer (called offline password managers), whereas others store data in the provider's cloud (often called online password managers). However offline password managers also offer data storage in the user's own cloud accounts rather than the provider's cloud. While the core functionality of a password manager is to securely store large collections of passwords, many provide additional features such as form filling and password generation." ;
    skos:exactMatch d3f:PasswordManager ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PatentReference a owl:Class ;
    rdfs:label "PatentReference" ;
    d3f:pref-label "Patent" ;
    dcterms:title "Patent Reference" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:exactMatch d3f:PatentReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PearsonsCorrelationCoefficient a owl:Class ;
    rdfs:label "PearsonsCorrelationCoefficient" ;
    d3f:d3fend-id "D3A-PCC" ;
    d3f:kb-article "## References Wolfram MathWorld. (n.d.). Correlation Coefficient. [Link](https://mathworld.wolfram.com/CorrelationCoefficient.html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pearson's Correlation Coefficient" ;
    rdfs:subClassOf d3f:Correlation ;
    skos:exactMatch d3f:PearsonsCorrelationCoefficient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PeripheralDeviceEvent a owl:Class ;
    rdfs:label "PeripheralDeviceEvent" ;
    dcterms:title "Peripheral Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event involving external or auxiliary devices, such as USB drives, Thunderbolt peripherals, or Bluetooth devices. Peripheral events provide visibility into resource availability and potential unauthorized access." ;
    skos:exactMatch d3f:PeripheralDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PeripheralFirmwareVerification a owl:Class ;
    rdfs:label "PeripheralFirmwareVerification" ;
    d3f:d3fend-id "D3-PFV" ;
    d3f:kb-article "# How it works Peripherial firmware is collected and analyzed on a host either periodically or on demand. This information may be collected for future comparisons. Changes in firmware hash values may indicate that the firmware has been tampered with or that firmware images are not maintained to cu" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Peripheral Firmware Verification" ;
    rdfs:subClassOf d3f:FirmwareVerification ;
    skos:definition "Cryptographically verifying peripheral firmware integrity." ;
    skos:exactMatch d3f:PeripheralFirmwareVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PeripheralHubFirmware a owl:Class ;
    rdfs:label "PeripheralHubFirmware" ;
    dcterms:title "Peripheral Hub Firmware" ;
    rdfs:seeAlso dbr:USB_hub ;
    rdfs:subClassOf d3f:PeripheralFirmware ;
    skos:altLabel "USB Hub Firmware" ;
    skos:definition "Firmware that is installed on peripheral hub device such as a USB or Firewire hub." ;
    skos:exactMatch d3f:PeripheralHubFirmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Person a owl:Class ;
    rdfs:label "Person" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:Agent ;
    skos:closeMatch oscal:Party ;
    skos:definition "A person is a human being." ;
    skos:exactMatch d3f:Person,
        spdx:Person,
        unified_cyber_ontology:Person ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhiCoefficient a owl:Class ;
    rdfs:label "PhiCoefficient" ;
    d3f:d3fend-id "D3A-PC" ;
    d3f:kb-article "## References \\Wikipedia. (n.d.). Phi coefficient. [Link](https://en.wikipedia.org/wiki/Phi_coefficient)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "MCC" ;
    dcterms:title "Phi Coefficient" ;
    rdfs:subClassOf d3f:Correlation ;
    skos:definition "The phi coefficient (or mean square contingency coefficient is a measure of association for two binary variables." ;
    skos:exactMatch d3f:PhiCoefficient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalAddress a owl:Class ;
    rdfs:label "PhysicalAddress" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Address" ;
    rdfs:seeAlso <https://dbpedia.org/page/Physical_address> ;
    rdfs:subClassOf d3f:MemoryAddress ;
    skos:definition "In a computer supporting virtual memory, the term physical address is used mostly to differentiate from a virtual address. In particular, in computers utilizing a memory management unit(MMU) to translate memory addresses, the virtual and physical addresses refer to an address before and after translation performed by the MMU, respectively." ;
    skos:exactMatch d3f:PhysicalAddress ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalAttacker a owl:Class ;
    rdfs:label "PhysicalAttacker" ;
    dcterms:title "Physical Attacker" ;
    rdfs:subClassOf d3f:LocalAttacker ;
    skos:definition "An attacker who is physically close enough to interact with the system directly, such as through physical access to devices." ;
    skos:exactMatch d3f:PhysicalAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalDataDiode a owl:Class ;
    rdfs:label "PhysicalDataDiode" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Data Diode" ;
    rdfs:seeAlso <https://isagca.org/hubfs/2023%20ISA%20Website%20Redesigns/ISAGCA/PDFs/Industrial%20Cybersecurity%20Knowledge%20FINAL.pdf?hsLang=en> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A device that physically enforces one-way (unidirectional) network communication." ;
    skos:exactMatch d3f:PhysicalDataDiode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "https://owlcyberdefense.com/products/data-diode-products/" .

d3f:PhysicalEnclosureHardening a owl:Class ;
    rdfs:label "PhysicalEnclosureHardening" ;
    d3f:d3fend-id "D3-PEH" ;
    d3f:kb-article "## How it works System designers or operators make physical changes to a computer enclosure which reduce the ability for agents or the environment to affect the contained computer system. These additions to the enclosure may be of various materials to reduce the effects of heat, gases, vibration, o" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Enclosure Hardening" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:definition "Physical changes to a computer enclosure which reduce the ability for agents or the environment to affect the contained computer system." ;
    skos:exactMatch d3f:PhysicalEnclosureHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalKey a owl:Class ;
    rdfs:label "PhysicalKey" ;
    dcterms:title "Physical Key" ;
    rdfs:subClassOf d3f:PhysicalArtifact ;
    skos:definition "A physical key is used to operate a lock, typically metal, designed with specific markers that match the internal mechanism of a lock, allowing it to rotate the lock when inserted." ;
    skos:exactMatch d3f:PhysicalKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalKeyLock a owl:Class ;
    rdfs:label "PhysicalKeyLock" ;
    d3f:synonym "keyed lock" ;
    dcterms:title "Physical Key Lock" ;
    rdfs:subClassOf d3f:PhysicalLock ;
    skos:definition "A mechanical locking device for securing moveable portions of physical barriers (e.g., doors, gates, drawers) in a secured position." ;
    skos:exactMatch d3f:PhysicalKeyLock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkConnectEvent a owl:Class ;
    rdfs:label "PhysicalLinkConnectEvent" ;
    dcterms:title "Physical Link Connect Event" ;
    rdfs:subClassOf d3f:PhysicalLinkEvent ;
    skos:definition "The medium is attached or the port is enabled, establishing electrical or optical continuity so that link negotiation can begin." ;
    skos:exactMatch d3f:PhysicalLinkConnectEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkDisableEvent a owl:Class ;
    rdfs:label "PhysicalLinkDisableEvent" ;
    dcterms:title "Physical Link Disable Event" ;
    rdfs:subClassOf d3f:PhysicalLinkEvent ;
    skos:definition "An administrator issues a shutdown or disable command, forcing the link out of service regardless of signal status." ;
    skos:exactMatch d3f:PhysicalLinkDisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkDisconnectEvent a owl:Class ;
    rdfs:label "PhysicalLinkDisconnectEvent" ;
    dcterms:title "Physical Link Disconnect Event" ;
    rdfs:subClassOf d3f:PhysicalLinkEvent ;
    skos:definition "The transmission medium is removed or power is cut, physically breaking the path between the two interfaces." ;
    skos:exactMatch d3f:PhysicalLinkDisconnectEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkDownEvent a owl:Class ;
    rdfs:label "PhysicalLinkDownEvent" ;
    dcterms:title "Physical Link Down Event" ;
    rdfs:subClassOf d3f:PhysicalLinkEvent ;
    skos:definition "Carrier or negotiation is lost, or the port is shut, rendering the link non-operational while the medium remains connected." ;
    skos:exactMatch d3f:PhysicalLinkDownEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkErrorDisableEvent a owl:Class ;
    rdfs:label "PhysicalLinkErrorDisableEvent" ;
    dcterms:title "Physical Link Error Disable Event" ;
    rdfs:subClassOf d3f:PhysicalLinkEvent ;
    skos:definition "The device automatically disables the link in response to fault conditions such as excessive faults or signal degradation." ;
    skos:exactMatch d3f:PhysicalLinkErrorDisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkUpEvent a owl:Class ;
    rdfs:label "PhysicalLinkUpEvent" ;
    dcterms:title "Physical Link Up Event" ;
    rdfs:subClassOf d3f:PhysicalLinkEvent ;
    skos:definition "Auto-negotiation and signal detection complete; carrier is present and the link can forward frames." ;
    skos:exactMatch d3f:PhysicalLinkUpEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLocation a owl:Class ;
    rdfs:label "PhysicalLocation" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Location" ;
    rdfs:seeAlso dbr:Location_\(geography\),
        <https://schema.ocsf.io/objects/location> ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:definition "The terms location  [here, a physical location] and place in geography are used to identify a point or an area on the Earth's surface or elsewhere. The term location generally implies a higher degree of certainty than place, which often indicates an entity with an ambiguous boundary, relying more on human or social attributes of place identity and sense of place than on geometry. The distinction between space and place is considered a central concern of geography, and has been addressed by scholars such as Yi-Fu Tuan and John Agnew." ;
    skos:exactMatch d3f:PhysicalLocation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLocking a owl:Class ;
    rdfs:label "PhysicalLocking" ;
    d3f:d3fend-id "D3-EPL" ;
    d3f:kb-article "## How it works A physical mechanism which has a associated credential which when entered enables the lock bolt to operate, i.e. open or close. ## Considerations * Consider that locks for specified materials should adhere to relevant regulations. * Lock equipment cabinets when not needed for ope" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Locking" ;
    rdfs:subClassOf d3f:PhysicalAccessMediation ;
    skos:definition "Employ a mechanical locking device for securing moveable portions of physical barriers (e.g., doors, gates, drawers) in a secured position." ;
    skos:exactMatch d3f:PhysicalLocking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Pix2Pix a owl:Class ;
    rdfs:label "Pix2Pix" ;
    d3f:d3fend-id "D3A-PIX" ;
