d3f:HTTPConnectEvent a owl:Class ;
    rdfs:label "HTTPConnectEvent" ;
    dcterms:title "HTTP CONNECT Event" ;
    rdfs:subClassOf d3f:HTTPRequestEvent ;
    skos:definition "An event where the HTTP CONNECT method is used to establish a tunnel to the server identified by the target resource." ;
