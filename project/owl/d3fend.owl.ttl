d3f:ApplicationProcessConfiguration a owl:Class ;
    rdfs:label "ApplicationProcessConfiguration" ;
    dcterms:title "Application Process Configuration" ;
    rdfs:subClassOf d3f:ApplicationConfiguration ;
    skos:definition "The current configuration of an application process, stored in memory. It may have been sourced from other types of application configurations, e.g. Application Configuration Files or Application Configuration Database Records." ;
    skos:exactMatch d3f:ApplicationProcessConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationShim a owl:Class ;
