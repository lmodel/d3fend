    skos:exactMatch d3f:DynamicAnalysisTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ElectricalSignal a owl:Class ;
    rdfs:label "ElectricalSignal" ;
    dcterms:title "Electrical Signal" ;
