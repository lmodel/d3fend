d3f:ContentFormatConversion a owl:Class ;
    rdfs:label "ContentFormatConversion" ;
    d3f:d3fend-id "D3-CFC" ;
    d3f:kb-article "## How it works This technique may enhance security by transforming files into safer or normalized formats." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Content Format Conversion" ;
    rdfs:subClassOf d3f:ContentModification ;
    skos:definition "Content format conversion is mechanical transformation from one format to another which may be normalization or specifically flattening." ;
    skos:exactMatch d3f:ContentFormatConversion ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ContentPolicy a owl:Class ;
    rdfs:label "ContentPolicy" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Content Policy" ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A set of rules and guidelines that dictate the acceptable use, distribution, and management of digital content within a system or platform. It defines what content is allowed, restricted, or prohibited, ensuring compliance with legal, ethical, and organizational standards." ;
    skos:exactMatch d3f:ContentPolicy ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

