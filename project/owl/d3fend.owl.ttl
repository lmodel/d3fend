    skos:definition "x may-access y: They entity x may access the thing y; that is, 'x accesses y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_add a owl:DatatypeProperty ;
