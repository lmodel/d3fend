        d3f:OffensiveTactic,
        d3f:SPARTATacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Reconnaissance",
        "Threat actor is trying to gather information they can use to plan future operations." ;
    skos:editorialNote "Threat actor is trying to gather information they can use to plan future operations." ;
    skos:exactMatch d3f:ST0001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ST0002 a owl:Class ;
    rdfs:label "ST0002" ;
    d3f:display-order "2" ;
