        d3f:T1555 ;
    skos:definition "Analyzing system calls to determine whether a process is exhibiting unauthorized behavior." ;
    skos:exactMatch d3f:SystemCallAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1007,
