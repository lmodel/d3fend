    d3f:d3fend-id "D3-DEM" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Data Flow Mapping" ;
    dcterms:title "Data Exchange Mapping" ;
    rdfs:subClassOf d3f:SystemMapping ;
    skos:definition "Data exchange mapping identifies and models the organization's intended design for the flows of the data types, formats, and volumes between systems at the application layer." ;
    skos:exactMatch d3f:DataExchangeMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

