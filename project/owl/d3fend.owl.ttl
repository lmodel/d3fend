    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-setthreadcontext> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:SetThreadContext ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ShadowStack a owl:Class ;
    rdfs:label "ShadowStack" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Shadow Stack" ;
    rdfs:seeAlso <https://dbpedia.org/page/Shadow_stack> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A shadow stack is a mechanism for protecting a procedure's stored return address, such as from a stack buffer overflow. The shadow stack itself is a second, separate stack that \"shadows\" the program call stack. In the function prologue, a function stores its return address to both the call stack and the shadow stack. In the function epilogue, a function loads the return address from both the call stack and the shadow stack, and then compares them. If the two records of the return address differ, then an attack is detected." ;
    skos:exactMatch d3f:ShadowStack ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ShadowStackComparisons a owl:Class ;
    rdfs:label "ShadowStackComparisons" ;
    d3f:d3fend-id "D3-SSC" ;
    d3f:kb-article "## How it works This technique compares the call stack stored in system memory with the shadow call stack maintained in the cache memory of the processor. Mismatches between the two are compared since a return oriented programming attack may only be able to control or spoof the call stack and not t" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Shadow Stack Comparisons" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PrivilegeEscalationTechnique ;
    skos:definition "Comparing a call stack in system memory with a shadow call stack maintained by the processor to determine unauthorized shellcode activity." ;
    skos:exactMatch d3f:ShadowStackComparisons ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1068,
        mitre-attack:T1203,
        mitre-attack:T1210,
        mitre-attack:T1211,
        mitre-attack:T1212 .

