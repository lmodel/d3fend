d3f:FileInternalStructureVerification a owl:Class ;
    rdfs:label "FileInternalStructureVerification" ;
    d3f:d3fend-id "D3-FISV" ;
    d3f:kb-article "## How it works File format specifications often define expected values for specific fields. A common example are file signatures, or magic numbers, which are used to quickly identify files. Another example is within the Compound Document Header of Microsoft Office files, the 29th and 30th byte ide" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Internal Structure Verification" ;
    rdfs:subClassOf d3f:FileFormatVerification ;
    skos:definition "The process of checking specific static values within a file, such as file signatures or magic numbers, to ensure they match the expected values defined by the file format specification." ;
    skos:exactMatch d3f:FileInternalStructureVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileMagicByteVerification a owl:Class ;
    rdfs:label "FileMagicByteVerification" ;
    d3f:d3fend-id "D3-FMBV" ;
    d3f:kb-article "## How it works Many file formats use magic numbers to identify a file format or protocol. Verifying that the magic number matches the expected value of its declared format is a simple way of verifying the file format." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Magic Byte Verification" ;
    rdfs:subClassOf d3f:FileMetadataValueVerification ;
    skos:definition "Utilizing the magic number to verify the file" ;
    skos:exactMatch d3f:FileMagicByteVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileMagicBytes a owl:Class ;
    rdfs:label "FileMagicBytes" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Magic Bytes" ;
    rdfs:subClassOf d3f:FileHeaderBlockSignature ;
    skos:definition "A specific type of header signature located at the beginning of a file, used to identify the file format." ;
    skos:exactMatch d3f:FileMagicBytes ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileMetadataConsistencyValidation a owl:Class ;
    rdfs:label "FileMetadataConsistencyValidation" ;
    d3f:d3fend-id "D3-FMCV" ;
    d3f:kb-article "## How it works This technique involves validating the consistency between a file's metadata and its actual content. It checks elements like declared lengths, pointers, and checksums to ensure they accurately describe the file's content. For instance, if a header specifies a content block of 50 byt" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Metadata Consistency Validation" ;
    rdfs:subClassOf d3f:FileFormatVerification ;
    skos:definition "The process of validating the consistency between a file's metadata and its actual content, ensuring that elements like declared lengths, pointers, and checksums accurately describe the file's content." ;
    skos:exactMatch d3f:FileMetadataConsistencyValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileMountEvent a owl:Class ;
    rdfs:label "FileMountEvent" ;
    dcterms:title "File Mount Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file system or storage volume is mounted, making its files and directories accessible to the operating system or applications." ;
    skos:exactMatch d3f:FileMountEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FilePathOpenFunction a owl:Class ;
    rdfs:label "FilePathOpenFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Path Open Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Has an input of a file path, and opens a file handle for reading or writing." ;
    skos:exactMatch d3f:FilePathOpenFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileRenamingEvent a owl:Class ;
    rdfs:label "FileRenamingEvent" ;
    dcterms:title "File Renaming Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event representing the renaming of a file, modifying its identifier within the file system while retaining its content and metadata." ;
    skos:exactMatch d3f:FileRenamingEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileServer a owl:Class ;
    rdfs:label "FileServer" ;
    dcterms:title "File Server" ;
    rdfs:seeAlso dbr:File_server ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "The term server highlights the role of the machine in the traditional client-server scheme, where the clients are the workstations using the storage. A file server does not normally perform computational tasks or run programs on behalf of its client workstations. File servers are commonly found in schools and offices, where users use a local area network to connect their client computers." ;
    skos:exactMatch d3f:FileServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileSetAttributesEvent a owl:Class ;
    rdfs:label "FileSetAttributesEvent" ;
    dcterms:title "File Set Attributes Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file's metadata attributes are modified, such as changing its timestamps, labels, or categorization within the system." ;
    skos:exactMatch d3f:FileSetAttributesEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileSetPermissionsEvent a owl:Class ;
    rdfs:label "FileSetPermissionsEvent" ;
    dcterms:title "File Set Permissions Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event involving the modification of a file's permissions or access control list (ACL), specifying which users or processes are granted or restricted access." ;
    skos:exactMatch d3f:FileSetPermissionsEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileShareService a owl:Class ;
    rdfs:label "FileShareService" ;
    dcterms:title "File Share Service" ;
    rdfs:seeAlso dbr:File_sharing ;
    rdfs:subClassOf d3f:NetworkService ;
    skos:definition "A file sharing service (or file share service) provides the ability to share data across a network." ;
    skos:exactMatch d3f:FileShareService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileSystem a owl:Class ;
    rdfs:label "FileSystem" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File System" ;
    rdfs:seeAlso dbr:File_system ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In computing, a file system or filesystem is used to control how data is stored and retrieved. Without a file system, information placed in a storage medium would be one large body of data with no way to tell where one piece of information stops and the next begins. By separating the data into pieces and giving each piece a name, the information is easily isolated and identified. Taking its name from the way paper-based information systems are named, each group of data is called a \"file\". The structure and logic rules used to manage the groups of information and their names is called a \"file system\"." ;
    skos:exactMatch d3f:FileSystem,
        unified_cyber_ontology:FileSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileSystemMetadata a owl:Class ;
    rdfs:label "FileSystemMetadata" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File System Metadata" ;
    rdfs:seeAlso <http://dbpedia.org/resource/File_system#Metadata> ;
    rdfs:subClassOf d3f:Metadata ;
    skos:definition "Metadata about the files and directories in a file system.  For example file name, file length, time modified, group and user ids, and other file attributes." ;
    skos:exactMatch d3f:FileSystemMetadata ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileSystemSensor a owl:Class ;
    rdfs:label "FileSystemSensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File System Sensor" ;
    rdfs:subClassOf d3f:EndpointSensor ;
    skos:definition "Collects files and file metadata on an endpoint." ;
    skos:exactMatch d3f:FileSystemSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileUnmountEvent a owl:Class ;
    rdfs:label "FileUnmountEvent" ;
    dcterms:title "File Unmount Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file system or storage volume is unmounted, disconnecting its files and directories from the operating system or applications." ;
    skos:exactMatch d3f:FileUnmountEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileUpdateEvent a owl:Class ;
    rdfs:label "FileUpdateEvent" ;
    dcterms:title "File Update Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event involving changes to the content or metadata of an existing file, reflecting updates that alter its state or properties." ;
    skos:exactMatch d3f:FileUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FingerPrintScannerInputDevice a owl:Class ;
    rdfs:label "FingerPrintScannerInputDevice" ;
    dcterms:title "Finger Print Scanner Input Device" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Fingerprint#Fingerprint_sensors> ;
    rdfs:subClassOf d3f:ImageScannerInputDevice ;
    skos:altLabel "Fingerprint Sensor" ;
    skos:definition "A fingerprint sensor is an electronic device used to capture a digital image of the fingerprint pattern. The captured image is called a live scan. This live scan is digitally processed to create a biometric template (a collection of extracted features) which is stored and used for matching. Many technologies have been used including optical, capacitive, RF, thermal, piezoresistive, ultrasonic, piezoelectric, and MEMS." ;
    skos:exactMatch d3f:FingerPrintScannerInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FirmwareBehaviorAnalysis a owl:Class ;
    rdfs:label "FirmwareBehaviorAnalysis" ;
    d3f:d3fend-id "D3-FBA" ;
    d3f:kb-article "## How it works Firmware behavior analysis provides protections by ensuring that installed firmware has not been tampered with or modified. Firmware analysis applies to mutable firmware and immutable read-only memory (ROMs). Firmware in deployed network devices is typically not analyzed and monitor" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Firmware Timing Analysis" ;
    dcterms:title "Firmware Behavior Analysis" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:T1542 ;
    skos:definition "Analyzing the behavior of embedded code in firmware and looking for anomalous behavior and suspicious activity." ;
    skos:exactMatch d3f:FirmwareBehaviorAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1014,
        mitre-attack:T1542.001,
        mitre-attack:T1542.002,
        mitre-attack:T1542.004 .

d3f:FirmwareEmbeddedMonitoringCode a owl:Class ;
    rdfs:label "FirmwareEmbeddedMonitoringCode" ;
    d3f:d3fend-id "D3-FEMC" ;
    d3f:kb-article "## How it works Firmware in deployed network devices is typically not monitored for malicious changes. This technique provides a method to embed a software security component into the deployed firmware which provides a near real-time monitoring hook. The exception handling code, in the firmware, is" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Firmware Embedded Monitoring Code" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:T1542 ;
    skos:definition "Monitoring code is injected into firmware for integrity monitoring of firmware and firmware data." ;
    skos:exactMatch d3f:FirmwareEmbeddedMonitoringCode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1014,
        mitre-attack:T1542.001,
        mitre-attack:T1542.002,
        mitre-attack:T1542.004 .

d3f:FirmwareSensor a owl:Class ;
    rdfs:label "FirmwareSensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Firmware Sensor" ;
    rdfs:subClassOf d3f:EndpointSensor ;
    skos:definition "Collects information on firmware installed on an Endpoint." ;
    skos:exactMatch d3f:FirmwareSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FlashMemory a owl:Class ;
    rdfs:label "FlashMemory" ;
    dcterms:title "Flash Memory" ;
    rdfs:seeAlso <https://dbpedia.org/page/Flash_memory> ;
    rdfs:subClassOf d3f:SecondaryStorage ;
    skos:definition "Flash memory is an electronic non-volatile computer memory storage medium that can be electrically erased and reprogrammed." ;
    skos:exactMatch d3f:FlashMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ForwardProxyServer a owl:Class ;
    rdfs:label "ForwardProxyServer" ;
    dcterms:title "Forward Proxy Server" ;
    rdfs:seeAlso dbr:Open_proxy ;
    rdfs:subClassOf d3f:ProxyServer ;
    skos:definition "An forward (or open) proxy is a proxy server that is accessible by any Internet user. Generally, a proxy server only allows users within a network group (i.e. a closed proxy) to store and forward Internet services such as DNS or web pages to reduce and control the bandwidth used by the group. With an open proxy, however, any user on the Internet is able to use this forwarding service." ;
    skos:exactMatch d3f:ForwardProxyServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ForwardResolutionIPDenylisting a owl:Class ;
    rdfs:label "ForwardResolutionIPDenylisting" ;
    d3f:d3fend-id "D3-FRIDL" ;
    d3f:kb-article "## How it works This technique prevents a client from learning IP addresses deemed to be potentially malicious, which would have been delivered via forward resolution responses. Responses to forward resolution requests (that is, requests where a domain is sent and IP(s) are returned) are collected" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Forward Resolution IP Blacklisting" ;
    dcterms:title "Forward Resolution IP Denylisting" ;
    rdfs:subClassOf d3f:DNSDenylisting ;
    skos:definition "Blocking a DNS lookup's answer's IP address value." ;
    skos:exactMatch d3f:ForwardResolutionIPDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FreeMemory a owl:Class ;
    rdfs:label "FreeMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Free Memory" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:FreeMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FullVolumeSnapshot a owl:Class ;
    rdfs:label "FullVolumeSnapshot" ;
    dcterms:title "Full Volume Snapshot" ;
    rdfs:seeAlso <https://aws.amazon.com/compare/the-difference-between-incremental-differential-and-other-backups/> ;
    rdfs:subClassOf d3f:VolumeSnapshot ;
    skos:definition "A full volume snapshot is a point-in-time copy of the complete contents of a volume." ;
    skos:exactMatch d3f:FullVolumeSnapshot ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FuzzyLogic a owl:Class ;
    rdfs:label "FuzzyLogic" ;
    d3f:d3fend-id "D3A-FL" ;
    d3f:kb-article "## How it works It is employed to handle the concept of partial truth, where the truth value may range between completely true and completely false.[1] By contrast, in Boolean logic, the truth values of variables may only be the integer values 0 or 1. ## References 1. Fuzzy logic. (2023, May 28). I" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Fuzzy Logic" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "Fuzzy logic is a form of many-valued logic in which the truth value of variables may be any real number between 0 and 1." ;
    skos:exactMatch d3f:FuzzyLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GNSSReceiver a owl:Class ;
    rdfs:label "GNSSReceiver" ;
    dcterms:title "GNSS Receiver" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Satellite_navigation> ;
    rdfs:subClassOf d3f:Receiver ;
    skos:definition "A GNSS (Global Navigation Satellite System) receiver is an electronic device that picks up signals from one or more satellite constellations (like GPS, GLONASS, Galileo, BeiDou) to calculate precise location, velocity, and time." ;
    skos:exactMatch d3f:GNSSReceiver ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GNSSSatellite a owl:Class ;
    rdfs:label "GNSSSatellite" ;
    dcterms:title "GNSS Satellite" ;
    rdfs:seeAlso dbr:Satellite_navigation ;
    rdfs:subClassOf d3f:Satellite ;
    skos:definition "A GNSS satellite is part of a space-based constellation that transmits signals, allowing receivers on Earth to determine their position, navigation, and timing (PNT) through trilateration." ;
    skos:exactMatch d3f:GNSSSatellite ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GNSSSignal a owl:Class ;
    rdfs:label "GNSSSignal" ;
    d3f:synonym "Global Navigation Satellite System Signal" ;
    dcterms:title "GNSS Signal" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Satellite_navigation>,
        <https://gssc.esa.int/navipedia/index.php/GNSS_signal> ;
    rdfs:subClassOf d3f:ElectromagneticSignal ;
    skos:definition "A GNSS (Global Navigation Satellite System) signal is a low-power radio signal broadcast from satellites that contains a carrier wave, a ranging code, and a navigation message. The receiver uses the carrier wave to precisely measure the time it takes for the signal to travel from the satellite, while the navigation message provides essential information like the satellite's position (ephemeris) and clock information." ;
    skos:exactMatch d3f:GNSSSignal ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GNSSTimeRecord a owl:Class ;
    rdfs:label "GNSSTimeRecord" ;
    dcterms:title "GNSS Time Record" ;
    rdfs:seeAlso <https://gssc.esa.int/navipedia/index.php/Time_References_in_GNSS> ;
    rdfs:subClassOf d3f:TimeRecord ;
    skos:definition "A GNSS Time Record is an information content entity encoded in a GNSS signal that represents the transmission time of that signal as determined by the transmitting satellite, expressed relative to a constellation-specific time standard and epoch." ;
    skos:exactMatch d3f:GNSSTimeRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GPT a owl:Class ;
    rdfs:label "GPT" ;
    d3f:d3fend-id "D3A-GPT" ;
    d3f:kb-article "## References Generative pre-trained transformer. (n.d.). In Wikipedia. [Link](https://en.wikipedia.org/wiki/Generative_pre-trained_transformer)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Generative Pre-trained Transformer" ;
    rdfs:subClassOf d3f:TransformerBasedLearning ;
    skos:definition "Generative pre-trained transformers (GPT) are a type of large language model (LLM) and a prominent framework for generative artificial intelligence." ;
    skos:exactMatch d3f:GPT ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GatedRecurrentUnit a owl:Class ;
    rdfs:label "GatedRecurrentUnit" ;
    d3f:d3fend-id "D3A-GRU" ;
    d3f:kb-article "## References Wikipedia. (2021, September 20). Gated Recurrent Unit. [Link](https://en.wikipedia.org/wiki/Gated_recurrent_unit)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Gated Recurrent Unit" ;
    rdfs:subClassOf d3f:RecurrentNeuralNetwork ;
    skos:definition "The GRU is like a long short-term memory (LSTM) with a forget gate, but has fewer parameters than LSTM, as it lacks an output gate. GRU's performance on certain tasks of polyphonic music modeling, speech signal modeling and natural language processing was found to be similar to that of LSTM" ;
    skos:exactMatch d3f:GatedRecurrentUnit ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GeometricMean a owl:Class ;
    rdfs:label "GeometricMean" ;
    d3f:d3fend-id "D3A-GM" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Geometric Mean" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "The nth root of the product of the data values, where there are n of these. This measure is valid only for data that are measured absolutely on a strictly positive scale." ;
    skos:exactMatch d3f:GeometricMean ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetOpenSockets a owl:Class ;
    rdfs:label "GetOpenSockets" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get Open Sockets" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:GetOpenSockets ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetOpenWindows a owl:Class ;
    rdfs:label "GetOpenWindows" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get Open Windows" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:GetOpenWindows ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetRunningProcesses a owl:Class ;
    rdfs:label "GetRunningProcesses" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get Running Processes" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:GetRunningProcesses ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetScreenCapture a owl:Class ;
    rdfs:label "GetScreenCapture" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get Screen Capture" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:GetScreenCapture ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetSystemNetworkConfigValue a owl:Class ;
    rdfs:label "GetSystemNetworkConfigValue" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get System Network Config Value" ;
    rdfs:subClassOf d3f:GetSystemConfigValue ;
    skos:exactMatch d3f:GetSystemNetworkConfigValue ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetSystemTime a owl:Class ;
    rdfs:label "GetSystemTime" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get System Time" ;
    rdfs:seeAlso <https://man7.org/linux/man-pages/man2/time.2.html> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "A system call that gets the system time. For POSIX.1 systems, time() invokes a call to get the system time." ;
    skos:exactMatch d3f:GetSystemTime ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetThreadContext a owl:Class ;
    rdfs:label "GetThreadContext" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get Thread Context" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-getthreadcontext> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:GetThreadContext ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GlobalUserAccount a owl:Class ;
    rdfs:label "GlobalUserAccount" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Global User Account" ;
    rdfs:seeAlso <https://networkencyclopedia.com/global-user-account> ;
    rdfs:subClassOf d3f:DomainUserAccount ;
    skos:definition "A type of user account in Microsoft Windows (NT) that has a domain-wide scope.defines that user's access to a logical group of network objects (computers, users, devices) that share the same Active Directory databases; that is, a user's access to the domain." ;
    skos:exactMatch d3f:GlobalUserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GoodmanAndKruskalsGamma a owl:Class ;
    rdfs:label "GoodmanAndKruskalsGamma" ;
    d3f:d3fend-id "D3A-GAKG" ;
    d3f:kb-article "## References 1. Wolfram Research. (2012). GoodmanKruskalGamma. Wolfram Language function. [Link](https://reference.wolfram.com/language/ref/GoodmanKruskalGamma.html) 1. Goodman and Kruskal's gamma. (2022, Nov 23). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Goodman_and_Kruskal%27s_gamma]" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Goodman and Kruskal's Gamma" ;
    rdfs:seeAlso <https://reference.wolfram.com/language/ref/GoodmanKruskalGamma.html> ;
    rdfs:subClassOf d3f:RankCorrelationCoefficient ;
    skos:definition "Goodman-Kruskal $\\\\gamma$ is a measure of rank correlation between x and y and is given by $(n_c -n_d) / (n_c + n_d)$, where $n_c$ is the number of concordant pairs of the observations and $n_d$ is the number of discordant pairs." ;
    skos:exactMatch d3f:GoodmanAndKruskalsGamma ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GradientBoostedDecisionTree a owl:Class ;
    rdfs:label "GradientBoostedDecisionTree" ;
    d3f:d3fend-id "D3A-GBDT" ;
    d3f:kb-article "## Reference 1. Google. (28 Sep 2023). Gradient Boosted Decision Trees. [Link](https://developers.google.com/machine-learning/decision-forests/intro-to-gbdt)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Gradient-Boosted Decision Tree" ;
    rdfs:subClassOf d3f:CART ;
    skos:definition "A gradient-boosted decision tree is, as in other bagging and boosting methods, a method where the relatively 'weak' machine learning model (a decision tree) is used in an ensemble to form a 'strong' machine learning model." ;
    skos:exactMatch d3f:GradientBoostedDecisionTree ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GraphicalUserInterface a owl:Class ;
    rdfs:label "GraphicalUserInterface" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Graphical User Interface" ;
    rdfs:seeAlso dbr:Graphical_user_interface ;
    rdfs:subClassOf d3f:UserInterface ;
    skos:altLabel "GUI" ;
    skos:definition "A graphical user interface (GUI)  is a type of user interface that allows users to interact with electronic devices through graphical icons and visual indicators such as secondary notation, instead of text-based user interfaces, typed command labels or text navigation. GUIs were introduced in reaction to the perceived steep learning curve of command-line interfaces (CLIs), which require commands to be typed on a computer keyboard." ;
    skos:exactMatch d3f:GraphicalUserInterface ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GraphicsCardFirmware a owl:Class ;
    rdfs:label "GraphicsCardFirmware" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Graphics Card Firmware" ;
    rdfs:seeAlso d3f:Firmware ;
    rdfs:subClassOf d3f:PeripheralFirmware ;
    skos:altLabel "Video Card Firmware" ;
    skos:definition "Firmware that is installed on computer graphics card." ;
    skos:exactMatch d3f:GraphicsCardFirmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GraphicsProcessingUnit a owl:Class ;
    rdfs:label "GraphicsProcessingUnit" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "GPU" ;
    dcterms:title "Graphics Processing Unit" ;
    rdfs:subClassOf d3f:Processor ;
    skos:definition "A Graphics Processing Unit (GPU) is a specialized processor designed to efficiently perform parallel computations, primarily for rendering graphics and visual data." ;
    skos:exactMatch d3f:GraphicsProcessingUnit ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GroupCreationEvent a owl:Class ;
    rdfs:label "GroupCreationEvent" ;
    dcterms:title "Group Creation Event" ;
    rdfs:subClassOf d3f:GroupManagementEvent ;
    skos:definition "An event where a new group is established within the system, defining an entity to manage users and permissions collectively." ;
    skos:exactMatch d3f:GroupCreationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GroupDeletionEvent a owl:Class ;
    rdfs:label "GroupDeletionEvent" ;
    dcterms:title "Group Deletion Event" ;
    rdfs:subClassOf d3f:GroupManagementEvent ;
    skos:definition "An event where an existing group is permanently removed from the system, dissolving its associated memberships and privileges." ;
    skos:exactMatch d3f:GroupDeletionEvent ;
