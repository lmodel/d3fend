    d3f:d3fend-id "D3-FFV" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Format Verification" ;
    rdfs:subClassOf d3f:ContentValidation ;
    skos:broadMatch d3f:T1564 ;
    skos:definition "Verifying that a file conforms to its expected format specifications" ;
    skos:exactMatch d3f:FileFormatVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1564.009 .

d3f:FileSystemLink a owl:Class ;
    rdfs:label "FileSystemLink" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File System Link" ;
    rdfs:seeAlso dbr:Hard_link ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A file system link associates a name with a file on a file system.  Most generally, this may be a direct reference (a hard link) or an indirect one (a soft link)." ;
    skos:exactMatch d3f:FileSystemLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Goal a owl:Class ;
    rdfs:label "Goal" ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:exactMatch d3f:Goal ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IdentifierAnalysis a owl:Class ;
    rdfs:label "IdentifierAnalysis" ;
    d3f:d3fend-id "D3-ID" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Identifier Analysis" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Analyzing identifier artifacts such as IP address, domain names, or URL(I)s." ;
    skos:exactMatch d3f:IdentifierAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IdentifierReputationAnalysis a owl:Class ;
    rdfs:label "IdentifierReputationAnalysis" ;
    d3f:d3fend-id "D3-IRA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Identifier Reputation Analysis" ;
    rdfs:subClassOf d3f:IdentifierAnalysis ;
    skos:definition "Analyzing the reputation of an identifier." ;
    skos:exactMatch d3f:IdentifierReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundInternetNetworkTraffic a owl:Class ;
    rdfs:label "InboundInternetNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inbound Internet Network Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InternetNetworkTraffic ],
        d3f:InboundNetworkTraffic ;
    skos:definition "Inbound internet traffic is network traffic from a host outside a given network initiated on an incoming connection to a host inside that network." ;
    skos:exactMatch d3f:InboundInternetNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InputDevice a owl:Class ;
    rdfs:label "InputDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Input Device" ;
    rdfs:seeAlso dbr:Input_device ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LocalResource ],
        d3f:HardwareDevice ;
    skos:definition "In computing, an input device is a piece of equipment used to provide data and control signals to an information processing system such as a computer or information appliance. Examples of input devices include keyboards, mouse, scanners, digital cameras, joysticks, and microphones." ;
    skos:exactMatch d3f:InputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LocalResource a owl:Class ;
    rdfs:label "LocalResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Resource" ;
    rdfs:seeAlso dbr:System_resource ;
    rdfs:subClassOf d3f:Resource ;
    skos:altLabel "System Resource" ;
    skos:definition "In computing, a system resource, or simply resource, is any physical or virtual component of limited availability within a computer system. Every device connected to a computer system is a resource. Every internal system component is a resource. Virtual system resources include files (concretely file handles), network connections (concretely network sockets), and memory areas. Managing resources is referred to as resource management, and includes both preventing resource leaks (releasing a resource when a process has finished using it) and dealing with resource contention (when multiple processes wish to access a limited resource)." ;
    skos:exactMatch d3f:LocalResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogicProgramming a owl:Class ;
    rdfs:label "LogicProgramming" ;
    d3f:d3fend-id "D3A-LP" ;
    d3f:kb-article "## How it works Any program written in a logic programming language is a set of sentences in logical form, expressing facts and rules about some problem domain. Major logic programming language families include Prolog, answer set programming (ASP) and Datalog. In all of these languages, rules are wr" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logic Programming" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "Logic programming is a programming paradigm which is largely based on formal logic." ;
    skos:exactMatch d3f:LogicProgramming ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogicalLink a owl:Class ;
    rdfs:label "LogicalLink" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logical Link" ;
    rdfs:subClassOf d3f:Link ;
    skos:definition "A Logical Link is an abstract or virtual connection between two entities that facilitates communication or data exchange without requiring a direct physical connection." ;
    skos:exactMatch d3f:LogicalLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ModalLogic a owl:Class ;
    rdfs:label "ModalLogic" ;
    d3f:d3fend-id "D3A-ML" ;
    d3f:kb-article "## References 1. Modal logic. (2023, June 4). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Modal_logic)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Modal Logic" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "Modal logic is a collection of formal systems developed to represent statements about necessity and possibility. It plays a major role in philosophy of language, epistemology, metaphysics, and natural language semantics." ;
    skos:exactMatch d3f:ModalLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkEvent a owl:Class ;
    rdfs:label "NetworkEvent" ;
    dcterms:title "Network Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/categories/network>,
        <https://schema.ocsf.io/categories/network> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:broadMatch unified_cyber_ontology:Action ;
    skos:definition "An event involving network communications within or between digital systems." ;
    skos:exactMatch d3f:NetworkEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkMapping a owl:Class ;
    rdfs:label "NetworkMapping" ;
    d3f:d3fend-id "D3-NM" ;
    d3f:display-order "3" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Mapping" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Network_topology> ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Network mapping encompasses the techniques to identify and model the physical layer, network layer, and data exchange layers of the organization's network and their physical location, and determine allowed pathways through that network." ;
    skos:exactMatch d3f:NetworkMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkResource a owl:Class ;
    rdfs:label "NetworkResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Resource" ;
    rdfs:seeAlso dbr:Shared_resource ;
    rdfs:subClassOf d3f:RemoteResource ;
    skos:altLabel "Shared Resource" ;
    skos:definition "In computing, a shared resource, or network share, is a computer resource made available from one host to other hosts on a computer network. It is a device or piece of information on a computer that can be remotely accessed from another computer, typically via a local area network or an enterprise intranet, transparently as if it were a resource in the local machine.Network sharing is made possible by inter-process communication over the network." ;
    skos:exactMatch d3f:NetworkResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPITerminateProcess a owl:Class ;
    rdfs:label "OSAPITerminateProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Terminate Process" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:exactMatch d3f:OSAPITerminateProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIWriteMemory a owl:Class ;
    rdfs:label "OSAPIWriteMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Write Memory" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that writes data into the memory space of another process or into specific regions of memory." ;
    skos:exactMatch d3f:OSAPIWriteMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTDiagnosticsMessage a owl:Class ;
    rdfs:label "OTDiagnosticsMessage" ;
    dcterms:title "OT Diagnostics Message" ;
    rdfs:seeAlso <https://icscsi.org/library/Documents/ICS_Protocols/Control%20Microsystems%20-%20DNP3%20User%20and%20Reference%20Manual.pdf>,
        <https://modbus.org/docs/Modbus_Application_Protocol_V1_1b3.pdf>,
        <https://nvlpubs.nist.gov/nistpubs/TechnicalNotes/NIST.TN.2023.pdf> ;
    rdfs:subClassOf d3f:OTProtocolMessage ;
    skos:definition "Relay error, exception, alarm, or log information." ;
    skos:exactMatch d3f:OTDiagnosticsMessage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTDiagnosticsMessageEvent a owl:Class ;
    rdfs:label "OTDiagnosticsMessageEvent" ;
    dcterms:title "OT Diagnostics Message Event" ;
    rdfs:subClassOf d3f:OTEvent ;
    skos:definition "Relay error, exception, alarm, or log information." ;
    skos:exactMatch d3f:OTDiagnosticsMessageEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTEmbeddedComputer a owl:Class ;
    rdfs:label "OTEmbeddedComputer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OT Embedded Computer" ;
    rdfs:subClassOf d3f:EmbeddedComputer ;
    skos:definition "A ruggedized computational device, embedded in industrial control systems, designed to handle real-time tasks and environmental stressors common in OT." ;
    skos:exactMatch d3f:OTEmbeddedComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTModifyControlProgramCommand a owl:Class ;
    rdfs:label "OTModifyControlProgramCommand" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OT Modify Control Program Command" ;
    rdfs:seeAlso <https://icscsi.org/library/Documents/ICS_Protocols/Control%20Microsystems%20-%20DNP3%20User%20and%20Reference%20Manual.pdf>,
        <https://modbus.org/docs/Modbus_Application_Protocol_V1_1b3.pdf>,
        <https://nvlpubs.nist.gov/nistpubs/TechnicalNotes/NIST.TN.2023.pdf> ;
    rdfs:subClassOf d3f:OTModifyDeviceConfigurationCommand ;
    skos:definition "OT command that adds, removes, or changes, process data on a remote device." ;
    skos:exactMatch d3f:OTModifyControlProgramCommand ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "GE-SRTP: WRITE PROGRAM BLOCK MEMORY GE-SRTP: CHANGE PLC CPU PRIVILEGE LEVEL GE-SRTP: SET CONTROL ID(CPU ID) GE-SRTP: PROGRAM STORE (UPLOAD FROM PLC) GE-SRTP: PROGRAM LOAD (DOWNLOAD TO PLC) GE-SRTP: TOGGLE FORCE SYSTEM MEMORY" .

d3f:OTModifyControlProgramCommandEvent a owl:Class ;
    rdfs:label "OTModifyControlProgramCommandEvent" ;
    dcterms:title "OT Modify Control Program Command Event" ;
    rdfs:subClassOf d3f:OTModifyDeviceConfigurationCommandEvent ;
    skos:definition "OT command that adds, removes, or changes, process data on a remote device." ;
    skos:exactMatch d3f:OTModifyControlProgramCommandEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemFile a owl:Class ;
    rdfs:label "OperatingSystemFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System File" ;
    rdfs:seeAlso dbr:Operating_system,
        dbr:System_file ;
    rdfs:subClassOf d3f:File ;
    skos:definition "An operating system file is a file that is part of, or used to store information about, the operating system itself." ;
    skos:exactMatch d3f:OperatingSystemFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperationalActivityMapping a owl:Class ;
    rdfs:label "OperationalActivityMapping" ;
    d3f:d3fend-id "D3-OAM" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Mission Mapping" ;
    dcterms:title "Operational Activity Mapping" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Operational activity mapping identifies activities of the organization and the organization's suborganizations, groups, roles, and individuals that carry out the activities and then establishes the dependencies of the activities on the systems and people that perform those activities." ;
    skos:exactMatch d3f:OperationalActivityMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundNetworkTraffic a owl:Class ;
    rdfs:label "OutboundNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "Outbound traffic is network traffic originating from a host of interest (client), to another host (server)." ;
    skos:exactMatch d3f:OutboundNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PartialMatching a owl:Class ;
    rdfs:label "PartialMatching" ;
    d3f:d3fend-id "D3A-PM" ;
    d3f:kb-article "## References 1. String-searching algorithm. (2023, April 8). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/String-searching_algorithm)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Partial Matching" ;
    rdfs:subClassOf d3f:StringPatternMatching ;
    skos:definition "Partial string pattern matching is a special case of string pattern matching where one seeks to find a pattern within a larger string (text). It allows for the detection of patterns that occur as substrings or partial segments within the full string, rather than requiring an exact match across the entire string." ;
    skos:exactMatch d3f:PartialMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalAccessMonitoring a owl:Class ;
    rdfs:label "PhysicalAccessMonitoring" ;
    d3f:d3fend-id "D3-PHAM" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Access Monitoring" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Monitoring the physical access of a specified environment through detection, recording, reviewing, and logging of who/what enters and exists areas." ;
    skos:exactMatch d3f:PhysicalAccessMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Plan a owl:Class ;
    rdfs:label "Plan" ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:exactMatch d3f:Plan ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PrimaryStorage a owl:Class ;
    rdfs:label "PrimaryStorage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Primary Storage" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Computer_data_storage#Primary_storage>,
        <https://www.memorymanagement.org/glossary/m.html#term-main-memory> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Storage ],
        d3f:HardwareDevice ;
    skos:definition "Primary memory of a computer is memory that is wired directly to the processor, consisting of RAM and possibly ROM.  These terms are used in contrast to mass storage devices and cache memory (although we may note that when a program accesses main memory, it is often actually interacting with a cache)." ;
    skos:exactMatch d3f:PrimaryStorage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessEnum a owl:Class ;
    rdfs:label "ProcessEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:BSDProcess d3f:LinuxProcess d3f:WindowsProcess d3f:iOSProcess d3f:macOSProcess ) ;
    skos:definition "Enumeration of Process values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A process is an instance of a computer program that is being executed. It contains the program code and its current activity. Depending on the operating system (OS), a process may be made up of multiple threads of execution that execute instructions concurrently. A computer program is a passive coll" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:BSDProcess,
        d3f:LinuxProcess,
        d3f:WindowsProcess,
        d3f:iOSProcess,
        d3f:macOSProcess .

d3f:ProcessEviction a owl:Class ;
    rdfs:label "ProcessEviction" ;
    d3f:d3fend-id "D3-PE" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Eviction" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Process eviction techniques terminate or remove running process." ;
    skos:exactMatch d3f:ProcessEviction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessSegment a owl:Class ;
    rdfs:label "ProcessSegment" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Process Memory" ;
    dcterms:title "Process Segment" ;
    rdfs:subClassOf d3f:BinarySegment ;
    skos:definition "Process segments are distinct partitions of the memory space of a running process.  Heap, data, code, and stack segments are examples of process segments." ;
    skos:exactMatch d3f:ProcessSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RankCorrelationCoefficient a owl:Class ;
    rdfs:label "RankCorrelationCoefficient" ;
    d3f:d3fend-id "D3A-RC" ;
    d3f:kb-article "Wikipedia. (n.d.). Rank correlation. [Link](https://en.wikipedia.org/wiki/Rank_correlation)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Rank Correlation" ;
    rdfs:subClassOf d3f:Correlation ;
    skos:definition "A rank correlation is any of several statistics that measure an ordinal association-the relationship between rankings of different ordinal variables or different rankings of the same variable, where a \"ranking\" is the assignment of the ordering labels \"first\", \"second\", \"third\", etc. to different observations of a particular variable." ;
    skos:exactMatch d3f:RankCorrelationCoefficient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RemoteCommand a owl:Class ;
    rdfs:label "RemoteCommand" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Command" ;
    rdfs:subClassOf d3f:Command ;
    skos:definition "A remote command is an instruction or set of instructions issued from a geographically or logically distant location to control, configure, or elicit a response from a target system, device, or entity. The execution of a remote command does not require direct physical interaction with the target; instead, it relies on a communication link to transmit the instruction and receive any resulting feedback or data." ;
    skos:exactMatch d3f:RemoteCommand ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Resource a owl:Class ;
    rdfs:label "Resource" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:System_resource ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In computing, a system resource, or simply resource, is any physical or virtual component of limited availability within a computer system. Every device connected to a computer system is a resource. Every internal system component is a resource. Virtual system resources include files (concretely file handles), network connections (concretely network sockets), and memory areas. Managing resources is referred to as resource management, and includes both preventing resource leaks (releasing a resource when a process has finished using it) and dealing with resource contention (when multiple processes wish to access a limited resource)." ;
    skos:exactMatch d3f:Resource,
        oscal:Resource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedLearning a owl:Class ;
    rdfs:label "Semi_SupervisedLearning" ;
    d3f:d3fend-id "D3A-SSL" ;
    d3f:kb-article "## References Semi-Supervised Learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Semi-Supervised_Learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-Supervised Learning" ;
    rdfs:seeAlso <https://link.springer.com/article/10.1007/s10994-019-05855-6> ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:altLabel "Semi-SupervisedLearning" ;
    skos:definition "Semi-supervised learning is a branch of machine learning that combines a small amount of labeled data with a large amount of unlabeled data during training." ;
    skos:exactMatch d3f:Semi-SupervisedLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SharedComputer a owl:Class ;
    rdfs:label "SharedComputer" ;
    dcterms:title "Shared Computer" ;
    rdfs:seeAlso dbr:Time-sharing ;
    rdfs:subClassOf d3f:ClientComputer ;
    skos:definition "A computer whose resources are intended to be shared widely." ;
    skos:exactMatch d3f:SharedComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemMapping a owl:Class ;
    rdfs:label "SystemMapping" ;
    d3f:d3fend-id "D3-SYSM" ;
    d3f:display-order "2" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Mapping" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "System mapping encompasses the techniques to identify the organization's systems, how they are configured and decomposed into subsystems and components, how they are dependent on one another, and where they are physically located." ;
    skos:exactMatch d3f:SystemMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemPlatformVariable a owl:Class ;
    rdfs:label "SystemPlatformVariable" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Configuration Resource" ;
    dcterms:title "System Platform Variable" ;
    rdfs:seeAlso <https://literature.rockwellautomation.com/idc/groups/literature/documents/pm/1756-pm015_-en-p.pdf>,
        <https://www.nrc.gov/docs/ml0932/ml093290422.pdf> ;
    rdfs:subClassOf d3f:RuntimeVariable ;
    skos:definition "Runtime variables  which may consist of memory usage, internal temperature, operating mode, clock time, scan time, hardware status, etc." ;
    skos:exactMatch d3f:SystemPlatformVariable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1491 a owl:Class ;
    rdfs:label "T1491" ;
    d3f:attack-id "T1491" ;
    dcterms:title "Defacement" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may modify visual content available internally or externally to an enterprise network, thus affecting the integrity of the original content. Reasons for [Defacement](https://attack.mitre.org/techniques/T1491) include delivering messaging, intimidation, or claiming (possibly false) credit for an intrusion. Disturbing or offensive images may be used as a part of [Defacement](https://attack.mitre.org/techniques/T1491) in order to cause user discomfort, or to pressure compliance with accompanying messages." ;
    skos:exactMatch d3f:T1491,
        mitre-attack:T1491 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1496 a owl:Class ;
    rdfs:label "T1496" ;
    d3f:attack-id "T1496" ;
    dcterms:title "Resource Hijacking" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may leverage the resources of co-opted systems to complete resource-intensive tasks, which may impact system and/or hosted service availability." ;
    skos:exactMatch d3f:T1496,
        mitre-attack:T1496 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1587 a owl:Class ;
    rdfs:label "T1587" ;
    d3f:attack-id "T1587" ;
    dcterms:title "Develop Capabilities" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may build capabilities that can be used during targeting. Rather than purchasing, freely downloading, or stealing capabilities, adversaries may develop their own capabilities in-house. This is the process of identifying development requirements and building solutions such as malware, exploits, and self-signed certificates. Adversaries may develop capabilities to support their operations throughout numerous phases of the adversary lifecycle.(Citation: Mandiant APT1)(Citation: Kaspersky Sofacy)(Citation: Bitdefender StrongPity June 2020)(Citation: Talos Promethium June 2020)" ;
    skos:exactMatch d3f:T1587,
        mitre-attack:T1587 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1591 a owl:Class ;
    rdfs:label "T1591" ;
    d3f:attack-id "T1591" ;
    dcterms:title "Gather Victim Org Information" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may gather information about the victim's organization that can be used during targeting. Information about an organization may include a variety of details, including the names of divisions/departments, specifics of business operations, as well as the roles and responsibilities of key employees." ;
    skos:exactMatch d3f:T1591,
        mitre-attack:T1591 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1592 a owl:Class ;
    rdfs:label "T1592" ;
    d3f:attack-id "T1592" ;
    dcterms:title "Gather Victim Host Information" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may gather information about the victim's hosts that can be used during targeting. Information about hosts may include a variety of details, including administrative data (ex: name, assigned IP, functionality, etc.) as well as specifics regarding its configuration (ex: operating system, language, etc.)." ;
    skos:exactMatch d3f:T1592,
        mitre-attack:T1592 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1598 a owl:Class ;
    rdfs:label "T1598" ;
    d3f:attack-id "T1598" ;
    dcterms:title "Phishing for Information" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may send phishing messages to elicit sensitive information that can be used during targeting. Phishing for information is an attempt to trick targets into divulging information, frequently credentials or other actionable information. Phishing for information is different from [Phishing](https://attack.mitre.org/techniques/T1566) in that the objective is gathering data from the victim rather than executing malicious code." ;
    skos:exactMatch d3f:T1598,
        mitre-attack:T1598 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1614 a owl:Class ;
    rdfs:label "T1614" ;
    d3f:attack-id "T1614" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Location Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may gather information in an attempt to calculate the geographical location of a victim host. Adversaries may use the information from [System Location Discovery](https://attack.mitre.org/techniques/T1614) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1614,
        mitre-attack:T1614 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TechniqueReferenceEnum a owl:Class ;
    rdfs:label "TechniqueReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-CertificateAndPublicKeyPinning d3f:Reference-CertificateTransparency d3f:Reference-FWTKDocumentation-Fwtk.org d3f:Reference-StreamingPhish d3f:Reference-UseRkillToStopMalwareProcesses-Ghacks.net ) ;
    skos:definition "Enumeration of TechniqueReference values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A reference used to develop KB articles." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:Reference-CertificateAndPublicKeyPinning,
        d3f:Reference-CertificateTransparency,
        d3f:Reference-FWTKDocumentation-Fwtk.org,
        d3f:Reference-StreamingPhish,
        d3f:Reference-UseRkillToStopMalwareProcesses-Ghacks.net .

d3f:TimeSeriesAnalysis a owl:Class ;
    rdfs:label "TimeSeriesAnalysis" ;
    d3f:d3fend-id "D3A-TSA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Time series. [Link](https://en.wikipedia.org/wiki/Time_series)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Time Series Analysis" ;
    rdfs:subClassOf d3f:StatisticalMethod ;
    skos:definition "Time series analysis comprises methods for analyzing time series data in order to extract meaningful statistics and other characteristics of the data." ;
    skos:exactMatch d3f:TimeSeriesAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnixLink a owl:Class ;
    rdfs:label "UnixLink" ;
    dcterms:title "Unix Link" ;
    rdfs:subClassOf d3f:FileSystemLink ;
    skos:definition "A Unix link is a file link in a Unix file system." ;
    skos:exactMatch d3f:UnixLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnsupervisedLearning a owl:Class ;
    rdfs:label "UnsupervisedLearning" ;
    d3f:d3fend-id "D3A-UL" ;
    d3f:kb-abstract "## References Unsupervised learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Unsupervised_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Unsupervised Learning" ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:definition "Unsupervised learning creates relationships with unlabeled data without the input of a human or other outside actor. Uses only input data." ;
    skos:exactMatch d3f:UnsupervisedLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserLogonInitResource a owl:Class ;
    rdfs:label "UserLogonInitResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Logon Init Resource" ;
    rdfs:subClassOf d3f:LocalResource ;
    skos:definition "A user logon initialization resource contains information used to configure a user's environment when a user logs into a system." ;
    skos:exactMatch d3f:UserLogonInitResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WatchdogTimerEvent a owl:Class ;
    rdfs:label "WatchdogTimerEvent" ;
    dcterms:title "Watchdog Timer Event" ;
    rdfs:subClassOf d3f:TimerEvent ;
    skos:definition "A watchdog timer event is any occurrence in which a watchdog timer is started, updated, reset, expired, or otherwise interacts with the system it monitors, resulting in a state change, status report, or corrective action intended to detect, signal, or recover from abnormal or stalled system behavior." ;
    skos:exactMatch d3f:WatchdogTimerEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryValueEvent a owl:Class ;
    rdfs:label "WindowsRegistryValueEvent" ;
    dcterms:title "Windows Registry Value Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/win/registry_value_activity>,
        <https://schema.ocsf.io/classes/win/registry_value_activity> ;
    rdfs:subClassOf d3f:WindowsRegistryEvent ;
    skos:definition "Events representing actions performed on Windows Registry values, which store configuration data within registry keys." ;
    skos:exactMatch d3f:WindowsRegistryValueEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:attack_may_be_countered_by a owl:DatatypeProperty ;
    rdfs:label "attack-may-be-countered-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_tactically_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:counters a owl:DatatypeProperty ;
    rdfs:label "counters" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_counter ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_artifact_data_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-artifact-data-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:definition "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_kb_data_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-kb-data-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:definition "x d3fend-kb-data-property y: The d3fend knowledge base object x has a data property y; e.g., a string capturing a particular aspect or section of a knowledge base article." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_process_object_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-process-object-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:evicts a owl:DatatypeProperty ;
    rdfs:label "evicts" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:counters ;
    skos:definition "x evicts y: The entity x forcibly removes entity y from the environment or resource where y was residing." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASAIAttackStagingTechnique a owl:Class ;
    rdfs:label "ATLASAIAttackStagingTechnique" ;
    dcterms:title "AI Attack Staging Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASAIAttackStagingTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AgentAuthentication a owl:Class ;
    rdfs:label "AgentAuthentication" ;
    d3f:d3fend-id "D3-AA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Agent Authentication" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:ImpactTechnique,
        d3f:InitialAccessTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1078,
        d3f:T1087,
        d3f:T1098,
        d3f:T1136 ;
    skos:definition "Agent authentication is the process of verifying the identities of agents to ensure they are authorized and trustworthy participants within a system." ;
    skos:exactMatch d3f:AgentAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1078,
        mitre-attack:T1078.001,
        mitre-attack:T1078.002,
        mitre-attack:T1078.003,
        mitre-attack:T1078.004,
        mitre-attack:T1087.001,
        mitre-attack:T1087.002,
        mitre-attack:T1087.004,
        mitre-attack:T1098,
        mitre-attack:T1098.002,
        mitre-attack:T1098.003,
        mitre-attack:T1136,
        mitre-attack:T1136.001,
        mitre-attack:T1136.002,
        mitre-attack:T1136.003,
        mitre-attack:T1531 .

d3f:ApplicationConfiguration a owl:Class ;
    rdfs:label "ApplicationConfiguration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Configuration" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/05739724-n> ;
    rdfs:subClassOf d3f:ConfigurationResource ;
    skos:definition "Information used to configure the parameters and initial settings for an application." ;
    skos:exactMatch d3f:ApplicationConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE140 a owl:Class ;
    rdfs:label "CWE_140" ;
    d3f:cwe-id "CWE-140" ;
    dcterms:title "Improper Neutralization of Delimiters" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-140" ;
    skos:definition "The product does not neutralize or incorrectly neutralizes delimiters." ;
    skos:exactMatch d3f:CWE-140,
        cwe:CWE-140 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE522 a owl:Class ;
    rdfs:label "CWE_522" ;
    d3f:cwe-id "CWE-522" ;
    dcterms:title "Insufficiently Protected Credentials" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE668 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-522" ;
    skos:definition "The product transmits or stores authentication credentials, but it uses an insecure method that is susceptible to unauthorized interception and/or retrieval." ;
    skos:exactMatch d3f:CWE-522,
        cwe:CWE-522 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE669 a owl:Class ;
    rdfs:label "CWE_669" ;
    d3f:cwe-id "CWE-669" ;
    dcterms:title "Incorrect Resource Transfer Between Spheres" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-669" ;
    skos:definition "The product does not properly transfer a resource/behavior to another sphere, or improperly imports a resource/behavior from another sphere, in a manner that provides unintended control over that resource." ;
    skos:exactMatch d3f:CWE-669,
        cwe:CWE-669 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE670 a owl:Class ;
    rdfs:label "CWE_670" ;
    d3f:cwe-id "CWE-670" ;
    dcterms:title "Always-Incorrect Control Flow Implementation" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-670" ;
    skos:definition "The code contains a control flow path that does not reflect the algorithm that the path is intended to implement, leading to incorrect behavior any time this path is navigated." ;
    skos:exactMatch d3f:CWE-670,
        cwe:CWE-670 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE863 a owl:Class ;
    rdfs:label "CWE_863" ;
    d3f:cwe-id "CWE-863" ;
    d3f:synonym "AuthZ" ;
    dcterms:title "Incorrect Authorization" ;
    rdfs:subClassOf d3f:CWE285 ;
    skos:altLabel "CWE-863" ;
    skos:definition "The product performs an authorization check when an actor attempts to access a resource or perform an action, but it does not correctly perform the check." ;
    skos:exactMatch d3f:CWE-863,
        cwe:CWE-863 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConfigurationFile a owl:Class ;
    rdfs:label "ConfigurationFile" ;
    dcterms:title "Configuration File" ;
    rdfs:seeAlso dbr:Configuration_file ;
    rdfs:subClassOf d3f:File ;
    skos:altLabel "Settings File" ;
    skos:definition "A file containing Information used to configure the parameters and initial settings for some computer programs. They are used for user applications, server processes and operating system settings." ;
    skos:exactMatch d3f:ConfigurationFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Correlation a owl:Class ;
    rdfs:label "Correlation" ;
    d3f:d3fend-id "D3A-COR" ;
    d3f:kb-article "Wolfram MathWorld. (n.d.). Correlation. [Link](https://mathworld.wolfram.com/Correlation.html)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DescriptiveStatistics ;
    skos:definition "Correlation is the degree to which two or more quantities are linearly associated." ;
    skos:exactMatch d3f:Correlation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DocumentFile a owl:Class ;
    rdfs:label "DocumentFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Document File" ;
    rdfs:seeAlso dbr:Document ;
    rdfs:subClassOf d3f:File ;
    skos:definition "A document is a written, drawn, presented or recorded representation of thoughts. An electronic document file is usually used to describe a primarily textual file, along with its structure and design, such as fonts, colors and additional images." ;
    skos:exactMatch d3f:DocumentFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EndpointSensor a owl:Class ;
    rdfs:label "EndpointSensor" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Endpoint Sensor" ;
    rdfs:seeAlso d3f:ComputerPlatform ;
    rdfs:subClassOf d3f:CyberSensor ;
    skos:definition "A sensor application installed on a endpoint (platform) to collect information on platform components." ;
    skos:exactMatch d3f:EndpointSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutableScriptEnum a owl:Class ;
    rdfs:label "ExecutableScriptEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:BashScriptFile d3f:JavascriptFile d3f:LuaScriptFile d3f:PowershellScriptFile d3f:RubyScriptFile d3f:WindowsBatchFile ) ;
    skos:definition "Enumeration of ExecutableScript values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "An executable script is written in a scripting language and interpreted at run time. This is in contrast with an executable binary, which contains machine code instructions for a physical CPU or byte code for a virtual machine." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:BashScriptFile,
        d3f:JavascriptFile,
        d3f:LuaScriptFile,
        d3f:PowershellScriptFile,
        d3f:RubyScriptFile,
        d3f:WindowsBatchFile .

d3f:ExecutionIsolation a owl:Class ;
    rdfs:label "ExecutionIsolation" ;
    d3f:d3fend-id "D3-EI" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Execution Isolation" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Execution Isolation techniques prevent application processes from accessing non-essential system resources, such as memory, devices, or files." ;
    skos:exactMatch d3f:ExecutionIsolation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileMetadata a owl:Class ;
    rdfs:label "FileMetadata" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Metadata" ;
    rdfs:subClassOf d3f:Metadata ;
    skos:definition "Information that describes and provides context about a file's content, structure, and attributes." ;
    skos:exactMatch d3f:FileMetadata ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileSection a owl:Class ;
    rdfs:label "FileSection" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Section" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/05876035-n> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "File Part" ;
    skos:definition "A file section is one of the portions of a file in which the file is regarded as divided and where together the file sections constitute the whole file." ;
    skos:exactMatch d3f:FileSection ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetSystemConfigValueEnum a owl:Class ;
