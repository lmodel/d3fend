<http://d3fend.mitre.org/ontologies/d3fend.owl#ExpectationRatingEnum#Unspecified> a owl:Class ;
    rdfs:label "Unspecified" ;
    rdfs:subClassOf d3f:ExpectationRatingEnum,
        linkml:PermissibleValue ;
    skos:definition "Unspecified" .

d3f:ExpectedErrorReduction a owl:Class ;
    rdfs:label "ExpectedErrorReduction" ;
    d3f:d3fend-id "D3A-EER" ;
    d3f:kb-article "## References Intro to Active Learning. inovex Blog. [Link](https://www.inovex.de/de/blog/intro-to-active-learning/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Expected Error Reduction" ;
    rdfs:subClassOf d3f:ActiveLearning ;
    skos:definition "Expected Error Reduction (EER) follows similar ideas as EMC, but again looks at the model output instead of the model itself and also takes the other data into account. In particular, a sample x is considered useful, if we can expect that knowing the label will reduce the future error on unseen samples" ;
    skos:exactMatch d3f:ExpectedErrorReduction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExpectedModelChange a owl:Class ;
    rdfs:label "ExpectedModelChange" ;
    d3f:d3fend-id "D3A-EMC" ;
    d3f:kb-article "nal Consiterations ## References Intro to Active Learning. inovex Blog. [Link](https://www.inovex.de/de/blog/intro-to-active-learning/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Expected Model Change" ;
    rdfs:subClassOf d3f:ActiveLearning ;
    skos:definition "Supervised learning establishes a relationship between the known input and output variables to conduct a predictive analysis." ;
    skos:exactMatch d3f:ExpectedModelChange ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExternalContentInclusionFunction a owl:Class ;
    rdfs:label "ExternalContentInclusionFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "External Content Inclusion Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "A subroutine which handles a content inclusion directive from an original file. When invoked, the external content is included in the resulting open file." ;
    skos:exactMatch d3f:ExternalContentInclusionFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExternalKnowledgeBase a owl:Class ;
    rdfs:label "ExternalKnowledgeBase" ;
    d3f:pref-label "External Knowledge Base" ;
    dcterms:title "External Knowledge Base" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:exactMatch d3f:ExternalKnowledgeBase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FPGABitstream a owl:Class ;
    rdfs:label "FPGABitstream" ;
    dcterms:title "FPGA Bitstream" ;
    rdfs:seeAlso dbr:Bitstream ;
    rdfs:subClassOf d3f:ApplicationConfigurationFile ;
    skos:definition "A binary configuration file generated by synthesizing and placing-and-routing an HDL design, which is loaded into a Field-Programmable Gate Array (FPGA) to physically define its internal logic, interconnects, and I/O behavior. Rather than being executed by a processor, it programs the device itself." ;
    skos:exactMatch d3f:FPGABitstream ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPDeleteEvent a owl:Class ;
    rdfs:label "FTPDeleteEvent" ;
    dcterms:title "FTP Delete Event" ;
    rdfs:subClassOf d3f:FTPEvent ;
    skos:definition "An event where files or directories are removed from an FTP server, resulting in their permanent deletion from the remote system." ;
    skos:exactMatch d3f:FTPDeleteEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPGetEvent a owl:Class ;
    rdfs:label "FTPGetEvent" ;
    dcterms:title "FTP Get Event" ;
    rdfs:subClassOf d3f:FTPEvent ;
    skos:definition "An event where a file is downloaded from an FTP server to a client, retrieving data from the remote system to the local destination." ;
    skos:exactMatch d3f:FTPGetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPListEvent a owl:Class ;
    rdfs:label "FTPListEvent" ;
    dcterms:title "FTP List Event" ;
    rdfs:subClassOf d3f:FTPEvent ;
    skos:definition "An event where the contents of a directory on an FTP server are listed, providing metadata such as file names, sizes, and timestamps." ;
    skos:exactMatch d3f:FTPListEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPPollEvent a owl:Class ;
    rdfs:label "FTPPollEvent" ;
    dcterms:title "FTP Poll Event" ;
    rdfs:subClassOf d3f:FTPEvent ;
    skos:definition "An event where a client queries an FTP server to check for the presence of specific files or directories without initiating a transfer." ;
    skos:exactMatch d3f:FTPPollEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPPutEvent a owl:Class ;
    rdfs:label "FTPPutEvent" ;
    dcterms:title "FTP Put Event" ;
    rdfs:subClassOf d3f:FTPEvent ;
    skos:definition "An event where a file is uploaded from a client to an FTP server, transferring data from the local system to the remote destination." ;
    skos:exactMatch d3f:FTPPutEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPRenameEvent a owl:Class ;
    rdfs:label "FTPRenameEvent" ;
    dcterms:title "FTP Rename Event" ;
    rdfs:subClassOf d3f:FTPEvent ;
    skos:definition "An event where files or directories on an FTP server are renamed, modifying their identifiers without altering their content or location." ;
    skos:exactMatch d3f:FTPRenameEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FastSymbolicLink a owl:Class ;
    rdfs:label "FastSymbolicLink" ;
    dcterms:title "Fast Symbolic Link" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Symbolic_link#Storage_of_symbolic_links> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UnixLink ],
        d3f:SymbolicLink ;
    skos:altLabel "Fast Symlink" ;
    skos:definition "Fast symbolic links, allow storage of the target path within the data structures used for storing file information on disk (e.g., within the inodes). This space normally stores a list of disk block addresses allocated to a file. Thus, symlinks with short target paths are accessed quickly. Systems with fast symlinks often fall back to using the original method if the target path exceeds the available inode space." ;
    skos:exactMatch d3f:FastSymbolicLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileAccessEvent a owl:Class ;
    rdfs:label "FileAccessEvent" ;
    dcterms:title "File Access Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file is accessed for operations such as reading, opening, or inspecting its contents or metadata, without necessarily modifying its state." ;
    skos:exactMatch d3f:FileAccessEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileAccessPatternAnalysis a owl:Class ;
    rdfs:label "FileAccessPatternAnalysis" ;
    d3f:d3fend-id "D3-FAPA" ;
    d3f:kb-article "## How it works File modifying malware such as wipers and ransomware are detected by identifying file access patterns that are associated with a malicious process. Examples of file access patterns include accessing a large number of files, accessing multiple file types, files being accessed located" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Access Pattern Analysis" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:definition "Analyzing the files accessed by a process to identify unauthorized activity." ;
    skos:exactMatch d3f:FileAccessPatternAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileCarving a owl:Class ;
    rdfs:label "FileCarving" ;
    d3f:d3fend-id "D3-FC" ;
    d3f:kb-article "## How it works Protocol stream reassembly software recreates a directional byte stream by analyzing captured network packets. Once the stream is reassembled pattern matching is applied to determine if it contains a file of interest. Files of interest range from executable, archive, or document file" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Carving" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:LateralMovementTechnique,
        d3f:T1071 ;
    skos:definition "Identifying and extracting files from network application protocols through the use of network stream reassembly software." ;
    skos:exactMatch d3f:FileCarving ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1071.002,
        mitre-attack:T1570 .

d3f:FileContentBlock a owl:Class ;
    rdfs:label "FileContentBlock" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Content Block" ;
    rdfs:subClassOf d3f:FileSection ;
    skos:definition "A section within a file that contains the main content or data payload." ;
    skos:exactMatch d3f:FileContentBlock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileContentBlockData a owl:Class ;
    rdfs:label "FileContentBlockData" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Content Block Data" ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "The actual content or main data within a file or data block." ;
    skos:exactMatch d3f:FileContentBlockData ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileContentBlockMetadata a owl:Class ;
    rdfs:label "FileContentBlockMetadata" ;
    dcterms:title "File Content Block Metadata" ;
    rdfs:subClassOf d3f:FileMetadata ;
    skos:definition "Content Blocks may contain metadata specific to the block's content at the beginning." ;
    skos:exactMatch d3f:FileContentBlockMetadata ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileContentDecompressionChecking a owl:Class ;
    rdfs:label "FileContentDecompressionChecking" ;
    d3f:d3fend-id "D3-FCDC" ;
    d3f:kb-article "## How it works Some file formats such as JPEGs include encoded or compressed sections. This technique verfies that those expected sections are present and can be properly decoded according to the spec." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Content Decompression Checking" ;
    rdfs:subClassOf d3f:FileFormatVerification ;
    skos:definition "Checking if compressed or encoded data sections can be successfully decompressed or decoded. Can follow with further analysis with semantic knowledge" ;
    skos:exactMatch d3f:FileContentDecompressionChecking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileContentRules a owl:Class ;
    rdfs:label "FileContentRules" ;
    d3f:d3fend-id "D3-FCR" ;
    d3f:kb-article "## How it works Rules, often called signatures, are used for both generic and targeted malware detection. The rules are usually expressed in a domain specific language (DSL), then deployed to software that scans files for matches. The rules are developed and broadly distributed by commercial vendors" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "File Content Signatures" ;
    dcterms:title "File Content Rules" ;
    rdfs:subClassOf d3f:FileContentAnalysis ;
    skos:definition "Employing a pattern matching rule language to analyze the content of files." ;
    skos:exactMatch d3f:FileContentRules ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileCopyEvent a owl:Class ;
    rdfs:label "FileCopyEvent" ;
    dcterms:title "File Copy Event" ;
    rdfs:subClassOf d3f:FileCreationEvent ;
    skos:definition "An event where a file is duplicated, creating a new file in a different location or under a different name while preserving the original file's content and attributes." ;
    skos:exactMatch d3f:FileCopyEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileCreationAnalysis a owl:Class ;
    rdfs:label "FileCreationAnalysis" ;
    d3f:d3fend-id "D3-FCA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Creation Analysis" ;
    rdfs:subClassOf d3f:SystemCallAnalysis ;
    skos:broadMatch d3f:T1074,
        d3f:T1218 ;
    skos:definition "Analyzing the properties of file create system call invocations." ;
    skos:exactMatch d3f:FileCreationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1074.001,
        mitre-attack:T1218.001 .

d3f:FileDecryptionEvent a owl:Class ;
    rdfs:label "FileDecryptionEvent" ;
    dcterms:title "File Decryption Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a previously encrypted file is decoded, rendering its content accessible to authorized users or processes." ;
    skos:exactMatch d3f:FileDecryptionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileDeletionEvent a owl:Class ;
    rdfs:label "FileDeletionEvent" ;
    dcterms:title "File Deletion Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event where a file is permanently removed from the file system or storage medium, potentially triggering actions related to data retention or recovery." ;
    skos:exactMatch d3f:FileDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileEncryption a owl:Class ;
    rdfs:label "FileEncryption" ;
    d3f:d3fend-id "D3-FE" ;
    d3f:kb-article "## How it Works Files are encrypted using either a single key for both encryption and decryption or separate keys. Single key encryption is symmetric encryption and using two key distinct keys is asymmetric encryption. ### Symmetric Cryptography Symmetric encryption uses the same cryptographic key" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Encryption" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
