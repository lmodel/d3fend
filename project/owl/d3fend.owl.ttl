d3f:HTTPHeadEvent a owl:Class ;
    rdfs:label "HTTPHeadEvent" ;
    dcterms:title "HTTP HEAD Event" ;
    rdfs:subClassOf d3f:HTTPRequestEvent ;
    skos:definition "An event where the HTTP HEAD method is used to request metadata about the specified resource without the response body." ;
    skos:exactMatch d3f:HTTPHeadEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HTTPOptionsEvent a owl:Class ;
    rdfs:label "HTTPOptionsEvent" ;
    dcterms:title "HTTP OPTIONS Event" ;
    rdfs:subClassOf d3f:HTTPRequestEvent ;
    skos:definition "An event where the HTTP OPTIONS method is used to describe the communication options for the target resource." ;
    skos:exactMatch d3f:HTTPOptionsEvent ;
