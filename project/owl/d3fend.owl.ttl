    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_modify a owl:DatatypeProperty ;
    rdfs:label "may-modify" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-modify y: They entity x may modify the thing y; that is, 'x modifies y' may be true." ;
