d3f:ExecutableFile a owl:Class ;
    rdfs:label "ExecutableFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Executable File" ;
    rdfs:seeAlso dbr:Executable ;
    rdfs:subClassOf d3f:File ;
    skos:altLabel "Executable" ;
    skos:definition "In computing, executable code or an executable file or executable program, sometimes simply an executable, causes a computer \"to perform indicated tasks according to encoded instructions,\" as opposed to a data file that must be parsed by a program to be meaningful. These instructions are traditionally machine code instructions for a physical CPU. However, in a more general sense, a file containing instructions (such as bytecode) for a software interpreter may also be considered executable; even a scripting language source file may therefore be considered executable in this sense. The exact interpretation depends upon the use; while the term often refers only to machine code files, in the context of protection against computer viruses all files which cause potentially hazardous instruction" ;
    skos:exactMatch d3f:ExecutableFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExternalControl a owl:Class ;
    rdfs:label "ExternalControl" ;
    dcterms:title "External Control" ;
    rdfs:subClassOf d3f:ExternalControlThing ;
    skos:exactMatch d3f:ExternalControl ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExternalControlThing a owl:Class ;
    rdfs:label "ExternalControlThing" ;
    dcterms:title "External Control Thing" ;
    rdfs:subClassOf d3f:ExternalThing ;
    skos:exactMatch d3f:ExternalControlThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FirmwareVerification a owl:Class ;
    rdfs:label "FirmwareVerification" ;
    d3f:d3fend-id "D3-FV" ;
    d3f:kb-article "## How it works Cryptographic hash values are computed for system and peripheral firmware. The hash values are compared against precomputed hash values for the identified firmware. A hash value mismatch may indicate that the firmware may have been tampered with or updated with a non-current release" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Firmware Verification" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:T1542 ;
    skos:definition "Cryptographically verifying firmware integrity." ;
    skos:exactMatch d3f:FirmwareVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1014,
        mitre-attack:T1542.001,
        mitre-attack:T1542.002,
        mitre-attack:T1542.004 .

d3f:ForwardResolutionDomainDenylisting a owl:Class ;
    rdfs:label "ForwardResolutionDomainDenylisting" ;
    d3f:d3fend-id "D3-FRDDL" ;
    d3f:kb-article "## How it works Policies are created that filter DNS queries using fully qualified domain name (FQDN) of record in the query. A DNS policy can be created for blocking DNS queries from FQDNs that have been identified as unauthorized. ## Considerations Continuous maintenance of unauthorized domain" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Forward Resolution Domain Blacklisting" ;
    dcterms:title "Forward Resolution Domain Denylisting" ;
    rdfs:subClassOf d3f:DNSDenylisting ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:T1071 ;
    skos:definition "Blocking a lookup based on the query's domain name value." ;
    skos:exactMatch d3f:ForwardResolutionDomainDenylisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1071.004,
        mitre-attack:T1568 .

d3f:Generation a owl:Class ;
    rdfs:label "Generation" ;
    dcterms:title "Media Generation" ;
    rdfs:subClassOf d3f:AnalyticalPurpose ;
    skos:exactMatch d3f:Generation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HTTPEvent a owl:Class ;
    rdfs:label "HTTPEvent" ;
    dcterms:title "HTTP Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/http_activity>,
        <https://schema.ocsf.io/classes/http_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:TCPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Hypertext Transfer Protocol (HTTP), which operates over TCP to transmit hypermedia documents." ;
    skos:exactMatch d3f:HTTPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardLink a owl:Class ;
    rdfs:label "HardLink" ;
    dcterms:title "Hard Link" ;
    rdfs:seeAlso dbr:Hard_link ;
    rdfs:subClassOf d3f:FileSystemLink ;
    skos:definition "In computing, a hard link is a directory entry that associates a name with a file on a file system. All directory-based file systems must have at least one hard link giving the original name for each file. The term \"hard link\" is usually only used in file systems that allow more than one hard link for the same file. Multiple hard links -- that is, multiple directory entries to the same file -- are supported by POSIX-compliant and partially POSIX-compliant operating systems, such as Linux, Android, macOS, and also Windows NT4 and later Windows NT operating systems." ;
    skos:exactMatch d3f:HardLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Harden a owl:Class ;
    rdfs:label "Harden" ;
    d3f:display-order "0" ;
    d3f:display-priority "0" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The harden tactic is used to increase the opportunity cost of computer network exploitation. Hardening differs from Detection in that it generally is conducted before a system is online and operational." ;
    skos:editorialNote "The harden tactic is used to increase the opportunity cost of computer network exploitation. Hardening differs from Detection in that it generally is conducted before a system is online and operational." ;
    skos:exactMatch d3f:Harden ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareClock a owl:Class ;
    rdfs:label "HardwareClock" ;
    dcterms:title "Hardware Clock" ;
    rdfs:seeAlso <https://linux.die.net/man/8/clock> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:HardwareDevice ],
        d3f:Clock ;
    skos:definition "A clock implemented using physical electronic components, typically providing timekeeping independent of system power or software state." ;
    skos:exactMatch d3f:HardwareClock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareTimerEvent a owl:Class ;
    rdfs:label "HardwareTimerEvent" ;
    dcterms:title "Hardware Timer Event" ;
    rdfs:subClassOf d3f:TimerEvent ;
    skos:definition "A timer event involving a physical timer mechanism implemented in hardware components." ;
    skos:exactMatch d3f:HardwareTimerEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HeterogeneousTransferLearning a owl:Class ;
    rdfs:label "HeterogeneousTransferLearning" ;
    d3f:d3fend-id "D3A-HTL" ;
    d3f:kb-article "## References Wang, Q., Mao, K. Z., Wang, B., & Guan, J. (2017). Big data clustering by hybrid optimization algorithm. Journal of Big Data, 4(1), 25. [Link](https://journalofbigdata.springeropen.com/articles/10.1186/s40537-017-0089-0)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Heterogeneous Transfer Learning" ;
    rdfs:subClassOf d3f:TransferLearning ;
    skos:definition "Heterogeneous transfer learning is characterized by the source and target domains having differing feature spaces, but may also be combined with other issues such as differing data distributions and label spaces." ;
    skos:exactMatch d3f:HeterogeneousTransferLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HierarchicalClustering a owl:Class ;
    rdfs:label "HierarchicalClustering" ;
    d3f:d3fend-id "D3A-HC" ;
    d3f:kb-article "## References Wikipedia. (2021, August 10). Hierarchical clustering. [Link](https://en.wikipedia.org/wiki/Hierarchical_clustering) html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hierarchical Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:definition "Hierarchical clustering (also called hierarchical cluster analysis or HCA) is a method of cluster analysis that seeks to build a hierarchy of clusters." ;
    skos:exactMatch d3f:HierarchicalClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Hostname a owl:Class ;
    rdfs:label "Hostname" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Hostname ;
    rdfs:subClassOf d3f:DomainNameEnum,
        d3f:Identifier,
        linkml:PermissibleValue ;
    skos:altLabel "Nodename" ;
    skos:definition "In computer networking, a hostname (archaically nodename) is a label that is assigned to a device connected to a computer network and that is used to identify the device in various forms of electronic communication, such as the World Wide Web. Hostnames may be simple names consisting of a single word or phrase, or they may be structured." ;
    skos:editorialNote "In computer networking, a hostname (archaically nodename) is a label that is assigned to a device connected to a computer network and that is used to identify the device in various forms of electronic communication, such as the World Wide Web. Hostnames may be simple names consisting of a single word or phrase, or they may be structured." ;
    skos:exactMatch d3f:Hostname,
        unified_cyber_ontology:Hostname ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HypothesisTesting a owl:Class ;
    rdfs:label "HypothesisTesting" ;
    d3f:d3fend-id "D3A-HT" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Statistical hypothesis testing. [Link](https://en.wikipedia.org/wiki/Statistical_hypothesis_testing)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hypothesis Testing" ;
    rdfs:subClassOf d3f:InferentialStatistics ;
    skos:definition "A statistical hypothesis test is a method of statistical inference used to decide whether the data at hand sufficiently support a particular hypothesis. Hypothesis testing allows us to make probabilistic statements about population parameters." ;
    skos:exactMatch d3f:HypothesisTesting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IA0001 a owl:Class ;
    rdfs:label "IA_0001" ;
    d3f:attack-id "IA-0001" ;
    dcterms:title "Compromise Supply Chain" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/IA-0001/> ;
    rdfs:subClassOf d3f:SPARTAInitialAccessTechnique ;
    skos:altLabel "IA-0001" ;
    skos:definition "Threat actors may manipulate or compromise products or product delivery mechanisms before the customer receives them in order to achieve data or system compromise." ;
    skos:exactMatch d3f:IA-0001,
        mitre-attack:IA-0001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IA0005 a owl:Class ;
    rdfs:label "IA_0005" ;
    d3f:attack-id "IA-0005" ;
    dcterms:title "Rendezvous & Proximity Operations" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/IA-0005/> ;
    rdfs:subClassOf d3f:SPARTAInitialAccessTechnique ;
    skos:altLabel "IA-0005" ;
    skos:definition "Threat actors may perform a space rendezvous which is a set of orbital maneuvers during which a spacecraft arrives at the same orbit and approach to a very close distance (e.g. within visual contact or close proximity) to a target spacecraft." ;
    skos:exactMatch d3f:IA-0005,
        mitre-attack:IA-0005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IA0008 a owl:Class ;
    rdfs:label "IA_0008" ;
    d3f:attack-id "IA-0008" ;
    dcterms:title "Rogue External Entity" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/IA-0008/> ;
    rdfs:subClassOf d3f:SPARTAInitialAccessTechnique ;
    skos:altLabel "IA-0008" ;
    skos:definition "Threat actors may gain access to a victim spacecraft through the use of a rogue external entity. With this technique, the threat actor does not need access to a legitimate ground station or communication site." ;
    skos:exactMatch d3f:IA-0008,
        mitre-attack:IA-0008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IA0009 a owl:Class ;
    rdfs:label "IA_0009" ;
    d3f:attack-id "IA-0009" ;
    dcterms:title "Trusted Relationship" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/IA-0009/> ;
    rdfs:subClassOf d3f:SPARTAInitialAccessTechnique ;
    skos:altLabel "IA-0009" ;
    skos:definition "Access through trusted third-party relationship exploits an existing connection that has been approved for interconnection. Leveraging third party / approved interconnections to pivot into the target systems is a common technique for threat actors as these interconnections typically lack stringent access control due to the trusted status." ;
    skos:exactMatch d3f:IA-0009,
        mitre-attack:IA-0009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImageCodeSegmentEnum a owl:Class ;
    rdfs:label "ImageCodeSegmentEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:AMD64CodeSegment d3f:ARM32CodeSegment d3f:X86CodeSegment ) ;
    skos:definition "Enumeration of ImageCodeSegment values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "An image code segment, also known as a text segment or simply as text, is a portion of an object file that contains executable instructions. The term \"segment\" comes from the memory segment, which is a historical approach to memory management that has been succeeded by paging. When a program is stor" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:AMD64CodeSegment,
        d3f:ARM32CodeSegment,
        d3f:X86CodeSegment .

d3f:ImageFile a owl:Class ;
    rdfs:label "ImageFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Image File" ;
    rdfs:subClassOf d3f:File ;
    skos:closeMatch unified_cyber_ontology:Image ;
    skos:definition "A file that contains graphics data." ;
    skos:exactMatch d3f:ImageFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImageScannerInputDevice a owl:Class ;
    rdfs:label "ImageScannerInputDevice" ;
    dcterms:title "Image Scanner Input Device" ;
    rdfs:seeAlso dbr:Image_scanner ;
    rdfs:subClassOf d3f:VideoInputDevice ;
    skos:altLabel "Scanner" ;
    skos:definition "An image scanner -- often abbreviated to just scanner, is a device that optically scans images, printed text, handwriting or an object and converts it to a digital image. Commonly used in offices are variations of the desktop flatbed scanner where the document is placed on a glass window for scanning. Hand-held scanners, where the device is moved by hand, have evolved from text scanning \"wands\" to 3D scanners used for industrial design, reverse engineering, test and measurement, orthotics, gaming and other applications. Mechanically driven scanners that move the document are typically used for large-format documents, where a flatbed design would be impractical." ;
    skos:exactMatch d3f:ImageScannerInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImageSegment a owl:Class ;
    rdfs:label "ImageSegment" ;
    dcterms:title "Image Segment" ;
    rdfs:seeAlso d3f:ObjectFile,
        dbr:Object_file ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:FileSection ],
        d3f:BinarySegment ;
    skos:definition "Image segments are distinct partitions of an object file. Both data and code segments are examples of image segments." ;
    skos:exactMatch d3f:ImageSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImpersonateUser a owl:Class ;
    rdfs:label "ImpersonateUser" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Impersonate User" ;
    rdfs:subClassOf d3f:SystemCall,
        d3f:SystemCallEnum,
        linkml:PermissibleValue ;
    skos:definition "Impersonate User" ;
    skos:exactMatch d3f:ImpersonateUser ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundNetworkTraffic a owl:Class ;
    rdfs:label "InboundNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inbound Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "Inbound traffic is network traffic originating from another host (client), to the host of interest (server)." ;
    skos:exactMatch d3f:InboundNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InferentialStatistics a owl:Class ;
    rdfs:label "InferentialStatistics" ;
    d3f:d3fend-id "D3A-IS" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Statistical inference. [Link](https://en.wikipedia.org/wiki/Statistical_inference)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inferential Statistics" ;
    rdfs:subClassOf d3f:StatisticalMethod ;
    skos:definition "Statistical inference is the process of using data analysis to infer properties of an underlying distribution of probability." ;
    skos:exactMatch d3f:InferentialStatistics ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InitScript a owl:Class ;
    rdfs:label "InitScript" ;
    dcterms:title "Init Script" ;
    rdfs:seeAlso dbr:Init,
        <https://blog.opstree.com/2020/02/11/shell-initialization-files/> ;
    rdfs:subClassOf d3f:ExecutableScript ;
    skos:altLabel "Initialization Script" ;
    skos:definition "An init script (or initialization script) is an executable script that initializes the an application, a process, or a service's state.  Examples include scripts run at boot by Unix or Windows, or those run to initialize a shell." ;
    skos:exactMatch d3f:InitScript ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Isolate a owl:Class ;
    rdfs:label "Isolate" ;
    d3f:display-order "2" ;
    d3f:display-priority "0" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The isolate tactic creates logical or physical barriers in a system which reduces opportunities for adversaries to create further accesses." ;
    skos:editorialNote "The isolate tactic creates logical or physical barriers in a system which reduces opportunities for adversaries to create further accesses." ;
    skos:exactMatch d3f:Isolate ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KerberosTicket a owl:Class ;
    rdfs:label "KerberosTicket" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kerberos Ticket" ;
    rdfs:subClassOf d3f:AccessToken ;
    skos:definition "An access ticket/token issued by a Kerberos system." ;
    skos:exactMatch d3f:KerberosTicket ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelEvent a owl:Class ;
    rdfs:label "KernelEvent" ;
    dcterms:title "Kernel Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/kernel_activity>,
        <https://schema.ocsf.io/classes/kernel_activity> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event involving operations at the kernel level of an operating system, encompassing interactions with core system resources such as drivers, modules, system calls, and other privileged processes. Kernel events are critical for understanding low-level system behavior and ensuring the integrity of the operating environment." ;
    skos:exactMatch d3f:KernelEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:KernelModuleEvent a owl:Class ;
    rdfs:label "KernelModuleEvent" ;
    dcterms:title "Kernel Module Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/kernel_extension>,
        <https://schema.ocsf.io/classes/kernel_extension_activity> ;
    rdfs:subClassOf d3f:KernelEvent ;
    skos:definition "An event involving the management of kernel modules, such as the loading or unloading of device drivers, extensions, or other dynamically linked components essential for kernel functionality." ;
    skos:exactMatch d3f:KernelModuleEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Link a owl:Class ;
    rdfs:label "Link" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Link> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DigitalInformationBearer ],
        d3f:D3FENDCore ;
    skos:definition "A link is a connection or association between two entities that facilitates communication, interaction, or data transfer." ;
    skos:exactMatch d3f:Link,
        oscal:Link ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LocalAttacker a owl:Class ;
    rdfs:label "LocalAttacker" ;
    dcterms:title "Local Attacker" ;
    rdfs:subClassOf d3f:Attacker ;
    skos:definition "An attacker who is physically near or on the premises of the target network or systems." ;
    skos:exactMatch d3f:LocalAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Log a owl:Class ;
    rdfs:label "Log" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Chronology,
        <http://wordnet-rdf.princeton.edu/id/06515215-n> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DigitalInformationBearer ],
        d3f:D3FENDCore ;
    skos:altLabel "Chronology" ;
    skos:definition "A record of events in the order of their occurrence." ;
    skos:exactMatch d3f:Log ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogFile a owl:Class ;
    rdfs:label "LogFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Log File" ;
    rdfs:seeAlso dbr:Log_file,
        <http://wordnet-rdf.princeton.edu/id/06515875-n> ;
    rdfs:subClassOf d3f:File ;
    skos:definition """A log file is a file that records either events that occur in an operating system or other software runs, or messages between different users of a communication software. Logging is the act of keeping a log. In the simplest case, messages are written to a single log file.

A transaction log is a file (i.e., log) of the communications between a system and the users of that system, or a data collection method that automatically captures the type, content, or time of transactions made by a person from a terminal with that system. For Web searching, a transaction log is an electronic record of interactions that have occurred during a searching episode between a Web search engine and users searching for information on that Web search engine.

Many operating systems, software frameworks and programs include a logging system. A widely used logging standard is syslog, defined in Internet Engineering Task Force (IETF) RFC 5424). The syslog standard enables a dedicated, standardized subsystem to generate, filter, record, and analyze log messages. This relieves software developers of having to design and code their own ad hoc logging systems.""" ;
    skos:exactMatch d3f:LogFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LogicalLinkMapping a owl:Class ;
    rdfs:label "LogicalLinkMapping" ;
    d3f:d3fend-id "D3-LLM" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logical Link Mapping" ;
    rdfs:subClassOf d3f:NetworkMapping ;
    skos:broadMatch d3f:T1114,
        d3f:T1505 ;
    skos:definition "Logical link mapping creates a model of existing or previous node-to-node connections using network-layer data or metadata." ;
    skos:exactMatch d3f:LogicalLinkMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.002,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003 .

d3f:MemoryAddress a owl:Class ;
    rdfs:label "MemoryAddress" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Address" ;
    rdfs:seeAlso <https://dbpedia.org/page/Memory_address> ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "In computing, a memory address is a reference to a specific memory location used at various levels by software and hardware." ;
    skos:exactMatch d3f:MemoryAddress ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryBlock a owl:Class ;
    rdfs:label "MemoryBlock" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Memory Block" ;
    rdfs:seeAlso <https://dbpedia.org/page/Block_(data_storage)> ;
    rdfs:subClassOf d3f:MemoryExtent ;
    skos:broadMatch unified_cyber_ontology:Memory ;
    skos:definition "In computing (specifically data transmission and data storage), a block, sometimes called a physical record, is a sequence of bytes or bits, usually containing some whole number of records, having a maximum length; a block size. Data thus structured are said to be blocked. The process of putting data into blocks is called blocking, while deblocking is the process of extracting data from blocks. Blocked data is normally stored in a data buffer and read or written a whole block at a time." ;
    skos:exactMatch d3f:MemoryBlock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MessageAnalysis a owl:Class ;
    rdfs:label "MessageAnalysis" ;
    d3f:d3fend-id "D3-MA" ;
    d3f:kb-article "## Technique Overview Email and messaging are frequently used to deliver malicious content to targets. These enterprise capabilities are used to deliver software exploits or social engineering tricks. If the recipient of a message trusts the sender, attackers can avoid escalating suspicion. Emails" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Electronic Message Analysis" ;
    dcterms:title "Message Analysis" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Analyzing email or instant message content to detect unauthorized activity." ;
    skos:exactMatch d3f:MessageAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Metadata a owl:Class ;
    rdfs:label "Metadata" ;
    rdfs:seeAlso dbr:Metadata,
        <https://schema.ocsf.io/objects/metadata> ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "Metadata is information which describes aspects of other information." ;
    skos:exactMatch d3f:Metadata,
        oscal:Metadata ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Model a owl:Class ;
    rdfs:label "Model" ;
    d3f:display-order "-1" ;
    d3f:display-priority "1" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The model tactic is used to apply security engineering, vulnerability, threat, and risk analyses to digital systems. This is accomplished by creating and maintaining a common understanding of the systems being defended, the operations on those systems, actors using the systems, and the relationships and interactions between these elements." ;
    skos:editorialNote "The model tactic is used to apply security engineering, vulnerability, threat, and risk analyses to digital systems. This is accomplished by creating and maintaining a common understanding of the systems being defended, the operations on those systems, actors using the systems, and the relationships and interactions between these elements." ;
    skos:exactMatch d3f:Model ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ModelBasedReinforcementLearning a owl:Class ;
    rdfs:label "Model_basedReinforcementLearning" ;
    d3f:d3fend-id "D3A-MBRL" ;
    d3f:kb-article "## References Model-Based Reinforcement Learning. In *Encyclopedia of Machine Learning*, pp. 642-644. Springer, 2010. [Link](https://link.springer.com/referenceworkentry/10.1007/978-0-387-30164-8_556#:~:text=Model%2Dbased%20Reinforcement%20Learning%20refers,state%20and%20the%20immediate%20reward)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Model-based Reinforcement Learning" ;
    rdfs:subClassOf d3f:ReinforcementLearning ;
    skos:altLabel "Model-basedReinforcementLearning" ;
    skos:definition "Model-based Reinforcement Learning refers to learning optimal behavior indirectly by learning a model of the environment by taking actions and observing the outcomes that include the next state and the immediate reward. The models predict the outcomes of actions and are used in lieu of or in addition to interaction with the environment to learn optimal policies." ;
    skos:exactMatch d3f:Model-basedReinforcementLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MultivariateAnalysis a owl:Class ;
    rdfs:label "MultivariateAnalysis" ;
    d3f:d3fend-id "D3A-MA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Multivariate statistics. [Link](https://en.wikipedia.org/wiki/Multivariate_statistics)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multivariate Analysis" ;
    rdfs:subClassOf d3f:StatisticalMethod ;
    skos:definition "Multivariate statistics encompassed the simultaneous observation and analysis of more than one outcome variable, i.e., multivariate random variables." ;
    skos:exactMatch d3f:MultivariateAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NISTSP80053ControlCatalogEnum a owl:Class ;
    rdfs:label "NISTSP800_53ControlCatalogEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:NIST_SP_800-53_R3 d3f:NIST_SP_800-53_R4 d3f:NIST_SP_800-53_R5 ) ;
    skos:definition "Enumeration of NISTSP800-53ControlCatalog values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A NIST SP 800-53 control catalog provides the entire set of security and privacy controls for a version of NIST SP 800-53." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:NIST_SP_800-53_R3,
        d3f:NIST_SP_800-53_R4,
        d3f:NIST_SP_800-53_R5 .

d3f:NetworkAccessMediation a owl:Class ;
    rdfs:label "NetworkAccessMediation" ;
    d3f:d3fend-id "D3-NAM" ;
    d3f:kb-article "## How it works Network Access Mediation is a crucial process in telecommunications and IT networks that involves controlling access to network resources. It acts as an intermediary layer between network access requests and the actual network resources, ensuring that only authorized users and devic" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Network Access Control" ;
    dcterms:title "Network Access Mediation" ;
    rdfs:seeAlso <https://nvlpubs.nist.gov/nistpubs/SpecialPublications/NIST.SP.800-160v1r1.pdf> ;
    rdfs:subClassOf d3f:AccessMediation ;
    skos:definition "Network access mediation is the control method for authorizing access to a system by a user (or a process acting on behalf of a user) communicating through a network, including a local area network, a wide area network, and the Internet." ;
    skos:exactMatch d3f:NetworkAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkFileResource a owl:Class ;
    rdfs:label "NetworkFileResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network File Resource" ;
    rdfs:subClassOf d3f:NetworkFileShareResource ;
    skos:definition "A computer file resource made available from one host to other hosts on a computer network." ;
    skos:exactMatch d3f:NetworkFileResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkFileShareResource a owl:Class ;
    rdfs:label "NetworkFileShareResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network File Share Resource" ;
    rdfs:subClassOf d3f:NetworkResource ;
    skos:definition "A shared file resource, or network file share, is a computer file made available from one host to other hosts on a computer network. Network sharing is made possible by inter-process communication over the network. It includes both files and directories." ;
    skos:exactMatch d3f:NetworkFileShareResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkResourceAccessMediation a owl:Class ;
    rdfs:label "NetworkResourceAccessMediation" ;
    d3f:d3fend-id "D3-NRAM" ;
    d3f:kb-article "## How it works Network Resource Access Control involves managing and regulating access to resources within an organization's network. This includes ensuring that only authorized users or processes can access specific systems or data, often through authentication and authorization mechanisms. Examp" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Remote Access Control" ;
    dcterms:title "Network Resource Access Mediation" ;
    rdfs:subClassOf d3f:AccessMediation ;
