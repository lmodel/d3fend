        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1546.007,
        mitre-attack:T1550,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:ProxyBasedWebServerAccessMediation a owl:Class ;
    rdfs:label "Proxy_basedWebServerAccessMediation" ;
    d3f:d3fend-id "D3-PBWSAM" ;
    d3f:kb-article "## How it works Proxy-based Web Server Access Mediation involves controlling access to web servers via proxy servers, which act as intermediaries between users and web resources. This approach can enhance security by anonymizing user requests, filtering content, and enforcing access policies. Examp" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Proxy-based Web Server Access Mediation" ;
    rdfs:subClassOf d3f:WebSessionAccessMediation ;
    skos:altLabel "Proxy-basedWebServerAccessMediation" ;
    skos:definition "Proxy-based web server access mediation focuses on the regulation of web server access through intermediary proxy servers." ;
    skos:exactMatch d3f:Proxy-basedWebServerAccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000101 a owl:Class ;
    rdfs:label "RD_0001_01" ;
    d3f:attack-id "RD-0001.01" ;
    dcterms:title "Ground Station Equipment" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0001/01/> ;
    rdfs:subClassOf d3f:RD0001 ;
    skos:altLabel "RD-0001.01" ;
    skos:definition """Threat actors will likely need to acquire the following types of equipment to establish ground-to-space communications:

Antenna positioners: which also usually come with satellite tracking antenna systems, in order to accurately send and receive signals along several different bands. This infrastructure is useful in pinpointing the location of a spacecraft in the sky.

Ground antennas: in order to send commands and receive telemetry from the victim spacecraft. Threat actors can utilize these antennas in relation to other tactics such as execution and exfiltration. Instead of compromising a third-part ground station, threat actors may opt to configure and run their own antennas in support of operations.

Ground data processors: in order to convert RF signals to TCP packets. This equipment is utilized in ground stations to convert the telemetry into human readable format.

Ground radio modems: in order to convert TCP packs to RF signals. This equipment is utilized in ground stations to convert commands into RF signals in order to send them to orbiting spacecraft.

Signal generator: in order to configure amplitude, frequency, and apply modulations to the signal.

Additional examples of equipment include couplers, attenuators, power dividers, diplexers, low noise amplifiers, high power amplifiers, filters, mixers, spectrum analyzers, etc.""" ;
    skos:exactMatch d3f:RD-0001.01,
        mitre-attack:RD-0001.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000102 a owl:Class ;
    rdfs:label "RD_0001_02" ;
    d3f:attack-id "RD-0001.02" ;
    dcterms:title "Commercial Ground Station Services" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0001/02/> ;
    rdfs:subClassOf d3f:RD0001 ;
    skos:altLabel "RD-0001.02" ;
    skos:definition "Threat actors may buy or rent commercial ground station services. These services often have all of the individual parts that are needed to properly communicate with spacecrafts. By utilizing existing infrastructure, threat actors may save time, money, and effort in order to support operations." ;
    skos:exactMatch d3f:RD-0001.02,
        mitre-attack:RD-0001.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000103 a owl:Class ;
    rdfs:label "RD_0001_03" ;
    d3f:attack-id "RD-0001.03" ;
    dcterms:title "Spacecraft" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0001/03/> ;
    rdfs:subClassOf d3f:RD0001 ;
    skos:altLabel "RD-0001.03" ;
    skos:definition "Threat actors may acquire their own spacecraft that has the capability to maneuver within close proximity to a target spacecraft. Since many of the commercial and military assets in space are tracked, and that information is publicly available, attackers can identify the location of space assets to infer the best positioning for intersecting orbits. Proximity operations support avoidance of the larger attenuation that would otherwise affect the signal when propagating long distances, or environmental circumstances that may present interference." ;
    skos:exactMatch d3f:RD-0001.03,
        mitre-attack:RD-0001.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000104 a owl:Class ;
    rdfs:label "RD_0001_04" ;
    d3f:attack-id "RD-0001.04" ;
    dcterms:title "Launch Facility" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0001/04/> ;
    rdfs:subClassOf d3f:RD0001 ;
    skos:altLabel "RD-0001.04" ;
    skos:definition "Threat actors may need to acquire a launch facility, which is a specialized location designed for launching spacecraft and rockets into space. These facilities typically include launch pads, control centers, and assembly buildings, and are often located near bodies of water or in remote areas to minimize potential safety hazards and provide enough room for rocket launches. Launch facilities can be operated by the military, national space agencies such as NASA in the United States or Roscosmos in Russia, or by private companies such as SpaceX or Blue Origin." ;
    skos:exactMatch d3f:RD-0001.04,
        mitre-attack:RD-0001.04 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000201 a owl:Class ;
    rdfs:label "RD_0002_01" ;
    d3f:attack-id "RD-0002.01" ;
    dcterms:title "Mission-Operated Ground System" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0002/01/> ;
    rdfs:subClassOf d3f:RD0002 ;
    skos:altLabel "RD-0002.01" ;
    skos:definition "Threat actors may compromise mission owned/operated ground systems that can be used for future campaigns or to perpetuate other techniques. These ground systems have already been configured for communications to the victim spacecraft. By compromising this infrastructure, threat actors can stage, launch, and execute an operation. Threat actors may utilize these systems for various tasks, including Execution and Exfiltration." ;
    skos:exactMatch d3f:RD-0002.01,
        mitre-attack:RD-0002.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000202 a owl:Class ;
    rdfs:label "RD_0002_02" ;
    d3f:attack-id "RD-0002.02" ;
    dcterms:title "3rd Party Ground System" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0002/02/> ;
    rdfs:subClassOf d3f:RD0002 ;
    skos:altLabel "RD-0002.02" ;
    skos:definition "Threat actors may compromise access to third-party ground systems that can be used for future campaigns or to perpetuate other techniques. These ground systems can be or may have already been configured for communications to the victim spacecraft. By compromising this infrastructure, threat actors can stage, launch, and execute an operation." ;
    skos:exactMatch d3f:RD-0002.02,
        mitre-attack:RD-0002.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000203 a owl:Class ;
    rdfs:label "RD_0002_03" ;
    d3f:attack-id "RD-0002.03" ;
    dcterms:title "3rd-Party Spacecraft" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0002/03/> ;
    rdfs:subClassOf d3f:RD0002 ;
    skos:altLabel "RD-0002.03" ;
    skos:definition "Threat actors may compromise a 3rd-party spacecraft that has the capability to maneuver within close proximity to a target spacecraft. This technique enables historically lower-tier attackers the same capability as top tier nation-state actors without the initial development cost. Additionally, this technique complicates attribution of an attack. Since many of the commercial and military assets in space are tracked, and that information is publicly available, attackers can identify the location of space assets to infer the best positioning for intersecting orbits. Proximity operations support avoidance of the larger attenuation that would otherwise affect the signal when propagating long distances, or environmental circumstances that may present interference. Further, the compromised spacecraft may posses the capability to grapple target spacecraft once it has established the appropriate space rendezvous. If from a proximity / rendezvous perspective a threat actor has the ability to connect via docking interface or expose testing (i.e., JTAG port) once it has grappled the target spacecraft, they could perform various attacks depending on the access enabled via the physical connection." ;
    skos:exactMatch d3f:RD-0002.03,
        mitre-attack:RD-0002.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000301 a owl:Class ;
    rdfs:label "RD_0003_01" ;
    d3f:attack-id "RD-0003.01" ;
    dcterms:title "Exploit/Payload" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0003/01/> ;
    rdfs:subClassOf d3f:RD0003 ;
    skos:altLabel "RD-0003.01" ;
    skos:definition "Threat actors may buy, steal, or download exploits and payloads that can be used for future campaigns or to perpetuate other techniques. An exploit/payload takes advantage of a bug or vulnerability in order to cause unintended or unanticipated behavior to occur on the victim spacecraft's hardware, software, and/or subsystems. Rather than develop their own, threat actors may find/modify exploits from online or purchase them from exploit vendors." ;
    skos:exactMatch d3f:RD-0003.01,
        mitre-attack:RD-0003.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000302 a owl:Class ;
    rdfs:label "RD_0003_02" ;
    d3f:attack-id "RD-0003.02" ;
    dcterms:title "Cryptographic Keys" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0003/02/> ;
    rdfs:subClassOf d3f:RD0003 ;
    skos:altLabel "RD-0003.02" ;
    skos:definition "Threat actors may obtain encryption keys as they are used for the main commanding of the target spacecraft or any of its subsystems/payloads. Once obtained, threat actors may use any number of means to command the spacecraft without needing to go through a legitimate channel. These keys may be obtained through reconnaissance of the ground system or retrieved from the victim spacecraft." ;
    skos:exactMatch d3f:RD-0003.02,
        mitre-attack:RD-0003.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000401 a owl:Class ;
    rdfs:label "RD_0004_01" ;
    d3f:attack-id "RD-0004.01" ;
    dcterms:title "Identify/Select Delivery Mechanism" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0004/01/> ;
    rdfs:subClassOf d3f:RD0004 ;
    skos:altLabel "RD-0004.01" ;
    skos:definition "Threat actors may identify, select, and prepare a delivery mechanism in which to attack the space system (i.e., communicate with the victim spacecraft, deny the ground, etc.) to achieve their desired impact. This mechanism may be located on infrastructure that was previously purchased or rented by the threat actor or was otherwise compromised by them. The mechanism must include all aspects needed to communicate with the victim spacecraft, including ground antenna, converters, and amplifiers." ;
    skos:exactMatch d3f:RD-0004.01,
        mitre-attack:RD-0004.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000402 a owl:Class ;
    rdfs:label "RD_0004_02" ;
    d3f:attack-id "RD-0004.02" ;
    dcterms:title "Upload Exploit/Payload" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0004/02/> ;
    rdfs:subClassOf d3f:RD0004 ;
    skos:altLabel "RD-0004.02" ;
    skos:definition "Threat actors may upload exploits and payloads to a third-party infrastructure that they have purchased or rented or stage it on an otherwise compromised ground station. Exploits and payloads would include files and commands to be uploaded to the victim spacecraft in order to conduct the threat actor's attack." ;
    skos:exactMatch d3f:RD-0004.02,
        mitre-attack:RD-0004.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000501 a owl:Class ;
    rdfs:label "RD_0005_01" ;
    d3f:attack-id "RD-0005.01" ;
    dcterms:title "Launch Services" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0005/01/> ;
    rdfs:subClassOf d3f:RD0005 ;
    skos:altLabel "RD-0005.01" ;
    skos:definition "Threat actors may acquire launch capabilities through their own development or through space launch service providers (companies or organizations that specialize in launching payloads into space). Space launch service providers typically offer a range of services, including launch vehicle design, development, and manufacturing as well as payload integration and testing. These services are critical to the success of any space mission and require specialized expertise, advanced technology, and extensive infrastructure." ;
    skos:exactMatch d3f:RD-0005.01,
        mitre-attack:RD-0005.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000502 a owl:Class ;
    rdfs:label "RD_0005_02" ;
    d3f:attack-id "RD-0005.02" ;
    dcterms:title "Non-Kinetic Physical ASAT" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0005/02/> ;
    rdfs:subClassOf d3f:RD0005 ;
    skos:altLabel "RD-0005.02" ;
    skos:definition """A non-kinetic physical ASAT attack is when a satellite is physically damaged without any direct contact. Non-kinetic physical attacks can be characterized into a few types: electromagnetic pulses, high-powered lasers, and high-powered microwaves. These attacks have medium possible attribution levels and often provide little evidence of success to the attacker.*

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:RD-0005.02,
        mitre-attack:RD-0005.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000503 a owl:Class ;
    rdfs:label "RD_0005_03" ;
    d3f:attack-id "RD-0005.03" ;
    dcterms:title "Kinetic Physical ASAT" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0005/03/> ;
    rdfs:subClassOf d3f:RD0005 ;
    skos:altLabel "RD-0005.03" ;
    skos:definition """Kinetic physical ASAT attacks attempt to damage or destroy space- or land-based space assets. They typically are organized into three categories: direct-ascent, co-orbital, and ground station attacks. The nature of these attacks makes them easier to attribute and allow for better confirmation of success on the part of the attacker. *

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:RD-0005.03,
        mitre-attack:RD-0005.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD000504 a owl:Class ;
    rdfs:label "RD_0005_04" ;
    d3f:attack-id "RD-0005.04" ;
    dcterms:title "Electronic ASAT" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0005/04/> ;
    rdfs:subClassOf d3f:RD0005 ;
    skos:altLabel "RD-0005.04" ;
    skos:definition """Rather than attempting to damage the physical components of space systems, electronic ASAT attacks target the means by which space systems transmit and receive data. Both jamming and spoofing are forms of electronic attack that can be difficult to attribute and only have temporary effects.*

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:RD-0005.04,
        mitre-attack:RD-0005.04 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000101 a owl:Class ;
    rdfs:label "REC_0001_01" ;
    d3f:attack-id "REC-0001.01" ;
    dcterms:title "Software Design" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/01/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.01" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's internal software that can be used for future campaigns or to help perpetuate other techniques. Information (e.g. source code, binaries, etc.) about commercial, open-source, or custom developed software may include a variety of details such as types, versions, and memory maps. Leveraging this information threat actors may target vendors of operating systems, flight software, or open-source communities to embed backdoors or for performing reverse engineering research to support offensive cyber operations." ;
    skos:exactMatch d3f:REC-0001.01,
        mitre-attack:REC-0001.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000102 a owl:Class ;
    rdfs:label "REC_0001_02" ;
    d3f:attack-id "REC-0001.02" ;
    dcterms:title "Firmware" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/02/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.02" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's firmware that can be used for future campaigns or to help perpetuate other techniques. Information about the firmware may include a variety of details such as type and versions on specific devices, which may be used to infer more information (ex. configuration, purpose, age/patch level, etc.). Leveraging this information threat actors may target firmware vendors to embed backdoors or for performing reverse engineering research to support offensive cyber operations." ;
    skos:exactMatch d3f:REC-0001.02,
        mitre-attack:REC-0001.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000103 a owl:Class ;
    rdfs:label "REC_0001_03" ;
    d3f:attack-id "REC-0001.03" ;
    dcterms:title "Cryptographic Algorithms" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/03/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.03" ;
    skos:definition "Threat actors may gather information about any cryptographic algorithms used on the victim spacecraft's that can be used for future campaigns or to help perpetuate other techniques. Information about the algorithms can include type and private keys. Threat actors may also obtain the authentication scheme (i.e., key/password/counter values) and leverage it to establish communications for commanding the target spacecraft or any of its subsystems. Some spacecraft only require authentication vice authentication and encryption, therefore once obtained, threat actors may use any number of means to command the spacecraft without needing to go through a legitimate channel. The authentication information may be obtained through reconnaissance of the ground system or retrieved from the victim spacecraft." ;
    skos:exactMatch d3f:REC-0001.03,
        mitre-attack:REC-0001.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000104 a owl:Class ;
    rdfs:label "REC_0001_04" ;
    d3f:attack-id "REC-0001.04" ;
    dcterms:title "Data Bus" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/04/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.04" ;
    skos:definition """Threat actors may gather information about the data bus used within the victim spacecraft that can be used for future campaigns or to help perpetuate other techniques. Information about the data bus can include the make and model which could lead to more information (ex. protocol, purpose, controller, etc.), as well as locations/addresses of major subsystems residing on the bus.

Threat actors may also gather information about the bus voltages of the victim spacecraft. This information can include optimal power levels, connectors, range, and transfer rate.""" ;
    skos:exactMatch d3f:REC-0001.04,
        mitre-attack:REC-0001.04 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000105 a owl:Class ;
    rdfs:label "REC_0001_05" ;
    d3f:attack-id "REC-0001.05" ;
    dcterms:title "Thermal Control System" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/05/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.05" ;
    skos:definition "Threat actors may gather information about the thermal control system used with the victim spacecraft that can be used for future campaigns or to help perpetuate other techniques. Information gathered can include type, make/model, and varies analysis programs that monitor it." ;
    skos:exactMatch d3f:REC-0001.05,
        mitre-attack:REC-0001.05 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000106 a owl:Class ;
    rdfs:label "REC_0001_06" ;
    d3f:attack-id "REC-0001.06" ;
    dcterms:title "Maneuver & Control" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/06/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.06" ;
    skos:definition "Threat actors may gather information about the station-keeping control systems within the victim spacecraft that can be used for future campaigns or to help perpetuate other techniques. Information gathered can include thruster types, propulsion types, attitude sensors, and data flows associated with the relevant subsystems." ;
    skos:exactMatch d3f:REC-0001.06,
        mitre-attack:REC-0001.06 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000107 a owl:Class ;
    rdfs:label "REC_0001_07" ;
    d3f:attack-id "REC-0001.07" ;
    dcterms:title "Payload" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/07/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.07" ;
    skos:definition "Threat actors may gather information about the type(s) of payloads hosted on the victim spacecraft. This information could include specific commands, make and model, and relevant software. Threat actors may also gather information about the location of the payload on the bus and internal routing as it pertains to commands within the payload itself." ;
    skos:exactMatch d3f:REC-0001.07,
        mitre-attack:REC-0001.07 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000108 a owl:Class ;
    rdfs:label "REC_0001_08" ;
    d3f:attack-id "REC-0001.08" ;
    dcterms:title "Power" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/08/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.08" ;
    skos:definition "Threat actors may gather information about the power system used within the victim spacecraft. This information can include type, power intake, and internal algorithms. Threat actors may also gather information about the solar panel configurations such as positioning, automated tasks, and layout. Additionally, threat actors may gather information about the batteries used within the victim spacecraft. This information can include the type, quantity, storage capacity, make and model, and location." ;
    skos:exactMatch d3f:REC-0001.08,
        mitre-attack:REC-0001.08 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000109 a owl:Class ;
    rdfs:label "REC_0001_09" ;
    d3f:attack-id "REC-0001.09" ;
    dcterms:title "Fault Management" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/09/> ;
    rdfs:subClassOf d3f:REC0001 ;
    skos:altLabel "REC-0001.09" ;
    skos:definition "Threat actors may gather information about any fault management that may be present on the victim spacecraft. This information can help threat actors construct specific attacks that may put the spacecraft into a fault condition and potentially a more vulnerable state depending on the fault response." ;
    skos:exactMatch d3f:REC-0001.09,
        mitre-attack:REC-0001.09 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000201 a owl:Class ;
    rdfs:label "REC_0002_01" ;
    d3f:attack-id "REC-0002.01" ;
    dcterms:title "Identifiers" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0002/01/> ;
    rdfs:subClassOf d3f:REC0002 ;
    skos:altLabel "REC-0002.01" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's identity attributes that can be used for future campaigns or to help perpetuate other techniques. Information may include a variety of details such as the satellite catalog number, international designator, mission name, and more." ;
    skos:exactMatch d3f:REC-0002.01,
        mitre-attack:REC-0002.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000202 a owl:Class ;
    rdfs:label "REC_0002_02" ;
    d3f:attack-id "REC-0002.02" ;
    dcterms:title "Organization" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0002/02/> ;
    rdfs:subClassOf d3f:REC0002 ;
    skos:altLabel "REC-0002.02" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's associated organization(s) that can be used for future campaigns or to help perpetuate other techniques. Collection efforts may target the mission owner/operator in order to conduct further attacks against the organization, individual, or other interested parties. Threat actors may also seek information regarding the spacecraft's designer/builder, including physical locations, key employees, and roles and responsibilities as they pertain to the spacecraft, as well as information pertaining to the mission's end users/customers." ;
    skos:exactMatch d3f:REC-0002.02,
        mitre-attack:REC-0002.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000203 a owl:Class ;
    rdfs:label "REC_0002_03" ;
    d3f:attack-id "REC-0002.03" ;
    dcterms:title "Operations" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0002/03/> ;
    rdfs:subClassOf d3f:REC0002 ;
    skos:altLabel "REC-0002.03" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's operations that can be used for future campaigns or to help perpetuate other techniques. Collection efforts may target mission objectives, orbital parameters such as orbit slot and inclination, user guides and schedules, etc. Additionally, threat actors may seek information about constellation deployments and configurations where applicable." ;
    skos:exactMatch d3f:REC-0002.03,
        mitre-attack:REC-0002.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000301 a owl:Class ;
    rdfs:label "REC_0003_01" ;
    d3f:attack-id "REC-0003.01" ;
    dcterms:title "Communications Equipment" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0003/01/> ;
    rdfs:subClassOf d3f:REC0003 ;
    skos:altLabel "REC-0003.01" ;
    skos:definition """Threat actors may gather information regarding the communications equipment and its configuration that will be used for communicating with the victim spacecraft. This includes:

Antenna Shape: This information can help determine the range in which it can communicate, the power of it's transmission, and the receiving patterns.

Antenna Configuration/Location:	This information can include positioning, transmission frequency, wavelength, and timing.

Telemetry Signal Type: Information can include timing, radio frequency wavelengths, and other information that can provide insight into the spacecraft's telemetry system.

Beacon Frequency: This information can provide insight into where the spacecrafts located, what it's orbit is, and how long it can take to communicate with a ground station.

Beacon Polarization: This information can help triangulate the spacecrafts it orbits the earth and determine how a satellite must be oriented in order to communicate with the victim spacecraft.

Transponder: This could include the number of transponders per band, transponder translation factor, transponder mappings, power utilization, and/or saturation point.""" ;
    skos:exactMatch d3f:REC-0003.01,
        mitre-attack:REC-0003.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000302 a owl:Class ;
    rdfs:label "REC_0003_02" ;
    d3f:attack-id "REC-0003.02" ;
    dcterms:title "Commanding Details" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0003/02/> ;
    rdfs:subClassOf d3f:REC0003 ;
    skos:altLabel "REC-0003.02" ;
    skos:definition """Threat actors may gather information regarding the commanding approach that will be used for communicating with the victim spacecraft. This includes:

Commanding Signal Type: This can include timing, radio frequency wavelengths, and other information that can provide insight into the spacecraft's commanding system.

Valid Commanding Patterns: Most commonly, this comes in the form of a command database, but can also include other means that provide information on valid commands and the communication protocols used by the victim spacecraft.

Valid Commanding Periods: This information can provide insight into when a command will be accepted by the spacecraft and help the threat actor construct a viable attack campaign.""" ;
    skos:exactMatch d3f:REC-0003.02,
        mitre-attack:REC-0003.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000303 a owl:Class ;
    rdfs:label "REC_0003_03" ;
    d3f:attack-id "REC-0003.03" ;
    dcterms:title "Mission-Specific Channel Scanning" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0003/03/> ;
    rdfs:subClassOf d3f:REC0003 ;
    skos:altLabel "REC-0003.03" ;
    skos:definition "Threat actors may seek knowledge about mission-specific  communication channels dedicated to a payload. Such channels could be managed by a different organization than the owner of the spacecraft itself." ;
    skos:exactMatch d3f:REC-0003.03,
        mitre-attack:REC-0003.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000304 a owl:Class ;
    rdfs:label "REC_0003_04" ;
    d3f:attack-id "REC-0003.04" ;
    dcterms:title "Valid Credentials" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0003/04/> ;
    rdfs:subClassOf d3f:REC0003 ;
    skos:altLabel "REC-0003.04" ;
    skos:definition "Threat actors may seek out valid credentials which can be utilized to facilitate several tactics throughout an attack. Credentials may include, but are not limited to: system service accounts, user accounts, maintenance accounts, cryptographic keys and other authentication mechanisms." ;
    skos:exactMatch d3f:REC-0003.04,
        mitre-attack:REC-0003.04 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000401 a owl:Class ;
    rdfs:label "REC_0004_01" ;
    d3f:attack-id "REC-0004.01" ;
    dcterms:title "Flight Termination" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0004/01/> ;
    rdfs:subClassOf d3f:REC0004 ;
    skos:altLabel "REC-0004.01" ;
    skos:definition "Threat actor may obtain information regarding the vehicle's flight termination system. Threat actors may use this information to perform later attacks and target the vehicle's termination system to have desired impact on mission." ;
    skos:exactMatch d3f:REC-0004.01,
        mitre-attack:REC-0004.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000501 a owl:Class ;
    rdfs:label "REC_0005_01" ;
    d3f:attack-id "REC-0005.01" ;
    dcterms:title "Uplink Intercept Eavesdropping" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0005/01/> ;
    rdfs:subClassOf d3f:REC0005 ;
    skos:altLabel "REC-0005.01" ;
    skos:definition "Threat actors may capture the RF communications as it pertains to the uplink to the victim spacecraft. This information can contain commanding information that the threat actor can use to perform other attacks against the victim spacecraft." ;
    skos:exactMatch d3f:REC-0005.01,
        mitre-attack:REC-0005.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000502 a owl:Class ;
    rdfs:label "REC_0005_02" ;
    d3f:attack-id "REC-0005.02" ;
    dcterms:title "Downlink Intercept" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0005/02/> ;
    rdfs:subClassOf d3f:REC0005 ;
    skos:altLabel "REC-0005.02" ;
    skos:definition "Threat actors may capture the RF communications as it pertains to the downlink of the victim spacecraft. This information can contain important telemetry such as onboard status and mission data." ;
    skos:exactMatch d3f:REC-0005.02,
        mitre-attack:REC-0005.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000503 a owl:Class ;
    rdfs:label "REC_0005_03" ;
    d3f:attack-id "REC-0005.03" ;
    dcterms:title "Proximity Operations" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0005/03/> ;
    rdfs:subClassOf d3f:REC0005 ;
    skos:altLabel "REC-0005.03" ;
    skos:definition "Threat actors may capture signals and/or network communications as they travel on-board the vehicle (i.e., EMSEC/TEMPEST), via RF, or terrestrial networks. This information can be decoded to determine commanding and telemetry protocols, command times, and other information that could be used for future attacks." ;
    skos:exactMatch d3f:REC-0005.03,
        mitre-attack:REC-0005.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000504 a owl:Class ;
    rdfs:label "REC_0005_04" ;
    d3f:attack-id "REC-0005.04" ;
    dcterms:title "Active Scanning (RF/Optical)" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0005/04/> ;
    rdfs:subClassOf d3f:REC0005 ;
    skos:altLabel "REC-0005.04" ;
    skos:definition "Threat actors may interfere with the link by actively transmitting packets to activate the transmitter and induce a reply. The scan can be similar to a brute force attack, aiming to guess the used frequencies and protocols to obtain a reply." ;
    skos:exactMatch d3f:REC-0005.04,
        mitre-attack:REC-0005.04 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000601 a owl:Class ;
    rdfs:label "REC_0006_01" ;
    d3f:attack-id "REC-0006.01" ;
    dcterms:title "Development Environment" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0006/01/> ;
    rdfs:subClassOf d3f:REC0006 ;
    skos:altLabel "REC-0006.01" ;
    skos:definition "Threat actors may gather information regarding the development environment for the victim spacecraft's FSW. This information can include IDEs, configurations, source code, environment variables, source code repositories, code \"secrets\", and compiled binaries." ;
    skos:exactMatch d3f:REC-0006.01,
        mitre-attack:REC-0006.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000602 a owl:Class ;
    rdfs:label "REC_0006_02" ;
    d3f:attack-id "REC-0006.02" ;
    dcterms:title "Security Testing Tools" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0006/02/> ;
    rdfs:subClassOf d3f:REC0006 ;
    skos:altLabel "REC-0006.02" ;
    skos:definition "Threat actors may gather information regarding how a victim spacecraft is tested in regards to the FSW. Understanding the testing approach including tools could identify gaps and vulnerabilities that could be discovered and exploited by a threat actor." ;
    skos:exactMatch d3f:REC-0006.02,
        mitre-attack:REC-0006.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0007 a owl:Class ;
    rdfs:label "REC_0007" ;
    d3f:attack-id "REC-0007" ;
    dcterms:title "Monitor for Safe-Mode Indicators" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0007/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0007" ;
    skos:definition "Threat actors may gather information regarding safe-mode indicators on the victim spacecraft. Safe-mode is when all non-essential systems are shut down and only essential functions within the spacecraft are active. During this mode, several commands are available to be processed that are not normally processed. Further, many protections may be disabled at this time." ;
    skos:exactMatch d3f:REC-0007,
        mitre-attack:REC-0007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000801 a owl:Class ;
    rdfs:label "REC_0008_01" ;
    d3f:attack-id "REC-0008.01" ;
    dcterms:title "Hardware Recon" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0008/01/> ;
    rdfs:subClassOf d3f:REC0008 ;
    skos:altLabel "REC-0008.01" ;
    skos:definition "Threat actors may gather information that can be used to facilitate a future attack where they manipulate hardware components in the victim spacecraft prior to the customer receiving them in order to achieve data or system compromise. The threat actor can insert backdoors and give them a high level of control over the system when they modify the hardware or firmware in the supply chain. This would include ASIC and FPGA devices as well." ;
    skos:exactMatch d3f:REC-0008.01,
        mitre-attack:REC-0008.01 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000802 a owl:Class ;
    rdfs:label "REC_0008_02" ;
    d3f:attack-id "REC-0008.02" ;
    dcterms:title "Software Recon" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0008/02/> ;
    rdfs:subClassOf d3f:REC0008 ;
    skos:altLabel "REC-0008.02" ;
    skos:definition "Threat actors may gather information relating to the mission's software supply chain in order to facilitate future attacks to achieve data or system compromise. This attack can take place in a number of ways, including manipulation of source code, manipulation of the update and/or distribution mechanism, or replacing compiled versions with a malicious one." ;
    skos:exactMatch d3f:REC-0008.02,
        mitre-attack:REC-0008.02 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000803 a owl:Class ;
    rdfs:label "REC_0008_03" ;
    d3f:attack-id "REC-0008.03" ;
    dcterms:title "Known Vulnerabilities" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0008/03/> ;
    rdfs:subClassOf d3f:REC0008 ;
    skos:altLabel "REC-0008.03" ;
    skos:definition "Threat actors may gather information about vulnerabilities that can be used for future campaigns or to perpetuate other techniques. A vulnerability is a weakness in the victim spacecraft's hardware, subsystems, bus, or software that can, potentially, be exploited by a threat actor to cause unintended or unanticipated behavior to occur.  During reconnaissance as threat actors identify the types/versions of software (i.e., COTS, open-source) being used, they will look for well-known vulnerabilities that could affect the spacecraft. Threat actors may find vulnerability information by searching leaked documents, vulnerability databases/scanners, compromising ground systems, and searching through online databases." ;
    skos:exactMatch d3f:REC-0008.03,
        mitre-attack:REC-0008.03 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC000804 a owl:Class ;
    rdfs:label "REC_0008_04" ;
    d3f:attack-id "REC-0008.04" ;
    dcterms:title "Business Relationships" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0008/04/> ;
    rdfs:subClassOf d3f:REC0008 ;
    skos:altLabel "REC-0008.04" ;
    skos:definition "Adversaries may gather information about the victim's business relationships that can be used during targeting. Information about an mission’s business relationships may include a variety of details, including second or third-party organizations/domains (ex: managed service providers, contractors/sub-contractors, etc.) that have connected (and potentially elevated) network access or sensitive information. This information may also reveal supply chains and shipment paths for the victim’s hardware and software resources." ;
    skos:exactMatch d3f:REC-0008.04,
        mitre-attack:REC-0008.04 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0009 a owl:Class ;
    rdfs:label "REC_0009" ;
    d3f:attack-id "REC-0009" ;
    dcterms:title "Gather Mission Information" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0009/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0009" ;
    skos:definition """Threat actors may initially seek to gain an understanding of a target mission by gathering information commonly captured in a Concept of Operations (or similar) document and related artifacts. Information of interest includes, but is not limited to:
	- the needs, goals, and objectives of the system
	- system overview and key elements/instruments
	- modes of operations (including operational constraints)
	- proposed capabilities and the underlying science/technology used to provide capabilities (i.e., scientific papers, research studies, etc.)
	- physical and support environments""" ;
    skos:exactMatch d3f:REC-0009,
        mitre-attack:REC-0009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RealTimeOperatingSystem a owl:Class ;
    rdfs:label "Real_timeOperatingSystem" ;
    d3f:synonym "RTOS" ;
    dcterms:title "Real-time operating system" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Real-time_operating_system> ;
    rdfs:subClassOf d3f:OperatingSystem ;
    skos:altLabel "Real-timeOperatingSystem" ;
    skos:definition "A real-time operating system (RTOS) is an operating system (OS) for real-time computing applications that processes data and events that have critically defined time constraints." ;
    skos:exactMatch d3f:Real-timeOperatingSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RelationalBasedTransferLearning a owl:Class ;
    rdfs:label "Relational_basedTransferLearning" ;
    d3f:d3fend-id "D3A-RBTL" ;
    d3f:kb-article "## References V7 Labs. (n.d.). Transfer Learning Guide. [Link](https://www.v7labs.com/blog/transfer-learning-guide#:~:text=Relational%2Dbased%20transfer%20learning%20approaches,domain%20to%20the%20target%20domain)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Relational-based Transfer Learning" ;
    rdfs:subClassOf d3f:HomogenousTransferLearning ;
    skos:altLabel "Relational-basedTransferLearning" ;
    skos:definition "Relational-based Transfer Learning is a subfield of machine learning where knowledge and patterns learned from one domain, characterized by relational and structured data, are transferred to enhance the learning of another related domain. This approach leverages shared concepts, relations, and structures across domains, taking advantage of the rich semantic knowledge within relational data to improve learning performance in the target task." ;
    skos:exactMatch d3f:Relational-basedTransferLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SecondStageBootLoader a owl:Class ;
    rdfs:label "Second_stageBootLoader" ;
    dcterms:title "Second-stage Boot Loader" ;
    rdfs:subClassOf d3f:BootLoader ;
    skos:altLabel "Second-stageBootLoader" ;
    skos:definition "An optional, often feature rich, second stage set of routines run in order to load the operating system." ;
    skos:exactMatch d3f:Second-stageBootLoader ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SelfOrganizingMap a owl:Class ;
    rdfs:label "Self_organizingMap" ;
    d3f:d3fend-id "D3A-SOM" ;
    d3f:kb-article "## References GeeksforGeeks. (n.d.). ANN - Self Organizing Neural Network (SONN). [Link](https://www.geeksforgeeks.org/ann-self-organizing-neural-network-sonn/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Self-organizing Map" ;
    rdfs:subClassOf d3f:ANNBasedClustering ;
    skos:altLabel "Self-organizingMap" ;
    skos:definition "A Self-Organizing Map (SOM) is a unsupervised learning model in Artificial Neural Network where the feature maps are the generated two-dimensional discretized form of an input space during the model training (based on competitive learning)" ;
    skos:exactMatch d3f:Self-organizingMap ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedBoosting a owl:Class ;
    rdfs:label "Semi_supervisedBoosting" ;
    d3f:d3fend-id "D3A-SSB" ;
    d3f:kb-article "## References Jashish Shrestha. (n.d.). Beginner's Guide to Semi-Supervised Learning. [Link](http://jashish.com.np/blog/posts/beginners-guide-to-semi-supervised-learning/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Boosting" ;
    rdfs:subClassOf d3f:SemiSupervisedWrapperMethod ;
    skos:altLabel "Semi-supervisedBoosting" ;
    skos:definition "Boosting methods can be readily extended to the semi-supervised setting, by introducing pseudo-labeled data after each learning step; which gives rise to the idea of semi-supervised boosting methods. The pseudo-labeling approach of self- training and co-training can be easily extended to boosting methods. Several boosting methods such as SSMBoost, ASSEMBLE, SemiBoost, RegBoost, etc can be found which can be applied for utilizing unlabeled datasets for supervised classifiers." ;
    skos:exactMatch d3f:Semi-supervisedBoosting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedClusterThenLabel a owl:Class ;
    rdfs:label "Semi_supervisedCluster_then_label" ;
    d3f:d3fend-id "D3A-SSCTL" ;
    d3f:kb-article "## References Jashish Shrestha. (n.d.). Beginner's Guide to Semi-Supervised Learning. [Link](http://jashish.com.np/blog/posts/beginners-guide-to-semi-supervised-learning/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Cluster-then-label" ;
    rdfs:subClassOf d3f:UnsupervisedPreprocessing ;
    skos:altLabel "Semi-supervisedCluster-then-label" ;
    skos:definition "Pre-training methods are aimed to guide the parameters of a network towards interesting regions in model space using unlabeled data, before fine-tuning the parameters with the labeled data." ;
    skos:exactMatch d3f:Semi-supervisedCluster-then-label ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedCoTraining a owl:Class ;
    rdfs:label "Semi_supervisedCo_training" ;
    d3f:d3fend-id "D3A-SSCT" ;
    d3f:kb-article "## References Jashish Shrestha. (n.d.). Beginner's Guide to Semi-Supervised Learning. [Link](http://jashish.com.np/blog/posts/beginners-guide-to-semi-supervised-learning/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Co-training" ;
    rdfs:subClassOf d3f:SemiSupervisedWrapperMethod ;
    skos:altLabel "Semi-supervisedCo-training" ;
    skos:definition "Multi-view co-training involves training the classifiers in completely different views of training data. On the other hand, single-view co-training methods are generally applied as ensemble methods." ;
    skos:exactMatch d3f:Semi-supervisedCo-training ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedFeatureExtraction a owl:Class ;
    rdfs:label "Semi_supervisedFeatureExtraction" ;
    d3f:d3fend-id "D3A-SSFE" ;
    d3f:kb-article "## References Jashish Shrestha. (n.d.). Beginner's Guide to Semi-Supervised Learning. [Link](http://jashish.com.np/blog/posts/beginners-guide-to-semi-supervised-learning/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Feature Extraction" ;
    rdfs:subClassOf d3f:UnsupervisedPreprocessing ;
    skos:altLabel "Semi-supervisedFeatureExtraction" ;
    skos:definition "Feature extraction refers to reducing the number of dimensions in a data point so that it is computationally feasible and effective to learn a model." ;
    skos:exactMatch d3f:Semi-supervisedFeatureExtraction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedGenerativeModelLearning a owl:Class ;
    rdfs:label "Semi_supervisedGenerativeModelLearning" ;
    d3f:d3fend-id "D3A-SSGML" ;
    d3f:kb-article "## References Weak supervision. Wikipedia. [Link](https://en.wikipedia.org/wiki/Weak_supervision#Generative_models)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Generative Model Learning" ;
    rdfs:subClassOf d3f:IntrinsicallySemiSupervisedLearning ;
    skos:altLabel "Semi-supervisedGenerativeModelLearning" ;
    skos:definition "A Semi Supervised Machine Learning model which assume that the distributions take some particular form p(x|y,theta) parameterized by the vector. If these assumptions are incorrect, the unlabeled data may actually decrease the accuracy of the solution relative to what would have been obtained from labeled data alone. However, if the assumptions are correct, then the unlabeled data necessarily improves performance." ;
    skos:exactMatch d3f:Semi-supervisedGenerativeModelLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedInductiveLearning a owl:Class ;
    rdfs:label "Semi_supervisedInductiveLearning" ;
    d3f:d3fend-id "D3A-SSIL" ;
    d3f:kb-article "## References Semi-Supervised Learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Semi-Supervised_Learning#Semi-supervised_learning). Zhou, D., & Li, M. (2005). Semi-supervised learning by higher order regularization. In Proceedings of the 43rd Annual Meeting of the Association for Computati" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Inductive Learning" ;
    rdfs:subClassOf d3f:SemiSupervisedLearning ;
    skos:altLabel "Semi-supervisedInductiveLearning" ;
    skos:definition "The goal of inductive learning is to infer the correct mapping from X to Y." ;
    skos:exactMatch d3f:Semi-supervisedInductiveLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedManifoldLearning a owl:Class ;
    rdfs:label "Semi_supervisedManifoldLearning" ;
    d3f:d3fend-id "D3A-SSML" ;
    d3f:kb-article "## References Weak supervision. Wikipedia. [Link](https://en.wikipedia.org/wiki/Weak_supervision#Generative_models)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Manifold Learning" ;
    rdfs:subClassOf d3f:IntrinsicallySemiSupervisedLearning ;
    skos:altLabel "Semi-supervisedManifoldLearning" ;
    skos:definition "A version of Semi-Supervised Learning that applies the Manifold assumption that the data like approximately on a manifold of much lower dimension than the input space." ;
    skos:exactMatch d3f:Semi-supervisedManifoldLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedPreTraining a owl:Class ;
    rdfs:label "Semi_supervisedPre_training" ;
    d3f:d3fend-id "D3A-SSPT" ;
    d3f:kb-article "## References Jashish Shrestha. (n.d.). Beginner's Guide to Semi-Supervised Learning. [Link](http://jashish.com.np/blog/posts/beginners-guide-to-semi-supervised-learning/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Pre-training" ;
    rdfs:subClassOf d3f:UnsupervisedPreprocessing ;
    skos:altLabel "Semi-supervisedPre-training" ;
    skos:definition "Pre-training methods are aimed to guide the parameters of a network towards interesting regions in model space using unlabeled data, before fine-tuning the parameters with the labeled data" ;
    skos:exactMatch d3f:Semi-supervisedPre-training ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SemiSupervisedSelfTraining a owl:Class ;
    rdfs:label "Semi_supervisedSelf_training" ;
    d3f:d3fend-id "D3A-SSST" ;
    d3f:kb-article "## References AltexSoft. (n.d.). Semi-Supervised Learning: A Technical Guide with Python Examples. [Link](https://www.altexsoft.com/blog/semi-supervised-learning/#:~:text=One%20of%20the%20simplest%20examples,of%20labeled%20and%20unlabeled%20data.)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Semi-supervised Self-training" ;
    rdfs:subClassOf d3f:SemiSupervisedWrapperMethod ;
    skos:altLabel "Semi-supervisedSelf-training" ;
    skos:definition "Self-training is the procedure in which a supervised method for classification or regression is modified it to work in a semi-supervised manner, taking advantage of labeled and unlabeled data" ;
    skos:exactMatch d3f:Semi-supervisedSelf-training ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioComputer a owl:Class ;
    rdfs:label "Software_definedRadioComputer" ;
    d3f:synonym "Standalone SDR" ;
    dcterms:title "Software-Defined Radio Computer" ;
    rdfs:seeAlso <https://satsearch.co/products/alenspace-totem-software-defined-radio-sdr> ;
    rdfs:subClassOf d3f:OTEmbeddedComputer ;
    skos:altLabel "Software-definedRadioComputer" ;
    skos:definition "An embedded computer that includes a self-contained radio system, onboard compute (e.g., SoC/CPU/DSP/FPGA), and software/firmware sufficient to run waveforms and manage RF functions without requiring a continuously attached host PC. It typically exposes control and data via network or other external interfaces and may run an embedded OS." ;
    skos:exactMatch d3f:Software-definedRadioComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioConfiguration a owl:Class ;
    rdfs:label "Software_definedRadioConfiguration" ;
    dcterms:title "Software-defined Radio Configuration" ;
    rdfs:seeAlso <https://www.analog.com/media/en/training-seminars/design-handbooks/Software-Defined-Radio-for-Engineers-2018/SDR4Engineers.pdf> ;
    rdfs:subClassOf d3f:HardwareDeviceConfiguration ;
    skos:altLabel "Software-definedRadioConfiguration" ;
    skos:definition "The physical radio hardware parameters used by a software-defined radio (SDR), including center frequency, bandwidth, gain settings, antenna selection, ADC/DAC sample rates, filter characteristics, power output, and others." ;
    skos:exactMatch d3f:Software-definedRadioConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioDevice a owl:Class ;
    rdfs:label "Software_definedRadioDevice" ;
    d3f:synonym "Peripheral SDR" ;
    dcterms:title "Software-Defined Radio Device" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Software-defined_radio#RTL-SDR> ;
    rdfs:subClassOf d3f:SoftwareDefinedRadio ;
    skos:altLabel "Software-definedRadioDevice" ;
    skos:definition "A hardware device that functions primarily as an RF front end plus data conversion and transport, relying on an external host computer to run most waveform/DSP processing and to control operation. It is commonly connected via USB, PCIe, or similar links and behaves like a high-speed radio peripheral." ;
    skos:exactMatch d3f:Software-definedRadioDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioRFStateChangeEvent a owl:Class ;
    rdfs:label "Software_definedRadioRFStateChangeEvent" ;
    dcterms:title "Software-defined Radio RF State Change Event" ;
    rdfs:subClassOf d3f:SoftwareDefinedRadioEvent ;
    skos:altLabel "Software-definedRadioRFStateChangeEvent" ;
    skos:definition "A software-defined radio (SDR) event where one or more radio-frequency (RF) parameters have been changed in a way that affects reception or emission (e.g., center frequency retune, gain/attenuation update, bandwidth/filter selection, antenna/port switch, TX enable/disable, etc)." ;
    skos:exactMatch d3f:Software-definedRadioRFStateChangeEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioWaveformApplication a owl:Class ;
    rdfs:label "Software_definedRadioWaveformApplication" ;
    d3f:synonym "SDR waveform" ;
    dcterms:title "Software-defined Radio Waveform Application" ;
    rdfs:seeAlso <https://ieeexplore.ieee.org/document/5768314>,
        <https://media.defense.gov/2020/Feb/13/2002249005/-1/-1/1/SCA_4.1_SCASPECIFICATION.PDF> ;
    rdfs:subClassOf d3f:DigitalSignalProcessingApplication ;
    skos:altLabel "Software-definedRadioWaveformApplication" ;
    skos:definition "A software implementation of a radio waveform that executes on the programmable processing elements of a software-defined radio and realizes the signal processing functions necessary to transmit and receive a specific radio signal. On peripheral SDRs, this can take the form of a compiled flowgraph that runs on the host PC, whereas in stand-alone SDRs it may be an FPGA bitstream or waveform package that executes on the SDR's processing elements." ;
    skos:exactMatch d3f:Software-definedRadioWaveformApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioWaveformConfigurationEvent a owl:Class ;
    rdfs:label "Software_definedRadioWaveformConfigurationEvent" ;
    dcterms:title "Software-defined Radio Waveform Application Configuration Event" ;
    rdfs:subClassOf d3f:SoftwareDefinedRadioEvent ;
    skos:altLabel "Software-definedRadioWaveformConfigurationEvent" ;
    skos:definition "An SDR event where the waveform application's operational parameters have been applied and validated (e.g., sample rate, bandwidth, channel selection, framing/modulation options), placing the waveform in a state ready to run." ;
    skos:exactMatch d3f:Software-definedRadioWaveformConfigurationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareDefinedRadioWaveformLoadEvent a owl:Class ;
    rdfs:label "Software_definedRadioWaveformLoadEvent" ;
    dcterms:title "Software-defined Radio Waveform Application Load Event" ;
    rdfs:subClassOf d3f:SoftwareDefinedRadioEvent ;
    skos:altLabel "Software-definedRadioWaveformLoadEvent" ;
    skos:definition "An SDR event where a waveform application (software/firmware/FPGA image and associated descriptors) has been installed or selected on the SDR and is available to be configured." ;
    skos:exactMatch d3f:Software-definedRadioWaveformLoadEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SymmetricFeatureBasedTransferLearning a owl:Class ;
    rdfs:label "SymmetricFeature_basedTransferLearning" ;
    d3f:d3fend-id "D3A-SFTL" ;
    d3f:kb-article "## References Day, O., & Khoshgoftaar, T.M. (2017). A survey on heterogeneous transfer learning. *Journal of Big Data, 4*(1), 29. [Link](https://doi.org/10.1186/s40537-017-0089-0)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Symmetric Feature-based Transfer Learning" ;
    rdfs:subClassOf d3f:HomogenousTransferLearning ;
    skos:altLabel "SymmetricFeature-basedTransferLearning" ;
    skos:definition "Homogeneous symmetric transformation takes both the source feature space Xs and target feature space Xt and learns feature transformations as to project each onto a common subspace Xc for adaptation purposes. This derived subspace becomes a domain-invariant feature subspace to associate cross-domain data, and in effect, reduces marginal distribution differences." ;
    skos:exactMatch d3f:SymmetricFeature-basedTransferLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1001001 a owl:Class ;
    rdfs:label "T1001_001" ;
    d3f:attack-id "T1001.001" ;
    dcterms:title "Junk Data" ;
    rdfs:subClassOf d3f:T1001 ;
    skos:altLabel "T1001.001" ;
    skos:definition "Adversaries may add junk data to protocols used for command and control to make detection more difficult.(Citation: FireEye SUNBURST Backdoor December 2020) By adding random or meaningless data to the protocols used for command and control, adversaries can prevent trivial methods for decoding, deciphering, or otherwise analyzing the traffic. Examples may include appending/prepending data with junk characters or writing junk characters between significant characters." ;
    skos:exactMatch d3f:T1001.001,
        mitre-attack:T1001.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1001002 a owl:Class ;
    rdfs:label "T1001_002" ;
    d3f:attack-id "T1001.002" ;
    dcterms:title "Steganography" ;
    rdfs:subClassOf d3f:T1001 ;
    skos:altLabel "T1001.002" ;
    skos:definition "Adversaries may use steganographic techniques to hide command and control traffic to make detection efforts more difficult. Steganographic techniques can be used to hide data in digital messages that are transferred between systems. This hidden information can be used for command and control of compromised systems. In some cases, the passing of files embedded using steganography, such as image or document files, can be used for command and control." ;
    skos:exactMatch d3f:T1001.002,
        mitre-attack:T1001.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1001003 a owl:Class ;
    rdfs:label "T1001_003" ;
    d3f:attack-id "T1001.003" ;
    dcterms:title "Protocol or Service Impersonation" ;
    rdfs:subClassOf d3f:T1001 ;
    skos:altLabel "T1001.003" ;
    skos:definition "Adversaries may impersonate legitimate protocols or web service traffic to disguise command and control activity and thwart analysis efforts. By impersonating legitimate protocols or web services, adversaries can make their command and control traffic blend in with legitimate network traffic." ;
    skos:exactMatch d3f:T1001.003,
        mitre-attack:T1001.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003001 a owl:Class ;
    rdfs:label "T1003_001" ;
    d3f:attack-id "T1003.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "LSASS Memory" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.001" ;
    skos:definition "Adversaries may attempt to access credential material stored in the process memory of the Local Security Authority Subsystem Service (LSASS). After a user logs on, the system generates and stores a variety of credential materials in LSASS process memory. These credential materials can be harvested by an administrative user or SYSTEM and used to conduct [Lateral Movement](https://attack.mitre.org/tactics/TA0008) using [Use Alternate Authentication Material](https://attack.mitre.org/techniques/T1550)." ;
    skos:exactMatch d3f:T1003.001,
        mitre-attack:T1003.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003002 a owl:Class ;
    rdfs:label "T1003_002" ;
    d3f:attack-id "T1003.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Security Account Manager" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.002" ;
    skos:definition "Adversaries may attempt to extract credential material from the Security Account Manager (SAM) database either through in-memory techniques or through the Windows Registry where the SAM database is stored. The SAM is a database file that contains local accounts for the host, typically those found with the <code>net user</code> command. Enumerating the SAM database requires SYSTEM level access." ;
    skos:exactMatch d3f:T1003.002,
        mitre-attack:T1003.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003003 a owl:Class ;
    rdfs:label "T1003_003" ;
    d3f:attack-id "T1003.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "NTDS" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.003" ;
    skos:definition "Adversaries may attempt to access or create a copy of the Active Directory domain database in order to steal credential information, as well as obtain other information about domain members such as devices, users, and access rights. By default, the NTDS file (NTDS.dit) is located in <code>%SystemRoot%\\NTDS\\Ntds.dit</code> of a domain controller.(Citation: Wikipedia Active Directory)" ;
    skos:exactMatch d3f:T1003.003,
        mitre-attack:T1003.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003004 a owl:Class ;
    rdfs:label "T1003_004" ;
    d3f:attack-id "T1003.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "LSA Secrets" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.004" ;
    skos:definition "Adversaries with SYSTEM access to a host may attempt to access Local Security Authority (LSA) secrets, which can contain a variety of different credential materials, such as credentials for service accounts.(Citation: Passcape LSA Secrets)(Citation: Microsoft AD Admin Tier Model)(Citation: Tilbury Windows Credentials) LSA secrets are stored in the registry at <code>HKEY_LOCAL_MACHINE\\SECURITY\\Policy\\Secrets</code>. LSA secrets can also be dumped from memory.(Citation: ired Dumping LSA Secrets)" ;
    skos:exactMatch d3f:T1003.004,
        mitre-attack:T1003.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003005 a owl:Class ;
    rdfs:label "T1003_005" ;
    d3f:attack-id "T1003.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cached Domain Credentials" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.005" ;
    skos:definition "Adversaries may attempt to access cached domain credentials used to allow authentication to occur in the event a domain controller is unavailable.(Citation: Microsoft - Cached Creds)" ;
    skos:exactMatch d3f:T1003.005,
        mitre-attack:T1003.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003006 a owl:Class ;
    rdfs:label "T1003_006" ;
    d3f:attack-id "T1003.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DCSync" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.006" ;
    skos:definition "Adversaries may attempt to access credentials and other sensitive information by abusing a Windows Domain Controller's application programming interface (API)(Citation: Microsoft DRSR Dec 2017) (Citation: Microsoft GetNCCChanges) (Citation: Samba DRSUAPI) (Citation: Wine API samlib.dll) to simulate the replication process from a remote domain controller using a technique called DCSync." ;
    skos:exactMatch d3f:T1003.006,
        mitre-attack:T1003.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003007 a owl:Class ;
    rdfs:label "T1003_007" ;
    d3f:attack-id "T1003.007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Proc Filesystem" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.007" ;
    skos:definition "Adversaries may gather credentials from the proc filesystem or `/proc`. The proc filesystem is a pseudo-filesystem used as an interface to kernel data structures for Linux based systems managing virtual memory. For each process, the `/proc/<PID>/maps` file shows how memory is mapped within the process’s virtual address space. And `/proc/<PID>/mem`, exposed for debugging purposes, provides access to the process’s virtual address space.(Citation: Picus Labs Proc cump 2022)(Citation: baeldung Linux proc map 2022)" ;
    skos:exactMatch d3f:T1003.007,
        mitre-attack:T1003.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1003008 a owl:Class ;
    rdfs:label "T1003_008" ;
    d3f:attack-id "T1003.008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "/etc/passwd and /etc/shadow" ;
    rdfs:subClassOf d3f:T1003 ;
    skos:altLabel "T1003.008" ;
    skos:definition "Adversaries may attempt to dump the contents of <code>/etc/passwd</code> and <code>/etc/shadow</code> to enable offline password cracking. Most modern Linux operating systems use a combination of <code>/etc/passwd</code> and <code>/etc/shadow</code> to store user account information including password hashes in <code>/etc/shadow</code>. By default, <code>/etc/shadow</code> is only readable by the root user.(Citation: Linux Password and Shadow File Formats)" ;
    skos:exactMatch d3f:T1003.008,
        mitre-attack:T1003.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1011001 a owl:Class ;
    rdfs:label "T1011_001" ;
    d3f:attack-id "T1011.001" ;
    dcterms:title "Exfiltration Over Bluetooth" ;
    rdfs:subClassOf d3f:T1011 ;
    skos:altLabel "T1011.001" ;
    skos:definition "Adversaries may attempt to exfiltrate data over Bluetooth rather than the command and control channel. If the command and control network is a wired Internet connection, an adversary may opt to exfiltrate data using a Bluetooth communication channel." ;
    skos:exactMatch d3f:T1011.001,
        mitre-attack:T1011.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1016001 a owl:Class ;
    rdfs:label "T1016_001" ;
    d3f:attack-id "T1016.001" ;
    dcterms:title "Internet Connection Discovery" ;
    rdfs:subClassOf d3f:T1016 ;
    skos:altLabel "T1016.001" ;
    skos:definition "Adversaries may check for Internet connectivity on compromised systems. This may be performed during automated discovery and can be accomplished in numerous ways such as using [Ping](https://attack.mitre.org/software/S0097), <code>tracert</code>, and GET requests to websites." ;
    skos:exactMatch d3f:T1016.001,
        mitre-attack:T1016.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1016002 a owl:Class ;
    rdfs:label "T1016_002" ;
    d3f:attack-id "T1016.002" ;
    dcterms:title "Wi-Fi Discovery" ;
    rdfs:subClassOf d3f:T1016 ;
    skos:altLabel "T1016.002" ;
    skos:definition "Adversaries may search for information about Wi-Fi networks, such as network names and passwords, on compromised systems. Adversaries may use Wi-Fi information as part of [Account Discovery](https://attack.mitre.org/techniques/T1087), [Remote System Discovery](https://attack.mitre.org/techniques/T1018), and other discovery or [Credential Access](https://attack.mitre.org/tactics/TA0006) activity to support both ongoing and future campaigns." ;
    skos:exactMatch d3f:T1016.002,
        mitre-attack:T1016.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1020001 a owl:Class ;
    rdfs:label "T1020_001" ;
    d3f:attack-id "T1020.001" ;
    dcterms:title "Traffic Duplication" ;
    rdfs:subClassOf d3f:T1020 ;
    skos:altLabel "T1020.001" ;
    skos:definition "Adversaries may leverage traffic mirroring in order to automate data exfiltration over compromised infrastructure. Traffic mirroring is a native feature for some devices, often used for network analysis. For example, devices may be configured to forward network traffic to one or more destinations for analysis by a network analyzer or other monitoring device. (Citation: Cisco Traffic Mirroring)(Citation: Juniper Traffic Mirroring)" ;
    skos:exactMatch d3f:T1020.001,
        mitre-attack:T1020.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021001 a owl:Class ;
    rdfs:label "T1021_001" ;
    d3f:attack-id "T1021.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Desktop Protocol" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.001" ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to log into a computer using the Remote Desktop Protocol (RDP). The adversary may then perform actions as the logged-on user." ;
    skos:exactMatch d3f:T1021.001,
        mitre-attack:T1021.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021002 a owl:Class ;
    rdfs:label "T1021_002" ;
    d3f:attack-id "T1021.002" ;
    dcterms:title "SMB/Windows Admin Shares" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.002" ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to interact with a remote network share using Server Message Block (SMB). The adversary may then perform actions as the logged-on user." ;
    skos:exactMatch d3f:T1021.002,
        mitre-attack:T1021.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021003 a owl:Class ;
    rdfs:label "T1021_003" ;
    d3f:attack-id "T1021.003" ;
    dcterms:title "Distributed Component Object Model" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.003" ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to interact with remote machines by taking advantage of Distributed Component Object Model (DCOM). The adversary may then perform actions as the logged-on user." ;
    skos:exactMatch d3f:T1021.003,
        mitre-attack:T1021.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021004 a owl:Class ;
    rdfs:label "T1021_004" ;
    d3f:attack-id "T1021.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "SSH" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.004" ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to log into remote machines using Secure Shell (SSH). The adversary may then perform actions as the logged-on user." ;
    skos:exactMatch d3f:T1021.004,
        mitre-attack:T1021.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021005 a owl:Class ;
    rdfs:label "T1021_005" ;
    d3f:attack-id "T1021.005" ;
    dcterms:title "VNC" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.005" ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to remotely control machines using Virtual Network Computing (VNC).  VNC is a platform-independent desktop sharing system that uses the RFB (“remote framebuffer”) protocol to enable users to remotely control another computer’s display by relaying the screen, mouse, and keyboard inputs over the network.(Citation: The Remote Framebuffer Protocol)" ;
    skos:exactMatch d3f:T1021.005,
        mitre-attack:T1021.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021006 a owl:Class ;
    rdfs:label "T1021_006" ;
    d3f:attack-id "T1021.006" ;
    dcterms:title "Windows Remote Management" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.006" ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to interact with remote systems using Windows Remote Management (WinRM). The adversary may then perform actions as the logged-on user." ;
    skos:exactMatch d3f:T1021.006,
        mitre-attack:T1021.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021007 a owl:Class ;
    rdfs:label "T1021_007" ;
    d3f:attack-id "T1021.007" ;
    dcterms:title "Cloud Services" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.007" ;
    skos:definition "Adversaries may log into accessible cloud services within a compromised environment using [Valid Accounts](https://attack.mitre.org/techniques/T1078) that are synchronized with or federated to on-premises user identities. The adversary may then perform management actions or access cloud-hosted resources as the logged-on user." ;
    skos:exactMatch d3f:T1021.007,
        mitre-attack:T1021.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021008 a owl:Class ;
    rdfs:label "T1021_008" ;
    d3f:attack-id "T1021.008" ;
    dcterms:title "Direct Cloud VM Connections" ;
    rdfs:subClassOf d3f:T1021 ;
    skos:altLabel "T1021.008" ;
    skos:definition "Adversaries may leverage [Valid Accounts](https://attack.mitre.org/techniques/T1078) to log directly into accessible cloud hosted compute infrastructure through cloud native methods. Many cloud providers offer interactive connections to virtual infrastructure that can be accessed through the [Cloud API](https://attack.mitre.org/techniques/T1059/009), such as Azure Serial Console(Citation: Azure Serial Console), AWS EC2 Instance Connect(Citation: EC2 Instance Connect)(Citation: lucr-3: Getting SaaS-y in the cloud), and AWS System Manager.(Citation: AWS System Manager)." ;
    skos:exactMatch d3f:T1021.008,
        mitre-attack:T1021.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027001 a owl:Class ;
    rdfs:label "T1027_001" ;
    d3f:attack-id "T1027.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Binary Padding" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.001" ;
    skos:definition "Adversaries may use binary padding to add junk data and change the on-disk representation of malware. This can be done without affecting the functionality or behavior of a binary, but can increase the size of the binary beyond what some security tools are capable of handling due to file size limitations." ;
    skos:exactMatch d3f:T1027.001,
        mitre-attack:T1027.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027002 a owl:Class ;
    rdfs:label "T1027_002" ;
    d3f:attack-id "T1027.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Packing" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.002" ;
    skos:definition "Adversaries may perform software packing or virtual machine software protection to conceal their code. Software packing is a method of compressing or encrypting an executable. Packing an executable changes the file signature in an attempt to avoid signature-based detection. Most decompression techniques decompress the executable code in memory. Virtual machine software protection translates an executable's original code into a special format that only a special virtual machine can run. A virtual machine is then called to run this code.(Citation: ESET FinFisher Jan 2018)" ;
    skos:exactMatch d3f:T1027.002,
        mitre-attack:T1027.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027003 a owl:Class ;
    rdfs:label "T1027_003" ;
    d3f:attack-id "T1027.003" ;
    dcterms:title "Steganography" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.003" ;
    skos:definition "Adversaries may use steganography techniques in order to prevent the detection of hidden information. Steganographic techniques can be used to hide data in digital media such as images, audio tracks, video clips, or text files." ;
    skos:exactMatch d3f:T1027.003,
        mitre-attack:T1027.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027004 a owl:Class ;
    rdfs:label "T1027_004" ;
    d3f:attack-id "T1027.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compile After Delivery" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.004" ;
    skos:definition "Adversaries may attempt to make payloads difficult to discover and analyze by delivering files to victims as uncompiled code. Text-based source code files may subvert analysis and scrutiny from protections targeting executables/binaries. These payloads will need to be compiled before execution; typically via native utilities such as csc.exe or GCC/MinGW.(Citation: ClearSky MuddyWater Nov 2018)" ;
    skos:exactMatch d3f:T1027.004,
        mitre-attack:T1027.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027005 a owl:Class ;
    rdfs:label "T1027_005" ;
    d3f:attack-id "T1027.005" ;
    dcterms:title "Indicator Removal from Tools" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.005" ;
    skos:definition "Adversaries may remove indicators from tools if they believe their malicious tool was detected, quarantined, or otherwise curtailed. They can modify the tool by removing the indicator and using the updated version that is no longer detected by the target's defensive systems or subsequent targets that may use similar systems." ;
    skos:exactMatch d3f:T1027.005,
        mitre-attack:T1027.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027006 a owl:Class ;
    rdfs:label "T1027_006" ;
    d3f:attack-id "T1027.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "HTML Smuggling" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.006" ;
    skos:definition "Adversaries may smuggle data and files past content filters by hiding malicious payloads inside of seemingly benign HTML files. HTML documents can store large binary objects known as JavaScript Blobs (immutable data that represents raw bytes) that can later be constructed into file-like objects. Data may also be stored in Data URLs, which enable embedding media type or MIME files inline of HTML documents. HTML5 also introduced a download attribute that may be used to initiate file downloads.(Citation: HTML Smuggling Menlo Security 2020)(Citation: Outlflank HTML Smuggling 2018)" ;
    skos:exactMatch d3f:T1027.006,
        mitre-attack:T1027.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027007 a owl:Class ;
    rdfs:label "T1027_007" ;
    d3f:attack-id "T1027.007" ;
    dcterms:title "Dynamic API Resolution" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.007" ;
    skos:definition "Adversaries may obfuscate then dynamically resolve API functions called by their malware in order to conceal malicious functionalities and impair defensive analysis. Malware commonly uses various [Native API](https://attack.mitre.org/techniques/T1106) functions provided by the OS to perform various tasks such as those involving processes, files, and other system artifacts." ;
    skos:exactMatch d3f:T1027.007,
        mitre-attack:T1027.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027008 a owl:Class ;
    rdfs:label "T1027_008" ;
    d3f:attack-id "T1027.008" ;
    dcterms:title "Stripped Payloads" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.008" ;
    skos:definition "Adversaries may attempt to make a payload difficult to analyze by removing symbols, strings, and other human readable information. Scripts and executables may contain variables names and other strings that help developers document code functionality. Symbols are often created by an operating system’s `linker` when executable payloads are compiled. Reverse engineers use these symbols and strings to analyze code and to identify functionality in payloads.(Citation: Mandiant golang stripped binaries explanation)(Citation: intezer stripped binaries elf files 2018)" ;
    skos:exactMatch d3f:T1027.008,
        mitre-attack:T1027.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027009 a owl:Class ;
    rdfs:label "T1027_009" ;
    d3f:attack-id "T1027.009" ;
    dcterms:title "Embedded Payloads" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.009" ;
    skos:definition "Adversaries may embed payloads within other files to conceal malicious content from defenses. Otherwise seemingly benign files (such as scripts and executables) may be abused to carry and obfuscate malicious payloads and content. In some cases, embedded payloads may also enable adversaries to [Subvert Trust Controls](https://attack.mitre.org/techniques/T1553) by not impacting execution controls such as digital signatures and notarization tickets.(Citation: Sentinel Labs)" ;
    skos:exactMatch d3f:T1027.009,
        mitre-attack:T1027.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027010 a owl:Class ;
    rdfs:label "T1027_010" ;
    d3f:attack-id "T1027.010" ;
    dcterms:title "Command Obfuscation" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.010" ;
    skos:definition "Adversaries may obfuscate content during command execution to impede detection. Command-line obfuscation is a method of making strings and patterns within commands and scripts more difficult to signature and analyze. This type of obfuscation can be included within commands executed by delivered payloads (e.g., [Phishing](https://attack.mitre.org/techniques/T1566) and [Drive-by Compromise](https://attack.mitre.org/techniques/T1189)) or interactively via [Command and Scripting Interpreter](https://attack.mitre.org/techniques/T1059).(Citation: Akamai JS)(Citation: Malware Monday VBE)" ;
    skos:exactMatch d3f:T1027.010,
        mitre-attack:T1027.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027011 a owl:Class ;
    rdfs:label "T1027_011" ;
    d3f:attack-id "T1027.011" ;
    dcterms:title "Fileless Storage" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.011" ;
    skos:definition "Adversaries may store data in \"fileless\" formats to conceal malicious activity from defenses. Fileless storage can be broadly defined as any format other than a file. Common examples of non-volatile fileless storage include the Windows Registry, event logs, or WMI repository.(Citation: Microsoft Fileless)(Citation: SecureList Fileless)" ;
    skos:exactMatch d3f:T1027.011,
        mitre-attack:T1027.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027012 a owl:Class ;
    rdfs:label "T1027_012" ;
    d3f:attack-id "T1027.012" ;
    dcterms:title "LNK Icon Smuggling" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.012" ;
    skos:definition "Adversaries may smuggle commands to download malicious payloads past content filters by hiding them within otherwise seemingly benign windows shortcut files. Windows shortcut files (.LNK) include many metadata fields, including an icon location field (also known as the `IconEnvironmentDataBlock`) designed to specify the path to an icon file that is to be displayed for the LNK file within a host directory." ;
    skos:exactMatch d3f:T1027.012,
        mitre-attack:T1027.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027013 a owl:Class ;
    rdfs:label "T1027_013" ;
    d3f:attack-id "T1027.013" ;
    dcterms:title "Encrypted/Encoded File" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.013" ;
    skos:definition "Adversaries may encrypt or encode files to obfuscate strings, bytes, and other specific patterns to impede detection. Encrypting and/or encoding file content aims to conceal malicious artifacts within a file used in an intrusion. Many other techniques, such as [Software Packing](https://attack.mitre.org/techniques/T1027/002), [Steganography](https://attack.mitre.org/techniques/T1027/003), and [Embedded Payloads](https://attack.mitre.org/techniques/T1027/009), share this same broad objective. Encrypting and/or encoding files could lead to a lapse in detection of static signatures, only for this malicious content to be revealed (i.e., [Deobfuscate/Decode Files or Information](https://attack.mitre.org/techniques/T1140)) at the time of execution/use." ;
    skos:exactMatch d3f:T1027.013,
        mitre-attack:T1027.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027014 a owl:Class ;
    rdfs:label "T1027_014" ;
    d3f:attack-id "T1027.014" ;
    dcterms:title "Polymorphic Code" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.014" ;
    skos:definition "Adversaries may utilize polymorphic code (also known as metamorphic or mutating code) to evade detection. Polymorphic code is a type of software capable of changing its runtime footprint during code execution.(Citation: polymorphic-blackberry) With each execution of the software, the code is mutated into a different version of itself that achieves the same purpose or objective as the original. This functionality enables the malware to evade traditional signature-based defenses, such as antivirus and antimalware tools.(Citation: polymorphic-sentinelone)" ;
    skos:exactMatch d3f:T1027.014,
        mitre-attack:T1027.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027015 a owl:Class ;
    rdfs:label "T1027_015" ;
    d3f:attack-id "T1027.015" ;
    dcterms:title "Compression" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.015" ;
    skos:definition "Adversaries may use compression to obfuscate their payloads or files. Compressed file formats such as ZIP, gzip, 7z, and RAR can compress and archive multiple files together to make it easier and faster to transfer files. In addition to compressing files, adversaries may also compress shellcode directly - for example, in order to store it in a Windows Registry key (i.e., [Fileless Storage](https://attack.mitre.org/techniques/T1027/011)).(Citation: Trustwave Pillowmint June 2020)" ;
    skos:exactMatch d3f:T1027.015,
        mitre-attack:T1027.015 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027016 a owl:Class ;
    rdfs:label "T1027_016" ;
    d3f:attack-id "T1027.016" ;
    dcterms:title "Junk Code Insertion" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.016" ;
    skos:definition "Adversaries may use junk code / dead code to obfuscate a malware’s functionality. Junk code is code that either does not execute, or if it does execute, does not change the functionality of the code. Junk code makes analysis more difficult and time-consuming, as the analyst steps through non-functional code instead of analyzing the main code. It also may hinder detections that rely on static code analysis due to the use of benign functionality, especially when combined with [Compression](https://attack.mitre.org/techniques/T1027/015) or [Software Packing](https://attack.mitre.org/techniques/T1027/002).(Citation: ReasonLabs)(Citation: ReasonLabs Cyberpedia Junk Code)" ;
    skos:exactMatch d3f:T1027.016,
        mitre-attack:T1027.016 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1027017 a owl:Class ;
    rdfs:label "T1027_017" ;
    d3f:attack-id "T1027.017" ;
    dcterms:title "SVG Smuggling" ;
    rdfs:subClassOf d3f:T1027 ;
    skos:altLabel "T1027.017" ;
    skos:definition "Adversaries may smuggle data and files past content filters by hiding malicious payloads inside of seemingly benign SVG files.(Citation: Trustwave SVG Smuggling 2025) SVGs, or Scalable Vector Graphics, are vector-based image files constructed using XML. As such, they can legitimately include `<script>` tags that enable adversaries to include malicious JavaScript payloads. However, SVGs may appear less suspicious to users than other types of executable files, as they are often treated as image files." ;
    skos:exactMatch d3f:T1027.017,
        mitre-attack:T1027.017 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036001 a owl:Class ;
    rdfs:label "T1036_001" ;
    d3f:attack-id "T1036.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Invalid Code Signature" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.001" ;
    skos:definition "Adversaries may attempt to mimic features of valid code signatures to increase the chance of deceiving a user, analyst, or tool. Code signing provides a level of authenticity on a binary from the developer and a guarantee that the binary has not been tampered with. Adversaries can copy the metadata and signature information from a signed program, then use it as a template for an unsigned program. Files with invalid code signatures will fail digital signature validation checks, but they may appear more legitimate to users and security tools may improperly handle these files.(Citation: Threatexpress MetaTwin 2017)" ;
    skos:exactMatch d3f:T1036.001,
        mitre-attack:T1036.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036002 a owl:Class ;
    rdfs:label "T1036_002" ;
    d3f:attack-id "T1036.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Right-to-Left Override" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.002" ;
    skos:definition "Adversaries may abuse the right-to-left override (RTLO or RLO) character (U+202E) to disguise a string and/or file name to make it appear benign. RTLO is a non-printing Unicode character that causes the text that follows it to be displayed in reverse. For example, a Windows screensaver executable named <code>March 25 \\u202Excod.scr</code> will display as <code>March 25 rcs.docx</code>. A JavaScript file named <code>photo_high_re\\u202Egnp.js</code> will be displayed as <code>photo_high_resj.png</code>.(Citation: Infosecinstitute RTLO Technique)" ;
    skos:exactMatch d3f:T1036.002,
        mitre-attack:T1036.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036003 a owl:Class ;
    rdfs:label "T1036_003" ;
    d3f:attack-id "T1036.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Rename Legitimate Utilities" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.003" ;
    skos:definition "Adversaries may rename legitimate system utilities to try to evade security mechanisms concerning the usage of those utilities. Security monitoring and control mechanisms may be in place for system utilities adversaries are capable of abusing. (Citation: LOLBAS Main Site) It may be possible to bypass those security mechanisms by renaming the utility prior to utilization (ex: rename <code>rundll32.exe</code>). (Citation: Elastic Masquerade Ball) An alternative case occurs when a legitimate utility is copied or moved to a different directory and renamed to avoid detections based on system utilities executing from non-standard paths. (Citation: F-Secure CozyDuke)" ;
    skos:exactMatch d3f:T1036.003,
        mitre-attack:T1036.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036004 a owl:Class ;
    rdfs:label "T1036_004" ;
    d3f:attack-id "T1036.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Masquerade Task or Service" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.004" ;
    skos:definition "Adversaries may attempt to manipulate the name of a task or service to make it appear legitimate or benign. Tasks/services executed by the Task Scheduler or systemd will typically be given a name and/or description.(Citation: TechNet Schtasks)(Citation: Systemd Service Units) Windows services will have a service name as well as a display name. Many benign tasks and services exist that have commonly associated names. Adversaries may give tasks or services names that are similar or identical to those of legitimate ones." ;
    skos:exactMatch d3f:T1036.004,
        mitre-attack:T1036.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036005 a owl:Class ;
    rdfs:label "T1036_005" ;
    d3f:attack-id "T1036.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Match Legitimate Resource Name or Location" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.005" ;
    skos:definition "Adversaries may match or approximate the name or location of legitimate files or resources when naming/placing them. This is done for the sake of evading defenses and observation. This may be done by placing an executable in a commonly trusted directory (ex: under System32) or giving it the name of a legitimate, trusted program (ex: svchost.exe). In containerized environments, this may also be done by creating a resource in a namespace that matches the naming convention of a container pod or cluster. Alternatively, a file or container image name given may be a close approximation to legitimate programs/images or something innocuous." ;
    skos:exactMatch d3f:T1036.005,
        mitre-attack:T1036.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036006 a owl:Class ;
    rdfs:label "T1036_006" ;
    d3f:attack-id "T1036.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Space after Filename" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.006" ;
    skos:definition "Adversaries can hide a program's true filetype by changing the extension of a file. With certain file types (specifically this does not work with .app extensions), appending a space to the end of a filename will change how the file is processed by the operating system." ;
    skos:exactMatch d3f:T1036.006,
        mitre-attack:T1036.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036007 a owl:Class ;
    rdfs:label "T1036_007" ;
    d3f:attack-id "T1036.007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Double File Extension" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.007" ;
    skos:definition "Adversaries may abuse a double extension in the filename as a means of masquerading the true file type. A file name may include a secondary file type extension that may cause only the first extension to be displayed (ex: <code>File.txt.exe</code> may render in some views as just <code>File.txt</code>). However, the second extension is the true file type that determines how the file is opened and executed. The real file extension may be hidden by the operating system in the file browser (ex: explorer.exe), as well as in any software configured using or similar to the system’s policies.(Citation: PCMag DoubleExtension)(Citation: SOCPrime DoubleExtension)" ;
    skos:exactMatch d3f:T1036.007,
        mitre-attack:T1036.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036008 a owl:Class ;
    rdfs:label "T1036_008" ;
    d3f:attack-id "T1036.008" ;
    dcterms:title "Masquerade File Type" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.008" ;
    skos:definition "Adversaries may masquerade malicious payloads as legitimate files through changes to the payload's formatting, including the file’s signature, extension, and contents. Various file types have a typical standard format, including how they are encoded and organized. For example, a file’s signature (also known as header or magic bytes) is the beginning bytes of a file and is often used to identify the file’s type. For example, the header of a JPEG file,  is <code> 0xFF 0xD8</code> and the file extension is either `.JPE`, `.JPEG` or `.JPG`." ;
    skos:exactMatch d3f:T1036.008,
        mitre-attack:T1036.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036009 a owl:Class ;
    rdfs:label "T1036_009" ;
    d3f:attack-id "T1036.009" ;
    dcterms:title "Break Process Trees" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.009" ;
    skos:definition "An adversary may attempt to evade process tree-based analysis by modifying executed malware's parent process ID (PPID). If endpoint protection software leverages the “parent-child\" relationship for detection, breaking this relationship could result in the adversary’s behavior not being associated with previous process tree activity. On Unix-based systems breaking this process tree is common practice for administrators to execute software using scripts and programs.(Citation: 3OHA double-fork 2022)" ;
    skos:exactMatch d3f:T1036.009,
        mitre-attack:T1036.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036010 a owl:Class ;
    rdfs:label "T1036_010" ;
    d3f:attack-id "T1036.010" ;
    dcterms:title "Masquerade Account Name" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.010" ;
    skos:definition "Adversaries may match or approximate the names of legitimate accounts to make newly created ones appear benign. This will typically occur during [Create Account](https://attack.mitre.org/techniques/T1136), although accounts may also be renamed at a later date. This may also coincide with [Account Access Removal](https://attack.mitre.org/techniques/T1531) if the actor first deletes an account before re-creating one with the same name.(Citation: Huntress MOVEit 2023)" ;
    skos:exactMatch d3f:T1036.010,
        mitre-attack:T1036.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036011 a owl:Class ;
    rdfs:label "T1036_011" ;
    d3f:attack-id "T1036.011" ;
    dcterms:title "Overwrite Process Arguments" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.011" ;
    skos:definition "Adversaries may modify a process's in-memory arguments to change its name in order to appear as a legitimate or benign process. On Linux, the operating system stores command-line arguments in the process’s stack and passes them to the `main()` function as the `argv` array. The first element, `argv[0]`, typically contains the process name or path - by default, the command used to actually start the process (e.g., `cat /etc/passwd`). By default, the Linux `/proc` filesystem uses this value to represent the process name. The `/proc/<PID>/cmdline` file reflects the contents of this memory, and tools like `ps` use it to display process information. Since arguments are stored in user-space memory at launch, this modification can be performed without elevated privileges." ;
    skos:exactMatch d3f:T1036.011,
        mitre-attack:T1036.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1036012 a owl:Class ;
    rdfs:label "T1036_012" ;
    d3f:attack-id "T1036.012" ;
    dcterms:title "Browser Fingerprint" ;
    rdfs:subClassOf d3f:T1036 ;
    skos:altLabel "T1036.012" ;
    skos:definition "Adversaries may attempt to blend in with legitimate traffic by spoofing browser and system attributes like operating system, system language, platform, user-agent string, resolution, time zone, etc.  The HTTP User-Agent request header is a string that lets servers and network peers identify the application, operating system, vendor, and/or version of the requesting user agent.(Citation: Mozilla User Agent)" ;
    skos:exactMatch d3f:T1036.012,
        mitre-attack:T1036.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1037001 a owl:Class ;
    rdfs:label "T1037_001" ;
    d3f:attack-id "T1037.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Logon Script (Windows)" ;
    rdfs:subClassOf d3f:T1037 ;
    skos:altLabel "T1037.001" ;
    skos:definition "Adversaries may use Windows logon scripts automatically executed at logon initialization to establish persistence. Windows allows logon scripts to be run whenever a specific user or group of users log into a system.(Citation: TechNet Logon Scripts) This is done via adding a path to a script to the <code>HKCU\\Environment\\UserInitMprLogonScript</code> Registry key.(Citation: Hexacorn Logon Scripts)" ;
    skos:exactMatch d3f:T1037.001,
        mitre-attack:T1037.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1037002 a owl:Class ;
    rdfs:label "T1037_002" ;
    d3f:attack-id "T1037.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Login Hook" ;
    rdfs:subClassOf d3f:T1037 ;
    skos:altLabel "T1037.002" ;
    skos:definition "Adversaries may use a Login Hook to establish persistence executed upon user logon. A login hook is a plist file that points to a specific script to execute with root privileges upon user logon. The plist file is located in the <code>/Library/Preferences/com.apple.loginwindow.plist</code> file and can be modified using the <code>defaults</code> command-line utility. This behavior is the same for logout hooks where a script can be executed upon user logout. All hooks require administrator permissions to modify or create hooks.(Citation: Login Scripts Apple Dev)(Citation: LoginWindowScripts Apple Dev)" ;
    skos:exactMatch d3f:T1037.002,
        mitre-attack:T1037.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1037003 a owl:Class ;
    rdfs:label "T1037_003" ;
    d3f:attack-id "T1037.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Logon Script" ;
    rdfs:subClassOf d3f:T1037 ;
    skos:altLabel "T1037.003" ;
    skos:definition "Group Policy Object / Active Directory Users and Computers are both Active Directory-based." ;
    skos:exactMatch d3f:T1037.003,
        mitre-attack:T1037.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1037004 a owl:Class ;
    rdfs:label "T1037_004" ;
    d3f:attack-id "T1037.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "RC Scripts" ;
    rdfs:subClassOf d3f:T1037 ;
    skos:altLabel "T1037.004" ;
    skos:definition "Adversaries may establish persistence by modifying RC scripts which are executed during a Unix-like system’s startup. These files allow system administrators to map and start custom services at startup for different run levels. RC scripts require root privileges to modify." ;
    skos:exactMatch d3f:T1037.004,
        mitre-attack:T1037.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1037005 a owl:Class ;
    rdfs:label "T1037_005" ;
    d3f:attack-id "T1037.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Startup Items" ;
    rdfs:subClassOf d3f:T1037 ;
    skos:altLabel "T1037.005" ;
    skos:definition "Adversaries may use startup items automatically executed at boot initialization to establish persistence. Startup items execute during the final phase of the boot process and contain shell scripts or other executable files along with configuration information used by the system to determine the execution order for all startup items.(Citation: Startup Items)" ;
    skos:exactMatch d3f:T1037.005,
        mitre-attack:T1037.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1048001 a owl:Class ;
    rdfs:label "T1048_001" ;
    d3f:attack-id "T1048.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over Symmetric Encrypted Non-C2 Protocol" ;
    rdfs:subClassOf d3f:T1048 ;
    skos:altLabel "T1048.001" ;
    skos:definition "Adversaries may steal data by exfiltrating it over a symmetrically encrypted network protocol other than that of the existing command and control channel. The data may also be sent to an alternate network location from the main command and control server." ;
    skos:exactMatch d3f:T1048.001,
        mitre-attack:T1048.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1048002 a owl:Class ;
    rdfs:label "T1048_002" ;
    d3f:attack-id "T1048.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over Asymmetric Encrypted Non-C2 Protocol" ;
    rdfs:subClassOf d3f:T1048 ;
    skos:altLabel "T1048.002" ;
    skos:definition "Adversaries may steal data by exfiltrating it over an asymmetrically encrypted network protocol other than that of the existing command and control channel. The data may also be sent to an alternate network location from the main command and control server." ;
    skos:exactMatch d3f:T1048.002,
        mitre-attack:T1048.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1048003 a owl:Class ;
    rdfs:label "T1048_003" ;
    d3f:attack-id "T1048.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over Unencrypted Non-C2 Protocol" ;
    rdfs:subClassOf d3f:T1048 ;
    skos:altLabel "T1048.003" ;
    skos:definition "Adversaries may steal data by exfiltrating it over an un-encrypted network protocol other than that of the existing command and control channel. The data may also be sent to an alternate network location from the main command and control server.(Citation: copy_cmd_cisco)" ;
    skos:exactMatch d3f:T1048.003,
        mitre-attack:T1048.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1052001 a owl:Class ;
    rdfs:label "T1052_001" ;
    d3f:attack-id "T1052.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration over USB" ;
    rdfs:subClassOf d3f:T1052 ;
    skos:altLabel "T1052.001" ;
    skos:definition "Adversaries may attempt to exfiltrate data over a USB connected physical device. In certain circumstances, such as an air-gapped network compromise, exfiltration could occur via a USB device introduced by a user. The USB device could be used as the final exfiltration point or to hop between otherwise disconnected systems." ;
    skos:exactMatch d3f:T1052.001,
        mitre-attack:T1052.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1053001 a owl:Class ;
    rdfs:label "T1053_001" ;
    d3f:attack-id "T1053.001" ;
    dcterms:title "At (Linux) Execution" ;
    rdfs:seeAlso d3f:T1053.002 ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.001" ;
    skos:definition "Adversaries may abuse the [at](https://attack.mitre.org/software/S0110) utility to perform task scheduling for initial, recurring, or future execution of malicious code. The [at](https://attack.mitre.org/software/S0110) command within Linux operating systems enables administrators to schedule tasks.(Citation: Kifarunix - Task Scheduling in Linux)" ;
    skos:exactMatch d3f:T1053.001,
        mitre-attack:T1053.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1053.002" .

d3f:T1053002 a owl:Class ;
    rdfs:label "T1053_002" ;
    d3f:attack-id "T1053.002" ;
    dcterms:title "At" ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.002" ;
    skos:definition "Adversaries may abuse the [at](https://attack.mitre.org/software/S0110) utility to perform task scheduling for initial or recurring execution of malicious code. The [at](https://attack.mitre.org/software/S0110) utility exists as an executable within Windows, Linux, and macOS for scheduling tasks at a specified time and date. Although deprecated in favor of [Scheduled Task](https://attack.mitre.org/techniques/T1053/005)'s [schtasks](https://attack.mitre.org/software/S0111) in Windows environments, using [at](https://attack.mitre.org/software/S0110) requires that the Task Scheduler service be running, and the user to be logged on as a member of the local Administrators group." ;
    skos:exactMatch d3f:T1053.002,
        mitre-attack:T1053.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1053003 a owl:Class ;
    rdfs:label "T1053_003" ;
    d3f:attack-id "T1053.003" ;
    dcterms:title "Cron" ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.003" ;
    skos:definition "Adversaries may abuse the <code>cron</code> utility to perform task scheduling for initial or recurring execution of malicious code.(Citation: 20 macOS Common Tools and Techniques) The <code>cron</code> utility is a time-based job scheduler for Unix-like operating systems.  The <code> crontab</code> file contains the schedule of cron entries to be run and the specified times for execution. Any <code>crontab</code> files are stored in operating system-specific file paths." ;
    skos:exactMatch d3f:T1053.003,
        mitre-attack:T1053.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1053004 a owl:Class ;
    rdfs:label "T1053_004" ;
    d3f:attack-id "T1053.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Launchd" ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.004" ;
    skos:definition "This technique is deprecated due to the inaccurate usage. The report cited did not provide technical detail as to how the malware interacted directly with launchd rather than going through known services. Other system services are used to interact with launchd rather than launchd being used by itself." ;
    skos:exactMatch d3f:T1053.004,
        mitre-attack:T1053.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique is deprecated due to the inaccurate usage. The report cited did not provide technical detail as to how the malware interacted directly with launchd rather than going through known services. Other system services are used to interact with launchd rather than launchd being used by itself." .

d3f:T1053005 a owl:Class ;
    rdfs:label "T1053_005" ;
    d3f:attack-id "T1053.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Scheduled Task" ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.005" ;
    skos:definition "Adversaries may abuse the Windows Task Scheduler to perform task scheduling for initial or recurring execution of malicious code. There are multiple ways to access the Task Scheduler in Windows. The [schtasks](https://attack.mitre.org/software/S0111) utility can be run directly on the command line, or the Task Scheduler can be opened through the GUI within the Administrator Tools section of the Control Panel.(Citation: Stack Overflow) In some cases, adversaries have used a .NET wrapper for the Windows Task Scheduler, and alternatively, adversaries have used the Windows netapi32 library and [Windows Management Instrumentation](https://attack.mitre.org/techniques/T1047) (WMI) to create a scheduled task. Adversaries may also utilize the Powershell Cmdlet `Invoke-CimMethod`, which leverages WMI class `PS_ScheduledTask` to create a scheduled task via an XML path.(Citation: Red Canary - Atomic Red Team)" ;
    skos:exactMatch d3f:T1053.005,
        mitre-attack:T1053.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1053006 a owl:Class ;
    rdfs:label "T1053_006" ;
    d3f:attack-id "T1053.006" ;
    dcterms:title "Systemd Timers" ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.006" ;
    skos:definition "Adversaries may abuse systemd timers to perform task scheduling for initial or recurring execution of malicious code. Systemd timers are unit files with file extension <code>.timer</code> that control services. Timers can be set to run on a calendar event or after a time span relative to a starting point. They can be used as an alternative to [Cron](https://attack.mitre.org/techniques/T1053/003) in Linux environments.(Citation: archlinux Systemd Timers Aug 2020) Systemd timers may be activated remotely via the <code>systemctl</code> command line utility, which operates over [SSH](https://attack.mitre.org/techniques/T1021/004).(Citation: Systemd Remote Control)" ;
    skos:exactMatch d3f:T1053.006,
        mitre-attack:T1053.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1053007 a owl:Class ;
    rdfs:label "T1053_007" ;
    d3f:attack-id "T1053.007" ;
    dcterms:title "Container Orchestration Job" ;
    rdfs:subClassOf d3f:T1053 ;
    skos:altLabel "T1053.007" ;
    skos:definition "Adversaries may abuse task scheduling functionality provided by container orchestration tools such as Kubernetes to schedule deployment of containers configured to execute malicious code. Container orchestration jobs run these automated tasks at a specific date and time, similar to cron jobs on a Linux system. Deployments of this type can also be configured to maintain a quantity of containers over time, automating the process of maintaining persistence within a cluster." ;
    skos:exactMatch d3f:T1053.007,
        mitre-attack:T1053.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055001 a owl:Class ;
    rdfs:label "T1055_001" ;
    d3f:attack-id "T1055.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Dynamic-link Library Injection" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.001" ;
    skos:definition "Adversaries may inject dynamic-link libraries (DLLs) into processes in order to evade process-based defenses as well as possibly elevate privileges. DLL injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.001,
        mitre-attack:T1055.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055002 a owl:Class ;
    rdfs:label "T1055_002" ;
    d3f:attack-id "T1055.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Portable Executable Injection" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.002" ;
    skos:definition "Adversaries may inject portable executables (PE) into processes in order to evade process-based defenses as well as possibly elevate privileges. PE injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.002,
        mitre-attack:T1055.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055003 a owl:Class ;
    rdfs:label "T1055_003" ;
    d3f:attack-id "T1055.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Thread Execution Hijacking" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.003" ;
    skos:definition "Adversaries may inject malicious code into hijacked processes in order to evade process-based defenses as well as possibly elevate privileges. Thread Execution Hijacking is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.003,
        mitre-attack:T1055.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055004 a owl:Class ;
    rdfs:label "T1055_004" ;
    d3f:attack-id "T1055.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Asynchronous Procedure Call" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.004" ;
    skos:definition "Adversaries may inject malicious code into processes via the asynchronous procedure call (APC) queue in order to evade process-based defenses as well as possibly elevate privileges. APC injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.004,
        mitre-attack:T1055.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055005 a owl:Class ;
    rdfs:label "T1055_005" ;
    d3f:attack-id "T1055.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Thread Local Storage" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.005" ;
    skos:definition "Adversaries may inject malicious code into processes via thread local storage (TLS) callbacks in order to evade process-based defenses as well as possibly elevate privileges. TLS callback injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.005,
        mitre-attack:T1055.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055008 a owl:Class ;
    rdfs:label "T1055_008" ;
    d3f:attack-id "T1055.008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Ptrace System Calls" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.008" ;
    skos:definition "Adversaries may inject malicious code into processes via ptrace (process trace) system calls in order to evade process-based defenses as well as possibly elevate privileges. Ptrace system call injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.008,
        mitre-attack:T1055.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055009 a owl:Class ;
    rdfs:label "T1055_009" ;
    d3f:attack-id "T1055.009" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Proc Memory" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.009" ;
    skos:definition "Adversaries may inject malicious code into processes via the /proc filesystem in order to evade process-based defenses as well as possibly elevate privileges. Proc memory injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.009,
        mitre-attack:T1055.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055011 a owl:Class ;
    rdfs:label "T1055_011" ;
    d3f:attack-id "T1055.011" ;
    dcterms:title "Extra Window Memory Injection" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.011" ;
    skos:definition "Adversaries may inject malicious code into process via Extra Window Memory (EWM) in order to evade process-based defenses as well as possibly elevate privileges. EWM injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.011,
        mitre-attack:T1055.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055012 a owl:Class ;
    rdfs:label "T1055_012" ;
    d3f:attack-id "T1055.012" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Hollowing" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.012" ;
    skos:definition "Adversaries may inject malicious code into suspended and hollowed processes in order to evade process-based defenses. Process hollowing is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.012,
        mitre-attack:T1055.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055013 a owl:Class ;
    rdfs:label "T1055_013" ;
    d3f:attack-id "T1055.013" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Doppelgänging" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.013" ;
    skos:definition "Adversaries may inject malicious code into process via process doppelgänging in order to evade process-based defenses as well as possibly elevate privileges. Process doppelgänging is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.013,
        mitre-attack:T1055.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055014 a owl:Class ;
    rdfs:label "T1055_014" ;
    d3f:attack-id "T1055.014" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "VDSO Hijacking" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.014" ;
    skos:definition "Adversaries may inject malicious code into processes via VDSO hijacking in order to evade process-based defenses as well as possibly elevate privileges. Virtual dynamic shared object (vdso) hijacking is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1055.014,
        mitre-attack:T1055.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1055015 a owl:Class ;
    rdfs:label "T1055_015" ;
    d3f:attack-id "T1055.015" ;
    dcterms:title "ListPlanting" ;
    rdfs:subClassOf d3f:T1055 ;
    skos:altLabel "T1055.015" ;
    skos:definition "Adversaries may abuse list-view controls to inject malicious code into hijacked processes in order to evade process-based defenses as well as possibly elevate privileges. ListPlanting is a method of executing arbitrary code in the address space of a separate live process. Code executed via ListPlanting may also evade detection from security products since the execution is masked under a legitimate process." ;
    skos:exactMatch d3f:T1055.015,
        mitre-attack:T1055.015 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1056001 a owl:Class ;
    rdfs:label "T1056_001" ;
    d3f:attack-id "T1056.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Keylogging" ;
    rdfs:subClassOf d3f:T1056 ;
    skos:altLabel "T1056.001" ;
    skos:definition "Adversaries may log user keystrokes to intercept credentials as the user types them. Keylogging is likely to be used to acquire credentials for new access opportunities when [OS Credential Dumping](https://attack.mitre.org/techniques/T1003) efforts are not effective, and may require an adversary to intercept keystrokes on a system for a substantial period of time before credentials can be successfully captured. In order to increase the likelihood of capturing credentials quickly, an adversary may also perform actions such as clearing browser cookies to force users to reauthenticate to systems.(Citation: Talos Kimsuky Nov 2021)" ;
    skos:exactMatch d3f:T1056.001,
        mitre-attack:T1056.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1056002 a owl:Class ;
    rdfs:label "T1056_002" ;
    d3f:attack-id "T1056.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "GUI Input Capture" ;
    rdfs:subClassOf d3f:T1056 ;
    skos:altLabel "T1056.002" ;
    skos:definition "Adversaries may mimic common operating system GUI components to prompt users for credentials with a seemingly legitimate prompt. When programs are executed that need additional privileges than are present in the current user context, it is common for the operating system to prompt the user for proper credentials to authorize the elevated privileges for the task (ex: [Bypass User Account Control](https://attack.mitre.org/techniques/T1548/002))." ;
    skos:exactMatch d3f:T1056.002,
        mitre-attack:T1056.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1056003 a owl:Class ;
    rdfs:label "T1056_003" ;
    d3f:attack-id "T1056.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Portal Capture" ;
    rdfs:subClassOf d3f:T1056 ;
    skos:altLabel "T1056.003" ;
    skos:definition "Adversaries may install code on externally facing portals, such as a VPN login page, to capture and transmit credentials of users who attempt to log into the service. For example, a compromised login page may log provided user credentials before logging the user in to the service." ;
    skos:exactMatch d3f:T1056.003,
        mitre-attack:T1056.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1056004 a owl:Class ;
    rdfs:label "T1056_004" ;
    d3f:attack-id "T1056.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential API Hooking" ;
    rdfs:subClassOf d3f:T1056 ;
    skos:altLabel "T1056.004" ;
    skos:definition "Adversaries may hook into Windows application programming interface (API) functions to collect user credentials. Malicious hooking mechanisms may capture API calls that include parameters that reveal user authentication credentials.(Citation: Microsoft TrojanSpy:Win32/Ursnif.gen!I Sept 2017) Unlike [Keylogging](https://attack.mitre.org/techniques/T1056/001),  this technique focuses specifically on API functions that include parameters that reveal user credentials. Hooking involves redirecting calls to these functions and can be implemented via:" ;
    skos:exactMatch d3f:T1056.004,
        mitre-attack:T1056.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059001 a owl:Class ;
    rdfs:label "T1059_001" ;
    d3f:attack-id "T1059.001" ;
    dcterms:title "PowerShell" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.001" ;
    skos:definition "Adversaries may abuse PowerShell commands and scripts for execution. PowerShell is a powerful interactive command-line interface and scripting environment included in the Windows operating system.(Citation: TechNet PowerShell) Adversaries can use PowerShell to perform a number of actions, including discovery of information and execution of code. Examples include the <code>Start-Process</code> cmdlet which can be used to run an executable and the <code>Invoke-Command</code> cmdlet which runs a command locally or on a remote computer (though administrator permissions are required to use PowerShell to connect to remote systems)." ;
    skos:exactMatch d3f:T1059.001,
        mitre-attack:T1059.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059002 a owl:Class ;
    rdfs:label "T1059_002" ;
    d3f:attack-id "T1059.002" ;
    dcterms:title "AppleScript" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.002" ;
    skos:definition "Adversaries may abuse AppleScript for execution. AppleScript is a macOS scripting language designed to control applications and parts of the OS via inter-application messages called AppleEvents.(Citation: Apple AppleScript) These AppleEvent messages can be sent independently or easily scripted with AppleScript. These events can locate open windows, send keystrokes, and interact with almost any open application locally or remotely." ;
    skos:exactMatch d3f:T1059.002,
        mitre-attack:T1059.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059003 a owl:Class ;
    rdfs:label "T1059_003" ;
    d3f:attack-id "T1059.003" ;
    dcterms:title "Windows Command Shell" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.003" ;
    skos:definition "Adversaries may abuse the Windows command shell for execution. The Windows command shell ([cmd](https://attack.mitre.org/software/S0106)) is the primary command prompt on Windows systems. The Windows command prompt can be used to control almost any aspect of a system, with various permission levels required for different subsets of commands. The command prompt can be invoked remotely via [Remote Services](https://attack.mitre.org/techniques/T1021) such as [SSH](https://attack.mitre.org/techniques/T1021/004).(Citation: SSH in Windows)" ;
    skos:exactMatch d3f:T1059.003,
        mitre-attack:T1059.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059004 a owl:Class ;
    rdfs:label "T1059_004" ;
    d3f:attack-id "T1059.004" ;
    dcterms:title "Unix Shell" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "Bash Execution" ;
    skos:definition "Adversaries may abuse Unix shell commands and scripts for execution. Unix shells are the primary command prompt on Linux and macOS systems, though many variations of the Unix shell exist (e.g. sh, bash, zsh, etc.) depending on the specific OS or distribution.(Citation: DieNet Bash)(Citation: Apple ZShell) Unix shells can control every aspect of a system, with certain commands requiring elevated privileges." ;
    skos:exactMatch d3f:T1059.004,
        mitre-attack:T1059.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059005 a owl:Class ;
    rdfs:label "T1059_005" ;
    d3f:attack-id "T1059.005" ;
    dcterms:title "Visual Basic" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.005" ;
    skos:definition "Adversaries may abuse Visual Basic (VB) for execution. VB is a programming language created by Microsoft with interoperability with many Windows technologies such as [Component Object Model](https://attack.mitre.org/techniques/T1559/001) and the [Native API](https://attack.mitre.org/techniques/T1106) through the Windows API. Although tagged as legacy with no planned future evolutions, VB is integrated and supported in the .NET Framework and cross-platform .NET Core.(Citation: VB .NET Mar 2020)(Citation: VB Microsoft)" ;
    skos:exactMatch d3f:T1059.005,
        mitre-attack:T1059.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059006 a owl:Class ;
    rdfs:label "T1059_006" ;
    d3f:attack-id "T1059.006" ;
    dcterms:title "Python" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.006" ;
    skos:definition "Adversaries may abuse Python commands and scripts for execution. Python is a very popular scripting/programming language, with capabilities to perform many functions. Python can be executed interactively from the command-line (via the <code>python.exe</code> interpreter) or via scripts (.py) that can be written and distributed to different systems. Python code can also be compiled into binary executables.(Citation: Zscaler APT31 Covid-19 October 2020)" ;
    skos:exactMatch d3f:T1059.006,
        mitre-attack:T1059.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059007 a owl:Class ;
    rdfs:label "T1059_007" ;
    d3f:attack-id "T1059.007" ;
    dcterms:title "JavaScript" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.007" ;
    skos:definition "Adversaries may abuse various implementations of JavaScript for execution. JavaScript (JS) is a platform-independent scripting language (compiled just-in-time at runtime) commonly associated with scripts in webpages, though JS can be executed in runtime environments outside the browser.(Citation: NodeJS)" ;
    skos:exactMatch d3f:T1059.007,
        mitre-attack:T1059.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059008 a owl:Class ;
    rdfs:label "T1059_008" ;
    d3f:attack-id "T1059.008" ;
    dcterms:title "Network Device CLI" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.008" ;
    skos:definition "Adversaries may abuse scripting or built-in command line interpreters (CLI) on network devices to execute malicious command and payloads. The CLI is the primary means through which users and administrators interact with the device in order to view system information, modify device operations, or perform diagnostic and administrative functions. CLIs typically contain various permission levels required for different commands." ;
    skos:exactMatch d3f:T1059.008,
        mitre-attack:T1059.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059009 a owl:Class ;
    rdfs:label "T1059_009" ;
    d3f:attack-id "T1059.009" ;
    dcterms:title "Cloud API" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.009" ;
    skos:definition "Adversaries may abuse cloud APIs to execute malicious commands. APIs available in cloud environments provide various functionalities and are a feature-rich method for programmatic access to nearly all aspects of a tenant. These APIs may be utilized through various methods such as command line interpreters (CLIs), in-browser Cloud Shells, [PowerShell](https://attack.mitre.org/techniques/T1059/001) modules like Azure for PowerShell(Citation: Microsoft - Azure PowerShell), or software developer kits (SDKs) available for languages such as [Python](https://attack.mitre.org/techniques/T1059/006)." ;
    skos:exactMatch d3f:T1059.009,
        mitre-attack:T1059.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059010 a owl:Class ;
    rdfs:label "T1059_010" ;
    d3f:attack-id "T1059.010" ;
    dcterms:title "AutoHotKey & AutoIT" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.010" ;
    skos:definition "Adversaries may execute commands and perform malicious tasks using AutoIT and AutoHotKey automation scripts. AutoIT and AutoHotkey (AHK) are scripting languages that enable users to automate Windows tasks. These automation scripts can be used to perform a wide variety of actions, such as clicking on buttons, entering text, and opening and closing programs.(Citation: AutoIT)(Citation: AutoHotKey)" ;
    skos:exactMatch d3f:T1059.010,
        mitre-attack:T1059.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059011 a owl:Class ;
    rdfs:label "T1059_011" ;
    d3f:attack-id "T1059.011" ;
    dcterms:title "Lua" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.011" ;
    skos:definition "Adversaries may abuse Lua commands and scripts for execution. Lua is a cross-platform scripting and programming language primarily designed for embedded use in applications. Lua can be executed on the command-line (through the stand-alone lua interpreter), via scripts (<code>.lua</code>), or from Lua-embedded programs (through the <code>struct lua_State</code>).(Citation: Lua main page)(Citation: Lua state)" ;
    skos:exactMatch d3f:T1059.011,
        mitre-attack:T1059.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059012 a owl:Class ;
    rdfs:label "T1059_012" ;
    d3f:attack-id "T1059.012" ;
    dcterms:title "Hypervisor CLI" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.012" ;
    skos:definition "Adversaries may abuse hypervisor command line interpreters (CLIs) to execute malicious commands. Hypervisor CLIs typically enable a wide variety of functionality for managing both the hypervisor itself and the guest virtual machines it hosts." ;
    skos:exactMatch d3f:T1059.012,
        mitre-attack:T1059.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059013 a owl:Class ;
    rdfs:label "T1059_013" ;
    d3f:attack-id "T1059.013" ;
    dcterms:title "Container CLI/API" ;
    rdfs:subClassOf d3f:T1059 ;
    skos:altLabel "T1059.013" ;
    skos:definition "Adversaries may abuse built-in CLI tools or API calls to execute malicious commands in containerized environments." ;
    skos:exactMatch d3f:T1059.013,
        mitre-attack:T1059.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1069001 a owl:Class ;
    rdfs:label "T1069_001" ;
    d3f:attack-id "T1069.001" ;
    dcterms:title "Local Groups" ;
    rdfs:subClassOf d3f:T1069 ;
    skos:altLabel "T1069.001" ;
    skos:definition "Adversaries may attempt to find local system groups and permission settings. The knowledge of local system permission groups can help adversaries determine which groups exist and which users belong to a particular group. Adversaries may use this information to determine which users have elevated permissions, such as the users found within the local administrators group." ;
    skos:exactMatch d3f:T1069.001,
        mitre-attack:T1069.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1069002 a owl:Class ;
    rdfs:label "T1069_002" ;
    d3f:attack-id "T1069.002" ;
    dcterms:title "Domain Groups" ;
    rdfs:subClassOf d3f:T1069 ;
    skos:altLabel "T1069.002" ;
    skos:definition "Adversaries may attempt to find domain-level groups and permission settings. The knowledge of domain-level permission groups can help adversaries determine which groups exist and which users belong to a particular group. Adversaries may use this information to determine which users have elevated permissions, such as domain administrators." ;
    skos:exactMatch d3f:T1069.002,
        mitre-attack:T1069.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1069003 a owl:Class ;
    rdfs:label "T1069_003" ;
    d3f:attack-id "T1069.003" ;
    dcterms:title "Cloud Groups" ;
    rdfs:subClassOf d3f:T1069 ;
    skos:altLabel "T1069.003" ;
    skos:definition "Adversaries may attempt to find cloud groups and permission settings. The knowledge of cloud permission groups can help adversaries determine the particular roles of users and groups within an environment, as well as which users are associated with a particular group." ;
    skos:exactMatch d3f:T1069.003,
        mitre-attack:T1069.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070001 a owl:Class ;
    rdfs:label "T1070_001" ;
    d3f:attack-id "T1070.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Clear Windows Event Logs" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.001" ;
    skos:definition "Adversaries may clear Windows Event Logs to hide the activity of an intrusion. Windows Event Logs are a record of a computer's alerts and notifications. There are three system-defined sources of events: System, Application, and Security, with five event types: Error, Warning, Information, Success Audit, and Failure Audit." ;
    skos:exactMatch d3f:T1070.001,
        mitre-attack:T1070.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070002 a owl:Class ;
    rdfs:label "T1070_002" ;
    d3f:attack-id "T1070.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Clear Linux or Mac System Logs" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.002" ;
    skos:definition "Adversaries may clear system logs to hide evidence of an intrusion. macOS and Linux both keep track of system or user-initiated actions via system logs. The majority of native system logging is stored under the <code>/var/log/</code> directory. Subfolders in this directory categorize logs by their related functions, such as:(Citation: Linux Logs)" ;
    skos:exactMatch d3f:T1070.002,
        mitre-attack:T1070.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070003 a owl:Class ;
    rdfs:label "T1070_003" ;
    d3f:attack-id "T1070.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Clear Command History" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.003" ;
    skos:definition "In addition to clearing system logs, an adversary may clear the command history of a compromised account to conceal the actions undertaken during an intrusion. Various command interpreters keep track of the commands users type in their terminal so that users can retrace what they've done." ;
    skos:exactMatch d3f:T1070.003,
        mitre-attack:T1070.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070004 a owl:Class ;
    rdfs:label "T1070_004" ;
    d3f:attack-id "T1070.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Deletion" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.004" ;
    skos:definition "Adversaries may delete files left behind by the actions of their intrusion activity. Malware, tools, or other non-native files dropped or created on a system by an adversary (ex: [Ingress Tool Transfer](https://attack.mitre.org/techniques/T1105)) may leave traces to indicate to what was done within a network and how. Removal of these files can occur during an intrusion, or as part of a post-intrusion process to minimize the adversary's footprint." ;
    skos:exactMatch d3f:T1070.004,
        mitre-attack:T1070.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070005 a owl:Class ;
    rdfs:label "T1070_005" ;
    d3f:attack-id "T1070.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Share Connection Removal" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.005" ;
    skos:definition "Adversaries may remove share connections that are no longer useful in order to clean up traces of their operation. Windows shared drive and [SMB/Windows Admin Shares](https://attack.mitre.org/techniques/T1021/002) connections can be removed when no longer needed. [Net](https://attack.mitre.org/software/S0039) is an example utility that can be used to remove network share connections with the <code>net use \\\\system\\share /delete</code> command. (Citation: Technet Net Use)" ;
    skos:exactMatch d3f:T1070.005,
        mitre-attack:T1070.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070006 a owl:Class ;
    rdfs:label "T1070_006" ;
    d3f:attack-id "T1070.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Timestomp" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.006" ;
    skos:definition "Adversaries may modify file time attributes to hide new or changes to existing files. Timestomping is a technique that modifies the timestamps of a file (the modify, access, create, and change times), often to mimic files that are in the same folder. This is done, for example, on files that have been modified or created by the adversary so that they do not appear conspicuous to forensic investigators or file analysis tools." ;
    skos:exactMatch d3f:T1070.006,
        mitre-attack:T1070.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070007 a owl:Class ;
    rdfs:label "T1070_007" ;
    d3f:attack-id "T1070.007" ;
    dcterms:title "Clear Network Connection History and Configurations" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.007" ;
    skos:definition "Adversaries may clear or remove evidence of malicious network connections in order to clean up traces of their operations. Configuration settings as well as various artifacts that highlight connection history may be created on a system and/or in application logs from behaviors that require network connections, such as [Remote Services](https://attack.mitre.org/techniques/T1021) or [External Remote Services](https://attack.mitre.org/techniques/T1133). Defenders may use these artifacts to monitor or otherwise analyze network connections created by adversaries." ;
    skos:exactMatch d3f:T1070.007,
        mitre-attack:T1070.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070008 a owl:Class ;
    rdfs:label "T1070_008" ;
    d3f:attack-id "T1070.008" ;
    dcterms:title "Clear Mailbox Data" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.008" ;
    skos:definition "Adversaries may modify mail and mail application data to remove evidence of their activity. Email applications allow users and other programs to export and delete mailbox data via command line tools or use of APIs. Mail application data can be emails, email metadata, or logs generated by the application or operating system, such as export requests." ;
    skos:exactMatch d3f:T1070.008,
        mitre-attack:T1070.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070009 a owl:Class ;
    rdfs:label "T1070_009" ;
    d3f:attack-id "T1070.009" ;
    dcterms:title "Clear Persistence" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.009" ;
    skos:definition "Adversaries may clear artifacts associated with previously established persistence on a host system to remove evidence of their activity. This may involve various actions, such as removing services, deleting executables, [Modify Registry](https://attack.mitre.org/techniques/T1112), [Plist File Modification](https://attack.mitre.org/techniques/T1647), or other methods of cleanup to prevent defenders from collecting evidence of their persistent presence.(Citation: Cylance Dust Storm) Adversaries may also delete accounts previously created to maintain persistence (i.e. [Create Account](https://attack.mitre.org/techniques/T1136)).(Citation: Talos - Cisco Attack 2022)" ;
    skos:exactMatch d3f:T1070.009,
        mitre-attack:T1070.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070010 a owl:Class ;
    rdfs:label "T1070_010" ;
    d3f:attack-id "T1070.010" ;
    dcterms:title "Relocate Malware" ;
    rdfs:subClassOf d3f:T1070 ;
    skos:altLabel "T1070.010" ;
    skos:definition "Once a payload is delivered, adversaries may reproduce copies of the same malware on the victim system to remove evidence of their presence and/or avoid defenses. Copying malware payloads to new locations may also be combined with [File Deletion](https://attack.mitre.org/techniques/T1070/004) to cleanup older artifacts." ;
    skos:exactMatch d3f:T1070.010,
        mitre-attack:T1070.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1071001 a owl:Class ;
    rdfs:label "T1071_001" ;
    d3f:attack-id "T1071.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Protocols" ;
    rdfs:subClassOf d3f:T1071 ;
    skos:altLabel "T1071.001" ;
    skos:definition "Adversaries may communicate using application layer protocols associated with web traffic to avoid detection/network filtering by blending in with existing traffic. Commands to the remote system, and often the results of those commands, will be embedded within the protocol traffic between the client and server." ;
    skos:exactMatch d3f:T1071.001,
        mitre-attack:T1071.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1071002 a owl:Class ;
    rdfs:label "T1071_002" ;
    d3f:attack-id "T1071.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Transfer Protocols" ;
    rdfs:subClassOf d3f:T1071 ;
    skos:altLabel "T1071.002" ;
    skos:definition "Adversaries may communicate using application layer protocols associated with transferring files to avoid detection/network filtering by blending in with existing traffic. Commands to the remote system, and often the results of those commands, will be embedded within the protocol traffic between the client and server." ;
    skos:exactMatch d3f:T1071.002,
        mitre-attack:T1071.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1071003 a owl:Class ;
    rdfs:label "T1071_003" ;
    d3f:attack-id "T1071.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Mail Protocols" ;
    rdfs:subClassOf d3f:T1071 ;
    skos:altLabel "T1071.003" ;
    skos:definition "Adversaries may communicate using application layer protocols associated with electronic mail delivery to avoid detection/network filtering by blending in with existing traffic. Commands to the remote system, and often the results of those commands, will be embedded within the protocol traffic between the client and server." ;
    skos:exactMatch d3f:T1071.003,
        mitre-attack:T1071.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1071004 a owl:Class ;
    rdfs:label "T1071_004" ;
    d3f:attack-id "T1071.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DNS" ;
    rdfs:subClassOf d3f:T1071 ;
    skos:altLabel "T1071.004" ;
    skos:definition "Adversaries may communicate using the Domain Name System (DNS) application layer protocol to avoid detection/network filtering by blending in with existing traffic. Commands to the remote system, and often the results of those commands, will be embedded within the protocol traffic between the client and server." ;
    skos:exactMatch d3f:T1071.004,
        mitre-attack:T1071.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1071005 a owl:Class ;
    rdfs:label "T1071_005" ;
    d3f:attack-id "T1071.005" ;
    dcterms:title "Publish/Subscribe Protocols" ;
    rdfs:subClassOf d3f:T1071 ;
    skos:altLabel "T1071.005" ;
    skos:definition "Adversaries may communicate using publish/subscribe (pub/sub) application layer protocols to avoid detection/network filtering by blending in with existing traffic. Commands to the remote system, and often the results of those commands, will be embedded within the protocol traffic between the client and server." ;
    skos:exactMatch d3f:T1071.005,
        mitre-attack:T1071.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1074001 a owl:Class ;
    rdfs:label "T1074_001" ;
    d3f:attack-id "T1074.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Data Staging" ;
    rdfs:subClassOf d3f:T1074 ;
    skos:altLabel "T1074.001" ;
    skos:definition "Adversaries may stage collected data in a central location or directory on the local system prior to Exfiltration. Data may be kept in separate files or combined into one file through techniques such as [Archive Collected Data](https://attack.mitre.org/techniques/T1560). Interactive command shells may be used, and common functionality within [cmd](https://attack.mitre.org/software/S0106) and bash may be used to copy data into a staging location." ;
    skos:exactMatch d3f:T1074.001,
        mitre-attack:T1074.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1074002 a owl:Class ;
    rdfs:label "T1074_002" ;
    d3f:attack-id "T1074.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Data Staging" ;
    rdfs:subClassOf d3f:T1074 ;
    skos:altLabel "T1074.002" ;
    skos:definition "Adversaries may stage data collected from multiple systems in a central location or directory on one system prior to Exfiltration. Data may be kept in separate files or combined into one file through techniques such as [Archive Collected Data](https://attack.mitre.org/techniques/T1560). Interactive command shells may be used, and common functionality within [cmd](https://attack.mitre.org/software/S0106) and bash may be used to copy data into a staging location." ;
    skos:exactMatch d3f:T1074.002,
        mitre-attack:T1074.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1078001 a owl:Class ;
    rdfs:label "T1078_001" ;
    d3f:attack-id "T1078.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Default Accounts" ;
    rdfs:subClassOf d3f:T1078 ;
    skos:altLabel "T1078.001" ;
    skos:definition "Adversaries may obtain and abuse credentials of a default account as a means of gaining Initial Access, Persistence, Privilege Escalation, or Defense Evasion. Default accounts are those that are built-into an OS, such as the Guest or Administrator accounts on Windows systems. Default accounts also include default factory/provider set accounts on other types of systems, software, or devices, including the root user account in AWS and the default service account in Kubernetes.(Citation: Microsoft Local Accounts Feb 2019)(Citation: AWS Root User)(Citation: Threat Matrix for Kubernetes)" ;
    skos:exactMatch d3f:T1078.001,
        mitre-attack:T1078.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1078002 a owl:Class ;
    rdfs:label "T1078_002" ;
    d3f:attack-id "T1078.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Accounts" ;
    rdfs:subClassOf d3f:T1078 ;
    skos:altLabel "T1078.002" ;
    skos:definition "Adversaries may obtain and abuse credentials of a domain account as a means of gaining Initial Access, Persistence, Privilege Escalation, or Defense Evasion.(Citation: TechNet Credential Theft) Domain accounts are those managed by Active Directory Domain Services where access and permissions are configured across systems and services that are part of that domain. Domain accounts can cover users, administrators, and services.(Citation: Microsoft AD Accounts)" ;
    skos:exactMatch d3f:T1078.002,
        mitre-attack:T1078.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1078003 a owl:Class ;
    rdfs:label "T1078_003" ;
    d3f:attack-id "T1078.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Accounts" ;
    rdfs:subClassOf d3f:T1078 ;
    skos:altLabel "T1078.003" ;
    skos:definition "Adversaries may obtain and abuse credentials of a local account as a means of gaining Initial Access, Persistence, Privilege Escalation, or Defense Evasion. Local accounts are those configured by an organization for use by users, remote support, services, or for administration on a single system or service." ;
    skos:exactMatch d3f:T1078.003,
        mitre-attack:T1078.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1078004 a owl:Class ;
    rdfs:label "T1078_004" ;
    d3f:attack-id "T1078.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Accounts" ;
    rdfs:subClassOf d3f:T1078 ;
    skos:altLabel "T1078.004" ;
    skos:definition "Valid accounts in cloud environments may allow adversaries to perform actions to achieve Initial Access, Persistence, Privilege Escalation, or Defense Evasion. Cloud accounts are those created and configured by an organization for use by users, remote support, services, or for administration of resources within a cloud service provider or SaaS application. Cloud Accounts can exist solely in the cloud; alternatively, they may be hybrid-joined between on-premises systems and the cloud through syncing or federation with other identity sources such as Windows Active Directory. (Citation: AWS Identity Federation)(Citation: Google Federating GC)(Citation: Microsoft Deploying AD Federation)" ;
    skos:exactMatch d3f:T1078.004,
        mitre-attack:T1078.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1087001 a owl:Class ;
    rdfs:label "T1087_001" ;
    d3f:attack-id "T1087.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Account" ;
    rdfs:subClassOf d3f:T1087 ;
    skos:altLabel "T1087.001" ;
    skos:definition "Adversaries may attempt to get a listing of local system accounts. This information can help adversaries determine which local accounts exist on a system to aid in follow-on behavior." ;
    skos:exactMatch d3f:T1087.001,
        mitre-attack:T1087.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1087002 a owl:Class ;
    rdfs:label "T1087_002" ;
    d3f:attack-id "T1087.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Account" ;
    rdfs:subClassOf d3f:T1087 ;
    skos:altLabel "T1087.002" ;
    skos:definition "Adversaries may attempt to get a listing of domain accounts. This information can help adversaries determine which domain accounts exist to aid in follow-on behavior such as targeting specific accounts which possess particular privileges." ;
    skos:exactMatch d3f:T1087.002,
        mitre-attack:T1087.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1087003 a owl:Class ;
    rdfs:label "T1087_003" ;
    d3f:attack-id "T1087.003" ;
    dcterms:title "Email Account" ;
    rdfs:subClassOf d3f:T1087 ;
    skos:altLabel "T1087.003" ;
    skos:definition "Adversaries may attempt to get a listing of email addresses and accounts. Adversaries may try to dump Exchange address lists such as global address lists (GALs).(Citation: Microsoft Exchange Address Lists)" ;
    skos:exactMatch d3f:T1087.003,
        mitre-attack:T1087.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1087004 a owl:Class ;
    rdfs:label "T1087_004" ;
    d3f:attack-id "T1087.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Account" ;
    rdfs:subClassOf d3f:T1087 ;
    skos:altLabel "T1087.004" ;
    skos:definition "Adversaries may attempt to get a listing of cloud accounts. Cloud accounts are those created and configured by an organization for use by users, remote support, services, or for administration of resources within a cloud service provider or SaaS application." ;
    skos:exactMatch d3f:T1087.004,
        mitre-attack:T1087.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1090001 a owl:Class ;
    rdfs:label "T1090_001" ;
    d3f:attack-id "T1090.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Internal Proxy" ;
    rdfs:subClassOf d3f:T1090 ;
    skos:altLabel "T1090.001" ;
    skos:definition "Adversaries may use an internal proxy to direct command and control traffic between two or more systems in a compromised environment. Many tools exist that enable traffic redirection through proxies or port redirection, including [HTRAN](https://attack.mitre.org/software/S0040), ZXProxy, and ZXPortMap. (Citation: Trend Micro APT Attack Tools) Adversaries use internal proxies to manage command and control communications inside a compromised environment, to reduce the number of simultaneous outbound network connections, to provide resiliency in the face of connection loss, or to ride over existing trusted communications paths between infected systems to avoid suspicion. Internal proxy connections may use common peer-to-peer (p2p) networking protocols, such as SMB, to better blend in with the environment." ;
    skos:exactMatch d3f:T1090.001,
        mitre-attack:T1090.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1090002 a owl:Class ;
    rdfs:label "T1090_002" ;
    d3f:attack-id "T1090.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "External Proxy" ;
    rdfs:subClassOf d3f:T1090 ;
    skos:altLabel "T1090.002" ;
    skos:definition "Adversaries may use an external proxy to act as an intermediary for network communications to a command and control server to avoid direct connections to their infrastructure. Many tools exist that enable traffic redirection through proxies or port redirection, including [HTRAN](https://attack.mitre.org/software/S0040), ZXProxy, and ZXPortMap. (Citation: Trend Micro APT Attack Tools) Adversaries use these types of proxies to manage command and control communications, to provide resiliency in the face of connection loss, or to ride over existing trusted communications paths to avoid suspicion." ;
    skos:exactMatch d3f:T1090.002,
        mitre-attack:T1090.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1090003 a owl:Class ;
    rdfs:label "T1090_003" ;
    d3f:attack-id "T1090.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multi-hop Proxy" ;
    rdfs:subClassOf d3f:T1090 ;
    skos:altLabel "T1090.003" ;
    skos:definition "Adversaries may chain together multiple proxies to disguise the source of malicious traffic. Typically, a defender will be able to identify the last proxy traffic traversed before it enters their network; the defender may or may not be able to identify any previous proxies before the last-hop proxy. This technique makes identifying the original source of the malicious traffic even more difficult by requiring the defender to trace malicious traffic through several proxies to identify its source." ;
    skos:exactMatch d3f:T1090.003,
        mitre-attack:T1090.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1090004 a owl:Class ;
    rdfs:label "T1090_004" ;
    d3f:attack-id "T1090.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Fronting" ;
    rdfs:subClassOf d3f:T1090 ;
    skos:altLabel "T1090.004" ;
    skos:definition "Adversaries may take advantage of routing schemes in Content Delivery Networks (CDNs) and other services which host multiple domains to obfuscate the intended destination of HTTPS traffic or traffic tunneled through HTTPS. (Citation: Fifield Blocking Resistent Communication through domain fronting 2015) Domain fronting involves using different domain names in the SNI field of the TLS header and the Host field of the HTTP header. If both domains are served from the same CDN, then the CDN may route to the address specified in the HTTP header after unwrapping the TLS header. A variation of the the technique, \"domainless\" fronting, utilizes a SNI field that is left blank; this may allow the fronting to work even when the CDN attempts to validate that the SNI and HTTP Host fields match (if the blank SNI fields are ignored)." ;
    skos:exactMatch d3f:T1090.004,
        mitre-attack:T1090.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098001 a owl:Class ;
    rdfs:label "T1098_001" ;
    d3f:attack-id "T1098.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Additional Cloud Credentials" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.001" ;
    skos:definition "Adversaries may add adversary-controlled credentials to a cloud account to maintain persistent access to victim accounts and instances within the environment." ;
    skos:exactMatch d3f:T1098.001,
        mitre-attack:T1098.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098002 a owl:Class ;
    rdfs:label "T1098_002" ;
    d3f:attack-id "T1098.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Additional Email Delegate Permissions" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.002" ;
    skos:definition "Adversaries may grant additional permission levels to maintain persistent access to an adversary-controlled email account." ;
    skos:exactMatch d3f:T1098.002,
        mitre-attack:T1098.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098003 a owl:Class ;
    rdfs:label "T1098_003" ;
    d3f:attack-id "T1098.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Additional Cloud Roles" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.003" ;
    skos:definition "An adversary may add additional roles or permissions to an adversary-controlled cloud account to maintain persistent access to a tenant. For example, adversaries may update IAM policies in cloud-based environments or add a new global administrator in Office 365 environments.(Citation: AWS IAM Policies and Permissions)(Citation: Google Cloud IAM Policies)(Citation: Microsoft Support O365 Add Another Admin, October 2019)(Citation: Microsoft O365 Admin Roles) With sufficient permissions, a compromised account can gain almost unlimited access to data and settings (including the ability to reset the passwords of other admins).(Citation: Expel AWS Attacker)" ;
    skos:exactMatch d3f:T1098.003,
        mitre-attack:T1098.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098004 a owl:Class ;
    rdfs:label "T1098_004" ;
    d3f:attack-id "T1098.004" ;
    dcterms:title "SSH Authorized Keys" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.004" ;
    skos:definition "Adversaries may modify the SSH <code>authorized_keys</code> file to maintain persistence on a victim host. Linux distributions and macOS commonly use key-based authentication to secure the authentication process of SSH sessions for remote management. The <code>authorized_keys</code> file in SSH specifies the SSH keys that can be used for logging into the user account for which the file is configured. This file is usually found in the user's home directory under <code>&lt;user-home&gt;/.ssh/authorized_keys</code>.(Citation: SSH Authorized Keys) Users may edit the system’s SSH config file to modify the directives PubkeyAuthentication and RSAAuthentication to the value “yes” to ensure public key and RSA authentication are enabled. The SSH config file is usually located under <code>/etc/ssh/sshd_config</code>." ;
    skos:exactMatch d3f:T1098.004,
        mitre-attack:T1098.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098005 a owl:Class ;
    rdfs:label "T1098_005" ;
    d3f:attack-id "T1098.005" ;
    dcterms:title "Device Registration" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.005" ;
    skos:definition "Adversaries may register a device to an adversary-controlled account. Devices may be registered in a multifactor authentication (MFA) system, which handles authentication to the network, or in a device management system, which handles device access and compliance." ;
    skos:exactMatch d3f:T1098.005,
        mitre-attack:T1098.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098006 a owl:Class ;
    rdfs:label "T1098_006" ;
    d3f:attack-id "T1098.006" ;
    dcterms:title "Additional Container Cluster Roles" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.006" ;
    skos:definition "An adversary may add additional roles or permissions to an adversary-controlled user or service account to maintain persistent access to a container orchestration system. For example, an adversary with sufficient permissions may create a RoleBinding or a ClusterRoleBinding to bind a Role or ClusterRole to a Kubernetes account.(Citation: Kubernetes RBAC)(Citation: Aquasec Kubernetes Attack 2023) Where attribute-based access control (ABAC) is in use, an adversary with sufficient permissions may modify a Kubernetes ABAC policy to give the target account additional permissions.(Citation: Kuberentes ABAC)" ;
    skos:exactMatch d3f:T1098.006,
        mitre-attack:T1098.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1098007 a owl:Class ;
    rdfs:label "T1098_007" ;
    d3f:attack-id "T1098.007" ;
    dcterms:title "Additional Local or Domain Groups" ;
    rdfs:subClassOf d3f:T1098 ;
    skos:altLabel "T1098.007" ;
    skos:definition "An adversary may add additional local or domain groups to an adversary-controlled account to maintain persistent access to a system or domain." ;
    skos:exactMatch d3f:T1098.007,
        mitre-attack:T1098.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1102001 a owl:Class ;
    rdfs:label "T1102_001" ;
    d3f:attack-id "T1102.001" ;
    dcterms:title "Dead Drop Resolver" ;
    rdfs:subClassOf d3f:T1102 ;
    skos:altLabel "T1102.001" ;
    skos:definition "Adversaries may use an existing, legitimate external Web service to host information that points to additional command and control (C2) infrastructure. Adversaries may post content, known as a dead drop resolver, on Web services with embedded (and often obfuscated/encoded) domains or IP addresses. Once infected, victims will reach out to and be redirected by these resolvers." ;
    skos:exactMatch d3f:T1102.001,
        mitre-attack:T1102.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1102002 a owl:Class ;
    rdfs:label "T1102_002" ;
    d3f:attack-id "T1102.002" ;
    dcterms:title "Bidirectional Communication" ;
    rdfs:subClassOf d3f:T1102 ;
    skos:altLabel "T1102.002" ;
    skos:definition "Adversaries may use an existing, legitimate external Web service as a means for sending commands to and receiving output from a compromised system over the Web service channel. Compromised systems may leverage popular websites and social media to host command and control (C2) instructions. Those infected systems can then send the output from those commands back over that Web service channel. The return traffic may occur in a variety of ways, depending on the Web service being utilized. For example, the return traffic may take the form of the compromised system posting a comment on a forum, issuing a pull request to development project, updating a document hosted on a Web service, or by sending a Tweet." ;
    skos:exactMatch d3f:T1102.002,
        mitre-attack:T1102.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1102003 a owl:Class ;
    rdfs:label "T1102_003" ;
    d3f:attack-id "T1102.003" ;
    dcterms:title "One-Way Communication" ;
    rdfs:subClassOf d3f:T1102 ;
    skos:altLabel "T1102.003" ;
    skos:definition "Adversaries may use an existing, legitimate external Web service as a means for sending commands to a compromised system without receiving return output over the Web service channel. Compromised systems may leverage popular websites and social media to host command and control (C2) instructions. Those infected systems may opt to send the output from those commands back over a different C2 channel, including to another distinct Web service. Alternatively, compromised systems may return no output at all in cases where adversaries want to send instructions to systems and do not want a response." ;
    skos:exactMatch d3f:T1102.003,
        mitre-attack:T1102.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1110001 a owl:Class ;
    rdfs:label "T1110_001" ;
    d3f:attack-id "T1110.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Guessing" ;
    rdfs:subClassOf d3f:T1110 ;
    skos:altLabel "T1110.001" ;
    skos:definition "Adversaries with no prior knowledge of legitimate credentials within the system or environment may guess passwords to attempt access to accounts. Without knowledge of the password for an account, an adversary may opt to systematically guess the password using a repetitive or iterative mechanism. An adversary may guess login credentials without prior knowledge of system or environment passwords during an operation by using a list of common passwords. Password guessing may or may not take into account the target's policies on password complexity or use policies that may lock accounts out after a number of failed attempts." ;
    skos:exactMatch d3f:T1110.001,
        mitre-attack:T1110.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1110002 a owl:Class ;
    rdfs:label "T1110_002" ;
    d3f:attack-id "T1110.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Cracking" ;
    rdfs:subClassOf d3f:T1110 ;
    skos:altLabel "T1110.002" ;
    skos:definition "Adversaries may use password cracking to attempt to recover usable credentials, such as plaintext passwords, when credential material such as password hashes are obtained. [OS Credential Dumping](https://attack.mitre.org/techniques/T1003) can be used to obtain password hashes, this may only get an adversary so far when [Pass the Hash](https://attack.mitre.org/techniques/T1550/002) is not an option. Further,  adversaries may leverage [Data from Configuration Repository](https://attack.mitre.org/techniques/T1602) in order to obtain hashed credentials for network devices.(Citation: US-CERT-TA18-106A)" ;
    skos:exactMatch d3f:T1110.002,
        mitre-attack:T1110.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1110003 a owl:Class ;
    rdfs:label "T1110_003" ;
    d3f:attack-id "T1110.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Spraying" ;
    rdfs:subClassOf d3f:T1110 ;
    skos:altLabel "T1110.003" ;
    skos:definition "Adversaries may use a single or small list of commonly used passwords against many different accounts to attempt to acquire valid account credentials. Password spraying uses one password (e.g. 'Password01'), or a small list of commonly used passwords, that may match the complexity policy of the domain. Logins are attempted with that password against many different accounts on a network to avoid account lockouts that would normally occur when brute forcing a single account with many passwords. (Citation: BlackHillsInfosec Password Spraying)" ;
    skos:exactMatch d3f:T1110.003,
        mitre-attack:T1110.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1110004 a owl:Class ;
    rdfs:label "T1110_004" ;
    d3f:attack-id "T1110.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Stuffing" ;
    rdfs:subClassOf d3f:T1110 ;
    skos:altLabel "T1110.004" ;
    skos:definition "Adversaries may use credentials obtained from breach dumps of unrelated accounts to gain access to target accounts through credential overlap. Occasionally, large numbers of username and password pairs are dumped online when a website or service is compromised and the user account credentials accessed. The information may be useful to an adversary attempting to compromise accounts by taking advantage of the tendency for users to use the same passwords across personal and business accounts." ;
    skos:exactMatch d3f:T1110.004,
        mitre-attack:T1110.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1114001 a owl:Class ;
    rdfs:label "T1114_001" ;
    d3f:attack-id "T1114.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Email Collection" ;
    rdfs:subClassOf d3f:T1114 ;
    skos:altLabel "T1114.001" ;
    skos:definition "Adversaries may target user email on local systems to collect sensitive information. Files containing email data can be acquired from a user’s local system, such as Outlook storage or cache files." ;
    skos:exactMatch d3f:T1114.001,
        mitre-attack:T1114.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1114002 a owl:Class ;
    rdfs:label "T1114_002" ;
    d3f:attack-id "T1114.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Email Collection" ;
    rdfs:subClassOf d3f:T1114 ;
    skos:altLabel "T1114.002" ;
    skos:definition "Adversaries may target an Exchange server, Office 365, or Google Workspace to collect sensitive information. Adversaries may leverage a user's credentials and interact directly with the Exchange server to acquire information from within a network. Adversaries may also access externally facing Exchange services, Office 365, or Google Workspace to access email using credentials or access tokens. Tools such as [MailSniper](https://attack.mitre.org/software/S0413) can be used to automate searches for specific keywords." ;
    skos:exactMatch d3f:T1114.002,
        mitre-attack:T1114.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1114003 a owl:Class ;
    rdfs:label "T1114_003" ;
    d3f:attack-id "T1114.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Email Forwarding Rule" ;
    rdfs:subClassOf d3f:T1114 ;
    skos:altLabel "T1114.003" ;
    skos:definition "Adversaries may setup email forwarding rules to collect sensitive information. Adversaries may abuse email forwarding rules to monitor the activities of a victim, steal information, and further gain intelligence on the victim or the victim’s organization to use as part of further exploits or operations.(Citation: US-CERT TA18-068A 2018) Furthermore, email forwarding rules can allow adversaries to maintain persistent access to victim's emails even after compromised credentials are reset by administrators.(Citation: Pfammatter - Hidden Inbox Rules) Most email clients allow users to create inbox rules for various email functions, including forwarding to a different recipient. These rules may be created through a local email application, a web interface, or by command-line interface. Messages can be forwarded to internal or external recipients, and there are no restrictions limiting the extent of this rule. Administrators may also create forwarding rules for user accounts with the same considerations and outcomes.(Citation: Microsoft Tim McMichael Exchange Mail Forwarding 2)(Citation: Mac Forwarding Rules)" ;
    skos:exactMatch d3f:T1114.003,
        mitre-attack:T1114.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1127001 a owl:Class ;
    rdfs:label "T1127_001" ;
    d3f:attack-id "T1127.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "MSBuild" ;
    rdfs:subClassOf d3f:T1127 ;
    skos:altLabel "T1127.001" ;
    skos:definition "Adversaries may use MSBuild to proxy execution of code through a trusted Windows utility. MSBuild.exe (Microsoft Build Engine) is a software build platform used by Visual Studio. It handles XML formatted project files that define requirements for loading and building various platforms and configurations.(Citation: MSDN MSBuild)" ;
    skos:exactMatch d3f:T1127.001,
        mitre-attack:T1127.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1127002 a owl:Class ;
    rdfs:label "T1127_002" ;
    d3f:attack-id "T1127.002" ;
    dcterms:title "ClickOnce" ;
    rdfs:subClassOf d3f:T1127 ;
    skos:altLabel "T1127.002" ;
    skos:definition "Adversaries may use ClickOnce applications (.appref-ms and .application files) to proxy execution of code through a trusted Windows utility.(Citation: Burke/CISA ClickOnce BlackHat) ClickOnce is a deployment that enables a user to create self-updating Windows-based .NET applications (i.e, .XBAP, .EXE, or .DLL) that install and run from a file share or web page with minimal user interaction. The application launches as a child process of DFSVC.EXE, which is responsible for installing, launching, and updating the application.(Citation: SpectorOps Medium ClickOnce)" ;
    skos:exactMatch d3f:T1127.002,
        mitre-attack:T1127.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1127003 a owl:Class ;
    rdfs:label "T1127_003" ;
    d3f:attack-id "T1127.003" ;
    dcterms:title "JamPlus" ;
    rdfs:subClassOf d3f:T1127 ;
    skos:altLabel "T1127.003" ;
    skos:definition "Adversaries may use `JamPlus` to proxy the execution of a malicious script. `JamPlus` is a build utility tool for code and data build systems. It works with several popular compilers and can be used for generating workspaces in code editors such as Visual Studio.(Citation: JamPlus manual)" ;
    skos:exactMatch d3f:T1127.003,
        mitre-attack:T1127.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1132001 a owl:Class ;
    rdfs:label "T1132_001" ;
    d3f:attack-id "T1132.001" ;
    dcterms:title "Standard Encoding" ;
    rdfs:subClassOf d3f:T1132 ;
    skos:altLabel "T1132.001" ;
    skos:definition "Adversaries may encode data with a standard data encoding system to make the content of command and control traffic more difficult to detect. Command and control (C2) information can be encoded using a standard data encoding system that adheres to existing protocol specifications. Common data encoding schemes include ASCII, Unicode, hexadecimal, Base64, and MIME.(Citation: Wikipedia Binary-to-text Encoding)(Citation: Wikipedia Character Encoding) Some data encoding systems may also result in data compression, such as gzip." ;
    skos:exactMatch d3f:T1132.001,
        mitre-attack:T1132.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1132002 a owl:Class ;
    rdfs:label "T1132_002" ;
    d3f:attack-id "T1132.002" ;
    dcterms:title "Non-Standard Encoding" ;
    rdfs:subClassOf d3f:T1132 ;
    skos:altLabel "T1132.002" ;
    skos:definition "Adversaries may encode data with a non-standard data encoding system to make the content of command and control traffic more difficult to detect. Command and control (C2) information can be encoded using a non-standard data encoding system that diverges from existing protocol specifications. Non-standard data encoding schemes may be based on or related to standard data encoding schemes, such as a modified Base64 encoding for the message body of an HTTP request.(Citation: Wikipedia Binary-to-text Encoding) (Citation: Wikipedia Character Encoding)" ;
    skos:exactMatch d3f:T1132.002,
        mitre-attack:T1132.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1134001 a owl:Class ;
    rdfs:label "T1134_001" ;
    d3f:attack-id "T1134.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Token Impersonation/Theft" ;
    rdfs:subClassOf d3f:T1134 ;
    skos:altLabel "T1134.001" ;
    skos:definition "Adversaries may duplicate then impersonate another user's existing token to escalate privileges and bypass access controls. For example, an adversary can duplicate an existing token using `DuplicateToken` or `DuplicateTokenEx`.(Citation: DuplicateToken function) The token can then be used with `ImpersonateLoggedOnUser` to allow the calling thread to impersonate a logged on user's security context, or with `SetThreadToken` to assign the impersonated token to a thread." ;
    skos:exactMatch d3f:T1134.001,
        mitre-attack:T1134.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1134002 a owl:Class ;
    rdfs:label "T1134_002" ;
    d3f:attack-id "T1134.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Create Process with Token" ;
    rdfs:subClassOf d3f:T1134 ;
    skos:altLabel "T1134.002" ;
    skos:definition "Adversaries may create a new process with an existing token to escalate privileges and bypass access controls. Processes can be created with the token and resulting security context of another user using features such as <code>CreateProcessWithTokenW</code> and <code>runas</code>.(Citation: Microsoft RunAs)" ;
    skos:exactMatch d3f:T1134.002,
        mitre-attack:T1134.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1134003 a owl:Class ;
    rdfs:label "T1134_003" ;
    d3f:attack-id "T1134.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Make and Impersonate Token" ;
    rdfs:subClassOf d3f:T1134 ;
    skos:altLabel "T1134.003" ;
    skos:definition "Adversaries may make new tokens and impersonate users to escalate privileges and bypass access controls. For example, if an adversary has a username and password but the user is not logged onto the system the adversary can then create a logon session for the user using the `LogonUser` function.(Citation: LogonUserW function) The function will return a copy of the new session's access token and the adversary can use `SetThreadToken` to assign the token to a thread." ;
    skos:exactMatch d3f:T1134.003,
        mitre-attack:T1134.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1134004 a owl:Class ;
    rdfs:label "T1134_004" ;
    d3f:attack-id "T1134.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Parent PID Spoofing" ;
    rdfs:subClassOf d3f:T1134 ;
    skos:altLabel "T1134.004" ;
    skos:definition "Adversaries may spoof the parent process identifier (PPID) of a new process to evade process-monitoring defenses or to elevate privileges. New processes are typically spawned directly from their parent, or calling, process unless explicitly specified. One way of explicitly assigning the PPID of a new process is via the <code>CreateProcess</code> API call, which supports a parameter that defines the PPID to use.(Citation: DidierStevens SelectMyParent Nov 2009) This functionality is used by Windows features such as User Account Control (UAC) to correctly set the PPID after a requested elevated process is spawned by SYSTEM (typically via <code>svchost.exe</code> or <code>consent.exe</code>) rather than the current user context.(Citation: Microsoft UAC Nov 2018)" ;
    skos:exactMatch d3f:T1134.004,
        mitre-attack:T1134.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1134005 a owl:Class ;
    rdfs:label "T1134_005" ;
    d3f:attack-id "T1134.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "SID-History Injection" ;
    rdfs:subClassOf d3f:T1134 ;
    skos:altLabel "T1134.005" ;
    skos:definition "Adversaries may use SID-History Injection to escalate privileges and bypass access controls. The Windows security identifier (SID) is a unique value that identifies a user or group account. SIDs are used by Windows security in both security descriptors and access tokens. (Citation: Microsoft SID) An account can hold additional SIDs in the SID-History Active Directory attribute (Citation: Microsoft SID-History Attribute), allowing inter-operable account migration between domains (e.g., all values in SID-History are included in access tokens)." ;
    skos:exactMatch d3f:T1134.005,
        mitre-attack:T1134.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1136001 a owl:Class ;
    rdfs:label "T1136_001" ;
    d3f:attack-id "T1136.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Account" ;
    rdfs:subClassOf d3f:T1136 ;
    skos:altLabel "T1136.001" ;
    skos:definition "Adversaries may create a local account to maintain access to victim systems. Local accounts are those configured by an organization for use by users, remote support, services, or for administration on a single system or service." ;
    skos:exactMatch d3f:T1136.001,
        mitre-attack:T1136.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1136002 a owl:Class ;
    rdfs:label "T1136_002" ;
    d3f:attack-id "T1136.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Account" ;
    rdfs:subClassOf d3f:T1136 ;
    skos:altLabel "T1136.002" ;
    skos:definition "Adversaries may create a domain account to maintain access to victim systems. Domain accounts are those managed by Active Directory Domain Services where access and permissions are configured across systems and services that are part of that domain. Domain accounts can cover user, administrator, and service accounts. With a sufficient level of access, the <code>net user /add /domain</code> command can be used to create a domain account.(Citation: Savill 1999)" ;
    skos:exactMatch d3f:T1136.002,
        mitre-attack:T1136.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1136003 a owl:Class ;
    rdfs:label "T1136_003" ;
    d3f:attack-id "T1136.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Account" ;
    rdfs:subClassOf d3f:T1136 ;
    skos:altLabel "T1136.003" ;
    skos:definition "Adversaries may create a cloud account to maintain access to victim systems. With a sufficient level of access, such accounts may be used to establish secondary credentialed access that does not require persistent remote access tools to be deployed on the system.(Citation: Microsoft O365 Admin Roles)(Citation: Microsoft Support O365 Add Another Admin, October 2019)(Citation: AWS Create IAM User)(Citation: GCP Create Cloud Identity Users)(Citation: Microsoft Azure AD Users)" ;
    skos:exactMatch d3f:T1136.003,
        mitre-attack:T1136.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1137001 a owl:Class ;
    rdfs:label "T1137_001" ;
    d3f:attack-id "T1137.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Office Template Macros" ;
    rdfs:subClassOf d3f:T1137 ;
    skos:altLabel "T1137.001" ;
    skos:definition "Adversaries may abuse Microsoft Office templates to obtain persistence on a compromised system. Microsoft Office contains templates that are part of common Office applications and are used to customize styles. The base templates within the application are used each time an application starts. (Citation: Microsoft Change Normal Template)" ;
    skos:exactMatch d3f:T1137.001,
        mitre-attack:T1137.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1137002 a owl:Class ;
    rdfs:label "T1137_002" ;
    d3f:attack-id "T1137.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Office Test" ;
    rdfs:subClassOf d3f:T1137 ;
    skos:altLabel "T1137.002" ;
    skos:definition "Adversaries may abuse the Microsoft Office \"Office Test\" Registry key to obtain persistence on a compromised system. An Office Test Registry location exists that allows a user to specify an arbitrary DLL that will be executed every time an Office application is started. This Registry key is thought to be used by Microsoft to load DLLs for testing and debugging purposes while developing Office applications. This Registry key is not created by default during an Office installation.(Citation: Hexacorn Office Test)(Citation: Palo Alto Office Test Sofacy)" ;
    skos:exactMatch d3f:T1137.002,
        mitre-attack:T1137.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1137003 a owl:Class ;
    rdfs:label "T1137_003" ;
    d3f:attack-id "T1137.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outlook Forms" ;
    rdfs:subClassOf d3f:T1137 ;
    skos:altLabel "T1137.003" ;
    skos:definition "Adversaries may abuse Microsoft Outlook forms to obtain persistence on a compromised system. Outlook forms are used as templates for presentation and functionality in Outlook messages. Custom Outlook forms can be created that will execute code when a specifically crafted email is sent by an adversary utilizing the same custom Outlook form.(Citation: SensePost Outlook Forms)" ;
    skos:exactMatch d3f:T1137.003,
        mitre-attack:T1137.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1137004 a owl:Class ;
    rdfs:label "T1137_004" ;
    d3f:attack-id "T1137.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outlook Home Page" ;
    rdfs:subClassOf d3f:T1137 ;
    skos:altLabel "T1137.004" ;
    skos:definition "Adversaries may abuse Microsoft Outlook's Home Page feature to obtain persistence on a compromised system. Outlook Home Page is a legacy feature used to customize the presentation of Outlook folders. This feature allows for an internal or external URL to be loaded and presented whenever a folder is opened. A malicious HTML page can be crafted that will execute code when loaded by Outlook Home Page.(Citation: SensePost Outlook Home Page)" ;
    skos:exactMatch d3f:T1137.004,
        mitre-attack:T1137.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1137005 a owl:Class ;
    rdfs:label "T1137_005" ;
    d3f:attack-id "T1137.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outlook Rules" ;
    rdfs:subClassOf d3f:T1137 ;
    skos:altLabel "T1137.005" ;
    skos:definition "Adversaries may abuse Microsoft Outlook rules to obtain persistence on a compromised system. Outlook rules allow a user to define automated behavior to manage email messages. A benign rule might, for example, automatically move an email to a particular folder in Outlook if it contains specific words from a specific sender. Malicious Outlook rules can be created that can trigger code execution when an adversary sends a specifically crafted email to that user.(Citation: SilentBreak Outlook Rules)" ;
    skos:exactMatch d3f:T1137.005,
        mitre-attack:T1137.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1137006 a owl:Class ;
    rdfs:label "T1137_006" ;
    d3f:attack-id "T1137.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Add-ins" ;
    rdfs:subClassOf d3f:T1137 ;
    skos:altLabel "T1137.006" ;
    skos:definition "Adversaries may abuse Microsoft Office add-ins to obtain persistence on a compromised system. Office add-ins can be used to add functionality to Office programs. (Citation: Microsoft Office Add-ins) There are different types of add-ins that can be used by the various Office products; including Word/Excel add-in Libraries (WLL/XLL), VBA add-ins, Office Component Object Model (COM) add-ins, automation add-ins, VBA Editor (VBE), Visual Studio Tools for Office (VSTO) add-ins, and Outlook add-ins. (Citation: MRWLabs Office Persistence Add-ins)(Citation: FireEye Mail CDS 2018)" ;
    skos:exactMatch d3f:T1137.006,
        mitre-attack:T1137.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1176001 a owl:Class ;
    rdfs:label "T1176_001" ;
    d3f:attack-id "T1176.001" ;
    dcterms:title "Browser Extensions" ;
    rdfs:subClassOf d3f:T1176 ;
    skos:altLabel "T1176.001" ;
    skos:definition "Adversaries may abuse internet browser extensions to establish persistent access to victim systems. Browser extensions or plugins are small programs that can add functionality to and customize aspects of internet browsers. They can be installed directly via a local file or custom URL or through a browser's app store - an official online platform where users can browse, install, and manage extensions for a specific web browser. Extensions generally inherit the web browser's permissions previously granted.(Citation: Wikipedia Browser Extension)(Citation: Chrome Extensions Definition)" ;
    skos:exactMatch d3f:T1176.001,
        mitre-attack:T1176.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1176002 a owl:Class ;
    rdfs:label "T1176_002" ;
    d3f:attack-id "T1176.002" ;
    dcterms:title "IDE Extensions" ;
    rdfs:subClassOf d3f:T1176 ;
    skos:altLabel "T1176.002" ;
    skos:definition "Adversaries may abuse an integrated development environment (IDE) extension to establish persistent access to victim systems.(Citation: Mnemonic misuse visual studio) IDEs such as Visual Studio Code, IntelliJ IDEA, and Eclipse support extensions - software components that add features like code linting, auto-completion, task automation, or integration with tools like Git and Docker. A malicious extension can be installed through an extension marketplace (i.e., [Compromise Software Dependencies and Development Tools](https://attack.mitre.org/techniques/T1195/001)) or side-loaded directly into the IDE.(Citation: Abramovsky VSCode Security)(Citation: Lakshmanan Visual Studio Marketplace)" ;
    skos:exactMatch d3f:T1176.002,
        mitre-attack:T1176.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1195001 a owl:Class ;
    rdfs:label "T1195_001" ;
    d3f:attack-id "T1195.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compromise Software Dependencies and Development Tools" ;
    rdfs:subClassOf d3f:T1195 ;
    skos:altLabel "T1195.001" ;
    skos:definition "Adversaries may manipulate software dependencies and development tools prior to receipt by a final consumer for the purpose of data or system compromise. Applications often depend on external software to function properly. Popular open source projects that are used as dependencies in many applications may be targeted as a means to add malicious code to users of the dependency.(Citation: Trendmicro NPM Compromise)" ;
    skos:exactMatch d3f:T1195.001,
        mitre-attack:T1195.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1195002 a owl:Class ;
    rdfs:label "T1195_002" ;
    d3f:attack-id "T1195.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compromise Software Supply Chain" ;
    rdfs:subClassOf d3f:T1195 ;
    skos:altLabel "T1195.002" ;
    skos:definition "Adversaries may manipulate application software prior to receipt by a final consumer for the purpose of data or system compromise. Supply chain compromise of software can take place in a number of ways, including manipulation of the application source code, manipulation of the update/distribution mechanism for that software, or replacing compiled releases with a modified version." ;
    skos:exactMatch d3f:T1195.002,
        mitre-attack:T1195.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1195003 a owl:Class ;
    rdfs:label "T1195_003" ;
    d3f:attack-id "T1195.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compromise Hardware Supply Chain" ;
    rdfs:subClassOf d3f:T1195 ;
    skos:altLabel "T1195.003" ;
    skos:definition "Adversaries may manipulate hardware components in products prior to receipt by a final consumer for the purpose of data or system compromise. By modifying hardware or firmware in the supply chain, adversaries can insert a backdoor into consumer networks that may be difficult to detect and give the adversary a high degree of control over the system. Hardware backdoors may be inserted into various devices, such as servers, workstations, network infrastructure, or peripherals." ;
    skos:exactMatch d3f:T1195.003,
        mitre-attack:T1195.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1204001 a owl:Class ;
    rdfs:label "T1204_001" ;
    d3f:attack-id "T1204.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Malicious Link" ;
    rdfs:subClassOf d3f:T1204 ;
    skos:altLabel "T1204.001" ;
    skos:definition "An adversary may rely upon a user clicking a malicious link in order to gain execution. Users may be subjected to social engineering to get them to click on a link that will lead to code execution. This user action will typically be observed as follow-on behavior from [Spearphishing Link](https://attack.mitre.org/techniques/T1566/002). Clicking on a link may also lead to other execution techniques such as exploitation of a browser or application vulnerability via [Exploitation for Client Execution](https://attack.mitre.org/techniques/T1203). Links may also lead users to download files that require execution via [Malicious File](https://attack.mitre.org/techniques/T1204/002)." ;
    skos:exactMatch d3f:T1204.001,
        mitre-attack:T1204.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1204002 a owl:Class ;
    rdfs:label "T1204_002" ;
    d3f:attack-id "T1204.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Malicious File" ;
    rdfs:subClassOf d3f:T1204 ;
    skos:altLabel "T1204.002" ;
    skos:definition "An adversary may rely upon a user opening a malicious file in order to gain execution. Users may be subjected to social engineering to get them to open a file that will lead to code execution. This user action will typically be observed as follow-on behavior from [Spearphishing Attachment](https://attack.mitre.org/techniques/T1566/001). Adversaries may use several types of files that require a user to execute them, including .doc, .pdf, .xls, .rtf, .scr, .exe, .lnk, .pif, and .cpl." ;
    skos:exactMatch d3f:T1204.002,
        mitre-attack:T1204.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1204003 a owl:Class ;
    rdfs:label "T1204_003" ;
    d3f:attack-id "T1204.003" ;
    dcterms:title "Malicious Image" ;
    rdfs:subClassOf d3f:T1204 ;
    skos:altLabel "T1204.003" ;
    skos:definition "Adversaries may rely on a user running a malicious image to facilitate execution. Amazon Web Services (AWS) Amazon Machine Images (AMIs), Google Cloud Platform (GCP) Images, and Azure Images as well as popular container runtimes such as Docker can be backdoored. Backdoored images may be uploaded to a public repository via [Upload Malware](https://attack.mitre.org/techniques/T1608/001), and users may then download and deploy an instance or container from the image without realizing the image is malicious, thus bypassing techniques that specifically achieve Initial Access. This can lead to the execution of malicious code, such as code that executes cryptocurrency mining, in the instance or container.(Citation: Summit Route Malicious AMIs)" ;
    skos:exactMatch d3f:T1204.003,
        mitre-attack:T1204.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1204004 a owl:Class ;
    rdfs:label "T1204_004" ;
    d3f:attack-id "T1204.004" ;
    dcterms:title "Malicious Copy and Paste" ;
    rdfs:subClassOf d3f:T1204 ;
    skos:altLabel "T1204.004" ;
    skos:definition "An adversary may rely upon a user copying and pasting code in order to gain execution. Users may be subjected to social engineering to get them to copy and paste code directly into a [Command and Scripting Interpreter](https://attack.mitre.org/techniques/T1059)." ;
    skos:exactMatch d3f:T1204.004,
        mitre-attack:T1204.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1204005 a owl:Class ;
    rdfs:label "T1204_005" ;
    d3f:attack-id "T1204.005" ;
    dcterms:title "Malicious Library" ;
    rdfs:subClassOf d3f:T1204 ;
    skos:altLabel "T1204.005" ;
    skos:definition "Adversaries may rely on a user installing a malicious library to facilitate execution. Threat actors may [Upload Malware](https://attack.mitre.org/techniques/T1608/001) to package managers such as NPM and PyPi, as well as to public code repositories such as GitHub. User may install libraries without realizing they are malicious, thus bypassing techniques that specifically achieve Initial Access. This can lead to the execution of malicious code, such as code that establishes persistence, steals data, or mines cryptocurrency.(Citation: Datadog Security Labs Malicious PyPi Packages 2024)(Citation: Fortinet Malicious NPM Packages 2023)" ;
    skos:exactMatch d3f:T1204.005,
        mitre-attack:T1204.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1205001 a owl:Class ;
    rdfs:label "T1205_001" ;
    d3f:attack-id "T1205.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Port Knocking" ;
    rdfs:subClassOf d3f:T1205 ;
    skos:altLabel "T1205.001" ;
    skos:definition "Adversaries may use port knocking to hide open ports used for persistence or command and control. To enable a port, an adversary sends a series of attempted connections to a predefined sequence of closed ports. After the sequence is completed, opening a port is often accomplished by the host based firewall, but could also be implemented by custom software." ;
    skos:exactMatch d3f:T1205.001,
        mitre-attack:T1205.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1205002 a owl:Class ;
    rdfs:label "T1205_002" ;
    d3f:attack-id "T1205.002" ;
    dcterms:title "Socket Filters" ;
    rdfs:subClassOf d3f:T1205 ;
    skos:altLabel "T1205.002" ;
    skos:definition "Adversaries may attach filters to a network socket to monitor then activate backdoors used for persistence or command and control. With elevated permissions, adversaries can use features such as the `libpcap` library to open sockets and install filters to allow or disallow certain types of data to come through the socket. The filter may apply to all traffic passing through the specified network interface (or every interface if not specified). When the network interface receives a packet matching the filter criteria, additional actions can be triggered on the host, such as activation of a reverse shell." ;
    skos:exactMatch d3f:T1205.002,
        mitre-attack:T1205.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213001 a owl:Class ;
    rdfs:label "T1213_001" ;
    d3f:attack-id "T1213.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Confluence" ;
    rdfs:subClassOf d3f:T1213 ;
    skos:altLabel "T1213.001" ;
    skos:definition "Adversaries may leverage Confluence repositories to mine valuable information. Often found in development environments alongside Atlassian JIRA, Confluence is generally used to store development-related documentation, however, in general may contain more diverse categories of useful information, such as:" ;
    skos:exactMatch d3f:T1213.001,
        mitre-attack:T1213.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213002 a owl:Class ;
    rdfs:label "T1213_002" ;
    d3f:attack-id "T1213.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Sharepoint" ;
    rdfs:subClassOf d3f:T1213 ;
    skos:altLabel "T1213.002" ;
    skos:definition "Adversaries may leverage the SharePoint repository as a source to mine valuable information. SharePoint will often contain useful information for an adversary to learn about the structure and functionality of the internal network and systems. For example, the following is a list of example information that may hold potential value to an adversary and may also be found on SharePoint:" ;
    skos:exactMatch d3f:T1213.002,
        mitre-attack:T1213.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213003 a owl:Class ;
    rdfs:label "T1213_003" ;
    d3f:attack-id "T1213.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Code Repositories" ;
    rdfs:subClassOf d3f:T1213 ;
    skos:altLabel "T1213.003" ;
    skos:definition "Adversaries may leverage code repositories to collect valuable information. Code repositories are tools/services that store source code and automate software builds. They may be hosted internally or privately on third party sites such as Github, GitLab, SourceForge, and BitBucket. Users typically interact with code repositories through a web application or command-line utilities such as git." ;
    skos:exactMatch d3f:T1213.003,
        mitre-attack:T1213.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213004 a owl:Class ;
    rdfs:label "T1213_004" ;
    d3f:attack-id "T1213.004" ;
    dcterms:title "Customer Relationship Management Software" ;
    rdfs:subClassOf d3f:T1213 ;
    skos:altLabel "T1213.004" ;
    skos:definition "Adversaries may leverage Customer Relationship Management (CRM) software to mine valuable information. CRM software is used to assist organizations in tracking and managing customer interactions, as well as storing customer data." ;
    skos:exactMatch d3f:T1213.004,
        mitre-attack:T1213.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213005 a owl:Class ;
    rdfs:label "T1213_005" ;
    d3f:attack-id "T1213.005" ;
    dcterms:title "Messaging Applications" ;
    rdfs:subClassOf d3f:T1213 ;
    skos:altLabel "T1213.005" ;
    skos:definition "Adversaries may leverage chat and messaging applications, such as Microsoft Teams, Google Chat, and Slack, to mine valuable information." ;
    skos:exactMatch d3f:T1213.005,
        mitre-attack:T1213.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213006 a owl:Class ;
    rdfs:label "T1213_006" ;
    d3f:attack-id "T1213.006" ;
    dcterms:title "Databases" ;
    rdfs:subClassOf d3f:T1213 ;
    skos:altLabel "T1213.006" ;
    skos:definition "Adversaries may leverage databases to mine valuable information. These databases may be hosted on-premises or in the cloud (both in platform-as-a-service and software-as-a-service environments)." ;
    skos:exactMatch d3f:T1213.006,
        mitre-attack:T1213.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1216001 a owl:Class ;
    rdfs:label "T1216_001" ;
    d3f:attack-id "T1216.001" ;
    dcterms:title "PubPrn" ;
    rdfs:subClassOf d3f:T1216 ;
    skos:altLabel "T1216.001" ;
    skos:definition "Adversaries may use PubPrn to proxy execution of malicious remote files. PubPrn.vbs is a [Visual Basic](https://attack.mitre.org/techniques/T1059/005) script that publishes a printer to Active Directory Domain Services. The script may be signed by Microsoft and is commonly executed through the [Windows Command Shell](https://attack.mitre.org/techniques/T1059/003) via <code>Cscript.exe</code>. For example, the following code publishes a printer within the specified domain: <code>cscript pubprn Printer1 LDAP://CN=Container1,DC=Domain1,DC=Com</code>.(Citation: pubprn)" ;
    skos:exactMatch d3f:T1216.001,
        mitre-attack:T1216.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1216002 a owl:Class ;
    rdfs:label "T1216_002" ;
    d3f:attack-id "T1216.002" ;
    dcterms:title "SyncAppvPublishingServer" ;
    rdfs:subClassOf d3f:T1216 ;
    skos:altLabel "T1216.002" ;
    skos:definition "Adversaries may abuse SyncAppvPublishingServer.vbs to proxy execution of malicious [PowerShell](https://attack.mitre.org/techniques/T1059/001) commands. SyncAppvPublishingServer.vbs is a Visual Basic script associated with how Windows virtualizes applications (Microsoft Application Virtualization, or App-V).(Citation: 1 - appv) For example, Windows may render Win32 applications to users as virtual applications, allowing users to launch and interact with them as if they were installed locally.(Citation: 2 - appv)(Citation: 3 - appv)" ;
    skos:exactMatch d3f:T1216.002,
        mitre-attack:T1216.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218001 a owl:Class ;
    rdfs:label "T1218_001" ;
    d3f:attack-id "T1218.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compiled HTML File" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.001" ;
    skos:definition "Adversaries may abuse Compiled HTML files (.chm) to conceal malicious code. CHM files are commonly distributed as part of the Microsoft HTML Help system. CHM files are compressed compilations of various content such as HTML documents, images, and scripting/web related programming languages such VBA, JScript, Java, and ActiveX. (Citation: Microsoft HTML Help May 2018) CHM content is displayed using underlying components of the Internet Explorer browser (Citation: Microsoft HTML Help ActiveX) loaded by the HTML Help executable program (hh.exe). (Citation: Microsoft HTML Help Executable Program)" ;
    skos:exactMatch d3f:T1218.001,
        mitre-attack:T1218.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218002 a owl:Class ;
    rdfs:label "T1218_002" ;
    d3f:attack-id "T1218.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Control Panel" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.002" ;
    skos:definition "Adversaries may abuse control.exe to proxy execution of malicious payloads. The Windows Control Panel process binary (control.exe) handles execution of Control Panel items, which are utilities that allow users to view and adjust computer settings." ;
    skos:exactMatch d3f:T1218.002,
        mitre-attack:T1218.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218003 a owl:Class ;
    rdfs:label "T1218_003" ;
    d3f:attack-id "T1218.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "CMSTP" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.003" ;
    skos:definition "Adversaries may abuse CMSTP to proxy execution of malicious code. The Microsoft Connection Manager Profile Installer (CMSTP.exe) is a command-line program used to install Connection Manager service profiles. (Citation: Microsoft Connection Manager Oct 2009) CMSTP.exe accepts an installation information file (INF) as a parameter and installs a service profile leveraged for remote access connections." ;
    skos:exactMatch d3f:T1218.003,
        mitre-attack:T1218.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218004 a owl:Class ;
    rdfs:label "T1218_004" ;
    d3f:attack-id "T1218.004" ;
    dcterms:title "InstallUtil" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.004" ;
    skos:definition "Adversaries may use InstallUtil to proxy execution of code through a trusted Windows utility. InstallUtil is a command-line utility that allows for installation and uninstallation of resources by executing specific installer components specified in .NET binaries. (Citation: MSDN InstallUtil) The InstallUtil binary may also be digitally signed by Microsoft and located in the .NET directories on a Windows system: <code>C:\\Windows\\Microsoft.NET\\Framework\\v<version>\\InstallUtil.exe</code> and <code>C:\\Windows\\Microsoft.NET\\Framework64\\v<version>\\InstallUtil.exe</code>." ;
    skos:exactMatch d3f:T1218.004,
        mitre-attack:T1218.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218005 a owl:Class ;
    rdfs:label "T1218_005" ;
    d3f:attack-id "T1218.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Mshta" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.005" ;
    skos:definition "Adversaries may abuse mshta.exe to proxy execution of malicious .hta files and Javascript or VBScript through a trusted Windows utility. There are several examples of different types of threats leveraging mshta.exe during initial compromise and for execution of code (Citation: Cylance Dust Storm) (Citation: Red Canary HTA Abuse Part Deux) (Citation: FireEye Attacks Leveraging HTA) (Citation: Airbus Security Kovter Analysis) (Citation: FireEye FIN7 April 2017)" ;
    skos:exactMatch d3f:T1218.005,
        mitre-attack:T1218.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218007 a owl:Class ;
    rdfs:label "T1218_007" ;
    d3f:attack-id "T1218.007" ;
    dcterms:title "Msiexec" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.007" ;
    skos:definition "Adversaries may abuse msiexec.exe to proxy execution of malicious payloads. Msiexec.exe is the command-line utility for the Windows Installer and is thus commonly associated with executing installation packages (.msi).(Citation: Microsoft msiexec) The Msiexec.exe binary may also be digitally signed by Microsoft." ;
    skos:exactMatch d3f:T1218.007,
        mitre-attack:T1218.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218008 a owl:Class ;
    rdfs:label "T1218_008" ;
    d3f:attack-id "T1218.008" ;
    dcterms:title "Odbcconf" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.008" ;
    skos:definition "Adversaries may abuse odbcconf.exe to proxy execution of malicious payloads. Odbcconf.exe is a Windows utility that allows you to configure Open Database Connectivity (ODBC) drivers and data source names.(Citation: Microsoft odbcconf.exe) The Odbcconf.exe binary may be digitally signed by Microsoft." ;
    skos:exactMatch d3f:T1218.008,
        mitre-attack:T1218.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218009 a owl:Class ;
    rdfs:label "T1218_009" ;
    d3f:attack-id "T1218.009" ;
    dcterms:title "Regsvcs/Regasm" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.009" ;
    skos:definition "Adversaries may abuse Regsvcs and Regasm to proxy execution of code through a trusted Windows utility. Regsvcs and Regasm are Windows command-line utilities that are used to register .NET [Component Object Model](https://attack.mitre.org/techniques/T1559/001) (COM) assemblies. Both are binaries that may be digitally signed by Microsoft. (Citation: MSDN Regsvcs) (Citation: MSDN Regasm)" ;
    skos:exactMatch d3f:T1218.009,
        mitre-attack:T1218.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218010 a owl:Class ;
    rdfs:label "T1218_010" ;
    d3f:attack-id "T1218.010" ;
    dcterms:title "Regsvr32" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.010" ;
    skos:definition "Adversaries may abuse Regsvr32.exe to proxy execution of malicious code. Regsvr32.exe is a command-line program used to register and unregister object linking and embedding controls, including dynamic link libraries (DLLs), on Windows systems. The Regsvr32.exe binary may also be signed by Microsoft. (Citation: Microsoft Regsvr32)" ;
    skos:exactMatch d3f:T1218.010,
        mitre-attack:T1218.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218011 a owl:Class ;
    rdfs:label "T1218_011" ;
    d3f:attack-id "T1218.011" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Rundll32" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.011" ;
    skos:definition "Adversaries may abuse rundll32.exe to proxy execution of malicious code. Using rundll32.exe, vice executing directly (i.e. [Shared Modules](https://attack.mitre.org/techniques/T1129)), may avoid triggering security tools that may not monitor execution of the rundll32.exe process because of allowlists or false positives from normal operations. Rundll32.exe is commonly associated with executing DLL payloads (ex: <code>rundll32.exe {DLLname, DLLfunction}</code>)." ;
    skos:exactMatch d3f:T1218.011,
        mitre-attack:T1218.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218012 a owl:Class ;
    rdfs:label "T1218_012" ;
    d3f:attack-id "T1218.012" ;
    dcterms:title "Verclsid" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.012" ;
    skos:definition "Adversaries may abuse verclsid.exe to proxy execution of malicious code. Verclsid.exe is known as the Extension CLSID Verification Host and is responsible for verifying each shell extension before they are used by Windows Explorer or the Windows Shell.(Citation: WinOSBite verclsid.exe)" ;
    skos:exactMatch d3f:T1218.012,
        mitre-attack:T1218.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218013 a owl:Class ;
    rdfs:label "T1218_013" ;
    d3f:attack-id "T1218.013" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Mavinject" ;
    rdfs:seeAlso <https://posts.specterops.io/mavinject-exe-functionality-deconstructed-c29ab2cf5c0e> ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.013" ;
    skos:definition "Adversaries may abuse mavinject.exe to proxy execution of malicious code. Mavinject.exe is the Microsoft Application Virtualization Injector, a Windows utility that can inject code into external processes as part of Microsoft Application Virtualization (App-V).(Citation: LOLBAS Mavinject)" ;
    skos:exactMatch d3f:T1218.013,
        mitre-attack:T1218.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218014 a owl:Class ;
    rdfs:label "T1218_014" ;
    d3f:attack-id "T1218.014" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "MMC" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.014" ;
    skos:definition "Adversaries may abuse mmc.exe to proxy execution of malicious .msc files. Microsoft Management Console (MMC) is a binary that may be signed by Microsoft and is used in several ways in either its GUI or in a command prompt.(Citation: win_mmc)(Citation: what_is_mmc) MMC can be used to create, open, and save custom consoles that contain administrative tools created by Microsoft, called snap-ins. These snap-ins may be used to manage Windows systems locally or remotely. MMC can also be used to open Microsoft created .msc files to manage system configuration.(Citation: win_msc_files_overview)" ;
    skos:exactMatch d3f:T1218.014,
        mitre-attack:T1218.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1218015 a owl:Class ;
    rdfs:label "T1218_015" ;
    d3f:attack-id "T1218.015" ;
    dcterms:title "Electron Applications" ;
    rdfs:subClassOf d3f:T1218 ;
    skos:altLabel "T1218.015" ;
    skos:definition "Adversaries may abuse components of the Electron framework to execute malicious code. The Electron framework hosts many common applications such as Signal, Slack, and Microsoft Teams.(Citation: Electron 2) Originally developed by GitHub, Electron is a cross-platform desktop application development framework that employs web technologies like JavaScript, HTML, and CSS.(Citation: Electron 3) The Chromium engine is used to display web content and Node.js runs the backend code.(Citation: Electron 1)" ;
    skos:exactMatch d3f:T1218.015,
        mitre-attack:T1218.015 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1219001 a owl:Class ;
    rdfs:label "T1219_001" ;
    d3f:attack-id "T1219.001" ;
    dcterms:title "IDE Tunneling" ;
    rdfs:subClassOf d3f:T1219 ;
    skos:altLabel "T1219.001" ;
    skos:definition "Adversaries may abuse Integrated Development Environment (IDE) software with remote development features to establish an interactive command and control channel on target systems within a network. IDE tunneling combines SSH, port forwarding, file sharing, and debugging into a single secure connection, letting developers work on remote systems as if they were local. Unlike SSH and port forwarding, IDE tunneling encapsulates an entire session and may use proprietary tunneling protocols alongside SSH, allowing adversaries to blend in with legitimate development workflows. Some IDEs, like Visual Studio Code, also provide CLI tools (e.g., `code tunnel`) that adversaries may use to programmatically establish tunnels and generate web-accessible URLs for remote access. These tunnels can be authenticated through accounts such as GitHub, enabling the adversary to control the compromised system via a legitimate developer portal.(Citation: sentinelone operationDigitalEye Dec 2024)(Citation: Unit42 Chinese VSCode 06 September 2024)(Citation: Thornton tutorial VSCode shell September 2023)" ;
    skos:exactMatch d3f:T1219.001,
        mitre-attack:T1219.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1219002 a owl:Class ;
    rdfs:label "T1219_002" ;
    d3f:attack-id "T1219.002" ;
    dcterms:title "Remote Desktop Software" ;
    rdfs:subClassOf d3f:T1219 ;
    skos:altLabel "T1219.002" ;
    skos:definition "An adversary may use legitimate desktop support software to establish an interactive command and control channel to target systems within networks. Desktop support software provides a graphical interface for remotely controlling another computer, transmitting the display output, keyboard input, and mouse control between devices using various protocols. Desktop support software, such as `VNC`, `Team Viewer`, `AnyDesk`, `ScreenConnect`, `LogMein`, `AmmyyAdmin`, and other remote monitoring and management (RMM) tools, are commonly used as legitimate technical support software and may be allowed by application control within a target environment.(Citation: Symantec Living off the Land)(Citation: CrowdStrike 2015 Global Threat Report)(Citation: CrySyS Blog TeamSpy)" ;
    skos:exactMatch d3f:T1219.002,
        mitre-attack:T1219.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1219003 a owl:Class ;
    rdfs:label "T1219_003" ;
    d3f:attack-id "T1219.003" ;
    dcterms:title "Remote Access Hardware" ;
    rdfs:subClassOf d3f:T1219 ;
    skos:altLabel "T1219.003" ;
    skos:definition "An adversary may use legitimate remote access hardware to establish an interactive command and control channel to target systems within networks. These services, including IP-based keyboard, video, or mouse (KVM) devices such as TinyPilot and PiKVM, are commonly used as legitimate tools and may be allowed by peripheral device policies within a target environment." ;
    skos:exactMatch d3f:T1219.003,
        mitre-attack:T1219.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1222001 a owl:Class ;
    rdfs:label "T1222_001" ;
    d3f:attack-id "T1222.001" ;
    dcterms:title "Windows File and Directory Permissions Modification" ;
    rdfs:subClassOf d3f:T1222 ;
    skos:altLabel "T1222.001" ;
    skos:definition "Adversaries may modify file or directory permissions/attributes to evade access control lists (ACLs) and access protected files.(Citation: Hybrid Analysis Icacls1 June 2018)(Citation: Hybrid Analysis Icacls2 May 2018) File and directory permissions are commonly managed by ACLs configured by the file or directory owner, or users with the appropriate permissions. File and directory ACL implementations vary by platform, but generally explicitly designate which users or groups can perform which actions (read, write, execute, etc.)." ;
    skos:exactMatch d3f:T1222.001,
        mitre-attack:T1222.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1222002 a owl:Class ;
    rdfs:label "T1222_002" ;
    d3f:attack-id "T1222.002" ;
    dcterms:title "Linux and Mac File and Directory Permissions Modification" ;
    rdfs:subClassOf d3f:T1222 ;
    skos:altLabel "T1222.002" ;
    skos:definition "Adversaries may modify file or directory permissions/attributes to evade access control lists (ACLs) and access protected files.(Citation: Hybrid Analysis Icacls1 June 2018)(Citation: Hybrid Analysis Icacls2 May 2018) File and directory permissions are commonly managed by ACLs configured by the file or directory owner, or users with the appropriate permissions. File and directory ACL implementations vary by platform, but generally explicitly designate which users or groups can perform which actions (read, write, execute, etc.)." ;
    skos:exactMatch d3f:T1222.002,
        mitre-attack:T1222.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1406001 a owl:Class ;
    rdfs:label "T1406_001" ;
    d3f:attack-id "T1406.001" ;
    dcterms:title "Steganography" ;
    rdfs:subClassOf d3f:T1406 ;
    skos:altLabel "T1406.001" ;
    skos:definition "Adversaries may use steganography techniques in order to prevent the detection of hidden information. Steganographic techniques can be used to hide data in digital media such as images, audio tracks, video clips, or text files." ;
    skos:exactMatch d3f:T1406.001,
        mitre-attack:T1406.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1406002 a owl:Class ;
    rdfs:label "T1406_002" ;
    d3f:attack-id "T1406.002" ;
    dcterms:title "Software Packing" ;
    rdfs:subClassOf d3f:T1406 ;
    skos:altLabel "T1406.002" ;
    skos:definition "Adversaries may perform software packing to conceal their code. Software packing is a method of compressing or encrypting an executable. Packing an executable changes the file signature in an attempt to avoid signature-based detection. Most decompression techniques decompress the executable code in memory." ;
    skos:exactMatch d3f:T1406.002,
        mitre-attack:T1406.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1417001 a owl:Class ;
    rdfs:label "T1417_001" ;
    d3f:attack-id "T1417.001" ;
    dcterms:title "Keylogging" ;
    rdfs:subClassOf d3f:T1417 ;
    skos:altLabel "T1417.001" ;
    skos:definition "Adversaries may log user keystrokes to intercept credentials or other information from the user as the user types them." ;
    skos:exactMatch d3f:T1417.001,
        mitre-attack:T1417.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1417002 a owl:Class ;
    rdfs:label "T1417_002" ;
    d3f:attack-id "T1417.002" ;
    dcterms:title "GUI Input Capture" ;
    rdfs:subClassOf d3f:T1417 ;
    skos:altLabel "T1417.002" ;
    skos:definition "Adversaries may mimic common operating system GUI components to prompt users for sensitive information with a seemingly legitimate prompt. The operating system and installed applications often have legitimate needs to prompt the user for sensitive information such as account credentials, bank account information, or Personally Identifiable Information (PII). Compared to traditional PCs, the constrained display size of mobile devices may impair the ability to provide users with contextual information, making users more susceptible to this technique’s use.(Citation: Felt-PhishingOnMobileDevices)" ;
    skos:exactMatch d3f:T1417.002,
        mitre-attack:T1417.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1418001 a owl:Class ;
    rdfs:label "T1418_001" ;
    d3f:attack-id "T1418.001" ;
    dcterms:title "Security Software Discovery" ;
    rdfs:subClassOf d3f:T1418 ;
    skos:altLabel "T1418.001" ;
    skos:definition "Adversaries may attempt to get a listing of security applications and configurations that are installed on a device. This may include things such as mobile security products. Adversaries may use the information from [Security Software Discovery](https://attack.mitre.org/techniques/T1418/001) during automated discovery to shape follow-on behaviors, including whether or not to fully infect the target and/or attempt specific actions." ;
    skos:exactMatch d3f:T1418.001,
        mitre-attack:T1418.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1422001 a owl:Class ;
    rdfs:label "T1422_001" ;
    d3f:attack-id "T1422.001" ;
    dcterms:title "Internet Connection Discovery" ;
    rdfs:subClassOf d3f:T1422 ;
    skos:altLabel "T1422.001" ;
    skos:definition "Adversaries may check for Internet connectivity on compromised systems. This may be performed during automated discovery and can be accomplished in numerous ways such as using `adb shell netstat` for Android.(Citation: adb_commands)" ;
    skos:exactMatch d3f:T1422.001,
        mitre-attack:T1422.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1422002 a owl:Class ;
    rdfs:label "T1422_002" ;
    d3f:attack-id "T1422.002" ;
    dcterms:title "Wi-Fi Discovery" ;
    rdfs:subClassOf d3f:T1422 ;
    skos:altLabel "T1422.002" ;
    skos:definition "Adversaries may search for information about Wi-Fi networks, such as network names and passwords, on compromised systems. Adversaries may use Wi-Fi information as part of [Discovery](https://attack.mitre.org/tactics/TA0032) or [Credential Access](https://attack.mitre.org/tactics/TA0031) activity to support both ongoing and future campaigns." ;
    skos:exactMatch d3f:T1422.002,
        mitre-attack:T1422.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1430001 a owl:Class ;
    rdfs:label "T1430_001" ;
    d3f:attack-id "T1430.001" ;
    dcterms:title "Remote Device Management Services" ;
    rdfs:subClassOf d3f:T1430 ;
    skos:altLabel "T1430.001" ;
    skos:definition "An adversary may use access to cloud services (e.g. Google's Android Device Manager or Apple iCloud's Find my iPhone) or to an enterprise mobility management (EMM)/mobile device management (MDM) server console to track the location of mobile devices managed by the service.(Citation: Krebs-Location)" ;
    skos:exactMatch d3f:T1430.001,
        mitre-attack:T1430.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1430002 a owl:Class ;
    rdfs:label "T1430_002" ;
    d3f:attack-id "T1430.002" ;
    dcterms:title "Impersonate SS7 Nodes" ;
    rdfs:subClassOf d3f:T1430 ;
    skos:altLabel "T1430.002" ;
    skos:definition "Adversaries may exploit the lack of authentication in signaling system network nodes to track the location of mobile devices by impersonating a node.(Citation: Engel-SS7)(Citation: Engel-SS7-2008)(Citation: 3GPP-Security)(Citation: Positive-SS7)(Citation: CSRIC5-WG10-FinalReport)" ;
    skos:exactMatch d3f:T1430.002,
        mitre-attack:T1430.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1437001 a owl:Class ;
    rdfs:label "T1437_001" ;
    d3f:attack-id "T1437.001" ;
    dcterms:title "Web Protocols" ;
    rdfs:subClassOf d3f:T1437 ;
    skos:altLabel "T1437.001" ;
    skos:definition "Adversaries may communicate using application layer protocols associated with web protocols traffic to avoid detection/network filtering by blending in with existing traffic. Commands to remote mobile devices, and often the results of those commands, will be embedded within the protocol traffic between the mobile client and server." ;
    skos:exactMatch d3f:T1437.001,
        mitre-attack:T1437.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1474001 a owl:Class ;
    rdfs:label "T1474_001" ;
    d3f:attack-id "T1474.001" ;
    dcterms:title "Compromise Software Dependencies and Development Tools" ;
    rdfs:subClassOf d3f:T1474 ;
    skos:altLabel "T1474.001" ;
    skos:definition "Adversaries may manipulate products or product delivery mechanisms prior to receipt by a final consumer for the purpose of data or system compromise. Applications often depend on external software to function properly. Popular open source projects that are used as dependencies in many applications may be targeted as a means to add malicious code to users of the dependency.(Citation: Grace-Advertisement)" ;
    skos:exactMatch d3f:T1474.001,
        mitre-attack:T1474.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1474002 a owl:Class ;
    rdfs:label "T1474_002" ;
    d3f:attack-id "T1474.002" ;
    dcterms:title "Compromise Hardware Supply Chain" ;
    rdfs:subClassOf d3f:T1474 ;
    skos:altLabel "T1474.002" ;
    skos:definition "Adversaries may manipulate hardware components in products prior to receipt by a final consumer for the purpose of data or system compromise. By modifying hardware or firmware in the supply chain, adversaries can insert a backdoor into consumer networks that may be difficult to detect and give the adversary a high degree of control over the system." ;
    skos:exactMatch d3f:T1474.002,
        mitre-attack:T1474.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1474003 a owl:Class ;
    rdfs:label "T1474_003" ;
    d3f:attack-id "T1474.003" ;
    dcterms:title "Compromise Software Supply Chain" ;
    rdfs:subClassOf d3f:T1474 ;
    skos:altLabel "T1474.003" ;
    skos:definition "Adversaries may manipulate application software prior to receipt by a final consumer for the purpose of data or system compromise. Supply chain compromise of software can take place in a number of ways, including manipulation of the application source code, manipulation of the update/distribution mechanism for that software, or replacing compiled releases with a modified version." ;
    skos:exactMatch d3f:T1474.003,
        mitre-attack:T1474.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1480001 a owl:Class ;
    rdfs:label "T1480_001" ;
    d3f:attack-id "T1480.001" ;
    dcterms:title "Environmental Keying" ;
    rdfs:subClassOf d3f:T1480 ;
    skos:altLabel "T1480.001" ;
    skos:definition "Adversaries may environmentally key payloads or other features of malware to evade defenses and constraint execution to a specific target environment. Environmental keying uses cryptography to constrain execution or actions based on adversary supplied environment specific conditions that are expected to be present on the target. Environmental keying is an implementation of [Execution Guardrails](https://attack.mitre.org/techniques/T1480) that utilizes cryptographic techniques for deriving encryption/decryption keys from specific types of values in a given computing environment.(Citation: EK Clueless Agents)" ;
    skos:exactMatch d3f:T1480.001,
        mitre-attack:T1480.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1480002 a owl:Class ;
    rdfs:label "T1480_002" ;
    d3f:attack-id "T1480.002" ;
    dcterms:title "Mutual Exclusion" ;
    rdfs:subClassOf d3f:T1480 ;
    skos:altLabel "T1480.002" ;
    skos:definition "Adversaries may constrain execution or actions based on the presence of a mutex associated with malware. A mutex is a locking mechanism used to synchronize access to a resource. Only one thread or process can acquire a mutex at a given time.(Citation: Microsoft Mutexes)" ;
    skos:exactMatch d3f:T1480.002,
        mitre-attack:T1480.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1481001 a owl:Class ;
    rdfs:label "T1481_001" ;
    d3f:attack-id "T1481.001" ;
    dcterms:title "Dead Drop Resolver" ;
    rdfs:subClassOf d3f:T1481 ;
    skos:altLabel "T1481.001" ;
    skos:definition "Adversaries may use an existing, legitimate external Web service to host information that points to additional command and control (C2) infrastructure. Adversaries may post content, known as a dead drop resolver, on Web services with embedded (and often obfuscated/encoded) domains or IP addresses. Once infected, victims will reach out to and be redirected by these resolvers." ;
    skos:exactMatch d3f:T1481.001,
        mitre-attack:T1481.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1481002 a owl:Class ;
    rdfs:label "T1481_002" ;
    d3f:attack-id "T1481.002" ;
    dcterms:title "Bidirectional Communication" ;
    rdfs:subClassOf d3f:T1481 ;
    skos:altLabel "T1481.002" ;
    skos:definition "Adversaries may use an existing, legitimate external Web service channel as a means for sending commands to and receiving output from a compromised system. Compromised systems may leverage popular websites and social media to host command and control (C2) instructions. Those infected systems can then send the output from those commands back over that Web service channel. The return traffic may occur in a variety of ways, depending on the Web service being utilized. For example, the return traffic may take the form of the compromised system posting a comment on a forum, issuing a pull request to development project, updating a document hosted on a Web service, or by sending a Tweet." ;
    skos:exactMatch d3f:T1481.002,
        mitre-attack:T1481.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1481003 a owl:Class ;
    rdfs:label "T1481_003" ;
    d3f:attack-id "T1481.003" ;
    dcterms:title "One-Way Communication" ;
    rdfs:subClassOf d3f:T1481 ;
    skos:altLabel "T1481.003" ;
    skos:definition "Adversaries may use an existing, legitimate external Web service channel as a means for sending commands to a compromised system without receiving return output. Compromised systems may leverage popular websites and social media to host command and control (C2) instructions. Those infected systems may opt to send the output from those commands back over a different C2 channel, including to another distinct Web service. Alternatively, compromised systems may return no output at all in cases where adversaries want to send instructions to systems and do not want a response." ;
    skos:exactMatch d3f:T1481.003,
        mitre-attack:T1481.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1484001 a owl:Class ;
    rdfs:label "T1484_001" ;
    d3f:attack-id "T1484.001" ;
    dcterms:title "Group Policy Modification" ;
    rdfs:subClassOf d3f:T1484 ;
    skos:altLabel "T1484.001" ;
    skos:definition "Adversaries may modify Group Policy Objects (GPOs) to subvert the intended discretionary access controls for a domain, usually with the intention of escalating privileges on the domain. Group policy allows for centralized management of user and computer settings in Active Directory (AD). GPOs are containers for group policy settings made up of files stored within a predictable network path `\\<DOMAIN>\\SYSVOL\\<DOMAIN>\\Policies\\`.(Citation: TechNet Group Policy Basics)(Citation: ADSecurity GPO Persistence 2016)" ;
    skos:exactMatch d3f:T1484.001,
        mitre-attack:T1484.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1484002 a owl:Class ;
    rdfs:label "T1484_002" ;
    d3f:attack-id "T1484.002" ;
    dcterms:title "Trust Modification" ;
    rdfs:subClassOf d3f:T1484 ;
    skos:altLabel "T1484.002" ;
    skos:definition "Adversaries may add new domain trusts, modify the properties of existing domain trusts, or otherwise change the configuration of trust relationships between domains and tenants to evade defenses and/or elevate privileges.Trust details, such as whether or not user identities are federated, allow authentication and authorization properties to apply between domains or tenants for the purpose of accessing shared resources.(Citation: Microsoft - Azure AD Federation) These trust objects may include accounts, credentials, and other authentication material applied to servers, tokens, and domains." ;
    skos:exactMatch d3f:T1484.002,
        mitre-attack:T1484.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1485001 a owl:Class ;
    rdfs:label "T1485_001" ;
    d3f:attack-id "T1485.001" ;
    dcterms:title "Lifecycle-Triggered Deletion" ;
    rdfs:subClassOf d3f:T1485 ;
    skos:altLabel "T1485.001" ;
    skos:definition "Adversaries may modify the lifecycle policies of a cloud storage bucket to destroy all objects stored within." ;
    skos:exactMatch d3f:T1485.001,
        mitre-attack:T1485.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1491001 a owl:Class ;
    rdfs:label "T1491_001" ;
    d3f:attack-id "T1491.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Internal Defacement" ;
    rdfs:subClassOf d3f:T1491 ;
    skos:altLabel "T1491.001" ;
    skos:definition "An adversary may deface systems internal to an organization in an attempt to intimidate or mislead users, thus discrediting the integrity of the systems. This may take the form of modifications to internal websites, or directly to user systems with the replacement of the desktop wallpaper.(Citation: Novetta Blockbuster) Disturbing or offensive images may be used as a part of [Internal Defacement](https://attack.mitre.org/techniques/T1491/001) in order to cause user discomfort, or to pressure compliance with accompanying messages. Since internally defacing systems exposes an adversary's presence, it often takes place after other intrusion goals have been accomplished.(Citation: Novetta Blockbuster Destructive Malware)" ;
    skos:exactMatch d3f:T1491.001,
        mitre-attack:T1491.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1491002 a owl:Class ;
    rdfs:label "T1491_002" ;
    d3f:attack-id "T1491.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "External Defacement" ;
    rdfs:subClassOf d3f:T1491 ;
    skos:altLabel "T1491.002" ;
    skos:definition "An adversary may deface systems external to an organization in an attempt to deliver messaging, intimidate, or otherwise mislead an organization or users. [External Defacement](https://attack.mitre.org/techniques/T1491/002) may ultimately cause users to distrust the systems and to question/discredit the system’s integrity. Externally-facing websites are a common victim of defacement; often targeted by adversary and hacktivist groups in order to push a political message or spread propaganda.(Citation: FireEye Cyber Threats to Media Industries)(Citation: Kevin Mandia Statement to US Senate Committee on Intelligence)(Citation: Anonymous Hackers Deface Russian Govt Site) [External Defacement](https://attack.mitre.org/techniques/T1491/002) may be used as a catalyst to trigger events, or as a response to actions taken by an organization or government. Similarly, website defacement may also be used as setup, or a precursor, for future attacks such as [Drive-by Compromise](https://attack.mitre.org/techniques/T1189).(Citation: Trend Micro Deep Dive Into Defacement)" ;
    skos:exactMatch d3f:T1491.002,
        mitre-attack:T1491.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1496001 a owl:Class ;
    rdfs:label "T1496_001" ;
    d3f:attack-id "T1496.001" ;
    dcterms:title "Compute Hijacking" ;
    rdfs:subClassOf d3f:T1496 ;
    skos:altLabel "T1496.001" ;
    skos:definition "Adversaries may leverage the compute resources of co-opted systems to complete resource-intensive tasks, which may impact system and/or hosted service availability." ;
    skos:exactMatch d3f:T1496.001,
        mitre-attack:T1496.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1496002 a owl:Class ;
    rdfs:label "T1496_002" ;
    d3f:attack-id "T1496.002" ;
    dcterms:title "Bandwidth Hijacking" ;
    rdfs:subClassOf d3f:T1496 ;
    skos:altLabel "T1496.002" ;
    skos:definition "Adversaries may leverage the network bandwidth resources of co-opted systems to complete resource-intensive tasks, which may impact system and/or hosted service availability." ;
    skos:exactMatch d3f:T1496.002,
        mitre-attack:T1496.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1496003 a owl:Class ;
    rdfs:label "T1496_003" ;
    d3f:attack-id "T1496.003" ;
    dcterms:title "SMS Pumping" ;
    rdfs:subClassOf d3f:T1496 ;
    skos:altLabel "T1496.003" ;
    skos:definition "Adversaries may leverage messaging services for SMS pumping, which may impact system and/or hosted service availability.(Citation: Twilio SMS Pumping) SMS pumping is a type of telecommunications fraud whereby a threat actor first obtains a set of phone numbers from a telecommunications provider, then leverages a victim’s messaging infrastructure to send large amounts of SMS messages to numbers in that set. By generating SMS traffic to their phone number set, a threat actor may earn payments from the telecommunications provider.(Citation: Twilio SMS Pumping Fraud)" ;
    skos:exactMatch d3f:T1496.003,
        mitre-attack:T1496.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1496004 a owl:Class ;
    rdfs:label "T1496_004" ;
    d3f:attack-id "T1496.004" ;
    dcterms:title "Cloud Service Hijacking" ;
    rdfs:subClassOf d3f:T1496 ;
    skos:altLabel "T1496.004" ;
    skos:definition "Adversaries may leverage compromised software-as-a-service (SaaS) applications to complete resource-intensive tasks, which may impact hosted service availability." ;
    skos:exactMatch d3f:T1496.004,
        mitre-attack:T1496.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1497001 a owl:Class ;
    rdfs:label "T1497_001" ;
    d3f:attack-id "T1497.001" ;
    dcterms:title "System Checks" ;
    rdfs:subClassOf d3f:T1497 ;
    skos:altLabel "T1497.001" ;
    skos:definition "Adversaries may employ various system checks to detect and avoid virtualization and analysis environments. This may include changing behaviors based on the results of checks for the presence of artifacts indicative of a virtual machine environment (VME) or sandbox. If the adversary detects a VME, they may alter their malware to disengage from the victim or conceal the core functions of the implant. They may also search for VME artifacts before dropping secondary or additional payloads. Adversaries may use the information learned from [Virtualization/Sandbox Evasion](https://attack.mitre.org/techniques/T1497) during automated discovery to shape follow-on behaviors.(Citation: Deloitte Environment Awareness)" ;
    skos:exactMatch d3f:T1497.001,
        mitre-attack:T1497.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1497002 a owl:Class ;
    rdfs:label "T1497_002" ;
    d3f:attack-id "T1497.002" ;
    dcterms:title "User Activity Based Checks" ;
    rdfs:subClassOf d3f:T1497 ;
    skos:altLabel "T1497.002" ;
    skos:definition "Adversaries may employ various user activity checks to detect and avoid virtualization and analysis environments. This may include changing behaviors based on the results of checks for the presence of artifacts indicative of a virtual machine environment (VME) or sandbox. If the adversary detects a VME, they may alter their malware to disengage from the victim or conceal the core functions of the implant. They may also search for VME artifacts before dropping secondary or additional payloads. Adversaries may use the information learned from [Virtualization/Sandbox Evasion](https://attack.mitre.org/techniques/T1497) during automated discovery to shape follow-on behaviors.(Citation: Deloitte Environment Awareness)" ;
    skos:exactMatch d3f:T1497.002,
        mitre-attack:T1497.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1497003 a owl:Class ;
    rdfs:label "T1497_003" ;
    d3f:attack-id "T1497.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Time Based Evasion" ;
    rdfs:subClassOf d3f:T1497 ;
    skos:altLabel "T1497.003" ;
    skos:definition "Adversaries may employ various time-based methods to detect and avoid virtualization and analysis environments. This may include enumerating time-based properties, such as uptime or the system clock, as well as the use of timers or other triggers to avoid a virtual machine environment (VME) or sandbox, specifically those that are automated or only operate for a limited amount of time." ;
    skos:exactMatch d3f:T1497.003,
        mitre-attack:T1497.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1498001 a owl:Class ;
    rdfs:label "T1498_001" ;
    d3f:attack-id "T1498.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Direct Network Flood" ;
    rdfs:subClassOf d3f:T1498 ;
    skos:altLabel "T1498.001" ;
    skos:definition "Adversaries may attempt to cause a denial of service (DoS) by directly sending a high-volume of network traffic to a target. This DoS attack may also reduce the availability and functionality of the targeted system(s) and network. [Direct Network Flood](https://attack.mitre.org/techniques/T1498/001)s are when one or more systems are used to send a high-volume of network packets towards the targeted service's network. Almost any network protocol may be used for flooding. Stateless protocols such as UDP or ICMP are commonly used but stateful protocols such as TCP can be used as well." ;
    skos:exactMatch d3f:T1498.001,
        mitre-attack:T1498.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1498002 a owl:Class ;
    rdfs:label "T1498_002" ;
    d3f:attack-id "T1498.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Reflection Amplification" ;
    rdfs:subClassOf d3f:T1498 ;
    skos:altLabel "T1498.002" ;
    skos:definition "Adversaries may attempt to cause a denial of service (DoS) by reflecting a high-volume of network traffic to a target. This type of Network DoS takes advantage of a third-party server intermediary that hosts and will respond to a given spoofed source IP address. This third-party server is commonly termed a reflector. An adversary accomplishes a reflection attack by sending packets to reflectors with the spoofed address of the victim. Similar to Direct Network Floods, more than one system may be used to conduct the attack, or a botnet may be used. Likewise, one or more reflectors may be used to focus traffic on the target.(Citation: Cloudflare ReflectionDoS May 2017) This Network DoS attack may also reduce the availability and functionality of the targeted system(s) and network." ;
    skos:exactMatch d3f:T1498.002,
        mitre-attack:T1498.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1499001 a owl:Class ;
    rdfs:label "T1499_001" ;
    d3f:attack-id "T1499.001" ;
    dcterms:title "OS Exhaustion Flood" ;
    rdfs:subClassOf d3f:T1499 ;
    skos:altLabel "T1499.001" ;
    skos:definition "Adversaries may launch a denial of service (DoS) attack targeting an endpoint's operating system (OS). A system's OS is responsible for managing the finite resources as well as preventing the entire system from being overwhelmed by excessive demands on its capacity. These attacks do not need to exhaust the actual resources on a system; the attacks may simply exhaust the limits and available resources that an OS self-imposes." ;
    skos:exactMatch d3f:T1499.001,
        mitre-attack:T1499.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1499002 a owl:Class ;
    rdfs:label "T1499_002" ;
    d3f:attack-id "T1499.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Service Exhaustion Flood" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:T1499 ],
        d3f:T1498 ;
    skos:altLabel "T1499.002" ;
    skos:definition "Adversaries may target the different network services provided by systems to conduct a denial of service (DoS). Adversaries often target the availability of DNS and web services, however others have been targeted as well.(Citation: Arbor AnnualDoSreport Jan 2018) Web server software can be attacked through a variety of means, some of which apply generally while others are specific to the software being used to provide the service." ;
    skos:exactMatch d3f:T1499.002,
        mitre-attack:T1499.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1499003 a owl:Class ;
    rdfs:label "T1499_003" ;
    d3f:attack-id "T1499.003" ;
    dcterms:title "Application Exhaustion Flood" ;
    rdfs:subClassOf d3f:T1499 ;
    skos:altLabel "T1499.003" ;
    skos:definition "Adversaries may target resource intensive features of applications to cause a denial of service (DoS), denying availability to those applications. For example, specific features in web applications may be highly resource intensive. Repeated requests to those features may be able to exhaust system resources and deny access to the application or the server itself.(Citation: Arbor AnnualDoSreport Jan 2018)" ;
    skos:exactMatch d3f:T1499.003,
        mitre-attack:T1499.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1499004 a owl:Class ;
    rdfs:label "T1499_004" ;
    d3f:attack-id "T1499.004" ;
    dcterms:title "Application or System Exploitation" ;
    rdfs:subClassOf d3f:T1499 ;
    skos:altLabel "T1499.004" ;
    skos:definition "Adversaries may exploit software vulnerabilities that can cause an application or system to crash and deny availability to users. (Citation: Sucuri BIND9 August 2015) Some systems may automatically restart critical applications and services when crashes occur, but they can likely be re-exploited to cause a persistent denial of service (DoS) condition." ;
    skos:exactMatch d3f:T1499.004,
        mitre-attack:T1499.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505001 a owl:Class ;
    rdfs:label "T1505_001" ;
    d3f:attack-id "T1505.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "SQL Stored Procedures" ;
    rdfs:subClassOf d3f:T1505 ;
    skos:altLabel "T1505.001" ;
    skos:definition "Adversaries may abuse SQL stored procedures to establish persistent access to systems. SQL Stored Procedures are code that can be saved and reused so that database users do not waste time rewriting frequently used SQL queries. Stored procedures can be invoked via SQL statements to the database using the procedure name or via defined events (e.g. when a SQL server application is started/restarted)." ;
    skos:exactMatch d3f:T1505.001,
        mitre-attack:T1505.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505002 a owl:Class ;
    rdfs:label "T1505_002" ;
    d3f:attack-id "T1505.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Transport Agent" ;
    rdfs:subClassOf d3f:T1505 ;
    skos:altLabel "T1505.002" ;
    skos:definition "Adversaries may abuse Microsoft transport agents to establish persistent access to systems. Microsoft Exchange transport agents can operate on email messages passing through the transport pipeline to perform various tasks such as filtering spam, filtering malicious attachments, journaling, or adding a corporate signature to the end of all outgoing emails.(Citation: Microsoft TransportAgent Jun 2016)(Citation: ESET LightNeuron May 2019) Transport agents can be written by application developers and then compiled to .NET assemblies that are subsequently registered with the Exchange server. Transport agents will be invoked during a specified stage of email processing and carry out developer defined tasks." ;
    skos:exactMatch d3f:T1505.002,
        mitre-attack:T1505.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505003 a owl:Class ;
    rdfs:label "T1505_003" ;
    d3f:attack-id "T1505.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Shell" ;
    rdfs:subClassOf d3f:T1505 ;
    skos:altLabel "T1505.003" ;
    skos:definition "Adversaries may backdoor web servers with web shells to establish persistent access to systems. A Web shell is a Web script that is placed on an openly accessible Web server to allow an adversary to access the Web server as a gateway into a network. A Web shell may provide a set of functions to execute or a command-line interface on the system that hosts the Web server.(Citation: volexity_0day_sophos_FW)" ;
    skos:exactMatch d3f:T1505.003,
        mitre-attack:T1505.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505004 a owl:Class ;
    rdfs:label "T1505_004" ;
    d3f:attack-id "T1505.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "IIS Components" ;
    rdfs:subClassOf d3f:T1505 ;
    skos:altLabel "T1505.004" ;
    skos:definition "Adversaries may install malicious components that run on Internet Information Services (IIS) web servers to establish persistence. IIS provides several mechanisms to extend the functionality of the web servers. For example, Internet Server Application Programming Interface (ISAPI) extensions and filters can be installed to examine and/or modify incoming and outgoing IIS web requests. Extensions and filters are deployed as DLL files that export three functions: <code>Get{Extension/Filter}Version</code>, <code>Http{Extension/Filter}Proc</code>, and (optionally) <code>Terminate{Extension/Filter}</code>. IIS modules may also be installed to extend IIS web servers.(Citation: Microsoft ISAPI Extension Overview 2017)(Citation: Microsoft ISAPI Filter Overview 2017)(Citation: IIS Backdoor 2011)(Citation: Trustwave IIS Module 2013)" ;
    skos:exactMatch d3f:T1505.004,
        mitre-attack:T1505.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505005 a owl:Class ;
    rdfs:label "T1505_005" ;
    d3f:attack-id "T1505.005" ;
    dcterms:title "Terminal Services DLL" ;
    rdfs:subClassOf d3f:T1505 ;
    skos:altLabel "T1505.005" ;
    skos:definition "Adversaries may abuse components of Terminal Services to enable persistent access to systems. Microsoft Terminal Services, renamed to Remote Desktop Services in some Windows Server OSs as of 2022, enable remote terminal connections to hosts. Terminal Services allows servers to transmit a full, interactive, graphical user interface to clients via RDP.(Citation: Microsoft Remote Desktop Services)" ;
    skos:exactMatch d3f:T1505.005,
        mitre-attack:T1505.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1505006 a owl:Class ;
    rdfs:label "T1505_006" ;
    d3f:attack-id "T1505.006" ;
    dcterms:title "vSphere Installation Bundles" ;
    rdfs:subClassOf d3f:T1505 ;
    skos:altLabel "T1505.006" ;
    skos:definition "Adversaries may abuse vSphere Installation Bundles (VIBs) to establish persistent access to ESXi hypervisors. VIBs are collections of files used for software distribution and virtual system management in VMware environments. Since ESXi uses an in-memory filesystem where changes made to most files are stored in RAM rather than in persistent storage, these modifications are lost after a reboot. However, VIBs can be used to create startup tasks, apply custom firewall rules, or deploy binaries that persist across reboots. Typically, administrators use VIBs for updates and system maintenance." ;
    skos:exactMatch d3f:T1505.006,
        mitre-attack:T1505.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1518001 a owl:Class ;
    rdfs:label "T1518_001" ;
    d3f:attack-id "T1518.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Security Software Discovery" ;
    rdfs:subClassOf d3f:T1518 ;
    skos:altLabel "T1518.001" ;
    skos:definition "Adversaries may attempt to get a listing of security software, configurations, defensive tools, and sensors that are installed on a system or in a cloud environment. This may include things such as cloud monitoring agents and anti-virus. Adversaries may use the information from [Security Software Discovery](https://attack.mitre.org/techniques/T1518/001) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1518.001,
        mitre-attack:T1518.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1518002 a owl:Class ;
    rdfs:label "T1518_002" ;
    d3f:attack-id "T1518.002" ;
    dcterms:title "Backup Software Discovery" ;
    rdfs:subClassOf d3f:T1518 ;
    skos:altLabel "T1518.002" ;
    skos:definition "Adversaries may attempt to get a listing of backup software or configurations that are installed on a system. Adversaries may use this information to shape follow-on behaviors, such as [Data Destruction](https://attack.mitre.org/techniques/T1485), [Inhibit System Recovery](https://attack.mitre.org/techniques/T1490), or [Data Encrypted for Impact](https://attack.mitre.org/techniques/T1486)." ;
    skos:exactMatch d3f:T1518.002,
        mitre-attack:T1518.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1521001 a owl:Class ;
    rdfs:label "T1521_001" ;
    d3f:attack-id "T1521.001" ;
    dcterms:title "Symmetric Cryptography" ;
    rdfs:subClassOf d3f:T1521 ;
    skos:altLabel "T1521.001" ;
    skos:definition "Adversaries may employ a known symmetric encryption algorithm to conceal command and control traffic, rather than relying on any inherent protections provided by a communication protocol. Symmetric encryption algorithms use the same key for plaintext encryption and ciphertext decryption. Common symmetric encryption algorithms include AES, Blowfish, and RC4." ;
    skos:exactMatch d3f:T1521.001,
        mitre-attack:T1521.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1521002 a owl:Class ;
    rdfs:label "T1521_002" ;
    d3f:attack-id "T1521.002" ;
    dcterms:title "Asymmetric Cryptography" ;
    rdfs:subClassOf d3f:T1521 ;
    skos:altLabel "T1521.002" ;
    skos:definition "Adversaries may employ a known asymmetric encryption algorithm to conceal command and control traffic, rather than relying on any inherent protections provided by a communication protocol. Asymmetric cryptography, also known as public key cryptography, uses a keypair per party: one public that can be freely distributed, and one private that should not be distributed. Due to how asymmetric algorithms work, the sender encrypts data with the receiver’s public key and the receiver decrypts the data with their private key. This ensures that only the intended recipient can read the encrypted data. Common public key encryption algorithms include RSA, ElGamal, and ECDSA." ;
    skos:exactMatch d3f:T1521.002,
        mitre-attack:T1521.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1521003 a owl:Class ;
    rdfs:label "T1521_003" ;
    d3f:attack-id "T1521.003" ;
    dcterms:title "SSL Pinning" ;
    rdfs:subClassOf d3f:T1521 ;
    skos:altLabel "T1521.003" ;
    skos:definition "Adversaries may use [SSL Pinning](https://attack.mitre.org/techniques/T1521/003)  to protect the C2 traffic from being intercepted and analyzed." ;
    skos:exactMatch d3f:T1521.003,
        mitre-attack:T1521.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1542001 a owl:Class ;
    rdfs:label "T1542_001" ;
    d3f:attack-id "T1542.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Firmware" ;
    rdfs:subClassOf d3f:T1542 ;
    skos:altLabel "T1542.001" ;
    skos:definition "Adversaries may modify system firmware to persist on systems.The BIOS (Basic Input/Output System) and The Unified Extensible Firmware Interface (UEFI) or Extensible Firmware Interface (EFI) are examples of system firmware that operate as the software interface between the operating system and hardware of a computer.(Citation: Wikipedia BIOS)(Citation: Wikipedia UEFI)(Citation: About UEFI)" ;
    skos:exactMatch d3f:T1542.001,
        mitre-attack:T1542.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1542002 a owl:Class ;
    rdfs:label "T1542_002" ;
    d3f:attack-id "T1542.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Component Firmware" ;
    rdfs:subClassOf d3f:T1542 ;
    skos:altLabel "T1542.002" ;
    skos:definition "Adversaries may modify component firmware to persist on systems. Some adversaries may employ sophisticated means to compromise computer components and install malicious firmware that will execute adversary code outside of the operating system and main system firmware or BIOS. This technique may be similar to [System Firmware](https://attack.mitre.org/techniques/T1542/001) but conducted upon other system components/devices that may not have the same capability or level of integrity checking." ;
    skos:exactMatch d3f:T1542.002,
        mitre-attack:T1542.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1542003 a owl:Class ;
    rdfs:label "T1542_003" ;
    d3f:attack-id "T1542.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bootkit" ;
    rdfs:subClassOf d3f:T1542 ;
    skos:altLabel "T1542.003" ;
    skos:definition "Adversaries may use bootkits to persist on systems. Bootkits reside at a layer below the operating system and may make it difficult to perform full remediation unless an organization suspects one was used and can act accordingly." ;
    skos:exactMatch d3f:T1542.003,
        mitre-attack:T1542.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1542004 a owl:Class ;
    rdfs:label "T1542_004" ;
    d3f:attack-id "T1542.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "ROMMONkit" ;
    rdfs:subClassOf d3f:T1542 ;
    skos:altLabel "T1542.004" ;
    skos:definition "Adversaries may abuse the ROM Monitor (ROMMON) by loading an unauthorized firmware with adversary code to provide persistent access and manipulate device behavior that is difficult to detect. (Citation: Cisco Synful Knock Evolution)(Citation: Cisco Blog Legacy Device Attacks)" ;
    skos:exactMatch d3f:T1542.004,
        mitre-attack:T1542.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1542005 a owl:Class ;
    rdfs:label "T1542_005" ;
    d3f:attack-id "T1542.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "TFTP Boot" ;
    rdfs:subClassOf d3f:T1542 ;
    skos:altLabel "T1542.005" ;
    skos:definition "Adversaries may abuse netbooting to load an unauthorized network device operating system from a Trivial File Transfer Protocol (TFTP) server. TFTP boot (netbooting) is commonly used by network administrators to load configuration-controlled network device images from a centralized management server. Netbooting is one option in the boot sequence and can be used to centralize, manage, and control device images." ;
    skos:exactMatch d3f:T1542.005,
        mitre-attack:T1542.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1543001 a owl:Class ;
    rdfs:label "T1543_001" ;
    d3f:attack-id "T1543.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Launch Agent" ;
    rdfs:subClassOf d3f:T1543 ;
    skos:altLabel "T1543.001" ;
    skos:definition "Adversaries may create or modify launch agents to repeatedly execute malicious payloads as part of persistence. When a user logs in, a per-user launchd process is started which loads the parameters for each launch-on-demand user agent from the property list (.plist) file found in <code>/System/Library/LaunchAgents</code>, <code>/Library/LaunchAgents</code>, and <code>~/Library/LaunchAgents</code>.(Citation: AppleDocs Launch Agent Daemons)(Citation: OSX Keydnap malware) (Citation: Antiquated Mac Malware) Property list files use the <code>Label</code>, <code>ProgramArguments </code>, and <code>RunAtLoad</code> keys to identify the Launch Agent's name, executable location, and execution time.(Citation: OSX.Dok Malware) Launch Agents are often installed to perform updates to programs, launch user specified programs at login, or to conduct other developer tasks." ;
    skos:exactMatch d3f:T1543.001,
        mitre-attack:T1543.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1543002 a owl:Class ;
    rdfs:label "T1543_002" ;
    d3f:attack-id "T1543.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Systemd Service" ;
    rdfs:subClassOf d3f:T1543 ;
    skos:altLabel "T1543.002" ;
    skos:definition "Adversaries may create or modify systemd services to repeatedly execute malicious payloads as part of persistence. Systemd is a system and service manager commonly used for managing background daemon processes (also known as services) and other system resources.(Citation: Linux man-pages: systemd January 2014) Systemd is the default initialization (init) system on many Linux distributions replacing legacy init systems, including SysVinit and Upstart, while remaining backwards compatible." ;
    skos:exactMatch d3f:T1543.002,
        mitre-attack:T1543.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1543003 a owl:Class ;
    rdfs:label "T1543_003" ;
    d3f:attack-id "T1543.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows Service" ;
    rdfs:subClassOf d3f:T1543 ;
    skos:altLabel "T1543.003" ;
    skos:definition "Adversaries may create or modify Windows services to repeatedly execute malicious payloads as part of persistence. When Windows boots up, it starts programs or applications called services that perform background system functions.(Citation: TechNet Services) Windows service configuration information, including the file path to the service's executable or recovery programs/commands, is stored in the Windows Registry." ;
    skos:exactMatch d3f:T1543.003,
        mitre-attack:T1543.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1543004 a owl:Class ;
    rdfs:label "T1543_004" ;
    d3f:attack-id "T1543.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Launch Daemon" ;
    rdfs:subClassOf d3f:T1543 ;
    skos:altLabel "T1543.004" ;
    skos:definition "Adversaries may create or modify Launch Daemons to execute malicious payloads as part of persistence. Launch Daemons are plist files used to interact with Launchd, the service management framework used by macOS. Launch Daemons require elevated privileges to install, are executed for every user on a system prior to login, and run in the background without the need for user interaction. During the macOS initialization startup, the launchd process loads the parameters for launch-on-demand system-level daemons from plist files found in <code>/System/Library/LaunchDaemons/</code> and <code>/Library/LaunchDaemons/</code>. Required Launch Daemons parameters include a <code>Label</code> to identify the task, <code>Program</code> to provide a path to the executable, and <code>RunAtLoad</code> to specify when the task is run. Launch Daemons are often used to provide access to shared resources, updates to software, or conduct automation tasks.(Citation: AppleDocs Launch Agent Daemons)(Citation: Methods of Mac Malware Persistence)(Citation: launchd Keywords for plists)" ;
    skos:exactMatch d3f:T1543.004,
        mitre-attack:T1543.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1543005 a owl:Class ;
    rdfs:label "T1543_005" ;
    d3f:attack-id "T1543.005" ;
    dcterms:title "Container Service" ;
    rdfs:subClassOf d3f:T1543 ;
    skos:altLabel "T1543.005" ;
    skos:definition "Adversaries may create or modify container or container cluster management tools that run as daemons, agents, or services on individual hosts. These include software for creating and managing individual containers, such as Docker and Podman, as well as container cluster node-level agents such as kubelet. By modifying these services, an adversary may be able to achieve persistence or escalate their privileges on a host." ;
    skos:exactMatch d3f:T1543.005,
        mitre-attack:T1543.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546001 a owl:Class ;
    rdfs:label "T1546_001" ;
    d3f:attack-id "T1546.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Change Default File Association" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.001" ;
    skos:definition "Adversaries may establish persistence by executing malicious content triggered by a file type association. When a file is opened, the default program used to open the file (also called the file association or handler) is checked. File association selections are stored in the Windows Registry and can be edited by users, administrators, or programs that have Registry access or by administrators using the built-in assoc utility.(Citation: Microsoft Change Default Programs)(Citation: Microsoft File Handlers)(Citation: Microsoft Assoc Oct 2017) Applications can modify the file association for a given file extension to call an arbitrary program when a file with the given extension is opened." ;
    skos:exactMatch d3f:T1546.001,
        mitre-attack:T1546.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546002 a owl:Class ;
    rdfs:label "T1546_002" ;
    d3f:attack-id "T1546.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Screensaver" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.002" ;
    skos:definition "Adversaries may establish persistence by executing malicious content triggered by user inactivity. Screensavers are programs that execute after a configurable time of user inactivity and consist of Portable Executable (PE) files with a .scr file extension.(Citation: Wikipedia Screensaver) The Windows screensaver application scrnsave.scr is located in <code>C:\\Windows\\System32\\</code>, and <code>C:\\Windows\\sysWOW64\\</code>  on 64-bit Windows systems, along with screensavers included with base Windows installations." ;
    skos:exactMatch d3f:T1546.002,
        mitre-attack:T1546.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546003 a owl:Class ;
    rdfs:label "T1546_003" ;
    d3f:attack-id "T1546.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows Management Instrumentation Event Subscription" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.003" ;
    skos:definition "Adversaries may establish persistence and elevate privileges by executing malicious content triggered by a Windows Management Instrumentation (WMI) event subscription. WMI can be used to install event filters, providers, consumers, and bindings that execute code when a defined event occurs. Examples of events that may be subscribed to are the wall clock time, user login, or the computer's uptime.(Citation: Mandiant M-Trends 2015)" ;
    skos:exactMatch d3f:T1546.003,
        mitre-attack:T1546.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546004 a owl:Class ;
    rdfs:label "T1546_004" ;
    d3f:attack-id "T1546.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Unix Shell Configuration Modification" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.004" ;
    skos:definition "Adversaries may establish persistence through executing malicious commands triggered by a user’s shell. User [Unix Shell](https://attack.mitre.org/techniques/T1059/004)s execute several configuration scripts at different points throughout the session based on events. For example, when a user opens a command-line interface or remotely logs in (such as via SSH) a login shell is initiated. The login shell executes scripts from the system (<code>/etc</code>) and the user’s home directory (<code>~/</code>) to configure the environment. All login shells on a system use /etc/profile when initiated. These configuration scripts run at the permission level of their directory and are often used to set environment variables, create aliases, and customize the user’s environment. When the shell exits or terminates, additional shell scripts are executed to ensure the shell exits appropriately." ;
    skos:exactMatch d3f:T1546.004,
        mitre-attack:T1546.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546005 a owl:Class ;
    rdfs:label "T1546_005" ;
    d3f:attack-id "T1546.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Trap" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.005" ;
    skos:definition "Adversaries may establish persistence by executing malicious content triggered by an interrupt signal. The <code>trap</code> command allows programs and shells to specify commands that will be executed upon receiving interrupt signals. A common situation is a script allowing for graceful termination and handling of common keyboard interrupts like <code>ctrl+c</code> and <code>ctrl+d</code>." ;
    skos:exactMatch d3f:T1546.005,
        mitre-attack:T1546.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546006 a owl:Class ;
    rdfs:label "T1546_006" ;
    d3f:attack-id "T1546.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "LC_LOAD_DYLIB Addition" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.006" ;
    skos:definition "Adversaries may establish persistence by executing malicious content triggered by the execution of tainted binaries. Mach-O binaries have a series of headers that are used to perform certain operations when a binary is loaded. The LC_LOAD_DYLIB header in a Mach-O binary tells macOS and OS X which dynamic libraries (dylibs) to load during execution time. These can be added ad-hoc to the compiled binary as long as adjustments are made to the rest of the fields and dependencies.(Citation: Writing Bad Malware for OSX) There are tools available to perform these changes." ;
    skos:exactMatch d3f:T1546.006,
        mitre-attack:T1546.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546007 a owl:Class ;
    rdfs:label "T1546_007" ;
    d3f:attack-id "T1546.007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Netsh Helper DLL" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.007" ;
    skos:definition "Adversaries may establish persistence by executing malicious content triggered by Netsh Helper DLLs. Netsh.exe (also referred to as Netshell) is a command-line scripting utility used to interact with the network configuration of a system. It contains functionality to add helper DLLs for extending functionality of the utility.(Citation: TechNet Netsh) The paths to registered netsh.exe helper DLLs are entered into the Windows Registry at <code>HKLM\\SOFTWARE\\Microsoft\\Netsh</code>." ;
    skos:exactMatch d3f:T1546.007,
        mitre-attack:T1546.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546008 a owl:Class ;
    rdfs:label "T1546_008" ;
    d3f:attack-id "T1546.008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Accessibility Features" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.008" ;
    skos:definition "Adversaries may establish persistence and/or elevate privileges by executing malicious content triggered by accessibility features. Windows contains accessibility features that may be launched with a key combination before a user has logged in (ex: when the user is on the Windows logon screen). An adversary can modify the way these programs are launched to get a command prompt or backdoor without logging in to the system." ;
    skos:exactMatch d3f:T1546.008,
        mitre-attack:T1546.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546009 a owl:Class ;
    rdfs:label "T1546_009" ;
    d3f:attack-id "T1546.009" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "AppCert DLLs" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.009" ;
    skos:definition "Adversaries may establish persistence and/or elevate privileges by executing malicious content triggered by AppCert DLLs loaded into processes. Dynamic-link libraries (DLLs) that are specified in the <code>AppCertDLLs</code> Registry key under <code>HKEY_LOCAL_MACHINE\\System\\CurrentControlSet\\Control\\Session Manager\\</code> are loaded into every process that calls the ubiquitously used application programming interface (API) functions <code>CreateProcess</code>, <code>CreateProcessAsUser</code>, <code>CreateProcessWithLoginW</code>, <code>CreateProcessWithTokenW</code>, or <code>WinExec</code>. (Citation: Elastic Process Injection July 2017)" ;
    skos:exactMatch d3f:T1546.009,
        mitre-attack:T1546.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546010 a owl:Class ;
    rdfs:label "T1546_010" ;
    d3f:attack-id "T1546.010" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "AppInit DLLs" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.010" ;
    skos:definition "Adversaries may establish persistence and/or elevate privileges by executing malicious content triggered by AppInit DLLs loaded into processes. Dynamic-link libraries (DLLs) that are specified in the <code>AppInit_DLLs</code> value in the Registry keys <code>HKEY_LOCAL_MACHINE\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Windows</code> or <code>HKEY_LOCAL_MACHINE\\Software\\Wow6432Node\\Microsoft\\Windows NT\\CurrentVersion\\Windows</code> are loaded by user32.dll into every process that loads user32.dll. In practice this is nearly every program, since user32.dll is a very common library. (Citation: Elastic Process Injection July 2017)" ;
    skos:exactMatch d3f:T1546.010,
        mitre-attack:T1546.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546011 a owl:Class ;
    rdfs:label "T1546_011" ;
    d3f:attack-id "T1546.011" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Shimming" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.011" ;
    skos:definition "Adversaries may establish persistence and/or elevate privileges by executing malicious content triggered by application shims. The Microsoft Windows Application Compatibility Infrastructure/Framework (Application Shim) was created to allow for backward compatibility of software as the operating system codebase changes over time. For example, the application shimming feature allows developers to apply fixes to applications (without rewriting code) that were created for Windows XP so that it will work with Windows 10. (Citation: Elastic Process Injection July 2017)" ;
    skos:exactMatch d3f:T1546.011,
        mitre-attack:T1546.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546012 a owl:Class ;
    rdfs:label "T1546_012" ;
    d3f:attack-id "T1546.012" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Image File Execution Options Injection" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.012" ;
    skos:definition "Adversaries may establish persistence and/or elevate privileges by executing malicious content triggered by Image File Execution Options (IFEO) debuggers. IFEOs enable a developer to attach a debugger to an application. When a process is created, a debugger present in an application’s IFEO will be prepended to the application’s name, effectively launching the new process under the debugger (e.g., <code>C:\\dbg\\ntsd.exe -g  notepad.exe</code>). (Citation: Microsoft Dev Blog IFEO Mar 2010)" ;
    skos:exactMatch d3f:T1546.012,
        mitre-attack:T1546.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546013 a owl:Class ;
    rdfs:label "T1546_013" ;
    d3f:attack-id "T1546.013" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "PowerShell Profile" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.013" ;
    skos:definition "Adversaries may gain persistence and elevate privileges by executing malicious content triggered by PowerShell profiles. A PowerShell profile  (<code>profile.ps1</code>) is a script that runs when [PowerShell](https://attack.mitre.org/techniques/T1059/001) starts and can be used as a logon script to customize user environments." ;
    skos:exactMatch d3f:T1546.013,
        mitre-attack:T1546.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546014 a owl:Class ;
    rdfs:label "T1546_014" ;
    d3f:attack-id "T1546.014" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Emond" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.014" ;
    skos:definition "Adversaries may gain persistence and elevate privileges by executing malicious content triggered by the Event Monitor Daemon (emond). Emond is a [Launch Daemon](https://attack.mitre.org/techniques/T1543/004) that accepts events from various services, runs them through a simple rules engine, and takes action. The emond binary at <code>/sbin/emond</code> will load any rules from the <code>/etc/emond.d/rules/</code> directory and take action once an explicitly defined event takes place." ;
    skos:exactMatch d3f:T1546.014,
        mitre-attack:T1546.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546015 a owl:Class ;
    rdfs:label "T1546_015" ;
    d3f:attack-id "T1546.015" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Component Object Model Hijacking" ;
    rdfs:seeAlso dbr:Component_Object_Model ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.015" ;
    skos:definition "Adversaries may establish persistence by executing malicious content triggered by hijacked references to Component Object Model (COM) objects. COM is a system within Windows to enable interaction between software components through the operating system.(Citation: Microsoft Component Object Model)  References to various COM objects are stored in the Registry." ;
    skos:exactMatch d3f:T1546.015,
        mitre-attack:T1546.015 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546016 a owl:Class ;
    rdfs:label "T1546_016" ;
    d3f:attack-id "T1546.016" ;
    dcterms:title "Installer Packages" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.016" ;
    skos:definition "Adversaries may establish persistence and elevate privileges by using an installer to trigger the execution of malicious content. Installer packages are OS specific and contain the resources an operating system needs to install applications on a system. Installer packages can include scripts that run prior to installation as well as after installation is complete. Installer scripts may inherit elevated permissions when executed. Developers often use these scripts to prepare the environment for installation, check requirements, download dependencies, and remove files after installation.(Citation: Installer Package Scripting Rich Trouton)" ;
    skos:exactMatch d3f:T1546.016,
        mitre-attack:T1546.016 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546017 a owl:Class ;
    rdfs:label "T1546_017" ;
    d3f:attack-id "T1546.017" ;
    dcterms:title "Udev Rules" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.017" ;
    skos:definition "Adversaries may maintain persistence through executing malicious content triggered using udev rules. Udev is the Linux kernel device manager that dynamically manages device nodes, handles access to pseudo-device files in the `/dev` directory, and responds to hardware events, such as when external devices like hard drives or keyboards are plugged in or removed. Udev uses rule files with `match keys` to specify the conditions a hardware event must meet and `action keys` to define the actions that should follow. Root permissions are required to create, modify, or delete rule files located in `/etc/udev/rules.d/`, `/run/udev/rules.d/`, `/usr/lib/udev/rules.d/`, `/usr/local/lib/udev/rules.d/`, and `/lib/udev/rules.d/`. Rule priority is determined by both directory and by the digit prefix in the rule filename.(Citation: Ignacio Udev research 2024)(Citation: Elastic Linux Persistence 2024)" ;
    skos:exactMatch d3f:T1546.017,
        mitre-attack:T1546.017 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1546018 a owl:Class ;
    rdfs:label "T1546_018" ;
    d3f:attack-id "T1546.018" ;
    dcterms:title "Python Startup Hooks" ;
    rdfs:subClassOf d3f:T1546 ;
    skos:altLabel "T1546.018" ;
    skos:definition "Adversaries may achieve persistence by leveraging Python’s startup mechanisms, including path configuration (`.pth`) files and the `sitecustomize.py` or `usercustomize.py` modules. These files are automatically processed during the initialization of the Python interpreter, allowing for the execution of arbitrary code whenever Python is invoked.(Citation: Volexity GlobalProtect CVE 2024)" ;
    skos:exactMatch d3f:T1546.018,
        mitre-attack:T1546.018 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547001 a owl:Class ;
    rdfs:label "T1547_001" ;
    d3f:attack-id "T1547.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Registry Run Keys / Startup Folder" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.001" ;
    skos:definition "Adversaries may achieve persistence by adding a program to a startup folder or referencing it with a Registry run key. Adding an entry to the \"run keys\" in the Registry or startup folder will cause the program referenced to be executed when a user logs in.(Citation: Microsoft Run Key) These programs will be executed under the context of the user and will have the account's associated permissions level." ;
    skos:exactMatch d3f:T1547.001,
        mitre-attack:T1547.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547002 a owl:Class ;
    rdfs:label "T1547_002" ;
    d3f:attack-id "T1547.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Package" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.002" ;
    skos:definition "Adversaries may abuse authentication packages to execute DLLs when the system boots. Windows authentication package DLLs are loaded by the Local Security Authority (LSA) process at system start. They provide support for multiple logon processes and multiple security protocols to the operating system.(Citation: MSDN Authentication Packages)" ;
    skos:exactMatch d3f:T1547.002,
        mitre-attack:T1547.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547003 a owl:Class ;
    rdfs:label "T1547_003" ;
    d3f:attack-id "T1547.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Time Providers" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.003" ;
    skos:definition "Adversaries may abuse time providers to execute DLLs when the system boots. The Windows Time service (W32Time) enables time synchronization across and within domains.(Citation: Microsoft W32Time Feb 2018) W32Time time providers are responsible for retrieving time stamps from hardware/network resources and outputting these values to other network clients.(Citation: Microsoft TimeProvider)" ;
    skos:exactMatch d3f:T1547.003,
        mitre-attack:T1547.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547004 a owl:Class ;
    rdfs:label "T1547_004" ;
    d3f:attack-id "T1547.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Winlogon Helper DLL" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.004" ;
    skos:definition "Adversaries may abuse features of Winlogon to execute DLLs and/or executables when a user logs in. Winlogon.exe is a Windows component responsible for actions at logon/logoff as well as the secure attention sequence (SAS) triggered by Ctrl-Alt-Delete. Registry entries in <code>HKLM\\Software[\\\\Wow6432Node\\\\]\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\</code> and <code>HKCU\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\</code> are used to manage additional helper programs and functionalities that support Winlogon.(Citation: Cylance Reg Persistence Sept 2013)" ;
    skos:exactMatch d3f:T1547.004,
        mitre-attack:T1547.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547005 a owl:Class ;
    rdfs:label "T1547_005" ;
    d3f:attack-id "T1547.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Security Support Provider" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.005" ;
    skos:definition "Adversaries may abuse security support providers (SSPs) to execute DLLs when the system boots. Windows SSP DLLs are loaded into the Local Security Authority (LSA) process at system start. Once loaded into the LSA, SSP DLLs have access to encrypted and plaintext passwords that are stored in Windows, such as any logged-on user's Domain password or smart card PINs." ;
    skos:exactMatch d3f:T1547.005,
        mitre-attack:T1547.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547006 a owl:Class ;
    rdfs:label "T1547_006" ;
    d3f:attack-id "T1547.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kernel Modules and Extensions" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.006" ;
    skos:definition "Adversaries may modify the kernel to automatically execute programs on system boot. Loadable Kernel Modules (LKMs) are pieces of code that can be loaded and unloaded into the kernel upon demand. They extend the functionality of the kernel without the need to reboot the system. For example, one type of module is the device driver, which allows the kernel to access hardware connected to the system.(Citation: Linux Kernel Programming)" ;
    skos:exactMatch d3f:T1547.006,
        mitre-attack:T1547.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547007 a owl:Class ;
    rdfs:label "T1547_007" ;
    d3f:attack-id "T1547.007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Re-opened Applications" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.007" ;
    skos:definition "Adversaries may modify plist files to automatically run an application when a user logs in. When a user logs out or restarts via the macOS Graphical User Interface (GUI), a prompt is provided to the user with a checkbox to \"Reopen windows when logging back in\".(Citation: Re-Open windows on Mac) When selected, all applications currently open are added to a property list file named <code>com.apple.loginwindow.[UUID].plist</code> within the <code>~/Library/Preferences/ByHost</code> directory.(Citation: Methods of Mac Malware Persistence)(Citation: Wardle Persistence Chapter) Applications listed in this file are automatically reopened upon the user’s next logon." ;
    skos:exactMatch d3f:T1547.007,
        mitre-attack:T1547.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547008 a owl:Class ;
    rdfs:label "T1547_008" ;
    d3f:attack-id "T1547.008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "LSASS Driver" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.008" ;
    skos:definition "Adversaries may modify or add LSASS drivers to obtain persistence on compromised systems. The Windows security subsystem is a set of components that manage and enforce the security policy for a computer or domain. The Local Security Authority (LSA) is the main component responsible for local security policy and user authentication. The LSA includes multiple dynamic link libraries (DLLs) associated with various other security functions, all of which run in the context of the LSA Subsystem Service (LSASS) lsass.exe process.(Citation: Microsoft Security Subsystem)" ;
    skos:exactMatch d3f:T1547.008,
        mitre-attack:T1547.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547009 a owl:Class ;
    rdfs:label "T1547_009" ;
    d3f:attack-id "T1547.009" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Shortcut Modification" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.009" ;
    skos:definition "Adversaries may create or modify shortcuts that can execute a program during system boot or user login. Shortcuts or symbolic links are used to reference other files or programs that will be opened or executed when the shortcut is clicked or executed by a system startup process." ;
    skos:exactMatch d3f:T1547.009,
        mitre-attack:T1547.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547010 a owl:Class ;
    rdfs:label "T1547_010" ;
    d3f:attack-id "T1547.010" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Port Monitors" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.010" ;
    skos:definition "Adversaries may use port monitors to run an adversary supplied DLL during system boot for persistence or privilege escalation. A port monitor can be set through the <code>AddMonitor</code> API call to set a DLL to be loaded at startup.(Citation: AddMonitor) This DLL can be located in <code>C:\\Windows\\System32</code> and will be loaded and run by the print spooler service, `spoolsv.exe`, under SYSTEM level permissions on boot.(Citation: Bloxham)" ;
    skos:exactMatch d3f:T1547.010,
        mitre-attack:T1547.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547011 a owl:Class ;
    rdfs:label "T1547_011" ;
    d3f:attack-id "T1547.011" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Plist Modification" ;
    rdfs:seeAlso d3f:T1647 ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.011" ;
    skos:definition "Adversaries can modify property list files (plist files) to execute their code as part of establishing persistence. Plist files are used by macOS applications to store properties and configuration settings for applications and services. Applications use information plist files, <code>Info.plist</code>, to tell the operating system how to handle the application at runtime using structured metadata in the form of keys and values. Plist files are formatted in XML and based on Apple's Core Foundation DTD and can be saved in text or binary format.(Citation: fileinfo plist file description)" ;
    skos:exactMatch d3f:T1547.011,
        mitre-attack:T1547.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1647" .

d3f:T1547012 a owl:Class ;
    rdfs:label "T1547_012" ;
    d3f:attack-id "T1547.012" ;
    dcterms:title "Print Processors" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.012" ;
    skos:definition "Adversaries may abuse print processors to run malicious DLLs during system boot for persistence and/or privilege escalation. Print processors are DLLs that are loaded by the print spooler service, `spoolsv.exe`, during boot.(Citation: Microsoft Intro Print Processors)" ;
    skos:exactMatch d3f:T1547.012,
        mitre-attack:T1547.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547013 a owl:Class ;
    rdfs:label "T1547_013" ;
    d3f:attack-id "T1547.013" ;
    dcterms:title "XDG Autostart Entries" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.013" ;
    skos:definition "Adversaries may add or modify XDG Autostart Entries to execute malicious programs or commands when a user’s desktop environment is loaded at login. XDG Autostart entries are available for any XDG-compliant Linux system. XDG Autostart entries use Desktop Entry files (`.desktop`) to configure the user’s desktop environment upon user login. These configuration files determine what applications launch upon user login, define associated applications to open specific file types, and define applications used to open removable media.(Citation: Free Desktop Application Autostart Feb 2006)(Citation: Free Desktop Entry Keys)" ;
    skos:exactMatch d3f:T1547.013,
        mitre-attack:T1547.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547014 a owl:Class ;
    rdfs:label "T1547_014" ;
    d3f:attack-id "T1547.014" ;
    dcterms:title "Active Setup" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.014" ;
    skos:definition "Adversaries may achieve persistence by adding a Registry key to the Active Setup of the local machine. Active Setup is a Windows mechanism that is used to execute programs when a user logs in. The value stored in the Registry key will be executed after a user logs into the computer.(Citation: Klein Active Setup 2010) These programs will be executed under the context of the user and will have the account's associated permissions level." ;
    skos:exactMatch d3f:T1547.014,
        mitre-attack:T1547.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1547015 a owl:Class ;
    rdfs:label "T1547_015" ;
    d3f:attack-id "T1547.015" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Login Items" ;
    rdfs:subClassOf d3f:T1547 ;
    skos:altLabel "T1547.015" ;
    skos:definition "Adversaries may add login items to execute upon user login to gain persistence or escalate privileges. Login items are applications, documents, folders, or server connections that are automatically launched when a user logs in.(Citation: Open Login Items Apple) Login items can be added via a shared file list or Service Management Framework.(Citation: Adding Login Items) Shared file list login items can be set using scripting languages such as [AppleScript](https://attack.mitre.org/techniques/T1059/002), whereas the Service Management Framework uses the API call <code>SMLoginItemSetEnabled</code>." ;
    skos:exactMatch d3f:T1547.015,
        mitre-attack:T1547.015 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548001 a owl:Class ;
    rdfs:label "T1548_001" ;
    d3f:attack-id "T1548.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Setuid and Setgid" ;
    rdfs:subClassOf d3f:T1548 ;
    skos:altLabel "T1548.001" ;
    skos:definition "An adversary may abuse configurations where an application has the setuid or setgid bits set in order to get code running in a different (and possibly more privileged) user’s context. On Linux or macOS, when the setuid or setgid bits are set for an application binary, the application will run with the privileges of the owning user or group respectively.(Citation: setuid man page) Normally an application is run in the current user’s context, regardless of which user or group owns the application. However, there are instances where programs need to be executed in an elevated context to function properly, but the user running them may not have the specific required privileges." ;
    skos:exactMatch d3f:T1548.001,
        mitre-attack:T1548.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548002 a owl:Class ;
    rdfs:label "T1548_002" ;
    d3f:attack-id "T1548.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bypass User Account Control" ;
    rdfs:subClassOf d3f:T1548 ;
    skos:altLabel "T1548.002" ;
    skos:definition "Adversaries may bypass UAC mechanisms to elevate process privileges on system. Windows User Account Control (UAC) allows a program to elevate its privileges (tracked as integrity levels ranging from low to high) to perform a task under administrator-level permissions, possibly by prompting the user for confirmation. The impact to the user ranges from denying the operation under high enforcement to allowing the user to perform the action if they are in the local administrators group and click through the prompt or allowing them to enter an administrator password to complete the action.(Citation: TechNet How UAC Works)" ;
    skos:exactMatch d3f:T1548.002,
        mitre-attack:T1548.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548003 a owl:Class ;
    rdfs:label "T1548_003" ;
    d3f:attack-id "T1548.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Sudo and Sudo Caching" ;
    rdfs:subClassOf d3f:T1548 ;
    skos:altLabel "T1548.003" ;
    skos:definition "Adversaries may perform sudo caching and/or use the sudoers file to elevate privileges. Adversaries may do this to execute commands as other users or spawn processes with higher privileges." ;
    skos:exactMatch d3f:T1548.003,
        mitre-attack:T1548.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548004 a owl:Class ;
    rdfs:label "T1548_004" ;
    d3f:attack-id "T1548.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Elevated Execution with Prompt" ;
    rdfs:subClassOf d3f:T1548 ;
    skos:altLabel "T1548.004" ;
    skos:definition "Adversaries may leverage the <code>AuthorizationExecuteWithPrivileges</code> API to escalate privileges by prompting the user for credentials.(Citation: AppleDocs AuthorizationExecuteWithPrivileges) The purpose of this API is to give application developers an easy way to perform operations with root privileges, such as for application installation or updating. This API does not validate that the program requesting root privileges comes from a reputable source or has been maliciously modified." ;
    skos:exactMatch d3f:T1548.004,
        mitre-attack:T1548.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548005 a owl:Class ;
    rdfs:label "T1548_005" ;
    d3f:attack-id "T1548.005" ;
    dcterms:title "Temporary Elevated Cloud Access" ;
    rdfs:subClassOf d3f:T1548 ;
    skos:altLabel "T1548.005" ;
    skos:definition "Adversaries may abuse permission configurations that allow them to gain temporarily elevated access to cloud resources. Many cloud environments allow administrators to grant user or service accounts permission to request just-in-time access to roles, impersonate other accounts, pass roles onto resources and services, or otherwise gain short-term access to a set of privileges that may be distinct from their own." ;
    skos:exactMatch d3f:T1548.005,
        mitre-attack:T1548.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1548006 a owl:Class ;
    rdfs:label "T1548_006" ;
    d3f:attack-id "T1548.006" ;
    dcterms:title "TCC Manipulation" ;
    rdfs:subClassOf d3f:T1548 ;
    skos:altLabel "T1548.006" ;
    skos:definition "Adversaries can manipulate or abuse the Transparency, Consent, & Control (TCC) service or database to execute malicious applications with elevated permissions. TCC is a Privacy & Security macOS control mechanism used to determine if the running process has permission to access the data or services protected by TCC, such as screen sharing, camera, microphone, or Full Disk Access (FDA)." ;
    skos:exactMatch d3f:T1548.006,
        mitre-attack:T1548.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1550001 a owl:Class ;
    rdfs:label "T1550_001" ;
    d3f:attack-id "T1550.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Access Token" ;
    rdfs:subClassOf d3f:T1550 ;
    skos:altLabel "T1550.001" ;
    skos:definition "Adversaries may use stolen application access tokens to bypass the typical authentication process and access restricted accounts, information, or services on remote systems. These tokens are typically stolen from users or services and used in lieu of login credentials." ;
    skos:exactMatch d3f:T1550.001,
        mitre-attack:T1550.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1550002 a owl:Class ;
    rdfs:label "T1550_002" ;
    d3f:attack-id "T1550.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pass the Hash" ;
    rdfs:subClassOf d3f:T1550 ;
    skos:altLabel "T1550.002" ;
    skos:definition "Adversaries may “pass the hash” using stolen password hashes to move laterally within an environment, bypassing normal system access controls. Pass the hash (PtH) is a method of authenticating as a user without having access to the user's cleartext password. This method bypasses standard authentication steps that require a cleartext password, moving directly into the portion of the authentication that uses the password hash." ;
    skos:exactMatch d3f:T1550.002,
        mitre-attack:T1550.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1550003 a owl:Class ;
    rdfs:label "T1550_003" ;
    d3f:attack-id "T1550.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pass the Ticket" ;
    rdfs:subClassOf d3f:T1550 ;
    skos:altLabel "T1550.003" ;
    skos:definition "Adversaries may “pass the ticket” using stolen Kerberos tickets to move laterally within an environment, bypassing normal system access controls. Pass the ticket (PtT) is a method of authenticating to a system using Kerberos tickets without having access to an account's password. Kerberos authentication can be used as the first step to lateral movement to a remote system." ;
    skos:exactMatch d3f:T1550.003,
        mitre-attack:T1550.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1550004 a owl:Class ;
    rdfs:label "T1550_004" ;
    d3f:attack-id "T1550.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Session Cookie" ;
    rdfs:subClassOf d3f:T1550 ;
    skos:altLabel "T1550.004" ;
    skos:definition "Adversaries can use stolen session cookies to authenticate to web applications and services. This technique bypasses some multi-factor authentication protocols since the session is already authenticated.(Citation: Pass The Cookie)" ;
    skos:exactMatch d3f:T1550.004,
        mitre-attack:T1550.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552001 a owl:Class ;
    rdfs:label "T1552_001" ;
    d3f:attack-id "T1552.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credentials In Files" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.001" ;
    skos:definition "Adversaries may search local file systems and remote file shares for files containing insecurely stored credentials. These can be files created by users to store their own credentials, shared credential stores for a group of individuals, configuration files containing passwords for a system or service, or source code/binary files containing embedded passwords." ;
    skos:exactMatch d3f:T1552.001,
        mitre-attack:T1552.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552002 a owl:Class ;
    rdfs:label "T1552_002" ;
    d3f:attack-id "T1552.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credentials in Registry" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.002" ;
    skos:definition "Adversaries may search the Registry on compromised systems for insecurely stored credentials. The Windows Registry stores configuration information that can be used by the system or other programs. Adversaries may query the Registry looking for credentials and passwords that have been stored for use by other programs or services. Sometimes these credentials are used for automatic logons." ;
    skos:exactMatch d3f:T1552.002,
        mitre-attack:T1552.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552003 a owl:Class ;
    rdfs:label "T1552_003" ;
    d3f:attack-id "T1552.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bash History" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.003" ;
    skos:definition "Adversaries may search the bash command history on compromised systems for insecurely stored credentials. Bash keeps track of the commands users type on the command-line with the \"history\" utility. Once a user logs out, the history is flushed to the user’s <code>.bash_history</code> file. For each user, this file resides at the same location: <code>~/.bash_history</code>. Typically, this file keeps track of the user’s last 500 commands. Users often type usernames and passwords on the command-line as parameters to programs, which then get saved to this file when they log out. Adversaries can abuse this by looking through the file for potential credentials. (Citation: External to DA, the OS X Way)" ;
    skos:exactMatch d3f:T1552.003,
        mitre-attack:T1552.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552004 a owl:Class ;
    rdfs:label "T1552_004" ;
    d3f:attack-id "T1552.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Private Keys" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.004" ;
    skos:definition "Adversaries may search for private key certificate files on compromised systems for insecurely stored credentials. Private cryptographic keys and certificates are used for authentication, encryption/decryption, and digital signatures.(Citation: Wikipedia Public Key Crypto) Common key and certificate file extensions include: .key, .pgp, .gpg, .ppk., .p12, .pem, .pfx, .cer, .p7b, .asc." ;
    skos:exactMatch d3f:T1552.004,
        mitre-attack:T1552.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552005 a owl:Class ;
    rdfs:label "T1552_005" ;
    d3f:attack-id "T1552.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Instance Metadata API" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.005" ;
    skos:definition "Adversaries may attempt to access the Cloud Instance Metadata API to collect credentials and other sensitive data." ;
    skos:exactMatch d3f:T1552.005,
        mitre-attack:T1552.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552006 a owl:Class ;
    rdfs:label "T1552_006" ;
    d3f:attack-id "T1552.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Group Policy Preferences" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.006" ;
    skos:definition "Adversaries may attempt to find unsecured credentials in Group Policy Preferences (GPP). GPP are tools that allow administrators to create domain policies with embedded credentials. These policies allow administrators to set local accounts.(Citation: Microsoft GPP 2016)" ;
    skos:exactMatch d3f:T1552.006,
        mitre-attack:T1552.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552007 a owl:Class ;
    rdfs:label "T1552_007" ;
    d3f:attack-id "T1552.007" ;
    dcterms:title "Container API" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.007" ;
    skos:definition "Adversaries may gather credentials via APIs within a containers environment. APIs in these environments, such as the Docker API and Kubernetes APIs, allow a user to remotely manage their container resources and cluster components.(Citation: Docker API)(Citation: Kubernetes API)" ;
    skos:exactMatch d3f:T1552.007,
        mitre-attack:T1552.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552008 a owl:Class ;
    rdfs:label "T1552_008" ;
    d3f:attack-id "T1552.008" ;
    dcterms:title "Chat Messages" ;
    rdfs:subClassOf d3f:T1552 ;
    skos:altLabel "T1552.008" ;
    skos:definition "Adversaries may directly collect unsecured credentials stored or passed through user communication services. Credentials may be sent and stored in user chat communication applications such as email, chat services like Slack or Teams, collaboration tools like Jira or Trello, and any other services that support user communication. Users may share various forms of credentials (such as usernames and passwords, API keys, or authentication tokens) on private or public corporate internal communications channels." ;
    skos:exactMatch d3f:T1552.008,
        mitre-attack:T1552.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553001 a owl:Class ;
    rdfs:label "T1553_001" ;
    d3f:attack-id "T1553.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Gatekeeper Bypass" ;
    rdfs:subClassOf d3f:T1553 ;
    skos:altLabel "T1553.001" ;
    skos:definition "Adversaries may modify file attributes and subvert Gatekeeper functionality to evade user prompts and execute untrusted programs. Gatekeeper is a set of technologies that act as layer of Apple’s security model to ensure only trusted applications are executed on a host. Gatekeeper was built on top of File Quarantine in Snow Leopard (10.6, 2009) and has grown to include Code Signing, security policy compliance, Notarization, and more. Gatekeeper also treats applications running for the first time differently than reopened applications.(Citation: TheEclecticLightCompany Quarantine and the flag)(Citation: TheEclecticLightCompany apple notarization )" ;
    skos:exactMatch d3f:T1553.001,
        mitre-attack:T1553.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553002 a owl:Class ;
    rdfs:label "T1553_002" ;
    d3f:attack-id "T1553.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Code Signing" ;
    rdfs:subClassOf d3f:T1553 ;
    skos:altLabel "T1553.002" ;
    skos:definition "Adversaries may create, acquire, or steal code signing materials to sign their malware or tools. Code signing provides a level of authenticity on a binary from the developer and a guarantee that the binary has not been tampered with. (Citation: Wikipedia Code Signing) The certificates used during an operation may be created, acquired, or stolen by the adversary. (Citation: Securelist Digital Certificates) (Citation: Symantec Digital Certificates) Unlike [Invalid Code Signature](https://attack.mitre.org/techniques/T1036/001), this activity will result in a valid signature." ;
    skos:exactMatch d3f:T1553.002,
        mitre-attack:T1553.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553003 a owl:Class ;
    rdfs:label "T1553_003" ;
    d3f:attack-id "T1553.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "SIP and Trust Provider Hijacking" ;
    rdfs:subClassOf d3f:T1553 ;
    skos:altLabel "T1553.003" ;
    skos:definition "Adversaries may tamper with SIP and trust provider components to mislead the operating system and application control tools when conducting signature validation checks. In user mode, Windows Authenticode (Citation: Microsoft Authenticode) digital signatures are used to verify a file's origin and integrity, variables that may be used to establish trust in signed code (ex: a driver with a valid Microsoft signature may be handled as safe). The signature validation process is handled via the WinVerifyTrust application programming interface (API) function,  (Citation: Microsoft WinVerifyTrust) which accepts an inquiry and coordinates with the appropriate trust provider, which is responsible for validating parameters of a signature. (Citation: SpectorOps Subverting Trust Sept 2017)" ;
    skos:exactMatch d3f:T1553.003,
        mitre-attack:T1553.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553004 a owl:Class ;
    rdfs:label "T1553_004" ;
    d3f:attack-id "T1553.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Install Root Certificate" ;
    rdfs:subClassOf d3f:T1553 ;
    skos:altLabel "T1553.004" ;
    skos:definition "Adversaries may install a root certificate on a compromised system to avoid warnings when connecting to adversary controlled web servers. Root certificates are used in public key cryptography to identify a root certificate authority (CA). When a root certificate is installed, the system or application will trust certificates in the root's chain of trust that have been signed by the root certificate.(Citation: Wikipedia Root Certificate) Certificates are commonly used for establishing secure TLS/SSL communications within a web browser. When a user attempts to browse a website that presents a certificate that is not trusted an error message will be displayed to warn the user of the security risk. Depending on the security settings, the browser may not allow the user to establish a connection to the website." ;
    skos:exactMatch d3f:T1553.004,
        mitre-attack:T1553.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553005 a owl:Class ;
    rdfs:label "T1553_005" ;
    d3f:attack-id "T1553.005" ;
    dcterms:title "Mark-of-the-Web Bypass" ;
    rdfs:subClassOf d3f:T1553 ;
    skos:altLabel "T1553.005" ;
    skos:definition "Adversaries may abuse specific file formats to subvert Mark-of-the-Web (MOTW) controls. In Windows, when files are downloaded from the Internet, they are tagged with a hidden NTFS Alternate Data Stream (ADS) named <code>Zone.Identifier</code> with a specific value known as the MOTW.(Citation: Microsoft Zone.Identifier 2020) Files that are tagged with MOTW are protected and cannot perform certain actions. For example, starting in MS Office 10, if a MS Office file has the MOTW, it will open in Protected View. Executables tagged with the MOTW will be processed by Windows Defender SmartScreen that compares files with an allowlist of well-known executables. If the file is not known/trusted, SmartScreen will prevent the execution and warn the user not to run it.(Citation: Beek Use of VHD Dec 2020)(Citation: Outflank MotW 2020)(Citation: Intezer Russian APT Dec 2020)" ;
    skos:exactMatch d3f:T1553.005,
        mitre-attack:T1553.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553006 a owl:Class ;
    rdfs:label "T1553_006" ;
    d3f:attack-id "T1553.006" ;
    dcterms:title "Code Signing Policy Modification" ;
    rdfs:subClassOf d3f:T1553 ;
    skos:altLabel "T1553.006" ;
    skos:definition "Adversaries may modify code signing policies to enable execution of unsigned or self-signed code. Code signing provides a level of authenticity on a program from a developer and a guarantee that the program has not been tampered with. Security controls can include enforcement mechanisms to ensure that only valid, signed code can be run on an operating system." ;
    skos:exactMatch d3f:T1553.006,
        mitre-attack:T1553.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555001 a owl:Class ;
    rdfs:label "T1555_001" ;
    d3f:attack-id "T1555.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Keychain" ;
    rdfs:subClassOf d3f:T1555 ;
    skos:altLabel "T1555.001" ;
    skos:definition "Adversaries may acquire credentials from Keychain. Keychain (or Keychain Services) is the macOS credential management system that stores account names, passwords, private keys, certificates, sensitive application data, payment data, and secure notes. There are three types of Keychains: Login Keychain, System Keychain, and Local Items (iCloud) Keychain. The default Keychain is the Login Keychain, which stores user passwords and information. The System Keychain stores items accessed by the operating system, such as items shared among users on a host. The Local Items (iCloud) Keychain is used for items synced with Apple’s iCloud service." ;
    skos:exactMatch d3f:T1555.001,
        mitre-attack:T1555.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555002 a owl:Class ;
    rdfs:label "T1555_002" ;
    d3f:attack-id "T1555.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Securityd Memory" ;
    rdfs:subClassOf d3f:T1555 ;
    skos:altLabel "T1555.002" ;
    skos:definition "An adversary with root access may gather credentials by reading `securityd`’s memory. `securityd` is a service/daemon responsible for implementing security protocols such as encryption and authorization.(Citation: Apple Dev SecurityD) A privileged adversary may be able to scan through `securityd`'s memory to find the correct sequence of keys to decrypt the user’s logon keychain. This may provide the adversary with various plaintext passwords, such as those for users, WiFi, mail, browsers, certificates, secure notes, etc.(Citation: OS X Keychain)(Citation: OSX Keydnap malware)" ;
    skos:exactMatch d3f:T1555.002,
        mitre-attack:T1555.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555003 a owl:Class ;
    rdfs:label "T1555_003" ;
    d3f:attack-id "T1555.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credentials from Web Browsers" ;
    rdfs:subClassOf d3f:T1555 ;
    skos:altLabel "T1555.003" ;
    skos:definition "Adversaries may acquire credentials from web browsers by reading files specific to the target browser.(Citation: Talos Olympic Destroyer 2018) Web browsers commonly save credentials such as website usernames and passwords so that they do not need to be entered manually in the future. Web browsers typically store the credentials in an encrypted format within a credential store; however, methods exist to extract plaintext credentials from web browsers." ;
    skos:exactMatch d3f:T1555.003,
        mitre-attack:T1555.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555004 a owl:Class ;
    rdfs:label "T1555_004" ;
    d3f:attack-id "T1555.004" ;
    dcterms:title "Windows Credential Manager" ;
    rdfs:subClassOf d3f:T1555 ;
    skos:altLabel "T1555.004" ;
    skos:definition "Adversaries may acquire credentials from the Windows Credential Manager. The Credential Manager stores credentials for signing into websites, applications, and/or devices that request authentication through NTLM or Kerberos in Credential Lockers (previously known as Windows Vaults).(Citation: Microsoft Credential Manager store)(Citation: Microsoft Credential Locker)" ;
    skos:exactMatch d3f:T1555.004,
        mitre-attack:T1555.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555005 a owl:Class ;
    rdfs:label "T1555_005" ;
    d3f:attack-id "T1555.005" ;
    dcterms:title "Password Managers" ;
    rdfs:subClassOf d3f:T1555 ;
    skos:altLabel "T1555.005" ;
    skos:definition "Adversaries may acquire user credentials from third-party password managers.(Citation: ise Password Manager February 2019) Password managers are applications designed to store user credentials, normally in an encrypted database. Credentials are typically accessible after a user provides a master password that unlocks the database. After the database is unlocked, these credentials may be copied to memory. These databases can be stored as files on disk.(Citation: ise Password Manager February 2019)" ;
    skos:exactMatch d3f:T1555.005,
        mitre-attack:T1555.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555006 a owl:Class ;
    rdfs:label "T1555_006" ;
    d3f:attack-id "T1555.006" ;
    dcterms:title "Cloud Secrets Management Stores" ;
    rdfs:subClassOf d3f:T1555 ;
    skos:altLabel "T1555.006" ;
    skos:definition "Adversaries may acquire credentials from cloud-native secret management solutions such as AWS Secrets Manager, GCP Secret Manager, Azure Key Vault, and Terraform Vault." ;
    skos:exactMatch d3f:T1555.006,
        mitre-attack:T1555.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556001 a owl:Class ;
    rdfs:label "T1556_001" ;
    d3f:attack-id "T1556.001" ;
    dcterms:title "Domain Controller Authentication" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.001" ;
    skos:definition "Adversaries may patch the authentication process on a domain controller to bypass the typical authentication mechanisms and enable access to accounts." ;
    skos:exactMatch d3f:T1556.001,
        mitre-attack:T1556.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556002 a owl:Class ;
    rdfs:label "T1556_002" ;
    d3f:attack-id "T1556.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Filter DLL" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.002" ;
    skos:definition "Adversaries may register malicious password filter dynamic link libraries (DLLs) into the authentication process to acquire user credentials as they are validated." ;
    skos:exactMatch d3f:T1556.002,
        mitre-attack:T1556.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556003 a owl:Class ;
    rdfs:label "T1556_003" ;
    d3f:attack-id "T1556.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pluggable Authentication Modules" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.003" ;
    skos:definition "Adversaries may modify pluggable authentication modules (PAM) to access user credentials or enable otherwise unwarranted access to accounts. PAM is a modular system of configuration files, libraries, and executable files which guide authentication for many services. The most common authentication module is <code>pam_unix.so</code>, which retrieves, sets, and verifies account authentication information in <code>/etc/passwd</code> and <code>/etc/shadow</code>.(Citation: Apple PAM)(Citation: Man Pam_Unix)(Citation: Red Hat PAM)" ;
    skos:exactMatch d3f:T1556.003,
        mitre-attack:T1556.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556004 a owl:Class ;
    rdfs:label "T1556_004" ;
    d3f:attack-id "T1556.004" ;
    dcterms:title "Network Device Authentication" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.004" ;
    skos:definition "Adversaries may use [Patch System Image](https://attack.mitre.org/techniques/T1601/001) to hard code a password in the operating system, thus bypassing of native authentication mechanisms for local accounts on network devices." ;
    skos:exactMatch d3f:T1556.004,
        mitre-attack:T1556.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556005 a owl:Class ;
    rdfs:label "T1556_005" ;
    d3f:attack-id "T1556.005" ;
    dcterms:title "Reversible Encryption" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.005" ;
    skos:definition "An adversary may abuse Active Directory authentication encryption properties to gain access to credentials on Windows systems. The <code>AllowReversiblePasswordEncryption</code> property specifies whether reversible password encryption for an account is enabled or disabled. By default this property is disabled (instead storing user credentials as the output of one-way hashing functions) and should not be enabled unless legacy or other software require it.(Citation: store_pwd_rev_enc)" ;
    skos:exactMatch d3f:T1556.005,
        mitre-attack:T1556.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556006 a owl:Class ;
    rdfs:label "T1556_006" ;
    d3f:attack-id "T1556.006" ;
    dcterms:title "Multi-Factor Authentication" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.006" ;
    skos:definition "Adversaries may disable or modify multi-factor authentication (MFA) mechanisms to enable persistent access to compromised accounts." ;
    skos:exactMatch d3f:T1556.006,
        mitre-attack:T1556.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556007 a owl:Class ;
    rdfs:label "T1556_007" ;
    d3f:attack-id "T1556.007" ;
    dcterms:title "Hybrid Identity" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.007" ;
    skos:definition "Adversaries may patch, modify, or otherwise backdoor cloud authentication processes that are tied to on-premises user identities in order to bypass typical authentication mechanisms, access credentials, and enable persistent access to accounts." ;
    skos:exactMatch d3f:T1556.007,
        mitre-attack:T1556.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556008 a owl:Class ;
    rdfs:label "T1556_008" ;
    d3f:attack-id "T1556.008" ;
    dcterms:title "Network Provider DLL" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.008" ;
    skos:definition "Adversaries may register malicious network provider dynamic link libraries (DLLs) to capture cleartext user credentials during the authentication process. Network provider DLLs allow Windows to interface with specific network protocols and can also support add-on credential management functions.(Citation: Network Provider API) During the logon process, Winlogon (the interactive logon module) sends credentials to the local `mpnotify.exe` process via RPC. The `mpnotify.exe` process then shares the credentials in cleartext with registered credential managers when notifying that a logon event is happening.(Citation: NPPSPY - Huntress)(Citation: NPPSPY Video)(Citation: NPLogonNotify)" ;
    skos:exactMatch d3f:T1556.008,
        mitre-attack:T1556.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556009 a owl:Class ;
    rdfs:label "T1556_009" ;
    d3f:attack-id "T1556.009" ;
    dcterms:title "Conditional Access Policies" ;
    rdfs:subClassOf d3f:T1556 ;
    skos:altLabel "T1556.009" ;
    skos:definition "Adversaries may disable or modify conditional access policies to enable persistent access to compromised accounts. Conditional access policies are additional verifications used by identity providers and identity and access management systems to determine whether a user should be granted access to a resource." ;
    skos:exactMatch d3f:T1556.009,
        mitre-attack:T1556.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1557001 a owl:Class ;
    rdfs:label "T1557_001" ;
    d3f:attack-id "T1557.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "LLMNR/NBT-NS Poisoning and SMB Relay" ;
    rdfs:subClassOf d3f:T1557 ;
    skos:altLabel "T1557.001" ;
    skos:definition "By responding to LLMNR/NBT-NS network traffic, adversaries may spoof an authoritative source for name resolution to force communication with an adversary controlled system. This activity may be used to collect or relay authentication materials." ;
    skos:exactMatch d3f:T1557.001,
        mitre-attack:T1557.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1557002 a owl:Class ;
    rdfs:label "T1557_002" ;
    d3f:attack-id "T1557.002" ;
    dcterms:title "ARP Cache Poisoning" ;
    rdfs:subClassOf d3f:T1557 ;
    skos:altLabel "T1557.002" ;
    skos:definition "Adversaries may poison Address Resolution Protocol (ARP) caches to position themselves between the communication of two or more networked devices. This activity may be used to enable follow-on behaviors such as [Network Sniffing](https://attack.mitre.org/techniques/T1040) or [Transmitted Data Manipulation](https://attack.mitre.org/techniques/T1565/002)." ;
    skos:exactMatch d3f:T1557.002,
        mitre-attack:T1557.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1557003 a owl:Class ;
    rdfs:label "T1557_003" ;
    d3f:attack-id "T1557.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DHCP Spoofing" ;
    rdfs:subClassOf d3f:T1557 ;
    skos:altLabel "T1557.003" ;
    skos:definition "Adversaries may redirect network traffic to adversary-owned systems by spoofing Dynamic Host Configuration Protocol (DHCP) traffic and acting as a malicious DHCP server on the victim network. By achieving the adversary-in-the-middle (AiTM) position, adversaries may collect network communications, including passed credentials, especially those sent over insecure, unencrypted protocols. This may also enable follow-on behaviors such as [Network Sniffing](https://attack.mitre.org/techniques/T1040) or [Transmitted Data Manipulation](https://attack.mitre.org/techniques/T1565/002)." ;
    skos:exactMatch d3f:T1557.003,
        mitre-attack:T1557.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1557004 a owl:Class ;
    rdfs:label "T1557_004" ;
    d3f:attack-id "T1557.004" ;
    dcterms:title "Evil Twin" ;
    rdfs:subClassOf d3f:T1557 ;
    skos:altLabel "T1557.004" ;
    skos:definition "Adversaries may host seemingly genuine Wi-Fi access points to deceive users into connecting to malicious networks as a way of supporting follow-on behaviors such as [Network Sniffing](https://attack.mitre.org/techniques/T1040), [Transmitted Data Manipulation](https://attack.mitre.org/techniques/T1565/002), or [Input Capture](https://attack.mitre.org/techniques/T1056).(Citation: Australia ‘Evil Twin’)" ;
    skos:exactMatch d3f:T1557.004,
        mitre-attack:T1557.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1558001 a owl:Class ;
    rdfs:label "T1558_001" ;
    d3f:attack-id "T1558.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Golden Ticket" ;
    rdfs:subClassOf d3f:T1558 ;
    skos:altLabel "T1558.001" ;
    skos:definition "Adversaries who have the KRBTGT account password hash may forge Kerberos ticket-granting tickets (TGT), also known as a golden ticket.(Citation: AdSecurity Kerberos GT Aug 2015) Golden tickets enable adversaries to generate authentication material for any account in Active Directory.(Citation: CERT-EU Golden Ticket Protection)" ;
    skos:exactMatch d3f:T1558.001,
        mitre-attack:T1558.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1558002 a owl:Class ;
    rdfs:label "T1558_002" ;
    d3f:attack-id "T1558.002" ;
    dcterms:title "Silver Ticket" ;
    rdfs:subClassOf d3f:T1558 ;
    skos:altLabel "T1558.002" ;
    skos:definition "Adversaries who have the password hash of a target service account (e.g. SharePoint, MSSQL) may forge Kerberos ticket granting service (TGS) tickets, also known as silver tickets. Kerberos TGS tickets are also known as service tickets.(Citation: ADSecurity Silver Tickets)" ;
    skos:exactMatch d3f:T1558.002,
        mitre-attack:T1558.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1558003 a owl:Class ;
    rdfs:label "T1558_003" ;
    d3f:attack-id "T1558.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Kerberoasting" ;
    rdfs:seeAlso <https://docs.microsoft.com/en-us/openspecs/windows_protocols/ms-nspi/6dd0a3ea-b4d4-4a73-a857-add03a89a543> ;
    rdfs:subClassOf d3f:T1558 ;
    skos:altLabel "T1558.003" ;
    skos:definition "Service Provider Name (SPN) scanning is one way to gather hashes, which results in RPC calls conforming to the NSPI protocol." ;
    skos:exactMatch d3f:T1558.003,
        mitre-attack:T1558.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1558004 a owl:Class ;
    rdfs:label "T1558_004" ;
    d3f:attack-id "T1558.004" ;
    dcterms:title "AS-REP Roasting" ;
    rdfs:subClassOf d3f:T1558 ;
    skos:altLabel "T1558.004" ;
    skos:definition "Adversaries may reveal credentials of accounts that have disabled Kerberos preauthentication by [Password Cracking](https://attack.mitre.org/techniques/T1110/002) Kerberos messages.(Citation: Harmj0y Roasting AS-REPs Jan 2017)" ;
    skos:exactMatch d3f:T1558.004,
        mitre-attack:T1558.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1558005 a owl:Class ;
    rdfs:label "T1558_005" ;
    d3f:attack-id "T1558.005" ;
    dcterms:title "Ccache Files" ;
    rdfs:subClassOf d3f:T1558 ;
    skos:altLabel "T1558.005" ;
    skos:definition "Adversaries may attempt to steal Kerberos tickets stored in credential cache files (or ccache). These files are used for short term storage of a user's active session credentials. The ccache file is created upon user authentication and allows for access to multiple services without the user having to re-enter credentials." ;
    skos:exactMatch d3f:T1558.005,
        mitre-attack:T1558.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1559001 a owl:Class ;
    rdfs:label "T1559_001" ;
    d3f:attack-id "T1559.001" ;
    dcterms:title "Component Object Model" ;
    rdfs:subClassOf d3f:T1559 ;
    skos:altLabel "T1559.001" ;
    skos:definition "Adversaries may use the Windows Component Object Model (COM) for local code execution. COM is an inter-process communication (IPC) component of the native Windows application programming interface (API) that enables interaction between software objects, or executable code that implements one or more interfaces.(Citation: Fireeye Hunting COM June 2019) Through COM, a client object can call methods of server objects, which are typically binary Dynamic Link Libraries (DLL) or executables (EXE).(Citation: Microsoft COM) Remote COM execution is facilitated by [Remote Services](https://attack.mitre.org/techniques/T1021) such as  [Distributed Component Object Model](https://attack.mitre.org/techniques/T1021/003) (DCOM).(Citation: Fireeye Hunting COM June 2019)" ;
    skos:exactMatch d3f:T1559.001,
        mitre-attack:T1559.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1559002 a owl:Class ;
    rdfs:label "T1559_002" ;
    d3f:attack-id "T1559.002" ;
    dcterms:title "Dynamic Data Exchange" ;
    rdfs:subClassOf d3f:T1559 ;
    skos:altLabel "T1559.002" ;
    skos:definition "Adversaries may use Windows Dynamic Data Exchange (DDE) to execute arbitrary commands. DDE is a client-server protocol for one-time and/or continuous inter-process communication (IPC) between applications. Once a link is established, applications can autonomously exchange transactions consisting of strings, warm data links (notifications when a data item changes), hot data links (duplications of changes to a data item), and requests for command execution." ;
    skos:exactMatch d3f:T1559.002,
        mitre-attack:T1559.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1559003 a owl:Class ;
    rdfs:label "T1559_003" ;
    d3f:attack-id "T1559.003" ;
    dcterms:title "XPC Services" ;
    rdfs:subClassOf d3f:T1559 ;
    skos:altLabel "T1559.003" ;
    skos:definition "Adversaries can provide malicious content to an XPC service daemon for local code execution. macOS uses XPC services for basic inter-process communication between various processes, such as between the XPC Service daemon and third-party application privileged helper tools. Applications can send messages to the XPC Service daemon, which runs as root, using the low-level XPC Service <code>C API</code> or the high level <code>NSXPCConnection API</code> in order to handle tasks that require elevated privileges (such as network connections). Applications are responsible for providing the protocol definition which serves as a blueprint of the XPC services. Developers typically use XPC Services to provide applications stability and privilege separation between the application client and the daemon.(Citation: creatingXPCservices)(Citation: Designing Daemons Apple Dev)" ;
    skos:exactMatch d3f:T1559.003,
        mitre-attack:T1559.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1560001 a owl:Class ;
    rdfs:label "T1560_001" ;
    d3f:attack-id "T1560.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Archive via Utility" ;
    rdfs:subClassOf d3f:T1560 ;
    skos:altLabel "T1560.001" ;
    skos:definition "Adversaries may use utilities to compress and/or encrypt collected data prior to exfiltration. Many utilities include functionalities to compress, encrypt, or otherwise package data into a format that is easier/more secure to transport." ;
    skos:exactMatch d3f:T1560.001,
        mitre-attack:T1560.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1560002 a owl:Class ;
    rdfs:label "T1560_002" ;
    d3f:attack-id "T1560.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Archive via Library" ;
    rdfs:subClassOf d3f:T1560 ;
    skos:altLabel "T1560.002" ;
    skos:definition "An adversary may compress or encrypt data that is collected prior to exfiltration using 3rd party libraries. Many libraries exist that can archive data, including [Python](https://attack.mitre.org/techniques/T1059/006) rarfile (Citation: PyPI RAR), libzip (Citation: libzip), and zlib (Citation: Zlib Github). Most libraries include functionality to encrypt and/or compress data." ;
    skos:exactMatch d3f:T1560.002,
        mitre-attack:T1560.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1560003 a owl:Class ;
    rdfs:label "T1560_003" ;
    d3f:attack-id "T1560.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Archive via Custom Method" ;
    rdfs:subClassOf d3f:T1560 ;
    skos:altLabel "T1560.003" ;
    skos:definition "An adversary may compress or encrypt data that is collected prior to exfiltration using a custom method. Adversaries may choose to use custom archival methods, such as encryption with XOR or stream ciphers implemented with no external library or utility references. Custom implementations of well-known compression algorithms have also been used.(Citation: ESET Sednit Part 2)" ;
    skos:exactMatch d3f:T1560.003,
        mitre-attack:T1560.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1561001 a owl:Class ;
    rdfs:label "T1561_001" ;
    d3f:attack-id "T1561.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disk Content Wipe" ;
    rdfs:subClassOf d3f:T1561 ;
    skos:altLabel "T1561.001" ;
    skos:definition "Adversaries may erase the contents of storage devices on specific systems or in large numbers in a network to interrupt availability to system and network resources." ;
    skos:exactMatch d3f:T1561.001,
        mitre-attack:T1561.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1561002 a owl:Class ;
    rdfs:label "T1561_002" ;
    d3f:attack-id "T1561.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disk Structure Wipe" ;
    rdfs:subClassOf d3f:T1561 ;
    skos:altLabel "T1561.002" ;
    skos:definition "Adversaries may corrupt or wipe the disk data structures on a hard drive necessary to boot a system; targeting specific critical systems or in large numbers in a network to interrupt availability to system and network resources." ;
    skos:exactMatch d3f:T1561.002,
        mitre-attack:T1561.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562001 a owl:Class ;
    rdfs:label "T1562_001" ;
    d3f:attack-id "T1562.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disable or Modify Tools" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.001" ;
    skos:definition "Adversaries may modify and/or disable security tools to avoid possible detection of their malware/tools and activities. This may take many forms, such as killing security software processes or services, modifying / deleting Registry keys or configuration files so that tools do not operate properly, or other methods to interfere with security tools scanning or reporting information. Adversaries may also disable updates to prevent the latest security patches from reaching tools on victim systems.(Citation: SCADAfence_ransomware)" ;
    skos:exactMatch d3f:T1562.001,
        mitre-attack:T1562.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562002 a owl:Class ;
    rdfs:label "T1562_002" ;
    d3f:attack-id "T1562.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disable Windows Event Logging" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.002" ;
    skos:definition "Adversaries may disable Windows event logging to limit data that can be leveraged for detections and audits. Windows event logs record user and system activity such as login attempts, process creation, and much more.(Citation: Windows Log Events) This data is used by security tools and analysts to generate detections." ;
    skos:exactMatch d3f:T1562.002,
        mitre-attack:T1562.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562003 a owl:Class ;
    rdfs:label "T1562_003" ;
    d3f:attack-id "T1562.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Impair Command History Logging" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.003" ;
    skos:definition "Adversaries may impair command history logging to hide commands they run on a compromised system. Various command interpreters keep track of the commands users type in their terminal so that users can retrace what they've done." ;
    skos:exactMatch d3f:T1562.003,
        mitre-attack:T1562.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562004 a owl:Class ;
    rdfs:label "T1562_004" ;
    d3f:attack-id "T1562.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disable or Modify System Firewall" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.004" ;
    skos:definition "Adversaries may disable or modify system firewalls in order to bypass controls limiting network usage. Changes could be disabling the entire mechanism as well as adding, deleting, or modifying particular rules. This can be done numerous ways depending on the operating system, including via command-line, editing Windows Registry keys, and Windows Control Panel." ;
    skos:exactMatch d3f:T1562.004,
        mitre-attack:T1562.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562006 a owl:Class ;
    rdfs:label "T1562_006" ;
    d3f:attack-id "T1562.006" ;
    dcterms:title "Indicator Blocking" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.006" ;
    skos:definition "An adversary may attempt to block indicators or events typically captured by sensors from being gathered and analyzed. This could include maliciously redirecting(Citation: Microsoft Lamin Sept 2017) or even disabling host-based sensors, such as Event Tracing for Windows (ETW)(Citation: Microsoft About Event Tracing 2018), by tampering settings that control the collection and flow of event telemetry.(Citation: Medium Event Tracing Tampering 2018) These settings may be stored on the system in configuration files and/or in the Registry as well as being accessible via administrative utilities such as [PowerShell](https://attack.mitre.org/techniques/T1059/001) or [Windows Management Instrumentation](https://attack.mitre.org/techniques/T1047)." ;
    skos:exactMatch d3f:T1562.006,
        mitre-attack:T1562.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562007 a owl:Class ;
    rdfs:label "T1562_007" ;
    d3f:attack-id "T1562.007" ;
    dcterms:title "Disable or Modify Cloud Firewall" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.007" ;
    skos:definition "Adversaries may disable or modify a firewall within a cloud environment to bypass controls that limit access to cloud resources. Cloud firewalls are separate from system firewalls that are described in [Disable or Modify System Firewall](https://attack.mitre.org/techniques/T1562/004)." ;
    skos:exactMatch d3f:T1562.007,
        mitre-attack:T1562.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562008 a owl:Class ;
    rdfs:label "T1562_008" ;
    d3f:attack-id "T1562.008" ;
    dcterms:title "Disable or Modify Cloud Logs" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.008" ;
    skos:definition "An adversary may disable or modify cloud logging capabilities and integrations to limit what data is collected on their activities and avoid detection. Cloud environments allow for collection and analysis of audit and application logs that provide insight into what activities a user does within the environment. If an adversary has sufficient permissions, they can disable or modify logging to avoid detection of their activities." ;
    skos:exactMatch d3f:T1562.008,
        mitre-attack:T1562.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562009 a owl:Class ;
    rdfs:label "T1562_009" ;
    d3f:attack-id "T1562.009" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Safe Mode Boot" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.009" ;
    skos:definition "Adversaries may abuse Windows safe mode to disable endpoint defenses. Safe mode starts up the Windows operating system with a limited set of drivers and services. Third-party security software such as endpoint detection and response (EDR) tools may not start after booting Windows in safe mode. There are two versions of safe mode: Safe Mode and Safe Mode with Networking. It is possible to start additional services after a safe mode boot.(Citation: Microsoft Safe Mode)(Citation: Sophos Snatch Ransomware 2019)" ;
    skos:exactMatch d3f:T1562.009,
        mitre-attack:T1562.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562010 a owl:Class ;
    rdfs:label "T1562_010" ;
    d3f:attack-id "T1562.010" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Downgrade Attack" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.010" ;
    skos:definition "Adversaries may downgrade or use a version of system features that may be outdated, vulnerable, and/or does not support updated security controls. Downgrade attacks typically take advantage of a system’s backward compatibility to force it into less secure modes of operation." ;
    skos:exactMatch d3f:T1562.010,
        mitre-attack:T1562.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562011 a owl:Class ;
    rdfs:label "T1562_011" ;
    d3f:attack-id "T1562.011" ;
    dcterms:title "Spoof Security Alerting" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.011" ;
    skos:definition "Adversaries may spoof security alerting from tools, presenting false evidence to impair defenders’ awareness of malicious activity.(Citation: BlackBasta) Messages produced by defensive tools contain information about potential security events as well as the functioning status of security software and the system. Security reporting messages are important for monitoring the normal operation of a system and identifying important events that can signal a security incident." ;
    skos:exactMatch d3f:T1562.011,
        mitre-attack:T1562.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562012 a owl:Class ;
    rdfs:label "T1562_012" ;
    d3f:attack-id "T1562.012" ;
    dcterms:title "Disable or Modify Linux Audit System" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.012" ;
    skos:definition "Adversaries may disable or modify the Linux audit system to hide malicious activity and avoid detection. Linux admins use the Linux Audit system to track security-relevant information on a system. The Linux Audit system operates at the kernel-level and maintains event logs on application and system activity such as process, network, file, and login events based on pre-configured rules." ;
    skos:exactMatch d3f:T1562.012,
        mitre-attack:T1562.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1562013 a owl:Class ;
    rdfs:label "T1562_013" ;
    d3f:attack-id "T1562.013" ;
    dcterms:title "Disable or Modify Network Device Firewall" ;
    rdfs:subClassOf d3f:T1562 ;
    skos:altLabel "T1562.013" ;
    skos:definition "Adversaries may disable network device-based firewall mechanisms entirely or add, delete, or modify particular rules in order to bypass controls limiting network usage." ;
    skos:exactMatch d3f:T1562.013,
        mitre-attack:T1562.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1563001 a owl:Class ;
    rdfs:label "T1563_001" ;
    d3f:attack-id "T1563.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "SSH Hijacking" ;
    rdfs:subClassOf d3f:T1563 ;
    skos:altLabel "T1563.001" ;
    skos:definition "Adversaries may hijack a legitimate user's SSH session to move laterally within an environment. Secure Shell (SSH) is a standard means of remote access on Linux and macOS systems. It allows a user to connect to another system via an encrypted tunnel, commonly authenticating through a password, certificate or the use of an asymmetric encryption key pair." ;
    skos:exactMatch d3f:T1563.001,
        mitre-attack:T1563.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1563002 a owl:Class ;
    rdfs:label "T1563_002" ;
    d3f:attack-id "T1563.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "RDP Hijacking" ;
    rdfs:subClassOf d3f:T1563 ;
    skos:altLabel "T1563.002" ;
    skos:definition "Adversaries may hijack a legitimate user’s remote desktop session to move laterally within an environment. Remote desktop is a common feature in operating systems. It allows a user to log into an interactive session with a system desktop graphical user interface on a remote system. Microsoft refers to its implementation of the Remote Desktop Protocol (RDP) as Remote Desktop Services (RDS).(Citation: TechNet Remote Desktop Services)" ;
    skos:exactMatch d3f:T1563.002,
        mitre-attack:T1563.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564001 a owl:Class ;
    rdfs:label "T1564_001" ;
    d3f:attack-id "T1564.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hidden Files and Directories" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.001" ;
    skos:definition "Adversaries may set files and directories to be hidden to evade detection mechanisms. To prevent normal users from accidentally changing special files on a system, most operating systems have the concept of a ‘hidden’ file. These files don’t show up when a user browses the file system with a GUI or when using normal commands on the command line. Users must explicitly ask to show the hidden files either via a series of Graphical User Interface (GUI) prompts or with command line switches (<code>dir /a</code> for Windows and <code>ls –a</code> for Linux and macOS)." ;
    skos:exactMatch d3f:T1564.001,
        mitre-attack:T1564.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564002 a owl:Class ;
    rdfs:label "T1564_002" ;
    d3f:attack-id "T1564.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hidden Users" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.002" ;
    skos:definition "Adversaries may use hidden users to hide the presence of user accounts they create or modify. Administrators may want to hide users when there are many user accounts on a given system or if they want to hide their administrative or other management accounts from other users." ;
    skos:exactMatch d3f:T1564.002,
        mitre-attack:T1564.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564003 a owl:Class ;
    rdfs:label "T1564_003" ;
    d3f:attack-id "T1564.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hidden Window" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.003" ;
    skos:definition "Adversaries may use hidden windows to conceal malicious activity from the plain sight of users. In some cases, windows that would typically be displayed when an application carries out an operation can be hidden. This may be utilized by system administrators to avoid disrupting user work environments when carrying out administrative tasks." ;
    skos:exactMatch d3f:T1564.003,
        mitre-attack:T1564.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564004 a owl:Class ;
    rdfs:label "T1564_004" ;
    d3f:attack-id "T1564.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "NTFS File Attributes" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.004" ;
    skos:definition "Adversaries may use NTFS file attributes to hide their malicious data in order to evade detection. Every New Technology File System (NTFS) formatted partition contains a Master File Table (MFT) that maintains a record for every file/directory on the partition. (Citation: SpectorOps Host-Based Jul 2017) Within MFT entries are file attributes, (Citation: Microsoft NTFS File Attributes Aug 2010) such as Extended Attributes (EA) and Data [known as Alternate Data Streams (ADSs) when more than one Data attribute is present], that can be used to store arbitrary data (and even complete files). (Citation: SpectorOps Host-Based Jul 2017) (Citation: Microsoft File Streams) (Citation: MalwareBytes ADS July 2015) (Citation: Microsoft ADS Mar 2014)" ;
    skos:exactMatch d3f:T1564.004,
        mitre-attack:T1564.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564005 a owl:Class ;
    rdfs:label "T1564_005" ;
    d3f:attack-id "T1564.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hidden File System" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.005" ;
    skos:definition "Adversaries may use a hidden file system to conceal malicious activity from users and security tools. File systems provide a structure to store and access data from physical storage. Typically, a user engages with a file system through applications that allow them to access files and directories, which are an abstraction from their physical location (ex: disk sector). Standard file systems include FAT, NTFS, ext4, and APFS. File systems can also contain other structures, such as the Volume Boot Record (VBR) and Master File Table (MFT) in NTFS.(Citation: MalwareTech VFS Nov 2014)" ;
    skos:exactMatch d3f:T1564.005,
        mitre-attack:T1564.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564006 a owl:Class ;
    rdfs:label "T1564_006" ;
    d3f:attack-id "T1564.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Run Virtual Instance" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.006" ;
    skos:definition "Adversaries may carry out malicious operations using a virtual instance to avoid detection. A wide variety of virtualization technologies exist that allow for the emulation of a computer or computing environment. By running malicious code inside of a virtual instance, adversaries can hide artifacts associated with their behavior from security tools that are unable to monitor activity inside the virtual instance. Additionally, depending on the virtual networking implementation (ex: bridged adapter), network traffic generated by the virtual instance can be difficult to trace back to the compromised host as the IP address and hostname might not match known values.(Citation: SingHealth Breach Jan 2019)" ;
    skos:exactMatch d3f:T1564.006,
        mitre-attack:T1564.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564007 a owl:Class ;
    rdfs:label "T1564_007" ;
    d3f:attack-id "T1564.007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "VBA Stomping" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.007" ;
    skos:definition "Adversaries may hide malicious Visual Basic for Applications (VBA) payloads embedded within MS Office documents by replacing the VBA source code with benign data.(Citation: FireEye VBA stomp Feb 2020)" ;
    skos:exactMatch d3f:T1564.007,
        mitre-attack:T1564.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564008 a owl:Class ;
    rdfs:label "T1564_008" ;
    d3f:attack-id "T1564.008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Email Hiding Rules" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.008" ;
    skos:definition "Adversaries may use email rules to hide inbound emails in a compromised user's mailbox. Many email clients allow users to create inbox rules for various email functions, including moving emails to other folders, marking emails as read, or deleting emails. Rules may be created or modified within email clients or through external features such as the <code>New-InboxRule</code> or <code>Set-InboxRule</code> [PowerShell](https://attack.mitre.org/techniques/T1059/001) cmdlets on Windows systems.(Citation: Microsoft Inbox Rules)(Citation: MacOS Email Rules)(Citation: Microsoft New-InboxRule)(Citation: Microsoft Set-InboxRule)" ;
    skos:exactMatch d3f:T1564.008,
        mitre-attack:T1564.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564009 a owl:Class ;
    rdfs:label "T1564_009" ;
    d3f:attack-id "T1564.009" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resource Forking" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.009" ;
    skos:definition "Adversaries may abuse resource forks to hide malicious code or executables to evade detection and bypass security applications. A resource fork provides applications a structured way to store resources such as thumbnail images, menu definitions, icons, dialog boxes, and code.(Citation: macOS Hierarchical File System Overview) Usage of a resource fork is identifiable when displaying a file’s extended attributes, using <code>ls -l@</code> or <code>xattr -l</code> commands. Resource forks have been deprecated and replaced with the application bundle structure. Non-localized resources are placed at the top level directory of an application bundle, while localized resources are placed in the <code>/Resources</code> folder.(Citation: Resource and Data Forks)(Citation: ELC Extended Attributes)" ;
    skos:exactMatch d3f:T1564.009,
        mitre-attack:T1564.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564010 a owl:Class ;
    rdfs:label "T1564_010" ;
    d3f:attack-id "T1564.010" ;
    dcterms:title "Process Argument Spoofing" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.010" ;
    skos:definition "Adversaries may attempt to hide process command-line arguments by overwriting process memory. Process command-line arguments are stored in the process environment block (PEB), a data structure used by Windows to store various information about/used by a process. The PEB includes the process command-line arguments that are referenced when executing the process. When a process is created, defensive tools/sensors that monitor process creations may retrieve the process arguments from the PEB.(Citation: Microsoft PEB 2021)(Citation: Xpn Argue Like Cobalt 2019)" ;
    skos:exactMatch d3f:T1564.010,
        mitre-attack:T1564.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564011 a owl:Class ;
    rdfs:label "T1564_011" ;
    d3f:attack-id "T1564.011" ;
    dcterms:title "Ignore Process Interrupts" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.011" ;
    skos:definition "Adversaries may evade defensive mechanisms by executing commands that hide from process interrupt signals. Many operating systems use signals to deliver messages to control process behavior. Command interpreters often include specific commands/flags that ignore errors and other hangups, such as when the user of the active session logs off.(Citation: Linux Signal Man)  These interrupt signals may also be used by defensive tools and/or analysts to pause or terminate specified running processes." ;
    skos:exactMatch d3f:T1564.011,
        mitre-attack:T1564.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564012 a owl:Class ;
    rdfs:label "T1564_012" ;
    d3f:attack-id "T1564.012" ;
    dcterms:title "File/Path Exclusions" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.012" ;
    skos:definition "Adversaries may attempt to hide their file-based artifacts by writing them to specific folders or file names excluded from antivirus (AV) scanning and other defensive capabilities. AV and other file-based scanners often include exclusions to optimize performance as well as ease installation and legitimate use of applications. These exclusions may be contextual (e.g., scans are only initiated in response to specific triggering events/alerts), but are also often hardcoded strings referencing specific folders and/or files assumed to be trusted and legitimate.(Citation: Microsoft File Folder Exclusions)" ;
    skos:exactMatch d3f:T1564.012,
        mitre-attack:T1564.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564013 a owl:Class ;
    rdfs:label "T1564_013" ;
    d3f:attack-id "T1564.013" ;
    dcterms:title "Bind Mounts" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.013" ;
    skos:definition "Adversaries may abuse bind mounts on file structures to hide their activity and artifacts from native utilities. A bind mount maps a directory or file from one location on the filesystem to another, similar to a shortcut on Windows. It’s commonly used to provide access to specific files or directories across different environments, such as inside containers or chroot environments, and requires sudo access." ;
    skos:exactMatch d3f:T1564.013,
        mitre-attack:T1564.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1564014 a owl:Class ;
    rdfs:label "T1564_014" ;
    d3f:attack-id "T1564.014" ;
    dcterms:title "Extended Attributes" ;
    rdfs:subClassOf d3f:T1564 ;
    skos:altLabel "T1564.014" ;
    skos:definition "Adversaries may abuse extended attributes (xattrs) on macOS and Linux to hide their malicious data in order to evade detection. Extended attributes are key-value pairs of file and directory metadata used by both macOS and Linux. They are not visible through standard tools like `Finder`,  `ls`, or `cat` and require utilities such as `xattr` (macOS) or `getfattr` (Linux) for inspection. Operating systems and applications use xattrs for tagging, integrity checks, and access control. On Linux, xattrs are organized into namespaces such as `user.` (user permissions), `trusted.` (root permissions), `security.`, and `system.`, each with specific permissions. On macOS, xattrs are flat strings without namespace prefixes, commonly prefixed with `com.apple.*` (e.g., `com.apple.quarantine`, `com.apple.metadata:_kMDItemUserTags`) and used by system features like Gatekeeper and Spotlight.(Citation: Establishing persistence using extended attributes on Linux)" ;
    skos:exactMatch d3f:T1564.014,
        mitre-attack:T1564.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1565001 a owl:Class ;
    rdfs:label "T1565_001" ;
    d3f:attack-id "T1565.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Stored Data Manipulation" ;
    rdfs:subClassOf d3f:T1565 ;
    skos:altLabel "T1565.001" ;
    skos:definition "Adversaries may insert, delete, or manipulate data at rest in order to influence external outcomes or hide activity, thus threatening the integrity of the data.(Citation: FireEye APT38 Oct 2018)(Citation: DOJ Lazarus Sony 2018) By manipulating stored data, adversaries may attempt to affect a business process, organizational understanding, and decision making." ;
    skos:exactMatch d3f:T1565.001,
        mitre-attack:T1565.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1565002 a owl:Class ;
    rdfs:label "T1565_002" ;
    d3f:attack-id "T1565.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Transmitted Data Manipulation" ;
    rdfs:subClassOf d3f:T1565 ;
    skos:altLabel "T1565.002" ;
    skos:definition "Adversaries may alter data en route to storage or other systems in order to manipulate external outcomes or hide activity, thus threatening the integrity of the data.(Citation: FireEye APT38 Oct 2018)(Citation: DOJ Lazarus Sony 2018) By manipulating transmitted data, adversaries may attempt to affect a business process, organizational understanding, and decision making." ;
    skos:exactMatch d3f:T1565.002,
        mitre-attack:T1565.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1565003 a owl:Class ;
    rdfs:label "T1565_003" ;
    d3f:attack-id "T1565.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Runtime Data Manipulation" ;
    rdfs:subClassOf d3f:T1565 ;
    skos:altLabel "T1565.003" ;
    skos:definition "Adversaries may modify systems in order to manipulate the data as it is accessed and displayed to an end user, thus threatening the integrity of the data.(Citation: FireEye APT38 Oct 2018)(Citation: DOJ Lazarus Sony 2018) By manipulating runtime data, adversaries may attempt to affect a business process, organizational understanding, and decision making." ;
    skos:exactMatch d3f:T1565.003,
        mitre-attack:T1565.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1566001 a owl:Class ;
    rdfs:label "T1566_001" ;
    d3f:attack-id "T1566.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Spearphishing Attachment" ;
    rdfs:subClassOf d3f:T1566 ;
    skos:altLabel "T1566.001" ;
    skos:definition "Adversaries may send spearphishing emails with a malicious attachment in an attempt to gain access to victim systems. Spearphishing attachment is a specific variant of spearphishing. Spearphishing attachment is different from other forms of spearphishing in that it employs the use of malware attached to an email. All forms of spearphishing are electronically delivered social engineering targeted at a specific individual, company, or industry. In this scenario, adversaries attach a file to the spearphishing email and usually rely upon [User Execution](https://attack.mitre.org/techniques/T1204) to gain execution.(Citation: Unit 42 DarkHydrus July 2018) Spearphishing may also involve social engineering techniques, such as posing as a trusted source." ;
    skos:exactMatch d3f:T1566.001,
        mitre-attack:T1566.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1566002 a owl:Class ;
    rdfs:label "T1566_002" ;
    d3f:attack-id "T1566.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Spearphishing Link" ;
    rdfs:subClassOf d3f:T1566 ;
    skos:altLabel "T1566.002" ;
    skos:definition "Adversaries may send spearphishing emails with a malicious link in an attempt to gain access to victim systems. Spearphishing with a link is a specific variant of spearphishing. It is different from other forms of spearphishing in that it employs the use of links to download malware contained in email, instead of attaching malicious files to the email itself, to avoid defenses that may inspect email attachments. Spearphishing may also involve social engineering techniques, such as posing as a trusted source." ;
    skos:exactMatch d3f:T1566.002,
        mitre-attack:T1566.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1566003 a owl:Class ;
    rdfs:label "T1566_003" ;
    d3f:attack-id "T1566.003" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Spearphishing via Service" ;
    rdfs:subClassOf d3f:T1566 ;
    skos:altLabel "T1566.003" ;
    skos:definition "Adversaries may send spearphishing messages via third-party services in an attempt to gain access to victim systems. Spearphishing via service is a specific variant of spearphishing. It is different from other forms of spearphishing in that it employs the use of third party services rather than directly via enterprise email channels." ;
    skos:exactMatch d3f:T1566.003,
        mitre-attack:T1566.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1566004 a owl:Class ;
    rdfs:label "T1566_004" ;
    d3f:attack-id "T1566.004" ;
    dcterms:title "Spearphishing Voice" ;
    rdfs:subClassOf d3f:T1566 ;
    skos:altLabel "T1566.004" ;
    skos:definition "Adversaries may use voice communications to ultimately gain access to victim systems. Spearphishing voice is a specific variant of spearphishing. It is different from other forms of spearphishing in that is employs the use of manipulating a user into providing access to systems through a phone call or other forms of voice communications. Spearphishing frequently involves social engineering techniques, such as posing as a trusted source (ex: [Impersonation](https://attack.mitre.org/techniques/T1656)) and/or creating a sense of urgency or alarm for the recipient." ;
    skos:exactMatch d3f:T1566.004,
        mitre-attack:T1566.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1567001 a owl:Class ;
    rdfs:label "T1567_001" ;
    d3f:attack-id "T1567.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration to Code Repository" ;
    rdfs:subClassOf d3f:T1567 ;
    skos:altLabel "T1567.001" ;
    skos:definition "Adversaries may exfiltrate data to a code repository rather than over their primary command and control channel. Code repositories are often accessible via an API (ex: https://api.github.com). Access to these APIs are often over HTTPS, which gives the adversary an additional level of protection." ;
    skos:exactMatch d3f:T1567.001,
        mitre-attack:T1567.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1567002 a owl:Class ;
    rdfs:label "T1567_002" ;
    d3f:attack-id "T1567.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration to Cloud Storage" ;
    rdfs:subClassOf d3f:T1567 ;
    skos:altLabel "T1567.002" ;
    skos:definition "Adversaries may exfiltrate data to a cloud storage service rather than over their primary command and control channel. Cloud storage services allow for the storage, edit, and retrieval of data from a remote cloud storage server over the Internet." ;
    skos:exactMatch d3f:T1567.002,
        mitre-attack:T1567.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1567003 a owl:Class ;
    rdfs:label "T1567_003" ;
    d3f:attack-id "T1567.003" ;
    dcterms:title "Exfiltration to Text Storage Sites" ;
    rdfs:subClassOf d3f:T1567 ;
    skos:altLabel "T1567.003" ;
    skos:definition "Adversaries may exfiltrate data to text storage sites instead of their primary command and control channel. Text storage sites, such as <code>pastebin[.]com</code>, are commonly used by developers to share code and other information." ;
    skos:exactMatch d3f:T1567.003,
        mitre-attack:T1567.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1567004 a owl:Class ;
    rdfs:label "T1567_004" ;
    d3f:attack-id "T1567.004" ;
    dcterms:title "Exfiltration Over Webhook" ;
    rdfs:subClassOf d3f:T1567 ;
    skos:altLabel "T1567.004" ;
    skos:definition "Adversaries may exfiltrate data to a webhook endpoint rather than over their primary command and control channel. Webhooks are simple mechanisms for allowing a server to push data over HTTP/S to a client without the need for the client to continuously poll the server.(Citation: RedHat Webhooks) Many public and commercial services, such as Discord, Slack, and `webhook.site`, support the creation of webhook endpoints that can be used by other services, such as Github, Jira, or Trello.(Citation: Discord Intro to Webhooks) When changes happen in the linked services (such as pushing a repository update or modifying a ticket), these services will automatically post the data to the webhook endpoint for use by the consuming application." ;
    skos:exactMatch d3f:T1567.004,
        mitre-attack:T1567.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1568001 a owl:Class ;
    rdfs:label "T1568_001" ;
    d3f:attack-id "T1568.001" ;
    dcterms:title "Fast Flux DNS" ;
    rdfs:subClassOf d3f:T1568 ;
    skos:altLabel "T1568.001" ;
    skos:definition "Adversaries may use Fast Flux DNS to hide a command and control channel behind an array of rapidly changing IP addresses linked to a single domain resolution. This technique uses a fully qualified domain name, with multiple IP addresses assigned to it which are swapped with high frequency, using a combination of round robin IP addressing and short Time-To-Live (TTL) for a DNS resource record.(Citation: MehtaFastFluxPt1)(Citation: MehtaFastFluxPt2)(Citation: Fast Flux - Welivesecurity)" ;
    skos:exactMatch d3f:T1568.001,
        mitre-attack:T1568.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1568002 a owl:Class ;
    rdfs:label "T1568_002" ;
    d3f:attack-id "T1568.002" ;
    dcterms:title "Domain Generation Algorithms" ;
    rdfs:subClassOf d3f:T1568 ;
    skos:altLabel "T1568.002" ;
    skos:definition "Adversaries may make use of Domain Generation Algorithms (DGAs) to dynamically identify a destination domain for command and control traffic rather than relying on a list of static IP addresses or domains. This has the advantage of making it much harder for defenders to block, track, or take over the command and control channel, as there potentially could be thousands of domains that malware can check for instructions.(Citation: Cybereason Dissecting DGAs)(Citation: Cisco Umbrella DGA)(Citation: Unit 42 DGA Feb 2019)" ;
    skos:exactMatch d3f:T1568.002,
        mitre-attack:T1568.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1568003 a owl:Class ;
    rdfs:label "T1568_003" ;
    d3f:attack-id "T1568.003" ;
    dcterms:title "DNS Calculation" ;
    rdfs:subClassOf d3f:T1568 ;
    skos:altLabel "T1568.003" ;
    skos:definition "Adversaries may perform calculations on addresses returned in DNS results to determine which port and IP address to use for command and control, rather than relying on a predetermined port number or the actual returned IP address. A IP and/or port number calculation can be used to bypass egress filtering on a C2 channel.(Citation: Meyers Numbered Panda)" ;
    skos:exactMatch d3f:T1568.003,
        mitre-attack:T1568.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1569001 a owl:Class ;
    rdfs:label "T1569_001" ;
    d3f:attack-id "T1569.001" ;
    dcterms:title "Launchctl" ;
    rdfs:subClassOf d3f:T1569 ;
    skos:altLabel "T1569.001" ;
    skos:definition "Adversaries may abuse launchctl to execute commands or programs. Launchctl interfaces with launchd, the service management framework for macOS. Launchctl supports taking subcommands on the command-line, interactively, or even redirected from standard input.(Citation: Launchctl Man)" ;
    skos:exactMatch d3f:T1569.001,
        mitre-attack:T1569.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1569002 a owl:Class ;
    rdfs:label "T1569_002" ;
    d3f:attack-id "T1569.002" ;
    dcterms:title "Service Execution" ;
    rdfs:subClassOf d3f:T1569 ;
    skos:altLabel "T1569.002" ;
    skos:definition "Adversaries may abuse the Windows service control manager to execute malicious commands or payloads. The Windows service control manager (<code>services.exe</code>) is an interface to manage and manipulate services.(Citation: Microsoft Service Control Manager) The service control manager is accessible to users via GUI components as well as system utilities such as <code>sc.exe</code> and [Net](https://attack.mitre.org/software/S0039)." ;
    skos:exactMatch d3f:T1569.002,
        mitre-attack:T1569.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1569003 a owl:Class ;
    rdfs:label "T1569_003" ;
    d3f:attack-id "T1569.003" ;
    dcterms:title "Systemctl" ;
    rdfs:subClassOf d3f:T1569 ;
    skos:altLabel "T1569.003" ;
    skos:definition "Adversaries may abuse systemctl to execute commands or programs. Systemctl is the primary interface for systemd, the Linux init system and service manager. Typically invoked from a shell, Systemctl can also be integrated into scripts or applications." ;
    skos:exactMatch d3f:T1569.003,
        mitre-attack:T1569.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1573001 a owl:Class ;
    rdfs:label "T1573_001" ;
    d3f:attack-id "T1573.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Symmetric Cryptography" ;
    rdfs:subClassOf d3f:T1573 ;
    skos:altLabel "T1573.001" ;
    skos:definition "Adversaries may employ a known symmetric encryption algorithm to conceal command and control traffic rather than relying on any inherent protections provided by a communication protocol. Symmetric encryption algorithms use the same key for plaintext encryption and ciphertext decryption. Common symmetric encryption algorithms include AES, DES, 3DES, Blowfish, and RC4." ;
    skos:exactMatch d3f:T1573.001,
        mitre-attack:T1573.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1573002 a owl:Class ;
    rdfs:label "T1573_002" ;
    d3f:attack-id "T1573.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Asymmetric Cryptography" ;
    rdfs:subClassOf d3f:T1573 ;
    skos:altLabel "T1573.002" ;
    skos:definition "Adversaries may employ a known asymmetric encryption algorithm to conceal command and control traffic rather than relying on any inherent protections provided by a communication protocol. Asymmetric cryptography, also known as public key cryptography, uses a keypair per party: one public that can be freely distributed, and one private. Due to how the keys are generated, the sender encrypts data with the receiver’s public key and the receiver decrypts the data with their private key. This ensures that only the intended recipient can read the encrypted data. Common public key encryption algorithms include RSA and ElGamal." ;
    skos:exactMatch d3f:T1573.002,
        mitre-attack:T1573.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574001 a owl:Class ;
    rdfs:label "T1574_001" ;
    d3f:attack-id "T1574.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DLL" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.001" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the search order used to load DLLs. Windows systems use a common method to look for required DLLs to load into a program. (Citation: Microsoft Dynamic Link Library Search Order)(Citation: FireEye Hijacking July 2010) Hijacking DLL loads may be for the purpose of establishing persistence as well as elevating privileges and/or evading restrictions on file execution." ;
    skos:exactMatch d3f:T1574.001,
        mitre-attack:T1574.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574002 a owl:Class ;
    rdfs:label "T1574_002" ;
    d3f:attack-id "T1574.002" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DLL Side-Loading" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.002" ;
    skos:definition "Adversaries may execute their own malicious payloads by side-loading DLLs. Similar to [DLL Search Order Hijacking](https://attack.mitre.org/techniques/T1574/001), side-loading involves hijacking which DLL a program loads. But rather than just planting the DLL within the search order of a program then waiting for the victim application to be invoked, adversaries may directly side-load their payloads by planting then invoking a legitimate application that executes their payload(s)." ;
    skos:exactMatch d3f:T1574.002,
        mitre-attack:T1574.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1574.001" .

d3f:T1574004 a owl:Class ;
    rdfs:label "T1574_004" ;
    d3f:attack-id "T1574.004" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Dylib Hijacking" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.004" ;
    skos:definition "Adversaries may execute their own payloads by placing a malicious dynamic library (dylib) with an expected name in a path a victim application searches at runtime. The dynamic loader will try to find the dylibs based on the sequential order of the search paths. Paths to dylibs may be prefixed with <code>@rpath</code>, which allows developers to use relative paths to specify an array of search paths used at runtime based on the location of the executable.  Additionally, if weak linking is used, such as the <code>LC_LOAD_WEAK_DYLIB</code> function, an application will still execute even if an expected dylib is not present. Weak linking enables developers to run an application on multiple macOS versions as new APIs are added." ;
    skos:exactMatch d3f:T1574.004,
        mitre-attack:T1574.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574005 a owl:Class ;
    rdfs:label "T1574_005" ;
    d3f:attack-id "T1574.005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Executable Installer File Permissions Weakness" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.005" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the binaries used by an installer. These processes may automatically execute specific binaries as part of their functionality or to perform other actions. If the permissions on the file system directory containing a target binary, or permissions on the binary itself, are improperly set, then the target binary may be overwritten with another binary using user-level permissions and executed by the original process. If the original process and thread are running under a higher permissions level, then the replaced binary will also execute under higher-level permissions, which could include SYSTEM." ;
    skos:exactMatch d3f:T1574.005,
        mitre-attack:T1574.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574006 a owl:Class ;
    rdfs:label "T1574_006" ;
    d3f:attack-id "T1574.006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Dynamic Linker Hijacking" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.006" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking environment variables the dynamic linker uses to load shared libraries. During the execution preparation phase of a program, the dynamic linker loads specified absolute paths of shared libraries from environment variables and files, such as <code>LD_PRELOAD</code> on Linux or <code>DYLD_INSERT_LIBRARIES</code> on macOS. Libraries specified in environment variables are loaded first, taking precedence over system libraries with the same function name.(Citation: Man LD.SO)(Citation: TLDP Shared Libraries)(Citation: Apple Doco Archive Dynamic Libraries) These variables are often used by developers to debug binaries without needing to recompile, deconflict mapped symbols, and implement custom functions without changing the original library.(Citation: Baeldung LD_PRELOAD)" ;
    skos:exactMatch d3f:T1574.006,
        mitre-attack:T1574.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574007 a owl:Class ;
    rdfs:label "T1574_007" ;
    d3f:attack-id "T1574.007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Path Interception by PATH Environment Variable" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.007" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking environment variables used to load libraries. The PATH environment variable contains a list of directories (User and System) that the OS searches sequentially through in search of the binary that was called from a script or the command line." ;
    skos:exactMatch d3f:T1574.007,
        mitre-attack:T1574.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574008 a owl:Class ;
    rdfs:label "T1574_008" ;
    d3f:attack-id "T1574.008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Path Interception by Search Order Hijacking" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.008" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the search order used to load other programs. Because some programs do not call other programs using the full path, adversaries may place their own file in the directory where the calling program is located, causing the operating system to launch their malicious software at the request of the calling program." ;
    skos:exactMatch d3f:T1574.008,
        mitre-attack:T1574.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574009 a owl:Class ;
    rdfs:label "T1574_009" ;
    d3f:attack-id "T1574.009" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Path Interception by Unquoted Path" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.009" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking vulnerable file path references. Adversaries can take advantage of paths that lack surrounding quotations by placing an executable in a higher level directory within the path, so that Windows will choose the adversary's executable to launch." ;
    skos:exactMatch d3f:T1574.009,
        mitre-attack:T1574.009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574010 a owl:Class ;
    rdfs:label "T1574_010" ;
    d3f:attack-id "T1574.010" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Services File Permissions Weakness" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "Service Registry Permissions Weakness" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the binaries used by services. Adversaries may use flaws in the permissions of Windows services to replace the binary that is executed upon service start. These service processes may automatically execute specific binaries as part of their functionality or to perform other actions. If the permissions on the file system directory containing a target binary, or permissions on the binary itself are improperly set, then the target binary may be overwritten with another binary using user-level permissions and executed by the original process. If the original process and thread are running under a higher permissions level, then the replaced binary will also execute under higher-level permissions, which could include SYSTEM." ;
    skos:exactMatch d3f:T1574.010,
        mitre-attack:T1574.010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574011 a owl:Class ;
    rdfs:label "T1574_011" ;
    d3f:attack-id "T1574.011" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Services Registry Permissions Weakness" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.011" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the Registry entries used by services. Adversaries may use flaws in the permissions for Registry keys related to services to redirect from the originally specified executable to one that they control, in order to launch their own code when a service starts. Windows stores local service configuration information in the Registry under <code>HKLM\\SYSTEM\\CurrentControlSet\\Services</code>. The information stored under a service's Registry keys can be manipulated to modify a service's execution parameters through tools such as the service controller, sc.exe,  [PowerShell](https://attack.mitre.org/techniques/T1059/001), or [Reg](https://attack.mitre.org/software/S0075). Access to Registry keys is controlled through access control lists and user permissions. (Citation: Registry Key Security)(Citation: malware_hides_service)" ;
    skos:exactMatch d3f:T1574.011,
        mitre-attack:T1574.011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574012 a owl:Class ;
    rdfs:label "T1574_012" ;
    d3f:attack-id "T1574.012" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "COR_PROFILER" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.012" ;
    skos:definition "Adversaries may leverage the COR_PROFILER environment variable to hijack the execution flow of programs that load the .NET CLR. The COR_PROFILER is a .NET Framework feature which allows developers to specify an unmanaged (or external of .NET) profiling DLL to be loaded into each .NET process that loads the Common Language Runtime (CLR). These profilers are designed to monitor, troubleshoot, and debug managed code executed by the .NET CLR.(Citation: Microsoft Profiling Mar 2017)(Citation: Microsoft COR_PROFILER Feb 2013)" ;
    skos:exactMatch d3f:T1574.012,
        mitre-attack:T1574.012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574013 a owl:Class ;
    rdfs:label "T1574_013" ;
    d3f:attack-id "T1574.013" ;
    dcterms:title "KernelCallbackTable" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.013" ;
    skos:definition "Adversaries may abuse the <code>KernelCallbackTable</code> of a process to hijack its execution flow in order to run their own payloads.(Citation: Lazarus APT January 2022)(Citation: FinFisher exposed ) The <code>KernelCallbackTable</code> can be found in the Process Environment Block (PEB) and is initialized to an array of graphic functions available to a GUI process once <code>user32.dll</code> is loaded.(Citation: Windows Process Injection KernelCallbackTable)" ;
    skos:exactMatch d3f:T1574.013,
        mitre-attack:T1574.013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1574014 a owl:Class ;
    rdfs:label "T1574_014" ;
    d3f:attack-id "T1574.014" ;
    dcterms:title "AppDomainManager" ;
    rdfs:subClassOf d3f:T1574 ;
    skos:altLabel "T1574.014" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking how the .NET `AppDomainManager` loads assemblies. The .NET framework uses the `AppDomainManager` class to create and manage one or more isolated runtime environments (called application domains) inside a process to host the execution of .NET applications. Assemblies (`.exe` or `.dll` binaries compiled to run as .NET code) may be loaded into an application domain as executable code.(Citation: Microsoft App Domains)" ;
    skos:exactMatch d3f:T1574.014,
        mitre-attack:T1574.014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1578001 a owl:Class ;
    rdfs:label "T1578_001" ;
    d3f:attack-id "T1578.001" ;
    dcterms:title "Create Snapshot" ;
    rdfs:subClassOf d3f:T1578 ;
    skos:altLabel "T1578.001" ;
    skos:definition "An adversary may create a snapshot or data backup within a cloud account to evade defenses. A snapshot is a point-in-time copy of an existing cloud compute component such as a virtual machine (VM), virtual hard drive, or volume. An adversary may leverage permissions to create a snapshot in order to bypass restrictions that prevent access to existing compute service infrastructure, unlike in [Revert Cloud Instance](https://attack.mitre.org/techniques/T1578/004) where an adversary may revert to a snapshot to evade detection and remove evidence of their presence." ;
    skos:exactMatch d3f:T1578.001,
        mitre-attack:T1578.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1578002 a owl:Class ;
    rdfs:label "T1578_002" ;
    d3f:attack-id "T1578.002" ;
    dcterms:title "Create Cloud Instance" ;
    rdfs:subClassOf d3f:T1578 ;
    skos:altLabel "T1578.002" ;
    skos:definition "An adversary may create a new instance or virtual machine (VM) within the compute service of a cloud account to evade defenses. Creating a new instance may allow an adversary to bypass firewall rules and permissions that exist on instances currently residing within an account. An adversary may [Create Snapshot](https://attack.mitre.org/techniques/T1578/001) of one or more volumes in an account, create a new instance, mount the snapshots, and then apply a less restrictive security policy to collect [Data from Local System](https://attack.mitre.org/techniques/T1005) or for [Remote Data Staging](https://attack.mitre.org/techniques/T1074/002).(Citation: Mandiant M-Trends 2020)" ;
    skos:exactMatch d3f:T1578.002,
        mitre-attack:T1578.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1578003 a owl:Class ;
    rdfs:label "T1578_003" ;
    d3f:attack-id "T1578.003" ;
    dcterms:title "Delete Cloud Instance" ;
    rdfs:subClassOf d3f:T1578 ;
    skos:altLabel "T1578.003" ;
    skos:definition "An adversary may delete a cloud instance after they have performed malicious activities in an attempt to evade detection and remove evidence of their presence.  Deleting an instance or virtual machine can remove valuable forensic artifacts and other evidence of suspicious behavior if the instance is not recoverable." ;
    skos:exactMatch d3f:T1578.003,
        mitre-attack:T1578.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1578004 a owl:Class ;
    rdfs:label "T1578_004" ;
    d3f:attack-id "T1578.004" ;
    dcterms:title "Revert Cloud Instance" ;
    rdfs:subClassOf d3f:T1578 ;
    skos:altLabel "T1578.004" ;
    skos:definition "An adversary may revert changes made to a cloud instance after they have performed malicious activities in attempt to evade detection and remove evidence of their presence. In highly virtualized environments, such as cloud-based infrastructure, this may be accomplished by restoring virtual machine (VM) or data storage snapshots through the cloud management dashboard or cloud APIs." ;
    skos:exactMatch d3f:T1578.004,
        mitre-attack:T1578.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1578005 a owl:Class ;
    rdfs:label "T1578_005" ;
    d3f:attack-id "T1578.005" ;
    dcterms:title "Modify Cloud Compute Configurations" ;
    rdfs:subClassOf d3f:T1578 ;
    skos:altLabel "T1578.005" ;
    skos:definition "Adversaries may modify settings that directly affect the size, locations, and resources available to cloud compute infrastructure in order to evade defenses. These settings may include service quotas, subscription associations, tenant-wide policies, or other configurations that impact available compute. Such modifications may allow adversaries to abuse the victim’s compute resources to achieve their goals, potentially without affecting the execution of running instances and/or revealing their activities to the victim." ;
    skos:exactMatch d3f:T1578.005,
        mitre-attack:T1578.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583001 a owl:Class ;
    rdfs:label "T1583_001" ;
    d3f:attack-id "T1583.001" ;
    dcterms:title "Domains" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.001" ;
    skos:definition "Adversaries may acquire domains that can be used during targeting. Domain names are the human readable names used to represent one or more IP addresses. They can be purchased or, in some cases, acquired for free." ;
    skos:exactMatch d3f:T1583.001,
        mitre-attack:T1583.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583002 a owl:Class ;
    rdfs:label "T1583_002" ;
    d3f:attack-id "T1583.002" ;
    dcterms:title "DNS Server" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.002" ;
    skos:definition "Adversaries may set up their own Domain Name System (DNS) servers that can be used during targeting. During post-compromise activity, adversaries may utilize DNS traffic for various tasks, including for Command and Control (ex: [Application Layer Protocol](https://attack.mitre.org/techniques/T1071)). Instead of hijacking existing DNS servers, adversaries may opt to configure and run their own DNS servers in support of operations." ;
    skos:exactMatch d3f:T1583.002,
        mitre-attack:T1583.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583003 a owl:Class ;
    rdfs:label "T1583_003" ;
    d3f:attack-id "T1583.003" ;
    dcterms:title "Virtual Private Server" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.003" ;
    skos:definition "Adversaries may rent Virtual Private Servers (VPSs) that can be used during targeting. There exist a variety of cloud service providers that will sell virtual machines/containers as a service. By utilizing a VPS, adversaries can make it difficult to physically tie back operations to them. The use of cloud infrastructure can also make it easier for adversaries to rapidly provision, modify, and shut down their infrastructure." ;
    skos:exactMatch d3f:T1583.003,
        mitre-attack:T1583.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583004 a owl:Class ;
    rdfs:label "T1583_004" ;
    d3f:attack-id "T1583.004" ;
    dcterms:title "Server" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.004" ;
    skos:definition "Adversaries may buy, lease, rent, or obtain physical servers that can be used during targeting. Use of servers allows an adversary to stage, launch, and execute an operation. During post-compromise activity, adversaries may utilize servers for various tasks, such as watering hole operations in [Drive-by Compromise](https://attack.mitre.org/techniques/T1189), enabling [Phishing](https://attack.mitre.org/techniques/T1566) operations, or facilitating [Command and Control](https://attack.mitre.org/tactics/TA0011). Instead of compromising a third-party [Server](https://attack.mitre.org/techniques/T1584/004) or renting a [Virtual Private Server](https://attack.mitre.org/techniques/T1583/003), adversaries may opt to configure and run their own servers in support of operations. Free trial periods of cloud servers may also be abused.(Citation: Free Trial PurpleUrchin)(Citation: Freejacked)" ;
    skos:exactMatch d3f:T1583.004,
        mitre-attack:T1583.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583005 a owl:Class ;
    rdfs:label "T1583_005" ;
    d3f:attack-id "T1583.005" ;
    dcterms:title "Botnet" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.005" ;
    skos:definition "Adversaries may buy, lease, or rent a network of compromised systems that can be used during targeting. A botnet is a network of compromised systems that can be instructed to perform coordinated tasks.(Citation: Norton Botnet) Adversaries may purchase a subscription to use an existing botnet from a booter/stresser service. With a botnet at their disposal, adversaries may perform follow-on activity such as large-scale [Phishing](https://attack.mitre.org/techniques/T1566) or Distributed Denial of Service (DDoS).(Citation: Imperva DDoS for Hire)(Citation: Krebs-Anna)(Citation: Krebs-Bazaar)(Citation: Krebs-Booter)" ;
    skos:exactMatch d3f:T1583.005,
        mitre-attack:T1583.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583006 a owl:Class ;
    rdfs:label "T1583_006" ;
    d3f:attack-id "T1583.006" ;
    dcterms:title "Web Services" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.006" ;
    skos:definition "Adversaries may register for web services that can be used during targeting. A variety of popular websites exist for adversaries to register for a web-based service that can be abused during later stages of the adversary lifecycle, such as during Command and Control ([Web Service](https://attack.mitre.org/techniques/T1102)), [Exfiltration Over Web Service](https://attack.mitre.org/techniques/T1567), or [Phishing](https://attack.mitre.org/techniques/T1566). Using common services, such as those offered by Google or Twitter, makes it easier for adversaries to hide in expected noise.(Citation: FireEye APT29) By utilizing a web service, adversaries can make it difficult to physically tie back operations to them." ;
    skos:exactMatch d3f:T1583.006,
        mitre-attack:T1583.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583007 a owl:Class ;
    rdfs:label "T1583_007" ;
    d3f:attack-id "T1583.007" ;
    dcterms:title "Serverless" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.007" ;
    skos:definition "Adversaries may purchase and configure serverless cloud infrastructure, such as Cloudflare Workers or AWS Lambda functions, that can be used during targeting. By utilizing serverless infrastructure, adversaries can make it more difficult to attribute infrastructure used during operations back to them." ;
    skos:exactMatch d3f:T1583.007,
        mitre-attack:T1583.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583008 a owl:Class ;
    rdfs:label "T1583_008" ;
    d3f:attack-id "T1583.008" ;
    dcterms:title "Malvertising" ;
    rdfs:subClassOf d3f:T1583 ;
    skos:altLabel "T1583.008" ;
    skos:definition "Adversaries may purchase online advertisements that can be abused to distribute malware to victims. Ads can be purchased to plant as well as favorably position artifacts in specific locations  online, such as prominently placed within search engine results. These ads may make it more difficult for users to distinguish between actual search results and advertisements.(Citation: spamhaus-malvertising) Purchased ads may also target specific audiences using the advertising network’s capabilities, potentially further taking advantage of the trust inherently given to search engines and popular websites." ;
    skos:exactMatch d3f:T1583.008,
        mitre-attack:T1583.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584001 a owl:Class ;
    rdfs:label "T1584_001" ;
    d3f:attack-id "T1584.001" ;
    dcterms:title "Domains" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.001" ;
    skos:definition "Adversaries may hijack domains and/or subdomains that can be used during targeting. Domain registration hijacking is the act of changing the registration of a domain name without the permission of the original registrant.(Citation: ICANNDomainNameHijacking) Adversaries may gain access to an email account for the person listed as the owner of the domain. The adversary can then claim that they forgot their password in order to make changes to the domain registration. Other possibilities include social engineering a domain registration help desk to gain access to an account or taking advantage of renewal process gaps.(Citation: Krebs DNS Hijack 2019)" ;
    skos:exactMatch d3f:T1584.001,
        mitre-attack:T1584.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584002 a owl:Class ;
    rdfs:label "T1584_002" ;
    d3f:attack-id "T1584.002" ;
    dcterms:title "DNS Server" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.002" ;
    skos:definition "Adversaries may compromise third-party DNS servers that can be used during targeting. During post-compromise activity, adversaries may utilize DNS traffic for various tasks, including for Command and Control (ex: [Application Layer Protocol](https://attack.mitre.org/techniques/T1071)). Instead of setting up their own DNS servers, adversaries may compromise third-party DNS servers in support of operations." ;
    skos:exactMatch d3f:T1584.002,
        mitre-attack:T1584.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584003 a owl:Class ;
    rdfs:label "T1584_003" ;
    d3f:attack-id "T1584.003" ;
    dcterms:title "Virtual Private Server" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.003" ;
    skos:definition "Adversaries may compromise third-party Virtual Private Servers (VPSs) that can be used during targeting. There exist a variety of cloud service providers that will sell virtual machines/containers as a service. Adversaries may compromise VPSs purchased by third-party entities. By compromising a VPS to use as infrastructure, adversaries can make it difficult to physically tie back operations to themselves.(Citation: NSA NCSC Turla OilRig)" ;
    skos:exactMatch d3f:T1584.003,
        mitre-attack:T1584.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584004 a owl:Class ;
    rdfs:label "T1584_004" ;
    d3f:attack-id "T1584.004" ;
    dcterms:title "Server" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.004" ;
    skos:definition "Adversaries may compromise third-party servers that can be used during targeting. Use of servers allows an adversary to stage, launch, and execute an operation. During post-compromise activity, adversaries may utilize servers for various tasks, including for Command and Control.(Citation: TrendMicro EarthLusca 2022) Instead of purchasing a [Server](https://attack.mitre.org/techniques/T1583/004) or [Virtual Private Server](https://attack.mitre.org/techniques/T1583/003), adversaries may compromise third-party servers in support of operations." ;
    skos:exactMatch d3f:T1584.004,
        mitre-attack:T1584.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584005 a owl:Class ;
    rdfs:label "T1584_005" ;
    d3f:attack-id "T1584.005" ;
    dcterms:title "Botnet" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.005" ;
    skos:definition "Adversaries may compromise numerous third-party systems to form a botnet that can be used during targeting. A botnet is a network of compromised systems that can be instructed to perform coordinated tasks.(Citation: Norton Botnet) Instead of purchasing/renting a botnet from a booter/stresser service, adversaries may build their own botnet by compromising numerous third-party systems.(Citation: Imperva DDoS for Hire) Adversaries may also conduct a takeover of an existing botnet, such as redirecting bots to adversary-controlled C2 servers.(Citation: Dell Dridex Oct 2015) With a botnet at their disposal, adversaries may perform follow-on activity such as large-scale [Phishing](https://attack.mitre.org/techniques/T1566) or Distributed Denial of Service (DDoS)." ;
    skos:exactMatch d3f:T1584.005,
        mitre-attack:T1584.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584006 a owl:Class ;
    rdfs:label "T1584_006" ;
    d3f:attack-id "T1584.006" ;
    dcterms:title "Web Services" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.006" ;
    skos:definition "Adversaries may compromise access to third-party web services that can be used during targeting. A variety of popular websites exist for legitimate users to register for web-based services, such as GitHub, Twitter, Dropbox, Google, SendGrid, etc. Adversaries may try to take ownership of a legitimate user's access to a web service and use that web service as infrastructure in support of cyber operations. Such web services can be abused during later stages of the adversary lifecycle, such as during Command and Control ([Web Service](https://attack.mitre.org/techniques/T1102)), [Exfiltration Over Web Service](https://attack.mitre.org/techniques/T1567), or [Phishing](https://attack.mitre.org/techniques/T1566).(Citation: Recorded Future Turla Infra 2020) Using common services, such as those offered by Google or Twitter, makes it easier for adversaries to hide in expected noise. By utilizing a web service, particularly when access is stolen from legitimate users, adversaries can make it difficult to physically tie back operations to them. Additionally, leveraging compromised web-based email services may allow adversaries to leverage the trust associated with legitimate domains." ;
    skos:exactMatch d3f:T1584.006,
        mitre-attack:T1584.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584007 a owl:Class ;
    rdfs:label "T1584_007" ;
    d3f:attack-id "T1584.007" ;
    dcterms:title "Serverless" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.007" ;
    skos:definition "Adversaries may compromise serverless cloud infrastructure, such as Cloudflare Workers or AWS Lambda functions, that can be used during targeting. By utilizing serverless infrastructure, adversaries can make it more difficult to attribute infrastructure used during operations back to them." ;
    skos:exactMatch d3f:T1584.007,
        mitre-attack:T1584.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584008 a owl:Class ;
    rdfs:label "T1584_008" ;
    d3f:attack-id "T1584.008" ;
    dcterms:title "Network Devices" ;
    rdfs:subClassOf d3f:T1584 ;
    skos:altLabel "T1584.008" ;
    skos:definition "Adversaries may compromise third-party network devices that can be used during targeting. Network devices, such as small office/home office (SOHO) routers, may be compromised where the adversary's ultimate goal is not [Initial Access](https://attack.mitre.org/tactics/TA0001) to that environment -- instead leveraging these devices to support additional targeting." ;
    skos:exactMatch d3f:T1584.008,
        mitre-attack:T1584.008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1585001 a owl:Class ;
    rdfs:label "T1585_001" ;
    d3f:attack-id "T1585.001" ;
    dcterms:title "Social Media Accounts" ;
    rdfs:subClassOf d3f:T1585 ;
    skos:altLabel "T1585.001" ;
    skos:definition "Adversaries may create and cultivate social media accounts that can be used during targeting. Adversaries can create social media accounts that can be used to build a persona to further operations. Persona development consists of the development of public information, presence, history and appropriate affiliations.(Citation: NEWSCASTER2014)(Citation: BlackHatRobinSage)" ;
    skos:exactMatch d3f:T1585.001,
        mitre-attack:T1585.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1585002 a owl:Class ;
    rdfs:label "T1585_002" ;
    d3f:attack-id "T1585.002" ;
    dcterms:title "Email Accounts" ;
    rdfs:subClassOf d3f:T1585 ;
    skos:altLabel "T1585.002" ;
    skos:definition "Adversaries may create email accounts that can be used during targeting. Adversaries can use accounts created with email providers to further their operations, such as leveraging them to conduct [Phishing for Information](https://attack.mitre.org/techniques/T1598) or [Phishing](https://attack.mitre.org/techniques/T1566).(Citation: Mandiant APT1) Establishing email accounts may also allow adversaries to abuse free services – such as trial periods – to [Acquire Infrastructure](https://attack.mitre.org/techniques/T1583) for follow-on purposes.(Citation: Free Trial PurpleUrchin)" ;
    skos:exactMatch d3f:T1585.002,
        mitre-attack:T1585.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1585003 a owl:Class ;
    rdfs:label "T1585_003" ;
    d3f:attack-id "T1585.003" ;
    dcterms:title "Cloud Accounts" ;
    rdfs:subClassOf d3f:T1585 ;
    skos:altLabel "T1585.003" ;
    skos:definition "Adversaries may create accounts with cloud providers that can be used during targeting. Adversaries can use cloud accounts to further their operations, including leveraging cloud storage services such as Dropbox, MEGA, Microsoft OneDrive, or AWS S3 buckets for [Exfiltration to Cloud Storage](https://attack.mitre.org/techniques/T1567/002) or to [Upload Tool](https://attack.mitre.org/techniques/T1608/002)s. Cloud accounts can also be used in the acquisition of infrastructure, such as [Virtual Private Server](https://attack.mitre.org/techniques/T1583/003)s or [Serverless](https://attack.mitre.org/techniques/T1583/007) infrastructure. Establishing cloud accounts may allow adversaries to develop sophisticated capabilities without managing their own servers.(Citation: Awake Security C2 Cloud)" ;
    skos:exactMatch d3f:T1585.003,
        mitre-attack:T1585.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1586001 a owl:Class ;
    rdfs:label "T1586_001" ;
    d3f:attack-id "T1586.001" ;
    dcterms:title "Social Media Accounts" ;
    rdfs:subClassOf d3f:T1586 ;
    skos:altLabel "T1586.001" ;
    skos:definition "Adversaries may compromise social media accounts that can be used during targeting. For operations incorporating social engineering, the utilization of an online persona may be important. Rather than creating and cultivating social media profiles (i.e. [Social Media Accounts](https://attack.mitre.org/techniques/T1585/001)), adversaries may compromise existing social media accounts. Utilizing an existing persona may engender a level of trust in a potential victim if they have a relationship, or knowledge of, the compromised persona." ;
    skos:exactMatch d3f:T1586.001,
        mitre-attack:T1586.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1586002 a owl:Class ;
    rdfs:label "T1586_002" ;
    d3f:attack-id "T1586.002" ;
    dcterms:title "Email Accounts" ;
    rdfs:subClassOf d3f:T1586 ;
    skos:altLabel "T1586.002" ;
    skos:definition "Adversaries may compromise email accounts that can be used during targeting. Adversaries can use compromised email accounts to further their operations, such as leveraging them to conduct [Phishing for Information](https://attack.mitre.org/techniques/T1598), [Phishing](https://attack.mitre.org/techniques/T1566), or large-scale spam email campaigns. Utilizing an existing persona with a compromised email account may engender a level of trust in a potential victim if they have a relationship with, or knowledge of, the compromised persona. Compromised email accounts can also be used in the acquisition of infrastructure (ex: [Domains](https://attack.mitre.org/techniques/T1583/001))." ;
    skos:exactMatch d3f:T1586.002,
        mitre-attack:T1586.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1586003 a owl:Class ;
    rdfs:label "T1586_003" ;
    d3f:attack-id "T1586.003" ;
    dcterms:title "Cloud Accounts" ;
    rdfs:subClassOf d3f:T1586 ;
    skos:altLabel "T1586.003" ;
    skos:definition "Adversaries may compromise cloud accounts that can be used during targeting. Adversaries can use compromised cloud accounts to further their operations, including leveraging cloud storage services such as Dropbox, Microsoft OneDrive, or AWS S3 buckets for [Exfiltration to Cloud Storage](https://attack.mitre.org/techniques/T1567/002) or to [Upload Tool](https://attack.mitre.org/techniques/T1608/002)s. Cloud accounts can also be used in the acquisition of infrastructure, such as [Virtual Private Server](https://attack.mitre.org/techniques/T1583/003)s or [Serverless](https://attack.mitre.org/techniques/T1583/007) infrastructure. Compromising cloud accounts may allow adversaries to develop sophisticated capabilities without managing their own servers.(Citation: Awake Security C2 Cloud)" ;
    skos:exactMatch d3f:T1586.003,
        mitre-attack:T1586.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1587001 a owl:Class ;
    rdfs:label "T1587_001" ;
    d3f:attack-id "T1587.001" ;
    dcterms:title "Malware" ;
    rdfs:subClassOf d3f:T1587 ;
    skos:altLabel "T1587.001" ;
    skos:definition "Adversaries may develop malware and malware components that can be used during targeting. Building malicious software can include the development of payloads, droppers, post-compromise tools, backdoors (including backdoored images), packers, C2 protocols, and the creation of infected removable media. Adversaries may develop malware to support their operations, creating a means for maintaining control of remote machines, evading defenses, and executing post-compromise behaviors.(Citation: Mandiant APT1)(Citation: Kaspersky Sofacy)(Citation: ActiveMalwareEnergy)(Citation: FBI Flash FIN7 USB)" ;
    skos:exactMatch d3f:T1587.001,
        mitre-attack:T1587.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1587002 a owl:Class ;
    rdfs:label "T1587_002" ;
    d3f:attack-id "T1587.002" ;
    dcterms:title "Code Signing Certificates" ;
    rdfs:subClassOf d3f:T1587 ;
    skos:altLabel "T1587.002" ;
    skos:definition "Adversaries may create self-signed code signing certificates that can be used during targeting. Code signing is the process of digitally signing executables and scripts to confirm the software author and guarantee that the code has not been altered or corrupted. Code signing provides a level of authenticity for a program from the developer and a guarantee that the program has not been tampered with.(Citation: Wikipedia Code Signing) Users and/or security tools may trust a signed piece of code more than an unsigned piece of code even if they don't know who issued the certificate or who the author is." ;
    skos:exactMatch d3f:T1587.002,
        mitre-attack:T1587.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1587003 a owl:Class ;
    rdfs:label "T1587_003" ;
    d3f:attack-id "T1587.003" ;
    dcterms:title "Digital Certificates" ;
    rdfs:subClassOf d3f:T1587 ;
    skos:altLabel "T1587.003" ;
    skos:definition "Adversaries may create self-signed SSL/TLS certificates that can be used during targeting. SSL/TLS certificates are designed to instill trust. They include information about the key, information about its owner's identity, and the digital signature of an entity that has verified the certificate's contents are correct. If the signature is valid, and the person examining the certificate trusts the signer, then they know they can use that key to communicate with its owner. In the case of self-signing, digital certificates will lack the element of trust associated with the signature of a third-party certificate authority (CA)." ;
    skos:exactMatch d3f:T1587.003,
        mitre-attack:T1587.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1587004 a owl:Class ;
    rdfs:label "T1587_004" ;
    d3f:attack-id "T1587.004" ;
    dcterms:title "Exploits" ;
    rdfs:subClassOf d3f:T1587 ;
    skos:altLabel "T1587.004" ;
    skos:definition "Adversaries may develop exploits that can be used during targeting. An exploit takes advantage of a bug or vulnerability in order to cause unintended or unanticipated behavior to occur on computer hardware or software. Rather than finding/modifying exploits from online or purchasing them from exploit vendors, an adversary may develop their own exploits.(Citation: NYTStuxnet) Adversaries may use information acquired via [Vulnerabilities](https://attack.mitre.org/techniques/T1588/006) to focus exploit development efforts. As part of the exploit development process, adversaries may uncover exploitable vulnerabilities through methods such as fuzzing and patch analysis.(Citation: Irongeek Sims BSides 2017)" ;
    skos:exactMatch d3f:T1587.004,
        mitre-attack:T1587.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588001 a owl:Class ;
    rdfs:label "T1588_001" ;
    d3f:attack-id "T1588.001" ;
    dcterms:title "Malware" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.001" ;
    skos:definition "Adversaries may buy, steal, or download malware that can be used during targeting. Malicious software can include payloads, droppers, post-compromise tools, backdoors, packers, and C2 protocols. Adversaries may acquire malware to support their operations, obtaining a means for maintaining control of remote machines, evading defenses, and executing post-compromise behaviors." ;
    skos:exactMatch d3f:T1588.001,
        mitre-attack:T1588.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588002 a owl:Class ;
    rdfs:label "T1588_002" ;
    d3f:attack-id "T1588.002" ;
    dcterms:title "Tool" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.002" ;
    skos:definition "Adversaries may buy, steal, or download software tools that can be used during targeting. Tools can be open or closed source, free or commercial. A tool can be used for malicious purposes by an adversary, but (unlike malware) were not intended to be used for those purposes (ex: [PsExec](https://attack.mitre.org/software/S0029)). Tool acquisition can involve the procurement of commercial software licenses, including for red teaming tools such as [Cobalt Strike](https://attack.mitre.org/software/S0154). Commercial software may be obtained through purchase, stealing licenses (or licensed copies of the software), or cracking trial versions.(Citation: Recorded Future Beacon 2019)" ;
    skos:exactMatch d3f:T1588.002,
        mitre-attack:T1588.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588003 a owl:Class ;
    rdfs:label "T1588_003" ;
    d3f:attack-id "T1588.003" ;
    dcterms:title "Code Signing Certificates" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.003" ;
    skos:definition "Adversaries may buy and/or steal code signing certificates that can be used during targeting. Code signing is the process of digitally signing executables and scripts to confirm the software author and guarantee that the code has not been altered or corrupted. Code signing provides a level of authenticity for a program from the developer and a guarantee that the program has not been tampered with.(Citation: Wikipedia Code Signing) Users and/or security tools may trust a signed piece of code more than an unsigned piece of code even if they don't know who issued the certificate or who the author is." ;
    skos:exactMatch d3f:T1588.003,
        mitre-attack:T1588.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588004 a owl:Class ;
    rdfs:label "T1588_004" ;
    d3f:attack-id "T1588.004" ;
    dcterms:title "Digital Certificates" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.004" ;
    skos:definition "Adversaries may buy and/or steal SSL/TLS certificates that can be used during targeting. SSL/TLS certificates are designed to instill trust. They include information about the key, information about its owner's identity, and the digital signature of an entity that has verified the certificate's contents are correct. If the signature is valid, and the person examining the certificate trusts the signer, then they know they can use that key to communicate with its owner." ;
    skos:exactMatch d3f:T1588.004,
        mitre-attack:T1588.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588005 a owl:Class ;
    rdfs:label "T1588_005" ;
    d3f:attack-id "T1588.005" ;
    dcterms:title "Exploits" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.005" ;
    skos:definition "Adversaries may buy, steal, or download exploits that can be used during targeting. An exploit takes advantage of a bug or vulnerability in order to cause unintended or unanticipated behavior to occur on computer hardware or software. Rather than developing their own exploits, an adversary may find/modify exploits from online or purchase them from exploit vendors.(Citation: Exploit Database)(Citation: TempertonDarkHotel)(Citation: NationsBuying)" ;
    skos:exactMatch d3f:T1588.005,
        mitre-attack:T1588.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588006 a owl:Class ;
    rdfs:label "T1588_006" ;
    d3f:attack-id "T1588.006" ;
    dcterms:title "Vulnerabilities" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.006" ;
    skos:definition "Adversaries may acquire information about vulnerabilities that can be used during targeting. A vulnerability is a weakness in computer hardware or software that can, potentially, be exploited by an adversary to cause unintended or unanticipated behavior to occur. Adversaries may find vulnerability information by searching open databases or gaining access to closed vulnerability databases.(Citation: National Vulnerability Database)" ;
    skos:exactMatch d3f:T1588.006,
        mitre-attack:T1588.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588007 a owl:Class ;
    rdfs:label "T1588_007" ;
    d3f:attack-id "T1588.007" ;
    dcterms:title "Artificial Intelligence" ;
    rdfs:subClassOf d3f:T1588 ;
    skos:altLabel "T1588.007" ;
    skos:definition "Adversaries may obtain access to generative artificial intelligence tools, such as large language models (LLMs), to aid various techniques during targeting. These tools may be used to inform, bolster, and enable a variety of malicious tasks including conducting [Reconnaissance](https://attack.mitre.org/tactics/TA0043), creating basic scripts, assisting social engineering, and even developing payloads.(Citation: MSFT-AI)" ;
    skos:exactMatch d3f:T1588.007,
        mitre-attack:T1588.007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1589001 a owl:Class ;
    rdfs:label "T1589_001" ;
    d3f:attack-id "T1589.001" ;
    dcterms:title "Credentials" ;
    rdfs:subClassOf d3f:T1589 ;
    skos:altLabel "T1589.001" ;
    skos:definition "Adversaries may gather credentials that can be used during targeting. Account credentials gathered by adversaries may be those directly associated with the target victim organization or attempt to take advantage of the tendency for users to use the same passwords across personal and business accounts." ;
    skos:exactMatch d3f:T1589.001,
        mitre-attack:T1589.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1589002 a owl:Class ;
    rdfs:label "T1589_002" ;
    d3f:attack-id "T1589.002" ;
    dcterms:title "Email Addresses" ;
    rdfs:subClassOf d3f:T1589 ;
    skos:altLabel "T1589.002" ;
    skos:definition "Adversaries may gather email addresses that can be used during targeting. Even if internal instances exist, organizations may have public-facing email infrastructure and addresses for employees." ;
    skos:exactMatch d3f:T1589.002,
        mitre-attack:T1589.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1589003 a owl:Class ;
    rdfs:label "T1589_003" ;
    d3f:attack-id "T1589.003" ;
    dcterms:title "Employee Names" ;
    rdfs:subClassOf d3f:T1589 ;
    skos:altLabel "T1589.003" ;
    skos:definition "Adversaries may gather employee names that can be used during targeting. Employee names be used to derive email addresses as well as to help guide other reconnaissance efforts and/or craft more-believable lures." ;
    skos:exactMatch d3f:T1589.003,
        mitre-attack:T1589.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590001 a owl:Class ;
    rdfs:label "T1590_001" ;
    d3f:attack-id "T1590.001" ;
    dcterms:title "Domain Properties" ;
    rdfs:subClassOf d3f:T1590 ;
    skos:altLabel "T1590.001" ;
    skos:definition "Adversaries may gather information about the victim's network domain(s) that can be used during targeting. Information about domains and their properties may include a variety of details, including what domain(s) the victim owns as well as administrative data (ex: name, registrar, etc.) and more directly actionable information such as contacts (email addresses and phone numbers), business addresses, and name servers." ;
    skos:exactMatch d3f:T1590.001,
        mitre-attack:T1590.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590002 a owl:Class ;
    rdfs:label "T1590_002" ;
    d3f:attack-id "T1590.002" ;
    dcterms:title "DNS" ;
    rdfs:subClassOf d3f:T1590 ;
    skos:altLabel "T1590.002" ;
    skos:definition "Adversaries may gather information about the victim's DNS that can be used during targeting. DNS information may include a variety of details, including registered name servers as well as records that outline addressing for a target’s subdomains, mail servers, and other hosts. DNS, MX, TXT, and SPF records may also reveal the use of third party cloud and SaaS providers, such as Office 365, G Suite, Salesforce, or Zendesk.(Citation: Sean Metcalf Twitter DNS Records)" ;
    skos:exactMatch d3f:T1590.002,
        mitre-attack:T1590.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590003 a owl:Class ;
    rdfs:label "T1590_003" ;
    d3f:attack-id "T1590.003" ;
    dcterms:title "Network Trust Dependencies" ;
    rdfs:subClassOf d3f:T1590 ;
    skos:altLabel "T1590.003" ;
    skos:definition "Adversaries may gather information about the victim's network trust dependencies that can be used during targeting. Information about network trusts may include a variety of details, including second or third-party organizations/domains (ex: managed service providers, contractors, etc.) that have connected (and potentially elevated) network access." ;
    skos:exactMatch d3f:T1590.003,
        mitre-attack:T1590.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590004 a owl:Class ;
    rdfs:label "T1590_004" ;
    d3f:attack-id "T1590.004" ;
    dcterms:title "Network Topology" ;
    rdfs:subClassOf d3f:T1590 ;
    skos:altLabel "T1590.004" ;
    skos:definition "Adversaries may gather information about the victim's network topology that can be used during targeting. Information about network topologies may include a variety of details, including the physical and/or logical arrangement of both external-facing and internal network environments. This information may also include specifics regarding network devices (gateways, routers, etc.) and other infrastructure." ;
    skos:exactMatch d3f:T1590.004,
        mitre-attack:T1590.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590005 a owl:Class ;
    rdfs:label "T1590_005" ;
    d3f:attack-id "T1590.005" ;
    dcterms:title "IP Addresses" ;
    rdfs:subClassOf d3f:T1590 ;
    skos:altLabel "T1590.005" ;
    skos:definition "Adversaries may gather the victim's IP addresses that can be used during targeting. Public IP addresses may be allocated to organizations by block, or a range of sequential addresses. Information about assigned IP addresses may include a variety of details, such as which IP addresses are in use. IP addresses may also enable an adversary to derive other details about a victim, such as organizational size, physical location(s), Internet service provider, and or where/how their publicly-facing infrastructure is hosted." ;
    skos:exactMatch d3f:T1590.005,
        mitre-attack:T1590.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590006 a owl:Class ;
    rdfs:label "T1590_006" ;
    d3f:attack-id "T1590.006" ;
    dcterms:title "Network Security Appliances" ;
    rdfs:subClassOf d3f:T1590 ;
    skos:altLabel "T1590.006" ;
    skos:definition "Adversaries may gather information about the victim's network security appliances that can be used during targeting. Information about network security appliances may include a variety of details, such as the existence and specifics of deployed firewalls, content filters, and proxies/bastion hosts. Adversaries may also target information about victim network-based intrusion detection systems (NIDS) or other appliances related to defensive cybersecurity operations." ;
    skos:exactMatch d3f:T1590.006,
        mitre-attack:T1590.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1591001 a owl:Class ;
    rdfs:label "T1591_001" ;
    d3f:attack-id "T1591.001" ;
    dcterms:title "Determine Physical Locations" ;
    rdfs:subClassOf d3f:T1591 ;
    skos:altLabel "T1591.001" ;
    skos:definition "Adversaries may gather the victim's physical location(s) that can be used during targeting. Information about physical locations of a target organization may include a variety of details, including where key resources and infrastructure are housed. Physical locations may also indicate what legal jurisdiction and/or authorities the victim operates within." ;
    skos:exactMatch d3f:T1591.001,
        mitre-attack:T1591.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1591002 a owl:Class ;
    rdfs:label "T1591_002" ;
    d3f:attack-id "T1591.002" ;
    dcterms:title "Business Relationships" ;
    rdfs:subClassOf d3f:T1591 ;
    skos:altLabel "T1591.002" ;
    skos:definition "Adversaries may gather information about the victim's business relationships that can be used during targeting. Information about an organization’s business relationships may include a variety of details, including second or third-party organizations/domains (ex: managed service providers, contractors, etc.) that have connected (and potentially elevated) network access. This information may also reveal supply chains and shipment paths for the victim’s hardware and software resources." ;
    skos:exactMatch d3f:T1591.002,
        mitre-attack:T1591.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1591003 a owl:Class ;
    rdfs:label "T1591_003" ;
    d3f:attack-id "T1591.003" ;
    dcterms:title "Identify Business Tempo" ;
    rdfs:subClassOf d3f:T1591 ;
    skos:altLabel "T1591.003" ;
    skos:definition "Adversaries may gather information about the victim's business tempo that can be used during targeting. Information about an organization’s business tempo may include a variety of details, including operational hours/days of the week. This information may also reveal times/dates of purchases and shipments of the victim’s hardware and software resources." ;
    skos:exactMatch d3f:T1591.003,
        mitre-attack:T1591.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1591004 a owl:Class ;
    rdfs:label "T1591_004" ;
    d3f:attack-id "T1591.004" ;
    dcterms:title "Identify Roles" ;
    rdfs:subClassOf d3f:T1591 ;
    skos:altLabel "T1591.004" ;
    skos:definition "Adversaries may gather information about identities and roles within the victim organization that can be used during targeting. Information about business roles may reveal a variety of targetable details, including identifiable information for key personnel as well as what data/resources they have access to." ;
    skos:exactMatch d3f:T1591.004,
        mitre-attack:T1591.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1592001 a owl:Class ;
    rdfs:label "T1592_001" ;
    d3f:attack-id "T1592.001" ;
    dcterms:title "Hardware" ;
    rdfs:subClassOf d3f:T1592 ;
    skos:altLabel "T1592.001" ;
    skos:definition "Adversaries may gather information about the victim's host hardware that can be used during targeting. Information about hardware infrastructure may include a variety of details such as types and versions on specific hosts, as well as the presence of additional components that might be indicative of added defensive protections (ex: card/biometric readers, dedicated encryption hardware, etc.)." ;
    skos:exactMatch d3f:T1592.001,
        mitre-attack:T1592.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1592002 a owl:Class ;
    rdfs:label "T1592_002" ;
    d3f:attack-id "T1592.002" ;
    dcterms:title "Software" ;
    rdfs:subClassOf d3f:T1592 ;
    skos:altLabel "T1592.002" ;
    skos:definition "Adversaries may gather information about the victim's host software that can be used during targeting. Information about installed software may include a variety of details such as types and versions on specific hosts, as well as the presence of additional components that might be indicative of added defensive protections (ex: antivirus, SIEMs, etc.)." ;
    skos:exactMatch d3f:T1592.002,
        mitre-attack:T1592.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1592003 a owl:Class ;
    rdfs:label "T1592_003" ;
    d3f:attack-id "T1592.003" ;
    dcterms:title "Firmware" ;
    rdfs:subClassOf d3f:T1592 ;
    skos:altLabel "T1592.003" ;
    skos:definition "Adversaries may gather information about the victim's host firmware that can be used during targeting. Information about host firmware may include a variety of details such as type and versions on specific hosts, which may be used to infer more information about hosts in the environment (ex: configuration, purpose, age/patch level, etc.)." ;
    skos:exactMatch d3f:T1592.003,
        mitre-attack:T1592.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1592004 a owl:Class ;
    rdfs:label "T1592_004" ;
    d3f:attack-id "T1592.004" ;
    dcterms:title "Client Configurations" ;
    rdfs:subClassOf d3f:T1592 ;
    skos:altLabel "T1592.004" ;
    skos:definition "Adversaries may gather information about the victim's client configurations that can be used during targeting. Information about client configurations may include a variety of details and settings, including operating system/version, virtualization, architecture (ex: 32 or 64 bit), language, and/or time zone." ;
    skos:exactMatch d3f:T1592.004,
        mitre-attack:T1592.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1593001 a owl:Class ;
    rdfs:label "T1593_001" ;
    d3f:attack-id "T1593.001" ;
    dcterms:title "Social Media" ;
    rdfs:subClassOf d3f:T1593 ;
    skos:altLabel "T1593.001" ;
    skos:definition "Adversaries may search social media for information about victims that can be used during targeting. Social media sites may contain various information about a victim organization, such as business announcements as well as information about the roles, locations, and interests of staff." ;
    skos:exactMatch d3f:T1593.001,
        mitre-attack:T1593.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1593002 a owl:Class ;
    rdfs:label "T1593_002" ;
    d3f:attack-id "T1593.002" ;
    dcterms:title "Search Engines" ;
    rdfs:subClassOf d3f:T1593 ;
    skos:altLabel "T1593.002" ;
    skos:definition "Adversaries may use search engines to collect information about victims that can be used during targeting. Search engine services typical crawl online sites to index context and may provide users with specialized syntax to search for specific keywords or specific types of content (i.e. filetypes).(Citation: SecurityTrails Google Hacking)(Citation: ExploitDB GoogleHacking)" ;
    skos:exactMatch d3f:T1593.002,
        mitre-attack:T1593.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1593003 a owl:Class ;
    rdfs:label "T1593_003" ;
    d3f:attack-id "T1593.003" ;
    dcterms:title "Code Repositories" ;
    rdfs:subClassOf d3f:T1593 ;
    skos:altLabel "T1593.003" ;
    skos:definition "Adversaries may search public code repositories for information about victims that can be used during targeting. Victims may store code in repositories on various third-party websites such as GitHub, GitLab, SourceForge, and BitBucket. Users typically interact with code repositories through a web application or command-line utilities such as git." ;
    skos:exactMatch d3f:T1593.003,
        mitre-attack:T1593.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1595001 a owl:Class ;
    rdfs:label "T1595_001" ;
    d3f:attack-id "T1595.001" ;
    dcterms:title "Scanning IP Blocks" ;
    rdfs:subClassOf d3f:T1595 ;
    skos:altLabel "T1595.001" ;
    skos:definition "Adversaries may scan victim IP blocks to gather information that can be used during targeting. Public IP addresses may be allocated to organizations by block, or a range of sequential addresses." ;
    skos:exactMatch d3f:T1595.001,
        mitre-attack:T1595.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1595002 a owl:Class ;
    rdfs:label "T1595_002" ;
    d3f:attack-id "T1595.002" ;
    dcterms:title "Vulnerability Scanning" ;
    rdfs:subClassOf d3f:T1595 ;
    skos:altLabel "T1595.002" ;
    skos:definition "Adversaries may scan victims for vulnerabilities that can be used during targeting. Vulnerability scans typically check if the configuration of a target host/application (ex: software and version) potentially aligns with the target of a specific exploit the adversary may seek to use." ;
    skos:exactMatch d3f:T1595.002,
        mitre-attack:T1595.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1595003 a owl:Class ;
    rdfs:label "T1595_003" ;
    d3f:attack-id "T1595.003" ;
    dcterms:title "Wordlist Scanning" ;
    rdfs:subClassOf d3f:T1595 ;
    skos:altLabel "T1595.003" ;
    skos:definition "Adversaries may iteratively probe infrastructure using brute-forcing and crawling techniques. While this technique employs similar methods to [Brute Force](https://attack.mitre.org/techniques/T1110), its goal is the identification of content and infrastructure rather than the discovery of valid credentials. Wordlists used in these scans may contain generic, commonly used names and file extensions or terms specific to a particular software. Adversaries may also create custom, target-specific wordlists using data gathered from other Reconnaissance techniques (ex: [Gather Victim Org Information](https://attack.mitre.org/techniques/T1591), or [Search Victim-Owned Websites](https://attack.mitre.org/techniques/T1594))." ;
    skos:exactMatch d3f:T1595.003,
        mitre-attack:T1595.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1596001 a owl:Class ;
    rdfs:label "T1596_001" ;
    d3f:attack-id "T1596.001" ;
    dcterms:title "DNS/Passive DNS" ;
    rdfs:subClassOf d3f:T1596 ;
    skos:altLabel "T1596.001" ;
    skos:definition "Adversaries may search DNS data for information about victims that can be used during targeting. DNS information may include a variety of details, including registered name servers as well as records that outline addressing for a target’s subdomains, mail servers, and other hosts." ;
    skos:exactMatch d3f:T1596.001,
        mitre-attack:T1596.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1596002 a owl:Class ;
    rdfs:label "T1596_002" ;
    d3f:attack-id "T1596.002" ;
    dcterms:title "WHOIS" ;
    rdfs:subClassOf d3f:T1596 ;
    skos:altLabel "T1596.002" ;
    skos:definition "Adversaries may search public WHOIS data for information about victims that can be used during targeting. WHOIS data is stored by regional Internet registries (RIR) responsible for allocating and assigning Internet resources such as domain names. Anyone can query WHOIS servers for information about a registered domain, such as assigned IP blocks, contact information, and DNS nameservers.(Citation: WHOIS)" ;
    skos:exactMatch d3f:T1596.002,
        mitre-attack:T1596.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1596003 a owl:Class ;
    rdfs:label "T1596_003" ;
    d3f:attack-id "T1596.003" ;
    dcterms:title "Digital Certificates" ;
    rdfs:subClassOf d3f:T1596 ;
    skos:altLabel "T1596.003" ;
    skos:definition "Adversaries may search public digital certificate data for information about victims that can be used during targeting. Digital certificates are issued by a certificate authority (CA) in order to cryptographically verify the origin of signed content. These certificates, such as those used for encrypted web traffic (HTTPS SSL/TLS communications), contain information about the registered organization such as name and location." ;
    skos:exactMatch d3f:T1596.003,
        mitre-attack:T1596.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1596004 a owl:Class ;
    rdfs:label "T1596_004" ;
    d3f:attack-id "T1596.004" ;
    dcterms:title "CDNs" ;
    rdfs:subClassOf d3f:T1596 ;
    skos:altLabel "T1596.004" ;
    skos:definition "Adversaries may search content delivery network (CDN) data about victims that can be used during targeting. CDNs allow an organization to host content from a distributed, load balanced array of servers. CDNs may also allow organizations to customize content delivery based on the requestor’s geographical region." ;
    skos:exactMatch d3f:T1596.004,
        mitre-attack:T1596.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1596005 a owl:Class ;
    rdfs:label "T1596_005" ;
    d3f:attack-id "T1596.005" ;
    dcterms:title "Scan Databases" ;
    rdfs:subClassOf d3f:T1596 ;
    skos:altLabel "T1596.005" ;
    skos:definition "Adversaries may search within public scan databases for information about victims that can be used during targeting. Various online services continuously publish the results of Internet scans/surveys, often harvesting information such as active IP addresses, hostnames, open ports, certificates, and even server banners.(Citation: Shodan)" ;
    skos:exactMatch d3f:T1596.005,
        mitre-attack:T1596.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1597001 a owl:Class ;
    rdfs:label "T1597_001" ;
    d3f:attack-id "T1597.001" ;
    dcterms:title "Threat Intel Vendors" ;
    rdfs:subClassOf d3f:T1597 ;
    skos:altLabel "T1597.001" ;
    skos:definition "Adversaries may search private data from threat intelligence vendors for information that can be used during targeting. Threat intelligence vendors may offer paid feeds or portals that offer more data than what is publicly reported. Although sensitive details (such as customer names and other identifiers) may be redacted, this information may contain trends regarding breaches such as target industries, attribution claims, and successful TTPs/countermeasures.(Citation: D3Secutrity CTI Feeds)" ;
    skos:exactMatch d3f:T1597.001,
        mitre-attack:T1597.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1597002 a owl:Class ;
    rdfs:label "T1597_002" ;
    d3f:attack-id "T1597.002" ;
    dcterms:title "Purchase Technical Data" ;
    rdfs:subClassOf d3f:T1597 ;
    skos:altLabel "T1597.002" ;
    skos:definition "Adversaries may purchase technical information about victims that can be used during targeting. Information about victims may be available for purchase within reputable private sources and databases, such as paid subscriptions to feeds of scan databases or other data aggregation services. Adversaries may also purchase information from less-reputable sources such as dark web or cybercrime blackmarkets." ;
    skos:exactMatch d3f:T1597.002,
        mitre-attack:T1597.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1598001 a owl:Class ;
    rdfs:label "T1598_001" ;
    d3f:attack-id "T1598.001" ;
    dcterms:title "Spearphishing Service" ;
    rdfs:subClassOf d3f:T1598 ;
    skos:altLabel "T1598.001" ;
    skos:definition "Adversaries may send spearphishing messages via third-party services to elicit sensitive information that can be used during targeting. Spearphishing for information is an attempt to trick targets into divulging information, frequently credentials or other actionable information. Spearphishing for information frequently involves social engineering techniques, such as posing as a source with a reason to collect information (ex: [Establish Accounts](https://attack.mitre.org/techniques/T1585) or [Compromise Accounts](https://attack.mitre.org/techniques/T1586)) and/or sending multiple, seemingly urgent messages." ;
    skos:exactMatch d3f:T1598.001,
        mitre-attack:T1598.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1598002 a owl:Class ;
    rdfs:label "T1598_002" ;
    d3f:attack-id "T1598.002" ;
    dcterms:title "Spearphishing Attachment" ;
    rdfs:subClassOf d3f:T1598 ;
    skos:altLabel "T1598.002" ;
    skos:definition "Adversaries may send spearphishing messages with a malicious attachment to elicit sensitive information that can be used during targeting. Spearphishing for information is an attempt to trick targets into divulging information, frequently credentials or other actionable information. Spearphishing for information frequently involves social engineering techniques, such as posing as a source with a reason to collect information (ex: [Establish Accounts](https://attack.mitre.org/techniques/T1585) or [Compromise Accounts](https://attack.mitre.org/techniques/T1586)) and/or sending multiple, seemingly urgent messages." ;
    skos:exactMatch d3f:T1598.002,
        mitre-attack:T1598.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1598003 a owl:Class ;
    rdfs:label "T1598_003" ;
    d3f:attack-id "T1598.003" ;
    dcterms:title "Spearphishing Link" ;
    rdfs:subClassOf d3f:T1598 ;
    skos:altLabel "T1598.003" ;
    skos:definition "Adversaries may send spearphishing messages with a malicious link to elicit sensitive information that can be used during targeting. Spearphishing for information is an attempt to trick targets into divulging information, frequently credentials or other actionable information. Spearphishing for information frequently involves social engineering techniques, such as posing as a source with a reason to collect information (ex: [Establish Accounts](https://attack.mitre.org/techniques/T1585) or [Compromise Accounts](https://attack.mitre.org/techniques/T1586)) and/or sending multiple, seemingly urgent messages." ;
    skos:exactMatch d3f:T1598.003,
        mitre-attack:T1598.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1598004 a owl:Class ;
    rdfs:label "T1598_004" ;
    d3f:attack-id "T1598.004" ;
    dcterms:title "Spearphishing Voice" ;
    rdfs:subClassOf d3f:T1598 ;
    skos:altLabel "T1598.004" ;
    skos:definition "Adversaries may use voice communications to elicit sensitive information that can be used during targeting. Spearphishing for information is an attempt to trick targets into divulging information, frequently credentials or other actionable information. Spearphishing for information frequently involves social engineering techniques, such as posing as a source with a reason to collect information (ex: [Impersonation](https://attack.mitre.org/techniques/T1656)) and/or creating a sense of urgency or alarm for the recipient." ;
    skos:exactMatch d3f:T1598.004,
        mitre-attack:T1598.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1599001 a owl:Class ;
    rdfs:label "T1599_001" ;
    d3f:attack-id "T1599.001" ;
    dcterms:title "Network Address Translation Traversal" ;
    rdfs:subClassOf d3f:T1599 ;
    skos:altLabel "T1599.001" ;
    skos:definition "Adversaries may bridge network boundaries by modifying a network device’s Network Address Translation (NAT) configuration. Malicious modifications to NAT may enable an adversary to bypass restrictions on traffic routing that otherwise separate trusted and untrusted networks." ;
    skos:exactMatch d3f:T1599.001,
        mitre-attack:T1599.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1600001 a owl:Class ;
    rdfs:label "T1600_001" ;
    d3f:attack-id "T1600.001" ;
    dcterms:title "Reduce Key Space" ;
    rdfs:subClassOf d3f:T1600 ;
    skos:altLabel "T1600.001" ;
    skos:definition "Adversaries may reduce the level of effort required to decrypt data transmitted over the network by reducing the cipher strength of encrypted communications.(Citation: Cisco Synful Knock Evolution)" ;
    skos:exactMatch d3f:T1600.001,
        mitre-attack:T1600.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1600002 a owl:Class ;
    rdfs:label "T1600_002" ;
    d3f:attack-id "T1600.002" ;
    dcterms:title "Disable Crypto Hardware" ;
    rdfs:subClassOf d3f:T1600 ;
    skos:altLabel "T1600.002" ;
    skos:definition "Adversaries disable a network device’s dedicated hardware encryption, which may enable them to leverage weaknesses in software encryption in order to reduce the effort involved in collecting, manipulating, and exfiltrating transmitted data." ;
    skos:exactMatch d3f:T1600.002,
        mitre-attack:T1600.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1601001 a owl:Class ;
    rdfs:label "T1601_001" ;
    d3f:attack-id "T1601.001" ;
    dcterms:title "Patch System Image" ;
    rdfs:subClassOf d3f:T1601 ;
    skos:altLabel "T1601.001" ;
    skos:definition "Adversaries may modify the operating system of a network device to introduce new capabilities or weaken existing defenses.(Citation: Killing the myth of Cisco IOS rootkits) (Citation: Killing IOS diversity myth) (Citation: Cisco IOS Shellcode) (Citation: Cisco IOS Forensics Developments) (Citation: Juniper Netscreen of the Dead) Some network devices are built with a monolithic architecture, where the entire operating system and most of the functionality of the device is contained within a single file.  Adversaries may change this file in storage, to be loaded in a future boot, or in memory during runtime." ;
    skos:exactMatch d3f:T1601.001,
        mitre-attack:T1601.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1601002 a owl:Class ;
    rdfs:label "T1601_002" ;
    d3f:attack-id "T1601.002" ;
    dcterms:title "Downgrade System Image" ;
    rdfs:subClassOf d3f:T1601 ;
    skos:altLabel "T1601.002" ;
    skos:definition "Adversaries may install an older version of the operating system of a network device to weaken security.  Older operating system versions on network devices often have weaker encryption ciphers and, in general, fewer/less updated defensive features. (Citation: Cisco Synful Knock Evolution)" ;
    skos:exactMatch d3f:T1601.002,
        mitre-attack:T1601.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1602001 a owl:Class ;
    rdfs:label "T1602_001" ;
    d3f:attack-id "T1602.001" ;
    dcterms:title "SNMP (MIB Dump)" ;
    rdfs:subClassOf d3f:T1602 ;
    skos:altLabel "T1602.001" ;
    skos:definition "Adversaries may target the Management Information Base (MIB) to collect and/or mine valuable information in a network managed using Simple Network Management Protocol (SNMP)." ;
    skos:exactMatch d3f:T1602.001,
        mitre-attack:T1602.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1602002 a owl:Class ;
    rdfs:label "T1602_002" ;
    d3f:attack-id "T1602.002" ;
    dcterms:title "Network Device Configuration Dump" ;
    rdfs:subClassOf d3f:T1602 ;
    skos:altLabel "T1602.002" ;
    skos:definition "Adversaries may access network configuration files to collect sensitive data about the device and the network. The network configuration is a file containing parameters that determine the operation of the device. The device typically stores an in-memory copy of the configuration while operating, and a separate configuration on non-volatile storage to load after device reset. Adversaries can inspect the configuration files to reveal information about the target network and its layout, the network device and its software, or identifying legitimate accounts and credentials for later use." ;
    skos:exactMatch d3f:T1602.002,
        mitre-attack:T1602.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1606001 a owl:Class ;
    rdfs:label "T1606_001" ;
    d3f:attack-id "T1606.001" ;
    dcterms:title "Web Cookies" ;
    rdfs:subClassOf d3f:T1606 ;
    skos:altLabel "T1606.001" ;
    skos:definition "Adversaries may forge web cookies that can be used to gain access to web applications or Internet services. Web applications and services (hosted in cloud SaaS environments or on-premise servers) often use session cookies to authenticate and authorize user access." ;
    skos:exactMatch d3f:T1606.001,
        mitre-attack:T1606.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1606002 a owl:Class ;
    rdfs:label "T1606_002" ;
    d3f:attack-id "T1606.002" ;
    dcterms:title "SAML Tokens" ;
    rdfs:subClassOf d3f:T1606 ;
    skos:altLabel "T1606.002" ;
    skos:definition "An adversary may forge SAML tokens with any permissions claims and lifetimes if they possess a valid SAML token-signing certificate.(Citation: Microsoft SolarWinds Steps) The default lifetime of a SAML token is one hour, but the validity period can be specified in the <code>NotOnOrAfter</code> value of the <code>conditions ...</code> element in a token. This value can be changed using the <code>AccessTokenLifetime</code> in a <code>LifetimeTokenPolicy</code>.(Citation: Microsoft SAML Token Lifetimes) Forged SAML tokens enable adversaries to authenticate across services that use SAML 2.0 as an SSO (single sign-on) mechanism.(Citation: Cyberark Golden SAML)" ;
    skos:exactMatch d3f:T1606.002,
        mitre-attack:T1606.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608001 a owl:Class ;
    rdfs:label "T1608_001" ;
    d3f:attack-id "T1608.001" ;
    dcterms:title "Upload Malware" ;
    rdfs:subClassOf d3f:T1608 ;
    skos:altLabel "T1608.001" ;
    skos:definition "Adversaries may upload malware to third-party or adversary controlled infrastructure to make it accessible during targeting. Malicious software can include payloads, droppers, post-compromise tools, backdoors, and a variety of other malicious content. Adversaries may upload malware to support their operations, such as making a payload available to a victim network to enable [Ingress Tool Transfer](https://attack.mitre.org/techniques/T1105) by placing it on an Internet accessible web server." ;
    skos:exactMatch d3f:T1608.001,
        mitre-attack:T1608.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608002 a owl:Class ;
    rdfs:label "T1608_002" ;
    d3f:attack-id "T1608.002" ;
    dcterms:title "Upload Tool" ;
    rdfs:subClassOf d3f:T1608 ;
    skos:altLabel "T1608.002" ;
    skos:definition "Adversaries may upload tools to third-party or adversary controlled infrastructure to make it accessible during targeting. Tools can be open or closed source, free or commercial. Tools can be used for malicious purposes by an adversary, but (unlike malware) were not intended to be used for those purposes (ex: [PsExec](https://attack.mitre.org/software/S0029)). Adversaries may upload tools to support their operations, such as making a tool available to a victim network to enable [Ingress Tool Transfer](https://attack.mitre.org/techniques/T1105) by placing it on an Internet accessible web server." ;
    skos:exactMatch d3f:T1608.002,
        mitre-attack:T1608.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608003 a owl:Class ;
    rdfs:label "T1608_003" ;
    d3f:attack-id "T1608.003" ;
    dcterms:title "Install Digital Certificate" ;
    rdfs:subClassOf d3f:T1608 ;
    skos:altLabel "T1608.003" ;
    skos:definition "Adversaries may install SSL/TLS certificates that can be used during targeting. SSL/TLS certificates are files that can be installed on servers to enable secure communications between systems. Digital certificates include information about the key, information about its owner's identity, and the digital signature of an entity that has verified the certificate's contents are correct. If the signature is valid, and the person examining the certificate trusts the signer, then they know they can use that key to communicate securely with its owner. Certificates can be uploaded to a server, then the server can be configured to use the certificate to enable encrypted communication with it.(Citation: DigiCert Install SSL Cert)" ;
    skos:exactMatch d3f:T1608.003,
        mitre-attack:T1608.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608004 a owl:Class ;
    rdfs:label "T1608_004" ;
    d3f:attack-id "T1608.004" ;
    dcterms:title "Drive-by Target" ;
    rdfs:subClassOf d3f:T1608 ;
    skos:altLabel "T1608.004" ;
    skos:definition "Adversaries may prepare an operational environment to infect systems that visit a website over the normal course of browsing. Endpoint systems may be compromised through browsing to adversary controlled sites, as in [Drive-by Compromise](https://attack.mitre.org/techniques/T1189). In such cases, the user's web browser is typically targeted for exploitation (often not requiring any extra user interaction once landing on the site), but adversaries may also set up websites for non-exploitation behavior such as [Application Access Token](https://attack.mitre.org/techniques/T1550/001). Prior to [Drive-by Compromise](https://attack.mitre.org/techniques/T1189), adversaries must stage resources needed to deliver that exploit to users who browse to an adversary controlled site. Drive-by content can be staged on adversary controlled infrastructure that has been acquired ([Acquire Infrastructure](https://attack.mitre.org/techniques/T1583)) or previously compromised ([Compromise Infrastructure](https://attack.mitre.org/techniques/T1584))." ;
    skos:exactMatch d3f:T1608.004,
        mitre-attack:T1608.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608005 a owl:Class ;
    rdfs:label "T1608_005" ;
    d3f:attack-id "T1608.005" ;
    dcterms:title "Link Target" ;
    rdfs:subClassOf d3f:T1608 ;
    skos:altLabel "T1608.005" ;
    skos:definition "Adversaries may put in place resources that are referenced by a link that can be used during targeting. An adversary may rely upon a user clicking a malicious link in order to divulge information (including credentials) or to gain execution, as in [Malicious Link](https://attack.mitre.org/techniques/T1204/001). Links can be used for spearphishing, such as sending an email accompanied by social engineering text to coax the user to actively click or copy and paste a URL into a browser. Prior to a phish for information (as in [Spearphishing Link](https://attack.mitre.org/techniques/T1598/003)) or a phish to gain initial access to a system (as in [Spearphishing Link](https://attack.mitre.org/techniques/T1566/002)), an adversary must set up the resources for a link target for the spearphishing link." ;
    skos:exactMatch d3f:T1608.005,
        mitre-attack:T1608.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608006 a owl:Class ;
    rdfs:label "T1608_006" ;
    d3f:attack-id "T1608.006" ;
    dcterms:title "SEO Poisoning" ;
    rdfs:subClassOf d3f:T1608 ;
    skos:altLabel "T1608.006" ;
    skos:definition "Adversaries may poison mechanisms that influence search engine optimization (SEO) to further lure staged capabilities towards potential victims. Search engines typically display results to users based on purchased ads as well as the site’s ranking/score/reputation calculated by their web crawlers and algorithms.(Citation: Atlas SEO)(Citation: MalwareBytes SEO)" ;
    skos:exactMatch d3f:T1608.006,
        mitre-attack:T1608.006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1614001 a owl:Class ;
    rdfs:label "T1614_001" ;
    d3f:attack-id "T1614.001" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Language Discovery" ;
    rdfs:subClassOf d3f:T1614 ;
    skos:altLabel "T1614.001" ;
    skos:definition "Adversaries may attempt to gather information about the system language of a victim in order to infer the geographical location of that host. This information may be used to shape follow-on behaviors, including whether the adversary infects the target and/or attempts specific actions. This decision may be employed by malware developers and operators to reduce their risk of attracting the attention of specific law enforcement agencies or prosecution/scrutiny from other entities.(Citation: Malware System Language Check)" ;
    skos:exactMatch d3f:T1614.001,
        mitre-attack:T1614.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1623001 a owl:Class ;
    rdfs:label "T1623_001" ;
    d3f:attack-id "T1623.001" ;
    dcterms:title "Unix Shell" ;
    rdfs:subClassOf d3f:T1623 ;
    skos:altLabel "T1623.001" ;
    skos:definition "Adversaries may abuse Unix shell commands and scripts for execution. Unix shells are the underlying command prompts on Android and iOS devices. Unix shells can control every aspect of a system, with certain commands requiring elevated privileges that are only accessible if the device has been rooted or jailbroken." ;
    skos:exactMatch d3f:T1623.001,
        mitre-attack:T1623.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1624001 a owl:Class ;
    rdfs:label "T1624_001" ;
    d3f:attack-id "T1624.001" ;
    dcterms:title "Broadcast Receivers" ;
    rdfs:subClassOf d3f:T1624 ;
    skos:altLabel "T1624.001" ;
    skos:definition "Adversaries may establish persistence using system mechanisms that trigger execution based on specific events. Mobile operating systems have means to subscribe to events such as receiving an SMS message, device boot completion, or other device activities." ;
    skos:exactMatch d3f:T1624.001,
        mitre-attack:T1624.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1625001 a owl:Class ;
    rdfs:label "T1625_001" ;
    d3f:attack-id "T1625.001" ;
    dcterms:title "System Runtime API Hijacking" ;
    rdfs:subClassOf d3f:T1625 ;
    skos:altLabel "T1625.001" ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the way an operating system runs applications. Hijacking execution flow can be for the purposes of persistence since this hijacked execution may reoccur at later points in time." ;
    skos:exactMatch d3f:T1625.001,
        mitre-attack:T1625.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1626001 a owl:Class ;
    rdfs:label "T1626_001" ;
    d3f:attack-id "T1626.001" ;
    dcterms:title "Device Administrator Permissions" ;
    rdfs:subClassOf d3f:T1626 ;
    skos:altLabel "T1626.001" ;
    skos:definition "Adversaries may abuse Android’s device administration API to obtain a higher degree of control over the device. By abusing the API, adversaries can perform several nefarious actions, such as resetting the device’s password for [Endpoint Denial of Service](https://attack.mitre.org/techniques/T1642), factory resetting the device for [File Deletion](https://attack.mitre.org/techniques/T1630/002) and to delete any traces of the malware, disabling all the device’s cameras, or to make it more difficult to uninstall the app." ;
    skos:exactMatch d3f:T1626.001,
        mitre-attack:T1626.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1627001 a owl:Class ;
    rdfs:label "T1627_001" ;
    d3f:attack-id "T1627.001" ;
    dcterms:title "Geofencing" ;
    rdfs:subClassOf d3f:T1627 ;
    skos:altLabel "T1627.001" ;
    skos:definition "Adversaries may use a device’s geographical location to limit certain malicious behaviors. For example, malware operators may limit the distribution of a second stage payload to certain geographic regions.(Citation: Lookout eSurv)" ;
    skos:exactMatch d3f:T1627.001,
        mitre-attack:T1627.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1628001 a owl:Class ;
    rdfs:label "T1628_001" ;
    d3f:attack-id "T1628.001" ;
    dcterms:title "Suppress Application Icon" ;
    rdfs:subClassOf d3f:T1628 ;
    skos:altLabel "T1628.001" ;
    skos:definition "A malicious application could suppress its icon from being displayed to the user in the application launcher. This hides the fact that it is installed, and can make it more difficult for the user to uninstall the application. Hiding the application's icon programmatically does not require any special permissions." ;
    skos:exactMatch d3f:T1628.001,
        mitre-attack:T1628.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1628002 a owl:Class ;
    rdfs:label "T1628_002" ;
    d3f:attack-id "T1628.002" ;
    dcterms:title "User Evasion" ;
    rdfs:subClassOf d3f:T1628 ;
    skos:altLabel "T1628.002" ;
    skos:definition "Adversaries may attempt to avoid detection by hiding malicious behavior from the user. By doing this, an adversary’s modifications would most likely remain installed on the device for longer, allowing the adversary to continue to operate on that device." ;
    skos:exactMatch d3f:T1628.002,
        mitre-attack:T1628.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1628003 a owl:Class ;
    rdfs:label "T1628_003" ;
    d3f:attack-id "T1628.003" ;
    dcterms:title "Conceal Multimedia Files" ;
    rdfs:subClassOf d3f:T1628 ;
    skos:altLabel "T1628.003" ;
    skos:definition "Adversaries may attempt to hide multimedia files from the user. By doing so, adversaries may conceal captured files, such as pictures, videos and/or screenshots, then later exfiltrate those files." ;
    skos:exactMatch d3f:T1628.003,
        mitre-attack:T1628.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1629001 a owl:Class ;
    rdfs:label "T1629_001" ;
    d3f:attack-id "T1629.001" ;
    dcterms:title "Prevent Application Removal" ;
    rdfs:subClassOf d3f:T1629 ;
    skos:altLabel "T1629.001" ;
    skos:definition "Adversaries may abuse the Android device administration API to prevent the user from uninstalling a target application. In earlier versions of Android, device administrator applications needed their administration capabilities explicitly deactivated by the user before the application could be uninstalled. This was later updated so the user could deactivate and uninstall the administrator application in one step." ;
    skos:exactMatch d3f:T1629.001,
        mitre-attack:T1629.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1629002 a owl:Class ;
    rdfs:label "T1629_002" ;
    d3f:attack-id "T1629.002" ;
    dcterms:title "Device Lockout" ;
    rdfs:subClassOf d3f:T1629 ;
    skos:altLabel "T1629.002" ;
    skos:definition "An adversary may seek to inhibit user interaction by locking the legitimate user out of the device. This is typically accomplished by requesting device administrator permissions and then locking the screen using `DevicePolicyManager.lockNow()`. Other novel techniques for locking the user out of the device have been observed, such as showing a persistent overlay, using carefully crafted “call” notification screens, and locking HTML pages in the foreground. These techniques can be very difficult to get around, and typically require booting the device into safe mode to uninstall the malware.(Citation: Microsoft MalLockerB)(Citation: Talos GPlayed)(Citation: securelist rotexy 2018)" ;
    skos:exactMatch d3f:T1629.002,
        mitre-attack:T1629.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1629003 a owl:Class ;
    rdfs:label "T1629_003" ;
    d3f:attack-id "T1629.003" ;
    dcterms:title "Disable or Modify Tools" ;
    rdfs:subClassOf d3f:T1629 ;
    skos:altLabel "T1629.003" ;
    skos:definition "Adversaries may disable security tools to avoid potential detection of their tools and activities. This can take the form of disabling security software, modifying SELinux configuration, or other methods to interfere with security tools scanning or reporting information. This is typically done by abusing device administrator permissions or using system exploits to gain root access to the device to modify protected system files." ;
    skos:exactMatch d3f:T1629.003,
        mitre-attack:T1629.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1630001 a owl:Class ;
    rdfs:label "T1630_001" ;
    d3f:attack-id "T1630.001" ;
    dcterms:title "Uninstall Malicious Application" ;
    rdfs:subClassOf d3f:T1630 ;
    skos:altLabel "T1630.001" ;
    skos:definition "Adversaries may include functionality in malware that uninstalls the malicious application from the device. This can be achieved by:" ;
    skos:exactMatch d3f:T1630.001,
        mitre-attack:T1630.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1630002 a owl:Class ;
    rdfs:label "T1630_002" ;
    d3f:attack-id "T1630.002" ;
    dcterms:title "File Deletion" ;
    rdfs:subClassOf d3f:T1630 ;
    skos:altLabel "T1630.002" ;
    skos:definition "Adversaries may wipe a device or delete individual files in order to manipulate external outcomes or hide activity. An application must have administrator access to fully wipe the device, while individual files may not require special permissions to delete depending on their storage location.(Citation: Android DevicePolicyManager 2019)" ;
    skos:exactMatch d3f:T1630.002,
        mitre-attack:T1630.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1630003 a owl:Class ;
    rdfs:label "T1630_003" ;
    d3f:attack-id "T1630.003" ;
    dcterms:title "Disguise Root/Jailbreak Indicators" ;
    rdfs:subClassOf d3f:T1630 ;
    skos:altLabel "T1630.003" ;
    skos:definition "An adversary could use knowledge of the techniques used by security software to evade detection.(Citation: Brodie)(Citation: Tan) For example, some mobile security products perform compromised device detection by searching for particular artifacts such as an installed \"su\" binary, but that check could be evaded by naming the binary something else. Similarly, polymorphic code techniques could be used to evade signature-based detection.(Citation: Rastogi)" ;
    skos:exactMatch d3f:T1630.003,
        mitre-attack:T1630.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1631001 a owl:Class ;
    rdfs:label "T1631_001" ;
    d3f:attack-id "T1631.001" ;
    dcterms:title "Ptrace System Calls" ;
    rdfs:subClassOf d3f:T1631 ;
    skos:altLabel "T1631.001" ;
    skos:definition "Adversaries may inject malicious code into processes via ptrace (process trace) system calls in order to evade process-based defenses as well as possibly elevate privileges. Ptrace system call injection is a method of executing arbitrary code in the address space of a separate live process." ;
    skos:exactMatch d3f:T1631.001,
        mitre-attack:T1631.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1632001 a owl:Class ;
    rdfs:label "T1632_001" ;
    d3f:attack-id "T1632.001" ;
    dcterms:title "Code Signing Policy Modification" ;
    rdfs:subClassOf d3f:T1632 ;
    skos:altLabel "T1632.001" ;
    skos:definition "Adversaries may modify code signing policies to enable execution of applications signed with unofficial or unknown keys. Code signing provides a level of authenticity on an app from a developer, guaranteeing that the program has not been tampered with and comes from an official source. Security controls can include enforcement mechanisms to ensure that only valid, signed code can be run on a device." ;
    skos:exactMatch d3f:T1632.001,
        mitre-attack:T1632.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1633001 a owl:Class ;
    rdfs:label "T1633_001" ;
    d3f:attack-id "T1633.001" ;
    dcterms:title "System Checks" ;
    rdfs:subClassOf d3f:T1633 ;
    skos:altLabel "T1633.001" ;
    skos:definition "Adversaries may employ various system checks to detect and avoid virtualization and analysis environments. This may include changing behavior after checking for the presence of artifacts indicative of a virtual environment or sandbox. If the adversary detects a virtual environment, they may alter their malware’s behavior to disengage from the victim or conceal the core functions of the implant. They may also search for virtualization artifacts before dropping secondary or additional payloads." ;
    skos:exactMatch d3f:T1633.001,
        mitre-attack:T1633.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1634001 a owl:Class ;
    rdfs:label "T1634_001" ;
    d3f:attack-id "T1634.001" ;
    dcterms:title "Keychain" ;
    rdfs:subClassOf d3f:T1634 ;
    skos:altLabel "T1634.001" ;
    skos:definition "Adversaries may collect keychain data from an iOS device to acquire credentials. Keychains are the built-in way for iOS to keep track of users' passwords and credentials for many services and features such as Wi-Fi passwords, websites, secure notes, certificates, private keys, and VPN credentials." ;
    skos:exactMatch d3f:T1634.001,
        mitre-attack:T1634.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1635001 a owl:Class ;
    rdfs:label "T1635_001" ;
    d3f:attack-id "T1635.001" ;
    dcterms:title "URI Hijacking" ;
    rdfs:subClassOf d3f:T1635 ;
    skos:altLabel "T1635.001" ;
    skos:definition "Adversaries may register Uniform Resource Identifiers (URIs) to intercept sensitive data." ;
    skos:exactMatch d3f:T1635.001,
        mitre-attack:T1635.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1636001 a owl:Class ;
    rdfs:label "T1636_001" ;
    d3f:attack-id "T1636.001" ;
    dcterms:title "Calendar Entries" ;
    rdfs:subClassOf d3f:T1636 ;
    skos:altLabel "T1636.001" ;
    skos:definition "Adversaries may utilize standard operating system APIs to gather calendar entry data. On Android, this can be accomplished using the Calendar Content Provider. On iOS, this can be accomplished using the `EventKit` framework." ;
    skos:exactMatch d3f:T1636.001,
        mitre-attack:T1636.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1636002 a owl:Class ;
    rdfs:label "T1636_002" ;
    d3f:attack-id "T1636.002" ;
    dcterms:title "Call Log" ;
    rdfs:subClassOf d3f:T1636 ;
    skos:altLabel "T1636.002" ;
    skos:definition "Adversaries may utilize standard operating system APIs to gather call log data. On Android, this can be accomplished using the Call Log Content Provider. iOS provides no standard API to access the call log." ;
    skos:exactMatch d3f:T1636.002,
        mitre-attack:T1636.002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1636003 a owl:Class ;
    rdfs:label "T1636_003" ;
    d3f:attack-id "T1636.003" ;
    dcterms:title "Contact List" ;
    rdfs:subClassOf d3f:T1636 ;
    skos:altLabel "T1636.003" ;
    skos:definition "Adversaries may utilize standard operating system APIs to gather contact list data. On Android, this can be accomplished using the Contacts Content Provider. On iOS, this can be accomplished using the `Contacts` framework." ;
    skos:exactMatch d3f:T1636.003,
        mitre-attack:T1636.003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1636004 a owl:Class ;
    rdfs:label "T1636_004" ;
    d3f:attack-id "T1636.004" ;
    dcterms:title "SMS Messages" ;
    rdfs:subClassOf d3f:T1636 ;
    skos:altLabel "T1636.004" ;
    skos:definition "Adversaries may utilize standard operating system APIs to gather SMS messages. On Android, this can be accomplished using the SMS Content Provider. iOS provides no standard API to access SMS messages." ;
    skos:exactMatch d3f:T1636.004,
        mitre-attack:T1636.004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1636005 a owl:Class ;
    rdfs:label "T1636_005" ;
    d3f:attack-id "T1636.005" ;
    dcterms:title "Accounts" ;
    rdfs:subClassOf d3f:T1636 ;
    skos:altLabel "T1636.005" ;
    skos:definition "Adversaries may utilize standard operating system APIs to gather account data. On Android, this can be accomplished by using the AccountManager API. For example, adversaries may use the `getAccounts()` method to list all accounts.(Citation: Android_AccountManager_Feb2025) On iOS, this can be accomplished by using the Keychain services." ;
    skos:exactMatch d3f:T1636.005,
        mitre-attack:T1636.005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1637001 a owl:Class ;
    rdfs:label "T1637_001" ;
    d3f:attack-id "T1637.001" ;
    dcterms:title "Domain Generation Algorithms" ;
    rdfs:subClassOf d3f:T1637 ;
    skos:altLabel "T1637.001" ;
    skos:definition "Adversaries may use [Domain Generation Algorithms](https://attack.mitre.org/techniques/T1637/001) (DGAs) to procedurally generate domain names for uses such as command and control communication   or malicious application distribution.(Citation: securelist rotexy 2018)" ;
    skos:exactMatch d3f:T1637.001,
        mitre-attack:T1637.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1639001 a owl:Class ;
    rdfs:label "T1639_001" ;
    d3f:attack-id "T1639.001" ;
    dcterms:title "Exfiltration Over Unencrypted Non-C2 Protocol" ;
    rdfs:subClassOf d3f:T1639 ;
    skos:altLabel "T1639.001" ;
    skos:definition "Adversaries may steal data by exfiltrating it over an un-encrypted network protocol other than that of the existing command and control channel. The data may also be sent to an alternate network location from the main command and control server." ;
    skos:exactMatch d3f:T1639.001,
        mitre-attack:T1639.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1641001 a owl:Class ;
    rdfs:label "T1641_001" ;
    d3f:attack-id "T1641.001" ;
    dcterms:title "Transmitted Data Manipulation" ;
    rdfs:subClassOf d3f:T1641 ;
    skos:altLabel "T1641.001" ;
    skos:definition "Adversaries may alter data en route to storage or other systems in order to manipulate external outcomes or hide activity. By manipulating transmitted data, adversaries may attempt to affect a business process, organizational understanding, or decision making." ;
    skos:exactMatch d3f:T1641.001,
        mitre-attack:T1641.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1655001 a owl:Class ;
    rdfs:label "T1655_001" ;
    d3f:attack-id "T1655.001" ;
    dcterms:title "Match Legitimate Name or Location" ;
    rdfs:subClassOf d3f:T1655 ;
    skos:altLabel "T1655.001" ;
    skos:definition "Adversaries may match or approximate the name or location of legitimate files or resources when naming/placing them. This is done for the sake of evading defenses and observation. This may be done by giving artifacts the name and icon of a legitimate, trusted application (i.e., Settings), or using a package name that matches legitimate, trusted applications (i.e., `com.google.android.gm`)." ;
    skos:exactMatch d3f:T1655.001,
        mitre-attack:T1655.001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TSNEClustering a owl:Class ;
    rdfs:label "t_SNEClustering" ;
    d3f:d3fend-id "D3A-TSC" ;
    d3f:kb-article "## References Wikipedia. (n.d.). T-distributed stochastic neighbor embedding. [Link](https://en.wikipedia.org/wiki/T-distributed_stochastic_neighbor_embedding)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "t-SNE Clustering" ;
    rdfs:subClassOf d3f:ProjectionBasedClustering ;
    skos:altLabel "t-SNEClustering" ;
    skos:definition "T-distributed Stochastic Neighbor Embedding (t-SNE) is a statistical method for visualizing high-dimensional data by giving each datapoint a location in a two or three-dimensional map." ;
    skos:exactMatch d3f:t-SNEClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TokenBasedAuthentication a owl:Class ;
    rdfs:label "Token_basedAuthentication" ;
    d3f:d3fend-id "D3-TBA" ;
    d3f:kb-article "## How it works Token-based authentication starts with a user logging into a system, device or application, typically using a password or a security question. An authorization server validates that initial authentication and then issues an access token, which is a small piece of data that lets a cl" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Token-based Authentication" ;
    rdfs:seeAlso <https://www.entrust.com/resources/learn/what-is-token-based-authentication> ;
    rdfs:subClassOf d3f:AgentAuthentication ;
    skos:altLabel "Token-basedAuthentication" ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "Token-based authentication is an authentication protocol where users verify their identity in exchange for a unique access token. Users can then access the website, application, or resource for the life of the token without having to re-enter their credentials." ;
    skos:exactMatch d3f:Token-basedAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1528,
        mitre-attack:T1550.001,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:TransformerXL a owl:Class ;
    rdfs:label "Transformer_XL" ;
    d3f:d3fend-id "D3A-TX" ;
    d3f:kb-article "## References Transformer-XL. (n.d.). Papers with Code. [Link](https://paperswithcode.com/method/transformer-xl)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:TransformerBasedLearning ;
    skos:altLabel "Transformer-XL" ;
    skos:definition "Transformer-XL is a transformer architecture that introduces the notion of recurrence to the deep self-attention network. Instead of computing the hidden states from scratch for each new segment, Transformer-XL reuses the hidden states obtained in previous segments." ;
    skos:exactMatch d3f:Transformer-XL ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:abuses a owl:DatatypeProperty ;
    rdfs:label "abuses" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01163606-v> ;
    rdfs:subPropertyOf d3f:uses ;
    skos:altLabel "misapplies",
        "misuses" ;
    skos:definition "x abuses y: The entity x applies an artifact y to a wrong thing or person; x applies y badly or incorrectly." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:access_mediated_by a owl:DatatypeProperty ;
    rdfs:label "access-mediated-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x access-mediated-by y: The entity or resource x has its access regulated, controlled, or facilitated by entity y, which acts as an intermediary or gatekeeper to enforce access control policies." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:accessed_by a owl:DatatypeProperty ;
    rdfs:label "accessed-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x accessed-by y: The entity or resource x is accessed by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:addressed_by a owl:DatatypeProperty ;
    rdfs:label "addressed-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x addressed-by y: Relates a resource x (e.g., network host, peripheral device, disk sector, a memory cell or other logical or physical entity) to a discrete address y in an address space that points to it." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:addresses a owl:DatatypeProperty ;
    rdfs:label "addresses" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:altLabel "points-to" ;
    skos:definition "x addresses y: Relates a pointer x to a digital artifact y located in the address space to which x points. The address space is part of some digital store, whether it be in memory, an image, or a persistent storage device." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:adds a owl:DatatypeProperty ;
    rdfs:label "adds" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x adds y: The subject x adds a data object y, such as a file, to some other digital artifact, such as a directory. Examples include an agent or technique adding a record to a database. or a domain entry to a DNS server." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:archived_at a owl:DatatypeProperty ;
    rdfs:label "archived-at" ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:attached_to a owl:DatatypeProperty ;
    rdfs:label "attached-to" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01980375-s> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x attached-to y: A subject x is joined in close association to an object y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:attack_id a owl:DatatypeProperty ;
    rdfs:label "attack-id" ;
    rdfs:range xsd:string ;
    skos:definition "x attack-id y: The offensive technique x has the att&ck unique id of y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:attack_kb_annotation a owl:DatatypeProperty ;
    rdfs:label "attack-kb-annotation" ;
    rdfs:range xsd:string ;
    skos:definition "x attack-kb-annotation y: The offensive technique x has the kb annotation of y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:attack_kb_data_property a owl:DatatypeProperty ;
    rdfs:label "attack-kb-data-property" ;
    rdfs:range xsd:string ;
    skos:altLabel "attack-kb-property" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:authenticates a owl:DatatypeProperty ;
    rdfs:label "authenticates" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01980375-s> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x authenticates y: The subject x establishes the authenticity of some y. This relation indicates an authentication event has occurred." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:authorizes a owl:DatatypeProperty ;
    rdfs:label "authorizes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00804987-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x authorizes y: A subject x grants authorization or clearance for an agent y to use an object.  This relation indicates an authorization event has occurred." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:available a owl:DatatypeProperty ;
    rdfs:label "available" ;
    dcterms:title "date available" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:date_value ;
    skos:definition "Date that the resource became or will become available." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:blocks a owl:DatatypeProperty ;
    rdfs:label "blocks" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01480024-v> ;
    rdfs:subPropertyOf d3f:counters ;
    skos:definition "x blocks y: The entity x blocks off the use of digital artifact y by reference to a block or allow list (or both.)" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:broader a owl:DatatypeProperty ;
    rdfs:label "broader" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:semantic_relation ;
    skos:definition "x broader y: The entity x represents a more general or inclusive concept than entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:broader_transitive a owl:DatatypeProperty ;
    rdfs:label "broader-transitive" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:semantic_relation ;
    skos:definition "x broader-transitive y: The entity x represents a more general concept than entity y, including indirect or hierarchical relationships where x encompasses y through intermediate entities." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:capec_id a owl:DatatypeProperty ;
    rdfs:label "capec-id" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_data_property ;
    skos:definition "Unique identifier for a CAPEC technique, i.e. a common attack pattern identified by the pattern CAPEC-[number]." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:carried_by a owl:DatatypeProperty ;
    rdfs:label "carried-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x carried-by y: The information entity x is dependent upon the entity y for its storage, transport, or communication. Entity y serves as the necessary bearer or link from which x can be recovered or interpreted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:carries a owl:DatatypeProperty ;
    rdfs:label "carries" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x carries y: The entity x serves as the bearer or link for information y, enabling y to be stored, transported, or communicated such that y can be recovered or interpreted from x" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:caused_by a owl:DatatypeProperty ;
    rdfs:label "caused-by" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.commoncoreontologies.org/ont00001819> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x caused-by y: The event or action x occurs as a consequence of event or action y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:causes a owl:DatatypeProperty ;
    rdfs:label "causes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.commoncoreontologies.org/ont00001803> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x causes y: The event or action x brings about event or action y as a consequence." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:comment a owl:DatatypeProperty ;
    rdfs:label "comment" ;
    rdfs:range xsd:string ;
    skos:definition "x comment y: The d3fend object x a d3fend team specific comment y. Not for use external to the MITRE development team." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:comments a owl:DatatypeProperty ;
    rdfs:label "comments" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:definition "x comments y: x claim has provider comments y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:communicates_with a owl:DatatypeProperty ;
    rdfs:label "communicates-with" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x communicates-with y: x and y exchange signals or data bidirectionally, enabling mutual awareness, coordination, or interaction." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( d3f:ConfidenceEnum xsd:string ) ] ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:configures a owl:DatatypeProperty ;
    rdfs:label "configures" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x configures y: The entity x sets the operational parameters of entity y, determining how y will operate." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:connected_to a owl:DatatypeProperty ;
    rdfs:label "connected-to" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x connected-to y: The subject x shares a direct physical or logical link with object y such that communication is possible between them without intermediate routing." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:connects a owl:DatatypeProperty ;
    rdfs:label "connects" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01071413-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x connects y: The subject x joins system y by means of communication equipment (to some other system, typically the adversary-targeted host)." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:contained_by a owl:DatatypeProperty ;
    rdfs:label "contained-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x contained-by y: The entity x exists within or is physically or logically enclosed by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:contains a owl:DatatypeProperty ;
    rdfs:label "contains" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02639021-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x contains y: A core relation that holds between a whole x and its part y.  Equivalent to relational concept 'has part' and thus transitive." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:contributor a owl:DatatypeProperty ;
    rdfs:label "contributor" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:control_name a owl:DatatypeProperty ;
    rdfs:label "control-name" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_external_control_data_property ;
    skos:definition "The control (or control enhancement) name." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:controlled_by a owl:DatatypeProperty ;
    rdfs:label "controlled-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x controlled-by y: x's operation or behavior is directed or regulated by y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:controls a owl:DatatypeProperty ;
    rdfs:label "controls" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x controls y: x directs or regulates y's operational state, behavior, or function." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:copies a owl:DatatypeProperty ;
    rdfs:label "copies" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01738810-v> ;
    rdfs:subPropertyOf d3f:creates ;
    skos:definition "x copies y: An technique or agent x reproduces or makes and exact copy of some digital artifact y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:copy_of a owl:DatatypeProperty ;
    rdfs:label "copy-of" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x copy-of y: The subject x is a duplicate of the object y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:corrupts a owl:DatatypeProperty ;
    rdfs:label "corrupts" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:impairs ;
    skos:definition "x corrupts y: The entity x causes y to enter an incorrect, inconsistent, or unintended state by modifying y's information-bearing content (e.g., a bit, symbol, word, configuration cell, or stored parameter) such that y's value no longer matches the expected or previously valid value." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:created a owl:DatatypeProperty ;
    rdfs:label "created" ;
    dcterms:title "date created" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:date_value ;
    skos:definition "Date of creation of the resource." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:created_by a owl:DatatypeProperty ;
    rdfs:label "created-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x created-by y: The entity x is brought into existence, developed, or generated by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:cwe_id a owl:DatatypeProperty ;
    rdfs:label "cwe-id" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:cwe_kb_annotation a owl:DatatypeProperty ;
    rdfs:label "cwe-kb-annotation" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_annotation a owl:DatatypeProperty ;
    rdfs:label "d3fend-annotation" ;
    rdfs:range xsd:string ;
    skos:definition "x d3fend-annotation y: The d3fend object x has the annotation y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_catalog_annotation_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-catalog-annotation-property" ;
    rdfs:range xsd:string ;
    skos:altLabel "d3fend-vendor-registry-annotation-property" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_comment a owl:DatatypeProperty ;
    rdfs:label "d3fend-comment" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_data_property ;
    skos:definition "x d3fend-comment y: The entity x has an D3FEND team written a public note about entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_display_annotation a owl:DatatypeProperty ;
    rdfs:label "d3fend-display-annotation" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_display_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-display-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:definition "x d3fend-display-property y: An object x should be displayed using the display property y, when it applies." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_id a owl:DatatypeProperty ;
    rdfs:label "d3fend-id" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_data_property ;
    skos:definition "Unique identifier for a D3FEND technique. D3-[Acronym]." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_kb_annotation_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-kb-annotation-property" ;
    rdfs:range xsd:string ;
    skos:definition "x d3fend-kb-annotation-property y: The entity x had the d3fend kb annotation y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_kb_reference_annotation a owl:DatatypeProperty ;
    rdfs:label "d3fend-kb-reference-annotation" ;
    rdfs:range xsd:string ;
    skos:definition "x d3fend-kb-data-property y: The reference x has the data property y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_private_annotation a owl:DatatypeProperty ;
    rdfs:label "d3fend-private-annotation" ;
    rdfs:range xsd:string ;
    skos:definition "x d3fend-private-annotation: The d3fend object x has the internal comment or tracking property y.  Not for use external to the MITRE development team." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:deceives a owl:DatatypeProperty ;
    rdfs:label "deceives" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:counters ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:deceives_with a owl:DatatypeProperty ;
    rdfs:label "deceives-with" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_tactical_verb_property ;
    skos:definition "x deceives-with y: The entity x misleads or manipulates another entity using y as a tool, method, or mechanism to create false perceptions or understanding." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:decodes a owl:DatatypeProperty ;
    rdfs:label "decodes" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x decodes y: Entity x transforms data y to a different form, usually through decompression." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:definition a owl:DatatypeProperty ;
    rdfs:label "definition" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso IAO:0000115 ;
    skos:definition "x definition y: The d3fend object x has the definition y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:deletes a owl:DatatypeProperty ;
    rdfs:label "deletes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01001860-v> ;
    rdfs:subPropertyOf d3f:evicts ;
    skos:definition "x deletes y: A technique or agent x wipes out the digitally or magnetically recorded information of digital object y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:dependent a owl:DatatypeProperty ;
    rdfs:label "dependent" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00729216-a> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x dependent y: A dependent y is an entity that requires the fulfillment of the requirements specified in dependency x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:derived_from a owl:DatatypeProperty ;
    rdfs:label "derived-from" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:depends_on ;
    skos:definition "x derived-from y: The entity x is derived from or based on the value of y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/06737512-n> ;
    skos:definition "A statement that represents something in words." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:detects a owl:DatatypeProperty ;
    rdfs:label "detects" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:counters ;
    skos:definition "x detects y: The entity x discovers the presence, occurrence, or state of entity y through observation or measurement." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:disables a owl:DatatypeProperty ;
    rdfs:label "disables" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00513267-v> ;
    rdfs:subPropertyOf d3f:evicts ;
    skos:definition "x disables y: The technique or agent x makes an entity y unable to perform its actions or capabilities." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:display_baseurl a owl:DatatypeProperty ;
    rdfs:label "display-baseurl" ;
    rdfs:range xsd:anyURI ;
    skos:definition "A base string to use as prefix to create a full URL for an entity. The baseurl must end in a forward slash: /" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:display_order a owl:DatatypeProperty ;
    rdfs:label "display-order" ;
    rdfs:range xsd:integer ;
    skos:definition "x display-order y: An object x should be displayed in ordinal position y when placed or listed in a d3fend display with other objects of its kind." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:display_priority a owl:DatatypeProperty ;
    rdfs:label "display-priority" ;
    rdfs:range xsd:integer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:draft a owl:DatatypeProperty ;
    rdfs:label "draft" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:drives a owl:DatatypeProperty ;
    rdfs:label "drives" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01184038-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x drives y: The device driver x causes a system component y to function by controlling it." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:employed_by a owl:DatatypeProperty ;
    rdfs:label "employed-by" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01161188-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x employed-by y: An entity x is put into service by a technique or agent y. Inverse of y employs x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:employs a owl:DatatypeProperty ;
    rdfs:label "employs" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x employs y: The entity x makes purposeful use of entity y to perform a function." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:enabled_by a owl:DatatypeProperty ;
    rdfs:label "enabled-by" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00513958-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x enabled-by y: A top level technique y enables a tactic x, that is, the property indicates that a technique y is used to put a particular tactic x into action. In other words, y renders x capable or able for some task.  Inverse of enables." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:enables a owl:DatatypeProperty ;
    rdfs:label "enables" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00513958-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x enables y: A top level technique x enables a tactic y, that is, the property indicates that a technique x is used to put a particular tactic y into action. In other words, x renders y capable or able for some task." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:encodes a owl:DatatypeProperty ;
    rdfs:label "encodes" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x encodes y: Entity x transforms data y to a different form, usually through compression." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:encrypts a owl:DatatypeProperty ;
    rdfs:label "encrypts" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00996121-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x encrypts y: The entity x converts the ordinary representation of a digital artifact y into a secret code." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:end a owl:DatatypeProperty ;
    rdfs:label "end" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_process_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:enforces a owl:DatatypeProperty ;
    rdfs:label "enforces" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x enforces y: Technique x forces entity y to be compliant with a law, rule, or obligation." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:enumerates a owl:DatatypeProperty ;
    rdfs:label "enumerates" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:reads ;
    skos:definition "x enumerates y: The subject x takes the action of reading from a digital source y to acquire data and create a list of its contents." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:erases a owl:DatatypeProperty ;
    rdfs:label "erases" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x erases y: A technique x removes recorded data from storage device y creating space for new data." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:evaluated_by a owl:DatatypeProperty ;
    rdfs:label "evaluated-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x evaluated-by y: The entity x is assessed and analyzed by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:evaluates a owl:DatatypeProperty ;
    rdfs:label "evaluates" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x evaluates y: The entity x systematically assesses entity y to judge its state, quality, or risk." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:exactly a owl:DatatypeProperty ;
    rdfs:label "exactly" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:semantic_relation ;
    skos:definition "x exactly y: The entity x is identical to or fully corresponds to entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:excises a owl:DatatypeProperty ;
    rdfs:label "excises" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x excises y: Technique x removes a section of entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:executed_by a owl:DatatypeProperty ;
    rdfs:label "executed-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x executed-by y: The entity or function x is carried out, performed, or run by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:expectation_rating a owl:DatatypeProperty ;
    rdfs:label "expectation-rating" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( d3f:ExpectationRatingEnum xsd:string ) ] ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:extends a owl:DatatypeProperty ;
    rdfs:label "extends" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00541315-v> ;
    rdfs:subPropertyOf d3f:modifies ;
    skos:definition "x extends y: The entity x extend the scope or range or area of entity y, especially in the sense of widen the range of applications." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:filters a owl:DatatypeProperty ;
    rdfs:label "filters" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01461293-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x filters y: An technique or agent x removes some specified set of of entities from the content of a digital artifact y, by passing an artifact's content through a filter.  A filter is a device that removes something from whatever passes through it." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:forges a owl:DatatypeProperty ;
    rdfs:label "forges" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:creates ;
    skos:definition "x forges y: An technique or agent x counterfeits a digital artifact y, such as a fake credential, with the intent to deceive." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:fork a owl:DatatypeProperty ;
    rdfs:label "fork" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_process_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_account a owl:DatatypeProperty ;
    rdfs:label "has-account" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:owns ;
    skos:definition "x has-account y: The subject x has ownership or possession of some account y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_agent a owl:DatatypeProperty ;
    rdfs:label "has-agent" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:has_participant ;
    skos:definition "x has-agent y: The event x occurs because agent y actively carries it out." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_audience a owl:DatatypeProperty ;
    rdfs:label "has-audience" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_use_case_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_contribution a owl:DatatypeProperty ;
    rdfs:label "has-contribution" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_contributor a owl:DatatypeProperty ;
    rdfs:label "has-contributor" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_goal a owl:DatatypeProperty ;
    rdfs:label "has-goal" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_use_case_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_link a owl:DatatypeProperty ;
    rdfs:label "has-link" ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf d3f:d3fend_kb_data_property ;
    skos:definition "x has-link y: The d3fend analysis x has the link y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_location a owl:DatatypeProperty ;
    rdfs:label "has-location" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02133811-s> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:altLabel "located_in" ;
    skos:definition "x has-location y: The entity x is situated in a particular spot or position y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_mediator a owl:DatatypeProperty ;
    rdfs:label "has-mediator" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:has_participant ;
    skos:definition "x has-mediator y: The entity x relies on or is facilitated by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_member a owl:DatatypeProperty ;
    rdfs:label "has-member" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_operating_mode a owl:DatatypeProperty ;
    rdfs:label "has-operating-mode" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x has-operating-mode y: The entity x is currently operating in or has the potential to be in operating mode y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_prerequisite a owl:DatatypeProperty ;
    rdfs:label "has-prerequisite" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_use_case_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_procedure a owl:DatatypeProperty ;
    rdfs:label "has-procedure" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_general_object_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_recipient a owl:DatatypeProperty ;
    rdfs:label "has-recipient" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.ontologyrepository.com/CommonCoreOntologies/has_recipient> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x has_recipient y: An agent y is the intended recipient and decoder of the information contained in communication x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_sender a owl:DatatypeProperty ;
    rdfs:label "has-sender" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.ontologyrepository.com/CommonCoreOntologies/has_sender> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x has_sender y: An agent y is the sender and encoder of the information contained in communication x." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_weakness a owl:DatatypeProperty ;
    rdfs:label "has-weakness" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_have_weakness ;
    skos:definition "x has-weakness y: The entity x exhibits a condition y that could, in some circumstances, lead to a vulnerability." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:hides a owl:ObjectProperty ;
    rdfs:label "hides" ;
    rdfs:range d3f:DigitalArtifact ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x hides y: A technique or operation x conceals the digital artifact y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:identified_by a owl:DatatypeProperty ;
    rdfs:label "identified-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x identified-by y: The entity x is recognized or described by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_catalog_data_property ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:identifies a owl:DatatypeProperty ;
    rdfs:label "identifies" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x identifies y: The entity x recognizes or brings attention to entity y, making it distinct or clear through naming, description, or discovery." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:implemented_by a owl:DatatypeProperty ;
    rdfs:label "implemented-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x implemented-by y: The entity x is realized or brought into operation by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:implements a owl:DatatypeProperty ;
    rdfs:label "implements" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x implements y: The entity x realize entity y by putting its design or specification into effect." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:initiates a owl:DatatypeProperty ;
    rdfs:label "initiates" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x initiates y: The entity or action x starts or triggers entity or function y, bringing it into action." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:injects a owl:DatatypeProperty ;
    rdfs:label "injects" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:executes ;
    skos:definition "x injects y: The subject x takes the action of exploiting a security flaw by introducing (injecting) y, which is code or data that will change the course of execution or state of a computing process to an alternate course or state. Typically code injection is associated with adversaries intending the alternate course to facilitate a malevolent purpose; however, code injection can be unintentional or the intentions behind it may be good or benign." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:installs a owl:DatatypeProperty ;
    rdfs:label "installs" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01572394-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x installs y: An entity x sets up a digital artifact y for subsequent use.  For example, an installation program can install application software." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:instructed_by a owl:DatatypeProperty ;
    rdfs:label "instructed-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x instructed-by y: A subject x takes machine instructions from object y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:instructs a owl:DatatypeProperty ;
    rdfs:label "instructs" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x instructs y: A subject x delivers machine instructions to object y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:interprets a owl:DatatypeProperty ;
    rdfs:label "interprets" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:executes ;
    skos:definition "x interprets y: The subject x interprets the executable script y. The sense of interprets is here 'Parse the source code and perform its behavior directly.'" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:inventoried_by a owl:DatatypeProperty ;
    rdfs:label "inventoried-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x inventoried-by y: The entity x is cataloged, recorded, or tracked by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:inventories a owl:DatatypeProperty ;
    rdfs:label "inventories" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x inventories y: The entity x systematically discovers entity y and records its presence and key details for tracking." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:invoked_by a owl:DatatypeProperty ;
    rdfs:label "invoked-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x invoked-by y: The entity x is called, triggered, or activated by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:invokes a owl:DatatypeProperty ;
    rdfs:label "invokes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/06599393-n> ;
    rdfs:subPropertyOf d3f:executes ;
    skos:altLabel "calls" ;
    skos:definition "x invokes y: The subject x invokes a system service y by use of an instruction object y that interrupts the program being executed and passes control to the operating system to perform that operation." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:isolates a owl:DatatypeProperty ;
    rdfs:label "isolates" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00496744-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x isolates y: The technique or agent x sets digital artifact y apart from other digital artifacts, sequestering y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:issued a owl:DatatypeProperty ;
    rdfs:label "issued" ;
    dcterms:title "date issued" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:date_value ;
    skos:definition "Date of formal issuance of the resource." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:jams a owl:DatatypeProperty ;
    rdfs:label "jams" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:impairs ;
    skos:definition "x jams y: The entity x deliberately introduces interfering energy that degrades, disrupts, blocks, or masks the information-bearing capability of the target y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_abstract a owl:DatatypeProperty ;
    rdfs:label "kb-abstract" ;
    rdfs:range xsd:string ;
    skos:definition "x kb-abstract y: The reference x has the abstract y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_article a owl:DatatypeProperty ;
    rdfs:label "kb-article" ;
    rdfs:range xsd:string ;
    skos:definition "The technique x has the kb-article y, where y is written in Markdown." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_author a owl:DatatypeProperty ;
    rdfs:label "kb-author" ;
    rdfs:range xsd:string ;
    skos:definition "x kb-author y: The reference x has some author y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_mitre_analysis a owl:DatatypeProperty ;
    rdfs:label "kb-mitre-analysis" ;
    rdfs:range xsd:string ;
    skos:definition "x kb-mitre-analysis y: The reference x has the mitre d3fend analysis y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_organization a owl:DatatypeProperty ;
    rdfs:label "kb-organization" ;
    rdfs:range xsd:string ;
    skos:definition "x kb-organization y: The reference x was created or owned by the organization y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_reference a owl:DatatypeProperty ;
    rdfs:label "kb-reference" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_object_property ;
    skos:altLabel "has-technique-reference" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:kb_reference_of a owl:ObjectProperty ;
