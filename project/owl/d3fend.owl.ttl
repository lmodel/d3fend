    rdfs:subClassOf d3f:MessageAnalysis ;
    skos:broadMatch d3f:LateralMovementTechnique,
        d3f:T1114,
        d3f:T1566 ;
    skos:definition "Characterizing the reputation of mail transfer agents (MTA) to determine the security risk in emails." ;
    skos:exactMatch d3f:SenderMTAReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.001,
        mitre-attack:T1534,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002 .

d3f:SenderReputationAnalysis a owl:Class ;
    rdfs:label "SenderReputationAnalysis" ;
    d3f:d3fend-id "D3-SRA" ;
    d3f:kb-article "## How it works Sender trust rating can be considered an indicator of the level of security risk and/or a trust level associated with a sender. The features considered in determining the trust rating include: * Length of time sender has sent emails to the enterprise * Number of recipients in the e" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Sender Reputation Analysis" ;
    rdfs:subClassOf d3f:MessageAnalysis ;
    skos:broadMatch d3f:LateralMovementTechnique,
        d3f:T1114,
        d3f:T1566 ;
    skos:definition "Ascertaining sender reputation based on information associated with a message (e.g. email/instant messaging)." ;
    skos:exactMatch d3f:SenderReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.001,
        mitre-attack:T1534,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002 .

d3f:SeqGAN a owl:Class ;
    rdfs:label "SeqGAN" ;
    d3f:d3fend-id "D3A-SEQ" ;
    d3f:kb-article "## References Yu, L., Zhang, W., Wang, J., & Yu, Y. (2017). SeqGAN: Sequence Generative Adversarial Nets with Policy Gradient. ArXiv preprint ArXiv:1609.05473. [Link](https://arxiv.org/abs/1609.05473)" ;
