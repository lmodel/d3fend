    skos:definition "Enumeration of GetSystemConfigValue values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:RegOpenKeyA,
        d3f:RegOpenKeyExA,
