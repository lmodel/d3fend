d3f:Router a owl:Class ;
    rdfs:label "Router" ;
    rdfs:seeAlso dbr:Router_\(computing\) ;
    rdfs:subClassOf d3f:ComputerNetworkNode ;
    skos:definition "A router is a networking device that forwards data packets between computer networks. Routers perform the traffic directing functions on the Internet. Data sent through the internet, such as a web page or email, is in the form of data packets. A packet is typically forwarded from one router to another router through the networks that constitute an internetwork (e.g. the Internet) until it reaches its destination node." ;
    skos:exactMatch d3f:Router ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RubyScriptFile a owl:Class ;
    rdfs:label "RubyScriptFile" ;
    rdfs:subClassOf d3f:ExecutableScriptEnum,
        linkml:PermissibleValue ;
    skos:definition "Ruby Script File" .

d3f:SafeMode a owl:Class ;
    rdfs:label "SafeMode" ;
    dcterms:title "Safe Mode" ;
    rdfs:seeAlso dbr:Safe_mode ;
    rdfs:subClassOf d3f:OperatingMode ;
    skos:definition "An intentionally constrained operating mode of a system in which nonessential functions are disabled or limited and control is shifted to a minimal, well-tested configuration that prioritizes preventing harm (to the system, its environment, or data), maintaining basic stability and monitoring, and enabling diagnosis and recovery back to normal operation." ;
    skos:exactMatch d3f:SafeMode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Satellite a owl:Class ;
    rdfs:label "Satellite" ;
    rdfs:seeAlso dbr:Satellite ;
    rdfs:subClassOf d3f:Spacecraft ;
    skos:definition "A satellite or an artificial satellite is an object, typically a spacecraft, placed into orbit around a celestial body. They have a variety of uses, including communication relay, weather forecasting, navigation (GPS), broadcasting, scientific research, and Earth observation." ;
    skos:exactMatch d3f:Satellite ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ScheduledJob a owl:Class ;
    rdfs:label "ScheduledJob" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Scheduled Task" ;
    dcterms:title "Scheduled Job" ;
    rdfs:seeAlso dbr:Cron,
        dbr:Windows_Task_Scheduler,
        <https://linux.die.net/man/1/at>,
        <https://schema.ocsf.io/objects/job> ;
    rdfs:subClassOf d3f:OperatingSystemProcess ;
    skos:definition "A task scheduler process is an operating system process that executes scheduled tasks (time-scheduling in the sense of wall clock time; not operating system scheduling of processes for multitasking)." ;
    skos:exactMatch d3f:ScheduledJob ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceAccount a owl:Class ;
    rdfs:label "ServiceAccount" ;
    d3f:synonym "System Account" ;
    dcterms:title "Service Account" ;
    rdfs:subClassOf d3f:UserAccount ;
    skos:definition "A service account is a type of account used by an application or service to interact with the operating system." ;
    skos:exactMatch d3f:ServiceAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceProvider a owl:Class ;
    rdfs:label "ServiceProvider" ;
    dcterms:title "Service Provider" ;
    rdfs:subClassOf d3f:Provider ;
    skos:definition "A service provider offers delivery of intangible outputs such as expertise, support, or access to resources to individuals, organizations, or other entities." ;
    skos:exactMatch d3f:ServiceProvider ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SessionToken a owl:Class ;
    rdfs:label "SessionToken" ;
    d3f:kb-article "## How it works Session identifiers become necessary in cases where the communications infrastructure uses a stateless protocol such as HTTP. For example, a buyer who visits a seller's website wants to collect a number of articles in a virtual shopping cart and then finalize the shopping by going t" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Session ID" ;
    dcterms:title "Session Token" ;
    rdfs:seeAlso dbr:Session_ID ;
    rdfs:subClassOf d3f:AccessToken ;
    skos:definition "In computer science, a session identifier, session ID or session token is a piece of data that is used in network communications (often over HTTPS) to identify a session, a series of related message exchanges." ;
    skos:exactMatch d3f:SessionToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SharedLibraryFile a owl:Class ;
    rdfs:label "SharedLibraryFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Shared Library File" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Library_(computing)#Shared_libraries> ;
    rdfs:subClassOf d3f:ObjectFile ;
    skos:altLabel "Shared Library",
        "Shared Object" ;
    skos:definition "A shared library file is a file that is intended to be shared by executable files and further shared library (object) files. Modules used by a program are loaded from individual shared objects into memory at load time or runtime, rather than being copied by a linker when it creates a single monolithic executable file for the program" ;
    skos:exactMatch d3f:SharedLibraryFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ShortcutFile a owl:Class ;
    rdfs:label "ShortcutFile" ;
    dcterms:title "Shortcut File" ;
    rdfs:seeAlso dbr:Shortcut_\(computing\),
        <http://dbpedia.org/resource/Symbolic_link#Shortcuts> ;
    rdfs:subClassOf d3f:File ;
    skos:definition """A shortcut file, or shortcut, is a handle that allows the user to find a file or resource located in a different directory or folder from the place where the shortcut is located.

Shortcuts, which are supported by the graphical file browsers of some operating systems, may resemble symbolic links but differ in a number of important ways. One difference is what type of software is able to follow them:

 - Symbolic links are automatically resolved by the file system. Any software program, upon accessing a symbolic link, will see the target instead, whether the program is aware of symbolic links or not.

 - Shortcuts are treated like ordinary files by the file system and by software programs that are not aware of them. Only software programs that understand shortcuts (such as the Windows shell and file browsers) treat them as references to other files.

Another difference are the capabilities of the mechanism:

 - Microsoft Windows shortcuts normally refer to a destination by an absolute path (starting from the root directory), whereas POSIX symbolic links can refer to destinations via either an absolute or a relative path. The latter is useful if both the location and destination of the symbolic link share a common path prefix[clarification needed], but that prefix is not yet known when the symbolic link is created (e.g., in an archive file that can be unpacked anywhere).

- Microsoft Windows application shortcuts contain additional metadata that can be associated with the destination, whereas POSIX symbolic links are just strings that will be interpreted as absolute or relative pathnames.

- Unlike symbolic links, Windows shortcuts maintain their references to their targets even when the target is moved or renamed. Windows domain clients may subscribe to a Windows service called Distributed Link Tracking to track the changes in files and folders to which they are interested. The service maintains the integrity of shortcuts, even when files and folders are moved across the network.[14] Additionally, in Windows 9x and later, Windows shell tries to find the target of a broken shortcut before proposing to delete it.""" ;
    skos:exactMatch d3f:ShortcutFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SlowSymbolicLink a owl:Class ;
    rdfs:label "SlowSymbolicLink" ;
    dcterms:title "Slow Symbolic Link" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Symbolic_link#Storage_of_symbolic_links> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UnixLink ],
        d3f:SymbolicLink ;
    skos:altLabel "Slow Symlink" ;
    skos:definition "A slow symbolic link is any symbolic link on a Unix filesystem that is not a fast symbolic link; slow symlink is thus retroactively termed from fast symlink.  Slow symbolic links stored the symbolic link information as data in regular files." ;
    skos:exactMatch d3f:SlowSymbolicLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareClock a owl:Class ;
    rdfs:label "SoftwareClock" ;
    dcterms:title "Software Clock" ;
    rdfs:seeAlso <https://linux.die.net/sag/hw-sw-clocks.html> ;
    rdfs:subClassOf d3f:Clock ;
    skos:definition "A clock implemented in software which may synchronize with hardware clocks or external time sources." ;
    skos:exactMatch d3f:SoftwareClock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareLibrary a owl:Class ;
    rdfs:label "SoftwareLibrary" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Library" ;
    rdfs:seeAlso <https://dbpedia.org/page/Library_(computing)> ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "A software library is a collection of software components that are used to build a software product." ;
    skos:exactMatch d3f:SoftwareLibrary ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareTimer a owl:Class ;
    rdfs:label "SoftwareTimer" ;
    dcterms:title "Software Timer" ;
    rdfs:seeAlso <https://docs.aws.amazon.com/freertos/latest/userguide/software-timers.html> ;
    rdfs:subClassOf d3f:Timer ;
    skos:definition "A timer implemented in software, typically managed by the operating system or application code. Software timers rely on underlying hardware timers or clocks to measure intervals and trigger actions. They are used for scheduling tasks, implementing timeouts, and managing periodic operations within software environments." ;
    skos:exactMatch d3f:SoftwareTimer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareWatchdogTimer a owl:Class ;
    rdfs:label "SoftwareWatchdogTimer" ;
    dcterms:title "Software Watchdog Timer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SoftwareTimer ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:WatchdogTimer ],
        d3f:RuntimeVariable ;
    skos:definition "A software watchdog timer is a watchdog timer implemented in software." ;
    skos:exactMatch d3f:SoftwareWatchdogTimer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SourceCodeReferenceEnum a owl:Class ;
    rdfs:label "SourceCodeReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-Munin d3f:Reference-OSQueryWindowsUserCollectionCode ) ;
    skos:definition "Enumeration of SourceCodeReference values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:Reference-Munin,
        d3f:Reference-OSQueryWindowsUserCollectionCode .

d3f:Spacecraft a owl:Class ;
    rdfs:label "Spacecraft" ;
    rdfs:seeAlso dbr:Spacecraft ;
    rdfs:subClassOf d3f:Vehicle ;
    skos:definition "A spacecraft is a vehicle that is designed to fly and operate in outer space. Spacecraft are used for a variety of purposes, including communications, Earth observation, meteorology, navigation, space colonization, planetary exploration, and transportation of humans and cargo." ;
    skos:exactMatch d3f:Spacecraft ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StageEnum a owl:Class ;
    rdfs:label "StageEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    skos:definition "Stage value. Open enum: arbitrary string values also accepted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values <http://d3fend.mitre.org/ontologies/d3fend.owl#StageEnum#Unspecified> .

d3f:StaticAnalysisTool a owl:Class ;
    rdfs:label "StaticAnalysisTool" ;
    dcterms:title "Static Analysis Tool" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Category:Program_analysis>,
        dbr:Program_analysis,
        dbr:Static_program_analysis ;
    rdfs:subClassOf d3f:CodeAnalyzer ;
    skos:altLabel "Static Program Analysis Tool" ;
    skos:definition "A static [program] analysis tool performs an automated analysis of computer software without actually executing programs, in contrast with dynamic analysis, which is analysis performed on programs while they are executing. In most cases the analysis is performed on some version of the source code, and in the other cases, some form of the object code." ;
    skos:exactMatch d3f:StaticAnalysisTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Step a owl:Class ;
    rdfs:label "Step" ;
    rdfs:subClassOf d3f:Plan ;
    skos:exactMatch d3f:Step,
        oscal:Step ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StorageSnapshot a owl:Class ;
    rdfs:label "StorageSnapshot" ;
    dcterms:title "Storage Snapshot" ;
    rdfs:subClassOf d3f:ComputingSnapshot ;
    skos:definition "A storage snapshot is a copy of a storage medium or system environment at a point in time." ;
    skos:exactMatch d3f:StorageSnapshot ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StrongPasswordPolicy a owl:Class ;
    rdfs:label "StrongPasswordPolicy" ;
    d3f:d3fend-id "D3-SPP" ;
    d3f:kb-article "## How it works Password strength guidelines include increasing password length, permitting passwords that contain ASCII or Unicode characters, and requiring systems to screen new passwords against lists of commonly used or compromised passwords. ## Considerations Extremely complex password requirem" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Strong Password Policy" ;
    rdfs:subClassOf d3f:CredentialHardening ;
    skos:broadMatch d3f:T1110 ;
    skos:definition "Modifying system configuration to increase password strength." ;
    skos:exactMatch d3f:StrongPasswordPolicy ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003 .

d3f:System a owl:Class ;
    rdfs:label "System" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/04384144-n> ;
    rdfs:subClassOf d3f:Artifact ;
    skos:definition "An artifact (instrumentality) that combines interrelated interacting artifacts designed to work as a coherent entity.  [Note that not all digital artifacts are systems nor are all systems digital artifacts.]" ;
    skos:exactMatch d3f:System ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

