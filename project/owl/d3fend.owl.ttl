d3f:ApplicationRestartEvent a owl:Class ;
    rdfs:label "ApplicationRestartEvent" ;
    dcterms:title "Application Restart Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event where an application is sequentially stopped and started, typically to refresh its state, apply updates, or resolve issues while preserving its availability." ;
    skos:exactMatch d3f:ApplicationRestartEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationRule a owl:Class ;
    rdfs:label "ApplicationRule" ;
    dcterms:title "Application Rule" ;
    rdfs:subClassOf d3f:ApplicationConfiguration ;
    skos:definition "A configuration of an application which is used to apply logical or data processing functions to data processed by the application." ;
    skos:exactMatch d3f:ApplicationRule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationRuntimeVariable a owl:Class ;
    rdfs:label "ApplicationRuntimeVariable" ;
    dcterms:title "Application Runtime Variable" ;
    rdfs:subClassOf d3f:RuntimeVariable ;
    skos:definition "A system variable that tracks aspects of runtime of a system." ;
    skos:exactMatch d3f:ApplicationRuntimeVariable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationScanTime a owl:Class ;
    rdfs:label "ApplicationScanTime" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Scan Time" ;
    rdfs:subClassOf d3f:ApplicationRuntimeVariable ;
    skos:definition "A variable that tracks the measured time it takes to begin, run, and complete a select portion of an application's logic." ;
    skos:exactMatch d3f:ApplicationScanTime ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationStartEvent a owl:Class ;
    rdfs:label "ApplicationStartEvent" ;
    dcterms:title "Application Start Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event where an application transitions from an inactive state to an active state, initializing its resources and becoming operational for user interaction or automated processes." ;
    skos:exactMatch d3f:ApplicationStartEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationStopEvent a owl:Class ;
    rdfs:label "ApplicationStopEvent" ;
    dcterms:title "Application Stop Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event capturing the cessation of an application’s operations, transitioning it to an inactive state and releasing any allocated resources." ;
    skos:exactMatch d3f:ApplicationStopEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationUpdateEvent a owl:Class ;
    rdfs:label "ApplicationUpdateEvent" ;
    dcterms:title "Application Update Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event describing changes made to an application, such as updates, reconfigurations, or patch installations, while maintaining its presence on the system." ;
    skos:exactMatch d3f:ApplicationUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApproximateStringMatching a owl:Class ;
    rdfs:label "ApproximateStringMatching" ;
    d3f:d3fend-id "D3A-ASM" ;
    d3f:kb-article "## References 1. Navarro, G. (2001). A guided tour to approximate string matching. _ACM Computing Surveys_, 33(1), 31-88. [Link](https://doi.org/10.1145/375360.375365)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Approximate String Matching" ;
    rdfs:subClassOf d3f:PartialMatching ;
    skos:definition "Approximate string matching is a form of string matching that allows errrors." ;
    skos:exactMatch d3f:ApproximateStringMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AssetVulnerabilityEnumeration a owl:Class ;
    rdfs:label "AssetVulnerabilityEnumeration" ;
    d3f:d3fend-id "D3-AVE" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Asset Vulnerability Enumeration" ;
    rdfs:subClassOf d3f:AssetInventory ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1056,
        d3f:T1127,
        d3f:T1137,
        d3f:T1195,
        d3f:T1218,
        d3f:T1497,
        d3f:T1505,
        d3f:T1542,
        d3f:T1546,
        d3f:T1547,
        d3f:T1564,
        d3f:T1574 ;
    skos:definition "Asset vulnerability enumeration enriches inventory items with knowledge identifying their vulnerabilities." ;
    skos:exactMatch d3f:AssetVulnerabilityEnumeration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
