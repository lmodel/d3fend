    dcterms:title "Application Shim" ;
    rdfs:seeAlso d3f:Shim,
        <http://dbpedia.org/resource/Shim_(computing)#Examples> ;
    rdfs:subClassOf d3f:Shim ;
    skos:definition "An application shim adapts an application program to run on a version of a platform for which they were not originally created. Most commonly \"Application Shimming\" refers to use of The Windows Application Compatibility Toolkit (ACT) provides backward compatibility by simulating the behavior of older version of Windows." ;
    skos:exactMatch d3f:ApplicationShim ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AssetInventoryAgent a owl:Class ;
