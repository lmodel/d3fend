    dcterms:title "Local Area Network Attacker" ;
    rdfs:subClassOf d3f:LocalAttacker ;
    skos:definition "An attacker who exploits vulnerabilities within the same local area network." ;
    skos:exactMatch d3f:LocalAreaNetworkAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LocalAreaNetworkTraffic a owl:Class ;
