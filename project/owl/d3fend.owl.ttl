        d3f:LateralMovementTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1055,
        d3f:T1056,
        d3f:T1218 ;
    skos:definition "Randomizing the base (start) address of one or more segments of memory during the initialization of a process." ;
    skos:exactMatch d3f:SegmentAddressOffsetRandomization ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1033,
        mitre-attack:T1055.012,
        mitre-attack:T1056.004,
