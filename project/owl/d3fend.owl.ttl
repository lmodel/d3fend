    rdfs:label "CWE_1111" ;
    d3f:cwe-id "CWE-1111" ;
    dcterms:title "Incomplete I/O Documentation" ;
    rdfs:subClassOf d3f:CWE1059 ;
    skos:altLabel "CWE-1111" ;
    skos:definition "The product's documentation does not adequately define inputs, outputs, or system/software interfaces." ;
    skos:exactMatch d3f:CWE-1111,
        cwe:CWE-1111 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1112 a owl:Class ;
    rdfs:label "CWE_1112" ;
    d3f:cwe-id "CWE-1112" ;
    dcterms:title "Incomplete Documentation of Program Execution" ;
    rdfs:subClassOf d3f:CWE1059 ;
    skos:altLabel "CWE-1112" ;
    skos:definition "The document does not fully define all mechanisms that are used to control or influence how product-specific programs are executed." ;
    skos:exactMatch d3f:CWE-1112,
        cwe:CWE-1112 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

