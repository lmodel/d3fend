d3f:LocalAreaNetwork a owl:Class ;
    rdfs:label "LocalAreaNetwork" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Local Area Network" ;
    rdfs:seeAlso dbr:Local_area_network ;
    rdfs:subClassOf d3f:Network ;
    skos:altLabel "LAN" ;
    skos:definition "A local area network (LAN) is a computer network that interconnects computers within a limited area such as a residence, school, laboratory, university campus or office building and has its network equipment and interconnects locally managed. Ethernet and Wi-Fi are the two most common transmission technologies in use for local area networks. Historical technologies include ARCNET, Token ring, and AppleTalk." ;
    skos:exactMatch d3f:LocalAreaNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LocalAreaNetworkAttacker a owl:Class ;
    rdfs:label "LocalAreaNetworkAttacker" ;
