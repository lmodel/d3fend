    rdfs:label "CWE_1117" ;
    d3f:cwe-id "CWE-1117" ;
    dcterms:title "Callable with Insufficient Behavioral Summary" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-1117" ;
