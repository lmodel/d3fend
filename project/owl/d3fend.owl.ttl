d3f:UserGroup a owl:Class ;
    rdfs:label "UserGroup" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Security Group" ;
    dcterms:title "User Group" ;
    rdfs:subClassOf d3f:AccessControlGroup ;
    skos:definition "User groups are a way to collect user accounts and/or computer accounts into manageable units. Administrators can assign permissions, roles, or access to resources, as well as modify group membership, depending on the operating system." ;
    skos:exactMatch d3f:UserGroup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserGroupPermissions a owl:Class ;
    rdfs:label "UserGroupPermissions" ;
    d3f:d3fend-id "D3F-UGPH" ;
    d3f:kb-article "## How it works Access is determined based on the attributes associated with subjects (requesters) and the objects being accessed. Each object and subject has a set of associated attributes, such as location, time of creation, and access rights. Access to an object is authorized or denied depending" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Role Based Access Controls" ;
    dcterms:title "User Group Permissions" ;
    rdfs:seeAlso <https://nvlpubs.nist.gov/nistpubs/SpecialPublications/NIST.SP.800-82r3.pdf> ;
    rdfs:subClassOf d3f:AccessPolicyAdministration ;
    skos:definition "Access control where access is determined based on attributes associated with users and the objects being accessed." ;
    skos:exactMatch d3f:UserGroupPermissions ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserInitConfigurationFile a owl:Class ;
    rdfs:label "UserInitConfigurationFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Init Configuration File" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UserLogonInitResource ],
        d3f:ConfigurationFile ;
    skos:altLabel "User Configuration File" ;
    skos:definition "A user initialization configuration file is a file containing the information necessary to configure that part of a user's environment which is common to all applications and actions. User configurations may be overridden by more specific configuration information (such as that found in a application configuration file.)" ;
    skos:exactMatch d3f:UserInitConfigurationFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserInputFunction a owl:Class ;
    rdfs:label "UserInputFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Input Function" ;
    rdfs:subClassOf d3f:InputFunction ;
    skos:definition "Generic function that receives direct user input from an untrusted source." ;
    skos:exactMatch d3f:UserInputFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserManualReference a owl:Class ;
    rdfs:label "UserManualReference" ;
    d3f:pref-label "User Manual" ;
    dcterms:title "User Manual Reference" ;
    rdfs:subClassOf d3f:TechniqueReference ;
    skos:exactMatch d3f:UserManualReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserProfile a owl:Class ;
    rdfs:label "UserProfile" ;
    dcterms:title "User Profile" ;
    rdfs:seeAlso dbr:User_profile,
        <https://en.wikipedia.org/wiki/User_profile> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A user profile is a collection of settings and information associated with a user. It contains critical information that is used to identify an individual, such as their name, age, portrait photograph and individual characteristics such as knowledge or expertise." ;
    skos:exactMatch d3f:UserProfile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserSessionInitConfigAnalysis a owl:Class ;
    rdfs:label "UserSessionInitConfigAnalysis" ;
    d3f:d3fend-id "D3-USICA" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "User Startup Config Analysis" ;
    dcterms:title "User Session Init Config Analysis" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:T1546,
        d3f:T1564 ;
    skos:definition "Analyzing modifications to user session config files such as .bashrc or .bash_profile." ;
    skos:exactMatch d3f:UserSessionInitConfigAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1546.004,
        mitre-attack:T1564.002 .

d3f:UserStartupDirectory a owl:Class ;
    rdfs:label "UserStartupDirectory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Startup Directory" ;
    rdfs:subClassOf d3f:UserLogonInitResource ;
    skos:definition "A user startup directory holds information necessary to start the users session with the system." ;
    skos:exactMatch d3f:UserStartupDirectory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserStartupScriptFile a owl:Class ;
    rdfs:label "UserStartupScriptFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Startup Script File" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UserLogonInitResource ],
        d3f:ExecutableScript ;
    skos:definition "A user startup script file is a shortcut file that is executed when a user logs in and starts a session on the host.  These indicate applications the user wants started at login.  For Windows, these are typically found in the user's startup directory." ;
    skos:exactMatch d3f:UserStartupScriptFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserToUserMessage a owl:Class ;
    rdfs:label "UserToUserMessage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User to User Message" ;
    rdfs:seeAlso dbr:Personal_message ;
    rdfs:subClassOf d3f:DigitalMessage ;
    skos:altLabel "Personal Message",
        "Private Message" ;
    skos:definition "Personal message, private message (PM), direct message (DM), or personal chat (PC) is a private form of messaging between different members on a given platform. It is only seen and accessible by the users participating in the message." ;
    skos:exactMatch d3f:UserToUserMessage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VMImage a owl:Class ;
    rdfs:label "VMImage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Virtual Machine Image" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Virtual_machine_image>,
        <https://www.ituonline.com/tech-definitions/what-is-a-virtual-machine-image/> ;
    rdfs:subClassOf d3f:StorageImage ;
    skos:altLabel "VM Image" ;
    skos:definition "A Virtual Machine Image (VMI) is a file that encapsulates the entire state of a virtual machine at a given point in time. This includes the operating system, applications, data, and configurations. VMIs are used to create and replicate virtual machines, ensuring consistency and reliability across different environments." ;
    skos:exactMatch d3f:VMImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VPNServer a owl:Class ;
    rdfs:label "VPNServer" ;
    dcterms:title "VPN Server" ;
    rdfs:seeAlso dbr:Virtual_private_network,
        <https://www.techopedia.com/definition/30750/vpn-server> ;
    rdfs:subClassOf d3f:Server ;
    skos:definition """A VPN server is a type of server that enables hosting and delivery of VPN services.

It is a combination of VPN hardware and software technologies that provides VPN clients with connectivity to a secure and/or private network, or rather, the VPN.""" ;
    skos:exactMatch d3f:VPNServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VariableInitialization a owl:Class ;
    rdfs:label "VariableInitialization" ;
    d3f:d3fend-id "D3-VI" ;
    d3f:kb-article "## How it Works Initializing variables upon declaration ensures that the variable has a known quantity before use. ## Considerations * Default behavior when declaring variables varies by language. * This is particularly important in programming languages that do not initialize variables to a defaul" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Variable Initialization" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:broadMatch d3f:T1505 ;
    skos:definition "Setting variables to a known value before use." ;
    skos:exactMatch d3f:VariableInitialization ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1505.001 .

d3f:VariableTypeValidation a owl:Class ;
    rdfs:label "VariableTypeValidation" ;
    d3f:d3fend-id "D3-VTV" ;
    d3f:kb-article "## How it Works A developer should consider how the variable will be used throughout the program and choose the correct variable type. A developer should programmatically check if a variable has the correct (expected) type before using that variable. ## Considerations * The result of an operation o" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Variable Type Validation" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:definition "Ensuring that a variable has the correct type." ;
    skos:exactMatch d3f:VariableTypeValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Variance a owl:Class ;
    rdfs:label "Variance" ;
    d3f:d3fend-id "D3A-VAR" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Variance. [Link](https://en.wikipedia.org/wiki/Variance)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:Variability ;
    skos:definition "Variance is a measure of dispersion, meaning it is a measure of how far a set of numbers is spread out from their average value." ;
    skos:exactMatch d3f:Variance ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VarianceReduction a owl:Class ;
    rdfs:label "VarianceReduction" ;
    d3f:d3fend-id "D3A-VR" ;
    d3f:kb-article "## References Intro to Active Learning. inovex Blog. [Link](https://www.inovex.de/de/blog/intro-to-active-learning/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Variance Reduction" ;
    rdfs:subClassOf d3f:ActiveLearning ;
    skos:definition "Leverages a well-known result from statistical learning and decomposes the model error into a data noise term, a model bias term and a model variance term. As the noise term only depends on the data and the bias is induced by the choice of model, any reduction in the error can only come from the variance term." ;
    skos:exactMatch d3f:VarianceReduction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VectorImage a owl:Class ;
    rdfs:label "VectorImage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Vector Image" ;
    rdfs:subClassOf d3f:DigitalImage ;
    skos:definition "A graphical image created using mathematical equations and geometric shapes defined by vectors." ;
    skos:exactMatch d3f:VectorImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VectorImageFile a owl:Class ;
    rdfs:label "VectorImageFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Vector Image File" ;
    rdfs:subClassOf d3f:ImageFile ;
    skos:definition "A file that contains graphics data represented by vectors." ;
    skos:exactMatch d3f:VectorImageFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VehicleOperatingMode a owl:Class ;
    rdfs:label "VehicleOperatingMode" ;
    dcterms:title "Vehicle Operating Mode" ;
    rdfs:subClassOf d3f:OperatingMode ;
    skos:exactMatch d3f:VehicleOperatingMode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Vendor a owl:Class ;
    rdfs:label "Vendor" ;
    rdfs:subClassOf d3f:Provider ;
    skos:definition "A vendor sells or supplies goods and services to customers." ;
    skos:exactMatch d3f:Vendor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VersionControlTool a owl:Class ;
    rdfs:label "VersionControlTool" ;
    dcterms:title "Version Control Tool" ;
    rdfs:seeAlso dbr:Software_configuration_management,
        dbr:Version_control ;
    rdfs:subClassOf d3f:DeveloperApplication ;
    skos:altLabel "Revision Control",
        "Source Control" ;
    skos:definition "Version control tools are tools that used to conduct version control. A  component of software configuration management, version control, also known as revision control, source control, or source code management systems are systems responsible for the management of changes to documents, computer programs, large web sites, and other collections of information. Changes are usually identified by a number or letter code, termed the \"revision number\", \"revision level\", or simply \"revision\". For example, an initial set of files is \"revision 1\". When the first change is made, the resulting set is \"revision 2\", and so on. Each revision is associated with a timestamp and the person making the change. Revisions can be compared, restored, and with some types of files, merged." ;
    skos:exactMatch d3f:VersionControlTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VideoSurveillance a owl:Class ;
    rdfs:label "VideoSurveillance" ;
    d3f:d3fend-id "D3-VS" ;
    d3f:kb-article "## How it works Video surveillance uses digital cameras that stream to a video management system (VMS) or network video recorder (NVR) for live monitoring, recording, and retrieval. Recording can be continuous or event-driven using analytics (motion in regions of interest, line crossing) or externa" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "CCTV Surveillance" ;
    dcterms:title "Video Surveillance" ;
    rdfs:subClassOf d3f:PhysicalAccessMonitoring ;
    skos:broadMatch d3f:CollectionTechnique ;
    skos:definition "Monitoring of physical areas via camera video feeds to deter, detect, and investigate unauthorized access and related security events." ;
    skos:exactMatch d3f:VideoSurveillance ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1125 .

d3f:VirtualAddress a owl:Class ;
    rdfs:label "VirtualAddress" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Logical Address" ;
    dcterms:title "Virtual Address" ;
    rdfs:seeAlso <https://dbpedia.org/page/Virtual_address_space>,
        <https://en.wikipedia.org/wiki/Memory_address#Logical_addresses>,
        <https://www.techopedia.com/definition/9934/virtual-address-va> ;
    rdfs:subClassOf d3f:MemoryAddress ;
    skos:definition "A virtual address in memory is a pointer or marker for a memory space that an operating system allows a process to use. The virtual address points to a location in primary storage that a process can use independently of other processes." ;
    skos:exactMatch d3f:VirtualAddress ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VirtualMemorySpace a owl:Class ;
    rdfs:label "VirtualMemorySpace" ;
    dcterms:title "Virtual Memory Space" ;
    rdfs:seeAlso <https://dbpedia.org/page/Virtual_memory>,
        <https://whatis.techtarget.com/definition/memory> ;
    rdfs:subClassOf d3f:MemoryAddressSpace ;
    skos:definition "Virtual memory is a memory management technique where secondary memory can be used as if it were a part of the main memory. Virtual memory uses hardware and software to enable a computer to compensate for physical memory shortages" ;
    skos:exactMatch d3f:VirtualMemorySpace ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VirtualizationSoftware a owl:Class ;
    rdfs:label "VirtualizationSoftware" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Virtualization Software" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Category:Virtualization_software> ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "Virtualization software allows a single host computer to create and run one or more virtual environments. Virtualization software is most often used to emulate a complete computer system in order to allow a guest operating system to be run, for example allowing Linux to run as a guest on top of a PC that is natively running a Microsoft Windows operating system (or the inverse, running Windows as a guest on Linux)." ;
    skos:exactMatch d3f:VirtualizationSoftware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Volume a owl:Class ;
    rdfs:label "Volume" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Drive Volume",
        "Logical Drive" ;
    skos:definition "In the context of computer operating systems, a volume or logical drive is a single accessible storage area with a single file system, typically (though not necessarily) resident on a single partition of a hard disk. Although a volume might be different from a physical disk drive, it can still be accessed with an operating system's logical interface. However, a volume differs from a partition." ;
    skos:exactMatch d3f:Volume,
        unified_cyber_ontology:Volume ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VolumeBootRecord a owl:Class ;
    rdfs:label "VolumeBootRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Volume Boot Record" ;
    rdfs:seeAlso dbr:Volume_boot_record ;
    rdfs:subClassOf d3f:BootRecord ;
    skos:definition "A volume boot record (VBR) (also known as a volume boot sector, a partition boot record or a partition boot sector) is a type of boot sector introduced by the IBM Personal Computer. It may be found on a partitioned data storage device, such as a hard disk, or an unpartitioned device, such as a floppy disk, and contains machine code for bootstrapping programs (usually, but not necessarily, operating systems) stored in other parts of the device. On non-partitioned storage devices, it is the first sector of the device. On partitioned devices, it is the first sector of an individual partition on the device, with the first sector of the entire device being a Master Boot Record (MBR) containing the partition table." ;
    skos:exactMatch d3f:VolumeBootRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Voting a owl:Class ;
    rdfs:label "Voting" ;
    d3f:d3fend-id "D3A-VOT" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning)." ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "Voting is another form of ensembling." ;
    skos:exactMatch d3f:Voting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Vulnerability a owl:Class ;
    rdfs:label "Vulnerability" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:definition "A Vulnerability is a publicly disclosed instance of one or more weaknesses in a product that an attacker could exploit, violating its confidentiality, integrity, or availability." ;
    skos:exactMatch d3f:Vulnerability,
        spdx:Vulnerability,
        stix:Vulnerability ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WatchdogTimerConfigurationEvent a owl:Class ;
    rdfs:label "WatchdogTimerConfigurationEvent" ;
    dcterms:title "Watchdog Timer Configuration Event" ;
    rdfs:subClassOf d3f:WatchdogTimerEvent ;
    skos:definition "An event in which a watchdog timer's timeout period or recovery action is configured." ;
    skos:exactMatch d3f:WatchdogTimerConfigurationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WatchdogTimerExpirationEvent a owl:Class ;
    rdfs:label "WatchdogTimerExpirationEvent" ;
    dcterms:title "Watchdog Timer Expiration Event" ;
    rdfs:subClassOf d3f:WatchdogTimerEvent ;
    skos:definition "An event indicating the watchdog timer was not serviced in time and triggers a reset or escalation action." ;
    skos:exactMatch d3f:WatchdogTimerExpirationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WatchdogTimerResetEvent a owl:Class ;
    rdfs:label "WatchdogTimerResetEvent" ;
    dcterms:title "Watchdog Timer Reset Event" ;
    rdfs:subClassOf d3f:WatchdogTimerEvent ;
    skos:definition "An event where a watchdog timer is reset as a consequence of watchdog timer expiry or watchdog timer escalation policy." ;
    skos:exactMatch d3f:WatchdogTimerResetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WatchdogTimerServiceEvent a owl:Class ;
    rdfs:label "WatchdogTimerServiceEvent" ;
    dcterms:title "Watchdog Timer Service Event" ;
    rdfs:subClassOf d3f:WatchdogTimerEvent ;
    skos:definition "An event in which the watchdog timer is serviced (kicked/pet), extending the time until expiry." ;
    skos:exactMatch d3f:WatchdogTimerServiceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebAPIResource a owl:Class ;
    rdfs:label "WebAPIResource" ;
    dcterms:title "Web API Resource" ;
    rdfs:subClassOf d3f:WebResource ;
    skos:definition "A web API resource is an API resource identified by a Uniform Resource Identifier (URI) and made available from one host to another host via a web protocol and across a network or networks." ;
    skos:exactMatch d3f:WebAPIResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebAccessToken a owl:Class ;
    rdfs:label "WebAccessToken" ;
    d3f:synonym "WAT" ;
    dcterms:title "Web Access Token" ;
    rdfs:seeAlso dbr:JSON_Web_Token,
        <https://auth0.com/blog/id-token-access-token-what-is-the-difference/> ;
    rdfs:subClassOf d3f:SessionToken ;
    skos:definition "A web access token is a credential that allows a web client application to access a specific resource to perform specific actions on behalf of the user." ;
    skos:exactMatch d3f:WebAccessToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebApplication a owl:Class ;
    rdfs:label "WebApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Application" ;
    rdfs:seeAlso dbr:Web_application ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:altLabel "Web App",
        "Web Application" ;
    skos:definition "An application which is delivered by a web server over HTTP protocols that is presented to a client web browser." ;
    skos:exactMatch d3f:WebApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebApplicationFirewall a owl:Class ;
    rdfs:label "WebApplicationFirewall" ;
    dcterms:title "Web Application Firewall" ;
    rdfs:seeAlso dbr:Web_application_firewall ;
    rdfs:subClassOf d3f:ApplicationLayerFirewall ;
    skos:altLabel "WAF" ;
    skos:definition "A web application firewall (or WAF) filters, monitors, and blocks HTTP traffic to and from a web application. A WAF is differentiated from a regular firewall in that a WAF is able to filter the content of specific web applications while regular firewalls serve as a safety gate between servers. By inspecting HTTP traffic, it can prevent attacks stemming from web application security flaws, such as SQL injection, cross-site scripting (XSS), file inclusion, and security misconfigurations." ;
    skos:exactMatch d3f:WebApplicationFirewall ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebApplicationServer a owl:Class ;
    rdfs:label "WebApplicationServer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Application Server" ;
    rdfs:seeAlso dbr:Application_server ;
    rdfs:subClassOf d3f:WebServer ;
    skos:definition "A web application server is a web server that hosts applications. Application server frameworks are software frameworks for building application servers. An application server framework provides both facilities to create web applications and a server environment to run them. In the case of Java application servers, the server behaves like an extended virtual machine for running applications, transparently handling connections to the database on one side, and, often, connections to the Web client on the other." ;
    skos:exactMatch d3f:WebApplicationServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebFileResource a owl:Class ;
    rdfs:label "WebFileResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web File Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:WebResource ],
        d3f:NetworkFileResource ;
    skos:definition "A web file resource is a file resource identified by a Uniform Resource Identifier (URI) and made available from one host to another host via a web protocol and across a network or networks." ;
    skos:exactMatch d3f:WebFileResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebIdentityToken a owl:Class ;
    rdfs:label "WebIdentityToken" ;
    d3f:kb-article "## How it works An ID token is proof of the user's authentication. An ID token is encoded as a JSON Web Token (JWT), a standard format that allows your application to easily inspect its content, and make sure it comes from the expected issuer and that no one else changed it." ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Identity Token" ;
    dcterms:title "Web Identity Token" ;
    rdfs:seeAlso <https://auth0.com/blog/id-token-access-token-what-is-the-difference/> ;
    rdfs:subClassOf d3f:Credential ;
    skos:definition "An ID token is an artifact that proves that the user has been authenticated." ;
    skos:exactMatch d3f:WebIdentityToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebResourceAccess a owl:Class ;
    rdfs:label "WebResourceAccess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Resource Access" ;
    rdfs:subClassOf d3f:NetworkResourceAccess ;
    skos:definition "Ephemeral digital artifact comprising a request of a network resource and any response from that network resource using a standard web protocol." ;
    skos:exactMatch d3f:WebResourceAccess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebScriptFile a owl:Class ;
    rdfs:label "WebScriptFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Script File" ;
    rdfs:subClassOf d3f:ExecutableScript ;
    skos:altLabel "Web Script" ;
    skos:definition "A file containing a script in a web-scripting programming language. Web scripts may be present and run on the client or on the server side." ;
    skos:exactMatch d3f:WebScriptFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebServerApplication a owl:Class ;
    rdfs:label "WebServerApplication" ;
    dcterms:title "Web Server Application" ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "A web server application handles HTTP requests from clients, serves static content, and may act as a reverse proxy or load balancer." ;
    skos:exactMatch d3f:WebServerApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebSessionActivityAnalysis a owl:Class ;
    rdfs:label "WebSessionActivityAnalysis" ;
    d3f:d3fend-id "D3-WSAA" ;
    d3f:kb-article "## How it works User web session data is collected over a period of time to create a user behavior profile. Data collected includes clicks made on a website, average time between clicks, filling out web forms, order in which pages are viewed, and downloading files. Current user web session behavior" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Web Session Activity Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Monitoring changes in user web session behavior by comparing current web session activity to a baseline behavior profile or a catalog of predetermined malicious behavior." ;
    skos:exactMatch d3f:WebSessionActivityAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WeightedMean a owl:Class ;
    rdfs:label "WeightedMean" ;
    d3f:d3fend-id "D3A-WM" ;
    d3f:kb-article "## Considerations The arithmetic mean, geometric mean, and harmonic mean can all be weighted. ## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Weighted Mean" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "A mean that incorporates weighting to certain data elements." ;
    skos:exactMatch d3f:WeightedMean ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WideAreaNetwork a owl:Class ;
    rdfs:label "WideAreaNetwork" ;
    dcterms:title "Wide Area Network" ;
    rdfs:seeAlso dbr:Local_area_network ;
    rdfs:subClassOf d3f:Network ;
    skos:altLabel "WAN" ;
    skos:definition "By contrast to a local area network (LAN), a wide area network (WAN), not only covers a larger geographic distance, but also generally involves leased telecommunication circuits or Internet links." ;
    skos:exactMatch d3f:WideAreaNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowOpenFile a owl:Class ;
    rdfs:label "WindowOpenFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows OpenFile" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/winbase/nf-winbase-openfile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OSAPIOpenFile ],
        d3f:OSAPICreateFile ;
    skos:definition "Creates, opens, reopens, or deletes a file." ;
    skos:exactMatch d3f:WindowOpenFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsCreateFileA a owl:Class ;
    rdfs:label "WindowsCreateFileA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows CreateFileA" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/fileapi/nf-fileapi-createfilea> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OSAPIOpenFile ],
        d3f:OSAPICreateFile ;
    skos:definition "Creates or opens a file or I/O device. The most commonly used I/O devices are as follows: file, file stream, directory, physical disk, volume, console buffer, tape drive, communications resource, mailslot, and pipe. The function returns a handle that can be used to access the file or device for various types of I/O depending on the file or device and the flags and attributes specified." ;
    skos:exactMatch d3f:WindowsCreateFileA ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsCreateProcessA a owl:Class ;
    rdfs:label "WindowsCreateProcessA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows CreateProcessA" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-createprocessa> ;
    rdfs:subClassOf d3f:OSAPICreateProcess ;
    skos:definition "Creates a new process and its primary thread. The new process runs in the security context of the calling process." ;
    skos:exactMatch d3f:WindowsCreateProcessA ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsCreateRemoteThread a owl:Class ;
    rdfs:label "WindowsCreateRemoteThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows CreateRemoteThread" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-createremotethread> ;
    rdfs:subClassOf d3f:OSAPICreateThread ;
    skos:definition "Creates a thread that runs in the virtual address space of another process." ;
    skos:exactMatch d3f:WindowsCreateRemoteThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsCreateThread a owl:Class ;
    rdfs:label "WindowsCreateThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows CreateThread" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-createthread> ;
    rdfs:subClassOf d3f:OSAPICreateThread ;
    skos:definition "Creates a thread to execute within the virtual address space of the calling process." ;
    skos:exactMatch d3f:WindowsCreateThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsDeleteFile a owl:Class ;
    rdfs:label "WindowsDeleteFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows DeleteFile" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/winbase/nf-winbase-deletefile> ;
    rdfs:subClassOf d3f:OSAPIDeleteFile ;
    skos:definition "Deletes an existing file." ;
    skos:exactMatch d3f:WindowsDeleteFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsDuplicateToken a owl:Class ;
    rdfs:label "WindowsDuplicateToken" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows DuplicateToken" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/securitybaseapi/nf-securitybaseapi-duplicatetoken> ;
    rdfs:subClassOf d3f:OSAPICopyToken ;
    skos:definition "The DuplicateToken function creates a new access token that duplicates one already in existence." ;
    skos:exactMatch d3f:WindowsDuplicateToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsGetThreadContext a owl:Class ;
    rdfs:label "WindowsGetThreadContext" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows GetThreadContext" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-getthreadcontext> ;
    rdfs:subClassOf d3f:OSAPIGetThreadContext ;
    skos:definition "Retrieves the context of the specified thread." ;
    skos:exactMatch d3f:WindowsGetThreadContext ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsNTGetThreadContext a owl:Class ;
    rdfs:label "WindowsNTGetThreadContext" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows NtGetThreadContext" ;
    rdfs:subClassOf d3f:OSAPIGetThreadContext ;
    skos:exactMatch d3f:WindowsNTGetThreadContext ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsNtAllocateVirtualMemory a owl:Class ;
    rdfs:label "WindowsNtAllocateVirtualMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows NtAllocateVirtualMemory" ;
    rdfs:seeAlso <https://j00ru.vexillium.org/syscalls/nt/64/>,
        <https://learn.microsoft.com/en-us/windows-hardware/drivers/ddi/ntifs/nf-ntifs-ntallocatevirtualmemory> ;
    rdfs:subClassOf d3f:OSAPIAllocateMemory ;
    skos:definition "The NtAllocateVirtualMemory routine reserves, commits, or both, a region of pages within the user-mode virtual address space of a specified process." ;
    skos:exactMatch d3f:WindowsNtAllocateVirtualMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsNtAllocateVirtualMemoryEx a owl:Class ;
    rdfs:label "WindowsNtAllocateVirtualMemoryEx" ;
    dcterms:title "Windows NtAllocateVirtualMemoryEx" ;
    rdfs:subClassOf d3f:OSAPIAllocateMemory ;
    skos:exactMatch d3f:WindowsNtAllocateVirtualMemoryEx ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsNtCreateFile a owl:Class ;
    rdfs:label "WindowsNtCreateFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows NtCreateFile" ;
    rdfs:seeAlso <https://j00ru.vexillium.org/syscalls/nt/64/>,
        <https://learn.microsoft.com/en-us/windows/win32/api/winternl/nf-winternl-ntcreatefile> ;
    rdfs:subClassOf d3f:OSAPICreateFile ;
    skos:definition "Creates a new file or directory, or opens an existing file, device, directory, or volume." ;
    skos:exactMatch d3f:WindowsNtCreateFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsNtCreateMailslotFile a owl:Class ;
    rdfs:label "WindowsNtCreateMailslotFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows NtCreateMailslotFile" ;
    rdfs:seeAlso <https://j00ru.vexillium.org/syscalls/nt/64/> ;
    rdfs:subClassOf d3f:OSAPICreateFile ;
    skos:definition "Creates a special File Object called Mailslot." ;
    skos:exactMatch d3f:WindowsNtCreateMailslotFile ;
