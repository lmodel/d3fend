    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-158" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes NUL characters or null bytes when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-158,
        cwe:CWE-158 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE166 a owl:Class ;
    rdfs:label "CWE_166" ;
    d3f:cwe-id "CWE-166" ;
    dcterms:title "Improper Handling of Missing Special Element" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE228 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        d3f:CWE159 ;
    skos:altLabel "CWE-166" ;
    skos:definition "The product receives input from an upstream component, but it does not handle or incorrectly handles when an expected special element is missing." ;
    skos:exactMatch d3f:CWE-166,
        cwe:CWE-166 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE167 a owl:Class ;
    rdfs:label "CWE_167" ;
    d3f:cwe-id "CWE-167" ;
    dcterms:title "Improper Handling of Additional Special Element" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE228 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        d3f:CWE159 ;
    skos:altLabel "CWE-167" ;
    skos:definition "The product receives input from an upstream component, but it does not handle or incorrectly handles when an additional unexpected special element is provided." ;
    skos:exactMatch d3f:CWE-167,
        cwe:CWE-167 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE168 a owl:Class ;
    rdfs:label "CWE_168" ;
    d3f:cwe-id "CWE-168" ;
    dcterms:title "Improper Handling of Inconsistent Special Elements" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE228 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        d3f:CWE159 ;
    skos:altLabel "CWE-168" ;
    skos:definition "The product does not properly handle input in which an inconsistency exists between two or more special characters or reserved words." ;
    skos:exactMatch d3f:CWE-168,
        cwe:CWE-168 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE170 a owl:Class ;
    rdfs:label "CWE_170" ;
    d3f:cwe-id "CWE-170" ;
    dcterms:title "Improper Null Termination" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-170" ;
    skos:definition "The product does not terminate or incorrectly terminates a string or array with a null character or equivalent terminator." ;
    skos:exactMatch d3f:CWE-170,
        cwe:CWE-170 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE173 a owl:Class ;
    rdfs:label "CWE_173" ;
    d3f:cwe-id "CWE-173" ;
    dcterms:title "Improper Handling of Alternate Encoding" ;
    rdfs:subClassOf d3f:CWE172 ;
    skos:altLabel "CWE-173" ;
    skos:definition "The product does not properly handle when an input uses an alternate encoding that is valid for the control sphere to which the input is being sent." ;
    skos:exactMatch d3f:CWE-173,
        cwe:CWE-173 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE174 a owl:Class ;
    rdfs:label "CWE_174" ;
    d3f:cwe-id "CWE-174" ;
    dcterms:title "Double Decoding of the Same Data" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE675 ],
        d3f:CWE172 ;
    skos:altLabel "CWE-174" ;
    skos:definition "The product decodes the same input twice, which can limit the effectiveness of any protection mechanism that occurs in between the decoding operations." ;
    skos:exactMatch d3f:CWE-174,
        cwe:CWE-174 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE175 a owl:Class ;
    rdfs:label "CWE_175" ;
    d3f:cwe-id "CWE-175" ;
    dcterms:title "Improper Handling of Mixed Encoding" ;
    rdfs:subClassOf d3f:CWE172 ;
    skos:altLabel "CWE-175" ;
    skos:definition "The product does not properly handle when the same input uses several different (mixed) encodings." ;
    skos:exactMatch d3f:CWE-175,
        cwe:CWE-175 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE176 a owl:Class ;
    rdfs:label "CWE_176" ;
    d3f:cwe-id "CWE-176" ;
    dcterms:title "Improper Handling of Unicode Encoding" ;
    rdfs:subClassOf d3f:CWE172 ;
    skos:altLabel "CWE-176" ;
    skos:definition "The product does not properly handle when an input contains Unicode encoding." ;
    skos:exactMatch d3f:CWE-176,
        cwe:CWE-176 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE177 a owl:Class ;
    rdfs:label "CWE_177" ;
    d3f:cwe-id "CWE-177" ;
    dcterms:title "Improper Handling of URL Encoding (Hex Encoding)" ;
    rdfs:subClassOf d3f:CWE172 ;
    skos:altLabel "CWE-177" ;
    skos:definition "The product does not properly handle when all or part of an input has been URL encoded." ;
    skos:exactMatch d3f:CWE-177,
        cwe:CWE-177 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE178 a owl:Class ;
    rdfs:label "CWE_178" ;
    d3f:cwe-id "CWE-178" ;
    dcterms:title "Improper Handling of Case Sensitivity" ;
    rdfs:subClassOf d3f:CWE706 ;
    skos:altLabel "CWE-178" ;
    skos:definition "The product does not properly account for differences in case sensitivity when accessing or determining the properties of a resource, leading to inconsistent results." ;
    skos:exactMatch d3f:CWE-178,
        cwe:CWE-178 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE180 a owl:Class ;
    rdfs:label "CWE_180" ;
    d3f:cwe-id "CWE-180" ;
    dcterms:title "Incorrect Behavior Order: Validate Before Canonicalize" ;
    rdfs:subClassOf d3f:CWE179 ;
    skos:altLabel "CWE-180" ;
    skos:definition "The product validates input before it is canonicalized, which prevents the product from detecting data that becomes invalid after the canonicalization step." ;
    skos:exactMatch d3f:CWE-180,
        cwe:CWE-180 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE181 a owl:Class ;
    rdfs:label "CWE_181" ;
    d3f:cwe-id "CWE-181" ;
    d3f:synonym "Validate-before-cleanse" ;
    dcterms:title "Incorrect Behavior Order: Validate Before Filter" ;
    rdfs:subClassOf d3f:CWE179 ;
    skos:altLabel "CWE-181" ;
    skos:definition "The product validates data before it has been filtered, which prevents the product from detecting data that becomes invalid after the filtering step." ;
    skos:exactMatch d3f:CWE-181,
        cwe:CWE-181 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE182 a owl:Class ;
    rdfs:label "CWE_182" ;
    d3f:cwe-id "CWE-182" ;
    dcterms:title "Collapse of Data into Unsafe Value" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE707 ],
        d3f:CWE693 ;
    skos:altLabel "CWE-182" ;
    skos:definition "The product filters data in a way that causes it to be reduced or \"collapsed\" into an unsafe value that violates an expected security property." ;
    skos:exactMatch d3f:CWE-182,
        cwe:CWE-182 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE186 a owl:Class ;
    rdfs:label "CWE_186" ;
    d3f:cwe-id "CWE-186" ;
    dcterms:title "Overly Restrictive Regular Expression" ;
    rdfs:subClassOf d3f:CWE185 ;
    skos:altLabel "CWE-186" ;
    skos:definition "A regular expression is overly restrictive, which prevents dangerous values from being detected." ;
    skos:exactMatch d3f:CWE-186,
        cwe:CWE-186 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE187 a owl:Class ;
    rdfs:label "CWE_187" ;
    d3f:cwe-id "CWE-187" ;
    dcterms:title "Partial String Comparison" ;
    rdfs:subClassOf d3f:CWE1023 ;
    skos:altLabel "CWE-187" ;
    skos:definition "The product performs a comparison that only examines a portion of a factor before determining whether there is a match, such as a substring, leading to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-187,
        cwe:CWE-187 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE191 a owl:Class ;
    rdfs:label "CWE_191" ;
    d3f:cwe-id "CWE-191" ;
    d3f:synonym "Integer underflow" ;
    dcterms:title "Integer Underflow (Wrap or Wraparound)" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-191" ;
    skos:definition "The product subtracts one value from another, such that the result is less than the minimum allowable integer value, which produces a value that is not equal to the correct result." ;
    skos:exactMatch d3f:CWE-191,
        cwe:CWE-191 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE192 a owl:Class ;
    rdfs:label "CWE_192" ;
    d3f:cwe-id "CWE-192" ;
    dcterms:title "Integer Coercion Error" ;
    rdfs:subClassOf d3f:CWE681 ;
    skos:altLabel "CWE-192" ;
    skos:definition "Integer coercion refers to a set of flaws pertaining to the type casting, extension, or truncation of primitive data types." ;
    skos:exactMatch d3f:CWE-192,
        cwe:CWE-192 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE193 a owl:Class ;
    rdfs:label "CWE_193" ;
    d3f:cwe-id "CWE-193" ;
    d3f:synonym "off-by-five" ;
    dcterms:title "Off-by-one Error" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-193" ;
    skos:definition "A product calculates or uses an incorrect maximum or minimum value that is 1 more, or 1 less, than the correct value." ;
    skos:exactMatch d3f:CWE-193,
        cwe:CWE-193 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE194 a owl:Class ;
    rdfs:label "CWE_194" ;
    d3f:cwe-id "CWE-194" ;
    dcterms:title "Unexpected Sign Extension" ;
    rdfs:subClassOf d3f:CWE681 ;
    skos:altLabel "CWE-194" ;
    skos:definition "The product performs an operation on a number that causes it to be sign extended when it is transformed into a larger data type. When the original number is negative, this can produce unexpected values that lead to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-194,
        cwe:CWE-194 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE195 a owl:Class ;
    rdfs:label "CWE_195" ;
    d3f:cwe-id "CWE-195" ;
    dcterms:title "Signed to Unsigned Conversion Error" ;
    rdfs:subClassOf d3f:CWE681 ;
    skos:altLabel "CWE-195" ;
    skos:definition "The product uses a signed primitive and performs a cast to an unsigned primitive, which can produce an unexpected value if the value of the signed primitive can not be represented using an unsigned primitive." ;
    skos:exactMatch d3f:CWE-195,
        cwe:CWE-195 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE196 a owl:Class ;
    rdfs:label "CWE_196" ;
    d3f:cwe-id "CWE-196" ;
    dcterms:title "Unsigned to Signed Conversion Error" ;
    rdfs:subClassOf d3f:CWE681 ;
    skos:altLabel "CWE-196" ;
    skos:definition "The product uses an unsigned primitive and performs a cast to a signed primitive, which can produce an unexpected value if the value of the unsigned primitive can not be represented using a signed primitive." ;
    skos:exactMatch d3f:CWE-196,
        cwe:CWE-196 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE197 a owl:Class ;
    rdfs:label "CWE_197" ;
    d3f:cwe-id "CWE-197" ;
    dcterms:title "Numeric Truncation Error" ;
    rdfs:subClassOf d3f:CWE681 ;
    skos:altLabel "CWE-197" ;
    skos:definition "Truncation errors occur when a primitive is cast to a primitive of a smaller size and data is lost in the conversion." ;
    skos:exactMatch d3f:CWE-197,
        cwe:CWE-197 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE198 a owl:Class ;
    rdfs:label "CWE_198" ;
    d3f:cwe-id "CWE-198" ;
    dcterms:title "Use of Incorrect Byte Ordering" ;
    rdfs:subClassOf d3f:CWE188 ;
    skos:altLabel "CWE-198" ;
    skos:definition "The product receives input from an upstream component, but it does not account for byte ordering (e.g. big-endian and little-endian) when processing the input, causing an incorrect number or value to be used." ;
    skos:exactMatch d3f:CWE-198,
        cwe:CWE-198 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE202 a owl:Class ;
    rdfs:label "CWE_202" ;
    d3f:cwe-id "CWE-202" ;
    dcterms:title "Exposure of Sensitive Information Through Data Queries" ;
    rdfs:subClassOf d3f:CWE1230 ;
    skos:altLabel "CWE-202" ;
    skos:definition "When trying to keep information confidential, an attacker can often infer some of the information by using statistics." ;
    skos:exactMatch d3f:CWE-202,
        cwe:CWE-202 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE204 a owl:Class ;
    rdfs:label "CWE_204" ;
    d3f:cwe-id "CWE-204" ;
    dcterms:title "Observable Response Discrepancy" ;
    rdfs:subClassOf d3f:CWE203 ;
    skos:altLabel "CWE-204" ;
    skos:definition "The product provides different responses to incoming requests in a way that reveals internal state information to an unauthorized actor outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-204,
        cwe:CWE-204 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE206 a owl:Class ;
    rdfs:label "CWE_206" ;
    d3f:cwe-id "CWE-206" ;
    dcterms:title "Observable Internal Behavioral Discrepancy" ;
    rdfs:subClassOf d3f:CWE205 ;
    skos:altLabel "CWE-206" ;
    skos:definition "The product performs multiple behaviors that are combined to produce a single result, but the individual behaviors are observable separately in a way that allows attackers to reveal internal state or internal decision points." ;
    skos:exactMatch d3f:CWE-206,
        cwe:CWE-206 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE207 a owl:Class ;
    rdfs:label "CWE_207" ;
    d3f:cwe-id "CWE-207" ;
    dcterms:title "Observable Behavioral Discrepancy With Equivalent Products" ;
    rdfs:subClassOf d3f:CWE205 ;
    skos:altLabel "CWE-207" ;
    skos:definition "The product operates in an environment in which its existence or specific identity should not be known, but it behaves differently than other products with equivalent functionality, in a way that is observable to an attacker." ;
    skos:exactMatch d3f:CWE-207,
        cwe:CWE-207 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE210 a owl:Class ;
    rdfs:label "CWE_210" ;
    d3f:cwe-id "CWE-210" ;
    dcterms:title "Self-generated Error Message Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE209 ;
    skos:altLabel "CWE-210" ;
    skos:definition "The product identifies an error condition and creates its own diagnostic or error messages that contain sensitive information." ;
    skos:exactMatch d3f:CWE-210,
        cwe:CWE-210 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE213 a owl:Class ;
    rdfs:label "CWE_213" ;
    d3f:cwe-id "CWE-213" ;
    dcterms:title "Exposure of Sensitive Information Due to Incompatible Policies" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-213" ;
    skos:definition "The product's intended functionality exposes information to certain actors in accordance with the developer's security policy, but this information is regarded as sensitive according to the intended security policies of other stakeholders such as the product's administrator, users, or others whose information is being processed." ;
    skos:exactMatch d3f:CWE-213,
        cwe:CWE-213 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE214 a owl:Class ;
    rdfs:label "CWE_214" ;
    d3f:cwe-id "CWE-214" ;
    dcterms:title "Invocation of Process Using Visible Sensitive Information" ;
    rdfs:subClassOf d3f:CWE497 ;
    skos:altLabel "CWE-214" ;
    skos:definition "A process is invoked with sensitive command-line arguments, environment variables, or other elements that can be seen by other processes on the operating system." ;
    skos:exactMatch d3f:CWE-214,
        cwe:CWE-214 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE215 a owl:Class ;
    rdfs:label "CWE_215" ;
    d3f:cwe-id "CWE-215" ;
    dcterms:title "Insertion of Sensitive Information Into Debugging Code" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-215" ;
    skos:definition "The product inserts sensitive information into debugging code, which could expose this information if the debugging code is not disabled in production." ;
    skos:exactMatch d3f:CWE-215,
        cwe:CWE-215 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE220 a owl:Class ;
    rdfs:label "CWE_220" ;
    d3f:cwe-id "CWE-220" ;
    dcterms:title "Storage of File With Sensitive Data Under FTP Root" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-220" ;
    skos:definition "The product stores sensitive data under the FTP server root with insufficient access control, which might make it accessible to untrusted parties." ;
    skos:exactMatch d3f:CWE-220,
        cwe:CWE-220 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE222 a owl:Class ;
    rdfs:label "CWE_222" ;
    d3f:cwe-id "CWE-222" ;
    dcterms:title "Truncation of Security-relevant Information" ;
    rdfs:subClassOf d3f:CWE221 ;
    skos:altLabel "CWE-222" ;
    skos:definition "The product truncates the display, recording, or processing of security-relevant information in a way that can obscure the source or nature of an attack." ;
    skos:exactMatch d3f:CWE-222,
        cwe:CWE-222 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE224 a owl:Class ;
    rdfs:label "CWE_224" ;
    d3f:cwe-id "CWE-224" ;
    dcterms:title "Obscured Security-relevant Information by Alternate Name" ;
    rdfs:subClassOf d3f:CWE221 ;
    skos:altLabel "CWE-224" ;
    skos:definition "The product records security-relevant information according to an alternate name of the affected entity, instead of the canonical name." ;
    skos:exactMatch d3f:CWE-224,
        cwe:CWE-224 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE230 a owl:Class ;
    rdfs:label "CWE_230" ;
    d3f:cwe-id "CWE-230" ;
    dcterms:title "Improper Handling of Missing Values" ;
    rdfs:subClassOf d3f:CWE229 ;
    skos:altLabel "CWE-230" ;
    skos:definition "The product does not handle or incorrectly handles when a parameter, field, or argument name is specified, but the associated value is missing, i.e. it is empty, blank, or null." ;
    skos:exactMatch d3f:CWE-230,
        cwe:CWE-230 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE231 a owl:Class ;
    rdfs:label "CWE_231" ;
    d3f:cwe-id "CWE-231" ;
    dcterms:title "Improper Handling of Extra Values" ;
    rdfs:subClassOf d3f:CWE229 ;
    skos:altLabel "CWE-231" ;
    skos:definition "The product does not handle or incorrectly handles when more values are provided than expected." ;
    skos:exactMatch d3f:CWE-231,
        cwe:CWE-231 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE232 a owl:Class ;
    rdfs:label "CWE_232" ;
    d3f:cwe-id "CWE-232" ;
    dcterms:title "Improper Handling of Undefined Values" ;
    rdfs:subClassOf d3f:CWE229 ;
    skos:altLabel "CWE-232" ;
    skos:definition "The product does not handle or incorrectly handles when a value is not defined or supported for the associated parameter, field, or argument name." ;
    skos:exactMatch d3f:CWE-232,
        cwe:CWE-232 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE234 a owl:Class ;
    rdfs:label "CWE_234" ;
    d3f:cwe-id "CWE-234" ;
    dcterms:title "Failure to Handle Missing Parameter" ;
    rdfs:subClassOf d3f:CWE233 ;
    skos:altLabel "CWE-234" ;
    skos:definition "If too few arguments are sent to a function, the function will still pop the expected number of arguments from the stack. Potentially, a variable number of arguments could be exhausted in a function as well." ;
    skos:exactMatch d3f:CWE-234,
        cwe:CWE-234 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE235 a owl:Class ;
    rdfs:label "CWE_235" ;
    d3f:cwe-id "CWE-235" ;
    dcterms:title "Improper Handling of Extra Parameters" ;
    rdfs:subClassOf d3f:CWE233 ;
    skos:altLabel "CWE-235" ;
    skos:definition "The product does not handle or incorrectly handles when the number of parameters, fields, or arguments with the same name exceeds the expected amount." ;
    skos:exactMatch d3f:CWE-235,
        cwe:CWE-235 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE236 a owl:Class ;
    rdfs:label "CWE_236" ;
    d3f:cwe-id "CWE-236" ;
    dcterms:title "Improper Handling of Undefined Parameters" ;
    rdfs:subClassOf d3f:CWE233 ;
    skos:altLabel "CWE-236" ;
    skos:definition "The product does not handle or incorrectly handles when a particular parameter, field, or argument name is not defined or supported by the product." ;
    skos:exactMatch d3f:CWE-236,
        cwe:CWE-236 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE238 a owl:Class ;
    rdfs:label "CWE_238" ;
    d3f:cwe-id "CWE-238" ;
    dcterms:title "Improper Handling of Incomplete Structural Elements" ;
    rdfs:subClassOf d3f:CWE237 ;
    skos:altLabel "CWE-238" ;
    skos:definition "The product does not handle or incorrectly handles when a particular structural element is not completely specified." ;
    skos:exactMatch d3f:CWE-238,
        cwe:CWE-238 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE239 a owl:Class ;
    rdfs:label "CWE_239" ;
    d3f:cwe-id "CWE-239" ;
    dcterms:title "Failure to Handle Incomplete Element" ;
    rdfs:subClassOf d3f:CWE237 ;
    skos:altLabel "CWE-239" ;
    skos:definition "The product does not properly handle when a particular element is not completely specified." ;
    skos:exactMatch d3f:CWE-239,
        cwe:CWE-239 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE24 a owl:Class ;
    rdfs:label "CWE_24" ;
    d3f:cwe-id "CWE-24" ;
    dcterms:title "Path Traversal: '../filedir'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-24" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"../\" sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-24,
        cwe:CWE-24 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE241 a owl:Class ;
    rdfs:label "CWE_241" ;
    d3f:cwe-id "CWE-241" ;
    dcterms:title "Improper Handling of Unexpected Data Type" ;
    rdfs:subClassOf d3f:CWE228 ;
    skos:altLabel "CWE-241" ;
    skos:definition "The product does not handle or incorrectly handles when a particular element is not the expected type, e.g. it expects a digit (0-9) but is provided with a letter (A-Z)." ;
    skos:exactMatch d3f:CWE-241,
        cwe:CWE-241 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE242 a owl:Class ;
    rdfs:label "CWE_242" ;
    d3f:cwe-id "CWE-242" ;
    dcterms:title "Use of Inherently Dangerous Function" ;
    rdfs:subClassOf d3f:CWE1177 ;
    skos:altLabel "CWE-242" ;
    skos:definition "The product calls a function that can never be guaranteed to work safely." ;
    skos:exactMatch d3f:CWE-242,
        cwe:CWE-242 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE243 a owl:Class ;
    rdfs:label "CWE_243" ;
    d3f:cwe-id "CWE-243" ;
    dcterms:title "Creation of chroot Jail Without Changing Working Directory" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE669 ],
        d3f:CWE573 ;
    skos:altLabel "CWE-243" ;
    skos:definition "The product uses the chroot() system call to create a jail, but does not change the working directory afterward. This does not prevent access to files outside of the jail." ;
    skos:exactMatch d3f:CWE-243,
        cwe:CWE-243 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE244 a owl:Class ;
    rdfs:label "CWE_244" ;
    d3f:cwe-id "CWE-244" ;
    dcterms:title "Improper Clearing of Heap Memory Before Release ('Heap Inspection')" ;
    rdfs:subClassOf d3f:CWE226 ;
    skos:altLabel "CWE-244" ;
    skos:definition "Using realloc() to resize buffers that store sensitive information can leave the sensitive information exposed to attack, because it is not removed from memory." ;
    skos:exactMatch d3f:CWE-244,
        cwe:CWE-244 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE245 a owl:Class ;
    rdfs:label "CWE_245" ;
    d3f:cwe-id "CWE-245" ;
    dcterms:title "J2EE Bad Practices: Direct Management of Connections" ;
    rdfs:subClassOf d3f:CWE695 ;
    skos:altLabel "CWE-245" ;
    skos:definition "The J2EE application directly manages connections, instead of using the container's connection management facilities." ;
    skos:exactMatch d3f:CWE-245,
        cwe:CWE-245 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE246 a owl:Class ;
    rdfs:label "CWE_246" ;
    d3f:cwe-id "CWE-246" ;
    dcterms:title "J2EE Bad Practices: Direct Use of Sockets" ;
    rdfs:subClassOf d3f:CWE695 ;
    skos:altLabel "CWE-246" ;
    skos:definition "The J2EE application directly uses sockets instead of using framework method calls." ;
    skos:exactMatch d3f:CWE-246,
        cwe:CWE-246 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE25 a owl:Class ;
    rdfs:label "CWE_25" ;
    d3f:cwe-id "CWE-25" ;
    dcterms:title "Path Traversal: '/../filedir'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-25" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"/../\" sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-25,
        cwe:CWE-25 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE250 a owl:Class ;
    rdfs:label "CWE_250" ;
    d3f:cwe-id "CWE-250" ;
    dcterms:title "Execution with Unnecessary Privileges" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE657 ],
        d3f:CWE269 ;
    skos:altLabel "CWE-250" ;
    skos:definition "The product performs an operation at a privilege level that is higher than the minimum level required, which creates new weaknesses or amplifies the consequences of other weaknesses." ;
    skos:exactMatch d3f:CWE-250,
        cwe:CWE-250 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE253 a owl:Class ;
    rdfs:label "CWE_253" ;
    d3f:cwe-id "CWE-253" ;
    dcterms:title "Incorrect Check of Function Return Value" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE754 ],
        d3f:CWE573 ;
    skos:altLabel "CWE-253" ;
    skos:definition "The product incorrectly checks a return value from a function, which prevents it from detecting errors or exceptional conditions." ;
    skos:exactMatch d3f:CWE-253,
        cwe:CWE-253 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE256 a owl:Class ;
    rdfs:label "CWE_256" ;
    d3f:cwe-id "CWE-256" ;
    dcterms:title "Plaintext Storage of a Password" ;
    rdfs:subClassOf d3f:CWE522 ;
    skos:altLabel "CWE-256" ;
    skos:definition "Storing a password in plaintext may result in a system compromise." ;
    skos:exactMatch d3f:CWE-256,
        cwe:CWE-256 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE257 a owl:Class ;
    rdfs:label "CWE_257" ;
    d3f:cwe-id "CWE-257" ;
    dcterms:title "Storing Passwords in a Recoverable Format" ;
    rdfs:subClassOf d3f:CWE522 ;
    skos:altLabel "CWE-257" ;
    skos:definition "The storage of passwords in a recoverable format makes them subject to password reuse attacks by malicious users. In fact, it should be noted that recoverable encrypted passwords provide no significant benefit over plaintext passwords since they are subject not only to reuse by malicious attackers but also by malicious insiders. If a system administrator can recover a password directly, or use a brute force search on the available information, the administrator can use the password on other accounts." ;
    skos:exactMatch d3f:CWE-257,
        cwe:CWE-257 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE258 a owl:Class ;
    rdfs:label "CWE_258" ;
    d3f:cwe-id "CWE-258" ;
    dcterms:title "Empty Password in Configuration File" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE521 ],
        d3f:CWE260 ;
    skos:altLabel "CWE-258" ;
    skos:definition "Using an empty string as a password is insecure." ;
    skos:exactMatch d3f:CWE-258,
        cwe:CWE-258 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE259 a owl:Class ;
    rdfs:label "CWE_259" ;
    d3f:cwe-id "CWE-259" ;
    dcterms:title "Use of Hard-coded Password" ;
    rdfs:subClassOf d3f:CWE798 ;
    skos:altLabel "CWE-259" ;
    skos:definition "The product contains a hard-coded password, which it uses for its own inbound authentication or for outbound communication to external components." ;
    skos:exactMatch d3f:CWE-259,
        cwe:CWE-259 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE26 a owl:Class ;
    rdfs:label "CWE_26" ;
    d3f:cwe-id "CWE-26" ;
    dcterms:title "Path Traversal: '/dir/../filename'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-26" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"/dir/../filename\" sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-26,
        cwe:CWE-26 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE261 a owl:Class ;
    rdfs:label "CWE_261" ;
    d3f:cwe-id "CWE-261" ;
    dcterms:title "Weak Encoding for Password" ;
    rdfs:subClassOf d3f:CWE522 ;
    skos:altLabel "CWE-261" ;
    skos:definition "Obscuring a password with a trivial encoding does not protect the password." ;
    skos:exactMatch d3f:CWE-261,
        cwe:CWE-261 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE262 a owl:Class ;
    rdfs:label "CWE_262" ;
    d3f:cwe-id "CWE-262" ;
    dcterms:title "Not Using Password Aging" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-262" ;
    skos:definition "The product does not have a mechanism in place for managing password aging." ;
    skos:exactMatch d3f:CWE-262,
        cwe:CWE-262 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE263 a owl:Class ;
    rdfs:label "CWE_263" ;
    d3f:cwe-id "CWE-263" ;
    dcterms:title "Password Aging with Long Expiration" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-263" ;
    skos:definition "The product supports password aging, but the expiration period is too long." ;
    skos:exactMatch d3f:CWE-263,
        cwe:CWE-263 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE268 a owl:Class ;
    rdfs:label "CWE_268" ;
    d3f:cwe-id "CWE-268" ;
    dcterms:title "Privilege Chaining" ;
    rdfs:subClassOf d3f:CWE269 ;
    skos:altLabel "CWE-268" ;
    skos:definition "Two distinct privileges, roles, capabilities, or rights can be combined in a way that allows an entity to perform unsafe actions that would not be allowed without that combination." ;
    skos:exactMatch d3f:CWE-268,
        cwe:CWE-268 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE27 a owl:Class ;
    rdfs:label "CWE_27" ;
    d3f:cwe-id "CWE-27" ;
    dcterms:title "Path Traversal: 'dir/../../filename'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-27" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize multiple internal \"../\" sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-27,
        cwe:CWE-27 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE270 a owl:Class ;
    rdfs:label "CWE_270" ;
    d3f:cwe-id "CWE-270" ;
    dcterms:title "Privilege Context Switching Error" ;
    rdfs:subClassOf d3f:CWE269 ;
    skos:altLabel "CWE-270" ;
    skos:definition "The product does not properly manage privileges while it is switching between different contexts that have different privileges or spheres of control." ;
    skos:exactMatch d3f:CWE-270,
        cwe:CWE-270 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE272 a owl:Class ;
    rdfs:label "CWE_272" ;
    d3f:cwe-id "CWE-272" ;
    dcterms:title "Least Privilege Violation" ;
    rdfs:subClassOf d3f:CWE271 ;
    skos:altLabel "CWE-272" ;
    skos:definition "The elevated privilege level required to perform operations such as chroot() should be dropped immediately after the operation is performed." ;
    skos:exactMatch d3f:CWE-272,
        cwe:CWE-272 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE273 a owl:Class ;
    rdfs:label "CWE_273" ;
    d3f:cwe-id "CWE-273" ;
    dcterms:title "Improper Check for Dropped Privileges" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE754 ],
        d3f:CWE271 ;
    skos:altLabel "CWE-273" ;
    skos:definition "The product attempts to drop privileges but does not check or incorrectly checks to see if the drop succeeded." ;
    skos:exactMatch d3f:CWE-273,
        cwe:CWE-273 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE274 a owl:Class ;
    rdfs:label "CWE_274" ;
    d3f:cwe-id "CWE-274" ;
    dcterms:title "Improper Handling of Insufficient Privileges" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        d3f:CWE269 ;
    skos:altLabel "CWE-274" ;
    skos:definition "The product does not handle or incorrectly handles when it has insufficient privileges to perform an operation, leading to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-274,
        cwe:CWE-274 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE276 a owl:Class ;
    rdfs:label "CWE_276" ;
    d3f:cwe-id "CWE-276" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Incorrect Default Permissions" ;
    rdfs:subClassOf d3f:CWE732 ;
    skos:altLabel "CWE-276" ;
    skos:definition "During installation, installed file permissions are set to allow anyone to modify those files." ;
    skos:exactMatch d3f:CWE-276,
        cwe:CWE-276 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE277 a owl:Class ;
    rdfs:label "CWE_277" ;
    d3f:cwe-id "CWE-277" ;
    dcterms:title "Insecure Inherited Permissions" ;
    rdfs:subClassOf d3f:CWE732 ;
    skos:altLabel "CWE-277" ;
    skos:definition "A product defines a set of insecure permissions that are inherited by objects that are created by the program." ;
    skos:exactMatch d3f:CWE-277,
        cwe:CWE-277 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE278 a owl:Class ;
    rdfs:label "CWE_278" ;
    d3f:cwe-id "CWE-278" ;
    dcterms:title "Insecure Preserved Inherited Permissions" ;
    rdfs:subClassOf d3f:CWE732 ;
    skos:altLabel "CWE-278" ;
    skos:definition "A product inherits a set of insecure permissions for an object, e.g. when copying from an archive file, without user awareness or involvement." ;
    skos:exactMatch d3f:CWE-278,
        cwe:CWE-278 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE279 a owl:Class ;
    rdfs:label "CWE_279" ;
    d3f:cwe-id "CWE-279" ;
    dcterms:title "Incorrect Execution-Assigned Permissions" ;
    rdfs:subClassOf d3f:CWE732 ;
    skos:altLabel "CWE-279" ;
    skos:definition "While it is executing, the product sets the permissions of an object in a way that violates the intended permissions that have been specified by the user." ;
    skos:exactMatch d3f:CWE-279,
        cwe:CWE-279 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE28 a owl:Class ;
    rdfs:label "CWE_28" ;
    d3f:cwe-id "CWE-28" ;
    dcterms:title "Path Traversal: '..\\filedir'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-28" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"..\\\" sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-28,
        cwe:CWE-28 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE280 a owl:Class ;
    rdfs:label "CWE_280" ;
    d3f:cwe-id "CWE-280" ;
    dcterms:title "Improper Handling of Insufficient Permissions or Privileges" ;
    rdfs:subClassOf d3f:CWE755 ;
    skos:altLabel "CWE-280" ;
    skos:definition "The product does not handle or incorrectly handles when it has insufficient privileges to access resources or functionality as specified by their permissions. This may cause it to follow unexpected code paths that may leave the product in an invalid state." ;
    skos:exactMatch d3f:CWE-280,
        cwe:CWE-280 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE281 a owl:Class ;
    rdfs:label "CWE_281" ;
    d3f:cwe-id "CWE-281" ;
    dcterms:title "Improper Preservation of Permissions" ;
    rdfs:subClassOf d3f:CWE732 ;
    skos:altLabel "CWE-281" ;
    skos:definition "The product does not preserve permissions or incorrectly preserves permissions when copying, restoring, or sharing objects, which can cause them to have less restrictive permissions than intended." ;
    skos:exactMatch d3f:CWE-281,
        cwe:CWE-281 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE283 a owl:Class ;
    rdfs:label "CWE_283" ;
    d3f:cwe-id "CWE-283" ;
    dcterms:title "Unverified Ownership" ;
    rdfs:subClassOf d3f:CWE282 ;
    skos:altLabel "CWE-283" ;
    skos:definition "The product does not properly verify that a critical resource is owned by the proper entity." ;
    skos:exactMatch d3f:CWE-283,
        cwe:CWE-283 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE289 a owl:Class ;
    rdfs:label "CWE_289" ;
    d3f:cwe-id "CWE-289" ;
    dcterms:title "Authentication Bypass by Alternate Name" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-289" ;
    skos:definition "The product performs authentication based on the name of a resource being accessed, or the name of the actor performing the access, but it does not properly check all possible names for that resource or actor." ;
    skos:exactMatch d3f:CWE-289,
        cwe:CWE-289 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE29 a owl:Class ;
    rdfs:label "CWE_29" ;
    d3f:cwe-id "CWE-29" ;
    dcterms:title "Path Traversal: '\\..\\filename'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-29" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '\\..\\filename' (leading backslash dot dot) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-29,
        cwe:CWE-29 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE291 a owl:Class ;
    rdfs:label "CWE_291" ;
    d3f:cwe-id "CWE-291" ;
    dcterms:title "Reliance on IP Address for Authentication" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE471 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE923 ],
        d3f:CWE290 ;
    skos:altLabel "CWE-291" ;
    skos:definition "The product uses an IP address for authentication." ;
    skos:exactMatch d3f:CWE-291,
        cwe:CWE-291 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE293 a owl:Class ;
    rdfs:label "CWE_293" ;
    d3f:cwe-id "CWE-293" ;
    d3f:synonym "referrer" ;
    dcterms:title "Using Referer Field for Authentication" ;
    rdfs:subClassOf d3f:CWE290 ;
    skos:altLabel "CWE-293" ;
    skos:definition "The referer field in HTTP requests can be easily modified and, as such, is not a valid means of message integrity checking." ;
    skos:exactMatch d3f:CWE-293,
        cwe:CWE-293 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE294 a owl:Class ;
    rdfs:label "CWE_294" ;
    d3f:cwe-id "CWE-294" ;
    dcterms:title "Authentication Bypass by Capture-replay" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-294" ;
    skos:definition "A capture-replay flaw exists when the design of the product makes it possible for a malicious user to sniff network traffic and bypass authentication by replaying it to the server in question to the same effect as the original message (or with minor changes)." ;
    skos:exactMatch d3f:CWE-294,
        cwe:CWE-294 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE296 a owl:Class ;
    rdfs:label "CWE_296" ;
    d3f:cwe-id "CWE-296" ;
    dcterms:title "Improper Following of a Certificate's Chain of Trust" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE573 ],
        d3f:CWE295 ;
    skos:altLabel "CWE-296" ;
    skos:definition "The product does not follow, or incorrectly follows, the chain of trust for a certificate back to a trusted root certificate, resulting in incorrect trust of any resource that is associated with that certificate." ;
    skos:exactMatch d3f:CWE-296,
        cwe:CWE-296 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE297 a owl:Class ;
    rdfs:label "CWE_297" ;
    d3f:cwe-id "CWE-297" ;
    dcterms:title "Improper Validation of Certificate with Host Mismatch" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE923 ],
        d3f:CWE295 ;
    skos:altLabel "CWE-297" ;
    skos:definition "The product communicates with a host that provides a certificate, but the product does not properly ensure that the certificate is actually associated with that host." ;
    skos:exactMatch d3f:CWE-297,
        cwe:CWE-297 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE298 a owl:Class ;
    rdfs:label "CWE_298" ;
    d3f:cwe-id "CWE-298" ;
    dcterms:title "Improper Validation of Certificate Expiration" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE672 ],
        d3f:CWE295 ;
    skos:altLabel "CWE-298" ;
    skos:definition "A certificate expiration is not validated or is incorrectly validated, so trust may be assigned to certificates that have been abandoned due to age." ;
    skos:exactMatch d3f:CWE-298,
        cwe:CWE-298 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE30 a owl:Class ;
    rdfs:label "CWE_30" ;
    d3f:cwe-id "CWE-30" ;
    dcterms:title "Path Traversal: '\\dir\\..\\filename'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-30" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '\\dir\\..\\filename' (leading backslash dot dot) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-30,
        cwe:CWE-30 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE300 a owl:Class ;
    rdfs:label "CWE_300" ;
    d3f:cwe-id "CWE-300" ;
    d3f:synonym "Adversary-in-the-Middle / AITM" ;
    dcterms:title "Channel Accessible by Non-Endpoint" ;
    rdfs:subClassOf d3f:CWE923 ;
    skos:altLabel "CWE-300" ;
    skos:definition "The product does not adequately verify the identity of actors at both ends of a communication channel, or does not adequately ensure the integrity of the channel, in a way that allows the channel to be accessed or influenced by an actor that is not an endpoint." ;
    skos:exactMatch d3f:CWE-300,
        cwe:CWE-300 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE301 a owl:Class ;
    rdfs:label "CWE_301" ;
    d3f:cwe-id "CWE-301" ;
    dcterms:title "Reflection Attack in an Authentication Protocol" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-301" ;
    skos:definition "Simple authentication protocols are subject to reflection attacks if a malicious user can use the target machine to impersonate a trusted user." ;
    skos:exactMatch d3f:CWE-301,
        cwe:CWE-301 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE302 a owl:Class ;
    rdfs:label "CWE_302" ;
    d3f:cwe-id "CWE-302" ;
    dcterms:title "Authentication Bypass by Assumed-Immutable Data" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE807 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-302" ;
    skos:definition "The authentication scheme or implementation uses key data elements that are assumed to be immutable, but can be controlled or modified by the attacker." ;
    skos:exactMatch d3f:CWE-302,
        cwe:CWE-302 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE304 a owl:Class ;
    rdfs:label "CWE_304" ;
    d3f:cwe-id "CWE-304" ;
    dcterms:title "Missing Critical Step in Authentication" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE573 ],
        d3f:CWE303 ;
    skos:altLabel "CWE-304" ;
    skos:definition "The product implements an authentication technique, but it skips a step that weakens the technique." ;
    skos:exactMatch d3f:CWE-304,
        cwe:CWE-304 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE305 a owl:Class ;
    rdfs:label "CWE_305" ;
    d3f:cwe-id "CWE-305" ;
    dcterms:title "Authentication Bypass by Primary Weakness" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-305" ;
    skos:definition "The authentication algorithm is sound, but the implemented mechanism can be bypassed as the result of a separate weakness that is primary to the authentication error." ;
    skos:exactMatch d3f:CWE-305,
        cwe:CWE-305 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE307 a owl:Class ;
    rdfs:label "CWE_307" ;
    d3f:cwe-id "CWE-307" ;
    dcterms:title "Improper Restriction of Excessive Authentication Attempts" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE799 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-307" ;
    skos:definition "The product does not implement sufficient measures to prevent multiple failed authentication attempts within a short time frame." ;
    skos:exactMatch d3f:CWE-307,
        cwe:CWE-307 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE308 a owl:Class ;
    rdfs:label "CWE_308" ;
    d3f:cwe-id "CWE-308" ;
    dcterms:title "Use of Single-factor Authentication" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE654 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-308" ;
    skos:definition "The use of single-factor authentication can lead to unnecessary risk of compromise when compared with the benefits of a dual-factor authentication scheme." ;
    skos:exactMatch d3f:CWE-308,
        cwe:CWE-308 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE309 a owl:Class ;
    rdfs:label "CWE_309" ;
    d3f:cwe-id "CWE-309" ;
    dcterms:title "Use of Password System for Primary Authentication" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE654 ],
        d3f:CWE1390 ;
    skos:altLabel "CWE-309" ;
    skos:definition "The use of password systems as the primary means of authentication may be subject to several flaws or shortcomings, each reducing the effectiveness of the mechanism." ;
    skos:exactMatch d3f:CWE-309,
        cwe:CWE-309 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE31 a owl:Class ;
    rdfs:label "CWE_31" ;
    d3f:cwe-id "CWE-31" ;
    dcterms:title "Path Traversal: 'dir\\..\\..\\filename'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-31" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize 'dir\\..\\..\\filename' (multiple internal backslash dot dot) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-31,
        cwe:CWE-31 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE313 a owl:Class ;
    rdfs:label "CWE_313" ;
    d3f:cwe-id "CWE-313" ;
    dcterms:title "Cleartext Storage in a File or on Disk" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-313" ;
    skos:definition "The product stores sensitive information in cleartext in a file, or on disk." ;
    skos:exactMatch d3f:CWE-313,
        cwe:CWE-313 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE314 a owl:Class ;
    rdfs:label "CWE_314" ;
    d3f:cwe-id "CWE-314" ;
    dcterms:title "Cleartext Storage in the Registry" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-314" ;
    skos:definition "The product stores sensitive information in cleartext in the registry." ;
    skos:exactMatch d3f:CWE-314,
        cwe:CWE-314 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE315 a owl:Class ;
    rdfs:label "CWE_315" ;
    d3f:cwe-id "CWE-315" ;
    dcterms:title "Cleartext Storage of Sensitive Information in a Cookie" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-315" ;
    skos:definition "The product stores sensitive information in cleartext in a cookie." ;
    skos:exactMatch d3f:CWE-315,
        cwe:CWE-315 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE316 a owl:Class ;
    rdfs:label "CWE_316" ;
    d3f:cwe-id "CWE-316" ;
    dcterms:title "Cleartext Storage of Sensitive Information in Memory" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-316" ;
    skos:definition "The product stores sensitive information in cleartext in memory." ;
    skos:exactMatch d3f:CWE-316,
        cwe:CWE-316 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE317 a owl:Class ;
    rdfs:label "CWE_317" ;
    d3f:cwe-id "CWE-317" ;
    dcterms:title "Cleartext Storage of Sensitive Information in GUI" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-317" ;
    skos:definition "The product stores sensitive information in cleartext within the GUI." ;
    skos:exactMatch d3f:CWE-317,
        cwe:CWE-317 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE318 a owl:Class ;
    rdfs:label "CWE_318" ;
    d3f:cwe-id "CWE-318" ;
    dcterms:title "Cleartext Storage of Sensitive Information in Executable" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-318" ;
    skos:definition "The product stores sensitive information in cleartext in an executable." ;
    skos:exactMatch d3f:CWE-318,
        cwe:CWE-318 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE32 a owl:Class ;
    rdfs:label "CWE_32" ;
    d3f:cwe-id "CWE-32" ;
    dcterms:title "Path Traversal: '...' (Triple Dot)" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-32" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '...' (triple dot) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-32,
        cwe:CWE-32 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE321 a owl:Class ;
    rdfs:label "CWE_321" ;
    d3f:cwe-id "CWE-321" ;
    dcterms:title "Use of Hard-coded Cryptographic Key" ;
    rdfs:subClassOf d3f:CWE798 ;
    skos:altLabel "CWE-321" ;
    skos:definition "The product uses a hard-coded, unchangeable cryptographic key." ;
    skos:exactMatch d3f:CWE-321,
        cwe:CWE-321 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE322 a owl:Class ;
    rdfs:label "CWE_322" ;
    d3f:cwe-id "CWE-322" ;
    dcterms:title "Key Exchange without Entity Authentication" ;
    rdfs:subClassOf d3f:CWE306 ;
    skos:altLabel "CWE-322" ;
    skos:definition "The product performs a key exchange with an actor without verifying the identity of that actor." ;
    skos:exactMatch d3f:CWE-322,
        cwe:CWE-322 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE323 a owl:Class ;
    rdfs:label "CWE_323" ;
    d3f:cwe-id "CWE-323" ;
    dcterms:title "Reusing a Nonce, Key Pair in Encryption" ;
    rdfs:subClassOf d3f:CWE344 ;
    skos:altLabel "CWE-323" ;
    skos:definition "Nonces should be used for the present occasion and only once." ;
    skos:exactMatch d3f:CWE-323,
        cwe:CWE-323 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE324 a owl:Class ;
    rdfs:label "CWE_324" ;
    d3f:cwe-id "CWE-324" ;
    dcterms:title "Use of a Key Past its Expiration Date" ;
    rdfs:subClassOf d3f:CWE672 ;
    skos:altLabel "CWE-324" ;
    skos:definition "The product uses a cryptographic key or password past its expiration date, which diminishes its safety significantly by increasing the timing window for cracking attacks against that key." ;
    skos:exactMatch d3f:CWE-324,
        cwe:CWE-324 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE325 a owl:Class ;
    rdfs:label "CWE_325" ;
    d3f:cwe-id "CWE-325" ;
    dcterms:title "Missing Cryptographic Step" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-325" ;
    skos:definition "The product does not implement a required step in a cryptographic algorithm, resulting in weaker encryption than advertised by the algorithm." ;
    skos:exactMatch d3f:CWE-325,
        cwe:CWE-325 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE329 a owl:Class ;
    rdfs:label "CWE_329" ;
    d3f:cwe-id "CWE-329" ;
    dcterms:title "Generation of Predictable IV with CBC Mode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE573 ],
        d3f:CWE1204 ;
    skos:altLabel "CWE-329" ;
    skos:definition "The product generates and uses a predictable initialization Vector (IV) with Cipher Block Chaining (CBC) Mode, which causes algorithms to be susceptible to dictionary attacks when they are encrypted under the same key." ;
    skos:exactMatch d3f:CWE-329,
        cwe:CWE-329 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE33 a owl:Class ;
    rdfs:label "CWE_33" ;
    d3f:cwe-id "CWE-33" ;
    dcterms:title "Path Traversal: '....' (Multiple Dot)" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-33" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '....' (multiple dot) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-33,
        cwe:CWE-33 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE332 a owl:Class ;
    rdfs:label "CWE_332" ;
    d3f:cwe-id "CWE-332" ;
    dcterms:title "Insufficient Entropy in PRNG" ;
    rdfs:subClassOf d3f:CWE331 ;
    skos:altLabel "CWE-332" ;
    skos:definition "The lack of entropy available for, or used by, a Pseudo-Random Number Generator (PRNG) can be a stability and security threat." ;
    skos:exactMatch d3f:CWE-332,
        cwe:CWE-332 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE333 a owl:Class ;
    rdfs:label "CWE_333" ;
    d3f:cwe-id "CWE-333" ;
    dcterms:title "Improper Handling of Insufficient Entropy in TRNG" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        d3f:CWE331 ;
    skos:altLabel "CWE-333" ;
    skos:definition "True random number generators (TRNG) generally have a limited source of entropy and therefore can fail or block." ;
    skos:exactMatch d3f:CWE-333,
        cwe:CWE-333 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE336 a owl:Class ;
    rdfs:label "CWE_336" ;
    d3f:cwe-id "CWE-336" ;
    dcterms:title "Same Seed in Pseudo-Random Number Generator (PRNG)" ;
    rdfs:subClassOf d3f:CWE335 ;
    skos:altLabel "CWE-336" ;
    skos:definition "A Pseudo-Random Number Generator (PRNG) uses the same seed each time the product is initialized." ;
    skos:exactMatch d3f:CWE-336,
        cwe:CWE-336 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE337 a owl:Class ;
    rdfs:label "CWE_337" ;
    d3f:cwe-id "CWE-337" ;
    dcterms:title "Predictable Seed in Pseudo-Random Number Generator (PRNG)" ;
    rdfs:subClassOf d3f:CWE335 ;
    skos:altLabel "CWE-337" ;
    skos:definition "A Pseudo-Random Number Generator (PRNG) is initialized from a predictable seed, such as the process ID or system time." ;
    skos:exactMatch d3f:CWE-337,
        cwe:CWE-337 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE338 a owl:Class ;
    rdfs:label "CWE_338" ;
    d3f:cwe-id "CWE-338" ;
    dcterms:title "Use of Cryptographically Weak Pseudo-Random Number Generator (PRNG)" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-338" ;
    skos:definition "The product uses a Pseudo-Random Number Generator (PRNG) in a security context, but the PRNG's algorithm is not cryptographically strong." ;
    skos:exactMatch d3f:CWE-338,
        cwe:CWE-338 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE339 a owl:Class ;
    rdfs:label "CWE_339" ;
    d3f:cwe-id "CWE-339" ;
    dcterms:title "Small Seed Space in PRNG" ;
    rdfs:subClassOf d3f:CWE335 ;
    skos:altLabel "CWE-339" ;
    skos:definition "A Pseudo-Random Number Generator (PRNG) uses a relatively small seed space, which makes it more susceptible to brute force attacks." ;
    skos:exactMatch d3f:CWE-339,
        cwe:CWE-339 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE34 a owl:Class ;
    rdfs:label "CWE_34" ;
    d3f:cwe-id "CWE-34" ;
    dcterms:title "Path Traversal: '....//'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-34" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '....//' (doubled dot dot slash) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-34,
        cwe:CWE-34 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE341 a owl:Class ;
    rdfs:label "CWE_341" ;
    d3f:cwe-id "CWE-341" ;
    dcterms:title "Predictable from Observable State" ;
    rdfs:subClassOf d3f:CWE340 ;
    skos:altLabel "CWE-341" ;
    skos:definition "A number or object is predictable based on observations that the attacker can make about the state of the system or network, such as time, process ID, etc." ;
    skos:exactMatch d3f:CWE-341,
        cwe:CWE-341 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE342 a owl:Class ;
    rdfs:label "CWE_342" ;
    d3f:cwe-id "CWE-342" ;
    dcterms:title "Predictable Exact Value from Previous Values" ;
    rdfs:subClassOf d3f:CWE340 ;
    skos:altLabel "CWE-342" ;
    skos:definition "An exact value or random number can be precisely predicted by observing previous values." ;
    skos:exactMatch d3f:CWE-342,
        cwe:CWE-342 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE343 a owl:Class ;
    rdfs:label "CWE_343" ;
    d3f:cwe-id "CWE-343" ;
    dcterms:title "Predictable Value Range from Previous Values" ;
    rdfs:subClassOf d3f:CWE340 ;
    skos:altLabel "CWE-343" ;
    skos:definition "The product's random number generator produces a series of values which, when observed, can be used to infer a relatively small range of possibilities for the next value that could be generated." ;
    skos:exactMatch d3f:CWE-343,
        cwe:CWE-343 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE347 a owl:Class ;
    rdfs:label "CWE_347" ;
    d3f:cwe-id "CWE-347" ;
    dcterms:title "Improper Verification of Cryptographic Signature" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-347" ;
    skos:definition "The product does not verify, or incorrectly verifies, the cryptographic signature for data." ;
    skos:exactMatch d3f:CWE-347,
        cwe:CWE-347 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE348 a owl:Class ;
    rdfs:label "CWE_348" ;
    d3f:cwe-id "CWE-348" ;
    dcterms:title "Use of Less Trusted Source" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-348" ;
    skos:definition "The product has two different sources of the same data or information, but it uses the source that has less support for verification, is less trusted, or is less resistant to attack." ;
    skos:exactMatch d3f:CWE-348,
        cwe:CWE-348 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE349 a owl:Class ;
    rdfs:label "CWE_349" ;
    d3f:cwe-id "CWE-349" ;
    dcterms:title "Acceptance of Extraneous Untrusted Data With Trusted Data" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-349" ;
    skos:definition "The product, when processing trusted data, accepts any untrusted data that is also included with the trusted data, treating the untrusted data as if it were trusted." ;
    skos:exactMatch d3f:CWE-349,
        cwe:CWE-349 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE35 a owl:Class ;
    rdfs:label "CWE_35" ;
    d3f:cwe-id "CWE-35" ;
    dcterms:title "Path Traversal: '.../...//'" ;
    rdfs:subClassOf d3f:CWE23 ;
    skos:altLabel "CWE-35" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '.../...//' (doubled triple dot slash) sequences that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-35,
        cwe:CWE-35 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE350 a owl:Class ;
    rdfs:label "CWE_350" ;
    d3f:cwe-id "CWE-350" ;
    dcterms:title "Reliance on Reverse DNS Resolution for a Security-Critical Action" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE807 ],
        d3f:CWE290 ;
    skos:altLabel "CWE-350" ;
    skos:definition "The product performs reverse DNS resolution on an IP address to obtain the hostname and make a security decision, but it does not properly ensure that the IP address is truly associated with the hostname." ;
    skos:exactMatch d3f:CWE-350,
        cwe:CWE-350 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE351 a owl:Class ;
    rdfs:label "CWE_351" ;
    d3f:cwe-id "CWE-351" ;
    dcterms:title "Insufficient Type Distinction" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-351" ;
    skos:definition "The product does not properly distinguish between different types of elements in a way that leads to insecure behavior." ;
    skos:exactMatch d3f:CWE-351,
        cwe:CWE-351 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE352 a owl:Class ;
    rdfs:label "CWE_352" ;
    d3f:cwe-id "CWE-352" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "CSRF" ;
    dcterms:title "Cross-Site Request Forgery (CSRF)" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-352" ;
    skos:definition "The web application does not, or cannot, sufficiently verify whether a request was intentionally provided by the user who sent the request, which could have originated from an unauthorized actor." ;
    skos:exactMatch d3f:CWE-352,
        cwe:CWE-352 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE353 a owl:Class ;
    rdfs:label "CWE_353" ;
    d3f:cwe-id "CWE-353" ;
    dcterms:title "Missing Support for Integrity Check" ;
    rdfs:subClassOf d3f:CWE345 ;
    skos:altLabel "CWE-353" ;
    skos:definition "The product uses a transmission protocol that does not include a mechanism for verifying the integrity of the data during transmission, such as a checksum." ;
    skos:exactMatch d3f:CWE-353,
        cwe:CWE-353 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE354 a owl:Class ;
    rdfs:label "CWE_354" ;
    d3f:cwe-id "CWE-354" ;
    dcterms:title "Improper Validation of Integrity Check Value" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE754 ],
        d3f:CWE345 ;
    skos:altLabel "CWE-354" ;
    skos:definition "The product does not validate or incorrectly validates the integrity check values or \"checksums\" of a message. This may prevent it from detecting if the data has been modified or corrupted in transmission." ;
    skos:exactMatch d3f:CWE-354,
        cwe:CWE-354 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE356 a owl:Class ;
    rdfs:label "CWE_356" ;
    d3f:cwe-id "CWE-356" ;
    dcterms:title "Product UI does not Warn User of Unsafe Actions" ;
    rdfs:subClassOf d3f:CWE221 ;
    skos:altLabel "CWE-356" ;
    skos:definition "The product's user interface does not warn the user before undertaking an unsafe action on behalf of that user. This makes it easier for attackers to trick users into inflicting damage to their system." ;
    skos:exactMatch d3f:CWE-356,
        cwe:CWE-356 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE358 a owl:Class ;
    rdfs:label "CWE_358" ;
    d3f:cwe-id "CWE-358" ;
    dcterms:title "Improperly Implemented Security Check for Standard" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE693 ],
        d3f:CWE573 ;
    skos:altLabel "CWE-358" ;
    skos:definition "The product does not implement or incorrectly implements one or more security-relevant checks as specified by the design of a standardized algorithm, protocol, or technique." ;
    skos:exactMatch d3f:CWE-358,
        cwe:CWE-358 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE359 a owl:Class ;
    rdfs:label "CWE_359" ;
    d3f:cwe-id "CWE-359" ;
    d3f:synonym "Privacy leak" ;
    dcterms:title "Exposure of Private Personal Information to an Unauthorized Actor" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-359" ;
    skos:definition "The product does not properly prevent a person's private, personal information from being accessed by actors who either (1) are not explicitly authorized to access the information or (2) do not have the implicit consent of the person about whom the information is collected." ;
    skos:exactMatch d3f:CWE-359,
        cwe:CWE-359 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE363 a owl:Class ;
    rdfs:label "CWE_363" ;
    d3f:cwe-id "CWE-363" ;
    dcterms:title "Race Condition Enabling Link Following" ;
    rdfs:subClassOf d3f:CWE367 ;
    skos:altLabel "CWE-363" ;
    skos:definition "The product checks the status of a file or directory before accessing it, which produces a race condition in which the file can be replaced with a link before the access is performed, causing the product to access the wrong file." ;
    skos:exactMatch d3f:CWE-363,
        cwe:CWE-363 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE366 a owl:Class ;
    rdfs:label "CWE_366" ;
    d3f:cwe-id "CWE-366" ;
    dcterms:title "Race Condition within a Thread" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-366" ;
    skos:definition "If two threads of execution use a resource simultaneously, there exists the possibility that resources may be used while invalid, in turn making the state of execution undefined." ;
    skos:exactMatch d3f:CWE-366,
        cwe:CWE-366 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE368 a owl:Class ;
    rdfs:label "CWE_368" ;
    d3f:cwe-id "CWE-368" ;
    dcterms:title "Context Switching Race Condition" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-368" ;
    skos:definition "A product performs a series of non-atomic actions to switch between contexts that cross privilege or other security boundaries, but a race condition allows an attacker to modify or misrepresent the product's behavior during the switch." ;
    skos:exactMatch d3f:CWE-368,
        cwe:CWE-368 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE369 a owl:Class ;
    rdfs:label "CWE_369" ;
    d3f:cwe-id "CWE-369" ;
    dcterms:title "Divide By Zero" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-369" ;
    skos:definition "The product divides a value by zero." ;
    skos:exactMatch d3f:CWE-369,
        cwe:CWE-369 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE37 a owl:Class ;
    rdfs:label "CWE_37" ;
    d3f:cwe-id "CWE-37" ;
    dcterms:title "Path Traversal: '/absolute/pathname/here'" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE36 ],
        d3f:CWE160 ;
    skos:altLabel "CWE-37" ;
    skos:definition "The product accepts input in the form of a slash absolute path ('/absolute/pathname/here') without appropriate validation, which can allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-37,
        cwe:CWE-37 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE370 a owl:Class ;
    rdfs:label "CWE_370" ;
    d3f:cwe-id "CWE-370" ;
    dcterms:title "Missing Check for Certificate Revocation after Initial Check" ;
    rdfs:subClassOf d3f:CWE299 ;
    skos:altLabel "CWE-370" ;
    skos:definition "The product does not check the revocation status of a certificate after its initial revocation check, which can cause the product to perform privileged actions even after the certificate is revoked at a later time." ;
    skos:exactMatch d3f:CWE-370,
        cwe:CWE-370 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE372 a owl:Class ;
    rdfs:label "CWE_372" ;
    d3f:cwe-id "CWE-372" ;
    dcterms:title "Incomplete Internal State Distinction" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-372" ;
    skos:definition "The product does not properly determine which state it is in, causing it to assume it is in state X when in fact it is in state Y, causing it to perform incorrect operations in a security-relevant manner." ;
    skos:exactMatch d3f:CWE-372,
        cwe:CWE-372 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE374 a owl:Class ;
    rdfs:label "CWE_374" ;
    d3f:cwe-id "CWE-374" ;
    dcterms:title "Passing Mutable Objects to an Untrusted Method" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-374" ;
    skos:definition "The product sends non-cloned mutable data as an argument to a method or function." ;
    skos:exactMatch d3f:CWE-374,
        cwe:CWE-374 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE375 a owl:Class ;
    rdfs:label "CWE_375" ;
    d3f:cwe-id "CWE-375" ;
    dcterms:title "Returning a Mutable Object to an Untrusted Caller" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-375" ;
    skos:definition "Sending non-cloned mutable data as a return value may result in that data being altered or deleted by the calling function." ;
    skos:exactMatch d3f:CWE-375,
        cwe:CWE-375 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE378 a owl:Class ;
    rdfs:label "CWE_378" ;
    d3f:cwe-id "CWE-378" ;
    dcterms:title "Creation of Temporary File With Insecure Permissions" ;
    rdfs:subClassOf d3f:CWE377 ;
    skos:altLabel "CWE-378" ;
    skos:definition "Opening temporary files without appropriate measures or controls can leave the file, its contents and any function that it impacts vulnerable to attack." ;
    skos:exactMatch d3f:CWE-378,
        cwe:CWE-378 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE379 a owl:Class ;
    rdfs:label "CWE_379" ;
    d3f:cwe-id "CWE-379" ;
    dcterms:title "Creation of Temporary File in Directory with Insecure Permissions" ;
    rdfs:subClassOf d3f:CWE377 ;
    skos:altLabel "CWE-379" ;
    skos:definition "The product creates a temporary file in a directory whose permissions allow unintended actors to determine the file's existence or otherwise access that file." ;
    skos:exactMatch d3f:CWE-379,
        cwe:CWE-379 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE38 a owl:Class ;
    rdfs:label "CWE_38" ;
    d3f:cwe-id "CWE-38" ;
    dcterms:title "Path Traversal: '\\absolute\\pathname\\here'" ;
    rdfs:subClassOf d3f:CWE36 ;
    skos:altLabel "CWE-38" ;
    skos:definition "The product accepts input in the form of a backslash absolute path ('\\absolute\\pathname\\here') without appropriate validation, which can allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-38,
        cwe:CWE-38 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE382 a owl:Class ;
    rdfs:label "CWE_382" ;
    d3f:cwe-id "CWE-382" ;
    dcterms:title "J2EE Bad Practices: Use of System.exit()" ;
    rdfs:subClassOf d3f:CWE705 ;
    skos:altLabel "CWE-382" ;
    skos:definition "A J2EE application uses System.exit(), which also shuts down its container." ;
    skos:exactMatch d3f:CWE-382,
        cwe:CWE-382 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE383 a owl:Class ;
    rdfs:label "CWE_383" ;
    d3f:cwe-id "CWE-383" ;
    dcterms:title "J2EE Bad Practices: Direct Use of Threads" ;
    rdfs:subClassOf d3f:CWE695 ;
    skos:altLabel "CWE-383" ;
    skos:definition "Thread management in a Web application is forbidden in some circumstances and is always highly error prone." ;
    skos:exactMatch d3f:CWE-383,
        cwe:CWE-383 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE384 a owl:Class ;
    rdfs:label "CWE_384" ;
    d3f:cwe-id "CWE-384" ;
    dcterms:title "Session Fixation" ;
    rdfs:subClassOf d3f:CWE610 ;
    skos:altLabel "CWE-384" ;
    skos:definition "Authenticating a user, or otherwise establishing a new user session, without invalidating any existing session identifier gives an attacker the opportunity to steal authenticated sessions." ;
    skos:exactMatch d3f:CWE-384,
        cwe:CWE-384 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE385 a owl:Class ;
    rdfs:label "CWE_385" ;
    d3f:cwe-id "CWE-385" ;
    dcterms:title "Covert Timing Channel" ;
    rdfs:subClassOf d3f:CWE514 ;
    skos:altLabel "CWE-385" ;
    skos:definition "Covert timing channels convey information by modulating some aspect of system behavior over time, so that the program receiving the information can observe system behavior and infer protected information." ;
    skos:exactMatch d3f:CWE-385,
        cwe:CWE-385 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE386 a owl:Class ;
    rdfs:label "CWE_386" ;
    d3f:cwe-id "CWE-386" ;
    dcterms:title "Symbolic Name not Mapping to Correct Object" ;
    rdfs:subClassOf d3f:CWE706 ;
    skos:altLabel "CWE-386" ;
    skos:definition "A constant symbolic reference to an object is used, even though the reference can resolve to a different object over time." ;
    skos:exactMatch d3f:CWE-386,
        cwe:CWE-386 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE39 a owl:Class ;
    rdfs:label "CWE_39" ;
    d3f:cwe-id "CWE-39" ;
    dcterms:title "Path Traversal: 'C:dirname'" ;
    rdfs:subClassOf d3f:CWE36 ;
    skos:altLabel "CWE-39" ;
    skos:definition "The product accepts input that contains a drive letter or Windows volume letter ('C:dirname') that potentially redirects access to an unintended location or arbitrary file." ;
    skos:exactMatch d3f:CWE-39,
        cwe:CWE-39 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE390 a owl:Class ;
    rdfs:label "CWE_390" ;
    d3f:cwe-id "CWE-390" ;
    dcterms:title "Detection of Error Condition Without Action" ;
    rdfs:subClassOf d3f:CWE755 ;
    skos:altLabel "CWE-390" ;
    skos:definition "The product detects a specific error, but takes no actions to handle the error." ;
    skos:exactMatch d3f:CWE-390,
        cwe:CWE-390 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE391 a owl:Class ;
    rdfs:label "CWE_391" ;
    d3f:cwe-id "CWE-391" ;
    dcterms:title "Unchecked Error Condition" ;
    rdfs:subClassOf d3f:CWE754 ;
    skos:altLabel "CWE-391" ;
    skos:definition "[PLANNED FOR DEPRECATION. SEE MAINTENANCE NOTES AND CONSIDER CWE-252, CWE-248, OR CWE-1069.] Ignoring exceptions and other error conditions may allow an attacker to induce unexpected behavior unnoticed." ;
    skos:exactMatch d3f:CWE-391,
        cwe:CWE-391 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE392 a owl:Class ;
    rdfs:label "CWE_392" ;
    d3f:cwe-id "CWE-392" ;
    dcterms:title "Missing Report of Error Condition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        d3f:CWE684 ;
    skos:altLabel "CWE-392" ;
    skos:definition "The product encounters an error but does not provide a status code or return value to indicate that an error has occurred." ;
    skos:exactMatch d3f:CWE-392,
        cwe:CWE-392 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE393 a owl:Class ;
    rdfs:label "CWE_393" ;
    d3f:cwe-id "CWE-393" ;
    dcterms:title "Return of Wrong Status Code" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        d3f:CWE684 ;
    skos:altLabel "CWE-393" ;
    skos:definition "A function or operation returns an incorrect return value or status code that does not indicate the true result of execution, causing the product to modify its behavior based on the incorrect result." ;
    skos:exactMatch d3f:CWE-393,
        cwe:CWE-393 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE394 a owl:Class ;
    rdfs:label "CWE_394" ;
    d3f:cwe-id "CWE-394" ;
    dcterms:title "Unexpected Status Code or Return Value" ;
    rdfs:subClassOf d3f:CWE754 ;
    skos:altLabel "CWE-394" ;
    skos:definition "The product does not properly check when a function or operation returns a value that is legitimate for the function, but is not expected by the product." ;
    skos:exactMatch d3f:CWE-394,
        cwe:CWE-394 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE395 a owl:Class ;
    rdfs:label "CWE_395" ;
    d3f:cwe-id "CWE-395" ;
    dcterms:title "Use of NullPointerException Catch to Detect NULL Pointer Dereference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        d3f:CWE705 ;
    skos:altLabel "CWE-395" ;
    skos:definition "Catching NullPointerException should not be used as an alternative to programmatic checks to prevent dereferencing a null pointer." ;
    skos:exactMatch d3f:CWE-395,
        cwe:CWE-395 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE396 a owl:Class ;
    rdfs:label "CWE_396" ;
    d3f:cwe-id "CWE-396" ;
    dcterms:title "Declaration of Catch for Generic Exception" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE705 ],
        d3f:CWE221 ;
    skos:altLabel "CWE-396" ;
    skos:definition "Catching overly broad exceptions promotes complex error handling code that is more likely to contain security vulnerabilities." ;
    skos:exactMatch d3f:CWE-396,
        cwe:CWE-396 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE397 a owl:Class ;
    rdfs:label "CWE_397" ;
    d3f:cwe-id "CWE-397" ;
    dcterms:title "Declaration of Throws for Generic Exception" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE703 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE705 ],
        d3f:CWE221 ;
    skos:altLabel "CWE-397" ;
    skos:definition "The product throws or raises an overly broad exceptions that can hide important details and produce inappropriate responses to certain conditions." ;
    skos:exactMatch d3f:CWE-397,
        cwe:CWE-397 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE40 a owl:Class ;
    rdfs:label "CWE_40" ;
    d3f:cwe-id "CWE-40" ;
    dcterms:title "Path Traversal: '\\\\UNC\\share\\name\\' (Windows UNC Share)" ;
    rdfs:subClassOf d3f:CWE36 ;
    skos:altLabel "CWE-40" ;
    skos:definition "The product accepts input that identifies a Windows UNC share ('\\\\UNC\\share\\name') that potentially redirects access to an unintended location or arbitrary file." ;
    skos:exactMatch d3f:CWE-40,
        cwe:CWE-40 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE401 a owl:Class ;
    rdfs:label "CWE_401" ;
    d3f:cwe-id "CWE-401" ;
    d3f:synonym "Memory Leak" ;
    dcterms:title "Missing Release of Memory after Effective Lifetime" ;
    rdfs:subClassOf d3f:CWE772 ;
    skos:altLabel "CWE-401" ;
    skos:definition "The product does not sufficiently track and release allocated memory after it has been used, making the memory unavailable for reallocation and reuse." ;
    skos:exactMatch d3f:CWE-401,
        cwe:CWE-401 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE403 a owl:Class ;
    rdfs:label "CWE_403" ;
    d3f:cwe-id "CWE-403" ;
    d3f:synonym "File descriptor leak" ;
    dcterms:title "Exposure of File Descriptor to Unintended Control Sphere ('File Descriptor Leak')" ;
    rdfs:subClassOf d3f:CWE402 ;
    skos:altLabel "CWE-403" ;
    skos:definition "A process does not close sensitive file descriptors before invoking a child process, which allows the child to perform unauthorized I/O operations using those descriptors." ;
    skos:exactMatch d3f:CWE-403,
        cwe:CWE-403 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE406 a owl:Class ;
    rdfs:label "CWE_406" ;
    d3f:cwe-id "CWE-406" ;
    dcterms:title "Insufficient Control of Network Message Volume (Network Amplification)" ;
    rdfs:subClassOf d3f:CWE405 ;
    skos:altLabel "CWE-406" ;
    skos:definition "The product does not sufficiently monitor or control transmitted network traffic volume, so that an actor can cause the product to transmit more traffic than should be allowed for that actor." ;
    skos:exactMatch d3f:CWE-406,
        cwe:CWE-406 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE408 a owl:Class ;
    rdfs:label "CWE_408" ;
    d3f:cwe-id "CWE-408" ;
    dcterms:title "Incorrect Behavior Order: Early Amplification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE696 ],
        d3f:CWE405 ;
    skos:altLabel "CWE-408" ;
    skos:definition "The product allows an entity to perform a legitimate but expensive operation before authentication or authorization has taken place." ;
    skos:exactMatch d3f:CWE-408,
        cwe:CWE-408 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE409 a owl:Class ;
    rdfs:label "CWE_409" ;
    d3f:cwe-id "CWE-409" ;
    dcterms:title "Improper Handling of Highly Compressed Data (Data Amplification)" ;
    rdfs:subClassOf d3f:CWE405 ;
    skos:altLabel "CWE-409" ;
    skos:definition "The product does not handle or incorrectly handles a compressed input with a very high compression ratio that produces a large output." ;
    skos:exactMatch d3f:CWE-409,
        cwe:CWE-409 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE410 a owl:Class ;
    rdfs:label "CWE_410" ;
    d3f:cwe-id "CWE-410" ;
    dcterms:title "Insufficient Resource Pool" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-410" ;
    skos:definition "The product's resource pool is not large enough to handle peak demand, which allows an attacker to prevent others from accessing the resource by using a (relatively) large number of requests for resources." ;
    skos:exactMatch d3f:CWE-410,
        cwe:CWE-410 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE412 a owl:Class ;
    rdfs:label "CWE_412" ;
    d3f:cwe-id "CWE-412" ;
    dcterms:title "Unrestricted Externally Accessible Lock" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-412" ;
    skos:definition "The product properly checks for the existence of a lock, but the lock can be externally controlled or influenced by an actor that is outside of the intended sphere of control." ;
    skos:exactMatch d3f:CWE-412,
        cwe:CWE-412 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE414 a owl:Class ;
    rdfs:label "CWE_414" ;
    d3f:cwe-id "CWE-414" ;
    dcterms:title "Missing Lock Check" ;
    rdfs:subClassOf d3f:CWE667 ;
    skos:altLabel "CWE-414" ;
    skos:definition "A product does not check to see if a lock is present before performing sensitive operations on a resource." ;
    skos:exactMatch d3f:CWE-414,
        cwe:CWE-414 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE415 a owl:Class ;
    rdfs:label "CWE_415" ;
    d3f:cwe-id "CWE-415" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Double-free" ;
    dcterms:title "Double Free" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE666 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE825 ],
        d3f:CWE1341 ;
    skos:altLabel "CWE-415" ;
    skos:definition "The product calls free() twice on the same memory address." ;
    skos:exactMatch d3f:CWE-415,
        cwe:CWE-415 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE416 a owl:Class ;
    rdfs:label "CWE_416" ;
    d3f:cwe-id "CWE-416" ;
    d3f:synonym "Dangling pointer" ;
    dcterms:title "Use After Free" ;
    rdfs:subClassOf d3f:CWE825 ;
    skos:altLabel "CWE-416" ;
    skos:definition "The product reuses or references memory after it has been freed. At some point afterward, the memory may be allocated again and saved in another pointer, while the original pointer references a location somewhere within the new allocation. Any operations using the original pointer are no longer valid because the memory \"belongs\" to the code that operates on the new pointer." ;
    skos:exactMatch d3f:CWE-416,
        cwe:CWE-416 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE419 a owl:Class ;
    rdfs:label "CWE_419" ;
    d3f:cwe-id "CWE-419" ;
    dcterms:title "Unprotected Primary Channel" ;
    rdfs:subClassOf d3f:CWE923 ;
    skos:altLabel "CWE-419" ;
    skos:definition "The product uses a primary channel for administration or restricted functionality, but it does not properly protect the channel." ;
    skos:exactMatch d3f:CWE-419,
        cwe:CWE-419 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE421 a owl:Class ;
    rdfs:label "CWE_421" ;
    d3f:cwe-id "CWE-421" ;
    dcterms:title "Race Condition During Access to Alternate Channel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE420 ],
        d3f:CWE362 ;
    skos:altLabel "CWE-421" ;
    skos:definition "The product opens an alternate channel to communicate with an authorized user, but the channel is accessible to other actors." ;
    skos:exactMatch d3f:CWE-421,
        cwe:CWE-421 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE422 a owl:Class ;
    rdfs:label "CWE_422" ;
    d3f:cwe-id "CWE-422" ;
    dcterms:title "Unprotected Windows Messaging Channel ('Shatter')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE420 ],
        d3f:CWE360 ;
    skos:altLabel "CWE-422" ;
    skos:definition "The product does not properly verify the source of a message in the Windows Messaging System while running at elevated privileges, creating an alternate channel through which an attacker can directly send a message to the product." ;
    skos:exactMatch d3f:CWE-422,
        cwe:CWE-422 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE425 a owl:Class ;
    rdfs:label "CWE_425" ;
    d3f:cwe-id "CWE-425" ;
    d3f:synonym "forced browsing" ;
    dcterms:title "Direct Request ('Forced Browsing')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE424 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE862 ],
        d3f:CWE288 ;
    skos:altLabel "CWE-425" ;
    skos:definition "The web application does not adequately enforce appropriate authorization on all restricted URLs, scripts, or files." ;
    skos:exactMatch d3f:CWE-425,
        cwe:CWE-425 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE426 a owl:Class ;
    rdfs:label "CWE_426" ;
    d3f:cwe-id "CWE-426" ;
    d3f:synonym "Untrusted Path" ;
    dcterms:title "Untrusted Search Path" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE673 ],
        d3f:CWE642 ;
    skos:altLabel "CWE-426" ;
    skos:definition "The product searches for critical resources using an externally-supplied search path that can point to resources that are not under the product's direct control." ;
    skos:exactMatch d3f:CWE-426,
        cwe:CWE-426 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE427 a owl:Class ;
    rdfs:label "CWE_427" ;
    d3f:cwe-id "CWE-427" ;
    d3f:synonym "Binary planting" ;
    dcterms:title "Uncontrolled Search Path Element" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-427" ;
    skos:definition "The product uses a fixed or controlled search path to find resources, but one or more locations in that path can be under the control of unintended actors." ;
    skos:exactMatch d3f:CWE-427,
        cwe:CWE-427 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE428 a owl:Class ;
    rdfs:label "CWE_428" ;
    d3f:cwe-id "CWE-428" ;
    dcterms:title "Unquoted Search Path or Element" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-428" ;
    skos:definition "The product uses a search path that contains an unquoted element, in which the element contains whitespace or other separators. This can cause the product to access resources in a parent path." ;
    skos:exactMatch d3f:CWE-428,
        cwe:CWE-428 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE43 a owl:Class ;
    rdfs:label "CWE_43" ;
    d3f:cwe-id "CWE-43" ;
    dcterms:title "Path Equivalence: 'filename....' (Multiple Trailing Dot)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE42 ],
        d3f:CWE163 ;
    skos:altLabel "CWE-43" ;
    skos:definition "The product accepts path input in the form of multiple trailing dot ('filedir....') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-43,
        cwe:CWE-43 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE430 a owl:Class ;
    rdfs:label "CWE_430" ;
    d3f:cwe-id "CWE-430" ;
    dcterms:title "Deployment of Wrong Handler" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-430" ;
    skos:definition "The wrong \"handler\" is assigned to process an object." ;
    skos:exactMatch d3f:CWE-430,
        cwe:CWE-430 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE431 a owl:Class ;
    rdfs:label "CWE_431" ;
    d3f:cwe-id "CWE-431" ;
    dcterms:title "Missing Handler" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-431" ;
    skos:definition "A handler is not available or implemented." ;
    skos:exactMatch d3f:CWE-431,
        cwe:CWE-431 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE432 a owl:Class ;
    rdfs:label "CWE_432" ;
    d3f:cwe-id "CWE-432" ;
    dcterms:title "Dangerous Signal Handler not Disabled During Sensitive Operations" ;
    rdfs:subClassOf d3f:CWE364 ;
    skos:altLabel "CWE-432" ;
    skos:definition "The product uses a signal handler that shares state with other signal handlers, but it does not properly mask or prevent those signal handlers from being invoked while the original signal handler is still running." ;
    skos:exactMatch d3f:CWE-432,
        cwe:CWE-432 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE433 a owl:Class ;
    rdfs:label "CWE_433" ;
    d3f:cwe-id "CWE-433" ;
    dcterms:title "Unparsed Raw Web Content Delivery" ;
    rdfs:subClassOf d3f:CWE219 ;
    skos:altLabel "CWE-433" ;
    skos:definition "The product stores raw content or supporting code under the web document root with an extension that is not specifically handled by the server." ;
    skos:exactMatch d3f:CWE-433,
        cwe:CWE-433 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE434 a owl:Class ;
    rdfs:label "CWE_434" ;
    d3f:cwe-id "CWE-434" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Unrestricted File Upload" ;
    dcterms:title "Unrestricted Upload of File with Dangerous Type" ;
    rdfs:subClassOf d3f:CWE669 ;
    skos:altLabel "CWE-434" ;
    skos:definition "The product allows the upload or transfer of dangerous file types that are automatically processed within its environment." ;
    skos:exactMatch d3f:CWE-434,
        cwe:CWE-434 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE437 a owl:Class ;
    rdfs:label "CWE_437" ;
    d3f:cwe-id "CWE-437" ;
    dcterms:title "Incomplete Model of Endpoint Features" ;
    rdfs:subClassOf d3f:CWE436 ;
    skos:altLabel "CWE-437" ;
    skos:definition "A product acts as an intermediary or monitor between two or more endpoints, but it does not have a complete model of an endpoint's features, behaviors, or state, potentially causing the product to perform incorrect actions based on this incomplete model." ;
    skos:exactMatch d3f:CWE-437,
        cwe:CWE-437 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE439 a owl:Class ;
    rdfs:label "CWE_439" ;
    d3f:cwe-id "CWE-439" ;
    d3f:synonym "Functional change" ;
    dcterms:title "Behavioral Change in New Version or Environment" ;
    rdfs:subClassOf d3f:CWE435 ;
    skos:altLabel "CWE-439" ;
    skos:definition "A's behavior or functionality changes with a new version of A, or a new environment, which is not known (or manageable) by B." ;
    skos:exactMatch d3f:CWE-439,
        cwe:CWE-439 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE440 a owl:Class ;
    rdfs:label "CWE_440" ;
    d3f:cwe-id "CWE-440" ;
    dcterms:title "Expected Behavior Violation" ;
    rdfs:subClassOf d3f:CWE684 ;
    skos:altLabel "CWE-440" ;
    skos:definition "A feature, API, or function does not perform according to its specification." ;
    skos:exactMatch d3f:CWE-440,
        cwe:CWE-440 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE444 a owl:Class ;
    rdfs:label "CWE_444" ;
    d3f:cwe-id "CWE-444" ;
    d3f:synonym "HTTP Request Smuggling" ;
    dcterms:title "Inconsistent Interpretation of HTTP Requests ('HTTP Request/Response Smuggling')" ;
    rdfs:subClassOf d3f:CWE436 ;
    skos:altLabel "CWE-444" ;
    skos:definition "The product acts as an intermediary HTTP agent (such as a proxy or firewall) in the data flow between two entities such as a client and server, but it does not interpret malformed HTTP requests or responses in ways that are consistent with how the messages will be processed by those entities that are at the ultimate destination." ;
    skos:exactMatch d3f:CWE-444,
        cwe:CWE-444 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE447 a owl:Class ;
    rdfs:label "CWE_447" ;
    d3f:cwe-id "CWE-447" ;
    dcterms:title "Unimplemented or Unsupported Feature in UI" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE671 ],
        d3f:CWE446 ;
    skos:altLabel "CWE-447" ;
    skos:definition "A UI function for a security feature appears to be supported and gives feedback to the user that suggests that it is supported, but the underlying functionality is not implemented." ;
    skos:exactMatch d3f:CWE-447,
        cwe:CWE-447 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE448 a owl:Class ;
    rdfs:label "CWE_448" ;
    d3f:cwe-id "CWE-448" ;
    dcterms:title "Obsolete Feature in UI" ;
    rdfs:subClassOf d3f:CWE446 ;
    skos:altLabel "CWE-448" ;
    skos:definition "A UI function is obsolete and the product does not warn the user." ;
    skos:exactMatch d3f:CWE-448,
        cwe:CWE-448 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE449 a owl:Class ;
    rdfs:label "CWE_449" ;
    d3f:cwe-id "CWE-449" ;
    dcterms:title "The UI Performs the Wrong Action" ;
    rdfs:subClassOf d3f:CWE446 ;
    skos:altLabel "CWE-449" ;
    skos:definition "The UI performs the wrong action with respect to the user's request." ;
    skos:exactMatch d3f:CWE-449,
        cwe:CWE-449 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE45 a owl:Class ;
    rdfs:label "CWE_45" ;
    d3f:cwe-id "CWE-45" ;
    dcterms:title "Path Equivalence: 'file...name' (Multiple Internal Dot)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE44 ],
        d3f:CWE165 ;
    skos:altLabel "CWE-45" ;
    skos:definition "The product accepts path input in the form of multiple internal dot ('file...dir') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-45,
        cwe:CWE-45 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE450 a owl:Class ;
    rdfs:label "CWE_450" ;
    d3f:cwe-id "CWE-450" ;
    dcterms:title "Multiple Interpretations of UI Input" ;
    rdfs:subClassOf d3f:CWE357 ;
    skos:altLabel "CWE-450" ;
    skos:definition "The UI has multiple interpretations of user input but does not prompt the user when it selects the less secure interpretation." ;
    skos:exactMatch d3f:CWE-450,
        cwe:CWE-450 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE453 a owl:Class ;
    rdfs:label "CWE_453" ;
    d3f:cwe-id "CWE-453" ;
    dcterms:title "Insecure Default Variable Initialization" ;
    rdfs:subClassOf d3f:CWE1188 ;
    skos:altLabel "CWE-453" ;
    skos:definition "The product, by default, initializes an internal variable with an insecure or less secure value than is possible." ;
    skos:exactMatch d3f:CWE-453,
        cwe:CWE-453 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE454 a owl:Class ;
    rdfs:label "CWE_454" ;
    d3f:cwe-id "CWE-454" ;
    dcterms:title "External Initialization of Trusted Variables or Data Stores" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE665 ],
        d3f:CWE1419 ;
    skos:altLabel "CWE-454" ;
    skos:definition "The product initializes critical internal variables or data stores using inputs that can be modified by untrusted actors." ;
    skos:exactMatch d3f:CWE-454,
        cwe:CWE-454 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE455 a owl:Class ;
    rdfs:label "CWE_455" ;
    d3f:cwe-id "CWE-455" ;
    dcterms:title "Non-exit on Failed Initialization" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE705 ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE665 ],
        d3f:CWE636 ;
    skos:altLabel "CWE-455" ;
    skos:definition "The product does not exit or otherwise modify its operation when security-relevant errors occur during initialization, such as when a configuration file has a format error or a hardware security module (HSM) cannot be activated, which can cause the product to execute in a less secure fashion than intended by the administrator." ;
    skos:exactMatch d3f:CWE-455,
        cwe:CWE-455 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE456 a owl:Class ;
    rdfs:label "CWE_456" ;
    d3f:cwe-id "CWE-456" ;
    dcterms:title "Missing Initialization of a Variable" ;
    rdfs:subClassOf d3f:CWE909 ;
    skos:altLabel "CWE-456" ;
    skos:definition "The product does not initialize critical variables, which causes the execution environment to use unexpected values." ;
    skos:exactMatch d3f:CWE-456,
        cwe:CWE-456 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE457 a owl:Class ;
    rdfs:label "CWE_457" ;
    d3f:cwe-id "CWE-457" ;
    dcterms:title "Use of Uninitialized Variable" ;
    rdfs:subClassOf d3f:CWE908 ;
    skos:altLabel "CWE-457" ;
    skos:definition "The code uses a variable that has not been initialized, leading to unpredictable or unintended results." ;
    skos:exactMatch d3f:CWE-457,
        cwe:CWE-457 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE46 a owl:Class ;
    rdfs:label "CWE_46" ;
    d3f:cwe-id "CWE-46" ;
    dcterms:title "Path Equivalence: 'filename ' (Trailing Space)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE162 ;
    skos:altLabel "CWE-46" ;
    skos:definition "The product accepts path input in the form of trailing space ('filedir ') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-46,
        cwe:CWE-46 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE460 a owl:Class ;
    rdfs:label "CWE_460" ;
    d3f:cwe-id "CWE-460" ;
    dcterms:title "Improper Cleanup on Thrown Exception" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        d3f:CWE459 ;
    skos:altLabel "CWE-460" ;
    skos:definition "The product does not clean up its state or incorrectly cleans up its state when an exception is thrown, leading to unexpected state or control flow." ;
    skos:exactMatch d3f:CWE-460,
        cwe:CWE-460 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE462 a owl:Class ;
    rdfs:label "CWE_462" ;
    d3f:cwe-id "CWE-462" ;
    dcterms:title "Duplicate Key in Associative List (Alist)" ;
    rdfs:subClassOf d3f:CWE694 ;
    skos:altLabel "CWE-462" ;
    skos:definition "Duplicate keys in associative lists can lead to non-unique keys being mistaken for an error." ;
    skos:exactMatch d3f:CWE-462,
        cwe:CWE-462 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE463 a owl:Class ;
    rdfs:label "CWE_463" ;
    d3f:cwe-id "CWE-463" ;
    dcterms:title "Deletion of Data Structure Sentinel" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-463" ;
    skos:definition "The accidental deletion of a data-structure sentinel can cause serious programming logic problems." ;
    skos:exactMatch d3f:CWE-463,
        cwe:CWE-463 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE464 a owl:Class ;
    rdfs:label "CWE_464" ;
    d3f:cwe-id "CWE-464" ;
    dcterms:title "Addition of Data Structure Sentinel" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-464" ;
    skos:definition "The accidental addition of a data-structure sentinel can cause serious programming logic problems." ;
    skos:exactMatch d3f:CWE-464,
        cwe:CWE-464 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE466 a owl:Class ;
    rdfs:label "CWE_466" ;
    d3f:cwe-id "CWE-466" ;
    dcterms:title "Return of Pointer Value Outside of Expected Range" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-466" ;
    skos:definition "A function can return a pointer to memory that is outside of the buffer that the pointer is expected to reference." ;
    skos:exactMatch d3f:CWE-466,
        cwe:CWE-466 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE467 a owl:Class ;
    rdfs:label "CWE_467" ;
    d3f:cwe-id "CWE-467" ;
    dcterms:title "Use of sizeof() on a Pointer Type" ;
    rdfs:subClassOf d3f:CWE131 ;
    skos:altLabel "CWE-467" ;
    skos:definition "The code calls sizeof() on a pointer type, which can be an incorrect calculation if the programmer intended to determine the size of the data that is being pointed to." ;
    skos:exactMatch d3f:CWE-467,
        cwe:CWE-467 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE468 a owl:Class ;
    rdfs:label "CWE_468" ;
    d3f:cwe-id "CWE-468" ;
    dcterms:title "Incorrect Pointer Scaling" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-468" ;
    skos:definition "In C and C++, one may often accidentally refer to the wrong memory due to the semantics of when math operations are implicitly scaled." ;
    skos:exactMatch d3f:CWE-468,
        cwe:CWE-468 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE469 a owl:Class ;
    rdfs:label "CWE_469" ;
    d3f:cwe-id "CWE-469" ;
    dcterms:title "Use of Pointer Subtraction to Determine Size" ;
    rdfs:subClassOf d3f:CWE682 ;
    skos:altLabel "CWE-469" ;
    skos:definition "The product subtracts one pointer from another in order to determine size, but this calculation can be incorrect if the pointers do not exist in the same memory chunk." ;
    skos:exactMatch d3f:CWE-469,
        cwe:CWE-469 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE47 a owl:Class ;
    rdfs:label "CWE_47" ;
    d3f:cwe-id "CWE-47" ;
    dcterms:title "Path Equivalence: ' filename' (Leading Space)" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-47" ;
    skos:definition "The product accepts path input in the form of leading space (' filedir') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-47,
        cwe:CWE-47 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE470 a owl:Class ;
    rdfs:label "CWE_470" ;
    d3f:cwe-id "CWE-470" ;
    d3f:synonym "Reflection Injection" ;
    dcterms:title "Use of Externally-Controlled Input to Select Classes or Code ('Unsafe Reflection')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE913 ],
        d3f:CWE610 ;
    skos:altLabel "CWE-470" ;
    skos:definition "The product uses external input with reflection to select which classes or code to use, but it does not sufficiently prevent the input from selecting improper classes or code." ;
    skos:exactMatch d3f:CWE-470,
        cwe:CWE-470 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE472 a owl:Class ;
    rdfs:label "CWE_472" ;
    d3f:cwe-id "CWE-472" ;
    d3f:synonym "Assumed-Immutable Parameter Tampering" ;
    dcterms:title "External Control of Assumed-Immutable Web Parameter" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE642 ],
        d3f:CWE471 ;
    skos:altLabel "CWE-472" ;
    skos:definition "The web application does not sufficiently verify inputs that are assumed to be immutable but are actually externally controllable, such as hidden form fields." ;
    skos:exactMatch d3f:CWE-472,
        cwe:CWE-472 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE473 a owl:Class ;
    rdfs:label "CWE_473" ;
    d3f:cwe-id "CWE-473" ;
    dcterms:title "PHP External Variable Modification" ;
    rdfs:subClassOf d3f:CWE471 ;
    skos:altLabel "CWE-473" ;
    skos:definition "A PHP application does not properly protect against the modification of variables from external sources, such as query parameters or cookies. This can expose the application to numerous weaknesses that would not exist otherwise." ;
    skos:exactMatch d3f:CWE-473,
        cwe:CWE-473 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE475 a owl:Class ;
    rdfs:label "CWE_475" ;
    d3f:cwe-id "CWE-475" ;
    dcterms:title "Undefined Behavior for Input to API" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-475" ;
    skos:definition "The behavior of this function is undefined unless its control parameter is set to a specific value." ;
    skos:exactMatch d3f:CWE-475,
        cwe:CWE-475 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE477 a owl:Class ;
    rdfs:label "CWE_477" ;
    d3f:cwe-id "CWE-477" ;
    dcterms:title "Use of Obsolete Function" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-477" ;
    skos:definition "The code uses deprecated or obsolete functions, which suggests that the code has not been actively reviewed or maintained." ;
    skos:exactMatch d3f:CWE-477,
        cwe:CWE-477 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE478 a owl:Class ;
    rdfs:label "CWE_478" ;
    d3f:cwe-id "CWE-478" ;
    dcterms:title "Missing Default Case in Multiple Condition Expression" ;
    rdfs:subClassOf d3f:CWE1023 ;
    skos:altLabel "CWE-478" ;
    skos:definition "The code does not have a default case in an expression with multiple conditions, such as a switch statement." ;
    skos:exactMatch d3f:CWE-478,
        cwe:CWE-478 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE479 a owl:Class ;
    rdfs:label "CWE_479" ;
    d3f:cwe-id "CWE-479" ;
    dcterms:title "Signal Handler Use of a Non-reentrant Function" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE828 ],
        d3f:CWE663 ;
    skos:altLabel "CWE-479" ;
    skos:definition "The product defines a signal handler that calls a non-reentrant function." ;
    skos:exactMatch d3f:CWE-479,
        cwe:CWE-479 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE48 a owl:Class ;
    rdfs:label "CWE_48" ;
    d3f:cwe-id "CWE-48" ;
    dcterms:title "Path Equivalence: 'file name' (Internal Whitespace)" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-48" ;
    skos:definition "The product accepts path input in the form of internal space ('file(SPACE)name') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-48,
        cwe:CWE-48 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE481 a owl:Class ;
    rdfs:label "CWE_481" ;
    d3f:cwe-id "CWE-481" ;
    dcterms:title "Assigning instead of Comparing" ;
    rdfs:subClassOf d3f:CWE480 ;
    skos:altLabel "CWE-481" ;
    skos:definition "The code uses an operator for assignment when the intention was to perform a comparison." ;
    skos:exactMatch d3f:CWE-481,
        cwe:CWE-481 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE482 a owl:Class ;
    rdfs:label "CWE_482" ;
    d3f:cwe-id "CWE-482" ;
    dcterms:title "Comparing instead of Assigning" ;
    rdfs:subClassOf d3f:CWE480 ;
    skos:altLabel "CWE-482" ;
    skos:definition "The code uses an operator for comparison when the intention was to perform an assignment." ;
    skos:exactMatch d3f:CWE-482,
        cwe:CWE-482 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE483 a owl:Class ;
    rdfs:label "CWE_483" ;
    d3f:cwe-id "CWE-483" ;
    dcterms:title "Incorrect Block Delimitation" ;
    rdfs:subClassOf d3f:CWE670 ;
    skos:altLabel "CWE-483" ;
    skos:definition "The code does not explicitly delimit a block that is intended to contain 2 or more statements, creating a logic error." ;
    skos:exactMatch d3f:CWE-483,
        cwe:CWE-483 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE484 a owl:Class ;
    rdfs:label "CWE_484" ;
    d3f:cwe-id "CWE-484" ;
    dcterms:title "Omitted Break Statement in Switch" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE710 ],
        d3f:CWE670 ;
    skos:altLabel "CWE-484" ;
    skos:definition "The product omits a break statement within a switch or similar construct, causing code associated with multiple conditions to execute. This can cause problems when the programmer only intended to execute code associated with one condition." ;
    skos:exactMatch d3f:CWE-484,
        cwe:CWE-484 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE486 a owl:Class ;
    rdfs:label "CWE_486" ;
    d3f:cwe-id "CWE-486" ;
    dcterms:title "Comparison of Classes by Name" ;
    rdfs:subClassOf d3f:CWE1025 ;
    skos:altLabel "CWE-486" ;
    skos:definition "The product compares classes by name, which can cause it to use the wrong class when multiple classes can have the same name." ;
    skos:exactMatch d3f:CWE-486,
        cwe:CWE-486 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE487 a owl:Class ;
    rdfs:label "CWE_487" ;
    d3f:cwe-id "CWE-487" ;
    dcterms:title "Reliance on Package-level Scope" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-487" ;
    skos:definition "Java packages are not inherently closed; therefore, relying on them for code security is not a good practice." ;
    skos:exactMatch d3f:CWE-487,
        cwe:CWE-487 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE488 a owl:Class ;
    rdfs:label "CWE_488" ;
    d3f:cwe-id "CWE-488" ;
    dcterms:title "Exposure of Data Element to Wrong Session" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-488" ;
    skos:definition "The product does not sufficiently enforce boundaries between the states of different sessions, causing data to be provided to, or used by, the wrong session." ;
    skos:exactMatch d3f:CWE-488,
        cwe:CWE-488 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE49 a owl:Class ;
    rdfs:label "CWE_49" ;
    d3f:cwe-id "CWE-49" ;
    dcterms:title "Path Equivalence: 'filename/' (Trailing Slash)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE162 ;
    skos:altLabel "CWE-49" ;
    skos:definition "The product accepts path input in the form of trailing slash ('filedir/') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-49,
        cwe:CWE-49 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE491 a owl:Class ;
    rdfs:label "CWE_491" ;
    d3f:cwe-id "CWE-491" ;
    dcterms:title "Public cloneable() Method Without Final ('Object Hijack')" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-491" ;
    skos:definition "A class has a cloneable() method that is not declared final, which allows an object to be created without calling the constructor. This can cause the object to be in an unexpected state." ;
    skos:exactMatch d3f:CWE-491,
        cwe:CWE-491 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE492 a owl:Class ;
    rdfs:label "CWE_492" ;
    d3f:cwe-id "CWE-492" ;
    dcterms:title "Use of Inner Class Containing Sensitive Data" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-492" ;
    skos:definition "Inner classes are translated into classes that are accessible at package scope and may expose code that the programmer intended to keep private to attackers." ;
    skos:exactMatch d3f:CWE-492,
        cwe:CWE-492 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE494 a owl:Class ;
    rdfs:label "CWE_494" ;
    d3f:cwe-id "CWE-494" ;
    dcterms:title "Download of Code Without Integrity Check" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE669 ],
        d3f:CWE345 ;
    skos:altLabel "CWE-494" ;
    skos:definition "The product downloads source code or an executable from a remote location and executes the code without sufficiently verifying the origin and integrity of the code." ;
    skos:exactMatch d3f:CWE-494,
        cwe:CWE-494 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE495 a owl:Class ;
    rdfs:label "CWE_495" ;
    d3f:cwe-id "CWE-495" ;
    dcterms:title "Private Data Structure Returned From A Public Method" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-495" ;
    skos:definition "The product has a method that is declared public, but returns a reference to a private data structure, which could then be modified in unexpected ways." ;
    skos:exactMatch d3f:CWE-495,
        cwe:CWE-495 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE496 a owl:Class ;
    rdfs:label "CWE_496" ;
    d3f:cwe-id "CWE-496" ;
    dcterms:title "Public Data Assigned to Private Array-Typed Field" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-496" ;
    skos:definition "Assigning public data to a private array is equivalent to giving public access to the array." ;
    skos:exactMatch d3f:CWE-496,
        cwe:CWE-496 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE498 a owl:Class ;
    rdfs:label "CWE_498" ;
    d3f:cwe-id "CWE-498" ;
    dcterms:title "Cloneable Class Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-498" ;
    skos:definition "The code contains a class with sensitive data, but the class is cloneable. The data can then be accessed by cloning the class." ;
    skos:exactMatch d3f:CWE-498,
        cwe:CWE-498 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE499 a owl:Class ;
    rdfs:label "CWE_499" ;
    d3f:cwe-id "CWE-499" ;
    dcterms:title "Serializable Class Containing Sensitive Data" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-499" ;
    skos:definition "The code contains a class with sensitive data, but the class does not explicitly deny serialization. The data can be accessed by serializing the class through another class." ;
    skos:exactMatch d3f:CWE-499,
        cwe:CWE-499 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE5 a owl:Class ;
    rdfs:label "CWE_5" ;
    d3f:cwe-id "CWE-5" ;
    dcterms:title "J2EE Misconfiguration: Data Transmission Without Encryption" ;
    rdfs:subClassOf d3f:CWE319 ;
    skos:altLabel "CWE-5" ;
    skos:definition "Information sent over a network can be compromised while in transit. An attacker may be able to read or modify the contents if the data are sent in plaintext or are weakly encrypted." ;
    skos:exactMatch d3f:CWE-5,
        cwe:CWE-5 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE50 a owl:Class ;
    rdfs:label "CWE_50" ;
    d3f:cwe-id "CWE-50" ;
    dcterms:title "Path Equivalence: '//multiple/leading/slash'" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE161 ;
    skos:altLabel "CWE-50" ;
    skos:definition "The product accepts path input in the form of multiple leading slash ('//multiple/leading/slash') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-50,
        cwe:CWE-50 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE500 a owl:Class ;
    rdfs:label "CWE_500" ;
    d3f:cwe-id "CWE-500" ;
    dcterms:title "Public Static Field Not Marked Final" ;
    rdfs:subClassOf d3f:CWE493 ;
    skos:altLabel "CWE-500" ;
    skos:definition "An object contains a public static field that is not marked final, which might allow it to be modified in unexpected ways." ;
    skos:exactMatch d3f:CWE-500,
        cwe:CWE-500 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE501 a owl:Class ;
    rdfs:label "CWE_501" ;
    d3f:cwe-id "CWE-501" ;
    dcterms:title "Trust Boundary Violation" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-501" ;
    skos:definition "The product mixes trusted and untrusted data in the same data structure or structured message." ;
    skos:exactMatch d3f:CWE-501,
        cwe:CWE-501 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE502 a owl:Class ;
    rdfs:label "CWE_502" ;
    d3f:cwe-id "CWE-502" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Marshaling, Unmarshaling" ;
    dcterms:title "Deserialization of Untrusted Data" ;
    rdfs:subClassOf d3f:CWE913 ;
    skos:altLabel "CWE-502" ;
    skos:definition "The product deserializes untrusted data without sufficiently ensuring that the resulting data will be valid." ;
    skos:exactMatch d3f:CWE-502,
        cwe:CWE-502 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE508 a owl:Class ;
    rdfs:label "CWE_508" ;
    d3f:cwe-id "CWE-508" ;
    dcterms:title "Non-Replicating Malicious Code" ;
    rdfs:subClassOf d3f:CWE507 ;
    skos:altLabel "CWE-508" ;
    skos:definition "Non-replicating malicious code only resides on the target system or product that is attacked; it does not attempt to spread to other systems." ;
    skos:exactMatch d3f:CWE-508,
        cwe:CWE-508 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE509 a owl:Class ;
    rdfs:label "CWE_509" ;
    d3f:cwe-id "CWE-509" ;
    dcterms:title "Replicating Malicious Code (Virus or Worm)" ;
    rdfs:subClassOf d3f:CWE507 ;
    skos:altLabel "CWE-509" ;
    skos:definition "Replicating malicious code, including viruses and worms, will attempt to attack other systems once it has successfully compromised the target system or the product." ;
    skos:exactMatch d3f:CWE-509,
        cwe:CWE-509 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE51 a owl:Class ;
    rdfs:label "CWE_51" ;
    d3f:cwe-id "CWE-51" ;
    dcterms:title "Path Equivalence: '/multiple//internal/slash'" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-51" ;
    skos:definition "The product accepts path input in the form of multiple internal slash ('/multiple//internal/slash/') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-51,
        cwe:CWE-51 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE510 a owl:Class ;
    rdfs:label "CWE_510" ;
    d3f:cwe-id "CWE-510" ;
    dcterms:title "Trapdoor" ;
    rdfs:subClassOf d3f:CWE506 ;
    skos:altLabel "CWE-510" ;
    skos:definition "A trapdoor is a hidden piece of code that responds to a special input, allowing its user access to resources without passing through the normal security enforcement mechanism." ;
    skos:exactMatch d3f:CWE-510,
        cwe:CWE-510 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE511 a owl:Class ;
    rdfs:label "CWE_511" ;
    d3f:cwe-id "CWE-511" ;
    dcterms:title "Logic/Time Bomb" ;
    rdfs:subClassOf d3f:CWE506 ;
    skos:altLabel "CWE-511" ;
    skos:definition "The product contains code that is designed to disrupt the legitimate operation of the product (or its environment) when a certain time passes, or when a certain logical condition is met." ;
    skos:exactMatch d3f:CWE-511,
        cwe:CWE-511 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE512 a owl:Class ;
    rdfs:label "CWE_512" ;
    d3f:cwe-id "CWE-512" ;
    dcterms:title "Spyware" ;
    rdfs:subClassOf d3f:CWE506 ;
    skos:altLabel "CWE-512" ;
    skos:definition "The product collects personally identifiable information about a human user or the user's activities, but the product accesses this information using other resources besides itself, and it does not require that user's explicit approval or direct input into the product." ;
    skos:exactMatch d3f:CWE-512,
        cwe:CWE-512 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE515 a owl:Class ;
    rdfs:label "CWE_515" ;
    d3f:cwe-id "CWE-515" ;
    dcterms:title "Covert Storage Channel" ;
    rdfs:subClassOf d3f:CWE514 ;
    skos:altLabel "CWE-515" ;
    skos:definition "A covert storage channel transfers information through the setting of bits by one program and the reading of those bits by another. What distinguishes this case from that of ordinary operation is that the bits are used to convey encoded information." ;
    skos:exactMatch d3f:CWE-515,
        cwe:CWE-515 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE52 a owl:Class ;
    rdfs:label "CWE_52" ;
    d3f:cwe-id "CWE-52" ;
    dcterms:title "Path Equivalence: '/multiple/trailing/slash//'" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE163 ;
    skos:altLabel "CWE-52" ;
    skos:definition "The product accepts path input in the form of multiple trailing slash ('/multiple/trailing/slash//') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-52,
        cwe:CWE-52 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE520 a owl:Class ;
    rdfs:label "CWE_520" ;
    d3f:cwe-id "CWE-520" ;
    dcterms:title ".NET Misconfiguration: Use of Impersonation" ;
    rdfs:subClassOf d3f:CWE266 ;
    skos:altLabel "CWE-520" ;
    skos:definition "Allowing a .NET application to run at potentially escalated levels of access to the underlying operating and file systems can be dangerous and result in various forms of attacks." ;
    skos:exactMatch d3f:CWE-520,
        cwe:CWE-520 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE523 a owl:Class ;
    rdfs:label "CWE_523" ;
    d3f:cwe-id "CWE-523" ;
    dcterms:title "Unprotected Transport of Credentials" ;
    rdfs:subClassOf d3f:CWE522 ;
    skos:altLabel "CWE-523" ;
    skos:definition "Login pages do not use adequate measures to protect the user name and password while they are in transit from the client to the server." ;
    skos:exactMatch d3f:CWE-523,
        cwe:CWE-523 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE525 a owl:Class ;
    rdfs:label "CWE_525" ;
    d3f:cwe-id "CWE-525" ;
    dcterms:title "Use of Web Browser Cache Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE524 ;
    skos:altLabel "CWE-525" ;
    skos:definition "The web application does not use an appropriate caching policy that specifies the extent to which each web page and associated form fields should be cached." ;
    skos:exactMatch d3f:CWE-525,
        cwe:CWE-525 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE526 a owl:Class ;
    rdfs:label "CWE_526" ;
    d3f:cwe-id "CWE-526" ;
    dcterms:title "Cleartext Storage of Sensitive Information in an Environment Variable" ;
    rdfs:subClassOf d3f:CWE312 ;
    skos:altLabel "CWE-526" ;
    skos:definition "The product uses an environment variable to store unencrypted sensitive information." ;
    skos:exactMatch d3f:CWE-526,
        cwe:CWE-526 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE527 a owl:Class ;
    rdfs:label "CWE_527" ;
    d3f:cwe-id "CWE-527" ;
    dcterms:title "Exposure of Version-Control Repository to an Unauthorized Control Sphere" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-527" ;
    skos:definition "The product stores a CVS, git, or other repository in a directory, archive, or other resource that is stored, transferred, or otherwise made accessible to unauthorized actors." ;
    skos:exactMatch d3f:CWE-527,
        cwe:CWE-527 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE528 a owl:Class ;
    rdfs:label "CWE_528" ;
    d3f:cwe-id "CWE-528" ;
    dcterms:title "Exposure of Core Dump File to an Unauthorized Control Sphere" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-528" ;
    skos:definition "The product generates a core dump file in a directory, archive, or other resource that is stored, transferred, or otherwise made accessible to unauthorized actors." ;
    skos:exactMatch d3f:CWE-528,
        cwe:CWE-528 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE529 a owl:Class ;
    rdfs:label "CWE_529" ;
    d3f:cwe-id "CWE-529" ;
    dcterms:title "Exposure of Access Control List Files to an Unauthorized Control Sphere" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-529" ;
    skos:definition "The product stores access control list files in a directory or other container that is accessible to actors outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-529,
        cwe:CWE-529 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE53 a owl:Class ;
    rdfs:label "CWE_53" ;
    d3f:cwe-id "CWE-53" ;
    dcterms:title "Path Equivalence: '\\multiple\\\\internal\\backslash'" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE165 ;
    skos:altLabel "CWE-53" ;
    skos:definition "The product accepts path input in the form of multiple internal backslash ('\\multiple\\trailing\\\\slash') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-53,
        cwe:CWE-53 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE530 a owl:Class ;
    rdfs:label "CWE_530" ;
    d3f:cwe-id "CWE-530" ;
    dcterms:title "Exposure of Backup File to an Unauthorized Control Sphere" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-530" ;
    skos:definition "A backup file is stored in a directory or archive that is made accessible to unauthorized actors." ;
    skos:exactMatch d3f:CWE-530,
        cwe:CWE-530 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE531 a owl:Class ;
    rdfs:label "CWE_531" ;
    d3f:cwe-id "CWE-531" ;
    dcterms:title "Inclusion of Sensitive Information in Test Code" ;
    rdfs:subClassOf d3f:CWE540 ;
    skos:altLabel "CWE-531" ;
    skos:definition "Accessible test applications can pose a variety of security risks. Since developers or administrators rarely consider that someone besides themselves would even know about the existence of these applications, it is common for them to contain sensitive information or functions." ;
    skos:exactMatch d3f:CWE-531,
        cwe:CWE-531 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE532 a owl:Class ;
    rdfs:label "CWE_532" ;
    d3f:cwe-id "CWE-532" ;
    dcterms:title "Insertion of Sensitive Information into Log File" ;
    rdfs:subClassOf d3f:CWE538 ;
    skos:altLabel "CWE-532" ;
    skos:definition "The product writes sensitive information to a log file." ;
    skos:exactMatch d3f:CWE-532,
        cwe:CWE-532 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE535 a owl:Class ;
    rdfs:label "CWE_535" ;
    d3f:cwe-id "CWE-535" ;
    dcterms:title "Exposure of Information Through Shell Error Message" ;
    rdfs:subClassOf d3f:CWE211 ;
    skos:altLabel "CWE-535" ;
    skos:definition "A command shell error message indicates that there exists an unhandled exception in the web application code. In many cases, an attacker can leverage the conditions that cause these errors in order to gain unauthorized access to the system." ;
    skos:exactMatch d3f:CWE-535,
        cwe:CWE-535 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE536 a owl:Class ;
    rdfs:label "CWE_536" ;
    d3f:cwe-id "CWE-536" ;
    dcterms:title "Servlet Runtime Error Message Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE211 ;
    skos:altLabel "CWE-536" ;
    skos:definition "A servlet error message indicates that there exists an unhandled exception in your web application code and may provide useful information to an attacker." ;
    skos:exactMatch d3f:CWE-536,
        cwe:CWE-536 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE537 a owl:Class ;
    rdfs:label "CWE_537" ;
    d3f:cwe-id "CWE-537" ;
    dcterms:title "Java Runtime Error Message Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE211 ;
    skos:altLabel "CWE-537" ;
    skos:definition "In many cases, an attacker can leverage the conditions that cause unhandled exception errors in order to gain unauthorized access to the system." ;
    skos:exactMatch d3f:CWE-537,
        cwe:CWE-537 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE539 a owl:Class ;
    rdfs:label "CWE_539" ;
    d3f:cwe-id "CWE-539" ;
    dcterms:title "Use of Persistent Cookies Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE552 ;
    skos:altLabel "CWE-539" ;
    skos:definition "The web application uses persistent cookies, but the cookies contain sensitive information." ;
    skos:exactMatch d3f:CWE-539,
        cwe:CWE-539 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE54 a owl:Class ;
    rdfs:label "CWE_54" ;
    d3f:cwe-id "CWE-54" ;
    dcterms:title "Path Equivalence: 'filedir\\' (Trailing Backslash)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE41 ],
        d3f:CWE162 ;
    skos:altLabel "CWE-54" ;
    skos:definition "The product accepts path input in the form of trailing backslash ('filedir\\') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-54,
        cwe:CWE-54 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE541 a owl:Class ;
    rdfs:label "CWE_541" ;
    d3f:cwe-id "CWE-541" ;
    dcterms:title "Inclusion of Sensitive Information in an Include File" ;
    rdfs:subClassOf d3f:CWE540 ;
    skos:altLabel "CWE-541" ;
    skos:definition "If an include file source is accessible, the file can contain usernames and passwords, as well as sensitive information pertaining to the application and system." ;
    skos:exactMatch d3f:CWE-541,
        cwe:CWE-541 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE543 a owl:Class ;
    rdfs:label "CWE_543" ;
    d3f:cwe-id "CWE-543" ;
    dcterms:title "Use of Singleton Pattern Without Synchronization in a Multithreaded Context" ;
    rdfs:subClassOf d3f:CWE820 ;
    skos:altLabel "CWE-543" ;
    skos:definition "The product uses the singleton pattern when creating a resource within a multithreaded environment." ;
    skos:exactMatch d3f:CWE-543,
        cwe:CWE-543 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE544 a owl:Class ;
    rdfs:label "CWE_544" ;
    d3f:cwe-id "CWE-544" ;
    dcterms:title "Missing Standardized Error Handling Mechanism" ;
    rdfs:subClassOf d3f:CWE755 ;
    skos:altLabel "CWE-544" ;
    skos:definition "The product does not use a standardized method for handling errors throughout the code, which might introduce inconsistent error handling and resultant weaknesses." ;
    skos:exactMatch d3f:CWE-544,
        cwe:CWE-544 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE546 a owl:Class ;
    rdfs:label "CWE_546" ;
    d3f:cwe-id "CWE-546" ;
    dcterms:title "Suspicious Comment" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-546" ;
    skos:definition "The code contains comments that suggest the presence of bugs, incomplete functionality, or weaknesses." ;
    skos:exactMatch d3f:CWE-546,
        cwe:CWE-546 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE547 a owl:Class ;
    rdfs:label "CWE_547" ;
    d3f:cwe-id "CWE-547" ;
    dcterms:title "Use of Hard-coded, Security-relevant Constants" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-547" ;
    skos:definition "The product uses hard-coded constants instead of symbolic names for security-critical values, which increases the likelihood of mistakes during code maintenance or security policy change." ;
    skos:exactMatch d3f:CWE-547,
        cwe:CWE-547 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE548 a owl:Class ;
    rdfs:label "CWE_548" ;
    d3f:cwe-id "CWE-548" ;
    dcterms:title "Exposure of Information Through Directory Listing" ;
    rdfs:subClassOf d3f:CWE497 ;
    skos:altLabel "CWE-548" ;
    skos:definition "The product inappropriately exposes a directory listing with an index of all the resources located inside of the directory." ;
    skos:exactMatch d3f:CWE-548,
        cwe:CWE-548 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE549 a owl:Class ;
    rdfs:label "CWE_549" ;
    d3f:cwe-id "CWE-549" ;
    dcterms:title "Missing Password Field Masking" ;
    rdfs:subClassOf d3f:CWE522 ;
    skos:altLabel "CWE-549" ;
    skos:definition "The product does not mask passwords during entry, increasing the potential for attackers to observe and capture passwords." ;
    skos:exactMatch d3f:CWE-549,
        cwe:CWE-549 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE55 a owl:Class ;
    rdfs:label "CWE_55" ;
    d3f:cwe-id "CWE-55" ;
    dcterms:title "Path Equivalence: '/./' (Single Dot Directory)" ;
    rdfs:subClassOf d3f:CWE41 ;
    skos:altLabel "CWE-55" ;
    skos:definition "The product accepts path input in the form of single dot directory exploit ('/./') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    skos:exactMatch d3f:CWE-55,
        cwe:CWE-55 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE550 a owl:Class ;
    rdfs:label "CWE_550" ;
    d3f:cwe-id "CWE-550" ;
    dcterms:title "Server-generated Error Message Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE209 ;
    skos:altLabel "CWE-550" ;
