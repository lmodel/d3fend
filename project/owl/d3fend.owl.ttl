d3f:ConnectedHoneynet a owl:Class ;
    rdfs:label "ConnectedHoneynet" ;
    d3f:d3fend-id "D3-CHN" ;
    d3f:kb-article "## How it works Decoy honeypots are deployed within the enterprise environment that emulate certain services or portions of an OS to attract attackers. ## Considerations A connected honeynet provides a tradeoff between emulating certain functionality but not being as sophisticated as an integrated" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Connected Honeynet" ;
    rdfs:subClassOf d3f:DecoyEnvironment ;
    skos:definition "A decoy service, system, or environment, that is connected to the enterprise network, and simulates or emulates certain functionality to the network, without exposing full access to a production system." ;
    skos:exactMatch d3f:ConnectedHoneynet ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConnectionAttemptAnalysis a owl:Class ;
    rdfs:label "ConnectionAttemptAnalysis" ;
    d3f:d3fend-id "D3-CAA" ;
    d3f:kb-article "## How it works Connection Attempt Analysis in multiple ways. ### Monitoring traffic to unallocated IP space One approach looks for failed connection attempts against unallocated IP space. First, network traffic is captured to map out the network to identify network assets as well as unallocated IP" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Network Scan Detection" ;
    dcterms:title "Connection Attempt Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1003,
        d3f:T1090,
        d3f:T1098,
        d3f:T1110,
        d3f:T1546,
        d3f:T1557 ;
    skos:definition "Analyzing failed connections in a network to detect unauthorized activity." ;
    skos:exactMatch d3f:ConnectionAttemptAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.006,
        mitre-attack:T1021,
        mitre-attack:T1047,
        mitre-attack:T1090.001,
        mitre-attack:T1098.001,
        mitre-attack:T1110.003,
        mitre-attack:T1110.004,
        mitre-attack:T1197,
        mitre-attack:T1199,
