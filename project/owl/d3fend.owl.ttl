    skos:editorialNote "Threat actor is trying to execute malicious code on the spacecraft." ;
    skos:exactMatch d3f:ST0004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ST0005 a owl:Class ;
    rdfs:label "ST0005" ;
    d3f:display-order "5" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Persistence" ;
    rdfs:seeAlso <https://sparta.aerospace.org/tactic/ST0005> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
