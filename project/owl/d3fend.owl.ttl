    skos:editorialNote "Threat actor is trying to move through across sub-systems of the spacecraft." ;
    skos:exactMatch d3f:ST0007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ST0008 a owl:Class ;
    rdfs:label "ST0008" ;
    d3f:display-order "8" ;
    d3f:owl_named_individual "true" ;
