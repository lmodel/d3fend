    skos:definition "The instructions and algorithms within an OT Controller defined by user programming to interpret inputs, process information, and determine outputs." ;
    skos:exactMatch d3f:OTControlLogicProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTControlProgram a owl:Class ;
    rdfs:label "OTControlProgram" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "OT Project File" ;
    dcterms:title "OT Control Program" ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "The file stored in controller memory that is used to operate the controller." ;
    skos:exactMatch d3f:OTControlProgram ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTControlVariable a owl:Class ;
    rdfs:label "OTControlVariable" ;
    dcterms:title "OT Control Variable" ;
    rdfs:subClassOf d3f:OTLogicVariable ;
    skos:definition "A control variable is the measurement of the physical condition of the device that influences the Process Variables." ;
    skos:exactMatch d3f:OTControlVariable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "If the Set Point of a temperature control system for a residential dwelling is 72 degrees, and the Process Variable is 82 degrees, the Control Variable for the air conditioner should be 'on.'" .

d3f:OTController a owl:Class ;
    rdfs:label "OTController" ;
    d3f:owl_named_individual "true" ;
