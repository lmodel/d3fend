    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_counter_attack ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_produce a owl:DatatypeProperty ;
    rdfs:label "may-produce" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-produce y: They entity x may produce the thing y; that is, 'x produces y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_query a owl:DatatypeProperty ;
