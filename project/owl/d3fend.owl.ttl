d3f:ST0004 a owl:Class ;
    rdfs:label "ST0004" ;
    d3f:display-order "4" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Execution" ;
    rdfs:seeAlso <https://sparta.aerospace.org/tactic/ST0004> ;
    rdfs:subClassOf [ a owl:Restriction ;
