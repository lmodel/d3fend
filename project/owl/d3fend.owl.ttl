        mitre-attack:T1548.004,
        mitre-attack:T1555.003 .

d3f:SystemCallEnum a owl:Class ;
    rdfs:label "SystemCallEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:CopyToken d3f:ImpersonateUser ) ;
    skos:definition "Enumeration of SystemCall values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A system call is the programmatic way in which a computer program requests a service from the kernel of the operating system it is executed on. This may include hardware-related services (for example, accessing a hard disk drive), creation and execution of new processes, and communication with integ" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:CopyToken,
        d3f:ImpersonateUser .

d3f:SystemCallFiltering a owl:Class ;
    rdfs:label "SystemCallFiltering" ;
    d3f:d3fend-id "D3-SCF" ;
    d3f:kb-article "## How it works System call filtering uses a mandatory access control paradigm (that is, a non-discretionary access control) system because the rules and polices that determine access is determined by a security control authority and not distributed to local users. Access determinations are based on" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "System Call Control" ;
    dcterms:title "System Call Filtering" ;
    rdfs:subClassOf d3f:AccessMediation ;
    skos:altLabel "Mandatory Access Control",
        "System Call Mediation" ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1036,
        d3f:T1053,
        d3f:T1055,
        d3f:T1074,
        d3f:T1134,
        d3f:T1218,
        d3f:T1497,
        d3f:T1505,
        d3f:T1518,
        d3f:T1546,
        d3f:T1548,
        d3f:T1555,
        d3f:T1562 ;
    skos:definition "Controlling access to local computer system resources with kernel-level capabilities." ;
    skos:exactMatch d3f:SystemCallFiltering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1007,
        mitre-attack:T1010,
        mitre-attack:T1012,
        mitre-attack:T1016,
        mitre-attack:T1018,
        mitre-attack:T1033,
        mitre-attack:T1036.005,
        mitre-attack:T1047,
        mitre-attack:T1049,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1055.001,
        mitre-attack:T1055.003,
        mitre-attack:T1055.004,
        mitre-attack:T1055.005,
        mitre-attack:T1055.008,
        mitre-attack:T1055.013,
        mitre-attack:T1055.014,
        mitre-attack:T1057,
        mitre-attack:T1074.001,
        mitre-attack:T1082,
        mitre-attack:T1106,
        mitre-attack:T1113,
        mitre-attack:T1124,
        mitre-attack:T1134.004,
        mitre-attack:T1140,
        mitre-attack:T1212,
        mitre-attack:T1218.001,
        mitre-attack:T1218.002,
        mitre-attack:T1218.003,
        mitre-attack:T1218.005,
        mitre-attack:T1218.011,
        mitre-attack:T1218.013,
        mitre-attack:T1220,
        mitre-attack:T1497.003,
        mitre-attack:T1505.001,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1518.001,
        mitre-attack:T1546.007,
        mitre-attack:T1546.009,
        mitre-attack:T1546.010,
        mitre-attack:T1548.002,
        mitre-attack:T1548.004,
        mitre-attack:T1550,
        mitre-attack:T1555.003,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:SystemConfigurationDatabase a owl:Class ;
    rdfs:label "SystemConfigurationDatabase" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Configuration Database" ;
    rdfs:subClassOf d3f:Database ;
    skos:definition "A database used to hold system configuration data." ;
    skos:exactMatch d3f:SystemConfigurationDatabase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemFileAnalysis a owl:Class ;
    rdfs:label "SystemFileAnalysis" ;
    d3f:d3fend-id "D3-SFA" ;
    d3f:kb-article "## How it works This technique ensures the integrity of system owned file resources. System files can impact the behavior below the user level. ## Considerations * Need to manage the size of log file analysis. * False positives are a concern with this technique and filtering will need to be given" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System File Analysis" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:DiscoveryTechnique,
        d3f:T1003,
        d3f:T1036,
        d3f:T1055,
        d3f:T1070,
        d3f:T1543,
        d3f:T1548,
        d3f:T1556,
        d3f:T1574 ;
    skos:definition "Monitoring system files such as authentication databases, configuration files, system logs, and system executables for modification or tampering." ;
    skos:exactMatch d3f:SystemFileAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.007,
        mitre-attack:T1018,
        mitre-attack:T1036.003,
        mitre-attack:T1055.009,
        mitre-attack:T1070.002,
        mitre-attack:T1543.002,
        mitre-attack:T1548.003,
        mitre-attack:T1556.003,
        mitre-attack:T1574.006 .

d3f:SystemServiceSoftware a owl:Class ;
    rdfs:label "SystemServiceSoftware" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Service Software" ;
    rdfs:seeAlso <https://www.os-book.com/OS9/slide-dir/PPT-dir/ch2.ppt> ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "Software services provided as part of the operating system, typically accessed through system calls." ;
    skos:exactMatch d3f:SystemServiceSoftware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1011 a owl:Class ;
    rdfs:label "T1011" ;
    d3f:attack-id "T1011" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over Other Network Medium" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may attempt to exfiltrate data over a different network medium than the command and control channel. If the command and control network is a wired Internet connection, the exfiltration may occur, for example, over a WiFi connection, modem, cellular data connection, Bluetooth, or another radio frequency (RF) channel." ;
    skos:exactMatch d3f:T1011,
        mitre-attack:T1011 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1020 a owl:Class ;
    rdfs:label "T1020" ;
    d3f:attack-id "T1020" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Automated Exfiltration" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may exfiltrate data, such as sensitive documents, through the use of automated processing after being gathered during Collection.(Citation: ESET Gamaredon June 2020)" ;
    skos:exactMatch d3f:T1020,
        mitre-attack:T1020 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1072 a owl:Class ;
    rdfs:label "T1072" ;
    d3f:attack-id "T1072" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Deployment Tools" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "Adversaries may gain access to and use centralized software suites installed within an enterprise to execute commands and move laterally through the network. Configuration management and software deployment applications may be used in an enterprise network or cloud environment for routine administration purposes. These systems may also be integrated into CI/CD pipelines. Examples of such solutions include: SCCM, HBSS, Altiris, AWS Systems Manager, Microsoft Intune, Azure Arc, and GCP Deployment Manager." ;
    skos:exactMatch d3f:T1072,
        mitre-attack:T1072 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1095 a owl:Class ;
    rdfs:label "T1095" ;
    d3f:attack-id "T1095" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Non-Application Layer Protocol" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may use an OSI non-application layer protocol for communication between host and C2 server or among infected hosts within a network. The list of possible protocols is extensive.(Citation: Wikipedia OSI) Specific examples include use of network layer protocols, such as the Internet Control Message Protocol (ICMP), transport layer protocols, such as the User Datagram Protocol (UDP), session layer protocols, such as Socket Secure (SOCKS), as well as redirected/tunneled protocols, such as Serial over LAN (SOL)." ;
    skos:exactMatch d3f:T1095,
        mitre-attack:T1095 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1418 a owl:Class ;
    rdfs:label "T1418" ;
    d3f:attack-id "T1418" ;
    dcterms:title "Software Discovery" ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of applications that are installed on a device. Adversaries may use the information from [Software Discovery](https://attack.mitre.org/techniques/T1418) during automated discovery to shape follow-on behaviors, including whether or not to fully infect the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1418,
        mitre-attack:T1418 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1421 a owl:Class ;
    rdfs:label "T1421" ;
    d3f:attack-id "T1421" ;
    dcterms:title "System Network Connections Discovery" ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of network connections to or from the compromised device they are currently accessing or from remote systems by querying for information over the network." ;
    skos:exactMatch d3f:T1421,
        mitre-attack:T1421 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1437 a owl:Class ;
    rdfs:label "T1437" ;
    d3f:attack-id "T1437" ;
    dcterms:title "Application Layer Protocol" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may communicate using application layer protocols to avoid detection/network filtering by blending in with existing traffic. Commands to the mobile device, and often the results of those commands, will be embedded within the protocol traffic between the mobile device and server." ;
    skos:exactMatch d3f:T1437,
        mitre-attack:T1437 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1485 a owl:Class ;
    rdfs:label "T1485" ;
    d3f:attack-id "T1485" ;
    dcterms:title "Data Destruction" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may destroy data and files on specific systems or in large numbers on a network to interrupt availability to systems, services, and network resources. Data destruction is likely to render stored data irrecoverable by forensic techniques through overwriting files or data on local and remote drives.(Citation: Symantec Shamoon 2012)(Citation: FireEye Shamoon Nov 2016)(Citation: Palo Alto Shamoon Nov 2016)(Citation: Kaspersky StoneDrill 2017)(Citation: Unit 42 Shamoon3 2018)(Citation: Talos Olympic Destroyer 2018) Common operating system file deletion commands such as <code>del</code> and <code>rm</code> often only remove pointers to files without wiping the contents of the files themselves, making the files recoverable by proper forensic methodology. This behavior is distinct from [Disk Content Wipe](https://attack.mitre.org/techniques/T1561/001) and [Disk Structure Wipe](https://attack.mitre.org/techniques/T1561/002) because individual files are destroyed rather than sections of a storage disk or the disk's logical structure." ;
    skos:exactMatch d3f:T1485,
        mitre-attack:T1485 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1554 a owl:Class ;
    rdfs:label "T1554" ;
    d3f:attack-id "T1554" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Compromise Host Software Binary" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may modify host software binaries to establish persistent access to systems. Software binaries/executables provide a wide range of system commands or services, programs, and libraries. Common software binaries are SSH clients, FTP clients, email clients, web browsers, and many other user or server applications." ;
    skos:exactMatch d3f:T1554,
        mitre-attack:T1554 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1571 a owl:Class ;
    rdfs:label "T1571" ;
    d3f:attack-id "T1571" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Non-Standard Port" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may communicate using a protocol and port pairing that are typically not associated. For example, HTTPS over port 8088(Citation: Symantec Elfin Mar 2019) or port 587(Citation: Fortinet Agent Tesla April 2018) as opposed to the traditional port 443. Adversaries may make changes to the standard port used by a protocol to bypass filtering or muddle analysis/parsing of network data." ;
    skos:exactMatch d3f:T1571,
        mitre-attack:T1571 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1599 a owl:Class ;
    rdfs:label "T1599" ;
    d3f:attack-id "T1599" ;
    dcterms:title "Network Boundary Bridging" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may bridge network boundaries by compromising perimeter network devices or internal devices responsible for network segmentation. Breaching these devices may enable an adversary to bypass restrictions on traffic routing that otherwise separate trusted and untrusted networks." ;
    skos:exactMatch d3f:T1599,
        mitre-attack:T1599 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1623 a owl:Class ;
    rdfs:label "T1623" ;
    d3f:attack-id "T1623" ;
    dcterms:title "Command and Scripting Interpreter" ;
    rdfs:subClassOf d3f:ATTACKMobileExecutionTechnique ;
    skos:definition "Adversaries may abuse command and script interpreters to execute commands, scripts, or binaries. These interfaces and languages provide ways of interacting with computer systems and are a common feature across many different platforms. Most systems come with some built-in command-line interface and scripting capabilities, for example, Android is a UNIX-like OS and includes a basic [Unix Shell](https://attack.mitre.org/techniques/T1623/001) that can be accessed via the Android Debug Bridge (ADB) or Java’s `Runtime` package." ;
    skos:exactMatch d3f:T1623,
        mitre-attack:T1623 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1624 a owl:Class ;
    rdfs:label "T1624" ;
    d3f:attack-id "T1624" ;
    dcterms:title "Event Triggered Execution" ;
    rdfs:subClassOf d3f:ATTACKMobilePersistenceTechnique ;
    skos:definition "Adversaries may establish persistence using system mechanisms that trigger execution based on specific events. Mobile operating systems have means to subscribe to events such as receiving an SMS message, device boot completion, or other device activities." ;
    skos:exactMatch d3f:T1624,
        mitre-attack:T1624 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1625 a owl:Class ;
    rdfs:label "T1625" ;
    d3f:attack-id "T1625" ;
    dcterms:title "Hijack Execution Flow" ;
    rdfs:subClassOf d3f:ATTACKMobilePersistenceTechnique ;
    skos:definition "Adversaries may execute their own malicious payloads by hijacking the way operating systems run applications. Hijacking execution flow can be for the purposes of persistence since this hijacked execution may reoccur over time." ;
    skos:exactMatch d3f:T1625,
        mitre-attack:T1625 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1626 a owl:Class ;
    rdfs:label "T1626" ;
    d3f:attack-id "T1626" ;
    dcterms:title "Abuse Elevation Control Mechanism" ;
    rdfs:subClassOf d3f:ATTACKMobilePrivilegeEscalationTechnique ;
    skos:definition "Adversaries may circumvent mechanisms designed to control elevated privileges to gain higher-level permissions. Most modern systems contain native elevation control mechanisms that are intended to limit privileges that a user can gain on a machine. Authorization has to be granted to specific users in order to perform tasks that are designated as higher risk. An adversary can use several methods to take advantage of built-in control mechanisms in order to escalate privileges on a system." ;
    skos:exactMatch d3f:T1626,
        mitre-attack:T1626 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1627 a owl:Class ;
    rdfs:label "T1627" ;
    d3f:attack-id "T1627" ;
    dcterms:title "Execution Guardrails" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may use execution guardrails to constrain execution or actions based on adversary supplied and environment specific conditions that are expected to be present on the target. Guardrails ensure that a payload only executes against an intended target and reduces collateral damage from an adversary’s campaign. Values an adversary can provide about a target system or environment to use as guardrails may include environment information such as location.(Citation: SWB Exodus March 2019)" ;
    skos:exactMatch d3f:T1627,
        mitre-attack:T1627 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1631 a owl:Class ;
    rdfs:label "T1631" ;
    d3f:attack-id "T1631" ;
    dcterms:title "Process Injection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePrivilegeEscalationTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may inject code into processes in order to evade process-based defenses or even elevate privileges. Process injection is a method of executing arbitrary code in the address space of a separate live process. Running code in the context of another process may allow access to the process's memory, system/network resources, and possibly elevated privileges. Execution via process injection may also evade detection from security products since the execution is masked under a legitimate process." ;
    skos:exactMatch d3f:T1631,
        mitre-attack:T1631 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1632 a owl:Class ;
    rdfs:label "T1632" ;
    d3f:attack-id "T1632" ;
    dcterms:title "Subvert Trust Controls" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may undermine security controls that will either warn users of untrusted activity or prevent execution of untrusted applications. Operating systems and security products may contain mechanisms to identify programs or websites as possessing some level of trust. Examples of such features include: an app being allowed to run because it is signed by a valid code signing certificate; an OS prompt alerting the user that an app came from an untrusted source; or getting an indication that you are about to connect to an untrusted site. The method adversaries use will depend on the specific mechanism they seek to subvert." ;
    skos:exactMatch d3f:T1632,
        mitre-attack:T1632 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1633 a owl:Class ;
    rdfs:label "T1633" ;
    d3f:attack-id "T1633" ;
    dcterms:title "Virtualization/Sandbox Evasion" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may employ various means to detect and avoid virtualization and analysis environments. This may include changing behaviors after checking for the presence of artifacts indicative of a virtual machine environment (VME) or sandbox. If the adversary detects a VME, they may alter their malware’s behavior to disengage from the victim or conceal the core functions of the payload. They may also search for VME artifacts before dropping further payloads. Adversaries may use the information learned from [Virtualization/Sandbox Evasion](https://attack.mitre.org/techniques/T1633) during automated discovery to shape follow-on behaviors." ;
    skos:exactMatch d3f:T1633,
        mitre-attack:T1633 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1634 a owl:Class ;
    rdfs:label "T1634" ;
    d3f:attack-id "T1634" ;
    dcterms:title "Credentials from Password Store" ;
    rdfs:subClassOf d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "Adversaries may search common password storage locations to obtain user credentials. Passwords can be stored in several places on a device, depending on the operating system or application holding the credentials. There are also specific applications that store passwords to make it easier for users to manage and maintain. Once credentials are obtained, they can be used to perform lateral movement and access restricted information." ;
    skos:exactMatch d3f:T1634,
        mitre-attack:T1634 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1635 a owl:Class ;
    rdfs:label "T1635" ;
    d3f:attack-id "T1635" ;
    dcterms:title "Steal Application Access Token" ;
    rdfs:subClassOf d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "Adversaries can steal user application access tokens as a means of acquiring credentials to access remote systems and resources. This can occur through social engineering or URI hijacking and typically requires user action to grant access, such as through a system “Open With” dialogue." ;
    skos:exactMatch d3f:T1635,
        mitre-attack:T1635 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1637 a owl:Class ;
    rdfs:label "T1637" ;
    d3f:attack-id "T1637" ;
    dcterms:title "Dynamic Resolution" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may dynamically establish connections to command and control infrastructure to evade common detections and remediations. This may be achieved by using malware that shares a common algorithm with the infrastructure the adversary uses to receive the malware's communications. This algorithm can be used to dynamically adjust parameters such as the domain name, IP address, or port number the malware uses for command and control." ;
    skos:exactMatch d3f:T1637,
        mitre-attack:T1637 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1638 a owl:Class ;
    rdfs:label "T1638" ;
    d3f:attack-id "T1638" ;
    dcterms:title "Adversary-in-the-Middle" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may attempt to position themselves between two or more networked devices to support follow-on behaviors such as [Transmitted Data Manipulation](https://attack.mitre.org/techniques/T1565/002) or [Endpoint Denial of Service](https://attack.mitre.org/techniques/T1642)." ;
    skos:exactMatch d3f:T1638,
        mitre-attack:T1638 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1639 a owl:Class ;
    rdfs:label "T1639" ;
    d3f:attack-id "T1639" ;
    dcterms:title "Exfiltration Over Alternative Protocol" ;
    rdfs:subClassOf d3f:ATTACKMobileExfiltrationTechnique ;
    skos:definition "Adversaries may steal data by exfiltrating it over a different protocol than that of the existing command and control channel. The data may also be sent to an alternate network location from the main command and control server." ;
    skos:exactMatch d3f:T1639,
        mitre-attack:T1639 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1641 a owl:Class ;
    rdfs:label "T1641" ;
    d3f:attack-id "T1641" ;
    dcterms:title "Data Manipulation" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may insert, delete, or alter data in order to manipulate external outcomes or hide activity. By manipulating data, adversaries may attempt to affect a business process, organizational understanding, or decision making." ;
    skos:exactMatch d3f:T1641,
        mitre-attack:T1641 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1644 a owl:Class ;
    rdfs:label "T1644" ;
    d3f:attack-id "T1644" ;
    dcterms:title "Out of Band Data" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may communicate with compromised devices using out of band data streams. This could be done for a variety of reasons, including evading network traffic monitoring, as a backup method of command and control, or for data exfiltration if the device is not connected to any Internet-providing networks (i.e. cellular or Wi-Fi). Several out of band data streams exist, such as SMS messages, NFC, and Bluetooth." ;
    skos:exactMatch d3f:T1644,
        mitre-attack:T1644 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1647 a owl:Class ;
    rdfs:label "T1647" ;
    d3f:attack-id "T1647" ;
    dcterms:title "Plist File Modification" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may modify property list files (plist files) to enable other malicious activity, while also potentially evading and bypassing system defenses. macOS applications use plist files, such as the <code>info.plist</code> file, to store properties and configuration settings that inform the operating system how to handle the application at runtime. Plist files are structured metadata in key-value pairs formatted in XML based on Apple's Core Foundation DTD. Plist files can be saved in text or binary format.(Citation: fileinfo plist file description)" ;
    skos:exactMatch d3f:T1647,
        mitre-attack:T1647 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1655 a owl:Class ;
    rdfs:label "T1655" ;
    d3f:attack-id "T1655" ;
    dcterms:title "Masquerading" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to manipulate features of their artifacts to make them appear legitimate or benign to users and/or security tools. Masquerading occurs when the name, location, or appearance of an object, legitimate or malicious, is manipulated or abused for the sake of evading defenses and observation. This may include manipulating file metadata, tricking users into misidentifying the file type, and giving legitimate task or service names." ;
    skos:exactMatch d3f:T1655,
        mitre-attack:T1655 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TemporalDifferenceLearning a owl:Class ;
    rdfs:label "TemporalDifferenceLearning" ;
    d3f:d3fend-id "D3A-TDL" ;
    d3f:kb-article "## References Temporal difference learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Temporal_difference_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Temporal Difference Learning" ;
    rdfs:subClassOf d3f:ModelFreeReinforcementLearning ;
    skos:definition "Temporal difference (TD) learning refers to a class of model-free reinforcement learning methods which learn by bootstrapping from the current estimate of the value function. These methods sample from the environment, like Monte Carlo methods, and perform updates based on current estimates, like dynamic programming methods" ;
    skos:exactMatch d3f:TemporalDifferenceLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "Temporal difference (TD) learning refers to a class of model-free reinforcement learning methods which learn by bootstrapping from the current estimate of the value function." .

d3f:ThinClientComputer a owl:Class ;
    rdfs:label "ThinClientComputer" ;
    dcterms:title "Thin Client Computer" ;
    rdfs:seeAlso dbr:Thin_client ;
    rdfs:subClassOf d3f:SharedComputer ;
    skos:definition "A thin client is a lightweight computer that has been optimized for establishing a remote connection with a server-based computing environment. The server does most of the work, which can include launching software programs, performing calculations, and storing data. This contrasts with a fat client or a conventional personal computer; the former is also intended for working in a client-server model but has significant local processing power, while the latter aims to perform its function mostly locally. Thin clients are shared computers as the thin client's computing resources are provided by a remote server." ;
    skos:exactMatch d3f:ThinClientComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TicketGrantingTicket a owl:Class ;
    rdfs:label "TicketGrantingTicket" ;
    dcterms:title "Ticket Granting Ticket" ;
    rdfs:seeAlso dbr:Charlie_and_the_Chocolate_Factory,
        dbr:Ticket_Granting_Ticket ;
    rdfs:subClassOf d3f:AccessToken ;
    skos:altLabel "Golden Ticket" ;
    skos:definition "In some computer security systems, a Ticket Granting Ticket or Ticket to Get Tickets (TGT) is a small, encrypted identification file with a limited validity period. After authentication, this file is granted to a user for data traffic protection by the key distribution center (KDC) subsystem of authentication services such as Kerberos. The TGT file contains the session key, its expiration date, and the user's IP address, which protects the user from man-in-the-middle attacks. The TGT is used to obtain a service ticket from Ticket Granting Service (TGS). User is granted access to network services only after this service ticket is provided." ;
    skos:exactMatch d3f:TicketGrantingTicket ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimeRecord a owl:Class ;
    rdfs:label "TimeRecord" ;
    dcterms:title "Time Record" ;
    rdfs:subClassOf d3f:Record ;
    skos:definition "A time record either records, describes, represents, or is generally about Time." ;
    skos:exactMatch d3f:TimeRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Transponder a owl:Class ;
    rdfs:label "Transponder" ;
    rdfs:seeAlso dbr:Transponder ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "In telecommunications, a transponder is a device that, upon receiving a signal, emits a different signal in response." ;
    skos:exactMatch d3f:Transponder ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TrustStore a owl:Class ;
    rdfs:label "TrustStore" ;
    dcterms:title "Trust Store" ;
    rdfs:seeAlso dbr:Public_key_certificate,
        <https://www.educative.io/edpresso/keystore-vs-truststore> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "Stores public information necessary to determine if another party can be trusted." ;
    skos:exactMatch d3f:TrustStore ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:URL a owl:Class ;
    rdfs:label "URL" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Uniform_Resource_Locator,
        <https://schema.ocsf.io/objects/url> ;
    rdfs:subClassOf d3f:Identifier ;
    skos:altLabel "Uniform Resource Locator" ;
    skos:closeMatch stix:Url ;
    skos:definition "A Uniform Resource Locator (URL), commonly informally termed a web address (a term which is not defined identically) is a reference to a web resource that specifies its location on a computer network and a mechanism for retrieving it.A URL is a specific type of Uniform Resource Identifier (URI), although many people use the two terms interchangeably. A URL implies the means to access an indicated resource, which is not true of every URI. URLs occur most commonly to reference web pages (http), but are also used for file transfer (ftp), email (mailto), database access (JDBC), and many other applications." ;
    skos:exactMatch d3f:URL,
        unified_cyber_ontology:URL ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAction a owl:Class ;
    rdfs:label "UserAction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Action" ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "An action performed by a user. Executing commands, granting permissions, and accessing resources are examples of user actions." ;
    skos:exactMatch d3f:UserAction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserInitScript a owl:Class ;
    rdfs:label "UserInitScript" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Init Script" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InitScript ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UserLogonInitResource ],
        d3f:ExecutableScript ;
    skos:definition "A script used to initialize and configure elements of the user's applications and user environment." ;
    skos:exactMatch d3f:UserInitScript ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserProcess a owl:Class ;
    rdfs:label "UserProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Process" ;
    rdfs:subClassOf d3f:Process ;
    skos:broadMatch unified_cyber_ontology:Process ;
    skos:closeMatch stix:Process ;
    skos:definition "A user process is a process running to perform functions in the name of on particular user and user account, such as run an application or application service serving any number users.  This is in contrast to a system process, which executes software to fulfill operating system functions." ;
    skos:exactMatch d3f:UserProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UtilitySoftware a owl:Class ;
    rdfs:label "UtilitySoftware" ;
    dcterms:title "Utility Software" ;
    rdfs:seeAlso dbr:Utility_software ;
    rdfs:subClassOf d3f:Software ;
    skos:altLabel "Utility Application" ;
    skos:definition "Utility applications are software applications designed to help to analyze, configure, optimize or maintain a computer. It is used to support the computer infrastructure - in contrast to application software, which is aimed at directly performing tasks that benefit ordinary users. However, utilities often form part of the application systems. For example, a batch job may run user-written code to update a database and may then include a step that runs a utility to back up the database, or a job may run a utility to compress a disk before copying files." ;
    skos:exactMatch d3f:UtilitySoftware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Vehicle a owl:Class ;
    rdfs:label "Vehicle" ;
    rdfs:seeAlso dbr:Vehicle ;
    rdfs:subClassOf d3f:PhysicalArtifact ;
    skos:definition "A vehicle is a machine designed for self-propulsion, usually to transport people, cargo, or both." ;
    skos:exactMatch d3f:Vehicle ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:VideoInputDevice a owl:Class ;
    rdfs:label "VideoInputDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Video Input Device" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Input_device#Video_input_devices> ;
    rdfs:subClassOf d3f:InputDevice ;
    skos:definition "Video input devices are used to digitize images or video from the outside world into the computer. The information can be stored in a multitude of formats depending on the user's requirement." ;
    skos:exactMatch d3f:VideoInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebAuthentication a owl:Class ;
    rdfs:label "WebAuthentication" ;
    dcterms:title "Web Authentication" ;
    rdfs:subClassOf d3f:Authentication ;
    skos:definition "A request-response comprising a user credential presentation to a system and a verification response where the verifying party is a web server." ;
    skos:exactMatch d3f:WebAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WebSocketURL a owl:Class ;
    rdfs:label "WebSocketURL" ;
    rdfs:subClassOf d3f:URLEnum,
        linkml:PermissibleValue ;
    skos:definition "Web Socket URL" .

d3f:WindowsBatchFile a owl:Class ;
    rdfs:label "WindowsBatchFile" ;
    rdfs:subClassOf d3f:ExecutableScriptEnum,
        linkml:PermissibleValue ;
    skos:definition "Windows Batch File" .

d3f:WindowsProcess a owl:Class ;
    rdfs:label "WindowsProcess" ;
    rdfs:subClassOf d3f:ProcessEnum,
        linkml:PermissibleValue ;
    skos:definition "Windows Process" .

d3f:WirelessAccessPoint a owl:Class ;
    rdfs:label "WirelessAccessPoint" ;
    dcterms:title "Wireless Access Point" ;
    rdfs:seeAlso dbr:Wireless_access_point ;
    rdfs:subClassOf d3f:ComputerNetworkNode ;
    skos:altLabel "WAP" ;
    skos:definition "In computer networking, a wireless access point (WAP), or more generally just access point (AP), is a networking hardware device that allows other Wi-Fi devices to connect to a wired network. The AP usually connects to a router (via a wired network) as a standalone device, but it can also be an integral component of the router itself. An AP is differentiated from a hotspot which is a physical location where Wi-Fi access is available." ;
    skos:exactMatch d3f:WirelessAccessPoint ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:creates a owl:DatatypeProperty ;
    rdfs:label "creates" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/01630392-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x creates y: The subject x bring into existence an object y.  Some technique or agent x creates a persistent digital artifact y (as opposed to production of a consumable or transient object.); i.e., bring forth or generate" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:depends_on a owl:DatatypeProperty ;
    rdfs:label "depends-on" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/00729216-a> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x depends-on y: The entity x is contingent on y being available; x relies on y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_input a owl:ObjectProperty ;
    rdfs:label "has-input" ;
    rdfs:range d3f:Artifact ;
    rdfs:subPropertyOf d3f:has_participant ;
    skos:definition "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:has_output a owl:ObjectProperty ;
    rdfs:label "has-output" ;
    rdfs:range d3f:Artifact ;
    rdfs:subPropertyOf d3f:has_participant ;
    skos:definition "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:iOSProcess a owl:Class ;
    rdfs:label "iOSProcess" ;
    rdfs:subClassOf d3f:ProcessEnum,
        linkml:PermissibleValue ;
    skos:definition "iOS Process" .

d3f:impairs a owl:DatatypeProperty ;
    rdfs:label "impairs" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x impairs y: The entity or action x hinders entity y by reducing its normal function, capacity, or availability." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:input_of a owl:ObjectProperty ;
    rdfs:label "input-of" ;
    rdfs:range d3f:Event ;
    rdfs:subPropertyOf d3f:participates_in ;
    skos:definition "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:macOSProcess a owl:Class ;
    rdfs:label "macOSProcess" ;
    rdfs:subClassOf d3f:ProcessEnum,
        linkml:PermissibleValue ;
    skos:definition "macOS Process" .

d3f:may_be_tactically_associated_with a owl:DatatypeProperty ;
    rdfs:label "may-be-tactically-associated-with" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-be-tactically-associated-with y: the defensive action x may be a tactic that counters offensive action y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_counter a owl:DatatypeProperty ;
    rdfs:label "may-counter" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:output_of a owl:ObjectProperty ;
    rdfs:label "output-of" ;
    rdfs:range d3f:Event ;
    rdfs:subPropertyOf d3f:participates_in ;
    skos:definition "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:participates_in a owl:DatatypeProperty ;
    rdfs:label "participates-in" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://purl.obolibrary.org/obo/BFO_0000056> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x participates-in y: The object x takes part in the event y, signifying that x contributes to or is affected by the event’s occurrence in some way." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:windows_registry_data_property a owl:DatatypeProperty ;
    rdfs:label "windows-registry-data-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_artifact_data_property ;
    skos:definition "x windows-registry-data-property y: The windows registry entry x has the property y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AML.TA0000 a owl:Class ;
    rdfs:label "AML_TA0000" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "AI Model Access" ;
    skos:editorialNote "The adversary is attempting to gain some level of access to an AI model. AI Model Access enables techniques that use various types of access to the AI model that can be used by the adversary to gain information, develop attacks, and as a means to input data to the model. The level of access can range from the full knowledge of the internals of the model to access to the physical environment where" .

d3f:AML.TA0001 a owl:Class ;
    rdfs:label "AML_TA0001" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "AI Attack Staging" ;
    skos:editorialNote "The adversary is leveraging their knowledge of and access to the target system to tailor the attack. AI Attack Staging consists of techniques adversaries use to prepare their attack on the target AI model. Techniques can include training proxy models, poisoning the target model, and crafting adversarial data to feed the target model. Some of these techniques can be performed in an offline manner" .

d3f:AML.TA0002 a owl:Class ;
    rdfs:label "AML_TA0002" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Reconnaissance" ;
    skos:editorialNote "The adversary is trying to gather information about the AI system they can use to plan future operations. Reconnaissance consists of techniques that involve adversaries actively or passively gathering information that can be used to support targeting. Such information may include details of the victim organizations' AI capabilities and research efforts. This information can be leveraged by the ad" .

d3f:AML.TA0003 a owl:Class ;
    rdfs:label "AML_TA0003" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Resource Development" ;
    skos:editorialNote "The adversary is trying to establish resources they can use to support operations. Resource Development consists of techniques that involve adversaries creating, purchasing, or compromising/stealing resources that can be used to support targeting. Such resources include AI artifacts, infrastructure, accounts, or capabilities. These resources can be leveraged by the adversary to aid in other phase" .

d3f:AML.TA0004 a owl:Class ;
    rdfs:label "AML_TA0004" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Initial Access" ;
    skos:editorialNote "The adversary is trying to gain access to the AI system. The target system could be a network, mobile device, or an edge device such as a sensor platform. The AI capabilities used by the system could be local with onboard or cloud-enabled AI capabilities. Initial Access consists of techniques that use various entry vectors to gain their initial foothold within the system." .

d3f:AML.TA0005 a owl:Class ;
    rdfs:label "AML_TA0005" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Execution" ;
    skos:editorialNote "The adversary is trying to run malicious code embedded in AI artifacts or software. Execution consists of techniques that result in adversary-controlled code running on a local or remote system. Techniques that run malicious code are often paired with techniques from all other tactics to achieve broader goals, like exploring a network or stealing data. For example, an adversary might use a remote" .

d3f:AML.TA0006 a owl:Class ;
    rdfs:label "AML_TA0006" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Persistence" ;
    skos:editorialNote "The adversary is trying to maintain their foothold via AI artifacts or software. Persistence consists of techniques that adversaries use to keep access to systems across restarts, changed credentials, and other interruptions that could cut off their access. Techniques used for persistence often involve leaving behind modified ML artifacts such as poisoned training data or manipulated AI models." .

d3f:AML.TA0007 a owl:Class ;
    rdfs:label "AML_TA0007" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Defense Evasion" ;
    skos:editorialNote "The adversary is trying to avoid being detected by AI-enabled security software. Defense Evasion consists of techniques that adversaries use to avoid detection throughout their compromise. Techniques used for defense evasion include evading AI-enabled security software such as malware detectors." .

d3f:AML.TA0008 a owl:Class ;
    rdfs:label "AML_TA0008" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Discovery" ;
    skos:editorialNote "The adversary is trying to figure out your AI environment. Discovery consists of techniques an adversary may use to gain knowledge about the system and internal network. These techniques help adversaries observe the environment and orient themselves before deciding how to act. They also allow adversaries to explore what they can control and what's around their entry point in order to discover how" .

d3f:AML.TA0009 a owl:Class ;
    rdfs:label "AML_TA0009" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Collection" ;
    skos:editorialNote "The adversary is trying to gather AI artifacts and other related information relevant to their goal. Collection consists of techniques adversaries may use to gather information and the sources information is collected from that are relevant to following through on the adversary's objectives. Frequently, the next goal after collecting data is to steal (exfiltrate) the AI artifacts, or use the coll" .

d3f:AML.TA0010 a owl:Class ;
    rdfs:label "AML_TA0010" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Exfiltration" ;
    skos:editorialNote "The adversary is trying to steal AI artifacts or other information about the AI system. Exfiltration consists of techniques that adversaries may use to steal data from your network. Data may be stolen for its valuable intellectual property, or for use in staging future operations. Techniques for getting data out of a target network typically include transferring it over their command and control" .

d3f:AML.TA0011 a owl:Class ;
    rdfs:label "AML_TA0011" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Impact" ;
    skos:editorialNote "The adversary is trying to manipulate, interrupt, erode confidence in, or destroy your AI systems and data. Impact consists of techniques that adversaries use to disrupt availability or compromise integrity by manipulating business and operational processes. Techniques used for impact can include destroying or tampering with data. In some cases, business processes can look fine, but may have been" .

d3f:AML.TA0012 a owl:Class ;
    rdfs:label "AML_TA0012" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Privilege Escalation" ;
    skos:editorialNote "The adversary is trying to gain higher-level permissions. Privilege Escalation consists of techniques that adversaries use to gain higher-level permissions on a system or network. Adversaries can often enter and explore a network with unprivileged access but require elevated permissions to follow through on their objectives. Common approaches are to take advantage of system weaknesses, misconfigu" .

d3f:AML.TA0013 a owl:Class ;
    rdfs:label "AML_TA0013" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Credential Access" ;
    skos:editorialNote "The adversary is trying to steal account names and passwords. Credential Access consists of techniques for stealing credentials like account names and passwords. Techniques used to get credentials include keylogging or credential dumping. Using legitimate credentials can give adversaries access to systems, make them harder to detect, and provide the opportunity to create more accounts to help ach" .

d3f:AML.TA0014 a owl:Class ;
    rdfs:label "AML_TA0014" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Command and Control" ;
    skos:editorialNote "The adversary is trying to communicate with compromised AI systems to control them. Command and Control consists of techniques that adversaries may use to communicate with systems under their control within a victim network. Adversaries commonly attempt to mimic normal, expected traffic to avoid detection. There are many ways an adversary can establish command and control with various levels of s" .

d3f:AML.TA0015 a owl:Class ;
    rdfs:label "AML_TA0015" ;
    rdfs:subClassOf d3f:OffensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "Lateral Movement" ;
    skos:editorialNote "The adversary is trying to move through your AI environment. Lateral Movement consists of techniques that adversaries may use to gain access to and control other systems or components in the environment. Adversaries may pivot towards AI Ops infrastructure such as model registries, experiment trackers, vector databases, notebooks, or training pipelines. As the adversary moves through the environme" .

d3f:AMLT0000 a owl:Class ;
    rdfs:label "AML_T0000" ;
    d3f:attack-id "AML.T0000" ;
    dcterms:title "Search Open Technical Databases" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0000> ;
    rdfs:subClassOf d3f:ATLASReconnaissanceTechnique ;
    skos:altLabel "AML.T0000" ;
    skos:definition """Adversaries may search for publicly available research and technical documentation to learn how and where AI is used within a victim organization.
The adversary can use this information to identify targets for attack, or to tailor an existing attack to make it more effective.
Organizations often use open source model architectures trained on additional proprietary data in production.
Knowledge of this underlying architecture allows the adversary to craft more realistic proxy models ([Create Proxy AI Model](/techniques/AML.T0005)).
An adversary can search these resources for publications for authors employed at the victim organization.

Research and technical materials may exist as academic papers published in [Journals and Conference Proceedings](/techniques/AML.T0000.000), or stored in [Pre-Print Repositories](/techniques/AML.T0000.001), as well as [Technical Blogs](/techniques/AML.T0000.002).""" ;
    skos:exactMatch d3f:AML.T0000,
        atlas:AML.T0000 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0005 a owl:Class ;
    rdfs:label "AML_T0005" ;
    d3f:attack-id "AML.T0005" ;
    dcterms:title "Create Proxy AI Model" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0005> ;
    rdfs:subClassOf d3f:ATLASAIAttackStagingTechnique ;
    skos:altLabel "AML.T0005" ;
    skos:definition """Adversaries may obtain models to serve as proxies for the target model in use at the victim organization.
Proxy models are used to simulate complete access to the target model in a fully offline manner.

Adversaries may train models from representative datasets, attempt to replicate models from victim inference APIs, or use available pre-trained models.""" ;
    skos:exactMatch d3f:AML.T0005,
        atlas:AML.T0005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0016 a owl:Class ;
    rdfs:label "AML_T0016" ;
    d3f:attack-id "AML.T0016" ;
    dcterms:title "Obtain Capabilities" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0016> ;
    rdfs:subClassOf d3f:ATLASResourceDevelopmentTechnique ;
    skos:altLabel "AML.T0016" ;
    skos:definition """Adversaries may search for and obtain software capabilities for use in their operations.
Capabilities may be specific to AI-based attacks [Adversarial AI Attack Implementations](/techniques/AML.T0016.000) or generic software tools repurposed for malicious intent ([Software Tools](/techniques/AML.T0016.001)). In both instances, an adversary may modify or customize the capability to aid in targeting a particular AI-enabled system.""" ;
    skos:exactMatch d3f:AML.T0016,
        atlas:AML.T0016 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0018 a owl:Class ;
    rdfs:label "AML_T0018" ;
    d3f:attack-id "AML.T0018" ;
    dcterms:title "Manipulate AI Model" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0018> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATLASPersistenceTechnique ],
        d3f:ATLASAIAttackStagingTechnique ;
    skos:altLabel "AML.T0018" ;
    skos:definition "Adversaries may directly manipulate an AI model to change its behavior or introduce malicious code. Manipulating a model gives the adversary a persistent change in the system. This can include poisoning the model by changing its weights, modifying the model architecture to change its behavior, and embedding malware which may be executed when the model is loaded." ;
    skos:exactMatch d3f:AML.T0018,
        atlas:AML.T0018 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0024 a owl:Class ;
    rdfs:label "AML_T0024" ;
    d3f:attack-id "AML.T0024" ;
    dcterms:title "Exfiltration via AI Inference API" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0024> ;
    rdfs:subClassOf d3f:ATLASExfiltrationTechnique ;
    skos:altLabel "AML.T0024" ;
    skos:definition """Adversaries may exfiltrate private information via [AI Model Inference API Access](/techniques/AML.T0040).
AI Models have been shown leak private information about their training data (e.g.  [Infer Training Data Membership](/techniques/AML.T0024.000), [Invert AI Model](/techniques/AML.T0024.001)).
The model itself may also be extracted ([Extract AI Model](/techniques/AML.T0024.002)) for the purposes of [AI Intellectual Property Theft](/techniques/AML.T0048.004).

Exfiltration of information relating to private training data raises privacy concerns.
Private training data may include personally identifiable information, or other protected data.""" ;
    skos:exactMatch d3f:AML.T0024,
        atlas:AML.T0024 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0051 a owl:Class ;
    rdfs:label "AML_T0051" ;
    d3f:attack-id "AML.T0051" ;
    dcterms:title "LLM Prompt Injection" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0051> ;
    rdfs:subClassOf d3f:ATLASExecutionTechnique ;
    skos:altLabel "AML.T0051" ;
    skos:definition """An adversary may craft malicious prompts as inputs to an LLM that cause the LLM to act in unintended ways.
These "prompt injections" are often designed to cause the model to ignore aspects of its original instructions and follow the adversary's instructions instead.

Prompt Injections can be an initial access vector to the LLM that provides the adversary with a foothold to carry out other steps in their operation.
They may be designed to bypass defenses in the LLM, or allow the adversary to issue privileged commands.
The effects of a prompt injection can persist throughout an interactive session with an LLM.

Malicious prompts may be injected directly by the adversary ([Direct](/techniques/AML.T0051.000)) either to leverage the LLM to generate harmful content or to gain a foothold on the system and lead to further effects.
Prompts may also be injected indirectly when as part of its normal operation the LLM ingests the malicious prompt from another data source ([Indirect](/techniques/AML.T0051.001)). This type of injection can be used by the adversary to a foothold on the system or to target the user of the LLM.
Malicious prompts may also be [Triggered](/techniques/AML.T0051.002) user actions or system events.""" ;
    skos:exactMatch d3f:AML.T0051,
        atlas:AML.T0051 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0069 a owl:Class ;
    rdfs:label "AML_T0069" ;
    d3f:attack-id "AML.T0069" ;
    dcterms:title "Discover LLM System Information" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0069> ;
    rdfs:subClassOf d3f:ATLASDiscoveryTechnique ;
    skos:altLabel "AML.T0069" ;
    skos:definition "The adversary is trying to discover something about the large language model's (LLM) system information. This may be found in a configuration file containing the system instructions or extracted via interactions with the LLM. The desired information may include the full system prompt, special characters that have significance to the LLM or keywords indicating functionality available to the LLM. Information about how the LLM is instructed can be used by the adversary to understand the system's capabilities and to aid them in crafting malicious prompts." ;
    skos:exactMatch d3f:AML.T0069,
        atlas:AML.T0069 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AMLT0084 a owl:Class ;
    rdfs:label "AML_T0084" ;
    d3f:attack-id "AML.T0084" ;
    dcterms:title "Discover AI Agent Configuration" ;
    rdfs:seeAlso <https://atlas.mitre.org/techniques/AML.T0084> ;
    rdfs:subClassOf d3f:ATLASDiscoveryTechnique ;
    skos:altLabel "AML.T0084" ;
    skos:definition """Adversaries may attempt to discover configuration information for AI agents present on the victim's system. Agent configurations can include tools or services they have access to.

Adversaries may directly access agent configuring dashboards or configuration files. They may also obtain configuration details by prompting the agent with questions such as "What tools do you have access to?"

Adversaries can use the information they discover about AI agents to help with targeting.""" ;
    skos:exactMatch d3f:AML.T0084,
        atlas:AML.T0084 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ANNBasedClustering a owl:Class ;
    rdfs:label "ANN_basedClustering" ;
    d3f:d3fend-id "D3A-ABC" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Artificial neural network. [Link](https://en.wikipedia.org/wiki/Artificial_neural_network)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "ANN-based Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:altLabel "ANN-basedClustering" ;
    skos:definition "Combines the principles of Artificial Neural Networks (ANN) and clustering methods." ;
    skos:exactMatch d3f:ANN-basedClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASPrivilegeEscalationTechnique a owl:Class ;
    rdfs:label "ATLASPrivilegeEscalationTechnique" ;
    dcterms:title "Privilege Escalation Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASPrivilegeEscalationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASThing a owl:Class ;
    rdfs:label "ATLASThing" ;
    dcterms:title "ATLAS Thing" ;
    rdfs:subClassOf d3f:ExternalThreatModelThing ;
    skos:exactMatch d3f:ATLASThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSPrivilegeEscalationTechnique a owl:Class ;
    rdfs:label "ATTACKICSPrivilegeEscalationTechnique" ;
    dcterms:title "Privilege Escalation Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSPrivilegeEscalationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSThing a owl:Class ;
    rdfs:label "ATTACKICSThing" ;
    dcterms:title "ATTACK ICS Thing" ;
    rdfs:subClassOf d3f:ATTACKThing ;
    skos:exactMatch d3f:ATTACKICSThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileThing a owl:Class ;
    rdfs:label "ATTACKMobileThing" ;
    dcterms:title "ATTACK Mobile Thing" ;
    rdfs:subClassOf d3f:ATTACKThing ;
    skos:exactMatch d3f:ATTACKMobileThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessControlAdministrationEvent a owl:Class ;
    rdfs:label "AccessControlAdministrationEvent" ;
    dcterms:title "Access Control Administration Event" ;
    rdfs:subClassOf d3f:AccessControlEvent ;
    skos:altLabel "Permission Administration Event",
        "Permission Provisioning Event" ;
    skos:definition "An event concerning the administrative actions of setting, modifying, or abolishing permissions, configuring access control settings, and managing user access rights to ensure alignment with access control policies." ;
    skos:exactMatch d3f:AccessControlAdministrationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessControlEvent a owl:Class ;
    rdfs:label "AccessControlEvent" ;
    dcterms:title "Access Control Event" ;
    rdfs:subClassOf d3f:AuthorizationEvent ;
    skos:definition "An event that captures the implementation or evaluation of access control measures, including the application of rules and policies to govern the accessibility of resources by agents within a digital system." ;
    skos:exactMatch d3f:AccessControlEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessControlGroup a owl:Class ;
    rdfs:label "AccessControlGroup" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Access Control Group" ;
    rdfs:seeAlso <https://schema.ocsf.io/objects/group> ;
    rdfs:subClassOf d3f:AccessControlConfiguration ;
    skos:definition "A collection of objects that can have access controls placed on them." ;
    skos:exactMatch d3f:AccessControlGroup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessMediationEvent a owl:Class ;
    rdfs:label "AccessMediationEvent" ;
    dcterms:title "Access Mediation Event" ;
    rdfs:subClassOf d3f:AccessControlEvent ;
    skos:altLabel "Access Enforcement Event" ;
    skos:definition "An event involving the intermediary control mechanism that evaluates access requests and enforces access control decisions, ensuring that subjects' resource interactions comply with the established access policies." ;
    skos:exactMatch d3f:AccessMediationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AgentGroup a owl:Class ;
    rdfs:label "AgentGroup" ;
    dcterms:title "Agent Group" ;
    rdfs:subClassOf d3f:Group ;
    skos:exactMatch d3f:AgentGroup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationConfigurationFile a owl:Class ;
    rdfs:label "ApplicationConfigurationFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Configuration File" ;
    rdfs:subClassOf d3f:ConfigurationFile ;
    skos:definition "A file containing Information used to configure the parameters and initial settings for an application.. A plist file is an example of this type of file for macOS.  Usually text-based." ;
    skos:exactMatch d3f:ApplicationConfigurationFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ArchiveFile a owl:Class ;
    rdfs:label "ArchiveFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Archive File" ;
    rdfs:seeAlso dbr:Archive_file ;
    rdfs:subClassOf d3f:File ;
    skos:definition "An archive file is a file that is composed of one or more computer files along with metadata. Archive files are used to collect multiple data files together into a single file for easier portability and storage, or simply to compress files to use less storage space. Archive files often store directory structures, error detection and correction information, arbitrary comments, and sometimes use built-in encryption." ;
    skos:exactMatch d3f:ArchiveFile,
        unified_cyber_ontology:ArchiveFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ArtifactServer a owl:Class ;
    rdfs:label "ArtifactServer" ;
    dcterms:title "Artifact Server" ;
    rdfs:seeAlso dbr:Content_management,
        dbr:Content_repository ;
    rdfs:subClassOf d3f:WebServer ;
    skos:definition "A digital artifact server provides access services to digital artifacts in a repository.  It provides an associated set of data management, search and access methods allowing application-independent access to the content." ;
    skos:exactMatch d3f:ArtifactServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ArtificialNeuralNetClassification a owl:Class ;
    rdfs:label "ArtificialNeuralNetClassification" ;
    d3f:d3fend-id "D3A-ANNC" ;
    d3f:kb-article "## References ANN Classification. [Link](http://uc-r.github.io/ann_classification)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Artificial Neural Network Classification" ;
    rdfs:subClassOf d3f:Classification ;
    skos:exactMatch d3f:ArtificialNeuralNetClassification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AsymmetricKey a owl:Class ;
    rdfs:label "AsymmetricKey" ;
    dcterms:title "Asymmetric Key" ;
    rdfs:seeAlso dbr:Public-key_cryptography ;
    rdfs:subClassOf d3f:CryptographicKey ;
    skos:definition "Asymmetric keys are public and private keys, paired such that asymmetric (public-key) cryptography algorithms can be implemented using them. Public-key cryptography, or asymmetric cryptography, is any cryptographic system that uses pairs of keys: public keys that may be disseminated widely paired with private keys which are known only to the owner. There are two functions that can be achieved: using a public key to authenticate that a message originated with a holder of the paired private key; or encrypting a message with a public key to ensure that only the holder of the paired private key can decrypt it." ;
    skos:exactMatch d3f:AsymmetricKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthenticationService a owl:Class ;
    rdfs:label "AuthenticationService" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Authentication Service" ;
    rdfs:seeAlso dbr:Authentication,
        <https://www.gartner.com/en/information-technology/glossary/authentication-service> ;
    rdfs:subClassOf d3f:ServiceApplicationProcess ;
    skos:definition "An authentication service is a mechanism, analogous to the use of passwords on time-sharing systems, for the secure authentication of the identity of network clients by servers and vice versa, without presuming the operating system integrity of either (e.g., Kerberos)." ;
    skos:exactMatch d3f:AuthenticationService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthorizationService a owl:Class ;
    rdfs:label "AuthorizationService" ;
    dcterms:title "Authorization Service" ;
    rdfs:seeAlso dbr:Authorization,
        <https://www.sciencedirect.com/referencework/9780122272400/encyclopedia-of-information-systems> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceApplicationProcess ],
        d3f:NetworkService ;
    skos:definition "An authorization service ensures that the user is authorized to have access to a particular resource. Authorization can be done through role-based access control (RBAC) or list-based access control (LBAC)." ;
    skos:exactMatch d3f:AuthorizationService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AverageAbsoluteDeviation a owl:Class ;
    rdfs:label "AverageAbsoluteDeviation" ;
    d3f:d3fend-id "D3A-AAD" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Average absolute deviation. [Link](https://en.wikipedia.org/wiki/Average_absolute_deviation)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Average Absolute Deviation" ;
    rdfs:subClassOf d3f:Variability ;
    skos:definition "The average absolute deviation (AAD) of a data set is the average of the absolute deviations from a central point." ;
    skos:exactMatch d3f:AverageAbsoluteDeviation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BayesianMethod a owl:Class ;
    rdfs:label "BayesianMethod" ;
    d3f:d3fend-id "D3A-BM" ;
    d3f:kb-article "## References Wolfram MathWorld. (n.d.). Bayesian Analysis. [Link](https://mathworld.wolfram.com/BayesianAnalysis.html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Bayesian Method" ;
    rdfs:subClassOf d3f:StatisticalMethod ;
    skos:definition "Bayesian analysis is a statistical procedure which endeavors to estimate parameters of an underlying distribution based on the observed distribution." ;
    skos:exactMatch d3f:BayesianMethod ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BinarySegment a owl:Class ;
    rdfs:label "BinarySegment" ;
    dcterms:title "Binary Segment" ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A binary segment is a partition of binary information within a larger binary object, which arranges a set of binary objects for its purpose.   For example, code, data, heap, and stack segments are segments of the binary information used by a process.  Code and data segments are also found in object files." ;
    skos:exactMatch d3f:BinarySegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BootLoader a owl:Class ;
    rdfs:label "BootLoader" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Boot Loader" ;
    rdfs:seeAlso dbr:Bootloader ;
    rdfs:subClassOf d3f:Software ;
    skos:altLabel "Bootloader" ;
    skos:definition "A bootloader is software that is responsible for booting a computer. When a computer is turned off, its software‍-‌including operating systems, application code, and data‍-‌remains stored on non-volatile memory. When the computer is powered on, it typically does not have an operating system or its loader in random-access memory (RAM). The computer first executes a relatively small program stored in read-only memory (ROM, and later EEPROM, NOR flash) along with some needed data, to initialize RAM (especially on x86 systems) to access the nonvolatile device (usually block device, eg NAND flash) or devices from which the operating system programs and data can be loaded into RAM." ;
    skos:exactMatch d3f:BootLoader ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BootRecord a owl:Class ;
    rdfs:label "BootRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Boot Record" ;
    rdfs:subClassOf d3f:Record ;
    skos:definition "A d3f:Record which is an essential component of the early boot (system initialization) process." ;
    skos:exactMatch d3f:BootRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:BuildTool a owl:Class ;
    rdfs:label "BuildTool" ;
    dcterms:title "Build Tool" ;
    rdfs:seeAlso dbr:Build_automation ;
    rdfs:subClassOf d3f:DeveloperApplication ;
    skos:altLabel "Build Automation Tool" ;
    skos:definition "A tool that automates the process of creating a software build and the associated processes including: compiling computer source code into binary code, packaging binary code, and running automated tests." ;
    skos:exactMatch d3f:BuildTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE116 a owl:Class ;
    rdfs:label "CWE_116" ;
    d3f:cwe-id "CWE-116" ;
    d3f:synonym "Output Encoding" ;
    dcterms:title "Improper Encoding or Escaping of Output" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-116" ;
    skos:definition "The product prepares a structured message for communication with another component, but encoding or escaping of the data is either missing or done incorrectly. As a result, the intended structure of the message is not preserved." ;
    skos:exactMatch d3f:CWE-116,
        cwe:CWE-116 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1391 a owl:Class ;
    rdfs:label "CWE_1391" ;
    d3f:cwe-id "CWE-1391" ;
    dcterms:title "Use of Weak Credentials" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-1391" ;
    skos:definition "The product uses weak credentials (such as a default key or hard-coded password) that can be calculated, derived, reused, or guessed by an attacker." ;
    skos:exactMatch d3f:CWE-1391,
        cwe:CWE-1391 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1420 a owl:Class ;
    rdfs:label "CWE_1420" ;
    d3f:cwe-id "CWE-1420" ;
    dcterms:title "Exposure of Sensitive Information during Transient Execution" ;
    rdfs:subClassOf d3f:CWE669 ;
    skos:altLabel "CWE-1420" ;
    skos:definition "A processor event or prediction may allow incorrect operations (or correct operations with incorrect data) to execute transiently, potentially exposing data over a covert channel." ;
    skos:exactMatch d3f:CWE-1420,
        cwe:CWE-1420 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE159 a owl:Class ;
    rdfs:label "CWE_159" ;
    d3f:cwe-id "CWE-159" ;
    dcterms:title "Improper Handling of Invalid Use of Special Elements" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-159" ;
    skos:definition "The product does not properly filter, remove, quote, or otherwise manage the invalid use of special elements in user-controlled input, which could cause adverse effect on its behavior and integrity." ;
    skos:exactMatch d3f:CWE-159,
        cwe:CWE-159 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE209 a owl:Class ;
    rdfs:label "CWE_209" ;
    d3f:cwe-id "CWE-209" ;
    dcterms:title "Generation of Error Message Containing Sensitive Information" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE755 ],
        d3f:CWE200 ;
    skos:altLabel "CWE-209" ;
    skos:definition "The product generates an error message that includes sensitive information about its environment, users, or associated data." ;
    skos:exactMatch d3f:CWE-209,
        cwe:CWE-209 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE211 a owl:Class ;
    rdfs:label "CWE_211" ;
    d3f:cwe-id "CWE-211" ;
    dcterms:title "Externally-Generated Error Message Containing Sensitive Information" ;
    rdfs:subClassOf d3f:CWE209 ;
    skos:altLabel "CWE-211" ;
    skos:definition "The product performs an operation that triggers an external diagnostic or error message that is not directly generated or controlled by the product, such as an error generated by the programming language interpreter that a software application uses. The error can contain sensitive system information." ;
    skos:exactMatch d3f:CWE-211,
        cwe:CWE-211 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE229 a owl:Class ;
    rdfs:label "CWE_229" ;
    d3f:cwe-id "CWE-229" ;
    dcterms:title "Improper Handling of Values" ;
    rdfs:subClassOf d3f:CWE228 ;
    skos:altLabel "CWE-229" ;
    skos:definition "The product does not properly handle when the expected number of values for parameters, fields, or arguments is not provided in input, or if those values are undefined." ;
    skos:exactMatch d3f:CWE-229,
        cwe:CWE-229 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE233 a owl:Class ;
    rdfs:label "CWE_233" ;
    d3f:cwe-id "CWE-233" ;
    dcterms:title "Improper Handling of Parameters" ;
    rdfs:subClassOf d3f:CWE228 ;
    skos:altLabel "CWE-233" ;
    skos:definition "The product does not properly handle when the expected number of parameters, fields, or arguments is not provided in input, or if those parameters are undefined." ;
    skos:exactMatch d3f:CWE-233,
        cwe:CWE-233 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE237 a owl:Class ;
    rdfs:label "CWE_237" ;
    d3f:cwe-id "CWE-237" ;
    dcterms:title "Improper Handling of Structural Elements" ;
    rdfs:subClassOf d3f:CWE228 ;
    skos:altLabel "CWE-237" ;
    skos:definition "The product does not handle or incorrectly handles inputs that are related to complex structures." ;
    skos:exactMatch d3f:CWE-237,
        cwe:CWE-237 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE260 a owl:Class ;
    rdfs:label "CWE_260" ;
    d3f:cwe-id "CWE-260" ;
    dcterms:title "Password in Configuration File" ;
    rdfs:subClassOf d3f:CWE522 ;
    skos:altLabel "CWE-260" ;
    skos:definition "The product stores a password in a configuration file that might be accessible to actors who do not know the password." ;
    skos:exactMatch d3f:CWE-260,
        cwe:CWE-260 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE290 a owl:Class ;
    rdfs:label "CWE_290" ;
    d3f:cwe-id "CWE-290" ;
    dcterms:title "Authentication Bypass by Spoofing" ;
    rdfs:subClassOf d3f:CWE1390 ;
    skos:altLabel "CWE-290" ;
    skos:definition "This attack-focused weakness is caused by incorrectly implemented authentication schemes that are subject to spoofing attacks." ;
    skos:exactMatch d3f:CWE-290,
        cwe:CWE-290 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE319 a owl:Class ;
    rdfs:label "CWE_319" ;
    d3f:cwe-id "CWE-319" ;
    dcterms:title "Cleartext Transmission of Sensitive Information" ;
    rdfs:subClassOf d3f:CWE311 ;
    skos:altLabel "CWE-319" ;
    skos:definition "The product transmits sensitive or security-critical data in cleartext in a communication channel that can be sniffed by unauthorized actors." ;
    skos:exactMatch d3f:CWE-319,
        cwe:CWE-319 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE335 a owl:Class ;
    rdfs:label "CWE_335" ;
    d3f:cwe-id "CWE-335" ;
    dcterms:title "Incorrect Usage of Seeds in Pseudo-Random Number Generator (PRNG)" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-335" ;
    skos:definition "The product uses a Pseudo-Random Number Generator (PRNG) but does not correctly manage seeds." ;
    skos:exactMatch d3f:CWE-335,
        cwe:CWE-335 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE340 a owl:Class ;
    rdfs:label "CWE_340" ;
    d3f:cwe-id "CWE-340" ;
    dcterms:title "Generation of Predictable Numbers or Identifiers" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-340" ;
    skos:definition "The product uses a scheme that generates numbers or identifiers that are more predictable than required." ;
    skos:exactMatch d3f:CWE-340,
        cwe:CWE-340 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE344 a owl:Class ;
    rdfs:label "CWE_344" ;
    d3f:cwe-id "CWE-344" ;
    dcterms:title "Use of Invariant Value in Dynamically Changing Context" ;
    rdfs:subClassOf d3f:CWE330 ;
    skos:altLabel "CWE-344" ;
    skos:definition "The product uses a constant value, name, or reference, but this value can (or should) vary across different environments." ;
    skos:exactMatch d3f:CWE-344,
        cwe:CWE-344 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE364 a owl:Class ;
    rdfs:label "CWE_364" ;
    d3f:cwe-id "CWE-364" ;
    dcterms:title "Signal Handler Race Condition" ;
    rdfs:subClassOf d3f:CWE362 ;
    skos:altLabel "CWE-364" ;
    skos:definition "The product uses a signal handler that introduces a race condition." ;
    skos:exactMatch d3f:CWE-364,
        cwe:CWE-364 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE420 a owl:Class ;
    rdfs:label "CWE_420" ;
    d3f:cwe-id "CWE-420" ;
    dcterms:title "Unprotected Alternate Channel" ;
    rdfs:subClassOf d3f:CWE923 ;
    skos:altLabel "CWE-420" ;
    skos:definition "The product protects a primary channel, but it does not use the same level of protection for an alternate channel." ;
    skos:exactMatch d3f:CWE-420,
        cwe:CWE-420 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE446 a owl:Class ;
    rdfs:label "CWE_446" ;
    d3f:cwe-id "CWE-446" ;
    dcterms:title "UI Discrepancy for Security Feature" ;
    rdfs:subClassOf d3f:CWE684 ;
    skos:altLabel "CWE-446" ;
    skos:definition "The user interface does not correctly enable or configure a security feature, but the interface provides feedback that causes the user to believe that the feature is in a secure state." ;
    skos:exactMatch d3f:CWE-446,
        cwe:CWE-446 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE459 a owl:Class ;
    rdfs:label "CWE_459" ;
    d3f:cwe-id "CWE-459" ;
    d3f:synonym "Insufficient Cleanup" ;
    dcterms:title "Incomplete Cleanup" ;
    rdfs:subClassOf d3f:CWE404 ;
    skos:altLabel "CWE-459" ;
    skos:definition "The product does not properly \"clean up\" and remove temporary or supporting resources after they have been used." ;
    skos:exactMatch d3f:CWE-459,
        cwe:CWE-459 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE480 a owl:Class ;
    rdfs:label "CWE_480" ;
    d3f:cwe-id "CWE-480" ;
    dcterms:title "Use of Incorrect Operator" ;
    rdfs:subClassOf d3f:CWE670 ;
    skos:altLabel "CWE-480" ;
    skos:definition "The product accidentally uses the wrong operator, which changes the logic in security-relevant ways." ;
    skos:exactMatch d3f:CWE-480,
        cwe:CWE-480 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE538 a owl:Class ;
    rdfs:label "CWE_538" ;
    d3f:cwe-id "CWE-538" ;
    dcterms:title "Insertion of Sensitive Information into Externally-Accessible File or Directory" ;
    rdfs:subClassOf d3f:CWE200 ;
    skos:altLabel "CWE-538" ;
    skos:definition "The product places sensitive information into files or directories that are accessible to actors who are allowed to have access to the files, but not to the sensitive information." ;
    skos:exactMatch d3f:CWE-538,
        cwe:CWE-538 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE540 a owl:Class ;
    rdfs:label "CWE_540" ;
    d3f:cwe-id "CWE-540" ;
    dcterms:title "Inclusion of Sensitive Information in Source Code" ;
    rdfs:subClassOf d3f:CWE538 ;
    skos:altLabel "CWE-540" ;
    skos:definition "Source code on a web server or repository often contains sensitive information and should generally not be accessible to users." ;
    skos:exactMatch d3f:CWE-540,
        cwe:CWE-540 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE66 a owl:Class ;
    rdfs:label "CWE_66" ;
    d3f:cwe-id "CWE-66" ;
    dcterms:title "Improper Handling of File Names that Identify Virtual Resources" ;
    rdfs:subClassOf d3f:CWE706 ;
    skos:altLabel "CWE-66" ;
    skos:definition "The product does not handle or incorrectly handles a file name that identifies a \"virtual\" resource that is not directly specified within the directory that is associated with the file name, causing the product to perform file-based operations on a resource that is not a file." ;
    skos:exactMatch d3f:CWE-66,
        cwe:CWE-66 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE770 a owl:Class ;
    rdfs:label "CWE_770" ;
    d3f:cwe-id "CWE-770" ;
    dcterms:title "Allocation of Resources Without Limits or Throttling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE665 ],
        d3f:CWE400 ;
    skos:altLabel "CWE-770" ;
    skos:definition "The product allocates a reusable resource or group of resources on behalf of an actor without imposing any restrictions on the size or number of resources that can be allocated, in violation of the intended security policy for that actor." ;
    skos:exactMatch d3f:CWE-770,
        cwe:CWE-770 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE772 a owl:Class ;
    rdfs:label "CWE_772" ;
    d3f:cwe-id "CWE-772" ;
    dcterms:title "Missing Release of Resource after Effective Lifetime" ;
    rdfs:subClassOf d3f:CWE404 ;
    skos:altLabel "CWE-772" ;
    skos:definition "The product does not release a resource after its effective lifetime has ended, i.e., after the resource is no longer needed." ;
    skos:exactMatch d3f:CWE-772,
        cwe:CWE-772 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE788 a owl:Class ;
    rdfs:label "CWE_788" ;
    d3f:cwe-id "CWE-788" ;
    dcterms:title "Access of Memory Location After End of Buffer" ;
    rdfs:subClassOf d3f:CWE119 ;
    skos:altLabel "CWE-788" ;
    skos:definition "The product reads or writes to a buffer using an index or pointer that references a memory location after the end of the buffer." ;
    skos:exactMatch d3f:CWE-788,
        cwe:CWE-788 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE807 a owl:Class ;
    rdfs:label "CWE_807" ;
    d3f:cwe-id "CWE-807" ;
    dcterms:title "Reliance on Untrusted Inputs in a Security Decision" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-807" ;
    skos:definition "The product uses a protection mechanism that relies on the existence or values of an input, but the input can be modified by an untrusted actor in a way that bypasses the protection mechanism." ;
    skos:exactMatch d3f:CWE-807,
        cwe:CWE-807 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE820 a owl:Class ;
    rdfs:label "CWE_820" ;
    d3f:cwe-id "CWE-820" ;
    dcterms:title "Missing Synchronization" ;
    rdfs:subClassOf d3f:CWE662 ;
    skos:altLabel "CWE-820" ;
    skos:definition "The product utilizes a shared resource in a concurrent manner but does not attempt to synchronize access to the resource." ;
    skos:exactMatch d3f:CWE-820,
        cwe:CWE-820 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE829 a owl:Class ;
    rdfs:label "CWE_829" ;
    d3f:cwe-id "CWE-829" ;
    dcterms:title "Inclusion of Functionality from Untrusted Control Sphere" ;
    rdfs:subClassOf d3f:CWE669 ;
    skos:altLabel "CWE-829" ;
    skos:definition "The product imports, requires, or includes executable functionality (such as a library) from a source that is outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-829,
        cwe:CWE-829 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE834 a owl:Class ;
    rdfs:label "CWE_834" ;
    d3f:cwe-id "CWE-834" ;
    dcterms:title "Excessive Iteration" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-834" ;
    skos:definition "The product performs an iteration or loop without sufficiently limiting the number of times that the loop is executed." ;
    skos:exactMatch d3f:CWE-834,
        cwe:CWE-834 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE94 a owl:Class ;
    rdfs:label "CWE_94" ;
    d3f:cwe-id "CWE-94" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Code Injection" ;
    dcterms:title "Improper Control of Generation of Code ('Code Injection')" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE913 ],
        d3f:CWE74 ;
    skos:altLabel "CWE-94" ;
    skos:definition "The product constructs all or part of a code segment using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the syntax or behavior of the intended code segment." ;
    skos:exactMatch d3f:CWE-94,
        cwe:CWE-94 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE99 a owl:Class ;
    rdfs:label "CWE_99" ;
    d3f:cwe-id "CWE-99" ;
    d3f:synonym "Insecure Direct Object Reference" ;
    dcterms:title "Improper Control of Resource Identifiers ('Resource Injection')" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-99" ;
    skos:definition "The product receives input from an upstream component, but it does not restrict or incorrectly restricts the input before it is used as an identifier for a resource that may be outside the intended sphere of control." ;
    skos:exactMatch d3f:CWE-99,
        cwe:CWE-99 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CertificateAnalysis a owl:Class ;
    rdfs:label "CertificateAnalysis" ;
    d3f:d3fend-id "D3-CA" ;
    d3f:kb-article "## How it works Certificate Analysis ensures that the data elements of the certificate are current and anchored in a known trust model. Certificate authorities, revocation lists, and third-party secure logs are used in the analysis. Analysis includes detection of server impersonation, phishing domai" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Certificate Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:CommandAndControlTechnique,
        d3f:ExfiltrationTechnique,
        d3f:T1048,
        d3f:T1071,
        d3f:T1573 ;
    skos:definition "Analyzing Public Key Infrastructure certificates to detect if they have been misconfigured or spoofed using both network traffic, certificate fields and third-party logs." ;
    skos:exactMatch d3f:CertificateAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1041,
        mitre-attack:T1048.002,
        mitre-attack:T1071,
        mitre-attack:T1071.001,
        mitre-attack:T1573.002 .

d3f:Classifying a owl:Class ;
    rdfs:label "Classifying" ;
    rdfs:subClassOf d3f:AnalyticalPurpose ;
    skos:exactMatch d3f:Classifying ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ClockEvent a owl:Class ;
    rdfs:label "ClockEvent" ;
    dcterms:title "Clock Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event involving a clock artifact, characterized by changes to or readings from a timekeeping mechanism that maintains a representation of temporal progression." ;
    skos:exactMatch d3f:ClockEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CodeAnalyzer a owl:Class ;
    rdfs:label "CodeAnalyzer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Code Analyzer" ;
    rdfs:seeAlso dbr:Program_analysis ;
    rdfs:subClassOf d3f:DeveloperApplication ;
    skos:altLabel "Program Analysis Tool" ;
    skos:definition "Code analyzers automatically analyze the composition or behavior of computer programs regarding a property such as correctness, robustness, security, and safety. Program analysis can be performed without executing the program (static program analysis), during runtime (dynamic program analysis) or in a combination of both." ;
    skos:exactMatch d3f:CodeAnalyzer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CodecApplication a owl:Class ;
    rdfs:label "CodecApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Codec Application" ;
    rdfs:subClassOf d3f:UserApplication ;
    skos:definition "An application that encodes and decodes digital data." ;
    skos:exactMatch d3f:CodecApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputerEnclosure a owl:Class ;
    rdfs:label "ComputerEnclosure" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Computer Enclosure" ;
    rdfs:seeAlso <https://dbpedia.org/page/Category:Computer_enclosure> ;
    rdfs:subClassOf d3f:PhysicalArtifact ;
    skos:definition "A part providing protection of computer equipment against certain external influences and protects against direct contact." ;
    skos:exactMatch d3f:ComputerEnclosure ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputerPlatform a owl:Class ;
    rdfs:label "ComputerPlatform" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Computing Platform" ;
    dcterms:title "Computer Platform" ;
    rdfs:seeAlso dbr:Computing_platform ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "Platform includes the hardware and OS. The term computing platform can refer to different abstraction levels, including a certain hardware architecture, an operating system (OS), and runtime libraries. In total it can be said to be the stage on which computer programs can run." ;
    skos:exactMatch d3f:ComputerPlatform ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConfigurationDatabase a owl:Class ;
    rdfs:label "ConfigurationDatabase" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Configuration Database" ;
    rdfs:subClassOf d3f:ConfigurationResource ;
    skos:exactMatch d3f:ConfigurationDatabase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConfigurationDatabaseRecord a owl:Class ;
    rdfs:label "ConfigurationDatabaseRecord" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Configuration Record" ;
    dcterms:title "Configuration Database Record" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DatabaseRecord ],
        d3f:ConfigurationResource ;
    skos:definition "A Configuration Database Record defines settings, parameters, or preferences for applications, systems, or devices." ;
    skos:exactMatch d3f:ConfigurationDatabaseRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ControlCatalog a owl:Class ;
    rdfs:label "ControlCatalog" ;
    dcterms:title "Control Catalog" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/06499734-n> ;
    rdfs:subClassOf d3f:ExternalControlThing ;
    skos:definition "A control catalog is a complete list of protective measures for systems, organizations, or individuals for subject domains (e.g., security and privacy.)" ;
    skos:exactMatch d3f:ControlCatalog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConvolutionalNeuralNetwork a owl:Class ;
    rdfs:label "ConvolutionalNeuralNetwork" ;
    d3f:d3fend-id "D3A-CNN" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Convolutional neural network. [Link](https://en.wikipedia.org/wiki/Convolutional_neural_network)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Convolutional Neural Network" ;
    rdfs:subClassOf d3f:DeepNeuralNetClassification ;
    skos:definition "A class of artificial neural network most commonly applied to analyze visual imagery.CNNs use a mathematical operation called convolution in place of general matrix multiplication in at least one of their layers." ;
    skos:exactMatch d3f:ConvolutionalNeuralNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CopyToken a owl:Class ;
    rdfs:label "CopyToken" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Copy Token" ;
    rdfs:subClassOf d3f:SystemCall,
        d3f:SystemCallEnum,
        linkml:PermissibleValue ;
    skos:definition "Copy Token" ;
    skos:exactMatch d3f:CopyToken ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CredentialRotation a owl:Class ;
    rdfs:label "CredentialRotation" ;
    d3f:d3fend-id "D3-CRO" ;
    d3f:kb-article "## How it works Credentials can be systematically changed at predetermined intervals or based on specific events. Credentials such as user passwords may be rotated manually, but it is increasingly common to use an automated system to manage rotation of enterprise passwords, certificates and keys." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Rotation" ;
    rdfs:seeAlso <https://www.ituonline.com/tech-definitions/what-is-credential-rotation/> ;
    rdfs:subClassOf d3f:CredentialHardening ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1003,
        d3f:T1098,
        d3f:T1110,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "Credential rotation is a security procedure in which authentication credentials, such as passwords, API keys, or certificates, are regularly changed or replaced to minimize the risk of unauthorized access." ;
    skos:exactMatch d3f:CredentialRotation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.003,
        mitre-attack:T1003.005,
        mitre-attack:T1003.008,
        mitre-attack:T1098.001,
        mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003,
        mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1142,
        mitre-attack:T1528,
        mitre-attack:T1539,
        mitre-attack:T1550.001,
        mitre-attack:T1550.004,
        mitre-attack:T1552,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:CryptographicKey a owl:Class ;
    rdfs:label "CryptographicKey" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cryptographic Key" ;
    rdfs:seeAlso dbr:Public-key_cryptography ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "In cryptography, a key is a piece of information (a parameter) that determines the functional output of a cryptographic algorithm. For encryption algorithms, a key specifies the transformation of plaintext into ciphertext, and vice versa for decryption algorithms. Keys also specify transformations in other cryptographic algorithms, such as digital signature schemes and message authentication codes." ;
    skos:exactMatch d3f:CryptographicKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CyberAction a owl:Class ;
    rdfs:label "CyberAction" ;
    dcterms:title "Cyber Action" ;
    rdfs:subClassOf d3f:Action ;
    skos:broadMatch oscal:Action,
        stix:StixDomainObject,
        unified_cyber_ontology:Action ;
    skos:exactMatch d3f:CyberAction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DE0002 a owl:Class ;
    rdfs:label "DE_0002" ;
    d3f:attack-id "DE-0002" ;
    dcterms:title "Disrupt or Deceive Downlink" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/DE-0002/> ;
    rdfs:subClassOf d3f:SPARTADefenseEvasionTechnique ;
    skos:altLabel "DE-0002" ;
    skos:definition "Threat actors may target ground-side telemetry reception, processing, or display to disrupt the operator’s visibility into spacecraft health and activity. This may involve denial-based attacks that prevent the spacecraft from transmitting telemetry to the ground (e.g., disabling telemetry links or crashing telemetry software), or more subtle deception-based attacks that manipulate telemetry content to conceal unauthorized actions. Since telemetry is the primary method ground controllers rely on to monitor spacecraft status, any disruption or manipulation can delay or prevent detection of malicious activity, suppress automated or manual mitigations, or degrade trust in telemetry-based decision support systems." ;
    skos:exactMatch d3f:DE-0002,
        mitre-attack:DE-0002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSEvent a owl:Class ;
    rdfs:label "DNSEvent" ;
    dcterms:title "DNS Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/dns_activity>,
        <https://schema.ocsf.io/classes/dns_activity> ;
    rdfs:subClassOf d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Domain Name System (DNS), which translates domain names to IP addresses and operates over UDP and TCP." ;
    skos:exactMatch d3f:DNSEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DNSLookup a owl:Class ;
    rdfs:label "DNSLookup" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "DNS Lookup" ;
    rdfs:seeAlso dbr:Domain_Name_System,
        dbr:List_of_DNS_record_types,
        <https://schema.ocsf.io/objects/dns_query> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A Domain Name System (DNS) lookup is a record returned from a DNS resolver after querying a DNS name server.  Typically considered an A or AAAA record, where a domain name is resolved to an IPv4 or IPv6 address, respectively." ;
    skos:exactMatch d3f:DNSLookup ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DatabaseApplication a owl:Class ;
    rdfs:label "DatabaseApplication" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Database Management System (DBMS)" ;
    dcterms:title "Database Application" ;
    rdfs:seeAlso <https://dbpedia.org/page/Database_application> ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "A database application is a computer program whose primary purpose is retrieving information from a computerized database." ;
    skos:exactMatch d3f:DatabaseApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Deceive a owl:Class ;
    rdfs:label "Deceive" ;
    d3f:display-order "3" ;
    d3f:display-priority "0" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The deceive tactic is used to advertise, entice, and allow potential attackers access to an observed or controlled environment." ;
    skos:editorialNote "The deceive tactic is used to advertise, entice, and allow potential attackers access to an observed or controlled environment." ;
    skos:exactMatch d3f:Deceive ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DeepNeuralNetClassification a owl:Class ;
    rdfs:label "DeepNeuralNetClassification" ;
    d3f:d3fend-id "D3A-DNNC" ;
    d3f:kb-article "## References Deep learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Deep_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Deep Neural Network Classification" ;
    rdfs:subClassOf d3f:ArtificialNeuralNetClassification ;
    skos:definition "A deep neural network (DNN) is an artificial neural network (ANN) with multiple layers between the input and output layers. There are different types of neural networks but they always consist of the same components: neurons, synapses, weights, biases, and functions. These components as a whole function similarly to a human brain, and can be trained like any other ML algorithm" ;
    skos:exactMatch d3f:DeepNeuralNetClassification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DefensiveAction a owl:Class ;
    rdfs:label "DefensiveAction" ;
    dcterms:title "Defensive Action" ;
    rdfs:subClassOf d3f:CyberAction ;
    skos:broadMatch unified_cyber_ontology:Action ;
    skos:exactMatch d3f:DefensiveAction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch oscal:ImplementedControlStatement .

d3f:Detect a owl:Class ;
    rdfs:label "Detect" ;
    d3f:display-order "1" ;
    d3f:display-priority "0" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The detect tactic is used to identify adversary access to or unauthorized activity on computer networks." ;
    skos:editorialNote "The detect tactic is used to identify adversary access to or unauthorized activity on computer networks." ;
    skos:exactMatch d3f:Detect ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalImage a owl:Class ;
    rdfs:label "DigitalImage" ;
    dcterms:title "Digital Image" ;
    rdfs:subClassOf d3f:DigitalMedia ;
    skos:definition "A digital image is a pixel-based visual representation stored in formats like JPEG or PNG, used for various digital applications." ;
    skos:exactMatch d3f:DigitalImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Directory a owl:Class ;
    rdfs:label "Directory" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Directory_\(computing\) ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In computing, a directory is a file system cataloging structure which contains references to other computer files, and possibly other directories. On many computers, directories are known as folders, or drawers to provide some relevancy to a workbench or the traditional office file cabinet." ;
    skos:exactMatch d3f:Directory,
        stix:Directory,
        unified_cyber_ontology:Directory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DiskFormatting a owl:Class ;
    rdfs:label "DiskFormatting" ;
    d3f:d3fend-id "D3-DKF" ;
    d3f:kb-article "### How it works This process involves setting up an empty file system on the disk, which includes creating a directory structure and initializing metadata structures. In cybersecurity, disk formatting can be used to remove all existing data on a disk, making it a clean slate for new data storage o" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Disk Formatting" ;
    rdfs:subClassOf d3f:ObjectEviction ;
    skos:broadMatch d3f:DiscoveryTechnique ;
    skos:definition "Disk Formatting is the process of preparing a data storage device, such as a hard drive, solid-state drive, or USB flash drive, for initial use." ;
    skos:exactMatch d3f:DiskFormatting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1619 .

d3f:EX0009 a owl:Class ;
    rdfs:label "EX_0009" ;
    d3f:attack-id "EX-0009" ;
    dcterms:title "Exploit Code Flaws" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0009/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0009" ;
    skos:definition "Threats actors may identify and exploit flaws or weaknesses within the software running on-board the target spacecraft. These attacks may be extremely targeted and tailored to specific coding errors introduced as a result of poor coding practices or they may target known issues in the commercial software components." ;
    skos:exactMatch d3f:EX-0009,
        mitre-attack:EX-0009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0016 a owl:Class ;
    rdfs:label "EX_0016" ;
    d3f:attack-id "EX-0016" ;
    dcterms:title "Jamming" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0016/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0016" ;
    skos:definition """Jamming is an electronic attack that uses radio frequency signals to interfere with communications. A jammer must operate in the same frequency band and within the field of view of the antenna it is targeting. Unlike physical attacks, jamming is completely reversible—once the jammer is disengaged, communications can be restored. Attribution of jamming can be tough because the source can be small and highly mobile, and users operating on the wrong frequency or pointed at the wrong satellite can jam friendly communications.* Similiar to intentional jamming, accidential jamming can cause temporary signal degradation. Accidental jamming refers to unintentional interference with communication signals, and it can potentially impact spacecraft in various ways, depending on the severity, frequency, and duration of the interference.

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:EX-0016,
        mitre-attack:EX-0016 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0018 a owl:Class ;
    rdfs:label "EX_0018" ;
    d3f:attack-id "EX-0018" ;
    dcterms:title "Non-Kinetic Physical Attack" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0018/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0018" ;
    skos:definition """A non-kinetic physical attack is when a satellite is physically damaged without any direct contact. Non-kinetic physical attacks can be characterized into a few types: electromagnetic pulses, high-powered lasers, and high-powered microwaves. These attacks have medium possible attribution levels and often provide little evidence of success to the attacker.*

*https://aerospace.csis.org/aerospace101/counterspace-weapons-101""" ;
    skos:exactMatch d3f:EX-0018,
        mitre-attack:EX-0018 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EquivalenceMatching a owl:Class ;
    rdfs:label "EquivalenceMatching" ;
    d3f:d3fend-id "D3A-EM" ;
    d3f:kb-article "## How it works Equality is a relationship between two quantities or, more generally two mathematical expressions, asserting that the quantities have the same value, or that the expressions represent the same mathematical object. Programming languages can have multiple senses of equality that may i" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Equivalence Matching" ;
    rdfs:subClassOf d3f:LogicalRules ;
    skos:definition "Equivalence matching is matching two values, which may be bound to variables, to see if they are equivalent." ;
    skos:exactMatch d3f:EquivalenceMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Estimation a owl:Class ;
    rdfs:label "Estimation" ;
    d3f:d3fend-id "D3A-EST" ;
    d3f:kb-article "## References Pennsylvania State University. (n.d.). Statistical Inference and Estimation. [Link](https://online.stat.psu.edu/stat504/lesson/statistical-inference-and-estimation)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:InferentialStatistics ;
    skos:definition "Estimation represents ways or a process of learning and determining the population parameter based on the model fitted to the data." ;
    skos:exactMatch d3f:Estimation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Evict a owl:Class ;
    rdfs:label "Evict" ;
    d3f:display-order "4" ;
    d3f:display-priority "0" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The eviction tactic is used to remove an adversary from a computer network." ;
    skos:editorialNote "The eviction tactic is used to remove an adversary from a computer network." ;
    skos:exactMatch d3f:Evict ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutableAllowlisting a owl:Class ;
    rdfs:label "ExecutableAllowlisting" ;
    d3f:d3fend-id "D3-EAL" ;
    d3f:kb-article "## How it works This technique is generic and there are numerous ways to compute and authenticate digital signatures. A digital certificate is generated from a private/public key pair issued by a certificate authority (CA). A hash of the file is encrypted using the private key. When the file is dow" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "File Signature Authentication" ;
    dcterms:title "Executable Allowlisting" ;
    rdfs:subClassOf d3f:ExecutionIsolation,
        d3f:PlatformHardeningEnum,
        linkml:PermissibleValue ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1027,
        d3f:T1036,
        d3f:T1037,
        d3f:T1055,
        d3f:T1134,
        d3f:T1137,
        d3f:T1204,
        d3f:T1218,
        d3f:T1505,
        d3f:T1546,
        d3f:T1547,
        d3f:T1548,
        d3f:T1562,
        d3f:T1565,
        d3f:T1574 ;
    skos:definition "Executable Allowlisting",
        "Using a digital signature to authenticate a file before opening." ;
    skos:editorialNote "Using a digital signature to authenticate a file before opening." ;
    skos:exactMatch d3f:ExecutableAllowlisting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1007,
        mitre-attack:T1010,
        mitre-attack:T1016,
        mitre-attack:T1018,
        mitre-attack:T1027.001,
        mitre-attack:T1027.002,
        mitre-attack:T1027.004,
        mitre-attack:T1033,
        mitre-attack:T1036.001,
        mitre-attack:T1036.003,
        mitre-attack:T1037.001,
