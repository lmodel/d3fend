    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_deceived_by a owl:DatatypeProperty ;
    rdfs:label "may-be-deceived-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:attack_may_be_countered_by ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_detected_by a owl:DatatypeProperty ;
