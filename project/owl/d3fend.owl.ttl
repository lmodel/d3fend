        d3f:T1552,
        d3f:T1555,
        d3f:T1564,
        d3f:T1566,
        d3f:T1614 ;
    skos:definition "Data inventorying identifies and records the schemas, formats, volumes, and locations of data stored and used on the organization's architecture." ;
