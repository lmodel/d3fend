d3f:WindowsVirtualAllocEx a owl:Class ;
    rdfs:label "WindowsVirtualAllocEx" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows VirtualAllocEx" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/memoryapi/nf-memoryapi-virtualallocex> ;
    rdfs:subClassOf d3f:OSAPIAllocateMemory ;
    skos:definition "Reserves, commits, or changes the state of a region of memory within the virtual address space of a specified process. The function initializes the memory it allocates to zero." ;
    skos:exactMatch d3f:WindowsVirtualAllocEx ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsVirtualFree a owl:Class ;
    rdfs:label "WindowsVirtualFree" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows VirtualFree" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/memoryapi/nf-memoryapi-virtualfree> ;
    rdfs:subClassOf d3f:OSAPIFreeMemory ;
    skos:definition "Releases, decommits, or releases and decommits a region of pages within the virtual address space of the calling process." ;
    skos:exactMatch d3f:WindowsVirtualFree ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsVirtualProtectEx a owl:Class ;
