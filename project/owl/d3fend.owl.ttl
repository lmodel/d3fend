    skos:definition "Mail traffic is network traffic that uses a standard mail transfer protocol." ;
    skos:exactMatch d3f:MailNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MailService a owl:Class ;
    rdfs:label "MailService" ;
    dcterms:title "Mail Service" ;
    rdfs:seeAlso dbr:Email,
        dbr:Message_transfer_agent ;
    rdfs:subClassOf d3f:NetworkService ;
    skos:altLabel "Email Service" ;
    skos:definition "A mail service provides the ability to send and receive mail across a computer network.  The mail service runs on message transfer agents (i.e., mail servers) and is accessed by users through an email client." ;
    skos:exactMatch d3f:MailService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryAddressSpace a owl:Class ;
