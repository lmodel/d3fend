    d3f:owl_named_individual "true" ;
    dcterms:title "Service Dependency" ;
    rdfs:subClassOf d3f:Dependency ;
    skos:definition "A service dependency indicates a service has an activity, agent, or another service which relies on it in order to be functional." ;
