    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:may_be_associated_with ;
    skos:definition "x may-corrupt y: They entity x may corrupt y's information content; that is, 'x corrupts y' may be true." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_create a owl:DatatypeProperty ;
