    rdfs:label "CWE_144" ;
    d3f:cwe-id "CWE-144" ;
    dcterms:title "Improper Neutralization of Line Delimiters" ;
    rdfs:subClassOf d3f:CWE140 ;
    skos:altLabel "CWE-144" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as line delimiters when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-144,
        cwe:CWE-144 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE145 a owl:Class ;
    rdfs:label "CWE_145" ;
    d3f:cwe-id "CWE-145" ;
    dcterms:title "Improper Neutralization of Section Delimiters" ;
    rdfs:subClassOf d3f:CWE140 ;
    skos:altLabel "CWE-145" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as section delimiters when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-145,
        cwe:CWE-145 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE146 a owl:Class ;
    rdfs:label "CWE_146" ;
    d3f:cwe-id "CWE-146" ;
    dcterms:title "Improper Neutralization of Expression/Command Delimiters" ;
    rdfs:subClassOf d3f:CWE140 ;
    skos:altLabel "CWE-146" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as expression or command delimiters when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-146,
        cwe:CWE-146 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE148 a owl:Class ;
    rdfs:label "CWE_148" ;
    d3f:cwe-id "CWE-148" ;
    dcterms:title "Improper Neutralization of Input Leaders" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-148" ;
    skos:definition "The product does not properly handle when a leading character or sequence (\"leader\") is missing or malformed, or if multiple leaders are used when only one should be allowed." ;
    skos:exactMatch d3f:CWE-148,
        cwe:CWE-148 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE149 a owl:Class ;
    rdfs:label "CWE_149" ;
    d3f:cwe-id "CWE-149" ;
    dcterms:title "Improper Neutralization of Quoting Syntax" ;
    rdfs:subClassOf d3f:CWE138 ;
    skos:altLabel "CWE-149" ;
    skos:definition "Quotes injected into a product can be used to compromise a system. As data are parsed, an injected/absent/duplicate/malformed use of quotes may cause the process to take unexpected actions." ;
    skos:exactMatch d3f:CWE-149,
        cwe:CWE-149 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE15 a owl:Class ;
    rdfs:label "CWE_15" ;
    d3f:cwe-id "CWE-15" ;
    dcterms:title "External Control of System or Configuration Setting" ;
