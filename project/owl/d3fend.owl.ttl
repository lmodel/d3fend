    rdfs:seeAlso <http://dbpedia.org/resource/Input_device#Voice_input_devices> ;
    rdfs:subClassOf d3f:InputDevice ;
    skos:definition "Audio input devices allow a user to send audio info to a computer for processing, recording, or carrying out commands. Devices such as microphones allow users to speak to the computer in order to record a voice message or navigate software. Aside from recording, audio input devices are also used with speech recognition software." ;
    skos:exactMatch d3f:AudioInputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AuthenticateUser a owl:Class ;
