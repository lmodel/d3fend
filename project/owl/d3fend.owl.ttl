        d3f:T1557,
        d3f:T1558,
        d3f:T1565,
        d3f:T1566,
        d3f:T1567,
        d3f:T1573 ;
    skos:definition "Comparing client-server request and response payloads to a baseline profile to identify outliers." ;
    skos:exactMatch d3f:Client-serverPayloadProfiling ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
