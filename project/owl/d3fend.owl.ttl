    rdfs:label "ProcessCreationEvent" ;
    dcterms:title "Process Creation Event" ;
    rdfs:subClassOf d3f:ProcessEvent ;
    skos:definition "An event where a new process is spawned, initializing its execution context and resource allocation." ;
