    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/memoryapi/nf-memoryapi-virtualprotectex> ;
    rdfs:subClassOf d3f:OSAPIAllocateMemory ;
    skos:definition "Changes the protection on a region of committed pages in the virtual address space of a specified process." ;
    skos:exactMatch d3f:WindowsVirtualProtectEx ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

