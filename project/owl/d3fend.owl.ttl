d3f:SoftwareLibraryFile a owl:Class ;
    rdfs:label "SoftwareLibraryFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Library File" ;
    rdfs:seeAlso <https://dbpedia.org/page/Library_(computing)> ;
    rdfs:subClassOf d3f:File ;
    skos:definition "A software library is a collection of software components that are used to build a software product." ;
    skos:exactMatch d3f:SoftwareLibraryFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwarePatch a owl:Class ;
    rdfs:label "SoftwarePatch" ;
    dcterms:title "Software Patch" ;
    rdfs:seeAlso dbr:Patch_\(computing\) ;
    rdfs:subClassOf d3f:Software ;
    skos:altLabel "Patch" ;
    skos:definition "A patch is a piece of software designed to update a computer program or its supporting data, to fix or improve it. This includes fixing security vulnerabilities and other bugs, with such patches usually called bugfixes or bug fixes, and improving the usability or performance. Although meant to fix problems, poorly designed patches can sometimes introduce new problems (see software regressions). In some special cases updates may knowingly break the functionality, for instance, by removing components for which the update provider is no longer licensed or disabling a device." ;
    skos:exactMatch d3f:SoftwarePatch ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SoftwareRepository a owl:Class ;
    rdfs:label "SoftwareRepository" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Software Repository" ;
    rdfs:seeAlso dbr:Software_repository ;
    rdfs:subClassOf d3f:Repository ;
    skos:altLabel "Package Repository" ;
    skos:definition "A software repository, or repo for short, is a storage location for software packages. Often a table of contents is also stored, along with metadata. A software repository is typically managed by source or version control, or repository managers. Package managers allow automatically installing and updating repositories, sometimes called 'packages'." ;
    skos:exactMatch d3f:SoftwareRepository ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

