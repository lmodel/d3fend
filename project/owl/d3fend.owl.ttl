            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceEvent ],
        d3f:ApplicationInstallationEvent ;
    skos:definition "An event representing the installation or registration of a service application within the system, enabling it to provide background or reusable functionality." ;
    skos:exactMatch d3f:ServiceInstallationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceRestartEvent a owl:Class ;
    rdfs:label "ServiceRestartEvent" ;
    dcterms:title "Service Restart Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceEvent ],
        d3f:ApplicationRestartEvent ;
    skos:definition "An event describing the sequential stopping and starting of a service application to refresh its state, apply updates, or resolve operational issues." ;
    skos:exactMatch d3f:ServiceRestartEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceStartEvent a owl:Class ;
    rdfs:label "ServiceStartEvent" ;
    dcterms:title "Service Start Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceEvent ],
        d3f:ApplicationStartEvent ;
    skos:definition "An event representing the initiation of a service application, transitioning it from an inactive state to an active state, enabling its background or networked operations." ;
    skos:exactMatch d3f:ServiceStartEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceStopEvent a owl:Class ;
    rdfs:label "ServiceStopEvent" ;
    dcterms:title "Service Stop Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceEvent ],
        d3f:ApplicationStopEvent ;
    skos:definition "An event capturing the cessation of a service application’s operations, transitioning it to an inactive state while ceasing its functionality to clients or dependent systems." ;
    skos:exactMatch d3f:ServiceStopEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceUpdateEvent a owl:Class ;
    rdfs:label "ServiceUpdateEvent" ;
    dcterms:title "Service Update Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ServiceEvent ],
        d3f:ApplicationUpdateEvent ;
    skos:definition "An event describing changes made to a service application, such as updates, reconfigurations, or patch installations, ensuring its continued availability and functionality." ;
    skos:exactMatch d3f:ServiceUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SessionCookie a owl:Class ;
    rdfs:label "SessionCookie" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Session Cookie" ;
    rdfs:seeAlso dbr:HTTP_cookie,
        <https://schema.ocsf.io/objects/http_cookie> ;
    rdfs:subClassOf d3f:Credential ;
    skos:altLabel "In-memory Cookie",
        "Non-persistent Cookie",
        "Transient Cookie",
        "Web Session Cookie" ;
    skos:definition "A session cookie, also known as an in-memory cookie, transient cookie or non-persistent cookie, exists only in temporary memory while the user navigates the website. Web browsers normally delete session cookies when the user closes the browser. Unlike other cookies, session cookies do not have an expiration date assigned to them, which is how the browser knows to treat them as session cookies." ;
    skos:exactMatch d3f:SessionCookie ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SessionDurationAnalysis a owl:Class ;
    rdfs:label "SessionDurationAnalysis" ;
    d3f:d3fend-id "D3-SDA" ;
    d3f:kb-article "## How it works Detecting unauthorized user sessions by comparing the duration of a user logon session with a baseline behavior model. The behavior model comprises historical user session duration times. Abnormalities between session duration and the behavior model may indicate suspicious activity." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Session Duration Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Analyzing the duration of user sessions in order to detect unauthorized activity." ;
    skos:exactMatch d3f:SessionDurationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SessionTermination a owl:Class ;
    rdfs:label "SessionTermination" ;
    d3f:d3fend-id "D3-ST" ;
    d3f:kb-article "Defined in NIST 800-53 as AC-12." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Session Termination" ;
    rdfs:subClassOf d3f:ProcessEviction ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1021,
        d3f:T1134,
        d3f:T1563 ;
    skos:definition "Forcefully end all active sessions associated with compromised accounts or devices." ;
    skos:exactMatch d3f:SessionTermination ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1021.001,
        mitre-attack:T1021.004,
        mitre-attack:T1133,
        mitre-attack:T1134.003,
        mitre-attack:T1199,
        mitre-attack:T1563,
        mitre-attack:T1563.001,
        mitre-attack:T1563.002 .

