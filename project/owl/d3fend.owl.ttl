d3f:NetworkAgent a owl:Class ;
    rdfs:label "NetworkAgent" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Exporter" ;
    dcterms:title "Network Agent" ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "A network agent is software installed on a network node or device that transmits information back to a collector agent or management system.  Kinds of network agents include SNMP Agent, IPMI agents, WBEM agents, and many proprietary agents capturing network monitoring and management information." ;
    skos:exactMatch d3f:NetworkAgent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

