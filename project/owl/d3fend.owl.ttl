    d3f:owl_named_individual "true" ;
    dcterms:title "Divisive Clustering" ;
    rdfs:subClassOf d3f:HierarchicalClustering ;
    skos:definition "A divisive clustering approach is a hierarchical, top-down approach to clustering a dataset." ;
    skos:exactMatch d3f:DivisiveClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainAccountMonitoring a owl:Class ;
    rdfs:label "DomainAccountMonitoring" ;
    d3f:d3fend-id "D3-DAM" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Account Monitoring" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
