            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PermissionGrantingEvent ],
        d3f:GroupManagementEvent ;
    skos:definition "An event where specific privileges or rights are granted to a group, enabling its members to perform actions or access resources as defined by the privileges." ;
    skos:exactMatch d3f:AssignPrivilegesToGroupEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

