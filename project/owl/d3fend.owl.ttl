    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_kb_data_property ;
    skos:definition "x kb-reference-title y: The d3fend knowledge base reference x has the reference title string y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:label a owl:DatatypeProperty ;
    rdfs:label "label" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:loaded_by a owl:DatatypeProperty ;
    rdfs:label "loaded-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x loaded-by y: The entity x is brought into memory by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:loads a owl:DatatypeProperty ;
    rdfs:label "loads" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02236692-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x loads y: The technique or process x transfers a software from a storage y to a computer's memory for subsequent execution." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:manages a owl:DatatypeProperty ;
    rdfs:label "manages" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/02447914-v> ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:altLabel "oversees",
        "supervises" ;
    skos:definition "x manages y: The technique or agent x watches and directs the use of a digital artifact y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:mapped_by a owl:DatatypeProperty ;
    rdfs:label "mapped-by" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x mapped-by y: The entity x is linked to another entity by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:maps a owl:DatatypeProperty ;
    rdfs:label "maps" ;
    rdfs:range xsd:string ;
