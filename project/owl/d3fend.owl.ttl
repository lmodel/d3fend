d3f:FileHeaderBlockSignature a owl:Class ;
    rdfs:label "FileHeaderBlockSignature" ;
    dcterms:title "File Header Block Signature" ;
    rdfs:subClassOf d3f:FileMetadata ;
    skos:definition "A sequence of bytes used to identify and validate specific header sections within a file." ;
    skos:exactMatch d3f:FileHeaderBlockSignature ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileMetadataValueVerification a owl:Class ;
    rdfs:label "FileMetadataValueVerification" ;
    d3f:d3fend-id "D3-FMVV" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Metadata Value Verification" ;
    rdfs:subClassOf d3f:FileFormatVerification ;
    skos:definition "The process of checking specific static values within a file, such as file signatures or magic numbers, to ensure they match the expected values defined by the file format specification." ;
    skos:exactMatch d3f:FileMetadataValueVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Firewall a owl:Class ;
    rdfs:label "Firewall" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Firewall_\(computing\) ;
    rdfs:subClassOf d3f:ComputerNetworkNode ;
    skos:altLabel "Network Firewall" ;
    skos:definition "In computing, a firewall is a network security system that monitors and controls incoming and outgoing network traffic based on predetermined security rules. A firewall typically establishes a barrier between a trusted internal network and untrusted external network, such as the Internet. Firewalls are often categorized as either network firewalls or host-based firewalls. Network firewalls filter traffic between two or more networks and run on network hardware. Host-based firewalls run on host computers and control network traffic in and out of those machines. This definition refers to network firewalls." ;
    skos:exactMatch d3f:Firewall ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Forecasting a owl:Class ;
    rdfs:label "Forecasting" ;
    rdfs:subClassOf d3f:AnalyticalPurpose ;
    skos:exactMatch d3f:Forecasting ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GetSystemConfigValue a owl:Class ;
    rdfs:label "GetSystemConfigValue" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Get System Config Value" ;
    rdfs:seeAlso <https://docs.microsoft.com/en-us/windows/win32/api/winreg/nf-winreg-regopenkeyexa> ;
    rdfs:subClassOf d3f:SystemConfigSystemCall ;
    skos:exactMatch d3f:GetSystemConfigValue ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GraphBasedClustering a owl:Class ;
    rdfs:label "Graph_basedClustering" ;
    d3f:d3fend-id "D3A-GBC" ;
    d3f:kb-article "## References 1. Jagota, A. (13 Dec 2020). Density-based and Graph-based Clustering. towardsdatascience.com. [Link](https://towardsdatascience.com/density-based-and-graph-based-clustering-a1f0d45ff5fb) 1. Connectivity-Based Clustering. Sarang, P. (2023) in Thinking Data Science. The Springer Series" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Connection-based Clustering" ;
    dcterms:title "Graph-based Clustering" ;
    rdfs:subClassOf d3f:ClusterAnalysis ;
    skos:altLabel "Graph-basedClustering" ;
    skos:definition "Graph-based Clustering is a form of clustering where data is represented with graphs to identify clusters.  We include Connection-based Clustering in this class." ;
    skos:exactMatch d3f:Graph-basedClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Group a owl:Class ;
    rdfs:label "Group" ;
    rdfs:subClassOf d3f:D3FENDCore ;
    skos:exactMatch d3f:Group,
        oscal:Group ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HTMLFile a owl:Class ;
    rdfs:label "HTMLFile" ;
    dcterms:title "HTML File" ;
    rdfs:seeAlso dbr:HTML ;
    rdfs:subClassOf d3f:DocumentFile ;
    skos:altLabel "HTML File" ;
    skos:definition "A document file encoded in HTML.The HyperText Markup Language, or HTML is the standard markup language for documents designed to be displayed in a web browser. It can be assisted by technologies such as Cascading Style Sheets (CSS) and scripting languages such as JavaScript. Web browsers receive HTML documents from a web server or from local storage and render the documents into multimedia web pages. HTML describes the structure of a web page semantically and originally included cues for the appearance of the document." ;
    skos:exactMatch d3f:HTMLFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HTTPSURL a owl:Class ;
    rdfs:label "HTTPSURL" ;
    rdfs:subClassOf d3f:URLEnum,
        linkml:PermissibleValue ;
    skos:definition "HTTPS URL" .

d3f:HTTPURL a owl:Class ;
    rdfs:label "HTTPURL" ;
    rdfs:subClassOf d3f:URLEnum,
        linkml:PermissibleValue ;
    skos:definition "HTTP URL" .

d3f:HardwareClockEvent a owl:Class ;
    rdfs:label "HardwareClockEvent" ;
    dcterms:title "Hardware Clock Event" ;
    rdfs:subClassOf d3f:ClockEvent ;
    skos:definition "A clock event involving a physical timekeeping mechanism implemented in hardware components." ;
    skos:exactMatch d3f:HardwareClockEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceConfiguration a owl:Class ;
    rdfs:label "HardwareDeviceConfiguration" ;
    dcterms:title "Hardware Device Configuration" ;
    rdfs:subClassOf d3f:ConfigurationResource ;
    skos:definition "Information used to configure the parameters and settings for hardware devices." ;
    skos:exactMatch d3f:HardwareDeviceConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareTimer a owl:Class ;
    rdfs:label "HardwareTimer" ;
    dcterms:title "Hardware Timer" ;
    rdfs:seeAlso <https://www.sciencedirect.com/topics/engineering/hardware-timer> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Timer ],
        d3f:HardwareDevice ;
    skos:definition "A hardware timer is defined as an electronic component that serves as an 8-bit or 16-bit counter, capable of measuring time intervals, generating timed outputs, and driving loads through mechanisms such as pulse width modulation (PWM)." ;
    skos:exactMatch d3f:HardwareTimer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IA0004 a owl:Class ;
    rdfs:label "IA_0004" ;
    d3f:attack-id "IA-0004" ;
    dcterms:title "Secondary/Backup Communication Channel" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/IA-0004/> ;
    rdfs:subClassOf d3f:SPARTAInitialAccessTechnique ;
    skos:altLabel "IA-0004" ;
    skos:definition "Threat actors may compromise alternative communication pathways which may not be as protected as the primary pathway. Depending on implementation the contingency communication pathways/solutions may lack the same level of security (i.e., physical security, encryption, authentication, etc.) which if forced to use could provide a threat actor an opportunity to launch attacks. Typically these would have to be coupled with other denial of service techniques on the primary pathway to force usage of secondary pathways." ;
    skos:exactMatch d3f:IA-0004,
        mitre-attack:IA-0004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IA0007 a owl:Class ;
    rdfs:label "IA_0007" ;
    d3f:attack-id "IA-0007" ;
    dcterms:title "Compromise Ground System" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/IA-0007/> ;
    rdfs:subClassOf d3f:SPARTAInitialAccessTechnique ;
    skos:altLabel "IA-0007" ;
    skos:definition "Threat actors may initially compromise the ground system in order to access the target spacecraft. Once compromised, the threat actor can perform a multitude of initial access techniques, including replay, compromising FSW deployment, compromising encryption keys, and compromising authentication schemes. Threat actors may also perform further reconnaissance within the system to enumerate mission networks and gather information related to ground station logical topology, missions ran out of said ground station, birds that are in-band of targeted ground stations, and other mission system capabilities." ;
    skos:exactMatch d3f:IA-0007,
        mitre-attack:IA-0007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IOModule a owl:Class ;
    rdfs:label "IOModule" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "I/O Module" ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "An I/O Module is a hardware device that translates signals between external sensors or actuators and control systems. It typically handles analog-to-digital (and vice versa) conversion, serving as the data interface that allows physical processes to be monitored and controlled by digital controllers." ;
    skos:exactMatch d3f:IOModule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IPCNetworkTraffic a owl:Class ;
    rdfs:label "IPCNetworkTraffic" ;
    dcterms:title "IPC Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "IPC network traffic is network traffic related to inter-process communication (IPC) between network nodes..This includes only network traffic conforming to a standard IPC protocol; not custom protocols." ;
    skos:exactMatch d3f:IPCNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImageCodeSegment a owl:Class ;
    rdfs:label "ImageCodeSegment" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Image Code Segment" ;
    rdfs:seeAlso d3f:ProcessCodeSegment,
        dbr:Code_segment ;
    rdfs:subClassOf d3f:ImageSegment ;
    skos:definition "An image code segment, also known as a text segment or simply as text, is a portion of an object file that contains executable instructions. The term \"segment\" comes from the memory segment, which is a historical approach to memory management that has been succeeded by paging. When a program is stored in an object file, the code segment is a part of this file; when the loader places a program into memory so that it may be executed, various memory regions are allocated (in particular, as pages), corresponding to both the segments in the object files and to segments only needed at run time. For example, the code segment of an object file is loaded into a corresponding code segment in memory." ;
    skos:exactMatch d3f:ImageCodeSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImageDataSegment a owl:Class ;
    rdfs:label "ImageDataSegment" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Image Data Segment" ;
    rdfs:seeAlso d3f:ProcessDataSegment,
        dbr:Data_segment ;
    rdfs:subClassOf d3f:ImageSegment ;
    skos:definition "An image data segment (often denoted .data) is a portion of an object file that contains initialized static variables, that is, global variables and static local variables. The size of this segment is determined by the size of the values in the program's source code, and does not change at run time. This segmenting of the memory space into discrete blocks with specific tasks carried over into the programming languages of the day and the concept is still widely in use within modern programming languages." ;
    skos:exactMatch d3f:ImageDataSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ImageToImageTranslationGAN a owl:Class ;
    rdfs:label "Image_to_ImageTranslationGAN" ;
    d3f:d3fend-id "D3A-ITITG" ;
    d3f:kb-article "## References MathWorks. (n.d.). Get Started with GANs for Image-to-Image Translation. [Link](https://www.mathworks.com/help/images/get-started-with-gans-for-image-to-image-translation.html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Image-to-Image Translation GAN" ;
    rdfs:subClassOf d3f:GenerativeAdversarialNetwork ;
    skos:altLabel "Image-to-ImageTranslationGAN" ;
    skos:definition "Image-to-image translation is the task of transferring styles and characteristics from one image domain to another." ;
    skos:exactMatch d3f:Image-to-ImageTranslationGAN ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundInternetEncryptedTraffic a owl:Class ;
    rdfs:label "InboundInternetEncryptedTraffic" ;
    dcterms:title "Inbound Internet Encrypted Traffic" ;
    rdfs:subClassOf d3f:InboundInternetNetworkTraffic ;
    skos:definition "Inbound  internet encrypted traffic is encrypted network traffic on an incoming connection initiated from a host outside the network to a host within a network ." ;
    skos:exactMatch d3f:InboundInternetEncryptedTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundInternetWebTraffic a owl:Class ;
    rdfs:label "InboundInternetWebTraffic" ;
    dcterms:title "Inbound Internet Web Traffic" ;
    rdfs:seeAlso dbr:Internetworking,
        <https://schema.ocsf.io/objects/http_response> ;
    rdfs:subClassOf d3f:InboundInternetNetworkTraffic ;
    skos:definition "Inbound internet web traffic is network traffic that is: (a) on an incoming connection initiated from a host outside the network to a host within a network, and (b) using a standard web protocol." ;
    skos:exactMatch d3f:InboundInternetWebTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InboundTrafficFiltering a owl:Class ;
    rdfs:label "InboundTrafficFiltering" ;
    d3f:d3fend-id "D3-ITF" ;
    d3f:kb-article "## How it works Inbound Traffic, in this context, is network traffic originating from an untrusted network towards a private host or enclave. For example: * An untrusted network host connecting to a internal commercial portal, shopping.example.com * An external mail server connecting to an internal" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Inbound Traffic Filtering" ;
    rdfs:subClassOf d3f:NetworkTrafficFiltering ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:T1498,
        d3f:T1499,
        d3f:T1566 ;
    skos:definition "Restricting network traffic originating from untrusted networks destined towards a private host or enclave." ;
    skos:exactMatch d3f:InboundTrafficFiltering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1190,
        mitre-attack:T1498.001,
        mitre-attack:T1498.002,
        mitre-attack:T1499.002,
        mitre-attack:T1566.001,
        mitre-attack:T1566.002 .

d3f:InputFunction a owl:Class ;
    rdfs:label "InputFunction" ;
    dcterms:title "Input Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Generic function that receives input from an untrusted source." ;
    skos:exactMatch d3f:InputFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:InternationalizedDomainName a owl:Class ;
    rdfs:label "InternationalizedDomainName" ;
    rdfs:subClassOf d3f:DomainNameEnum,
        linkml:PermissibleValue ;
    skos:definition "Internationalized Domain Name" .

d3f:IntranetNetwork a owl:Class ;
    rdfs:label "IntranetNetwork" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet Network" ;
    rdfs:seeAlso dbr:Intranet ;
    rdfs:subClassOf d3f:Network ;
    skos:definition "An intranet is a private network accessible only to an organization's staff or delegates. Generally a wide range of information and services from the organization's internal IT systems are available that would not be available to the public from the Internet. A company-wide intranet can constitute an important focal point of internal communication and collaboration, and provide a single starting point to access internal and external resources. In its simplest form an intranet is established with the technologies for local area networks (LANs) and wide area networks (WANs)." ;
    skos:exactMatch d3f:IntranetNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntrusionDetectionSystem a owl:Class ;
    rdfs:label "IntrusionDetectionSystem" ;
    dcterms:title "Intrusion Detection System" ;
    rdfs:seeAlso dbr:Intrusion_detection_system ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "IDS" ;
    skos:definition "An intrusion detection system (IDS) is a device or software application that monitors a network or systems for malicious activity or policy violations. Any intrusion activity or violation is typically reported either to an administrator or collected centrally using a security information and event management (SIEM) system. A SIEM system combines outputs from multiple sources and uses alarm filtering techniques to distinguish malicious activity from false alarms." ;
    skos:exactMatch d3f:IntrusionDetectionSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:JavascriptFile a owl:Class ;
    rdfs:label "JavascriptFile" ;
