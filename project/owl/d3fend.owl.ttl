d3f:OTEvent a owl:Class ;
    rdfs:label "OTEvent" ;
    dcterms:title "OT Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "A discrete occurrence within an operational technology environment that denotes a significant change in state, execution of a command, or transmission of information." ;
    skos:exactMatch d3f:OTEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTProtocolMessage a owl:Class ;
    rdfs:label "OTProtocolMessage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OT Protocol Message" ;
    rdfs:subClassOf d3f:DigitalMessage ;
    skos:definition "Packets generated by an operational technology protocol contain an OT protocol message." ;
    skos:exactMatch d3f:OTProtocolMessage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ObjectEviction a owl:Class ;
    rdfs:label "ObjectEviction" ;
    d3f:d3fend-id "D3-OE" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Object Eviction" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Terminate or remove an object from a host machine. This is the broadest class for object eviction." ;
    skos:exactMatch d3f:ObjectEviction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PeripheralFirmware a owl:Class ;
    rdfs:label "PeripheralFirmware" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Peripheral Firmware" ;
    rdfs:seeAlso d3f:Firmware,
        dbr:Peripheral ;
    rdfs:subClassOf d3f:Firmware ;
    skos:definition "Firmware that is installed on computer peripheral devices." ;
    skos:exactMatch d3f:PeripheralFirmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PersonalComputer a owl:Class ;
    rdfs:label "PersonalComputer" ;
    dcterms:title "Personal Computer" ;
    rdfs:seeAlso dbr:Personal_computer ;
    rdfs:subClassOf d3f:ClientComputer ;
    skos:definition "A personal computer (PC) is a multi-purpose computer whose size, capabilities, and price make it feasible for individual use. Personal computers are intended to be operated directly by an end user, rather than by a computer expert or technician. Unlike large, costly minicomputers and mainframes, time-sharing by many people at the same time is not used with personal computers. PCs have in practice become powerful enough that they may be shared by multiple users at any given time, though this is not common practice nor the primary purpose of a PC." ;
    skos:exactMatch d3f:PersonalComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Process a owl:Class ;
    rdfs:label "Process" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Process_\(computing\),
        <https://schema.ocsf.io/objects/process> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:process_security_context ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty d3f:process_security_context ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty d3f:process_security_context ],
        d3f:DigitalInformationBearer ;
    skos:definition "A process is an instance of a computer program that is being executed. It contains the program code and its current activity. Depending on the operating system (OS), a process may be made up of multiple threads of execution that execute instructions concurrently. A computer program is a passive collection of instructions, while a process is the actual execution of those instructions. Several processes may be associated with the same program; for example, opening up several instances of the same program often means more than one process is being executed." ;
    skos:exactMatch d3f:Process,
        stix:Process,
        unified_cyber_ontology:Process ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RDPEvent a owl:Class ;
    rdfs:label "RDPEvent" ;
    dcterms:title "RDP Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/rdp_activity>,
        <https://schema.ocsf.io/classes/rdp_activity> ;
    rdfs:subClassOf d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Remote Desktop Protocol (RDP), a communication protocol developed by Microsoft that facilitates secure remote access to graphical interfaces on desktops or applications hosted on remote servers. RDP supports multi-channel communication for transferring input, output, and management commands." ;
    skos:exactMatch d3f:RDPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RegressionAnalysis a owl:Class ;
    rdfs:label "RegressionAnalysis" ;
    d3f:d3fend-id "D3A-RA" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Regression analysis. [Link](https://en.wikipedia.org/wiki/Regression_analysis)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Regression Analysis" ;
    rdfs:subClassOf d3f:StatisticalMethod ;
    skos:definition "Regression analysis is a set of statistical processes for estimating the relationships between a dependent variable (often called the 'outcome' or 'response' variable, or a 'label' in machine learning parlance) and one or more independent variables (often called 'predictors', 'covariates', 'explanatory variables' or 'features')." ;
    skos:exactMatch d3f:RegressionAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RestoreObject a owl:Class ;
    rdfs:label "RestoreObject" ;
    d3f:d3fend-id "D3-RO" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Restore Object" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Restoring an object for an entity to access. This is the broadest class for object restoral." ;
    skos:exactMatch d3f:RestoreObject ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RiskImpactEnum a owl:Class ;
    rdfs:label "RiskImpactEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Very_Low> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Low> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Medium> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#High> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Very_High> ) ;
    skos:definition "Risk impact level. Open enum: arbitrary string values also accepted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#High>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Low>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Medium>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Very_High>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskImpactEnum#Very_Low> .

d3f:RiskLikelihoodEnum a owl:Class ;
    rdfs:label "RiskLikelihoodEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Very_Low> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Low> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Medium> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#High> <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Very_High> ) ;
    skos:definition "Risk likelihood level. Open enum: arbitrary string values also accepted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#High>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Low>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Medium>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Very_High>,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#RiskLikelihoodEnum#Very_Low> .

d3f:SPARTAPersistenceTechnique a owl:Class ;
    rdfs:label "SPARTAPersistenceTechnique" ;
    dcterms:title "Persistence Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAPersistenceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAResourceDevelopmentTechnique a owl:Class ;
    rdfs:label "SPARTAResourceDevelopmentTechnique" ;
    dcterms:title "Resource Development Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAResourceDevelopmentTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SecurityEvent a owl:Class ;
    rdfs:label "SecurityEvent" ;
    dcterms:title "Security Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:closeMatch unified_cyber_ontology:Action ;
    skos:definition "An event describing occurrences related to cybersecurity, including detection, remediation, or enforcement actions. Security events provide critical insights into the state, behavior, and resilience of digital systems." ;
    skos:exactMatch d3f:SecurityEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch stix:ObservedData .

d3f:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Sensor>,
        <https://schema.ocsf.io/objects/agent> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DigitalInformationBearer ],
        d3f:D3FENDCore ;
    skos:definition "In the broadest definition, a sensor is a device, module, machine, or subsystem that detects events or changes in its environment and sends the information to other electronics, frequently a computer." ;
    skos:exactMatch d3f:Sensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceApplicationProcess a owl:Class ;
    rdfs:label "ServiceApplicationProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Service Application Process" ;
    rdfs:subClassOf d3f:ApplicationProcess ;
    skos:definition "A Service Application Process performs specific tasks or provides functionality to support other processes, applications, or users." ;
    skos:exactMatch d3f:ServiceApplicationProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SetSystemConfigValueEnum a owl:Class ;
    rdfs:label "SetSystemConfigValueEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:RegSetKeyValueA d3f:RegSetKeyValueW d3f:RegSetValueA d3f:RegSetValueExA d3f:RegSetValueExW d3f:RegSetValueW ) ;
    skos:definition "Enumeration of SetSystemConfigValue values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:RegSetKeyValueA,
        d3f:RegSetKeyValueW,
        d3f:RegSetValueA,
        d3f:RegSetValueExA,
        d3f:RegSetValueExW,
        d3f:RegSetValueW .

d3f:SymbolicLink a owl:Class ;
    rdfs:label "SymbolicLink" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Symbolic Link" ;
    rdfs:seeAlso dbr:Symbolic_link ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:FileSystemLink ],
        d3f:File ;
    skos:altLabel "Soft Link",
        "Softlink",
        "Symlink" ;
    skos:definition "A symbolic link (also symlink or soft link) is a term for any file that contains a reference to another file or directory in the form of an absolute or relative path and that affects pathname resolution." ;
    skos:exactMatch d3f:SymbolicLink,
        unified_cyber_ontology:SymbolicLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1578 a owl:Class ;
    rdfs:label "T1578" ;
    d3f:attack-id "T1578" ;
    dcterms:title "Modify Cloud Compute Infrastructure" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "An adversary may attempt to modify a cloud account's compute service infrastructure to evade defenses. A modification to the compute service infrastructure can include the creation, deletion, or modification of one or more components such as compute instances, virtual machines, and snapshots." ;
    skos:exactMatch d3f:T1578,
        mitre-attack:T1578 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1596 a owl:Class ;
    rdfs:label "T1596" ;
    d3f:attack-id "T1596" ;
    dcterms:title "Search Open Technical Databases" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may search freely available technical databases for information about victims that can be used during targeting. Information about victims may be available in online databases and repositories, such as registrations of domains/certificates as well as public collections of network data/artifacts gathered from traffic and/or scans.(Citation: WHOIS)(Citation: DNS Dumpster)(Citation: Circl Passive DNS)(Citation: Medium SSL Cert)(Citation: SSLShopper Lookup)(Citation: DigitalShadows CDN)(Citation: Shodan)" ;
    skos:exactMatch d3f:T1596,
        mitre-attack:T1596 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1636 a owl:Class ;
    rdfs:label "T1636" ;
    d3f:attack-id "T1636" ;
    dcterms:title "Protected User Data" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may utilize standard operating system APIs to collect data from permission-backed data stores on a device, such as the calendar or contact list. These permissions need to be declared ahead of time. On Android, they must be included in the application’s manifest. On iOS, they must be included in the application’s `Info.plist` file." ;
    skos:exactMatch d3f:T1636,
        mitre-attack:T1636 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TCPEvent a owl:Class ;
    rdfs:label "TCPEvent" ;
    dcterms:title "TCP Event" ;
    rdfs:subClassOf d3f:TransportLayerEvent ;
    skos:definition "An event involving the Transmission Control Protocol (TCP), providing reliable, ordered, and error-checked delivery of data between applications." ;
    skos:exactMatch d3f:TCPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_kb_object_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-kb-object-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_object_property ;
    skos:definition "x d3fend-kb-object-property y: The object y is a d3fend knowledge base object property. These properties allow the linkage of knowledge and information supporting and illustrating the d3fend model." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_object_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-object-property" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:date_value a owl:DatatypeProperty ;
    rdfs:label "date_value" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:definition "A point or period of time associated with an event in the lifecycle of the resource." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:semantic_relation a owl:DatatypeProperty ;
    rdfs:label "semantic-relation" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x semantic-relation y: The entity x is conceptually or meaningfully connected to entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASExfiltrationTechnique a owl:Class ;
    rdfs:label "ATLASExfiltrationTechnique" ;
    dcterms:title "Exfiltration Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASExfiltrationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSPersistenceTechnique a owl:Class ;
    rdfs:label "ATTACKICSPersistenceTechnique" ;
    dcterms:title "Persistence Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSPersistenceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileExecutionTechnique a owl:Class ;
    rdfs:label "ATTACKMobileExecutionTechnique" ;
    dcterms:title "Execution Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileExecutionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobilePrivilegeEscalationTechnique a owl:Class ;
    rdfs:label "ATTACKMobilePrivilegeEscalationTechnique" ;
    dcterms:title "Privilege Escalation Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobilePrivilegeEscalationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ActiveLearning a owl:Class ;
    rdfs:label "ActiveLearning" ;
    d3f:d3fend-id "D3A-AL" ;
    d3f:kb-article "## How it works Traditional supervised learning often requires a large number of labeled instances, which can be costly or time-consuming to obtain. Active learning addresses this labeling bottleneck by asking an oracle (e.g., a human annotator) to label selected unlabeled instances. The goal is to" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Active Learning" ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:definition "Active learning aims to improve learning efficiency by allowing the learning algorithm to select which data to learn from." ;
    skos:exactMatch d3f:ActiveLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AnalyticalPurpose a owl:Class ;
    rdfs:label "AnalyticalPurpose" ;
    dcterms:title "Analytical Purpose" ;
    rdfs:subClassOf d3f:Goal ;
    skos:exactMatch d3f:AnalyticalPurpose ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AssetInventory a owl:Class ;
    rdfs:label "AssetInventory" ;
    d3f:d3fend-id "D3-AI" ;
    d3f:display-order "1" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Asset Discovery" ;
    dcterms:title "Asset Inventory" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Asset inventorying identifies and records the organization's assets and enriches each inventory item with knowledge about their vulnerabilities." ;
    skos:exactMatch d3f:AssetInventory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1173 a owl:Class ;
    rdfs:label "CWE_1173" ;
    d3f:cwe-id "CWE-1173" ;
    dcterms:title "Improper Use of Validation Framework" ;
    rdfs:subClassOf d3f:CWE20 ;
    skos:altLabel "CWE-1173" ;
    skos:definition "The product does not use, or incorrectly uses, an input validation framework that is provided by the source language or an independent library." ;
    skos:exactMatch d3f:CWE-1173,
        cwe:CWE-1173 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE221 a owl:Class ;
    rdfs:label "CWE_221" ;
    d3f:cwe-id "CWE-221" ;
    dcterms:title "Information Loss or Omission" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-221" ;
    skos:definition "The product does not record, or improperly records, security-relevant information that leads to an incorrect decision or hampers later analysis." ;
    skos:exactMatch d3f:CWE-221,
        cwe:CWE-221 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE228 a owl:Class ;
    rdfs:label "CWE_228" ;
    d3f:cwe-id "CWE-228" ;
    dcterms:title "Improper Handling of Syntactically Invalid Structure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE707 ],
        d3f:CWE703 ;
    skos:altLabel "CWE-228" ;
    skos:definition "The product does not handle or incorrectly handles input that is not syntactically well-formed with respect to the associated specification." ;
    skos:exactMatch d3f:CWE-228,
        cwe:CWE-228 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE312 a owl:Class ;
    rdfs:label "CWE_312" ;
    d3f:cwe-id "CWE-312" ;
    dcterms:title "Cleartext Storage of Sensitive Information" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE922 ],
        d3f:CWE311 ;
    skos:altLabel "CWE-312" ;
    skos:definition "The product stores sensitive information in cleartext within a resource that might be accessible to another control sphere." ;
    skos:exactMatch d3f:CWE-312,
        cwe:CWE-312 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE400 a owl:Class ;
    rdfs:label "CWE_400" ;
    d3f:cwe-id "CWE-400" ;
    d3f:synonym "Resource Exhaustion" ;
    dcterms:title "Uncontrolled Resource Consumption" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-400" ;
    skos:definition "The product does not properly control the allocation and maintenance of a limited resource." ;
    skos:exactMatch d3f:CWE-400,
        cwe:CWE-400 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE436 a owl:Class ;
    rdfs:label "CWE_436" ;
    d3f:cwe-id "CWE-436" ;
    dcterms:title "Interpretation Conflict" ;
    rdfs:subClassOf d3f:CWE435 ;
    skos:altLabel "CWE-436" ;
    skos:definition "Product A handles inputs or steps differently than Product B, which causes A to perform incorrect actions based on its perception of B's state." ;
    skos:exactMatch d3f:CWE-436,
        cwe:CWE-436 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE610 a owl:Class ;
    rdfs:label "CWE_610" ;
    d3f:cwe-id "CWE-610" ;
    dcterms:title "Externally Controlled Reference to a Resource in Another Sphere" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-610" ;
    skos:definition "The product uses an externally controlled name or reference that resolves to a resource that is outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-610,
        cwe:CWE-610 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE684 a owl:Class ;
    rdfs:label "CWE_684" ;
    d3f:cwe-id "CWE-684" ;
    dcterms:title "Incorrect Provision of Specified Functionality" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-684" ;
    skos:definition "The code does not function according to its published specifications, potentially leading to incorrect usage." ;
    skos:exactMatch d3f:CWE-684,
        cwe:CWE-684 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE695 a owl:Class ;
    rdfs:label "CWE_695" ;
    d3f:cwe-id "CWE-695" ;
    dcterms:title "Use of Low-Level Functionality" ;
    rdfs:subClassOf d3f:CWE573 ;
    skos:altLabel "CWE-695" ;
    skos:definition "The product uses low-level functionality that is explicitly prohibited by the framework or specification under which the product is supposed to operate." ;
    skos:exactMatch d3f:CWE-695,
        cwe:CWE-695 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE696 a owl:Class ;
    rdfs:label "CWE_696" ;
    d3f:cwe-id "CWE-696" ;
    dcterms:title "Incorrect Behavior Order" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-696" ;
    skos:definition "The product performs multiple related behaviors, but the behaviors are performed in the wrong order in ways which may produce resultant weaknesses." ;
    skos:exactMatch d3f:CWE-696,
        cwe:CWE-696 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE732 a owl:Class ;
    rdfs:label "CWE_732" ;
    d3f:cwe-id "CWE-732" ;
    dcterms:title "Incorrect Permission Assignment for Critical Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE668 ],
        d3f:CWE285 ;
    skos:altLabel "CWE-732" ;
    skos:definition "The product specifies permissions for a security-critical resource in a way that allows that resource to be read or modified by unintended actors." ;
    skos:exactMatch d3f:CWE-732,
        cwe:CWE-732 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE754 a owl:Class ;
    rdfs:label "CWE_754" ;
    d3f:cwe-id "CWE-754" ;
    dcterms:title "Improper Check for Unusual or Exceptional Conditions" ;
    rdfs:subClassOf d3f:CWE703 ;
    skos:altLabel "CWE-754" ;
    skos:definition "The product does not check or incorrectly checks for unusual or exceptional conditions that are not expected to occur frequently during day to day operation of the product." ;
    skos:exactMatch d3f:CWE-754,
        cwe:CWE-754 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Classification a owl:Class ;
    rdfs:label "Classification" ;
    d3f:d3fend-id "D3A-CLA" ;
    d3f:kb-article "## How it works Classification recognizes specific entities within the dataset and attempts to draw some conclusions on how those entities should be labeled or defined. Common classification algorithms are linear classifiers, support vector machines (SVM), decision trees, k-nearest neighbor, and ran" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:SupervisedLearning ;
    skos:definition "Classification uses an algorithm to accurately assign test data into specific categories." ;
    skos:exactMatch d3f:Classification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Credential a owl:Class ;
    rdfs:label "Credential" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Access_control,
        <http://dbpedia.org/resource/Access_control#Credential> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A credential is a physical/tangible object, a piece of knowledge, or a facet of a person's physical being that enables an individual access to a given physical facility or computer-based information system. Typically, credentials can be something a person knows (such as a number or PIN), something they have (such as an access badge), something they are (such as a biometric feature), something they do (measurable behavioral patterns) or some combination of these items. This is known as multi-factor authentication. The typical credential is an access card or key-fob, and newer software can also turn users' smartphones into access devices." ;
    skos:exactMatch d3f:Credential,
        unified_cyber_ontology:Credential ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DecoyObject a owl:Class ;
    rdfs:label "DecoyObject" ;
    d3f:d3fend-id "D3-DO" ;
    d3f:kb-article "## Technique Overview Decoy objects are typically configured with detectable means of communication but do not have any legitimate business purpose. Any communication via or to these objects should be logged and analyzed to find potential indicators of compromise for a possible past or future attack" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Lure" ;
    dcterms:title "Decoy Object" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "A Decoy Object is created and deployed for the purposes of deceiving attackers." ;
    skos:exactMatch d3f:DecoyObject ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DefensiveTacticEnum a owl:Class ;
    rdfs:label "DefensiveTacticEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Deceive d3f:Detect d3f:Evict d3f:Harden d3f:Isolate d3f:Model d3f:Restore ) ;
    skos:definition "Enumeration of DefensiveTactic values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A plan for attaining a particular goal." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:Deceive,
        d3f:Detect,
        d3f:Evict,
        d3f:Harden,
        d3f:Isolate,
        d3f:Model,
        d3f:Restore .

d3f:DeveloperApplication a owl:Class ;
    rdfs:label "DeveloperApplication" ;
    dcterms:title "Developer Application" ;
    rdfs:seeAlso dbr:Application_development,
        dbr:Application_software ;
    rdfs:subClassOf d3f:UserApplication ;
    skos:definition "An application used to develop computer software including applications used for software construction, analysis, testing, packaging, or management." ;
    skos:exactMatch d3f:DeveloperApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalMedia a owl:Class ;
    rdfs:label "DigitalMedia" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital Media" ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:definition "Digital media refers to any communication media that operate in conjunction with various encoded machine-readable data formats." ;
    skos:exactMatch d3f:DigitalMedia ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom d3f:Artifact ;
            owl:onProperty d3f:has_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom d3f:Artifact ;
            owl:onProperty d3f:has_input ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:has_input ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:has_output ],
        d3f:D3FENDCore ;
    skos:definition "An Event is an occurrence or action within a system, process, or environment within a finite span of time." ;
    skos:exactMatch d3f:Event ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ExecutableScript a owl:Class ;
    rdfs:label "ExecutableScript" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Executable Script" ;
    rdfs:seeAlso dbr:Executable ;
    rdfs:subClassOf d3f:ExecutableFile ;
    skos:definition "An executable script is written in a scripting language and interpreted at run time. This is in contrast with an executable binary, which contains machine code instructions for a physical CPU or byte code for a virtual machine." ;
    skos:exactMatch d3f:ExecutableScript ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FTPEvent a owl:Class ;
    rdfs:label "FTPEvent" ;
    dcterms:title "FTP Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/ftp_activity>,
        <https://schema.ocsf.io/classes/ftp_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:TCPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the File Transfer Protocol (FTP), a standard network protocol used to transfer files between a client and server over a TCP/IP network. FTP facilitates operations such as file uploads, downloads, directory listing, and remote file management." ;
    skos:exactMatch d3f:FTPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Firmware a owl:Class ;
    rdfs:label "Firmware" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Firmware ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "In electronic systems and computing, firmware is a type of software that provides control, monitoring and data manipulation of engineered products and systems. Typical examples of devices containing firmware are embedded systems (such as traffic lights, consumer appliances, remote controls and digital watches), computers, computer peripherals, mobile phones, and digital cameras. The firmware contained in these devices provides the low-level control program for the device." ;
    skos:exactMatch d3f:Firmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GroupManagementEvent a owl:Class ;
    rdfs:label "GroupManagementEvent" ;
    dcterms:title "Group Management Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/group_management>,
        <https://schema.ocsf.io/classes/group_management> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event involving the creation, modification, or deletion of a group, or changes to its membership and privileges. Group management events facilitate the enforcement of role-based access control by organizing users and permissions into logical units for streamlined administration and policy enforcement." ;
    skos:exactMatch d3f:GroupManagementEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HomogenousTransferLearning a owl:Class ;
    rdfs:label "HomogenousTransferLearning" ;
    d3f:d3fend-id "D3A-HTL" ;
    d3f:kb-article "## References Khalil, K., Asgher, U., & Ayaz, Y. (2022). Novel fNIRS study on homogeneous symmetric feature-based transfer learning for brain-computer interface. Scientific Reports, 12, 3198. [Link](https://www.nature.com/articles/s41598-022-06805-4)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Homogenous Transfer Learning" ;
    rdfs:subClassOf d3f:TransferLearning ;
    skos:definition "In homogeneous transfer learning, the feature spaces of the source and target domains is of the same dimension (Ds = Dt) while the data of both domains is represented by the same attributes (Xs = Xt) and labels (Ys = Yt). Thus, homogeneous transfer learning aims to bridge the gap in the data distributions experienced during cross-domain transfer." ;
    skos:exactMatch d3f:HomogenousTransferLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Identifier a owl:Class ;
    rdfs:label "Identifier" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Identifier ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:altLabel "ID" ;
    skos:definition "An identifier is a name that identifies (that is, labels the identity of) either a unique object or a unique class of objects, where the \"object\" or class may be an idea, physical [countable] object (or class thereof), or physical [noncountable] substance (or class thereof). The abbreviation ID often refers to identity, identification (the process of identifying), or an identifier (that is, an instance of identification). An identifier may be a word, number, letter, symbol, or any combination of those." ;
    skos:exactMatch d3f:Identifier,
        stix:Identifier ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MemoryEvent a owl:Class ;
    rdfs:label "MemoryEvent" ;
    dcterms:title "Memory Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/memory_activity>,
        <https://schema.ocsf.io/classes/memory_activity> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event capturing operations on the memory resources of a system, encompassing allocation, modification, access, protection, or deallocation." ;
    skos:exactMatch d3f:MemoryEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NTPEvent a owl:Class ;
    rdfs:label "NTPEvent" ;
    dcterms:title "NTP Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/ntp_activity>,
        <https://schema.ocsf.io/classes/ntp_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UDPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Network Time Protocol (NTP), a protocol designed to synchronize the clocks of computer systems over packet-switched, variable-latency data networks, UDP as its transport protocol." ;
    skos:exactMatch d3f:NTPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkConnectionEvent a owl:Class ;
    rdfs:label "NetworkConnectionEvent" ;
    dcterms:title "Network Connection Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/network_activity>,
        <https://schema.ocsf.io/classes/network_activity> ;
    rdfs:subClassOf d3f:NetworkEvent ;
    skos:definition "An event related to the establishment, maintenance, or termination of a network connection." ;
    skos:exactMatch d3f:NetworkConnectionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkIsolation a owl:Class ;
    rdfs:label "NetworkIsolation" ;
    d3f:d3fend-id "D3-NI" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Isolation" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Network Isolation techniques prevent network hosts from accessing non-essential system network resources." ;
    skos:exactMatch d3f:NetworkIsolation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkService a owl:Class ;
    rdfs:label "NetworkService" ;
    dcterms:title "Network Service" ;
    rdfs:seeAlso dbr:Network_service ;
    rdfs:subClassOf d3f:ServiceApplicationProcess ;
    skos:definition "In computer networking, a network service is an application running at the network application layer and above, that provides data storage, manipulation, presentation, communication or other capability which is often implemented using a client-server or peer-to-peer architecture based on application layer network protocols. Clients and servers will often have a user interface, and sometimes other hardware associated with it." ;
    skos:exactMatch d3f:NetworkService ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPICreateThread a owl:Class ;
    rdfs:label "OSAPICreateThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Create Thread" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that creates a new thread of execution within a process." ;
    skos:exactMatch d3f:OSAPICreateThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIOpenFile a owl:Class ;
    rdfs:label "OSAPIOpenFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Open File" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that opens a file for reading, writing, or both, and return a handle or descriptor that can be used to interact with the file." ;
    skos:exactMatch d3f:OSAPIOpenFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetNetworkTraffic a owl:Class ;
    rdfs:label "OutboundInternetNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet Network Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OutboundNetworkTraffic ],
        d3f:InternetNetworkTraffic ;
    skos:definition "Outbound internet network traffic is network traffic on an outgoing connection initiated from a host within a network to a host outside the network." ;
    skos:exactMatch d3f:OutboundInternetNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalArtifact a owl:Class ;
    rdfs:label "PhysicalArtifact" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Physical Artifact" ;
    rdfs:subClassOf d3f:Artifact ;
    skos:altLabel "Physical Object" ;
    skos:exactMatch d3f:PhysicalArtifact ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkEvent a owl:Class ;
    rdfs:label "PhysicalLinkEvent" ;
    dcterms:title "Physical Link Event" ;
    rdfs:subClassOf d3f:NetworkDeviceEvent ;
    skos:definition "A discrete event that changes either the presence of the transmission medium or the operational state of a single-hop layer-1 link between two network nodes." ;
    skos:exactMatch d3f:PhysicalLinkEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessEvent a owl:Class ;
    rdfs:label "ProcessEvent" ;
    dcterms:title "Process Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/process_activity>,
        <https://schema.ocsf.io/classes/process_activity> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event capturing lifecycle transitions, interactions, or activities of computer processes, including their creation, termination, and inter-process communication." ;
    skos:exactMatch d3f:ProcessEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Record a owl:Class ;
    rdfs:label "Record" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Record_\(computer_science\) ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "In computer science, a record (also called struct or compound data) is a basic data structure. A record is a collection of fields, possibly of different data types, typically in fixed number and sequence . The fields of a record may also be called members, particularly in object-oriented programming. Fields may also be called elements, though these risk confusion with the elements of a collection. A tuple may or may not be considered a record, and vice versa, depending on conventions and the specific programming language." ;
    skos:exactMatch d3f:Record ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RegressionAnalysisLearning a owl:Class ;
    rdfs:label "RegressionAnalysisLearning" ;
    d3f:d3fend-id "D3A-RAL" ;
    d3f:kb-article "## References Supervised Learning. IBM. [Link](https://www.ibm.com/topics/supervised-learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Regression Analysis Learning" ;
    rdfs:subClassOf d3f:SupervisedLearning ;
    skos:definition "Regression is used to understand the relationship between dependent and independent variables which is then used to make projections, such as for sales revenue for a given business." ;
    skos:exactMatch d3f:RegressionAnalysisLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RuntimeVariable a owl:Class ;
    rdfs:label "RuntimeVariable" ;
    dcterms:title "Runtime Variable" ;
    rdfs:seeAlso <https://dbpedia.org/page/Variable_(computer_science)> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A runtime variable is an abstract storage location paired with an associated symbolic name, which contains some known or unknown quantity of data or object referred to as a value, which can change during the execution of a computer program." ;
    skos:exactMatch d3f:RuntimeVariable ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SMBEvent a owl:Class ;
    rdfs:label "SMBEvent" ;
    dcterms:title "SMB Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/smb_activity>,
        <https://schema.ocsf.io/classes/smb_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:TCPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Server Message Block (SMB) protocol, a network file sharing protocol that allows client-server communication for accessing files, printers, and other shared network resources. SMB supports both transactional file operations and communication over reliable transport layers." ;
    skos:exactMatch d3f:SMBEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAImpactTechnique a owl:Class ;
    rdfs:label "SPARTAImpactTechnique" ;
    dcterms:title "Impact Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAImpactTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SSHEvent a owl:Class ;
    rdfs:label "SSHEvent" ;
    dcterms:title "SSH Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/ssh_activity>,
        <https://schema.ocsf.io/classes/ssh_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:TCPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Secure Shell (SSH) protocol, a cryptographic network protocol designed to provide secure remote login, command execution, and data transfer. SSH facilitates encrypted communication between clients and servers, ensuring confidentiality, integrity, and authenticity." ;
    skos:exactMatch d3f:SSHEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ScheduledJobEvent a owl:Class ;
    rdfs:label "ScheduledJobEvent" ;
    dcterms:title "Scheduled Job Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/scheduled_job_activity>,
        <https://schema.ocsf.io/classes/scheduled_job_activity> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event capturing the lifecycle or management of scheduled tasks within a system, including creation, modification, execution, or removal." ;
    skos:exactMatch d3f:ScheduledJobEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StatisticalMethod a owl:Class ;
    rdfs:label "StatisticalMethod" ;
    d3f:d3fend-id "D3A-SM" ;
    d3f:kb-article "## References Wolfram MathWorld. (n.d.). Statistics. [Link](https://mathworld.wolfram.com/Statistics.html)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Statistical Method" ;
    rdfs:subClassOf d3f:AnalyticTechnique ;
    skos:definition "Building methods using the mathematical study of the likelihood and probability of events occurring based on known information and inferred by taking a limited number of samples." ;
    skos:exactMatch d3f:StatisticalMethod ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1590 a owl:Class ;
    rdfs:label "T1590" ;
    d3f:attack-id "T1590" ;
    dcterms:title "Gather Victim Network Information" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may gather information about the victim's networks that can be used during targeting. Information about networks may include a variety of details, including administrative data (ex: IP ranges, domain names, etc.) as well as specifics regarding its topology and operations." ;
    skos:exactMatch d3f:T1590,
        mitre-attack:T1590 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1608 a owl:Class ;
    rdfs:label "T1608" ;
    d3f:attack-id "T1608" ;
    dcterms:title "Stage Capabilities" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may upload, install, or otherwise set up capabilities that can be used during targeting. To support their operations, an adversary may need to take capabilities they developed ([Develop Capabilities](https://attack.mitre.org/techniques/T1587)) or obtained ([Obtain Capabilities](https://attack.mitre.org/techniques/T1588)) and stage them on infrastructure under their control. These capabilities may be staged on infrastructure that was previously purchased/rented by the adversary ([Acquire Infrastructure](https://attack.mitre.org/techniques/T1583)) or was otherwise compromised by them ([Compromise Infrastructure](https://attack.mitre.org/techniques/T1584)). Capabilities may also be staged on web services, such as GitHub or Pastebin, or on Platform-as-a-Service (PaaS) offerings that enable users to easily provision applications.(Citation: Volexity Ocean Lotus November 2020)(Citation: Dragos Heroku Watering Hole)(Citation: Malwarebytes Heroku Skimmers)(Citation: Netskope GCP Redirection)(Citation: Netskope Cloud Phishing)" ;
    skos:exactMatch d3f:T1608,
        mitre-attack:T1608 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Variability a owl:Class ;
    rdfs:label "Variability" ;
    d3f:d3fend-id "D3A-VAR" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Statistical dispersion. [Link](https://en.wikipedia.org/wiki/Statistical_dispersion)" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DescriptiveStatistics ;
    skos:definition "Dispersion (also called variability, scatter, or spread) is the extent to which a distribution is stretched or squeezed. A measure of statistical dispersion is a nonnegative real number that is zero if all the data are the same and increases as the data become more diverse." ;
    skos:exactMatch d3f:Variability ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASImpactTechnique a owl:Class ;
    rdfs:label "ATLASImpactTechnique" ;
    dcterms:title "Impact Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASImpactTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASInitialAccessTechnique a owl:Class ;
    rdfs:label "ATLASInitialAccessTechnique" ;
    dcterms:title "Initial Access Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASInitialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASPersistenceTechnique a owl:Class ;
    rdfs:label "ATLASPersistenceTechnique" ;
    dcterms:title "Persistence Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASPersistenceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSEvasionTechnique a owl:Class ;
    rdfs:label "ATTACKICSEvasionTechnique" ;
    dcterms:title "Evasion Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSEvasionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSImpairProcessControlTechnique a owl:Class ;
    rdfs:label "ATTACKICSImpairProcessControlTechnique" ;
    dcterms:title "Impair Process Control Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:definition "The adversary is trying to manipulate, disable, or damage physical control processes." ;
    skos:exactMatch d3f:ATTACKICSImpairProcessControlTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1061 a owl:Class ;
    rdfs:label "CWE_1061" ;
    d3f:cwe-id "CWE-1061" ;
    dcterms:title "Insufficient Encapsulation" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1061" ;
    skos:definition "The product does not sufficiently hide the internal representation and implementation details of data or methods, which might allow external components or modules to modify data unexpectedly, invoke unexpected functionality, or introduce dependencies that the programmer did not intend." ;
    skos:exactMatch d3f:CWE-1061,
        cwe:CWE-1061 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE269 a owl:Class ;
    rdfs:label "CWE_269" ;
    d3f:cwe-id "CWE-269" ;
    dcterms:title "Improper Privilege Management" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-269" ;
    skos:definition "The product does not properly assign, modify, track, or check privileges for an actor, creating an unintended sphere of control for that actor." ;
    skos:exactMatch d3f:CWE-269,
        cwe:CWE-269 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE330 a owl:Class ;
    rdfs:label "CWE_330" ;
    d3f:cwe-id "CWE-330" ;
    dcterms:title "Use of Insufficiently Random Values" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-330" ;
    skos:definition "The product uses insufficiently random numbers or values in a security context that depends on unpredictable numbers." ;
    skos:exactMatch d3f:CWE-330,
        cwe:CWE-330 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE362 a owl:Class ;
    rdfs:label "CWE_362" ;
    d3f:cwe-id "CWE-362" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Race Condition" ;
    dcterms:title "Concurrent Execution using Shared Resource with Improper Synchronization ('Race Condition')" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-362" ;
    skos:definition "The product contains a concurrent code sequence that requires temporary, exclusive access to a shared resource, but a timing window exists in which the shared resource can be modified by another code sequence operating concurrently." ;
    skos:exactMatch d3f:CWE-362,
        cwe:CWE-362 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE552 a owl:Class ;
    rdfs:label "CWE_552" ;
    d3f:cwe-id "CWE-552" ;
    dcterms:title "Files or Directories Accessible to External Parties" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE668 ],
        d3f:CWE285 ;
    skos:altLabel "CWE-552" ;
    skos:definition "The product makes files or directories accessible to unauthorized actors, even though they should not be." ;
    skos:exactMatch d3f:CWE-552,
        cwe:CWE-552 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE705 a owl:Class ;
    rdfs:label "CWE_705" ;
    d3f:cwe-id "CWE-705" ;
    dcterms:title "Incorrect Control Flow Scoping" ;
    rdfs:subClassOf d3f:CWE691 ;
    skos:altLabel "CWE-705" ;
    skos:definition "The product does not properly return control flow to the proper location after it has completed a task or detected an unusual condition." ;
    skos:exactMatch d3f:CWE-705,
        cwe:CWE-705 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE706 a owl:Class ;
    rdfs:label "CWE_706" ;
    d3f:cwe-id "CWE-706" ;
    dcterms:title "Use of Incorrectly-Resolved Name or Reference" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-706" ;
    skos:definition "The product uses a name or reference to access a resource, but the name/reference resolves to a resource that is outside of the intended control sphere." ;
    skos:exactMatch d3f:CWE-706,
        cwe:CWE-706 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE758 a owl:Class ;
    rdfs:label "CWE_758" ;
    d3f:cwe-id "CWE-758" ;
    dcterms:title "Reliance on Undefined, Unspecified, or Implementation-Defined Behavior" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-758" ;
    skos:definition "The product uses an API function, data structure, or other entity in a way that relies on properties that are not always guaranteed to hold for that entity." ;
    skos:exactMatch d3f:CWE-758,
        cwe:CWE-758 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE79 a owl:Class ;
    rdfs:label "CWE_79" ;
    d3f:cwe-id "CWE-79" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "CSS" ;
    dcterms:title "Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')" ;
    rdfs:subClassOf d3f:CWE74 ;
    skos:altLabel "CWE-79" ;
    skos:definition "The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users." ;
    skos:exactMatch d3f:CWE-79,
        cwe:CWE-79 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CentralTendency a owl:Class ;
    rdfs:label "CentralTendency" ;
    d3f:d3fend-id "D3A-CT" ;
    d3f:kb-article "## References Australian Bureau of Statistics. (n.d.). Measures of Central Tendency. [Link](https://www.abs.gov.au/statistics/understanding-statistics/statistical-terms-and-concepts/measures-central-tendency) Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Central Tendency" ;
    rdfs:subClassOf d3f:DescriptiveStatistics ;
    skos:definition "A measure of central tendency ) is a summary measure that attempts to describe a whole set of data with a single value that represents the middle or centre of its distribution." ;
    skos:exactMatch d3f:CentralTendency ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputerNetworkNode a owl:Class ;
    rdfs:label "ComputerNetworkNode" ;
    dcterms:title "Computer Network Node" ;
    rdfs:seeAlso <https://schema.ocsf.io/objects/network_endpoint> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:NetworkNode ],
        d3f:ComputerPlatform ;
    skos:definition "A network node running on a computer platform." ;
    skos:exactMatch d3f:ComputerNetworkNode ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ConfigurationResource a owl:Class ;
    rdfs:label "ConfigurationResource" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Configuration Resource" ;
    rdfs:subClassOf d3f:Resource ;
    skos:definition "A resource used to configure a system including software and hardware." ;
    skos:exactMatch d3f:ConfigurationResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DefensiveTactic a owl:Class ;
    rdfs:label "DefensiveTactic" ;
    dcterms:title "Defensive Tactic" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/05913746-n> ;
    rdfs:subClassOf d3f:Goal ;
    skos:closeMatch unified_cyber_ontology:ActionPattern ;
    skos:definition "A plan for attaining a particular goal." ;
    skos:exactMatch d3f:DefensiveTactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:IntranetNetworkTraffic a owl:Class ;
    rdfs:label "IntranetNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Intranet Network Traffic" ;
    rdfs:seeAlso dbr:Intranet ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "Intranet network traffic is network traffic traversing that does not traverse a given network's boundaries." ;
    skos:exactMatch d3f:IntranetNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPIAllocateMemory a owl:Class ;
    rdfs:label "OSAPIAllocateMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Allocate Memory" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that requests and allocates a region of memory for use by a process or application." ;
    skos:exactMatch d3f:OSAPIAllocateMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPICreateProcess a owl:Class ;
    rdfs:label "OSAPICreateProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Create Process" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that creates a new process within the system." ;
    skos:exactMatch d3f:OSAPICreateProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTModifyDeviceOperatingModeCommand a owl:Class ;
    rdfs:label "OTModifyDeviceOperatingModeCommand" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OT Modify Device Operating Mode Command" ;
    rdfs:seeAlso <https://icscsi.org/library/Documents/ICS_Protocols/Control%20Microsystems%20-%20DNP3%20User%20and%20Reference%20Manual.pdf>,
        <https://modbus.org/docs/Modbus_Application_Protocol_V1_1b3.pdf>,
        <https://nvlpubs.nist.gov/nistpubs/TechnicalNotes/NIST.TN.2023.pdf> ;
    rdfs:subClassOf d3f:OTModifyDeviceConfigurationCommand ;
    skos:definition "Modifies the running state of an application or program on a device." ;
    skos:exactMatch d3f:OTModifyDeviceOperatingModeCommand ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "BACnet: deviceCommunicationControl BACnet: reinitializeDevice",
        "GE-SRTP: SET PLC (RUN VS STOP)" .

d3f:OTModifyDeviceOperatingModeCommandEvent a owl:Class ;
    rdfs:label "OTModifyDeviceOperatingModeCommandEvent" ;
    dcterms:title "OT Modify Device Operating Mode Command Event" ;
    rdfs:subClassOf d3f:OTModifyDeviceConfigurationCommandEvent ;
    skos:definition "Modifies the running state of an application or program on a device." ;
    skos:exactMatch d3f:OTModifyDeviceOperatingModeCommandEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTALateralMovementTechnique a owl:Class ;
    rdfs:label "SPARTALateralMovementTechnique" ;
    dcterms:title "Lateral Movement Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTALateralMovementTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1518 a owl:Class ;
    rdfs:label "T1518" ;
    d3f:attack-id "T1518" ;
    dcterms:title "Software Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of software and software versions that are installed on a system or in a cloud environment. Adversaries may use the information from [Software Discovery](https://attack.mitre.org/techniques/T1518) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1518,
        mitre-attack:T1518 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1588 a owl:Class ;
    rdfs:label "T1588" ;
    d3f:attack-id "T1588" ;
    dcterms:title "Obtain Capabilities" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may buy and/or steal capabilities that can be used during targeting. Rather than developing their own capabilities in-house, adversaries may purchase, freely download, or steal them. Activities may include the acquisition of malware, software (including licenses), exploits, certificates, and information relating to vulnerabilities. Adversaries may obtain capabilities to support their operations throughout numerous phases of the adversary lifecycle." ;
    skos:exactMatch d3f:T1588,
        mitre-attack:T1588 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccount a owl:Class ;
    rdfs:label "UserAccount" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Account" ;
    rdfs:seeAlso <http://dbpedia.org/resource/User_(computing)#User_account>,
        dbr:User_account,
        <https://schema.ocsf.io/objects/user> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A user account allows a user to authenticate to a system and potentially to receive authorization to access resources provided by or connected to that system; however, authentication does not imply authorization. To log into an account, a user is typically required to authenticate oneself with a password or other credentials for the purposes of accounting, security, logging, and resource management." ;
    skos:exactMatch d3f:UserAccount,
        stix:UserAccount,
        unified_cyber_ontology:UserAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserApplication a owl:Class ;
    rdfs:label "UserApplication" ;
    dcterms:title "User Application" ;
    rdfs:seeAlso dbr:Enterprise_software ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "A user application is executed for that an individual user on a user's personal computer or remotely by means of virtualization.  This is in contrast to service applications or enterprise software." ;
    skos:exactMatch d3f:UserApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_data_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-data-property" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASReconnaissanceTechnique a owl:Class ;
    rdfs:label "ATLASReconnaissanceTechnique" ;
    dcterms:title "Reconnaissance Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASReconnaissanceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSLateralMovementTechnique a owl:Class ;
    rdfs:label "ATTACKICSLateralMovementTechnique" ;
    dcterms:title "Lateral Movement Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSLateralMovementTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AccessMediation a owl:Class ;
    rdfs:label "AccessMediation" ;
    d3f:d3fend-id "D3-AMED" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Access Control" ;
    dcterms:title "Access Mediation" ;
    rdfs:seeAlso dbr:Access_control,
        <https://ieeexplore.ieee.org/stamp/stamp.jsp?tp=&arnumber=1451869>,
        <https://nvlpubs.nist.gov/nistpubs/FIPS/NIST.FIPS.201-2.pdf>,
        <https://nvlpubs.nist.gov/nistpubs/SpecialPublications/NIST.SP.800-160v1r1.pdf>,
        <https://www.cs.cmu.edu/afs/cs/usr/bsy/security/CSC-STD-001-83.txt> ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Access mediation is the process of granting or denying specific requests to: 1) obtain and use information and related information processing services; and 2) enter specific physical facilities (e.g., Federal buildings, military establishments, border crossing entrances). Access mediation decisions should enforce least privilege by granting access for scoped durations to prevent privilege creep and, where applicable, implement just-in-time (JIT) access. Denial decisions may prevent initial access or terminate access that has already been granted, ensuring continuous enforcement of security policies." ;
    skos:exactMatch d3f:AccessMediation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Application a owl:Class ;
    rdfs:label "Application" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Application_software,
        <http://wordnet-rdf.princeton.edu/id/06582286-n>,
        <https://schema.ocsf.io/objects/application> ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "A program that gives a computer instructions that provide the user with tools to accomplish a task; \"he has tried several different word processing applications\".  Distinct from system software that is intrinsically part of the operating system.  An application can be made up of executable files, configuration files, shared libraries, etc." ;
    skos:exactMatch d3f:Application,
        unified_cyber_ontology:Application ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationHardening a owl:Class ;
    rdfs:label "ApplicationHardening" ;
    d3f:d3fend-id "D3-AH" ;
    d3f:kb-article "## Technique Overview Exploits may, for example, rely on knowledge of addresses in a process's memory, they may alter memory contents, and they may cause a program to use instructions in a way that they were not intended. By, for example, including code that dynamically changes the memory address" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Process Hardening" ;
    dcterms:title "Application Hardening" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Application Hardening makes an executable application more resilient to a class of exploits which either introduce new code or execute unwanted existing code. These techniques may be applied at compile-time or on an application binary." ;
    skos:exactMatch d3f:ApplicationHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE20 a owl:Class ;
    rdfs:label "CWE_20" ;
    d3f:cwe-id "CWE-20" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Improper Input Validation" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-20" ;
    skos:definition "The product receives input or data, but it does not validate or incorrectly validates that the input has the properties that are required to process the data safely and correctly." ;
    skos:exactMatch d3f:CWE-20,
        cwe:CWE-20 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE697 a owl:Class ;
    rdfs:label "CWE_697" ;
    d3f:cwe-id "CWE-697" ;
    dcterms:title "Incorrect Comparison" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-697" ;
    skos:definition "The product compares two entities in a security-relevant context, but the comparison is incorrect, which may lead to resultant weaknesses." ;
    skos:exactMatch d3f:CWE-697,
        cwe:CWE-697 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE74 a owl:Class ;
    rdfs:label "CWE_74" ;
    d3f:cwe-id "CWE-74" ;
    dcterms:title "Improper Neutralization of Special Elements in Output Used by a Downstream Component ('Injection')" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-74" ;
    skos:definition "The product constructs all or part of a command, data structure, or record using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify how it is parsed or interpreted when it is sent to a downstream component." ;
    skos:exactMatch d3f:CWE-74,
        cwe:CWE-74 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE923 a owl:Class ;
    rdfs:label "CWE_923" ;
    d3f:cwe-id "CWE-923" ;
    dcterms:title "Improper Restriction of Communication Channel to Intended Endpoints" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-923" ;
    skos:definition "The product establishes a communication channel to (or from) an endpoint for privileged or protected operations, but it does not properly ensure that it is communicating with the correct endpoint." ;
    skos:exactMatch d3f:CWE-923,
        cwe:CWE-923 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ClusterAnalysis a owl:Class ;
    rdfs:label "ClusterAnalysis" ;
    d3f:d3fend-id "D3A-CA" ;
    d3f:kb-article "## References Cluster analysis. (n.d.). Wikipedia. [Link](https://en.wikipedia.org/wiki/Cluster_analysis)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cluster Analysis" ;
    rdfs:subClassOf d3f:UnsupervisedLearning ;
    skos:definition "Cluster analysis or clustering is the task of grouping a set of objects in such a way that objects in the same group (called a cluster) are more similar (in some sense) to each other than to those in other groups (clusters)." ;
    skos:exactMatch d3f:ClusterAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DHCPEvent a owl:Class ;
    rdfs:label "DHCPEvent" ;
    dcterms:title "DHCP Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/dhcp_activity>,
        <https://schema.ocsf.io/classes/dhcp_activity> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UDPEvent ],
        d3f:ApplicationLayerEvent ;
    skos:definition "An event involving the Dynamic Host Configuration Protocol (DHCP), a UDP-based protocol used to dynamically assign IP addresses and configure network parameters, enabling devices to communicate efficiently on a network." ;
    skos:exactMatch d3f:DHCPEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DocumentFileEnum a owl:Class ;
    rdfs:label "DocumentFileEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:AdobePDFFile1.3 d3f:MicrosoftWordDOCBFile d3f:MicrosoftWordDOCFile d3f:MicrosoftWordDOCMFile d3f:MicrosoftWordDOCXFile d3f:MicrosoftWordDOTFile d3f:MicrosoftWordDOTMFile d3f:MicrosoftWordDOTXFile d3f:MicrosoftWordWBKFile ) ;
    skos:definition "Enumeration of DocumentFile values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A document is a written, drawn, presented or recorded representation of thoughts. An electronic document file is usually used to describe a primarily textual file, along with its structure and design, such as fonts, colors and additional images." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:AdobePDFFile1.3,
        d3f:MicrosoftWordDOCBFile,
        d3f:MicrosoftWordDOCFile,
        d3f:MicrosoftWordDOCMFile,
        d3f:MicrosoftWordDOCXFile,
        d3f:MicrosoftWordDOTFile,
        d3f:MicrosoftWordDOTMFile,
        d3f:MicrosoftWordDOTXFile,
        d3f:MicrosoftWordWBKFile .

d3f:EnsembleLearning a owl:Class ;
    rdfs:label "EnsembleLearning" ;
    d3f:d3fend-id "D3A-EL" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Ensemble Learning" ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:definition "In statistics and machine learning, ensemble methods use multiple learning algorithms to obtain better predictive performance than could be obtained from any of the constituent learning algorithms alone" ;
    skos:exactMatch d3f:EnsembleLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HTTPRequestEvent a owl:Class ;
    rdfs:label "HTTPRequestEvent" ;
    dcterms:title "HTTP Request Event" ;
    rdfs:subClassOf d3f:HTTPEvent ;
    skos:definition "An event where an HTTP request is sent from a client to a server over an established TCP connection." ;
    skos:exactMatch d3f:HTTPRequestEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceStateEvent a owl:Class ;
    rdfs:label "HardwareDeviceStateEvent" ;
    dcterms:title "Hardware Device State Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event involving a change to a device's state, such as connection, disconnection, modification, or operational state transitions (e.g., online or offline). Device state events provide visibility into device availability and operational conditions." ;
    skos:exactMatch d3f:HardwareDeviceStateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:MachineLearning a owl:Class ;
    rdfs:label "MachineLearning" ;
    d3f:d3fend-id "D3A-ML" ;
    d3f:kb-article "## References Machine learning.\" Wikipedia. [Link](https://en.wikipedia.org/wiki/Machine_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Machine Learning" ;
    rdfs:subClassOf d3f:AnalyticTechnique ;
    skos:definition "Machine learning techniques are computational methods that combine statistics, probability, and optimization to make accurate predictions and/or improve performance." ;
    skos:exactMatch d3f:MachineLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemMonitoring a owl:Class ;
    rdfs:label "OperatingSystemMonitoring" ;
    d3f:d3fend-id "D3-OSM" ;
    d3f:kb-article "## Technique Overview \"An operating system (OS) is system software that manages computer hardware and software resources and provides common services for computer programs.\" [1] Operating System Monitoring Techniques have varied implementations including built-in kernel modules, third-party privil" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Monitoring" ;
    rdfs:subClassOf d3f:PlatformMonitoring ;
    skos:definition "The operating system software, for D3FEND's purposes, includes the kernel and its process management functions, hardware drivers, initialization or boot logic. It also includes and other key system daemons and their configuration. The monitoring or analysis of these components for unauthorized activity constitute **Operating System Monitoring**." ;
    skos:exactMatch d3f:OperatingSystemMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0001 a owl:Class ;
    rdfs:label "REC_0001" ;
    d3f:attack-id "REC-0001" ;
    dcterms:title "Gather Spacecraft Design Information" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0001/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0001" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's design that can be used for future campaigns or to help perpetuate other techniques. Information about the spacecraft can include software, firmware, encryption type, purpose, as well as various makes and models of subsystems." ;
    skos:exactMatch d3f:REC-0001,
        mitre-attack:REC-0001 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ResourceDevelopmentTechnique a owl:Class ;
    rdfs:label "ResourceDevelopmentTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resource Development Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to establish resources they can use to support operations." ;
    skos:exactMatch d3f:ResourceDevelopmentTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTATacticEnum a owl:Class ;
    rdfs:label "SPARTATacticEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:ST0001 d3f:ST0002 d3f:ST0003 d3f:ST0004 d3f:ST0005 d3f:ST0006 d3f:ST0007 d3f:ST0008 d3f:ST0009 ) ;
    skos:definition "Enumeration of SPARTATactic values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "SPARTA Tactics represent the 'why' of a SPARTA technique. They denote the tactical goal of a threat actor and the reason for performing a technique." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:ST0001,
        d3f:ST0002,
        d3f:ST0003,
        d3f:ST0004,
        d3f:ST0005,
        d3f:ST0006,
        d3f:ST0007,
        d3f:ST0008,
        d3f:ST0009 .

d3f:ServiceEvent a owl:Class ;
    rdfs:label "ServiceEvent" ;
    dcterms:title "Service Event" ;
    rdfs:subClassOf d3f:ApplicationEvent ;
    skos:definition "An event capturing the operation, configuration, or lifecycle of a service application. Services are specialized applications designed to provide reusable functionality to clients, systems, or other applications, often operating in the background or across networks." ;
    skos:exactMatch d3f:ServiceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SourceCodeHardening a owl:Class ;
    rdfs:label "SourceCodeHardening" ;
    d3f:d3fend-id "D3-SCH" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Source Code Hardening" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Hardening source code with the intention of making it more difficult to exploit and less error prone." ;
    skos:exactMatch d3f:SourceCodeHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SymbolicAI a owl:Class ;
    rdfs:label "SymbolicAI" ;
    d3f:d3fend-id "D3A-SR" ;
    d3f:kb-article "## How it works Symbolic artificial intelligence is used in tools such as logic programming, production rules, semantic nets and frames, and it developed applications such as knowledge-based systems (in particular, expert systems), symbolic mathematics, automated theorem provers, ontologies, the sem" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Symbolic Artificial Intelligence" ;
    dcterms:title "Symbolic AI" ;
    rdfs:subClassOf d3f:SymbolicLogic ;
    skos:definition "Symbolic artificial intelligence is the term for the collection of all methods in artificial intelligence that are based on high-level symbolic (human-readable) representations of problems, logic, and search." ;
    skos:exactMatch d3f:SymbolicAI ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1195 a owl:Class ;
    rdfs:label "T1195" ;
    d3f:attack-id "T1195" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Supply Chain Compromise" ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may manipulate products or product delivery mechanisms prior to receipt by a final consumer for the purpose of data or system compromise." ;
    skos:exactMatch d3f:T1195,
        mitre-attack:T1195 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1583 a owl:Class ;
    rdfs:label "T1583" ;
    d3f:attack-id "T1583" ;
    dcterms:title "Acquire Infrastructure" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may buy, lease, rent, or obtain infrastructure that can be used during targeting. A wide variety of infrastructure exists for hosting and orchestrating adversary operations. Infrastructure solutions include physical or cloud servers, domains, and third-party web services.(Citation: TrendmicroHideoutsLease) Some infrastructure providers offer free trial periods, enabling infrastructure acquisition at limited to no cost.(Citation: Free Trial PurpleUrchin) Additionally, botnets are available for rent or purchase." ;
    skos:exactMatch d3f:T1583,
        mitre-attack:T1583 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1584 a owl:Class ;
    rdfs:label "T1584" ;
    d3f:attack-id "T1584" ;
    dcterms:title "Compromise Infrastructure" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may compromise third-party infrastructure that can be used during targeting. Infrastructure solutions include physical or cloud servers, domains, network devices, and third-party web and DNS services. Instead of buying, leasing, or renting infrastructure an adversary may compromise infrastructure and use it during other phases of the adversary lifecycle.(Citation: Mandiant APT1)(Citation: ICANNDomainNameHijacking)(Citation: Talos DNSpionage Nov 2018)(Citation: FireEye EPS Awakens Part 2) Additionally, adversaries may compromise numerous machines to form a botnet they can leverage." ;
    skos:exactMatch d3f:T1584,
        mitre-attack:T1584 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASDiscoveryTechnique a owl:Class ;
    rdfs:label "ATLASDiscoveryTechnique" ;
    dcterms:title "Discovery Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASDiscoveryTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSDiscoveryTechnique a owl:Class ;
    rdfs:label "ATTACKICSDiscoveryTechnique" ;
    dcterms:title "Discovery Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSDiscoveryTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationEvent a owl:Class ;
    rdfs:label "ApplicationEvent" ;
    dcterms:title "Application Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/application_lifecycle>,
        <https://schema.ocsf.io/classes/application_lifecycle> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event that captures the behavior, state, or interactions of software applications or services operating within a system. Application events encompass lifecycle changes, configuration updates, and operational anomalies, providing insight into the health and performance of software components." ;
    skos:exactMatch d3f:ApplicationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationLayerEvent a owl:Class ;
    rdfs:label "ApplicationLayerEvent" ;
    dcterms:title "Application Layer Event" ;
    rdfs:subClassOf d3f:NetworkEvent ;
    skos:definition "An event occurring at the application layer, involving protocols that support application-specific communication." ;
    skos:exactMatch d3f:ApplicationLayerEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Artifact a owl:Class ;
    rdfs:label "Artifact" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <http://d3fend.mitre.org/ontologies/d3fend.owl>,
        <http://wordnet-rdf.princeton.edu/id/00022119-n> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom d3f:Event ;
            owl:onProperty d3f:output_of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:input_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom d3f:Weakness ;
            owl:onProperty d3f:may_have_weakness ],
        [ a owl:Restriction ;
            owl:allValuesFrom d3f:Event ;
            owl:onProperty d3f:input_of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:may_have_weakness ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:output_of ],
        d3f:D3FENDCore ;
    skos:broadMatch spdx:Element ;
    skos:definition "A man-made object taken as a whole." ;
    skos:exactMatch d3f:Artifact,
        stix:Artifact ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch unified_cyber_ontology:Item .

d3f:CWE285 a owl:Class ;
    rdfs:label "CWE_285" ;
    d3f:cwe-id "CWE-285" ;
    d3f:synonym "AuthZ" ;
    dcterms:title "Improper Authorization" ;
    rdfs:subClassOf d3f:CWE284 ;
    skos:altLabel "CWE-285" ;
    skos:definition "The product does not perform or incorrectly performs an authorization check when an actor attempts to access a resource or perform an action." ;
    skos:exactMatch d3f:CWE-285,
        cwe:CWE-285 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDeviceEvent a owl:Class ;
    rdfs:label "HardwareDeviceEvent" ;
    dcterms:title "Hardware Device Event" ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event capturing the existence, state, or interaction of hardware or virtual devices within a system. Device events encompass activities such as discovery, connection, disconnection, operational state changes, or configuration modifications, providing visibility into device behavior and health." ;
    skos:exactMatch d3f:HardwareDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PlatformMonitoring a owl:Class ;
    rdfs:label "PlatformMonitoring" ;
    d3f:d3fend-id "D3-PM" ;
    d3f:kb-article "Platform monitoring consists of the analysis and monitoring of system level devices and low-level components, including hardware devices, to detect unauthorized modifications or suspicious activity. Monitored platform components includes system files and embedded devices such as: * Kernel softwar" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Platform Monitoring" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Monitoring platform components such as operating systems software, hardware devices, or firmware." ;
    skos:exactMatch d3f:PlatformMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessAnalysis a owl:Class ;
    rdfs:label "ProcessAnalysis" ;
    d3f:d3fend-id "D3-PA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Analysis" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Process Analysis consists of observing a running application process and analyzing it to watch for certain behaviors or conditions which may indicate adversary activity. Analysis can occur inside of the process or through a third-party monitoring application. Examples include monitoring system and privileged calls, monitoring process initiation chains, and memory boundary allocations." ;
    skos:exactMatch d3f:ProcessAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAReconnaissanceTechnique a owl:Class ;
    rdfs:label "SPARTAReconnaissanceTechnique" ;
    dcterms:title "Reconnaissance Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAReconnaissanceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTATactic a owl:Class ;
    rdfs:label "SPARTATactic" ;
    dcterms:title "SPARTA Tactic" ;
    rdfs:seeAlso <https://sparta.aerospace.org/tactic/SPARTA> ;
    rdfs:subClassOf d3f:SPARTAThing ;
    skos:definition "SPARTA Tactics represent the 'why' of a SPARTA technique. They denote the tactical goal of a threat actor and the reason for performing a technique." ;
    skos:exactMatch d3f:SPARTATactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTATechnique a owl:Class ;
    rdfs:label "SPARTATechnique" ;
    dcterms:title "SPARTA Technique" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/SPARTA> ;
    rdfs:subClassOf d3f:SPARTAThing ;
    skos:definition "SPARTA Techniques represent 'how' a threat actor achieves a tactical goal by performing a threat action." ;
    skos:exactMatch d3f:SPARTATechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1497 a owl:Class ;
    rdfs:label "T1497" ;
    d3f:attack-id "T1497" ;
    dcterms:title "Virtualization/Sandbox Evasion" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DiscoveryTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may employ various means to detect and avoid virtualization and analysis environments. This may include changing behaviors based on the results of checks for the presence of artifacts indicative of a virtual machine environment (VME) or sandbox. If the adversary detects a VME, they may alter their malware to disengage from the victim or conceal the core functions of the implant. They may also search for VME artifacts before dropping secondary or additional payloads. Adversaries may use the information learned from [Virtualization/Sandbox Evasion](https://attack.mitre.org/techniques/T1497) during automated discovery to shape follow-on behaviors.(Citation: Deloitte Environment Awareness)" ;
    skos:exactMatch d3f:T1497,
        mitre-attack:T1497 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1553 a owl:Class ;
    rdfs:label "T1553" ;
    d3f:attack-id "T1553" ;
    dcterms:title "Subvert Trust Controls" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may undermine security controls that will either warn users of untrusted activity or prevent execution of untrusted programs. Operating systems and security products may contain mechanisms to identify programs or websites as possessing some level of trust. Examples of such features would include a program being allowed to run because it is signed by a valid code signing certificate, a program prompting the user with a warning because it has an attribute set from being downloaded from the Internet, or getting an indication that you are about to connect to an untrusted site." ;
    skos:exactMatch d3f:T1553,
        mitre-attack:T1553 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TechniqueReference a owl:Class ;
    rdfs:label "TechniqueReference" ;
    d3f:pref-label "Technique Reference" ;
    dcterms:title "Technique Reference" ;
    rdfs:subClassOf d3f:D3FENDKBThing ;
    skos:definition "A reference used to develop KB articles." ;
    skos:exactMatch d3f:TechniqueReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:WindowsRegistryKeyEvent a owl:Class ;
    rdfs:label "WindowsRegistryKeyEvent" ;
    dcterms:title "Windows Registry Key Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/win/registry_key_activity>,
        <https://schema.ocsf.io/classes/win/registry_key_activity> ;
    rdfs:subClassOf d3f:WindowsRegistryEvent ;
    skos:definition "Events representing actions performed on Windows Registry keys, such as creation, modification, or deletion, which define hierarchical nodes for storing configuration data." ;
    skos:exactMatch d3f:WindowsRegistryKeyEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASDefenseEvasionTechnique a owl:Class ;
    rdfs:label "ATLASDefenseEvasionTechnique" ;
    dcterms:title "Defense Evasion Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASDefenseEvasionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileDiscoveryTechnique a owl:Class ;
    rdfs:label "ATTACKMobileDiscoveryTechnique" ;
    dcterms:title "Discovery Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileDiscoveryTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE657 a owl:Class ;
    rdfs:label "CWE_657" ;
    d3f:cwe-id "CWE-657" ;
    dcterms:title "Violation of Secure Design Principles" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-657" ;
    skos:definition "The product violates well-established principles for secure design." ;
    skos:exactMatch d3f:CWE-657,
        cwe:CWE-657 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE665 a owl:Class ;
    rdfs:label "CWE_665" ;
    d3f:cwe-id "CWE-665" ;
    dcterms:title "Improper Initialization" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-665" ;
    skos:definition "The product does not initialize or incorrectly initializes a resource, which might leave the resource in an unexpected state when it is accessed or used." ;
    skos:exactMatch d3f:CWE-665,
        cwe:CWE-665 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE667 a owl:Class ;
    rdfs:label "CWE_667" ;
    d3f:cwe-id "CWE-667" ;
    dcterms:title "Improper Locking" ;
    rdfs:subClassOf d3f:CWE662 ;
    skos:altLabel "CWE-667" ;
    skos:definition "The product does not properly acquire or release a lock on a resource, leading to unexpected resource state changes and behaviors." ;
    skos:exactMatch d3f:CWE-667,
        cwe:CWE-667 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE682 a owl:Class ;
    rdfs:label "CWE_682" ;
    d3f:cwe-id "CWE-682" ;
    dcterms:title "Incorrect Calculation" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-682" ;
    skos:definition "The product performs a calculation that generates incorrect or unintended results that are later used in security-critical decisions or resource management." ;
    skos:exactMatch d3f:CWE-682,
        cwe:CWE-682 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE707 a owl:Class ;
    rdfs:label "CWE_707" ;
    d3f:cwe-id "CWE-707" ;
    dcterms:title "Improper Neutralization" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-707" ;
    skos:definition "The product does not ensure or incorrectly ensures that structured messages or data are well-formed and that certain security properties are met before being read from an upstream component or sent to a downstream component." ;
    skos:exactMatch d3f:CWE-707,
        cwe:CWE-707 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EventLogEvent a owl:Class ;
    rdfs:label "EventLogEvent" ;
    dcterms:title "Event Log Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/event_log>,
        <https://schema.ocsf.io/classes/event_log_activity> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event that captures actions or operations related to the management of system event logs, including modifications, access, and service state changes." ;
    skos:exactMatch d3f:EventLogEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OSAPICreateFile a owl:Class ;
    rdfs:label "OSAPICreateFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OS API Create File" ;
    rdfs:subClassOf d3f:OSAPISystemFunction ;
    skos:definition "An OS API function that creates a file." ;
    skos:exactMatch d3f:OSAPICreateFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAExfiltrationTechnique a owl:Class ;
    rdfs:label "SPARTAExfiltrationTechnique" ;
    dcterms:title "Exfiltration Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAExfiltrationTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1213 a owl:Class ;
    rdfs:label "T1213" ;
    d3f:attack-id "T1213" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data from Information Repositories" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may leverage information repositories to mine valuable information. Information repositories are tools that allow for storage of information, typically to facilitate collaboration or information sharing between users, and can store a wide variety of data that may aid adversaries in further objectives, or direct access to the target information. Adversaries may also abuse external sharing features to share sensitive documents with recipients outside of the organization." ;
    skos:exactMatch d3f:T1213,
        mitre-attack:T1213 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1076 a owl:Class ;
    rdfs:label "CWE_1076" ;
    d3f:cwe-id "CWE-1076" ;
    dcterms:title "Insufficient Adherence to Expected Conventions" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1076" ;
    skos:definition "The product's architecture, source code, design, documentation, or other artifact does not follow required conventions." ;
    skos:exactMatch d3f:CWE-1076,
        cwe:CWE-1076 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1078 a owl:Class ;
    rdfs:label "CWE_1078" ;
    d3f:cwe-id "CWE-1078" ;
    dcterms:title "Inappropriate Source Code Style or Formatting" ;
    rdfs:subClassOf d3f:CWE1076 ;
    skos:altLabel "CWE-1078" ;
    skos:definition "The source code does not follow desired style or formatting for indentation, white space, comments, etc." ;
    skos:exactMatch d3f:CWE-1078,
        cwe:CWE-1078 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE119 a owl:Class ;
    rdfs:label "CWE_119" ;
    d3f:cwe-id "CWE-119" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Buffer Overflow" ;
    dcterms:title "Improper Restriction of Operations within the Bounds of a Memory Buffer" ;
    rdfs:subClassOf d3f:CWE118 ;
    skos:altLabel "CWE-119" ;
    skos:definition "The product performs operations on a memory buffer, but it reads from or writes to a memory location outside the buffer's intended boundary. This may result in read or write operations on unexpected memory locations that could be linked to other variables, data structures, or internal program data." ;
    skos:exactMatch d3f:CWE-119,
        cwe:CWE-119 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE200 a owl:Class ;
    rdfs:label "CWE_200" ;
    d3f:cwe-id "CWE-200" ;
    d3f:synonym "Information Disclosure" ;
    dcterms:title "Exposure of Sensitive Information to an Unauthorized Actor" ;
    rdfs:subClassOf d3f:CWE668 ;
    skos:altLabel "CWE-200" ;
    skos:definition "The product exposes sensitive information to an actor that is not explicitly authorized to have access to that information." ;
    skos:exactMatch d3f:CWE-200,
        cwe:CWE-200 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE23 a owl:Class ;
    rdfs:label "CWE_23" ;
    d3f:cwe-id "CWE-23" ;
    d3f:synonym "Zip Slip" ;
    dcterms:title "Relative Path Traversal" ;
    rdfs:subClassOf d3f:CWE22 ;
    skos:altLabel "CWE-23" ;
    skos:definition "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize sequences such as \"..\" that can resolve to a location that is outside of that directory." ;
    skos:exactMatch d3f:CWE-23,
        cwe:CWE-23 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE405 a owl:Class ;
    rdfs:label "CWE_405" ;
    d3f:cwe-id "CWE-405" ;
    dcterms:title "Asymmetric Resource Consumption (Amplification)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CWE664 ],
        d3f:CWE400 ;
    skos:altLabel "CWE-405" ;
    skos:definition "The product does not properly control situations in which an adversary can cause the product to consume or produce excessive resources without requiring the adversary to invest equivalent work or otherwise prove authorization, i.e., the adversary's influence is \"asymmetric.\"" ;
    skos:exactMatch d3f:CWE-405,
        cwe:CWE-405 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE703 a owl:Class ;
    rdfs:label "CWE_703" ;
    d3f:cwe-id "CWE-703" ;
    dcterms:title "Improper Check or Handling of Exceptional Conditions" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-703" ;
    skos:definition "The product does not properly anticipate or handle exceptional conditions that rarely occur during normal operation of the product." ;
    skos:exactMatch d3f:CWE-703,
        cwe:CWE-703 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DE0003 a owl:Class ;
    rdfs:label "DE_0003" ;
    d3f:attack-id "DE-0003" ;
    dcterms:title "On-Board Values Obfuscation" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/DE-0003/> ;
    rdfs:subClassOf d3f:SPARTADefenseEvasionTechnique ;
    skos:altLabel "DE-0003" ;
    skos:definition "Threat actors may target various onboard values put in place to prevent malicious or poorly crafted commands from being processed. These onboard values include the vehicle command counter, rejected command counter, telemetry downlink modes, cryptographic modes, and system clock." ;
    skos:exactMatch d3f:DE-0003,
        mitre-attack:DE-0003 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ReconnaissanceTechnique a owl:Class ;
    rdfs:label "ReconnaissanceTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Reconnaissance Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to gather information they can use to plan future operations." ;
    skos:exactMatch d3f:ReconnaissanceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1205 a owl:Class ;
    rdfs:label "T1205" ;
    d3f:attack-id "T1205" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Traffic Signaling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DefenseEvasionTechnique ],
        d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries use traffic signaling techniques, such as sending specific network sequences or magic packets, to covertly trigger actions like opening ports, activating backdoors, or installing filters, facilitating command and control, persistence, and defense evasion." ;
    skos:exactMatch d3f:T1205,
        mitre-attack:T1205 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserBehaviorAnalysis a owl:Class ;
    rdfs:label "UserBehaviorAnalysis" ;
    d3f:d3fend-id "D3-UBA" ;
    d3f:kb-article "## Technique Overview Some techniques monitor patterns of human behavior and then apply algorithms and to identify patterns such as repeated login attempts from a single IP address or large file downloads, or abnormal accesses. Other techniques may have explicit or rigid definitions of \"bad behavi" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Credential Monitoring" ;
    dcterms:title "User Behavior Analysis" ;
    rdfs:seeAlso dbr:User_behavior_analytics ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "User behavior analytics (\"UBA\") as defined by Gartner, is a cybersecurity process about detection of insider threats, targeted attacks, and financial fraud. UBA solutions look at patterns of human behavior, and then apply algorithms and statistical analysis to detect meaningful anomalies from those patterns-anomalies that indicate potential threats.' Instead of tracking devices or security events, UBA tracks a system's users. Big data platforms are increasing UBA functionality by allowing them to analyze petabytes worth of data to detect insider threats and advanced persistent threats." ;
    skos:exactMatch d3f:UserBehaviorAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:d3fend_catalog_data_property a owl:DatatypeProperty ;
    rdfs:label "d3fend-catalog-data-property" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_data_property ;
    skos:altLabel "d3fend-vendor-registry-data-property" ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASResourceDevelopmentTechnique a owl:Class ;
    rdfs:label "ATLASResourceDevelopmentTechnique" ;
    dcterms:title "Resource Development Technique" ;
    rdfs:subClassOf d3f:ATLASTechnique ;
    skos:exactMatch d3f:ATLASResourceDevelopmentTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSExecutionTechnique a owl:Class ;
    rdfs:label "ATTACKICSExecutionTechnique" ;
    dcterms:title "Execution Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSExecutionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSImpactTechnique a owl:Class ;
    rdfs:label "ATTACKICSImpactTechnique" ;
    dcterms:title "Impact Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSImpactTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSTactic a owl:Class ;
    rdfs:label "ATTACKICSTactic" ;
    dcterms:title "ATTACK ICS Tactic" ;
    rdfs:subClassOf d3f:ATTACKICSThing ;
    skos:exactMatch d3f:ATTACKICSTactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSTechnique a owl:Class ;
    rdfs:label "ATTACKICSTechnique" ;
    dcterms:title "ATTACK ICS Technique" ;
    rdfs:subClassOf d3f:ATTACKICSThing ;
    skos:exactMatch d3f:ATTACKICSTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileCommandAndControlTechnique a owl:Class ;
    rdfs:label "ATTACKMobileCommandAndControlTechnique" ;
    dcterms:title "Command and Control Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileTactic a owl:Class ;
    rdfs:label "ATTACKMobileTactic" ;
    dcterms:title "ATTACK Mobile Tactic" ;
    rdfs:subClassOf d3f:ATTACKMobileThing ;
    skos:exactMatch d3f:ATTACKMobileTactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileTechnique a owl:Class ;
    rdfs:label "ATTACKMobileTechnique" ;
    dcterms:title "ATTACK Mobile Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileThing ;
    skos:exactMatch d3f:ATTACKMobileTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1120 a owl:Class ;
    rdfs:label "CWE_1120" ;
    d3f:cwe-id "CWE-1120" ;
    dcterms:title "Excessive Code Complexity" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-1120" ;
    skos:definition "The code is too complex, as calculated using a well-defined, quantitative measure." ;
    skos:exactMatch d3f:CWE-1120,
        cwe:CWE-1120 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE691 a owl:Class ;
    rdfs:label "CWE_691" ;
    d3f:cwe-id "CWE-691" ;
    dcterms:title "Insufficient Control Flow Management" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-691" ;
    skos:definition "The code does not sufficiently manage its control flow during execution, creating conditions in which the control flow can be modified in unexpected ways." ;
    skos:exactMatch d3f:CWE-691,
        cwe:CWE-691 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE755 a owl:Class ;
    rdfs:label "CWE_755" ;
    d3f:cwe-id "CWE-755" ;
    dcterms:title "Improper Handling of Exceptional Conditions" ;
    rdfs:subClassOf d3f:CWE703 ;
    skos:altLabel "CWE-755" ;
    skos:definition "The product does not handle or incorrectly handles an exceptional condition." ;
    skos:exactMatch d3f:CWE-755,
        cwe:CWE-755 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:EX0012 a owl:Class ;
    rdfs:label "EX_0012" ;
    d3f:attack-id "EX-0012" ;
    dcterms:title "Modify On-Board Values" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/EX-0012/> ;
    rdfs:subClassOf d3f:SPARTAExecutionTechnique ;
    skos:altLabel "EX-0012" ;
    skos:definition "Threat actors may perform specific commands in order to modify onboard values that the victim spacecraft relies on. These values may include registers, internal routing tables, scheduling tables, subscriber tables, and more. Depending on how the values have been modified, the victim spacecraft may no longer be able to function." ;
    skos:exactMatch d3f:EX-0012,
        mitre-attack:EX-0012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTADefenseEvasionTechnique a owl:Class ;
    rdfs:label "SPARTADefenseEvasionTechnique" ;
    dcterms:title "Defense Evasion Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTADefenseEvasionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ServiceApplication a owl:Class ;
    rdfs:label "ServiceApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Service Application" ;
    rdfs:seeAlso dbr:Server_\(computing\),
        dbr:Service_\(systems_architecture\),
        <https://schema.ocsf.io/objects/service> ;
    rdfs:subClassOf d3f:Application ;
    skos:definition "An application that provides a set of software functionalities so that multiple clients who can reuse the functionality, provided they are authorized for use of the service." ;
    skos:exactMatch d3f:ServiceApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Software a owl:Class ;
    rdfs:label "Software" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Software ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:closeMatch spdx:SoftwareArtifact ;
    skos:definition "Computer software, or simply software, is that part of a computer system that consists of encoded information or computer instructions, in contrast to the physical hardware from which the system is built." ;
    skos:exactMatch d3f:Software,
        stix:Software,
        unified_cyber_ontology:Software ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountEvent a owl:Class ;
    rdfs:label "UserAccountEvent" ;
    dcterms:title "User Account Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/account_change>,
        <https://schema.ocsf.io/classes/account_change> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:definition "An event capturing operations or state changes performed on user accounts, including lifecycle management, access control modifications, and policy assignments." ;
    skos:exactMatch d3f:UserAccountEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Weakness a owl:Class ;
    rdfs:label "Weakness" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom d3f:Artifact ;
            owl:onProperty d3f:may_be_weakness_of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty d3f:may_be_weakness_of ],
        d3f:D3FENDCore ;
    skos:definition "A weakness is a condition in a software, firmware, hardware, or service component that, under certain circumstances, could contribute to the introduction of vulnerabilities." ;
    skos:exactMatch d3f:Weakness ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileInitialAccessTechnique a owl:Class ;
    rdfs:label "ATTACKMobileInitialAccessTechnique" ;
    dcterms:title "Initial Access Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileInitialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobilePersistenceTechnique a owl:Class ;
    rdfs:label "ATTACKMobilePersistenceTechnique" ;
    dcterms:title "Persistence Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobilePersistenceTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileEvent a owl:Class ;
    rdfs:label "FileEvent" ;
    dcterms:title "File Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/1.3.0/classes/file_activity>,
        <https://schema.ocsf.io/classes/file_activity> ;
    rdfs:subClassOf d3f:DigitalEvent ;
    skos:broadMatch unified_cyber_ontology:Action ;
    skos:definition "An event involving operations performed on digital files, encompassing actions such as creation, modification, deletion, access, and attribute or permission changes." ;
    skos:exactMatch d3f:FileEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PlatformHardening a owl:Class ;
    rdfs:label "PlatformHardening" ;
    d3f:d3fend-id "D3-PH" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Endpoint Hardening" ;
    dcterms:title "Platform Hardening" ;
    rdfs:subClassOf d3f:DefensiveTechnique,
        d3f:PlatformHardeningEnum,
        linkml:PermissibleValue ;
    skos:definition """Hardening components of a Platform with the intention of making them more difficult to exploit.

Platforms includes components such as:
* BIOS UEFI Subsystems
* Hardware security devices such as Trusted Platform Modules
* Boot process logic or code
* Kernel software components""",
        "Platform Hardening" ;
    skos:editorialNote "Hardening components of a Platform with the intention of making them more difficult to exploit. Platforms includes components such as: * BIOS UEFI Subsystems * Hardware security devices such as Trusted Platform Modules * Boot process logic or code * Kernel software components" ;
    skos:exactMatch d3f:PlatformHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAInitialAccessTechnique a owl:Class ;
    rdfs:label "SPARTAInitialAccessTechnique" ;
    dcterms:title "Initial Access Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAInitialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1059 a owl:Class ;
    rdfs:label "T1059" ;
    d3f:attack-id "T1059" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Command and Scripting Interpreter" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse command and script interpreters to execute commands, scripts, or binaries. These interfaces and languages provide ways of interacting with computer systems and are a common feature across many different platforms. Most systems come with some built-in command-line interface and scripting capabilities, for example, macOS and Linux distributions include some flavor of [Unix Shell](https://attack.mitre.org/techniques/T1059/004) while Windows installations include the [Windows Command Shell](https://attack.mitre.org/techniques/T1059/003) and [PowerShell](https://attack.mitre.org/techniques/T1059/001)." ;
    skos:exactMatch d3f:T1059,
        mitre-attack:T1059 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1078 a owl:Class ;
    rdfs:label "T1078" ;
    d3f:attack-id "T1078" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Valid Accounts" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InitialAccessTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may obtain and abuse credentials of existing accounts as a means of gaining Initial Access, Persistence, Privilege Escalation, or Defense Evasion. Compromised credentials may be used to bypass access controls placed on various resources on systems within the network and may even be used for persistent access to remote systems and externally available services, such as VPNs, Outlook Web Access, network devices, and remote desktop.(Citation: volexity_0day_sophos_FW) Compromised credentials may also grant an adversary increased privilege to specific systems or access to restricted areas of the network. Adversaries may choose not to use malware or tools in conjunction with the legitimate access those credentials provide to make it harder to detect their presence." ;
    skos:exactMatch d3f:T1078,
        mitre-attack:T1078 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1087 a owl:Class ;
    rdfs:label "T1087" ;
    d3f:attack-id "T1087" ;
    dcterms:title "Account Discovery" ;
    rdfs:seeAlso d3f:T1136 ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of valid accounts, usernames, or email addresses on a system or within a compromised environment. This information can help adversaries determine which accounts exist, which can aid in follow-on behavior such as brute-forcing, spear-phishing attacks, or account takeovers (e.g., [Valid Accounts](https://attack.mitre.org/techniques/T1078))." ;
    skos:exactMatch d3f:T1087,
        mitre-attack:T1087 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1136 a owl:Class ;
    rdfs:label "T1136" ;
    d3f:attack-id "T1136" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Create Account" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may create an account to maintain access to victim systems.(Citation: Symantec WastedLocker June 2020) With a sufficient level of access, creating such accounts may be used to establish secondary credentialed access that do not require persistent remote access tools to be deployed on the system." ;
    skos:exactMatch d3f:T1136,
        mitre-attack:T1136 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKEnterpriseTactic a owl:Class ;
    rdfs:label "ATTACKEnterpriseTactic" ;
    dcterms:title "ATTACK Enterprise Tactic" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseThing ;
    skos:exactMatch d3f:ATTACKEnterpriseTactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKEnterpriseTechnique a owl:Class ;
    rdfs:label "ATTACKEnterpriseTechnique" ;
    dcterms:title "ATTACK Enterprise Technique" ;
    rdfs:subClassOf d3f:ATTACKEnterpriseThing ;
    skos:exactMatch d3f:ATTACKEnterpriseTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSCollectionTechnique a owl:Class ;
    rdfs:label "ATTACKICSCollectionTechnique" ;
    dcterms:title "Collection Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSCollectionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSInitialAccessTechnique a owl:Class ;
    rdfs:label "ATTACKICSInitialAccessTechnique" ;
    dcterms:title "Initial Access Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:exactMatch d3f:ATTACKICSInitialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileCredentialAccessTechnique a owl:Class ;
    rdfs:label "ATTACKMobileCredentialAccessTechnique" ;
    dcterms:title "Credential Access Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE345 a owl:Class ;
    rdfs:label "CWE_345" ;
    d3f:cwe-id "CWE-345" ;
    dcterms:title "Insufficient Verification of Data Authenticity" ;
    rdfs:subClassOf d3f:CWE693 ;
    skos:altLabel "CWE-345" ;
    skos:definition "The product does not sufficiently verify the origin or authenticity of data, in a way that causes it to accept invalid data." ;
    skos:exactMatch d3f:CWE-345,
        cwe:CWE-345 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE41 a owl:Class ;
    rdfs:label "CWE_41" ;
    d3f:cwe-id "CWE-41" ;
    dcterms:title "Improper Resolution of Path Equivalence" ;
    rdfs:subClassOf d3f:CWE706 ;
    skos:altLabel "CWE-41" ;
    skos:definition "The product is vulnerable to file system contents disclosure through path equivalence. Path equivalence involves the use of special characters in file and directory names. The associated manipulations are intended to generate multiple names for the same object." ;
    skos:exactMatch d3f:CWE-41,
        cwe:CWE-41 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:D3FENDCore a owl:Class ;
    rdfs:label "D3FENDCore" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "D3FEND Core" ;
    rdfs:subClassOf linkml:ClassDefinition ;
    skos:broadMatch unified_cyber_ontology:UcoThing ;
    skos:exactMatch d3f:D3FENDCore ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkTraffic a owl:Class ;
    rdfs:label "NetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Traffic" ;
    rdfs:seeAlso dbr:Network_traffic,
        <https://schema.ocsf.io/objects/network_traffic> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Data Traffic" ;
    skos:definition "Network traffic or data traffic is the data, or alternatively the amount of data, moving across a network at a given point of time.  Network data in computer networks is mostly encapsulated in network packets, which provide the load in the network." ;
    skos:exactMatch d3f:NetworkTraffic,
        stix:NetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OffensiveTechnique a owl:Class ;
    rdfs:label "OffensiveTechnique" ;
    d3f:display-baseurl "/offensive-technique/attack/" ;
    dcterms:title "Offensive Technique" ;
    rdfs:seeAlso <https://attack.mitre.org/docs/ATTACK_Design_and_Philosophy_March_2020.pdf> ;
    rdfs:subClassOf d3f:CyberTechnique ;
    skos:exactMatch d3f:OffensiveTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1498 a owl:Class ;
    rdfs:label "T1498" ;
    d3f:attack-id "T1498" ;
    dcterms:title "Network Denial of Service" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may perform Network Denial of Service (DoS) attacks to degrade or block the availability of targeted resources to users. Network DoS can be performed by exhausting the network bandwidth services rely on. Example resources include specific websites, email services, DNS, and web-based applications. Adversaries have been observed conducting network DoS attacks for political purposes(Citation: FireEye OpPoisonedHandover February 2016) and to support other malicious activities, including distraction(Citation: FSISAC FraudNetDoS September 2012), hacktivism, and extortion.(Citation: Symantec DDoS October 2014)" ;
    skos:exactMatch d3f:T1498,
        mitre-attack:T1498 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1557 a owl:Class ;
    rdfs:label "T1557" ;
    d3f:attack-id "T1557" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Adversary-in-the-Middle" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CredentialAccessTechnique ],
        d3f:CollectionTechnique ;
    skos:definition "Adversaries may attempt to position themselves between two or more networked devices using an adversary-in-the-middle (AiTM) technique to support follow-on behaviors such as [Network Sniffing](https://attack.mitre.org/techniques/T1040), [Transmitted Data Manipulation](https://attack.mitre.org/techniques/T1565/002), or replay attacks ([Exploitation for Credential Access](https://attack.mitre.org/techniques/T1212)). By abusing features of common networking protocols that can determine the flow of network traffic (e.g. ARP, DNS, LLMNR, etc.), adversaries may force a device to communicate through an adversary controlled system so they can collect information or perform additional actions.(Citation: Rapid7 MiTM Basics)" ;
    skos:exactMatch d3f:T1557,
        mitre-attack:T1557 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKICSInhibitResponseFunctionTechnique a owl:Class ;
    rdfs:label "ATTACKICSInhibitResponseFunctionTechnique" ;
    dcterms:title "Inhibit Response Function Technique" ;
    rdfs:subClassOf d3f:ATTACKICSTechnique ;
    skos:definition "The adversary is trying to prevent your safety, protection, quality assurance, and operator intervention functions from responding to a failure, hazard, or unsafe state." ;
    skos:exactMatch d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalInformation a owl:Class ;
    rdfs:label "DigitalInformation" ;
    dcterms:title "Digital Information" ;
    rdfs:subClassOf d3f:DigitalArtifact ;
    skos:definition "Digital information is a broad category of encoded representations in digital form that convey meaning, instructions, or functionality." ;
    skos:exactMatch d3f:DigitalInformation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Server a owl:Class ;
    rdfs:label "Server" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Server_\(computing\) ;
    rdfs:subClassOf d3f:Host ;
    skos:definition "In computing, a server is a piece of computer hardware or software (computer program) that provides functionality for other programs or devices, called \"clients\". This architecture is called the client-server model. Servers can provide various functionalities, often called \"services\", such as sharing data or resources among multiple clients, or performing computation for a client. A single server can serve multiple clients, and a single client can use multiple servers. A client process may run on the same device or may connect over a network to a server on a different device. Typical servers are database servers, file servers, mail servers, print servers, web servers, game servers, and application servers." ;
    skos:exactMatch d3f:Server,
        unified_cyber_ontology:Server ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1499 a owl:Class ;
    rdfs:label "T1499" ;
    d3f:attack-id "T1499" ;
    dcterms:title "Endpoint Denial of Service" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may perform Endpoint Denial of Service (DoS) attacks to degrade or block the availability of services to users. Endpoint DoS can be performed by exhausting the system resources those services are hosted on or exploiting the system to cause a persistent crash condition. Example services include websites, email services, DNS, and web-based applications. Adversaries have been observed conducting DoS attacks for political purposes(Citation: FireEye OpPoisonedHandover February 2016) and to support other malicious activities, including distraction(Citation: FSISAC FraudNetDoS September 2012), hacktivism, and extortion.(Citation: Symantec DDoS October 2014)" ;
    skos:exactMatch d3f:T1499,
        mitre-attack:T1499 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1567 a owl:Class ;
    rdfs:label "T1567" ;
    d3f:attack-id "T1567" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over Web Service" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may use an existing, legitimate external Web service to exfiltrate data rather than their primary command and control channel. Popular Web services acting as an exfiltration mechanism may give a significant amount of cover due to the likelihood that hosts within a network are already communicating with them prior to compromise. Firewall rules may also already exist to permit traffic to these services." ;
    skos:exactMatch d3f:T1567,
        mitre-attack:T1567 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASTactic a owl:Class ;
    rdfs:label "ATLASTactic" ;
    dcterms:title "ATLAS Tactic" ;
    rdfs:seeAlso atlas:tactics ;
    rdfs:subClassOf d3f:ATLASThing ;
    skos:definition "An ATLAS Tactic is a categorical classification of techniques within the MITRE ATLAS™ framework, representing adversarial goals particular to artificial intelligence systems. It also adapts MITRE ATT&CK® Enterprise Matrix tactics by integrating machine learning concepts, thus capturing the unique motives behind actions in AI-specific operations." ;
    skos:exactMatch d3f:ATLASTactic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATLASTechnique a owl:Class ;
    rdfs:label "ATLASTechnique" ;
    dcterms:title "ATLAS Technique" ;
    rdfs:seeAlso atlas:techniques ;
    rdfs:subClassOf d3f:ATLASThing ;
    skos:definition "An ATLAS Technique is an action conducted by adversaries to accomplish tactical goals within the context of artificial intelligence systems. These techniques articulate both 'how' adversaries execute these actions to reach their objectives and 'what' outcomes are achieved from these maneuvers." ;
    skos:exactMatch d3f:ATLASTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1056 a owl:Class ;
    rdfs:label "T1056" ;
    d3f:attack-id "T1056" ;
    dcterms:title "Input Capture" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:CredentialAccessTechnique ],
        d3f:CollectionTechnique ;
    skos:definition "Adversaries may use methods of capturing user input to obtain credentials or collect information. During normal system usage, users often provide credentials to various different locations, such as login pages/portals or system dialog boxes. Input capture mechanisms may be transparent to the user (e.g. [Credential API Hooking](https://attack.mitre.org/techniques/T1056/004)) or rely on deceiving the user into providing input into what they believe to be a genuine service (e.g. [Web Portal Capture](https://attack.mitre.org/techniques/T1056/003))." ;
    skos:exactMatch d3f:T1056,
        mitre-attack:T1056 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1090 a owl:Class ;
    rdfs:label "T1090" ;
    d3f:attack-id "T1090" ;
    dcterms:title "Proxy" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may use a connection proxy to direct network traffic between systems or act as an intermediary for network communications to a command and control server to avoid direct connections to their infrastructure. Many tools exist that enable traffic redirection through proxies or port redirection, including [HTRAN](https://attack.mitre.org/software/S0040), ZXProxy, and ZXPortMap. (Citation: Trend Micro APT Attack Tools) Adversaries use these types of proxies to manage command and control communications, reduce the number of simultaneous outbound network connections, provide resiliency in the face of connection loss, or to ride over existing trusted communications paths between victims to avoid suspicion. Adversaries may chain together multiple proxies to further disguise the source of malicious traffic." ;
    skos:exactMatch d3f:T1090,
        mitre-attack:T1090 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1560 a owl:Class ;
    rdfs:label "T1560" ;
    d3f:attack-id "T1560" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Archive Collected Data" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "An adversary may compress and/or encrypt data that is collected prior to exfiltration. Compressing the data can help to obfuscate the collected data and minimize the amount of data sent over the network.(Citation: DOJ GRU Indictment Jul 2018) Encryption can be used to hide information that is being exfiltrated from detection or make exfiltration less conspicuous upon inspection by a defender." ;
    skos:exactMatch d3f:T1560,
        mitre-attack:T1560 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkTrafficAnalysis a owl:Class ;
    rdfs:label "NetworkTrafficAnalysis" ;
    d3f:d3fend-id "D3-NTA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Traffic Analysis" ;
    rdfs:subClassOf d3f:DefensiveTechnique ;
    skos:definition "Analyzing intercepted or summarized computer network traffic to detect unauthorized activity." ;
    skos:exactMatch d3f:NetworkTrafficAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ATTACKMobileImpactTechnique a owl:Class ;
    rdfs:label "ATTACKMobileImpactTechnique" ;
    dcterms:title "Impact Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileImpactTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE138 a owl:Class ;
    rdfs:label "CWE_138" ;
    d3f:cwe-id "CWE-138" ;
    dcterms:title "Improper Neutralization of Special Elements" ;
    rdfs:subClassOf d3f:CWE707 ;
    skos:altLabel "CWE-138" ;
    skos:definition "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as control elements or syntactic markers when they are sent to a downstream component." ;
    skos:exactMatch d3f:CWE-138,
        cwe:CWE-138 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:File a owl:Class ;
    rdfs:label "File" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <http://wordnet-rdf.princeton.edu/id/06521201-n> ;
    rdfs:subClassOf d3f:Resource ;
    skos:closeMatch oscal:Resource ;
    skos:definition "A file maintained in computer-readable form." ;
    skos:exactMatch d3f:File,
        spdx:File,
        stix:File,
        unified_cyber_ontology:File ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAExecutionTechnique a owl:Class ;
    rdfs:label "SPARTAExecutionTechnique" ;
    dcterms:title "Execution Technique" ;
    rdfs:subClassOf d3f:SPARTATechnique ;
    skos:exactMatch d3f:SPARTAExecutionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1021 a owl:Class ;
    rdfs:label "T1021" ;
    d3f:attack-id "T1021" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Services" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Adversaries may use [Valid Accounts](https://attack.mitre.org/techniques/T1078) to log into a service that accepts remote connections, such as telnet, SSH, and VNC. The adversary may then perform actions as the logged-on user." ;
    skos:exactMatch d3f:T1021,
        mitre-attack:T1021 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1074 a owl:Class ;
    rdfs:label "T1074" ;
    d3f:attack-id "T1074" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data Staged" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may stage collected data in a central location or directory prior to Exfiltration. Data may be kept in separate files or combined into one file through techniques such as [Archive Collected Data](https://attack.mitre.org/techniques/T1560). Interactive command shells may be used, and common functionality within [cmd](https://attack.mitre.org/software/S0106) and bash may be used to copy data into a staging location.(Citation: PWC Cloud Hopper April 2017)" ;
    skos:exactMatch d3f:T1074,
        mitre-attack:T1074 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1127 a owl:Class ;
    rdfs:label "T1127" ;
    d3f:attack-id "T1127" ;
    dcterms:title "Trusted Developer Utilities Proxy Execution" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may take advantage of trusted developer utilities to proxy execution of malicious payloads. There are many utilities used for software development related tasks that can be used to execute code in various forms to assist in development, debugging, and reverse engineering.(Citation: engima0x3 DNX Bypass)(Citation: engima0x3 RCSI Bypass)(Citation: Exploit Monday WinDbg)(Citation: LOLBAS Tracker) These utilities may often be signed with legitimate certificates that allow them to execute on a system and proxy execution of malicious code through a trusted process that effectively bypasses application control solutions." ;
    skos:exactMatch d3f:T1127,
        mitre-attack:T1127 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1390 a owl:Class ;
    rdfs:label "CWE_1390" ;
    d3f:cwe-id "CWE-1390" ;
    dcterms:title "Weak Authentication" ;
    rdfs:subClassOf d3f:CWE287 ;
    skos:altLabel "CWE-1390" ;
    skos:definition "The product uses an authentication mechanism to restrict access to specific users or identities, but the mechanism does not sufficiently prove that the claimed identity is correct." ;
    skos:exactMatch d3f:CWE-1390,
        cwe:CWE-1390 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE573 a owl:Class ;
    rdfs:label "CWE_573" ;
    d3f:cwe-id "CWE-573" ;
    dcterms:title "Improper Following of Specification by Caller" ;
    rdfs:subClassOf d3f:CWE710 ;
    skos:altLabel "CWE-573" ;
    skos:definition "The product does not follow or incorrectly follows the specifications as required by the implementation language, environment, framework, protocol, or platform." ;
    skos:exactMatch d3f:CWE-573,
        cwe:CWE-573 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserManualReferenceEnum a owl:Class ;
    rdfs:label "UserManualReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-CManualIntegerInitialization_GNU d3f:Reference-CManualPointerArithmetic_GNU d3f:Reference-CiscoASR9000AccessListCommands d3f:Reference-ControlLogix5570and5560Controllers d3f:Reference-DYNAMICBASE_UseAddressSpaceLayoutRandomization_MicrosoftDocs d3f:Reference-DataExecutionPrevention_Microsoft d3f:Reference-FileAndFolderPermissions d3f:Reference-FileIntegrityMonitoringinMicrosoftDefenderforCloud-Microsoft d3f:Reference-GS_BufferSecurityCheck_MicrosoftDocs d3f:Reference-LibreNMSDocsNetworkMapExtension d3f:Reference-LibreNMSDocsOxidizedExtension d3f:Reference-PLX3x-Series-Multi-Protocol-Gateways d3f:Reference-QualysNetworkPassiveSensorGettingStartedGuide d3f:Reference-RegistryKeySecurityAndAccessRights d3f:Reference-SAFESEH_ImageHasSafeExceptionHandlers_MicrosoftDocs d3f:Reference-SNMPNetworkAutoDiscovery d3f:Reference-TechnicalProductGuideTriconSystems d3f:Reference-TivoliApplicationDependencyDiscoverManager7_3_0DependenciesBetweenResources d3f:Reference-Tripwire d3f:Reference-UseDNSPolicyForApplyingFiltersOnDNSQueries ) ;
    skos:definition "Enumeration of UserManualReference values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:Reference-CManualIntegerInitialization_GNU,
        d3f:Reference-CManualPointerArithmetic_GNU,
        d3f:Reference-CiscoASR9000AccessListCommands,
        d3f:Reference-ControlLogix5570and5560Controllers,
        d3f:Reference-DYNAMICBASE_UseAddressSpaceLayoutRandomization_MicrosoftDocs,
        d3f:Reference-DataExecutionPrevention_Microsoft,
        d3f:Reference-FileAndFolderPermissions,
        d3f:Reference-FileIntegrityMonitoringinMicrosoftDefenderforCloud-Microsoft,
        d3f:Reference-GS_BufferSecurityCheck_MicrosoftDocs,
        d3f:Reference-LibreNMSDocsNetworkMapExtension,
        d3f:Reference-LibreNMSDocsOxidizedExtension,
        d3f:Reference-PLX3x-Series-Multi-Protocol-Gateways,
        d3f:Reference-QualysNetworkPassiveSensorGettingStartedGuide,
        d3f:Reference-RegistryKeySecurityAndAccessRights,
        d3f:Reference-SAFESEH_ImageHasSafeExceptionHandlers_MicrosoftDocs,
        d3f:Reference-SNMPNetworkAutoDiscovery,
        d3f:Reference-TechnicalProductGuideTriconSystems,
        d3f:Reference-TivoliApplicationDependencyDiscoverManager7_3_0DependenciesBetweenResources,
        d3f:Reference-Tripwire,
        d3f:Reference-UseDNSPolicyForApplyingFiltersOnDNSQueries .

d3f:T1543 a owl:Class ;
    rdfs:label "T1543" ;
    d3f:attack-id "T1543" ;
    dcterms:title "Create or Modify System Process" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may create or modify system-level processes to repeatedly execute malicious payloads as part of persistence. When operating systems boot up, they can start processes that perform background system functions. On Windows and Linux, these system processes are referred to as services.(Citation: TechNet Services) On macOS, launchd processes known as [Launch Daemon](https://attack.mitre.org/techniques/T1543/004) and [Launch Agent](https://attack.mitre.org/techniques/T1543/001) are run to finish system initialization and load user specific parameters.(Citation: AppleDocs Launch Agent Daemons)" ;
    skos:exactMatch d3f:T1543,
        mitre-attack:T1543 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DigitalEvent a owl:Class ;
    rdfs:label "DigitalEvent" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Digital Event" ;
    rdfs:subClassOf d3f:Event ;
    skos:closeMatch unified_cyber_ontology:Action ;
    skos:definition "A digital event represents an observable occurrence, action, or state change within digital systems, networks, or their interactions. These events are characterized by their impact on the confidentiality, integrity, availability, or functionality of digital resources, processes, identities, or communications. Digital events are essential units of information in cybersecurity, serving as the basis for detecting threats, analyzing anomalies, and orchestrating responses in complex, interconnected environments." ;
    skos:exactMatch d3f:DigitalEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1555 a owl:Class ;
    rdfs:label "T1555" ;
    d3f:attack-id "T1555" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credentials from Password Stores" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may search for common password storage locations to obtain user credentials.(Citation: F-Secure The Dukes) Passwords are stored in several places on a system, depending on the operating system or application holding the credentials. There are also specific applications and services that store passwords to make them easier for users to manage and maintain, such as password managers and cloud secrets vaults. Once credentials are obtained, they can be used to perform lateral movement and access restricted information." ;
    skos:exactMatch d3f:T1555,
        mitre-attack:T1555 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AcademicPaperReferenceEnum a owl:Class ;
    rdfs:label "AcademicPaperReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-ARadiationHardenedSARADCWithDelayBasedDualFeedbackFlipFlopsForSensorReadoutSystems d3f:Reference-AnalysisOfTheWindowsVistaSecurityModel_SymantecCorporation d3f:Reference-CarvingContiguousandFragmentedFilesWithFastObjectValidation <http://d3fend.mitre.org/ontologies/d3fend.owl#Reference-ContinuousAuthenticationByAnalysisOfKeyboardTypingCharacteristics_BradfordUniv.,UK> d3f:Reference-DaggerModelingAndVisualizationForMissionImpactSituationalAwareness d3f:Reference-DeadCodeElimination d3f:Reference-DetectingDDoSAttackUsingSnort d3f:Reference-DiagnosisOfFaultsInducedByRadiationAndCircuitLevelDesignMitigationTechniques d3f:Reference-EnhancingNetworkSecurityByPreventingUser-InitiatedMalwareExecution_ d3f:Reference-FirmwareBehaviorAnalysisConFirm d3f:Reference-FirmwareBehaviorAnalysisVIPER d3f:Reference-FirmwareEmbeddedMonitoringCodeSymbiotes d3f:Reference-GatheringEvidenceModel-DrivenSoftwareEngineeringinAutomatedDigitalForensics d3f:Reference-IndirectBranchingCalls d3f:Reference-MissionDependencyModelingForCyberSituationalAwareness d3f:Reference-NearMemoryInMemoryDetectionofFilelessMalware d3f:Reference-Network-BasedBufferOverflowDetectionByExploitCodeAnalysis_InformationSecurityResearchCentre d3f:Reference-Network-levelPolymorphicShellcodeDetectionUsingEmulation d3f:Reference-PredictingDomainGenerationAlgorithmsWithLongShort-TermMemoryNetworks_ <d3f:Reference-Remembranceofdatapassed:Astudyofdisksanitizationpractices> d3f:Reference-RemotelyTriggeredBlackHoleFiltering-Cisco d3f:Reference-Testing_Metrics_for_Password_Creation_Policies_by_Attacking_Large_Sets_of_Revealed_Passwords d3f:Reference-UnderstandingtheDomainRegistrationBehaviorofSpammers ) ;
    skos:definition "Enumeration of AcademicPaperReference values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values <d3f:Reference-Remembranceofdatapassed:Astudyofdisksanitizationpractices>,
        d3f:Reference-ARadiationHardenedSARADCWithDelayBasedDualFeedbackFlipFlopsForSensorReadoutSystems,
        d3f:Reference-AnalysisOfTheWindowsVistaSecurityModel_SymantecCorporation,
        d3f:Reference-CarvingContiguousandFragmentedFilesWithFastObjectValidation,
        <http://d3fend.mitre.org/ontologies/d3fend.owl#Reference-ContinuousAuthenticationByAnalysisOfKeyboardTypingCharacteristics_BradfordUniv.,UK>,
        d3f:Reference-DaggerModelingAndVisualizationForMissionImpactSituationalAwareness,
        d3f:Reference-DeadCodeElimination,
        d3f:Reference-DetectingDDoSAttackUsingSnort,
        d3f:Reference-DiagnosisOfFaultsInducedByRadiationAndCircuitLevelDesignMitigationTechniques,
        d3f:Reference-EnhancingNetworkSecurityByPreventingUser-InitiatedMalwareExecution_,
        d3f:Reference-FirmwareBehaviorAnalysisConFirm,
        d3f:Reference-FirmwareBehaviorAnalysisVIPER,
        d3f:Reference-FirmwareEmbeddedMonitoringCodeSymbiotes,
        d3f:Reference-GatheringEvidenceModel-DrivenSoftwareEngineeringinAutomatedDigitalForensics,
        d3f:Reference-IndirectBranchingCalls,
        d3f:Reference-MissionDependencyModelingForCyberSituationalAwareness,
        d3f:Reference-NearMemoryInMemoryDetectionofFilelessMalware,
        d3f:Reference-Network-BasedBufferOverflowDetectionByExploitCodeAnalysis_InformationSecurityResearchCentre,
        d3f:Reference-Network-levelPolymorphicShellcodeDetectionUsingEmulation,
        d3f:Reference-PredictingDomainGenerationAlgorithmsWithLongShort-TermMemoryNetworks_,
        d3f:Reference-RemotelyTriggeredBlackHoleFiltering-Cisco,
        d3f:Reference-Testing_Metrics_for_Password_Creation_Policies_by_Attacking_Large_Sets_of_Revealed_Passwords,
        d3f:Reference-UnderstandingtheDomainRegistrationBehaviorofSpammers .

d3f:ATTACKMobileCollectionTechnique a owl:Class ;
    rdfs:label "ATTACKMobileCollectionTechnique" ;
    dcterms:title "Collection Technique" ;
    rdfs:subClassOf d3f:ATTACKMobileTechnique ;
    skos:exactMatch d3f:ATTACKMobileCollectionTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Subroutine a owl:Class ;
    rdfs:label "Subroutine" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Method" ;
    rdfs:seeAlso dbr:Subroutine ;
    rdfs:subClassOf d3f:Software ;
    skos:definition "In different programming languages, a subroutine may be called a procedure, a function, a routine, a method, or a subprogram. The generic term callable unit is sometimes used." ;
    skos:exactMatch d3f:Subroutine ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1542 a owl:Class ;
    rdfs:label "T1542" ;
    d3f:attack-id "T1542" ;
    dcterms:title "Pre-OS Boot" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may abuse Pre-OS Boot mechanisms as a way to establish persistence on a system. During the booting process of a computer, firmware and various startup services are loaded before the operating system. These programs control flow of execution before the operating system takes control.(Citation: Wikipedia Booting)" ;
    skos:exactMatch d3f:T1542,
        mitre-attack:T1542 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1556 a owl:Class ;
    rdfs:label "T1556" ;
    d3f:attack-id "T1556" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Modify Authentication Process" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DefenseEvasionTechnique ],
        d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may modify authentication mechanisms and processes to access user credentials or enable otherwise unwarranted access to accounts. The authentication process is handled by mechanisms, such as the Local Security Authentication Server (LSASS) process and the Security Accounts Manager (SAM) on Windows, pluggable authentication modules (PAM) on Unix-based systems, and authorization plugins on MacOS systems, responsible for gathering, storing, and validating credentials. By modifying an authentication process, an adversary may be able to authenticate to a service or system without using [Valid Accounts](https://attack.mitre.org/techniques/T1078)." ;
    skos:exactMatch d3f:T1556,
        mitre-attack:T1556 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1550 a owl:Class ;
    rdfs:label "T1550" ;
    d3f:attack-id "T1550" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Use Alternate Authentication Material" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may use alternate authentication material, such as password hashes, Kerberos tickets, and application access tokens, in order to move laterally within an environment and bypass normal system access controls." ;
    skos:exactMatch d3f:T1550,
        mitre-attack:T1550 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1037 a owl:Class ;
    rdfs:label "T1037" ;
    d3f:attack-id "T1037" ;
    dcterms:title "Boot or Logon Initialization Scripts" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may use scripts automatically executed at boot or logon initialization to establish persistence.(Citation: Mandiant APT29 Eye Spy Email Nov 22)(Citation: Anomali Rocke March 2019) Initialization scripts can be used to perform administrative functions, which may often execute other programs or send information to an internal logging server. These scripts can vary based on operating system and whether applied locally or remotely." ;
    skos:exactMatch d3f:T1037,
        mitre-attack:T1037 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:may_be_associated_with a owl:DatatypeProperty ;
    rdfs:label "may-be-associated-with" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf d3f:d3fend_object_property ;
    skos:definition "x may-be-associated-with y: The subject x and object y may be associated in some way." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1048 a owl:Class ;
    rdfs:label "T1048" ;
    d3f:attack-id "T1048" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over Alternative Protocol" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may steal data by exfiltrating it over a different protocol than that of the existing command and control channel. The data may also be sent to an alternate network location from the main command and control server." ;
    skos:exactMatch d3f:T1048,
        mitre-attack:T1048 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1070 a owl:Class ;
    rdfs:label "T1070" ;
    d3f:attack-id "T1070" ;
    dcterms:title "Indicator Removal" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may delete or modify artifacts generated within systems to remove evidence of their presence or hinder defenses. Various artifacts may be created by an adversary or something that can be attributed to an adversary’s actions. Typically these artifacts are used as defensive indicators related to monitored events, such as strings from downloaded files, logs that are generated from user actions, and other data analyzed by defenders. Location, format, and type of artifact (such as command or login history) are often specific to each platform." ;
    skos:exactMatch d3f:T1070,
        mitre-attack:T1070 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1552 a owl:Class ;
    rdfs:label "T1552" ;
    d3f:attack-id "T1552" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Unsecured Credentials" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may search compromised systems to find and obtain insecurely stored credentials. These credentials can be stored and/or misplaced in many locations on a system, including plaintext files (e.g. [Bash History](https://attack.mitre.org/techniques/T1552/003)), operating system or application-specific repositories (e.g. [Credentials in Registry](https://attack.mitre.org/techniques/T1552/002)),  or other specialized files/artifacts (e.g. [Private Keys](https://attack.mitre.org/techniques/T1552/004)).(Citation: Brining MimiKatz to Unix)" ;
    skos:exactMatch d3f:T1552,
        mitre-attack:T1552 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1558 a owl:Class ;
    rdfs:label "T1558" ;
    d3f:attack-id "T1558" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Steal or Forge Kerberos Tickets" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may attempt to subvert Kerberos authentication by stealing or forging Kerberos tickets to enable [Pass the Ticket](https://attack.mitre.org/techniques/T1550/003). Kerberos is an authentication protocol widely used in modern Windows domain environments. In Kerberos environments, referred to as “realms”, there are three basic participants: client, service, and Key Distribution Center (KDC).(Citation: ADSecurity Kerberos Ring Decoder) Clients request access to a service and through the exchange of Kerberos tickets, originating from KDC, they are granted access after having successfully authenticated. The KDC is responsible for both authentication and ticket granting.  Adversaries may attempt to abuse Kerberos by stealing tickets or forging tickets to enable unauthorized access." ;
    skos:exactMatch d3f:T1558,
        mitre-attack:T1558 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE664 a owl:Class ;
    rdfs:label "CWE_664" ;
    d3f:cwe-id "CWE-664" ;
    dcterms:title "Improper Control of a Resource Through its Lifetime" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-664" ;
    skos:definition "The product does not maintain or incorrectly maintains control over a resource throughout its lifetime of creation, use, and release." ;
    skos:exactMatch d3f:CWE-664,
        cwe:CWE-664 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE693 a owl:Class ;
    rdfs:label "CWE_693" ;
    d3f:cwe-id "CWE-693" ;
    dcterms:title "Protection Mechanism Failure" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-693" ;
    skos:definition "The product does not use or incorrectly uses a protection mechanism that provides sufficient defense against directed attacks against the product." ;
    skos:exactMatch d3f:CWE-693,
        cwe:CWE-693 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:GuidelineReferenceEnum a owl:Class ;
    rdfs:label "GuidelineReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-AuditUserAccountManagement d3f:Reference-CNNSI-4009 d3f:Reference-CybersecurityIncidentandVulnerabilityResponsePlaybooks d3f:Reference-DHS-CCTV-Technology-Handbook d3f:Reference-DigitalIdentityGuidelines800-63-3 d3f:Reference-FederalPublicKeyInfrastructure101 d3f:Reference-GeneralUseOfLocksInTheProtectionAndControlOfFacilitiesRadioActiveMaterialsClassifiedInformationClassifiedMatterAndSafeguardsInformation d3f:Reference-GuideToStorageEncryptionTechnologiesForEndUserDevices d3f:Reference-IntegerRangeValidation_SEI d3f:Reference-LeverageSecurityFrameworksLibraries_OWASP d3f:Reference-NIST-SP-800-53-R5 d3f:Reference-NIST-SP800-116r1 d3f:Reference-NIST-Special-Publication-800-160-Volume-1 d3f:Reference-NIST-Special-Publication-800-37-Revision-2 d3f:Reference-NIST-Special-Publication-800-41-Revision-1 d3f:Reference-NIST-Special-Publication-800-53-Revision-5 d3f:Reference-NIST-Special-Publication-800-53A-Revision-5 d3f:Reference-NISTIR-8011-Volume-1 d3f:Reference-NullPointerChecking_SEI d3f:Reference-PlatformFirmwareResiliencyGuidelines_NIST d3f:Reference-PointerValidationFunction_SEI d3f:Reference-RedHatEnterpriseLinux8SecurityTechnicalImplementationGuide d3f:Reference-S7-1200-Programmable-controller d3f:Reference-SecurePLCCodingPracticesTop20List d3f:Reference-SecuringWebTransactions d3f:Reference-Securing_Web_Transactions__TLS_Server_Certificate_Management_Appendix_A_Passive_Inspection d3f:Reference-SecurityConsiderationsForExchangingFilesOverTheInternet d3f:Reference-Windows10STIG ) ;
    skos:definition "Enumeration of GuidelineReference values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:Reference-AuditUserAccountManagement,
        d3f:Reference-CNNSI-4009,
        d3f:Reference-CybersecurityIncidentandVulnerabilityResponsePlaybooks,
        d3f:Reference-DHS-CCTV-Technology-Handbook,
        d3f:Reference-DigitalIdentityGuidelines800-63-3,
        d3f:Reference-FederalPublicKeyInfrastructure101,
        d3f:Reference-GeneralUseOfLocksInTheProtectionAndControlOfFacilitiesRadioActiveMaterialsClassifiedInformationClassifiedMatterAndSafeguardsInformation,
        d3f:Reference-GuideToStorageEncryptionTechnologiesForEndUserDevices,
        d3f:Reference-IntegerRangeValidation_SEI,
        d3f:Reference-LeverageSecurityFrameworksLibraries_OWASP,
        d3f:Reference-NIST-SP-800-53-R5,
        d3f:Reference-NIST-SP800-116r1,
        d3f:Reference-NIST-Special-Publication-800-160-Volume-1,
        d3f:Reference-NIST-Special-Publication-800-37-Revision-2,
        d3f:Reference-NIST-Special-Publication-800-41-Revision-1,
        d3f:Reference-NIST-Special-Publication-800-53-Revision-5,
        d3f:Reference-NIST-Special-Publication-800-53A-Revision-5,
        d3f:Reference-NISTIR-8011-Volume-1,
        d3f:Reference-NullPointerChecking_SEI,
        d3f:Reference-PlatformFirmwareResiliencyGuidelines_NIST,
        d3f:Reference-PointerValidationFunction_SEI,
        d3f:Reference-RedHatEnterpriseLinux8SecurityTechnicalImplementationGuide,
        d3f:Reference-S7-1200-Programmable-controller,
        d3f:Reference-SecurePLCCodingPracticesTop20List,
        d3f:Reference-SecuringWebTransactions,
        d3f:Reference-Securing_Web_Transactions__TLS_Server_Certificate_Management_Appendix_A_Passive_Inspection,
        d3f:Reference-SecurityConsiderationsForExchangingFilesOverTheInternet,
        d3f:Reference-Windows10STIG .

d3f:ImpactTechnique a owl:Class ;
    rdfs:label "ImpactTechnique" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Impact Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:OffensiveTechnique ],
        d3f:ATTACKEnterpriseTechnique ;
    skos:definition "The adversary is trying to manipulate, interrupt, or destroy your systems and data." ;
    skos:exactMatch d3f:ImpactTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1565 a owl:Class ;
    rdfs:label "T1565" ;
    d3f:attack-id "T1565" ;
    dcterms:title "Data Manipulation" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may insert, delete, or manipulate data in order to influence external outcomes or hide activity, thus threatening the integrity of the data.(Citation: Sygnia Elephant Beetle Jan 2022) By manipulating data, adversaries may attempt to affect a business process, organizational understanding, or decision making." ;
    skos:exactMatch d3f:T1565,
        mitre-attack:T1565 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:HardwareDevice a owl:Class ;
    rdfs:label "HardwareDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hardware Device" ;
    rdfs:seeAlso dbr:Computer_hardware,
        <https://schema.ocsf.io/objects/device_hw_info> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PhysicalArtifact ],
        d3f:DigitalInformationBearer ;
    skos:broadMatch unified_cyber_ontology:Device ;
    skos:definition "Hardware devices are the physical artifacts that constitute a network or computer system. Hardware devices are the physical parts or components of a computer, such as the monitor, keyboard, computer data storage, hard disk drive (HDD), graphic cards, sound cards, memory (RAM), motherboard, and so on, all of which are tangible physical objects. By contrast, software is instructions that can be stored and run by hardware. Hardware is directed by the software to execute any command or instruction. A combination of hardware and software forms a usable computing system." ;
    skos:exactMatch d3f:HardwareDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1573 a owl:Class ;
    rdfs:label "T1573" ;
    d3f:attack-id "T1573" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Encrypted Channel" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:altLabel "Custom Command and Control Protocol",
        "Custom Cryptographic Protocol",
        "Multilayer Encryption" ;
    skos:definition "Adversaries may employ an encryption algorithm to conceal command and control traffic rather than relying on any inherent protections provided by a communication protocol. Despite the use of a secure algorithm, these implementations may be vulnerable to reverse engineering if secret keys are encoded and/or generated within malware samples/configuration files." ;
    skos:exactMatch d3f:T1573,
        mitre-attack:T1573 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE668 a owl:Class ;
    rdfs:label "CWE_668" ;
    d3f:cwe-id "CWE-668" ;
    dcterms:title "Exposure of Resource to Wrong Sphere" ;
    rdfs:subClassOf d3f:CWE664 ;
    skos:altLabel "CWE-668" ;
    skos:definition "The product exposes a resource to the wrong control sphere, providing unintended actors with inappropriate access to the resource." ;
    skos:exactMatch d3f:CWE-668,
        cwe:CWE-668 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1134 a owl:Class ;
    rdfs:label "T1134" ;
    d3f:attack-id "T1134" ;
    dcterms:title "Access Token Manipulation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may modify access tokens to operate under a different user or system security context to perform actions and bypass access controls. Windows uses access tokens to determine the ownership of a running process. A user can manipulate access tokens to make a running process appear as though it is the child of a different process or belongs to someone other than the user that started the process. When this occurs, the process also takes on the security context associated with the new token." ;
    skos:exactMatch d3f:T1134,
        mitre-attack:T1134 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE710 a owl:Class ;
    rdfs:label "CWE_710" ;
    d3f:cwe-id "CWE-710" ;
    dcterms:title "Improper Adherence to Coding Standards" ;
    rdfs:subClassOf d3f:Weakness ;
    skos:altLabel "CWE-710" ;
    skos:definition "The product does not follow certain coding rules for development, which can lead to resultant weaknesses or increase the severity of the associated vulnerabilities." ;
    skos:exactMatch d3f:CWE-710,
        cwe:CWE-710 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DefensiveTechnique a owl:Class ;
    rdfs:label "DefensiveTechnique" ;
    d3f:display-baseurl "/technique/" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Countermeasure Technique" ;
    dcterms:title "Defensive Technique" ;
    rdfs:seeAlso <https://csrc.nist.gov/glossary/term/security_control> ;
    rdfs:subClassOf d3f:CyberTechnique ;
    skos:closeMatch unified_cyber_ontology:DefensiveTool ;
    skos:definition "A method which makes a computer system more difficult to attack." ;
    skos:exactMatch d3f:DefensiveTechnique ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch oscal:Control,
        spdx:Element,
        stix:CourseOfAction .

d3f:SpecificationReferenceEnum a owl:Class ;
    rdfs:label "SpecificationReferenceEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:Reference-DNSWhitelist-DNSWL-EmailAuthenticationMethodExtension d3f:Reference-DomainKeysIdentifiedMail-Signatures-IETF d3f:Reference-FIPS-201-3 d3f:Reference-IEEE-802_1AB-2016 d3f:Reference-IntelControlEnforcementTechnology d3f:Reference-LLVMControlFlowIntegrity d3f:Reference-LUKS1On-DiskFormatSpecificationVersion1.2.3 d3f:Reference-MicrosoftControlFlowGuard d3f:Reference-ONVIF-ProfileS d3f:Reference-PointerAuthenticationOnARMv8.3 d3f:Reference-PsSuspend d3f:Reference-RFC2289-AOne-TimePasswordSystem d3f:Reference-RFC3411-AnArchitectureForDescribingSimpleNetworkManagementProtocolSNMPManagementFrameworks d3f:Reference-RFC7208-SenderPolicyFramework-SPF-ForAuthorizingUseOfDomainsInEmail-IETF d3f:Reference-RFC7489-Domain-basedMessageAuthentication-Reporting-AndConformance-DMARC d3f:Reference-RFC7642SystemForCrossDomainIdentityManagementDefinitionsOverviewConceptsAndRequirements d3f:Reference-RFC8471TheTokenBindingProtocolVersion1.0 d3f:Reference-RevokingaPreviouslyIssuedVerifiableCredential-Microsoft d3f:Reference-SIA-OSDP-2-2 d3f:Reference-SecureMultipurposeInternetMailExtensionsMIME-Version3.1 d3f:Reference-SecurityArchitectureForTheInternetProtocol d3f:Reference-TCGTrustedAttestationProtocolUseCasesForTPMFamilies1.2And2.0AndDICE <http://d3fend.mitre.org/ontologies/d3fend.owl#Reference-TPM2.0LibrarySpecification_TrustedComputingGroup,Incorporated> d3f:Reference-Technical_Specifications_for_Construction_and_Management_of_Sensitive_Compartmented_Information_Facilities d3f:Reference-TrustedAttestationProtocolUseCases d3f:Reference-UEFIPlatformInitialization-Specification d3f:Reference-UnifiedArchitectureFrameworkUAF d3f:Reference-Web-BasedEnterpriseManagement d3f:Reference-WebAuthentication_AnAPIForAccessingPublicKeyCredentialsLevel2 d3f:Reference-Windows-Management-Infrastructure d3f:Reference-Windows-Management-Instrumentation ) ;
    skos:definition "Enumeration of SpecificationReference values. Open set: additional string values beyond this list are permitted." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
