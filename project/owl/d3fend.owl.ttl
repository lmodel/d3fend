    rdfs:subPropertyOf d3f:associated_with ;
    skos:definition "x has-dependent y: The entity x is relied upon or required by entity y." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:limits a owl:DatatypeProperty ;
    rdfs:label "limits" ;
