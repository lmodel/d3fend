        d3f:T1558,
        d3f:T1565,
        d3f:T1566,
        d3f:T1567,
        d3f:T1573 ;
    skos:definition "Monitoring geolocation data of user logon attempts and comparing it to a baseline user behavior profile to identify anomalies in logon location." ;
    skos:exactMatch d3f:UserGeolocationLogonPatternAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
