    skos:exactMatch d3f:DomainAccountMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1078.002,
        mitre-attack:T1087.002,
        mitre-attack:T1098.002,
        mitre-attack:T1098.003,
        mitre-attack:T1136.002 .

d3f:DomainName a owl:Class ;
    rdfs:label "DomainName" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Name" ;
    rdfs:subClassOf d3f:Identifier ;
    skos:definition "A domain name is an identification string that defines a realm of administrative autonomy, authority or control within the Internet. Domain names are formed by the rules and procedures of the Domain Name System (DNS). Any name registered in the DNS is a domain name.Domain names are used in various networking contexts and application-specific naming and addressing purposes. In general, a domain name represents an Internet Protocol (IP) resource, such as a personal computer used to access the Internet, a server computer hosting a web site, or the web site itself or any other service communicated via the Internet. In 2015, 294 million domain names had been registered." ;
    skos:exactMatch d3f:DomainName,
        stix:DomainName,
        unified_cyber_ontology:DomainName ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainNameReputationAnalysis a owl:Class ;
    rdfs:label "DomainNameReputationAnalysis" ;
    d3f:d3fend-id "D3-DNRA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Name Reputation Analysis" ;
    rdfs:subClassOf d3f:IdentifierReputationAnalysis ;
    skos:definition "Analyzing the reputation of a domain name." ;
    skos:exactMatch d3f:DomainNameReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainRegistration a owl:Class ;
    rdfs:label "DomainRegistration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Registration" ;
    rdfs:seeAlso dbr:Domain_registration,
        dbr:WHOIS ;
    rdfs:subClassOf d3f:DigitalInformation ;
    skos:altLabel "Domain Name Registration Data" ;
    skos:definition "A domain registration, or domain name registration data, is the relevant registration data from Internet resources such as domain names, IP addresses, and autonomous system numbers. Registration data is typically retrieved by means of either the Registration Data Access Protocol (RDAP) or its predecessor, the WHOIS protocol." ;
    skos:exactMatch d3f:DomainRegistration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainRegistrationTakedown a owl:Class ;
    rdfs:label "DomainRegistrationTakedown" ;
    d3f:d3fend-id "D3-DRT" ;
    d3f:kb-article "## How it works Most nameserver hosts and domain name registrars comply with internationally recognised standards and supply their services based on terms and conditions that provide users and organisations protection from abuse and trademark infringement. Performing a WHOIS query on the attacker's" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Registration Takedown" ;
    rdfs:subClassOf d3f:ObjectEviction ;
    skos:definition "The process of performing a takedown of the attacker's domain registration infrastructure." ;
    skos:exactMatch d3f:DomainRegistrationTakedown ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DomainTrustPolicy a owl:Class ;
    rdfs:label "DomainTrustPolicy" ;
    d3f:d3fend-id "D3-DTP" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Domain Trust Policy" ;
    rdfs:subClassOf d3f:AccessPolicyAdministration ;
    skos:broadMatch d3f:DiscoveryTechnique ;
    skos:definition "Restricting inter-domain trust by modifying domain configuration." ;
    skos:exactMatch d3f:DomainTrustPolicy ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1033 .

d3f:DriverLoadIntegrityChecking a owl:Class ;
    rdfs:label "DriverLoadIntegrityChecking" ;
    d3f:d3fend-id "D3-DLIC" ;
    d3f:kb-article "## How it works This technique can be accomplished in a number of ways: * A kernel level security agent installed on a host machine ensures that the driver associated with the agent is first in the initialization order. A dependent DLL associated with the driver is configured to be processed before" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Driver Load Integrity Checking" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:definition "Ensuring the integrity of drivers loaded during initialization of the operating system." ;
    skos:exactMatch d3f:DriverLoadIntegrityChecking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:DynamicAnalysis a owl:Class ;
    rdfs:label "DynamicAnalysis" ;
    d3f:d3fend-id "D3-DA" ;
    d3f:kb-article "## How it works Analyzing the interaction of a piece of code with a system while the code is being executed in a controlled environment such as a sandbox, virtual machine, or simulator. This exposes the natural behavior of the piece of code without requiring the code to be disassembled. ## Consider" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Malware Detonation" ;
    dcterms:title "Dynamic Analysis" ;
    rdfs:subClassOf d3f:FileAnalysis ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
