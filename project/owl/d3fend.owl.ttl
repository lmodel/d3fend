d3f:FileContentAnalysis a owl:Class ;
    rdfs:label "FileContentAnalysis" ;
    d3f:d3fend-id "D3-FCOA" ;
    d3f:kb-article "## How it works Analyzing a piece of code without it being executed in a sandbox, virtual machine, or simulator. Patterns or signatures in the file can indicate whati kind of software it is, including whether it is malware." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Content Analysis" ;
    rdfs:subClassOf d3f:FileAnalysis ;
    skos:definition "Employing a pattern matching algorithm to statically analyze the content of files." ;
    skos:exactMatch d3f:FileContentAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileCreationEvent a owl:Class ;
    rdfs:label "FileCreationEvent" ;
    dcterms:title "File Creation Event" ;
    rdfs:subClassOf d3f:FileEvent ;
    skos:definition "An event representing the creation of a new file within the system, establishing its existence and initial attributes in the file system or storage medium." ;
    skos:exactMatch d3f:FileCreationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:FileEviction a owl:Class ;
    rdfs:label "FileEviction" ;
    d3f:d3fend-id "D3-FEV" ;
    d3f:kb-article "## How it works Adversaries may place files or programs into a computer's file system to perform malicious actions. As part of the eviction process, these files and programs should be removed to prevent further compromise or reinfection. Examples of malicious types of files are malware which is dir" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File Eviction" ;
    rdfs:subClassOf d3f:ObjectEviction ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
