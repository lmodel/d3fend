d3f:WindowsWriteProcessMemory a owl:Class ;
    rdfs:label "WindowsWriteProcessMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows WriteProcessMemory" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/memoryapi/nf-memoryapi-writeprocessmemory> ;
    rdfs:subClassOf d3f:OSAPIWriteMemory ;
    skos:definition "Writes data to an area of memory in a specified process. The entire area to be written to must be accessible or the operation fails." ;
    skos:exactMatch d3f:WindowsWriteProcessMemory ;
