d3f:ComputerCase a owl:Class ;
    rdfs:label "ComputerCase" ;
    dcterms:title "Computer Case" ;
    rdfs:subClassOf d3f:ComputerEnclosure ;
    skos:definition "A computer case is a computer enclosure which encloses a single primary computer." ;
    skos:exactMatch d3f:ComputerCase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ComputingServer a owl:Class ;
    rdfs:label "ComputingServer" ;
    dcterms:title "Computing Server" ;
    rdfs:seeAlso <https://www.encyclopedia.com/computing/dictionaries-thesauruses-pictures-and-press-releases/compute-server> ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A compute server is a system specifically designed to undertake large amounts of computation, usually but not necessarily in a client/server environment." ;
    skos:exactMatch d3f:ComputingServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Condition a owl:Class ;
    rdfs:label "Condition" ;
    rdfs:subClassOf d3f:D3FENDCore ;
