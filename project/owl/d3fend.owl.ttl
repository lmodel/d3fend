    dcterms:title "Guideline Reference" ;
    rdfs:subClassOf d3f:PolicyReference ;
    skos:exactMatch d3f:GuidelineReference ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

