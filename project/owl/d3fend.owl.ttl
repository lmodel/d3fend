        d3f:T1564,
        d3f:T1574 ;
    skos:definition "Analyzing changes in service binary files by comparing to a source of truth." ;
    skos:exactMatch d3f:ServiceBinaryVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
