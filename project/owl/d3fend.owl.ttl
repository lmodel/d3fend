    rdfs:seeAlso <https://man7.org/linux/man-pages/man2/ptrace.2.html> ;
    rdfs:subClassOf d3f:OSAPIWriteMemory ;
    skos:definition "Copy the word data to the address addr in the tracee's memory." ;
    skos:exactMatch d3f:LinuxPtraceArgumentPTRACEPOKETEXT ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:LinuxPtraceArgumentPTRACESETREGS a owl:Class ;
