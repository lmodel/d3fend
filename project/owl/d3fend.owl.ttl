    skos:exactMatch d3f:ST0005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ST0006 a owl:Class ;
    rdfs:label "ST0006" ;
    d3f:display-order "6" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Defense Evasion" ;
    rdfs:seeAlso <https://sparta.aerospace.org/tactic/ST0006> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SPARTATactic ],
        d3f:OffensiveTactic,
        d3f:SPARTATacticEnum,
        linkml:PermissibleValue ;
