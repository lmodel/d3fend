        mitre-attack:T1212,
        mitre-attack:T1218.013,
        mitre-attack:T1620 .

d3f:SemiSupervisedTransductiveLearning a owl:Class ;
    rdfs:label "Semi_supervisedTransductiveLearning" ;
    d3f:d3fend-id "D3A-SSTL" ;
    d3f:kb-article "## References Semi-Supervised Learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Semi-Supervised_Learning#Semi-supervised_learning). Zhou, D., & Li, M. (2005). Semi-supervised learning by higher order regularization. In Proceedings of the 43rd Annual Meeting of the Association for Computati" ;
