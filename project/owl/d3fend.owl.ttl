    d3f:d3fend-id "D3A-ARTC" ;
    d3f:kb-article "## References GeeksforGeeks. (n.d.). Adaptive Resonance Theory (ART). [Link](https://www.geeksforgeeks.org/adaptive-resonance-theory-art/)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Adaptive Resonance Theory Clustering" ;
