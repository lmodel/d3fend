    skos:exactMatch d3f:ProcessStartFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessSuspension a owl:Class ;
    rdfs:label "ProcessSuspension" ;
    d3f:d3fend-id "D3-PS" ;
    d3f:kb-article "## How it works A running process might be suspended to mitigate its immediate effects if it is exhibiting anomalous, unauthorized, or malicious behavior. Defenders may choose to suspend rather than terminate to analyze the process first and resume the process if deemed benign. ### System-provided" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Suspension" ;
    rdfs:subClassOf d3f:ProcessEviction ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1505,
        d3f:T1546,
        d3f:T1562 ;
    skos:definition "Suspending a running process on a computer system." ;
    skos:exactMatch d3f:ProcessSuspension ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1033,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1212,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
