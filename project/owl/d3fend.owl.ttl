        d3f:T1136 ;
    skos:definition "The process of temporarily disabling user accounts on a system or domain." ;
    skos:exactMatch d3f:AccountLocking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
