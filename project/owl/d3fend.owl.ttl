    rdfs:label "CWE_1114" ;
    d3f:cwe-id "CWE-1114" ;
    dcterms:title "Inappropriate Whitespace Style" ;
    rdfs:subClassOf d3f:CWE1078 ;
    skos:altLabel "CWE-1114" ;
    skos:definition "The source code contains whitespace that is inconsistent across the code or does not follow expected standards for the product." ;
    skos:exactMatch d3f:CWE-1114,
        cwe:CWE-1114 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

