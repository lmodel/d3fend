d3f:ContainerImageAnalysis a owl:Class ;
    rdfs:label "ContainerImageAnalysis" ;
    d3f:d3fend-id "D3-CIA" ;
    d3f:kb-article "## How it works Container images are standalone collections of the executable code and content that are used to populate a container environment. They are usually created by either building a container from scratch or by building on top of an existing image pulled from a repository. Throughout the" ;
    d3f:owl_named_individual "true" ;
