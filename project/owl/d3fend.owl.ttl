        d3f:T1564,
        d3f:T1565,
        d3f:T1566,
        d3f:T1573,
        d3f:T1574 ;
    skos:definition "Content Filtering techniques aid in the process of analyzing an input file for malicious or erroneous content and outputing a sanitized version." ;
    skos:exactMatch d3f:ContentFiltering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.007,
