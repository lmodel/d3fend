    d3f:owl_named_individual "true" ;
    d3f:synonym "Autoregressive Integrated Moving Average Model" ;
    dcterms:title "ARIMA Model" ;
    rdfs:subClassOf d3f:TimeSeriesAnalysis ;
    skos:definition "An autoregressive integrated moving average (ARIMA) model is a generalization of an autoregressive moving average (ARMA) model." ;
    skos:exactMatch d3f:ARIMAModel ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

