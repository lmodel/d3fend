d3f:DynamicAnalysisTool a owl:Class ;
    rdfs:label "DynamicAnalysisTool" ;
    dcterms:title "Dynamic Analysis Tool" ;
    rdfs:seeAlso dbr:Dynamic_program_analysis ;
    rdfs:subClassOf d3f:CodeAnalyzer ;
