    rdfs:label "ProcessTerminationEvent" ;
    dcterms:title "Process Termination Event" ;
    rdfs:subClassOf d3f:ProcessEvent ;
    skos:definition "An event marking the cessation of a process, including resource deallocation and cleanup, either due to normal completion or abnormal termination." ;
