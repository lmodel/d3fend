d3f:UserAccountUpdateEvent a owl:Class ;
    rdfs:label "UserAccountUpdateEvent" ;
    dcterms:title "User Account Update Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event capturing updates to a user account, including changes to its attributes or configuration." ;
    skos:exactMatch d3f:UserAccountUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserBehavior a owl:Class ;
    rdfs:label "UserBehavior" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Behavior" ;
    rdfs:seeAlso dbr:User_behavior_analytics ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A user behavior is a pattern of user actions, or set of such patterns. Modeling and analyzing these patterns and monitoring a users actions for meaningful anomalies is known as user behavior analytics (UBA)." ;
    skos:exactMatch d3f:UserBehavior ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserDataTransferAnalysis a owl:Class ;
    rdfs:label "UserDataTransferAnalysis" ;
    d3f:d3fend-id "D3-UDTA" ;
    d3f:kb-article "## How it works Unusual data transfer activity may indicate unauthorized activity. Data transfers can be analyzed by collecting network traffic or application logs. ## Considerations * There is a potential for false positives from anomalies that are not associated with unauthorized activity. * Atta" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Data Transfer Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:definition "Analyzing the amount of data transferred by a user." ;
    skos:exactMatch d3f:UserDataTransferAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserGeolocationLogonPatternAnalysis a owl:Class ;
    rdfs:label "UserGeolocationLogonPatternAnalysis" ;
    d3f:d3fend-id "D3-UGLPA" ;
    d3f:kb-article "## How it works Geolocation data for each user logon attempt is collected and used to create a baseline user behavior profile. Current geolocation logon data is then compared against the user behavior profile. Logon activity that deviates from normal patterns and can help in identifying situations t" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "User Geolocation Logon Pattern Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:broadMatch d3f:CollectionTechnique,
        d3f:CommandAndControlTechnique,
        d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:ExfiltrationTechnique,
        d3f:InitialAccessTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:T1003,
        d3f:T1021,
        d3f:T1048,
        d3f:T1071,
