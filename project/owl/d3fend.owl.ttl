    skos:exactMatch d3f:CWE-1123,
        cwe:CWE-1123 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CWE1124 a owl:Class ;
    rdfs:label "CWE_1124" ;
    d3f:cwe-id "CWE-1124" ;
    dcterms:title "Excessively Deep Nesting" ;
    rdfs:subClassOf d3f:CWE1120 ;
