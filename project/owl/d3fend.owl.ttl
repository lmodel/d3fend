d3f:SpectralClustering a owl:Class ;
    rdfs:label "SpectralClustering" ;
    d3f:d3fend-id "D3A-SC" ;
    d3f:kb-article "## References Towards Data Science. (n.d.). Spectral Clustering. [Link](https://towardsdatascience.com/spectral-clustering-aba2640c0d5b)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Spectral Clustering" ;
    rdfs:subClassOf d3f:GraphBasedClustering ;
    skos:definition "Spectral clustering is a technique that identifies communities of nodes in a graph based on the edges connecting them." ;
    skos:exactMatch d3f:SpectralClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StackFrame a owl:Class ;
    rdfs:label "StackFrame" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Stack Frame" ;
    rdfs:seeAlso dbr:Call_stack,
        <http://dbpedia.org/resource/Call_stack#Structure> ;
    rdfs:subClassOf d3f:StackComponent ;
    skos:altLabel "Activation Frame",
        "Activation Record" ;
    skos:definition "A machine-dependent and application-binary-dependent (ABI-dependent) data structure containing subroutine state information including the arguments passed into the routine, the return address back to the routine's caller, and space for local variables of the routine." ;
    skos:exactMatch d3f:StackFrame ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StackFrameCanary a owl:Class ;
    rdfs:label "StackFrameCanary" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Stack Frame Canary" ;
    rdfs:seeAlso <http://dbpedia.org/resource/Stack_buffer_overflow#Stack_canaries> ;
    rdfs:subClassOf d3f:StackComponent ;
    skos:altLabel "Stack Canary" ;
    skos:definition "Stack canaries, named for their analogy to a canary in a coal mine, are used to detect a stack buffer overflow before execution of malicious code can occur. This method works by placing a small integer, the value of which is randomly chosen at program start, in memory just before the stack return pointer. Most buffer overflows overwrite memory from lower to higher memory addresses, so in order to overwrite the return pointer (and thus take control of the process) the canary value must also be overwritten. This value is checked to make sure it has not changed before a routine uses the return pointer on the stack. This technique can greatly increase the difficulty of exploiting a stack buffer overflow because it forces the attacker to gain control of the instruction pointer by some non-traditional means such as corrupting other important variables on the stack." ;
    skos:exactMatch d3f:StackFrameCanary ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StackFrameCanaryValidation a owl:Class ;
    rdfs:label "StackFrameCanaryValidation" ;
    d3f:d3fend-id "D3-SFCV" ;
    d3f:kb-article "## How it works This defense must be applied at compile-time, or via a patch to the program binary. Stack Frame Canary Verification inserts instructions at the prologue and epilogue of desired functions. In the prologue, a canary value, typically with the same size as the register size, is stored" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Stack Frame Canary Validation" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PrivilegeEscalationTechnique ;
    skos:definition "Comparing a value stored in a stack frame with a known good value in order to prevent or detect a memory segment overwrite." ;
    skos:exactMatch d3f:StackFrameCanaryValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1068,
        mitre-attack:T1203,
        mitre-attack:T1210,
        mitre-attack:T1211,
        mitre-attack:T1212 .

d3f:StackSegment a owl:Class ;
    rdfs:label "StackSegment" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Stack Segment" ;
    rdfs:seeAlso dbr:Call_stack,
        <http://dbpedia.org/resource/Data_segment#Stack> ;
    rdfs:subClassOf d3f:ProcessSegment ;
    skos:definition "The stack segment contains the program stack, a last-in-first-out structure, typically allocated in the higher parts of memory for the process." ;
    skos:exactMatch d3f:StackSegment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Stacking a owl:Class ;
    rdfs:label "Stacking" ;
    d3f:d3fend-id "D3A-STA" ;
    d3f:kb-article "## References Ensemble learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Ensemble_learning)." ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:EnsembleLearning ;
    skos:definition "Stacking is a method of using the results and predictions from one layer of ML models as inputs to another layer of ML models. Stacking (sometimes called stacked generalization) involves training a model to combine the predictions of several other learning algorithms." ;
    skos:exactMatch d3f:Stacking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

<http://d3fend.mitre.org/ontologies/d3fend.owl#StageEnum#Unspecified> a owl:Class ;
    rdfs:label "Unspecified" ;
    rdfs:subClassOf d3f:StageEnum,
        linkml:PermissibleValue ;
    skos:definition "Unspecified" .

d3f:StandaloneHoneynet a owl:Class ;
    rdfs:label "StandaloneHoneynet" ;
    d3f:d3fend-id "D3-SHN" ;
    d3f:kb-article "## How it works A standalone honeynet does not directly interact with the real enterprise environment. It may be located near or in some portion of the enterprise address space, but it does not interact with enterprise resources. ## Considerations A standalone honeynet is a lower risk to deploy com" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Standalone Honeynet" ;
    rdfs:subClassOf d3f:DecoyEnvironment ;
    skos:definition "An environment created for the purpose of attracting attackers and eliciting their behaviors that is not connected to any production enterprise systems." ;
    skos:exactMatch d3f:StandaloneHoneynet ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StandardDeviation a owl:Class ;
    rdfs:label "StandardDeviation" ;
    d3f:d3fend-id "D3A-SD" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Standard deviation. [Link](https://en.wikipedia.org/wiki/Standard_deviation)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "SD" ;
    dcterms:title "Standard Deviation" ;
    rdfs:subClassOf d3f:Variability ;
    skos:definition "The standard deviation is a measure of the amount of variation or dispersion of a set of values." ;
    skos:exactMatch d3f:StandardDeviation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StartupDirectory a owl:Class ;
    rdfs:label "StartupDirectory" ;
    dcterms:title "Startup Directory" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LocalResource ],
        d3f:Directory ;
    skos:definition "A startup directory is a directory containing executable files or links to executable files which are run when a user logs in or when a system component or service is started." ;
    skos:exactMatch d3f:StartupDirectory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StorageDeviceEvent a owl:Class ;
    rdfs:label "StorageDeviceEvent" ;
    dcterms:title "Storage Device Event" ;
    rdfs:subClassOf d3f:HardwareDeviceEvent ;
    skos:definition "An event describing the activity, configuration, or errors of storage devices, including physical disks, SSDs, or logical partitions. These events often pertain to data availability, integrity, and storage health." ;
    skos:exactMatch d3f:StorageDeviceEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StoredProcedure a owl:Class ;
    rdfs:label "StoredProcedure" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Stored Procedure" ;
    rdfs:seeAlso dbr:Stored_procedure ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "A stored procedure (also termed proc, storp, sproc, StoPro, StoredProc, StoreProc, sp, or SP) is a subroutine available to applications that access a relational database management system (RDBMS). Such procedures are stored in the database data dictionary." ;
    skos:exactMatch d3f:StoredProcedure ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StringEquivalenceMatching a owl:Class ;
    rdfs:label "StringEquivalenceMatching" ;
    d3f:d3fend-id "D3A-SEM" ;
    d3f:kb-article "## References 1. String-searching algorithm. (2023, April 8). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/String-searching_algorithm) 2. Types of Equality. (2007, March 2). In _WikiWikiWeb_. [Link](https://wiki.c2.com/?TypesOfEquality)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "String Equivalence Matching" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:StringPatternMatching ],
        d3f:EquivalenceMatching ;
    skos:definition "String equivalence matching is a type of string pattern matching which is exact; that is, the strings being compared must have the same value for each character in their sequence and be of the same length." ;
    skos:exactMatch d3f:StringEquivalenceMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StringFormatFunction a owl:Class ;
    rdfs:label "StringFormatFunction" ;
    dcterms:title "String Format Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "A function which creates a new string based on a format specification and correspondingi specified values." ;
    skos:exactMatch d3f:StringFormatFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:StyleGAN a owl:Class ;
    rdfs:label "StyleGAN" ;
    d3f:d3fend-id "D3A-STY" ;
    d3f:kb-article "## References Wikipedia. (n.d.). StyleGAN. [Link](https://en.wikipedia.org/wiki/StyleGAN)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Style GAN" ;
    rdfs:subClassOf d3f:ImageSynthesisGAN ;
    skos:definition "Successor to the ProGAN." ;
    skos:exactMatch d3f:StyleGAN ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SubspaceClustering a owl:Class ;
    rdfs:label "SubspaceClustering" ;
    d3f:d3fend-id "D3A-SC" ;
    d3f:kb-article "## References Parsons, L., Haque, E., & Liu, H. (2004). Subspace Clustering for High Dimensional Data: A Review. [Link](https://www.kdd.org/exploration_files/parsons.pdf)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Subspace Clustering" ;
    rdfs:subClassOf d3f:CorrelationClustering ;
    skos:definition "Subspace clustering is an extension of traditional clustering that seeks to find clusters in different subspaces within a dataset." ;
    skos:exactMatch d3f:SubspaceClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SubstringMatching a owl:Class ;
    rdfs:label "SubstringMatching" ;
    d3f:d3fend-id "D3A-SM" ;
    d3f:kb-article "## References 1. String-searching algorithm. (2023, April 8). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/String-searching_algorithm)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Substring Matching" ;
    rdfs:subClassOf d3f:PartialMatching ;
    skos:definition "String-searching algorithms, sometimes called string-matching algorithms, are an important class of string algorithms that try to find a place where one or several strings (also called patterns) are found within a larger string or text." ;
    skos:exactMatch d3f:SubstringMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SupplyChainAttacker a owl:Class ;
    rdfs:label "SupplyChainAttacker" ;
    dcterms:title "Supply Chain Attacker" ;
    rdfs:subClassOf d3f:Attacker ;
    skos:definition "An attacker who exploits vulnerabilities in the supply chain to compromise systems or data." ;
    skos:exactMatch d3f:SupplyChainAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SupportVectorMachineClassification a owl:Class ;
    rdfs:label "SupportVectorMachineClassification" ;
    d3f:d3fend-id "D3A-SVMC" ;
    d3f:kb-article "## References About Support Vector Machine (SVM). IBM SPSS Modeler SaaS Documentation. [Link](https://www.ibm.com/docs/en/spss-modeler/saas?topic=models-about-svm&mhsrc=ibmsearch_a&mhq=support%20vector%20machine)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Support Vector Machine Classification" ;
    rdfs:subClassOf d3f:Classification ;
    skos:definition "Support Vector Machine (SVM) is a robust classification and regression technique that maximizes the predictive accuracy of a model without overfitting the training data. SVM is particularly suited to analyzing data with very large numbers (for example, thousands) of predictor fields." ;
    skos:exactMatch d3f:SupportVectorMachineClassification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SuspendProcess a owl:Class ;
    rdfs:label "SuspendProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Suspend Process" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:SuspendProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SuspendThread a owl:Class ;
    rdfs:label "SuspendThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Suspend Thread" ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-suspendthread> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "Suspending a thread causes the thread to stop executing user-mode code." ;
    skos:exactMatch d3f:SuspendThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Switch a owl:Class ;
    rdfs:label "Switch" ;
    rdfs:seeAlso dbr:Network_switch ;
    rdfs:subClassOf d3f:ComputerNetworkNode ;
    skos:altLabel "Bridging Hub",
        "MAC Bridge",
        "Network Switch",
        "Switching Hub" ;
    skos:definition "A network switch (also called switching hub, bridging hub, and by the IEEE MAC bridge) is networking hardware that connects devices on a computer network by using packet switching to receive and forward data to the destination device. A network switch is a multiport network bridge that uses MAC addresses to forward data at the data link layer (layer 2) of the OSI model. Some switches can also forward data at the network layer (layer 3) by additionally incorporating routing functionality. Such switches are commonly known as layer-3 switches or multilayer switches." ;
    skos:exactMatch d3f:Switch ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SymmetricKey a owl:Class ;
    rdfs:label "SymmetricKey" ;
    dcterms:title "Symmetric Key" ;
    rdfs:seeAlso dbr:Symmetric-key_algorithm ;
    rdfs:subClassOf d3f:CryptographicKey ;
    skos:definition "A symmetric key is a single key used for both encryption and decryption and used with a symmetric-key algorithm. Symmetric-key algorithms are algorithms for cryptography that use the same cryptographic keys for both encryption of plaintext and decryption of ciphertext. The keys may be identical or there may be a simple transformation to go between the two keys. The keys, in practice, represent a shared secret between two or more parties that can be used to maintain a private information link. This requirement that both parties have access to the secret key is one of the main drawbacks of symmetric key encryption, in comparison to public-key encrytption (also known as asymmetric key encryption)." ;
    skos:exactMatch d3f:SymmetricKey ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemApplicationCycleCount a owl:Class ;
    rdfs:label "SystemApplicationCycleCount" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Controller Cycle Count" ;
    dcterms:title "System Application Cycle Count" ;
    rdfs:subClassOf d3f:SystemPlatformVariable ;
    skos:definition "A system variable that tracks the number of times the controller has completed its main program loop (scan cycle) since startup or last reset." ;
    skos:exactMatch d3f:SystemApplicationCycleCount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "In most controllers this is not a default tag rather something that should be programmed." .

d3f:SystemCallEvent a owl:Class ;
    rdfs:label "SystemCallEvent" ;
    dcterms:title "System Call Event" ;
    rdfs:subClassOf d3f:KernelEvent ;
    skos:definition "An event where a user-space process requests a service or resource from the operating system kernel through a system call interface, enabling controlled interactions with hardware or kernel-level operations." ;
    skos:exactMatch d3f:SystemCallEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemClockUpdateEvent a owl:Class ;
    rdfs:label "SystemClockUpdateEvent" ;
    dcterms:title "System Clock Update Event" ;
    rdfs:subClassOf d3f:SoftwareClockEvent ;
    skos:definition "An event in which the operating system's primary timekeeping value is modified or synchronized." ;
    skos:exactMatch d3f:SystemClockUpdateEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemConfigurationInitDatabaseRecord a owl:Class ;
    rdfs:label "SystemConfigurationInitDatabaseRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Configuration Init Database Record" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SystemConfigurationInitResource ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SystemInitConfiguration ],
        d3f:SystemConfigurationDatabaseRecord ;
    skos:altLabel "System Configuration Startup Database Record" ;
    skos:definition "A database record holding information used to configure the services, parameters, and initial settings for an operating system at startup." ;
    skos:exactMatch d3f:SystemConfigurationInitDatabaseRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemConfigurationPermissions a owl:Class ;
    rdfs:label "SystemConfigurationPermissions" ;
    d3f:d3fend-id "D3-SCP" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Configuration Permissions" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:PersistenceTechnique,
        d3f:T1137,
        d3f:T1218,
        d3f:T1543,
        d3f:T1546,
        d3f:T1548,
        d3f:T1552,
        d3f:T1564,
        d3f:T1614 ;
    skos:definition "Restricting system configuration modifications to a specific user or group of users." ;
    skos:exactMatch d3f:SystemConfigurationPermissions ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1012,
        mitre-attack:T1112,
        mitre-attack:T1137.006,
        mitre-attack:T1207,
        mitre-attack:T1218.014,
        mitre-attack:T1543.003,
        mitre-attack:T1546.012,
        mitre-attack:T1546.015,
        mitre-attack:T1548.004,
        mitre-attack:T1552.002,
        mitre-attack:T1564.003,
        mitre-attack:T1564.005,
        mitre-attack:T1614.001 .

d3f:SystemDaemonMonitoring a owl:Class ;
    rdfs:label "SystemDaemonMonitoring" ;
    d3f:d3fend-id "D3-SDM" ;
    d3f:kb-article "## How it works Attackers may manipulate system settings or services to disable system logging or monitoring of security tools and events. Firewall and antivirus services are popular targets for attackers. Disabling system logs will also allow an attacker's actions to go unnoticed. Analysis of logs," ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Daemon Monitoring" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:broadMatch d3f:ExecutionTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1053,
        d3f:T1562 ;
    skos:definition "Tracking changes to the state or configuration of critical system level processes." ;
    skos:exactMatch d3f:SystemDaemonMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1562.001 .

d3f:SystemDependency a owl:Class ;
    rdfs:label "SystemDependency" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Dependency" ;
    rdfs:seeAlso <https://dl.acm.org/doi/10.1145/960116.53994>,
        <https://r-docs.synapse.org/articles/systemDependencies.html>,
        <https://www.ibm.com/docs/en/taddm/7.3.0?topic=model-dependencies-between-resources> ;
    rdfs:subClassOf d3f:Dependency ;
    skos:definition "A system dependency indicates a system has an activity, agent, or another system which relies on it in order to be functional." ;
    skos:exactMatch d3f:SystemDependency ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemDependencyMapping a owl:Class ;
    rdfs:label "SystemDependencyMapping" ;
    d3f:d3fend-id "D3-SYSDM" ;
    d3f:kb-article "## How it works The organization collects and models architectural information about the software, hardware, and products and maps the dependencies between systems, including each system's internal components and dependencies. ## Considerations * Data exchanges identified in the network mapping eff" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Dependency Mapping" ;
    rdfs:subClassOf d3f:SystemMapping ;
    skos:definition "System dependency mapping identifies and models the dependencies of system components on each other to carry out their function." ;
    skos:exactMatch d3f:SystemDependencyMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemFirewallConfiguration a owl:Class ;
    rdfs:label "SystemFirewallConfiguration" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Firewall Configuration" ;
    rdfs:seeAlso dbr:Firewall_\(computing\) ;
    rdfs:subClassOf d3f:OperatingSystemConfigurationComponent ;
    skos:definition "The configuration for a individual host operating system's firewall." ;
    skos:exactMatch d3f:SystemFirewallConfiguration ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemFirmware a owl:Class ;
    rdfs:label "SystemFirmware" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Firmware" ;
    rdfs:subClassOf d3f:Firmware ;
    skos:altLabel "BIOS Firmware",
        "UEFI Firmware" ;
    skos:definition "Firmware that is installed on a computer's main board which manages the initial boot process. It can also continue to run or function after the operating system boots." ;
    skos:exactMatch d3f:SystemFirmware ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemFirmwareVerification a owl:Class ;
    rdfs:label "SystemFirmwareVerification" ;
    d3f:d3fend-id "D3-SFV" ;
    d3f:kb-article "## How it works Cryptographic hash values are computed for system firmware. The hash values are compared against precomputed firmware hash values to determine if the firmware has been tampered with. When system firmware verification fails a set of predefined responses is typically invoked. The resp" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Firmware Verification" ;
    rdfs:subClassOf d3f:FirmwareVerification ;
    skos:broadMatch d3f:T1542 ;
    skos:definition "Cryptographically verifying installed system firmware integrity." ;
    skos:exactMatch d3f:SystemFirmwareVerification ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1542.001,
        mitre-attack:T1542.004 .

d3f:SystemInitConfigAnalysis a owl:Class ;
    rdfs:label "SystemInitConfigAnalysis" ;
    d3f:d3fend-id "D3-SICA" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Autorun Analysis" ;
    dcterms:title "System Init Config Analysis" ;
    rdfs:subClassOf d3f:OperatingSystemMonitoring ;
    skos:altLabel "System Initialization Configuration Analysis" ;
    skos:broadMatch d3f:T1037,
        d3f:T1547,
        d3f:T1562,
        d3f:T1574 ;
    skos:definition "Analysis of any system process startup configuration." ;
    skos:exactMatch d3f:SystemInitConfigAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1037.004,
        mitre-attack:T1037.005,
        mitre-attack:T1547.001,
        mitre-attack:T1562.009,
        mitre-attack:T1574.011 .

d3f:SystemInitProcess a owl:Class ;
    rdfs:label "SystemInitProcess" ;
    dcterms:title "System Init Process" ;
    rdfs:seeAlso dbr:Booting,
        dbr:Linux_startup_process,
        dbr:Windows_startup_process ;
    rdfs:subClassOf d3f:OperatingSystemProcess ;
    skos:altLabel "System Initialization Process",
        "System Startup Process" ;
    skos:definition "A system initialization process is a process that executes to initialize (boot) an operating system." ;
    skos:exactMatch d3f:SystemInitProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemInitScript a owl:Class ;
    rdfs:label "SystemInitScript" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Init Script" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SystemConfigurationInitResource ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SystemInitConfiguration ],
        d3f:ExecutableScript ;
    skos:definition "A script used to initialize and configure elements of the system's environment, applications, services, or its operating system." ;
    skos:exactMatch d3f:SystemInitScript ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemPasswordDatabase a owl:Class ;
    rdfs:label "SystemPasswordDatabase" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Password Database" ;
    rdfs:subClassOf d3f:PasswordDatabase ;
    skos:definition "A password database used by a system service or process to authenticate users (e.g., Security Account Manager)" ;
    skos:exactMatch d3f:SystemPasswordDatabase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemStartupDirectory a owl:Class ;
    rdfs:label "SystemStartupDirectory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Startup Directory" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SystemInitConfiguration ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SystemConfigurationInitResource ],
        d3f:Directory ;
    skos:definition "A system startup directory is a directory containing executable files or links to executable files which are run when the system starts." ;
    skos:exactMatch d3f:SystemStartupDirectory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemStateImage a owl:Class ;
    rdfs:label "SystemStateImage" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System State Image" ;
    rdfs:seeAlso <https://dbpedia.org/resource/System_Image>,
        <https://en.wikipedia.org/wiki/System_image> ;
    rdfs:subClassOf d3f:StorageImage ;
    skos:altLabel "System Image" ;
    skos:definition "In computing, a system image is a serialized copy of the entire state of a computer system stored in some non-volatile form, such as a binary executable file." ;
    skos:exactMatch d3f:SystemStateImage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemTime a owl:Class ;
    rdfs:label "SystemTime" ;
    dcterms:title "System Time" ;
    rdfs:seeAlso dbr:System_time ;
    rdfs:subClassOf d3f:SystemPlatformVariable ;
    skos:definition "In computing, system time represents a computer system's notion of a point in time." ;
    skos:exactMatch d3f:SystemTime ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemTimeApplication a owl:Class ;
    rdfs:label "SystemTimeApplication" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Time Application" ;
    rdfs:subClassOf d3f:UtilitySoftware ;
    skos:definition "A system time utility is utility software that can get the system time, such as the Unix date command or Windows' Net utility." ;
    skos:exactMatch d3f:SystemTimeApplication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemUtilizationRecord a owl:Class ;
    rdfs:label "SystemUtilizationRecord" ;
    dcterms:title "System Utilization Record" ;
    rdfs:subClassOf d3f:Record ;
    skos:definition "A system utilization record is a record for the tracking of resource utilization e.g. CPU, Disk, Network, Memory Bandwidth, GPU, or other resources for a given time period." ;
    skos:exactMatch d3f:SystemUtilizationRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SystemVulnerabilityAssessment a owl:Class ;
    rdfs:label "SystemVulnerabilityAssessment" ;
    d3f:d3fend-id "D3-SYSVA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Vulnerability Assessment" ;
    rdfs:subClassOf d3f:SystemMapping ;
    skos:broadMatch d3f:T1562 ;
    skos:definition "System vulnerability assessment relates all the vulnerabilities of a system's components in the context of their configuration and internal dependencies and can also include assessing risk emerging from the system's design as a whole, not just the sum of individual component vulnerabilities." ;
    skos:exactMatch d3f:SystemVulnerabilityAssessment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1562.010 .

d3f:T0800 a owl:Class ;
    rdfs:label "T0800" ;
    d3f:attack-id "T0800" ;
    dcterms:title "Activate Firmware Update Mode" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may activate firmware update mode on devices to prevent expected response functions from engaging in reaction to an emergency or process malfunction. For example, devices such as protection relays may have an operation mode designed for firmware installation. This mode may halt process monitoring and related functions to allow new firmware to be loaded. A device left in update mode may be placed in an inactive holding state if no firmware is provided to it. By entering and leaving a device in this mode, the adversary may deny its usual functionalities." ;
    skos:exactMatch d3f:T0800,
        mitre-attack:T0800 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0801 a owl:Class ;
    rdfs:label "T0801" ;
    d3f:attack-id "T0801" ;
    dcterms:title "Monitor Process State" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may gather information about the physical process state. This information may be used to gain more information about the process itself or used as a trigger for malicious actions. The sources of process state information may vary such as, OPC tags, historian data, specific PLC block information, or network traffic." ;
    skos:exactMatch d3f:T0801,
        mitre-attack:T0801 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0802 a owl:Class ;
    rdfs:label "T0802" ;
    d3f:attack-id "T0802" ;
    dcterms:title "Automated Collection" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may automate collection of industrial environment information using tools or scripts. This automated collection may leverage native control protocols and tools available in the control systems environment. For example, the OPC protocol may be used to enumerate and gather information. Access to a system or interface with these native protocols may allow collection and enumeration of other attached, communicating servers and devices." ;
    skos:exactMatch d3f:T0802,
        mitre-attack:T0802 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0803 a owl:Class ;
    rdfs:label "T0803" ;
    d3f:attack-id "T0803" ;
    dcterms:title "Block Command Message" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may block a command message from reaching its intended target to prevent command execution. In OT networks, command messages are sent to provide instructions to control system devices. A blocked command message can inhibit response functions from correcting a disruption or unsafe condition. (Citation: Bonnie Zhu, Anthony Joseph, Shankar Sastry 2011)  (Citation: Electricity Information Sharing and Analysis Center; SANS Industrial Control Systems March 2016)" ;
    skos:exactMatch d3f:T0803,
        mitre-attack:T0803 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0804 a owl:Class ;
    rdfs:label "T0804" ;
    d3f:attack-id "T0804" ;
    dcterms:title "Block Reporting Message" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may block or prevent a reporting message from reaching its intended target. In control systems, reporting messages contain telemetry data (e.g., I/O values) pertaining to the current state of equipment and the industrial process. By blocking these reporting messages, an adversary can potentially hide their actions from an operator." ;
    skos:exactMatch d3f:T0804,
        mitre-attack:T0804 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0805 a owl:Class ;
    rdfs:label "T0805" ;
    d3f:attack-id "T0805" ;
    dcterms:title "Block Serial COM" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may block access to serial COM to prevent instructions or configurations from reaching target devices. Serial Communication ports (COM) allow communication with control system devices. Devices can receive command and configuration messages over such serial COM. Devices also use serial COM to send command and reporting messages. Blocking device serial COM may also block command messages and block reporting messages." ;
    skos:exactMatch d3f:T0805,
        mitre-attack:T0805 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0806 a owl:Class ;
    rdfs:label "T0806" ;
    d3f:attack-id "T0806" ;
    dcterms:title "Brute Force I/O" ;
    rdfs:subClassOf d3f:ATTACKICSImpairProcessControlTechnique ;
    skos:definition "Adversaries may repetitively or successively change I/O point values to perform an action. Brute Force I/O may be achieved by changing either a range of I/O point values or a single point value repeatedly to manipulate a process function. The adversary's goal and the information they have about the target environment will influence which of the options they choose. In the case of brute forcing a range of point values, the adversary may be able to achieve an impact without targeting a specific point. In the case where a single point is targeted, the adversary may be able to generate instability on the process function associated with that particular point." ;
    skos:exactMatch d3f:T0806,
        mitre-attack:T0806 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0807 a owl:Class ;
    rdfs:label "T0807" ;
    d3f:attack-id "T0807" ;
    dcterms:title "Command-Line Interface" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may utilize command-line interfaces (CLIs) to interact with systems and execute commands. CLIs provide a means of interacting with computer systems and are a common feature across many types of platforms and devices within control systems environments. (Citation: Enterprise ATT&CK January 2018) Adversaries may also use CLIs to install and run new software, including malicious tools that may be installed over the course of an operation." ;
    skos:exactMatch d3f:T0807,
        mitre-attack:T0807 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0808 a owl:Class ;
    rdfs:label "T0808" ;
    d3f:attack-id "T0808" ;
    dcterms:title "Control Device Identification" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Adversaries may perform control device identification to determine the make and model of a target device. Management software and device APIs may be utilized by the adversary to gain this information. By identifying and obtaining device specifics, the adversary may be able to determine device vulnerabilities. This device information can also be used to understand device functionality and inform the decision to target the environment." ;
    skos:exactMatch d3f:T0808,
        mitre-attack:T0808 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0809 a owl:Class ;
    rdfs:label "T0809" ;
    d3f:attack-id "T0809" ;
    dcterms:title "Data Destruction" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may perform data destruction over the course of an operation. The adversary may drop or create malware, tools, or other non-native files on a target system to accomplish this, potentially leaving behind traces of malicious activities. Such non-native files and other data may be removed over the course of an intrusion to maintain a small footprint or as a standard part of the post-intrusion cleanup process. (Citation: Enterprise ATT&CK January 2018)" ;
    skos:exactMatch d3f:T0809,
        mitre-attack:T0809 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0810 a owl:Class ;
    rdfs:label "T0810" ;
    d3f:attack-id "T0810" ;
    dcterms:title "Data Historian Compromise" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may compromise and gain control of a data historian to gain a foothold into the control system environment. Access to a data historian may be used to learn stored database archival and analysis information on the control system. A dual-homed data historian may provide adversaries an interface from the IT environment to the OT environment." ;
    skos:exactMatch d3f:T0810,
        mitre-attack:T0810 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0811 a owl:Class ;
    rdfs:label "T0811" ;
    d3f:attack-id "T0811" ;
    dcterms:title "Data from Information Repositories" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may target and collect data from information repositories. This can include sensitive data such as specifications, schematics, or diagrams of control system layouts, devices, and processes. Examples of information repositories include reference databases in the process environment, as well as databases in the corporate network that might contain information about the ICS.(Citation: Cybersecurity & Infrastructure Security Agency March 2018)" ;
    skos:exactMatch d3f:T0811,
        mitre-attack:T0811 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0812 a owl:Class ;
    rdfs:label "T0812" ;
    d3f:attack-id "T0812" ;
    dcterms:title "Default Credentials" ;
    rdfs:subClassOf d3f:ATTACKICSLateralMovementTechnique ;
    skos:definition "Adversaries may leverage manufacturer or supplier set default credentials on control system devices. These default credentials may have administrative permissions and may be necessary for initial configuration of the device. It is general best practice to change the passwords for these accounts as soon as possible, but some manufacturers may have devices that have passwords or usernames that cannot be changed. (Citation: Keith Stouffer May 2015)" ;
    skos:exactMatch d3f:T0812,
        mitre-attack:T0812 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0813 a owl:Class ;
    rdfs:label "T0813" ;
    d3f:attack-id "T0813" ;
    dcterms:title "Denial of Control" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may cause a denial of control to temporarily prevent operators and engineers from interacting with process controls. An adversary may attempt to deny process control access to cause a temporary loss of communication with the control device or to prevent operator adjustment of process controls. An affected process may still be operating during the period of control loss, but not necessarily in a desired state. (Citation: Corero) (Citation: Michael J. Assante and Robert M. Lee) (Citation: Tyson Macaulay)" ;
    skos:exactMatch d3f:T0813,
        mitre-attack:T0813 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0814 a owl:Class ;
    rdfs:label "T0814" ;
    d3f:attack-id "T0814" ;
    dcterms:title "Denial of Service" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may perform Denial-of-Service (DoS) attacks to disrupt expected device functionality. Examples of DoS attacks include overwhelming the target device with a high volume of requests in a short time period and sending the target device a request it does not know how to handle. Disrupting device state may temporarily render it unresponsive, possibly lasting until a reboot can occur. When placed in this state, devices may be unable to send and receive requests, and may not perform expected response functions in reaction to other events in the environment." ;
    skos:exactMatch d3f:T0814,
        mitre-attack:T0814 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0815 a owl:Class ;
    rdfs:label "T0815" ;
    d3f:attack-id "T0815" ;
    dcterms:title "Denial of View" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may cause a denial of view in attempt to disrupt and prevent operator oversight on the status of an ICS environment. This may manifest itself as a temporary communication failure between a device and its control source, where the interface recovers and becomes available once the interference ceases. (Citation: Corero) (Citation: Michael J. Assante and Robert M. Lee) (Citation: Tyson Macaulay)" ;
    skos:exactMatch d3f:T0815,
        mitre-attack:T0815 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0816 a owl:Class ;
    rdfs:label "T0816" ;
    d3f:attack-id "T0816" ;
    dcterms:title "Device Restart/Shutdown" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may forcibly restart or shutdown a device in an ICS environment to disrupt and potentially negatively impact physical processes. Methods of device restart and shutdown exist in some devices as built-in, standard functionalities. These functionalities can be executed using interactive device web interfaces, CLIs, and network protocol commands." ;
    skos:exactMatch d3f:T0816,
        mitre-attack:T0816 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0817 a owl:Class ;
    rdfs:label "T0817" ;
    d3f:attack-id "T0817" ;
    dcterms:title "Drive-by Compromise" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may gain access to a system during a drive-by compromise, when a user visits a website as part of a regular browsing session. With this technique, the user's web browser is targeted and exploited simply by visiting the compromised website." ;
    skos:exactMatch d3f:T0817,
        mitre-attack:T0817 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0818 a owl:Class ;
    rdfs:label "T0818" ;
    d3f:attack-id "T0818" ;
    dcterms:title "Engineering Workstation Compromise" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries will compromise and gain control of an engineering workstation for Initial Access into the control system environment. Access to an engineering workstation may occur through or physical means, such as a Valid Accounts with privileged access or infection by removable media. A dual-homed engineering workstation may allow the adversary access into multiple networks. For example, unsegregated process control, safety system, or information system networks. An Engineering Workstation is designed as a reliable computing platform that configures, maintains, and diagnoses control system equipment and applications. Compromise of an engineering workstation may provide access to, and control of, other control system applications and equipment. In the Maroochy attack, the adversary utilized a computer, possibly stolen, with proprietary engineering software to communicate with a wastewater system." ;
    skos:exactMatch d3f:T0818,
        mitre-attack:T0818 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0819 a owl:Class ;
    rdfs:label "T0819" ;
    d3f:attack-id "T0819" ;
    dcterms:title "Exploit Public-Facing Application" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may leverage weaknesses to exploit internet-facing software for initial access into an industrial network. Internet-facing software may be user applications, underlying networking implementations, an assets operating system, weak defenses, etc. Targets of this technique may be intentionally exposed for the purpose of remote management and visibility." ;
    skos:exactMatch d3f:T0819,
        mitre-attack:T0819 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0820 a owl:Class ;
    rdfs:label "T0820" ;
    d3f:attack-id "T0820" ;
    dcterms:title "Exploitation for Evasion" ;
    rdfs:subClassOf d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may exploit a software vulnerability to take advantage of a programming error in a program, service, or within the operating system software or kernel itself to evade detection. Vulnerabilities may exist in software that can be used to disable or circumvent security features." ;
    skos:exactMatch d3f:T0820,
        mitre-attack:T0820 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0821 a owl:Class ;
    rdfs:label "T0821" ;
    d3f:attack-id "T0821" ;
    dcterms:title "Modify Controller Tasking" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may modify the tasking of a controller to allow for the execution of their own programs. This can allow an adversary to manipulate the execution flow and behavior of a controller." ;
    skos:exactMatch d3f:T0821,
        mitre-attack:T0821 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0822 a owl:Class ;
    rdfs:label "T0822" ;
    d3f:attack-id "T0822" ;
    dcterms:title "External Remote Services" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may leverage external remote services as a point of initial access into your network. These services allow users to connect to internal network resources from external locations. Examples are VPNs, Citrix, and other access mechanisms. Remote service gateways often manage connections and credential authentication for these services. (Citation: Daniel Oakley, Travis Smith, Tripwire)" ;
    skos:exactMatch d3f:T0822,
        mitre-attack:T0822 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0823 a owl:Class ;
    rdfs:label "T0823" ;
    d3f:attack-id "T0823" ;
    dcterms:title "Graphical User Interface" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may attempt to gain access to a machine via a Graphical User Interface (GUI) to enhance execution capabilities. Access to a GUI allows a user to interact with a computer in a more visual manner than a CLI. A GUI allows users to move a cursor and click on interface objects, with a mouse and keyboard as the main input devices, as opposed to just using the keyboard." ;
    skos:exactMatch d3f:T0823,
        mitre-attack:T0823 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0824 a owl:Class ;
    rdfs:label "T0824" ;
    d3f:attack-id "T0824" ;
    dcterms:title "I/O Module Discovery" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Adversaries may use input/output (I/O) module discovery to gather key information about a control system device. An I/O module is a device that allows the control system device to either receive or send signals to other devices. These signals can be analog or digital, and may support a number of different protocols. Devices are often able to use attachable I/O modules to increase the number of inputs and outputs that it can utilize. An adversary with access to a device can use native device functions to enumerate I/O modules that are connected to the device. Information regarding the I/O modules can aid the adversary in understanding related control processes." ;
    skos:exactMatch d3f:T0824,
        mitre-attack:T0824 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0825 a owl:Class ;
    rdfs:label "T0825" ;
    d3f:attack-id "T0825" ;
    dcterms:title "Location Identification" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may perform location identification using device data to inform operations and targeted impact for attacks. Location identification data can come in a number of forms, including geographic location, location relative to other control system devices, time zone, and current time. An adversary may use an embedded global positioning system (GPS) module in a device to figure out the physical coordinates of a device. NIST SP800-82 recommends that devices utilize GPS or another location determining mechanism to attach appropriate timestamps to log entries (Citation: Guidance - NIST SP800-82). While this assists in logging and event tracking, an adversary could use the underlying positioning mechanism to determine the general location of a device. An adversary can also infer the physical location of serially connected devices by using serial connection enumeration." ;
    skos:exactMatch d3f:T0825,
        mitre-attack:T0825 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0826 a owl:Class ;
    rdfs:label "T0826" ;
    d3f:attack-id "T0826" ;
    dcterms:title "Loss of Availability" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may attempt to disrupt essential components or systems to prevent owner and operator from delivering products or services. (Citation: Corero) (Citation: Michael J. Assante and Robert M. Lee) (Citation: Tyson Macaulay)" ;
    skos:exactMatch d3f:T0826,
        mitre-attack:T0826 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0827 a owl:Class ;
    rdfs:label "T0827" ;
    d3f:attack-id "T0827" ;
    dcterms:title "Loss of Control" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may seek to achieve a sustained loss of control or a runaway condition in which operators cannot issue any commands even if the malicious interference has subsided. (Citation: Corero) (Citation: Michael J. Assante and Robert M. Lee) (Citation: Tyson Macaulay)" ;
    skos:exactMatch d3f:T0827,
        mitre-attack:T0827 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0828 a owl:Class ;
    rdfs:label "T0828" ;
    d3f:attack-id "T0828" ;
    dcterms:title "Loss of Productivity and Revenue" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may cause loss of productivity and revenue through disruption and even damage to the availability and integrity of control system operations, devices, and related processes. This technique may manifest as a direct effect of an ICS-targeting attack or tangentially, due to an IT-targeting attack against non-segregated environments." ;
    skos:exactMatch d3f:T0828,
        mitre-attack:T0828 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0829 a owl:Class ;
    rdfs:label "T0829" ;
    d3f:attack-id "T0829" ;
    dcterms:title "Loss of View" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may cause a sustained or permanent loss of view where the ICS equipment will require local, hands-on operator intervention; for instance, a restart or manual operation. By causing a sustained reporting or visibility loss, the adversary can effectively hide the present state of operations. This loss of view can occur without affecting the physical processes themselves. (Citation: Corero) (Citation: Michael J. Assante and Robert M. Lee) (Citation: Tyson Macaulay)" ;
    skos:exactMatch d3f:T0829,
        mitre-attack:T0829 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0830 a owl:Class ;
    rdfs:label "T0830" ;
    d3f:attack-id "T0830" ;
    dcterms:title "Adversary-in-the-Middle" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries with privileged network access may seek to modify network traffic in real time using adversary-in-the-middle (AiTM) attacks. (Citation: Gabriel Sanchez October 2017) This type of attack allows the adversary to intercept traffic to and/or from a particular device on the network. If a AiTM attack is established, then the adversary has the ability to block, log, modify, or inject traffic into the communication stream. There are several ways to accomplish this attack, but some of the most-common are Address Resolution Protocol (ARP) poisoning and the use of a proxy. (Citation: Bonnie Zhu, Anthony Joseph, Shankar Sastry 2011)" ;
    skos:exactMatch d3f:T0830,
        mitre-attack:T0830 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0831 a owl:Class ;
    rdfs:label "T0831" ;
    d3f:attack-id "T0831" ;
    dcterms:title "Manipulation of Control" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may manipulate physical process control within the industrial environment. Methods of manipulating control can include changes to set point values, tags, or other parameters. Adversaries may manipulate control systems devices or possibly leverage their own, to communicate with and command physical control processes. The duration of manipulation may be temporary or longer sustained, depending on operator detection." ;
    skos:exactMatch d3f:T0831,
        mitre-attack:T0831 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0832 a owl:Class ;
    rdfs:label "T0832" ;
    d3f:attack-id "T0832" ;
    dcterms:title "Manipulation of View" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may attempt to manipulate the information reported back to operators or controllers. This manipulation may be short term or sustained. During this time the process itself could be in a much different state than what is reported. (Citation: Corero) (Citation: Michael J. Assante and Robert M. Lee) (Citation: Tyson Macaulay)" ;
    skos:exactMatch d3f:T0832,
        mitre-attack:T0832 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0833 a owl:Class ;
    rdfs:label "T0833" ;
    d3f:attack-id "T0833" ;
    dcterms:title "Modify Control Logic" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSInhibitResponseFunctionTechnique ],
        d3f:ATTACKICSImpairProcessControlTechnique ;
    skos:definition "Adversaries may place malicious code in a system, which can cause the system to malfunction by modifying its control logic. Control system devices use programming languages (e.g. relay ladder logic) to control physical processes by affecting actuators, which cause machines to operate, based on environment sensor readings. These devices often include the ability to perform remote control logic updates." ;
    skos:exactMatch d3f:T0833,
        mitre-attack:T0833 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0834 a owl:Class ;
    rdfs:label "T0834" ;
    d3f:attack-id "T0834" ;
    dcterms:title "Native API" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may directly interact with the native OS application programming interface (API) to access system functions. Native APIs provide a controlled means of calling low-level OS services within the kernel, such as those involving hardware/devices, memory, and processes. (Citation: The MITRE Corporation May 2017) These native APIs are leveraged by the OS during system boot (when other system components are not yet initialized) as well as carrying out tasks and requests during routine operations." ;
    skos:exactMatch d3f:T0834,
        mitre-attack:T0834 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0835 a owl:Class ;
    rdfs:label "T0835" ;
    d3f:attack-id "T0835" ;
    dcterms:title "Manipulate I/O Image" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may manipulate the I/O image of PLCs through various means to prevent them from functioning as expected. Methods of I/O image manipulation may include overriding the I/O table via direct memory manipulation or using the override function used for testing PLC programs. (Citation: Dr. Kelvin T. Erickson December 2010) During the scan cycle, a PLC reads the status of all inputs and stores them in an image table. (Citation: Nanjundaiah, Vaidyanath) The image table is the PLCs internal storage location where values of inputs/outputs for one scan are stored while it executes the user program. After the PLC has solved the entire logic program, it updates the output image table. The contents of this output image table are written to the corresponding output points in I/O Modules." ;
    skos:exactMatch d3f:T0835,
        mitre-attack:T0835 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0836 a owl:Class ;
    rdfs:label "T0836" ;
    d3f:attack-id "T0836" ;
    dcterms:title "Modify Parameter" ;
    rdfs:subClassOf d3f:ATTACKICSImpairProcessControlTechnique ;
    skos:definition "Adversaries may modify parameters used to instruct industrial control system devices. These devices operate via programs that dictate how and when to perform actions based on such parameters. Such parameters can determine the extent to which an action is performed and may specify additional options. For example, a program on a control system device dictating motor processes may take a parameter defining the total number of seconds to run that motor." ;
    skos:exactMatch d3f:T0836,
        mitre-attack:T0836 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0837 a owl:Class ;
    rdfs:label "T0837" ;
    d3f:attack-id "T0837" ;
    dcterms:title "Loss of Protection" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may compromise protective system functions designed to prevent the effects of faults and abnormal conditions. This can result in equipment damage, prolonged process disruptions and hazards to personnel." ;
    skos:exactMatch d3f:T0837,
        mitre-attack:T0837 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0838 a owl:Class ;
    rdfs:label "T0838" ;
    d3f:attack-id "T0838" ;
    dcterms:title "Modify Alarm Settings" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may modify alarm settings to prevent alerts that may inform operators of their presence or to prevent responses to dangerous and unintended scenarios. Reporting messages are a standard part of data acquisition in control systems. Reporting messages are used as a way to transmit system state information and acknowledgements that specific actions have occurred. These messages provide vital information for the management of a physical process, and keep operators, engineers, and administrators aware of the state of system devices and physical processes." ;
    skos:exactMatch d3f:T0838,
        mitre-attack:T0838 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0839 a owl:Class ;
    rdfs:label "T0839" ;
    d3f:attack-id "T0839" ;
    dcterms:title "Module Firmware" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSPersistenceTechnique ],
        d3f:ATTACKICSImpairProcessControlTechnique ;
    skos:definition "Adversaries may install malicious or vulnerable firmware onto modular hardware devices. Control system devices often contain modular hardware devices. These devices may have their own set of firmware that is separate from the firmware of the main control system equipment." ;
    skos:exactMatch d3f:T0839,
        mitre-attack:T0839 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0840 a owl:Class ;
    rdfs:label "T0840" ;
    d3f:attack-id "T0840" ;
    dcterms:title "Network Connection Enumeration" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Adversaries may perform network connection enumeration to discover information about device communication patterns. If an adversary can inspect the state of a network connection with tools, such as Netstat(Citation: Netstat), in conjunction with [System Firmware](https://attack.mitre.org/techniques/T0857), then they can determine the role of certain devices on the network  (Citation: MITRE). The adversary can also use [Network Sniffing](https://attack.mitre.org/techniques/T0842) to watch network traffic for details about the source, destination, protocol, and content." ;
    skos:exactMatch d3f:T0840,
        mitre-attack:T0840 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0841 a owl:Class ;
    rdfs:label "T0841" ;
    d3f:attack-id "T0841" ;
    dcterms:title "Network Service Scanning" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Network Service Scanning is the process of discovering services on networked systems.  This can be achieved through a technique called port scanning or probing.  Port scanning interacts with the TCP/IP ports on a target system to determine whether ports are open, closed, or filtered by a firewall.  This does not reveal the service that is running behind the port, but since many common services are run on [https://www.iana.org/assignments/service-names-port-numbers/service-names-port-numbers.xhtml specific port numbers], the type of service can be assumed.  More in-depth testing includes interaction with the actual service to determine the service type and specific version.  One of the most-popular tools to use for Network Service Scanning is [https://nmap.org/ Nmap]." ;
    skos:exactMatch d3f:T0841,
        mitre-attack:T0841 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0842 a owl:Class ;
    rdfs:label "T0842" ;
    d3f:attack-id "T0842" ;
    dcterms:title "Network Sniffing" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Network sniffing is the practice of using a network interface on a computer system to monitor or capture information (Citation: Enterprise ATT&CK January 2018) regardless of whether it is the specified destination for the information." ;
    skos:exactMatch d3f:T0842,
        mitre-attack:T0842 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0843 a owl:Class ;
    rdfs:label "T0843" ;
    d3f:attack-id "T0843" ;
    dcterms:title "Program Download" ;
    rdfs:subClassOf d3f:ATTACKICSLateralMovementTechnique ;
    skos:definition "Adversaries may perform a program download to transfer a user program to a controller." ;
    skos:exactMatch d3f:T0843,
        mitre-attack:T0843 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0844 a owl:Class ;
    rdfs:label "T0844" ;
    d3f:attack-id "T0844" ;
    dcterms:title "Program Organization Units" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSLateralMovementTechnique ],
        d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Program Organizational Units (POUs) are block structures used within PLC programming to create programs and projects. (Citation: Guidance - IEC61131) POUs can be used to hold user programs written in IEC 61131-3 languages: Structured text, Instruction list, Function block, and Ladder logic. (Citation: Guidance - IEC61131) Application - 201203 They can also provide additional functionality, such as establishing connections between the PLC and other devices using TCON. (Citation: PLCBlaster - Spenneberg)" ;
    skos:exactMatch d3f:T0844,
        mitre-attack:T0844 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0845 a owl:Class ;
    rdfs:label "T0845" ;
    d3f:attack-id "T0845" ;
    dcterms:title "Program Upload" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may attempt to upload a program from a PLC to gather information about an industrial process. Uploading a program may allow them to acquire and study the underlying logic. Methods of program upload include vendor software, which enables the user to upload and read a program running on a PLC. This software can be used to upload the target program to a workstation, jump box, or an interfacing device." ;
    skos:exactMatch d3f:T0845,
        mitre-attack:T0845 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0846 a owl:Class ;
    rdfs:label "T0846" ;
    d3f:attack-id "T0846" ;
    dcterms:title "Remote System Discovery" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of other systems by IP address, hostname, or other logical identifier on a network that may be used for subsequent Lateral Movement or Discovery techniques. Functionality could exist within adversary tools to enable this, but utilities available on the operating system or vendor software could also be used. (Citation: Enterprise ATT&CK January 2018)" ;
    skos:exactMatch d3f:T0846,
        mitre-attack:T0846 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0847 a owl:Class ;
    rdfs:label "T0847" ;
    d3f:attack-id "T0847" ;
    dcterms:title "Replication Through Removable Media" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may move onto systems, such as those separated from the enterprise network, by copying malware to removable media which is inserted into the control systems environment. The adversary may rely on unknowing trusted third parties, such as suppliers or contractors with access privileges, to introduce the removable media. This technique enables initial access to target devices that never connect to untrusted networks, but are physically accessible." ;
    skos:exactMatch d3f:T0847,
        mitre-attack:T0847 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0848 a owl:Class ;
    rdfs:label "T0848" ;
    d3f:attack-id "T0848" ;
    dcterms:title "Rogue Master" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may setup a rogue master to leverage control server functions to communicate with outstations. A rogue master can be used to send legitimate control messages to other control system devices, affecting processes in unintended ways. It may also be used to disrupt network communications by capturing and receiving the network traffic meant for the actual master. Impersonating a master may also allow an adversary to avoid detection." ;
    skos:exactMatch d3f:T0848,
        mitre-attack:T0848 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0849 a owl:Class ;
    rdfs:label "T0849" ;
    d3f:attack-id "T0849" ;
    dcterms:title "Masquerading" ;
    rdfs:subClassOf d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may use masquerading to disguise a malicious application or executable as another file, to avoid operator and engineer suspicion. Possible disguises of these masquerading files can include commonly found programs, expected vendor executables and configuration files, and other commonplace application and naming conventions. By impersonating expected and vendor-relevant files and applications, operators and engineers may not notice the presence of the underlying malicious content and possibly end up running those masquerading as legitimate functions." ;
    skos:exactMatch d3f:T0849,
        mitre-attack:T0849 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0850 a owl:Class ;
    rdfs:label "T0850" ;
    d3f:attack-id "T0850" ;
    dcterms:title "Role Identification" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may perform role identification of devices involved with physical processes of interest in a target control system. Control systems devices often work in concert to control a physical process. Each device can have one or more roles that it performs within that control process. By collecting this role-based data, an adversary can construct a more targeted attack." ;
    skos:exactMatch d3f:T0850,
        mitre-attack:T0850 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0851 a owl:Class ;
    rdfs:label "T0851" ;
    d3f:attack-id "T0851" ;
    dcterms:title "Rootkit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSInhibitResponseFunctionTechnique ],
        d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may deploy rootkits to hide the presence of programs, files, network connections, services, drivers, and other system components. Rootkits are programs that hide the existence of malware by intercepting and modifying operating-system API calls that supply system information. Rootkits or rootkit-enabling functionality may reside at the user or kernel level in the operating system, or lower. (Citation: Enterprise ATT&CK January 2018)" ;
    skos:exactMatch d3f:T0851,
        mitre-attack:T0851 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0852 a owl:Class ;
    rdfs:label "T0852" ;
    d3f:attack-id "T0852" ;
    dcterms:title "Screen Capture" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may attempt to perform screen capture of devices in the control system environment. Screenshots may be taken of workstations, HMIs, or other devices that display environment-relevant process, device, reporting, alarm, or related data. These device displays may reveal information regarding the ICS process, layout, control, and related schematics. In particular, an HMI can provide a lot of important industrial process information. (Citation: ICS-CERT October 2017) Analysis of screen captures may provide the adversary with an understanding of intended operations and interactions between critical devices." ;
    skos:exactMatch d3f:T0852,
        mitre-attack:T0852 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0853 a owl:Class ;
    rdfs:label "T0853" ;
    d3f:attack-id "T0853" ;
    dcterms:title "Scripting" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may use scripting languages to execute arbitrary code in the form of a pre-written script or in the form of user-supplied code to an interpreter. Scripting languages are programming languages that differ from compiled languages, in that scripting languages use an interpreter, instead of a compiler. These interpreters read and compile part of the source code just before it is executed, as opposed to compilers, which compile each and every line of code to an executable file. Scripting allows software developers to run their code on any system where the interpreter exists. This way, they can distribute one package, instead of precompiling executables for many different systems. Scripting languages, such as Python, have their interpreters shipped as a default with many Linux distributions." ;
    skos:exactMatch d3f:T0853,
        mitre-attack:T0853 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0854 a owl:Class ;
    rdfs:label "T0854" ;
    d3f:attack-id "T0854" ;
    dcterms:title "Serial Connection Enumeration" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "Adversaries may perform serial connection enumeration to gather situational awareness after gaining access to devices in the OT network. Control systems devices often communicate to each other via various types of serial communication mediums. These serial communications are used to facilitate informational communication, as well as commands.  Serial Connection Enumeration differs from I/O Module Discovery, as I/O modules are auxiliary systems to the main system, and devices that are connected via serial connection are normally discrete systems." ;
    skos:exactMatch d3f:T0854,
        mitre-attack:T0854 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0855 a owl:Class ;
    rdfs:label "T0855" ;
    d3f:attack-id "T0855" ;
    dcterms:title "Unauthorized Command Message" ;
    rdfs:subClassOf d3f:ATTACKICSImpairProcessControlTechnique ;
    skos:definition "Adversaries may send unauthorized command messages to instruct control system assets to perform actions outside of their intended functionality, or without the logical preconditions to trigger their expected function. Command messages are used in ICS networks to give direct instructions to control systems devices. If an adversary can send an unauthorized command message to a control system, then it can instruct the control systems device to perform an action outside the normal bounds of the device's actions. An adversary could potentially instruct a control systems device to perform an action that will cause an [Impact](https://attack.mitre.org/tactics/TA0105). (Citation: Bonnie Zhu, Anthony Joseph, Shankar Sastry 2011)" ;
    skos:exactMatch d3f:T0855,
        mitre-attack:T0855 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0856 a owl:Class ;
    rdfs:label "T0856" ;
    d3f:attack-id "T0856" ;
    dcterms:title "Spoof Reporting Message" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSImpairProcessControlTechnique ],
        d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may spoof reporting messages in control system environments for evasion and to impair process control. In control systems, reporting messages contain telemetry data (e.g., I/O values) pertaining to the current state of equipment and the industrial process. Reporting messages are important for monitoring the normal operation of a system or identifying important events such as deviations from expected values." ;
    skos:exactMatch d3f:T0856,
        mitre-attack:T0856 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0857 a owl:Class ;
    rdfs:label "T0857" ;
    d3f:attack-id "T0857" ;
    dcterms:title "System Firmware" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSPersistenceTechnique ],
        d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "System firmware on modern assets is often designed with an update feature. Older device firmware may be factory installed and require special reprograming equipment. When available, the firmware update feature enables vendors to remotely patch bugs and perform upgrades. Device firmware updates are often delegated to the user and may be done using a software update package. It may also be possible to perform this task over the network." ;
    skos:exactMatch d3f:T0857,
        mitre-attack:T0857 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0858 a owl:Class ;
    rdfs:label "T0858" ;
    d3f:attack-id "T0858" ;
    dcterms:title "Change Operating Mode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSExecutionTechnique ],
        d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may change the operating mode of a controller to gain additional access to engineering functions such as Program Download.   Programmable controllers typically have several modes of operation that control the state of the user program and control access to the controllers API. Operating modes can be physically selected using a key switch on the face of the controller but may also be selected with calls to the controllers API. Operating modes and the mechanisms by which they are selected often vary by vendor and product line. Some commonly implemented operating modes are described below:" ;
    skos:exactMatch d3f:T0858,
        mitre-attack:T0858 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0859 a owl:Class ;
    rdfs:label "T0859" ;
    d3f:attack-id "T0859" ;
    dcterms:title "Valid Accounts" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSPersistenceTechnique ],
        d3f:ATTACKICSLateralMovementTechnique ;
    skos:definition "Adversaries may steal the credentials of a specific user or service account using credential access techniques. In some cases, default credentials for control system devices may be publicly available. Compromised credentials may be used to bypass access controls placed on various resources on hosts and within the network, and may even be used for persistent access to remote systems. Compromised and default credentials may also grant an adversary increased privilege to specific systems and devices or access to restricted areas of the network. Adversaries may choose not to use malware or tools, in conjunction with the legitimate access those credentials provide, to make it harder to detect their presence or to control devices and send legitimate commands in an unintended way." ;
    skos:exactMatch d3f:T0859,
        mitre-attack:T0859 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0860 a owl:Class ;
    rdfs:label "T0860" ;
    d3f:attack-id "T0860" ;
    dcterms:title "Wireless Compromise" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may perform wireless compromise as a method of gaining communications and unauthorized access to a wireless network. Access to a wireless network may be gained through the compromise of a wireless device. (Citation: Alexander Bolshev, Gleb Cherbov July 2014) (Citation: Alexander Bolshev March 2014) Adversaries may also utilize radios and other wireless communication devices on the same frequency as the wireless network. Wireless compromise can be done as an initial access vector from a remote distance." ;
    skos:exactMatch d3f:T0860,
        mitre-attack:T0860 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0861 a owl:Class ;
    rdfs:label "T0861" ;
    d3f:attack-id "T0861" ;
    dcterms:title "Point & Tag Identification" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may collect point and tag values to gain a more comprehensive understanding of the process environment. Points may be values such as inputs, memory locations, outputs or other process specific variables. (Citation: Dennis L. Sloatman September 2016) Tags are the identifiers given to points for operator convenience." ;
    skos:exactMatch d3f:T0861,
        mitre-attack:T0861 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0862 a owl:Class ;
    rdfs:label "T0862" ;
    d3f:attack-id "T0862" ;
    dcterms:title "Supply Chain Compromise" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may perform supply chain compromise to gain control systems environment access by means of infected products, software, and workflows. Supply chain compromise is the manipulation of products, such as devices or software, or their delivery mechanisms before receipt by the end consumer. Adversary compromise of these products and mechanisms is done for the goal of data or system compromise, once infected products are introduced to the target environment." ;
    skos:exactMatch d3f:T0862,
        mitre-attack:T0862 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0863 a owl:Class ;
    rdfs:label "T0863" ;
    d3f:attack-id "T0863" ;
    dcterms:title "User Execution" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may rely on a targeted organizations user interaction for the execution of malicious code. User interaction may consist of installing applications, opening email attachments, or granting higher permissions to documents." ;
    skos:exactMatch d3f:T0863,
        mitre-attack:T0863 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0864 a owl:Class ;
    rdfs:label "T0864" ;
    d3f:attack-id "T0864" ;
    dcterms:title "Transient Cyber Asset" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may target devices that are transient across ICS networks and external networks. Normally, transient assets are brought into an environment by authorized personnel and do not remain in that environment on a permanent basis. (Citation: North American Electric Reliability Corporation June 2021) Transient assets are commonly needed to support management functions and may be more common in systems where a remotely managed asset is not feasible, external connections for remote access do not exist, or 3rd party contractor/vendor access is required." ;
    skos:exactMatch d3f:T0864,
        mitre-attack:T0864 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0865 a owl:Class ;
    rdfs:label "T0865" ;
    d3f:attack-id "T0865" ;
    dcterms:title "Spearphishing Attachment" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may use a spearphishing attachment, a variant of spearphishing, as a form of a social engineering attack against specific targets. Spearphishing attachments are different from other forms of spearphishing in that they employ malware attached to an email. All forms of spearphishing are electronically delivered and target a specific individual, company, or industry. In this scenario, adversaries attach a file to the spearphishing email and usually rely upon [User Execution](https://attack.mitre.org/techniques/T0863) to gain execution and access. (Citation: Enterprise ATT&CK October 2019)" ;
    skos:exactMatch d3f:T0865,
        mitre-attack:T0865 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0866 a owl:Class ;
    rdfs:label "T0866" ;
    d3f:attack-id "T0866" ;
    dcterms:title "Exploitation of Remote Services" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSLateralMovementTechnique ],
        d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may exploit a software vulnerability to take advantage of a programming error in a program, service, or within the operating system software or kernel itself to enable remote service abuse. A common goal for post-compromise exploitation of remote services is for initial access into and lateral movement throughout the ICS environment to enable access to targeted systems. (Citation: Enterprise ATT&CK)" ;
    skos:exactMatch d3f:T0866,
        mitre-attack:T0866 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0867 a owl:Class ;
    rdfs:label "T0867" ;
    d3f:attack-id "T0867" ;
    dcterms:title "Lateral Tool Transfer" ;
    rdfs:subClassOf d3f:ATTACKICSLateralMovementTechnique ;
    skos:definition "Adversaries may transfer tools or other files from one system to another to stage adversary tools or other files over the course of an operation. (Citation: Enterprise ATT&CK) Copying of files may also be performed laterally between internal victim systems to support Lateral Movement with remote Execution using inherent file sharing protocols such as file sharing over SMB to connected network shares. (Citation: Enterprise ATT&CK)" ;
    skos:exactMatch d3f:T0867,
        mitre-attack:T0867 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0868 a owl:Class ;
    rdfs:label "T0868" ;
    d3f:attack-id "T0868" ;
    dcterms:title "Detect Operating Mode" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may gather information about a PLCs or controllers current operating mode. Operating modes dictate what change or maintenance functions can be manipulated and are often controlled by a key switch on the PLC (e.g.,  run, prog [program], and remote). Knowledge of these states may be valuable to an adversary to determine if they are able to reprogram the PLC. Operating modes and the mechanisms by which they are selected often vary by vendor and product line. Some commonly implemented operating modes are described below:" ;
    skos:exactMatch d3f:T0868,
        mitre-attack:T0868 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0869 a owl:Class ;
    rdfs:label "T0869" ;
    d3f:attack-id "T0869" ;
    dcterms:title "Standard Application Layer Protocol" ;
    rdfs:subClassOf d3f:ATTACKICSCommandAndControlTechnique ;
    skos:definition "Adversaries may establish command and control capabilities over commonly used application layer protocols such as HTTP(S), OPC, RDP, telnet, DNP3, and modbus. These protocols may be used to disguise adversary actions as benign network traffic. Standard protocols may be seen on their associated port or in some cases over a non-standard port.  Adversaries may use these protocols to reach out of the network for command and control, or in some cases to other infected devices within the network." ;
    skos:exactMatch d3f:T0869,
        mitre-attack:T0869 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0870 a owl:Class ;
    rdfs:label "T0870" ;
    d3f:attack-id "T0870" ;
    dcterms:title "Detect Program State" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may seek to gather information about the current state of a program on a PLC. State information reveals information about the program, including whether it's running, halted, stopped, or has generated an exception. This information may be leveraged as a verification of malicious program execution or to determine if a PLC is ready to download a new program." ;
    skos:exactMatch d3f:T0870,
        mitre-attack:T0870 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0871 a owl:Class ;
    rdfs:label "T0871" ;
    d3f:attack-id "T0871" ;
    dcterms:title "Execution through API" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may attempt to leverage Application Program Interfaces (APIs) used for communication between control software and the hardware. Specific functionality is often coded into APIs which can be called by software to engage specific functions on a device or other software." ;
    skos:exactMatch d3f:T0871,
        mitre-attack:T0871 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0872 a owl:Class ;
    rdfs:label "T0872" ;
    d3f:attack-id "T0872" ;
    dcterms:title "Indicator Removal on Host" ;
    rdfs:subClassOf d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may attempt to remove indicators of their presence on a system in an effort to cover their tracks. In cases where an adversary may feel detection is imminent, they may try to overwrite, delete, or cover up changes they have made to the device." ;
    skos:exactMatch d3f:T0872,
        mitre-attack:T0872 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0873 a owl:Class ;
    rdfs:label "T0873" ;
    d3f:attack-id "T0873" ;
    dcterms:title "Project File Infection" ;
    rdfs:subClassOf d3f:ATTACKICSPersistenceTechnique ;
    skos:definition "Adversaries may attempt to infect project files with malicious code. These project files may consist of objects, program organization units, variables such as tags, documentation, and other configurations needed for PLC programs to function. (Citation: Beckhoff) Using built in functions of the engineering software, adversaries may be able to download an infected program to a PLC in the operating environment enabling further [Execution](https://attack.mitre.org/tactics/TA0104) and [Persistence](https://attack.mitre.org/tactics/TA0110) techniques. (Citation: PLCdev)" ;
    skos:exactMatch d3f:T0873,
        mitre-attack:T0873 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0874 a owl:Class ;
    rdfs:label "T0874" ;
    d3f:attack-id "T0874" ;
    dcterms:title "Hooking" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSPrivilegeEscalationTechnique ],
        d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may hook into application programming interface (API) functions used by processes to redirect calls for execution and privilege escalation means. Windows processes often leverage these API functions to perform tasks that require reusable system resources. Windows API functions are typically stored in dynamic-link libraries (DLLs) as exported functions. (Citation: Enterprise ATT&CK)" ;
    skos:exactMatch d3f:T0874,
        mitre-attack:T0874 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0875 a owl:Class ;
    rdfs:label "T0875" ;
    d3f:attack-id "T0875" ;
    dcterms:title "Change Program State" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSImpairProcessControlTechnique ],
        d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may attempt to change the state of the current program on a control device. Program state changes may be used to allow for another program to take over control or be loaded onto the device." ;
    skos:exactMatch d3f:T0875,
        mitre-attack:T0875 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T0877 a owl:Class ;
    rdfs:label "T0877" ;
    d3f:attack-id "T0877" ;
    dcterms:title "I/O Image" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may seek to capture process values related to the inputs and outputs of a PLC. During the scan cycle, a PLC reads the status of all inputs and stores them in an image table. (Citation: Nanjundaiah, Vaidyanath) The image table is the PLCs internal storage location where values of inputs/outputs for one scan are stored while it executes the user program. After the PLC has solved the entire logic program, it updates the output image table. The contents of this output image table are written to the corresponding output points in I/O Modules." ;
    skos:exactMatch d3f:T0877,
        mitre-attack:T0877 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0878 a owl:Class ;
    rdfs:label "T0878" ;
    d3f:attack-id "T0878" ;
    dcterms:title "Alarm Suppression" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may target protection function alarms to prevent them from notifying operators of critical conditions. Alarm messages may be a part of an overall reporting system and of particular interest for adversaries. Disruption of the alarm system does not imply the disruption of the reporting system as a whole." ;
    skos:exactMatch d3f:T0878,
        mitre-attack:T0878 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0879 a owl:Class ;
    rdfs:label "T0879" ;
    d3f:attack-id "T0879" ;
    dcterms:title "Damage to Property" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may cause damage and destruction of property to infrastructure, equipment, and the surrounding environment when attacking control systems. This technique may result in device and operational equipment breakdown, or represent tangential damage from other techniques used in an attack. Depending on the severity of physical damage and disruption caused to control processes and systems, this technique may result in [Loss of Safety](https://attack.mitre.org/techniques/T0880). Operations that result in [Loss of Control](https://attack.mitre.org/techniques/T0827) may also cause damage to property, which may be directly or indirectly motivated by an adversary seeking to cause impact in the form of [Loss of Productivity and Revenue](https://attack.mitre.org/techniques/T0828)." ;
    skos:exactMatch d3f:T0879,
        mitre-attack:T0879 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0880 a owl:Class ;
    rdfs:label "T0880" ;
    d3f:attack-id "T0880" ;
    dcterms:title "Loss of Safety" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may compromise safety system functions designed to maintain safe operation of a process when unacceptable or dangerous conditions occur. Safety systems are often composed of the same elements as control systems but have the sole purpose of ensuring the process fails in a predetermined safe manner." ;
    skos:exactMatch d3f:T0880,
        mitre-attack:T0880 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0881 a owl:Class ;
    rdfs:label "T0881" ;
    d3f:attack-id "T0881" ;
    dcterms:title "Service Stop" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may stop or disable services on a system to render those services unavailable to legitimate users. Stopping critical services can inhibit or stop response to an incident or aid in the adversary's overall objectives to cause damage to the environment. (Citation: Enterprise ATT&CK)  Services may not allow for modification of their data stores while running. Adversaries may stop services in order to conduct Data Destruction. (Citation: Enterprise ATT&CK)" ;
    skos:exactMatch d3f:T0881,
        mitre-attack:T0881 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0882 a owl:Class ;
    rdfs:label "T0882" ;
    d3f:attack-id "T0882" ;
    dcterms:title "Theft of Operational Information" ;
    rdfs:subClassOf d3f:ATTACKICSImpactTechnique ;
    skos:definition "Adversaries may steal operational information on a production environment as a direct mission outcome for personal gain or to inform future operations. This information may include design documents, schedules, rotational data, or similar artifacts that provide insight on operations.    In the Bowman Dam incident, adversaries probed systems for operational data. (Citation: Mark Thompson March 2016) (Citation: Danny Yadron December 2015)" ;
    skos:exactMatch d3f:T0882,
        mitre-attack:T0882 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0883 a owl:Class ;
    rdfs:label "T0883" ;
    d3f:attack-id "T0883" ;
    dcterms:title "Internet Accessible Device" ;
    rdfs:subClassOf d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may gain access into industrial environments through systems exposed directly to the internet for remote access rather than through [External Remote Services](https://attack.mitre.org/techniques/T0822). Internet Accessible Devices are exposed to the internet unintentionally or intentionally without adequate protections. This may allow for adversaries to move directly into the control system network. Access onto these devices is accomplished without the use of exploits, these would be represented within the [Exploit Public-Facing Application](https://attack.mitre.org/techniques/T0819) technique." ;
    skos:exactMatch d3f:T0883,
        mitre-attack:T0883 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0884 a owl:Class ;
    rdfs:label "T0884" ;
    d3f:attack-id "T0884" ;
    dcterms:title "Connection Proxy" ;
    rdfs:subClassOf d3f:ATTACKICSCommandAndControlTechnique ;
    skos:definition "Adversaries may use a connection proxy to direct network traffic between systems or act as an intermediary for network communications." ;
    skos:exactMatch d3f:T0884,
        mitre-attack:T0884 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0885 a owl:Class ;
    rdfs:label "T0885" ;
    d3f:attack-id "T0885" ;
    dcterms:title "Commonly Used Port" ;
    rdfs:subClassOf d3f:ATTACKICSCommandAndControlTechnique ;
    skos:definition "Adversaries may communicate over a commonly used port to bypass firewalls or network detection systems and to blend in with normal network activity, to avoid more detailed inspection. They may use the protocol associated with the port, or a completely different protocol. They may use commonly open ports, such as the examples provided below." ;
    skos:exactMatch d3f:T0885,
        mitre-attack:T0885 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0886 a owl:Class ;
    rdfs:label "T0886" ;
    d3f:attack-id "T0886" ;
    dcterms:title "Remote Services" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSLateralMovementTechnique ],
        d3f:ATTACKICSInitialAccessTechnique ;
    skos:definition "Adversaries may leverage remote services to move between assets and network segments. These services are often used to allow operators to interact with systems remotely within the network, some examples are RDP, SMB, SSH, and other similar mechanisms. (Citation: Blake Johnson, Dan Caban, Marina Krotofil, Dan Scali, Nathan Brubaker, Christopher Glyer December 2017) (Citation: Dragos December 2017) (Citation: Joe Slowik April 2019)" ;
    skos:exactMatch d3f:T0886,
        mitre-attack:T0886 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0887 a owl:Class ;
    rdfs:label "T0887" ;
    d3f:attack-id "T0887" ;
    dcterms:title "Wireless Sniffing" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSDiscoveryTechnique ],
        d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may seek to capture radio frequency (RF) communication used for remote control and reporting in distributed environments. RF communication frequencies vary between 3 kHz to 300 GHz, although are commonly between 300 MHz to 6 GHz. (Citation: Candell, R., Hany, M., Lee, K. B., Liu,Y., Quimby, J., Remley, K. April 2018)  The wavelength and frequency of the signal affect how the signal propagates through open air, obstacles (e.g. walls and trees) and the type of radio required to capture them. These characteristics are often standardized in the protocol and hardware and may have an effect on how the signal is captured. Some examples of wireless protocols that may be found in cyber-physical environments are: WirelessHART, Zigbee, WIA-FA, and 700 MHz Public Safety Spectrum." ;
    skos:exactMatch d3f:T0887,
        mitre-attack:T0887 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0888 a owl:Class ;
    rdfs:label "T0888" ;
    d3f:attack-id "T0888" ;
    dcterms:title "Remote System Information Discovery" ;
    rdfs:subClassOf d3f:ATTACKICSDiscoveryTechnique ;
    skos:definition "An adversary may attempt to get detailed information about remote systems and their peripherals, such as make/model, role, and configuration. Adversaries may use information from Remote System Information Discovery to aid in targeting and shaping follow-on behaviors. For example, the system's operational role and model information can dictate whether it is a relevant target for the adversary's operational objectives. In addition, the system's configuration may be used to scope subsequent technique usage." ;
    skos:exactMatch d3f:T0888,
        mitre-attack:T0888 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0889 a owl:Class ;
    rdfs:label "T0889" ;
    d3f:attack-id "T0889" ;
    dcterms:title "Modify Program" ;
    rdfs:subClassOf d3f:ATTACKICSPersistenceTechnique ;
    skos:definition "Adversaries may modify or add a program on a controller to affect how it interacts with the physical process, peripheral devices and other hosts on the network. Modification to controller programs can be accomplished using a Program Download in addition to other types of program modification such as online edit and program append." ;
    skos:exactMatch d3f:T0889,
        mitre-attack:T0889 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0890 a owl:Class ;
    rdfs:label "T0890" ;
    d3f:attack-id "T0890" ;
    dcterms:title "Exploitation for Privilege Escalation" ;
    rdfs:subClassOf d3f:ATTACKICSPrivilegeEscalationTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities in an attempt to elevate privileges. Exploitation of a software vulnerability occurs when an adversary takes advantage of a programming error in a program, service, or within the operating system software or kernel itself to execute adversary-controlled code. Security constructs such as permission levels will often hinder access to information and use of certain techniques, so adversaries will likely need to perform privilege escalation to include use of software exploitation to circumvent those restrictions. (Citation: The MITRE Corporation)" ;
    skos:exactMatch d3f:T0890,
        mitre-attack:T0890 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0891 a owl:Class ;
    rdfs:label "T0891" ;
    d3f:attack-id "T0891" ;
    dcterms:title "Hardcoded Credentials" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKICSPersistenceTechnique ],
        d3f:ATTACKICSLateralMovementTechnique ;
    skos:definition "Adversaries may leverage credentials that are hardcoded in software or firmware to gain an unauthorized interactive user session to an asset. Examples credentials that may be hardcoded in an asset include:" ;
    skos:exactMatch d3f:T0891,
        mitre-attack:T0891 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0892 a owl:Class ;
    rdfs:label "T0892" ;
    d3f:attack-id "T0892" ;
    dcterms:title "Change Credential" ;
    rdfs:subClassOf d3f:ATTACKICSInhibitResponseFunctionTechnique ;
    skos:definition "Adversaries may modify software and device credentials to prevent operator and responder access. Depending on the device, the modification or addition of this password could prevent any device configuration actions from being accomplished and may require a factory reset or replacement of hardware. These credentials are often built-in features provided by the device vendors as a means to restrict access to management interfaces." ;
    skos:exactMatch d3f:T0892,
        mitre-attack:T0892 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0893 a owl:Class ;
    rdfs:label "T0893" ;
    d3f:attack-id "T0893" ;
    dcterms:title "Data from Local System" ;
    rdfs:subClassOf d3f:ATTACKICSCollectionTechnique ;
    skos:definition "Adversaries may target and collect data from local system sources, such as file systems, configuration files, or local databases. This can include sensitive data such as specifications, schematics, or diagrams of control system layouts, devices, and processes." ;
    skos:exactMatch d3f:T0893,
        mitre-attack:T0893 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0894 a owl:Class ;
    rdfs:label "T0894" ;
    d3f:attack-id "T0894" ;
    dcterms:title "System Binary Proxy Execution" ;
    rdfs:subClassOf d3f:ATTACKICSEvasionTechnique ;
    skos:definition "Adversaries may bypass process and/or signature-based defenses by proxying execution of malicious content with signed, or otherwise trusted, binaries. Binaries used in this technique are often Microsoft-signed files, indicating that they have been either downloaded from Microsoft or are already native in the operating system. (Citation: LOLBAS Project) Binaries signed with trusted digital certificates can typically execute on Windows systems protected by digital signature validation. Several Microsoft signed binaries that are default on Windows installations can be used to proxy execution of other files or commands. Similarly, on Linux systems adversaries may abuse trusted binaries such as split to proxy execution of malicious commands. (Citation: split man page)(Citation: GTFO split)" ;
    skos:exactMatch d3f:T0894,
        mitre-attack:T0894 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T0895 a owl:Class ;
    rdfs:label "T0895" ;
    d3f:attack-id "T0895" ;
    dcterms:title "Autorun Image" ;
    rdfs:subClassOf d3f:ATTACKICSExecutionTechnique ;
    skos:definition "Adversaries may leverage AutoRun functionality or scripts to execute malicious code. Devices configured to enable AutoRun functionality or legacy operating systems may be susceptible to abuse of these features to run malicious code stored on various forms of removeable media (i.e., USB, Disk Images [.ISO]). Commonly, AutoRun or AutoPlay are disabled in many operating systems configurations to mitigate against this technique. If a device is configured to enable AutoRun or AutoPlay, adversaries may execute code on the device by mounting the removable media to the device, either through physical or virtual means. This may be especially relevant for virtual machine environments where disk images may be dynamically mapped to a guest system on a hypervisor." ;
    skos:exactMatch d3f:T0895,
        mitre-attack:T0895 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1002 a owl:Class ;
    rdfs:label "T1002" ;
    d3f:attack-id "T1002" ;
    dcterms:title "Data Compressed" ;
    rdfs:seeAlso d3f:T1560 ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "An adversary may compress data (e.g., sensitive documents) that is collected prior to exfiltration in order to make it portable and minimize the amount of data sent over the network. The compression is done separately from the exfiltration channel and is performed using a custom program or algorithm, or a more common compression library or utility such as 7zip, RAR, ZIP, or zlib." ;
    skos:exactMatch d3f:T1002,
        mitre-attack:T1002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1560" .

d3f:T1004 a owl:Class ;
    rdfs:label "T1004" ;
    d3f:attack-id "T1004" ;
    dcterms:title "Winlogon Helper DLL" ;
    rdfs:seeAlso d3f:T1547.004 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Winlogon.exe is a Windows component responsible for actions at logon/logoff as well as the secure attention sequence (SAS) triggered by Ctrl-Alt-Delete. Registry entries in <code>HKLM\\Software\\[Wow6432Node\\]Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\</code> and <code>HKCU\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\</code> are used to manage additional helper programs and functionalities that support Winlogon. (Citation: Cylance Reg Persistence Sept 2013)" ;
    skos:exactMatch d3f:T1004,
        mitre-attack:T1004 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.004" .

d3f:T1005 a owl:Class ;
    rdfs:label "T1005" ;
    d3f:attack-id "T1005" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data from Local System" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may search local system sources, such as file systems and configuration files or local databases, to find files of interest and sensitive data prior to Exfiltration." ;
    skos:exactMatch d3f:T1005,
        mitre-attack:T1005 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1006 a owl:Class ;
    rdfs:label "T1006" ;
    d3f:attack-id "T1006" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Direct Volume Access" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may directly access a volume to bypass file access controls and file system monitoring. Windows allows programs to have direct access to logical volumes. Programs with direct access may read and write files directly from the drive by analyzing file system data structures. This technique may bypass Windows file access controls as well as file system monitoring tools. (Citation: Hakobyan 2009)" ;
    skos:exactMatch d3f:T1006,
        mitre-attack:T1006 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1007 a owl:Class ;
    rdfs:label "T1007" ;
    d3f:attack-id "T1007" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Service Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may try to gather information about registered local system services. Adversaries may obtain information about services using tools as well as OS utility commands such as <code>sc query</code>, <code>tasklist /svc</code>, <code>systemctl --type=service</code>, and <code>net start</code>." ;
    skos:exactMatch d3f:T1007,
        mitre-attack:T1007 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1008 a owl:Class ;
    rdfs:label "T1008" ;
    d3f:attack-id "T1008" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Fallback Channels" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may use fallback or alternate communication channels if the primary channel is compromised or inaccessible in order to maintain reliable command and control and to avoid data transfer thresholds." ;
    skos:exactMatch d3f:T1008,
        mitre-attack:T1008 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1009 a owl:Class ;
    rdfs:label "T1009" ;
    d3f:attack-id "T1009" ;
    dcterms:title "Binary Padding" ;
    rdfs:seeAlso d3f:T1027.001 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries can use binary padding to add junk data and change the on-disk representation of malware without affecting the functionality or behavior of the binary. This will often increase the size of the binary beyond what some security tools are capable of handling due to file size limitations." ;
    skos:exactMatch d3f:T1009,
        mitre-attack:T1009 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1027.001" .

d3f:T1010 a owl:Class ;
    rdfs:label "T1010" ;
    d3f:attack-id "T1010" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Window Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of open application windows. Window listings could convey information about how the system is used.(Citation: Prevailion DarkWatchman 2021) For example, information about application windows could be used identify potential data to collect as well as identifying security tooling ([Security Software Discovery](https://attack.mitre.org/techniques/T1518/001)) to evade.(Citation: ESET Grandoreiro April 2020)" ;
    skos:exactMatch d3f:T1010,
        mitre-attack:T1010 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1012 a owl:Class ;
    rdfs:label "T1012" ;
    d3f:attack-id "T1012" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Query Registry" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may interact with the Windows Registry to gather information about the system, configuration, and installed software." ;
    skos:exactMatch d3f:T1012,
        mitre-attack:T1012 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1013 a owl:Class ;
    rdfs:label "T1013" ;
    d3f:attack-id "T1013" ;
    dcterms:title "Port Monitors" ;
    rdfs:seeAlso d3f:T1547.010 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "A port monitor can be set through the  (Citation: AddMonitor) API call to set a DLL to be loaded at startup. (Citation: AddMonitor) This DLL can be located in <code>C:\\Windows\\System32</code> and will be loaded by the print spooler service, spoolsv.exe, on boot. The spoolsv.exe process also runs under SYSTEM level permissions. (Citation: Bloxham) Alternatively, an arbitrary DLL can be loaded if permissions allow writing a fully-qualified pathname for that DLL to <code>HKLM\\SYSTEM\\CurrentControlSet\\Control\\Print\\Monitors</code>." ;
    skos:exactMatch d3f:T1013,
        mitre-attack:T1013 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.010" .

d3f:T1014 a owl:Class ;
    rdfs:label "T1014" ;
    d3f:attack-id "T1014" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Rootkit" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may use rootkits to hide the presence of programs, files, network connections, services, drivers, and other system components. Rootkits are programs that hide the existence of malware by intercepting/hooking and modifying operating system API calls that supply system information. (Citation: Symantec Windows Rootkits)" ;
    skos:exactMatch d3f:T1014,
        mitre-attack:T1014 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1015 a owl:Class ;
    rdfs:label "T1015" ;
    d3f:attack-id "T1015" ;
    dcterms:title "Accessibility Features" ;
    rdfs:seeAlso d3f:T1546.008 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Windows contains accessibility features that may be launched with a key combination before a user has logged in (for example, when the user is on the Windows logon screen). An adversary can modify the way these programs are launched to get a command prompt or backdoor without logging in to the system." ;
    skos:exactMatch d3f:T1015,
        mitre-attack:T1015 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.008" .

d3f:T1017 a owl:Class ;
    rdfs:label "T1017" ;
    d3f:attack-id "T1017" ;
    dcterms:title "Application Deployment Software" ;
    rdfs:seeAlso d3f:T1072 ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Adversaries may deploy malicious software to systems within a network using application deployment systems employed by enterprise administrators. The permissions required for this action vary by system configuration; local credentials may be sufficient with direct access to the deployment server, or specific domain credentials may be required. However, the system may require an administrative account to log in or to perform software deployment." ;
    skos:exactMatch d3f:T1017,
        mitre-attack:T1017 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1072" .

d3f:T1018 a owl:Class ;
    rdfs:label "T1018" ;
    d3f:attack-id "T1018" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote System Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of other systems by IP address, hostname, or other logical identifier on a network that may be used for Lateral Movement from the current system. Functionality could exist within remote access tools to enable this, but utilities available on the operating system could also be used such as  [Ping](https://attack.mitre.org/software/S0097) or <code>net view</code> using [Net](https://attack.mitre.org/software/S0039)." ;
    skos:exactMatch d3f:T1018,
        mitre-attack:T1018 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1019 a owl:Class ;
    rdfs:label "T1019" ;
    d3f:attack-id "T1019" ;
    dcterms:title "System Firmware" ;
    rdfs:seeAlso d3f:T1542.001 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "The BIOS (Basic Input/Output System) and The Unified Extensible Firmware Interface (UEFI) or Extensible Firmware Interface (EFI) are examples of system firmware that operate as the software interface between the operating system and hardware of a computer. (Citation: Wikipedia BIOS) (Citation: Wikipedia UEFI) (Citation: About UEFI)" ;
    skos:exactMatch d3f:T1019,
        mitre-attack:T1019 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1542.001" .

d3f:T1022 a owl:Class ;
    rdfs:label "T1022" ;
    d3f:attack-id "T1022" ;
    dcterms:title "Data Encrypted" ;
    rdfs:seeAlso d3f:T1560 ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Data is encrypted before being exfiltrated in order to hide the information that is being exfiltrated from detection or to make the exfiltration less conspicuous upon inspection by a defender. The encryption is performed by a utility, programming library, or custom algorithm on the data itself and is considered separate from any encryption performed by the command and control or file transfer protocol. Common file archive formats that can encrypt files are RAR and zip." ;
    skos:exactMatch d3f:T1022,
        mitre-attack:T1022 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1560" .

d3f:T1023 a owl:Class ;
    rdfs:label "T1023" ;
    d3f:attack-id "T1023" ;
    dcterms:title "Shortcut Modification" ;
    rdfs:seeAlso d3f:T1547.009 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Shortcuts or symbolic links are ways of referencing other files or programs that will be opened or executed when the shortcut is clicked or executed by a system startup process. Adversaries could use shortcuts to execute their tools for persistence. They may create a new shortcut as a means of indirection that may use [Masquerading](https://attack.mitre.org/techniques/T1036) to look like a legitimate program. Adversaries could also edit the target path or entirely replace an existing shortcut so their tools will be executed instead of the intended legitimate program." ;
    skos:exactMatch d3f:T1023,
        mitre-attack:T1023 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.009" .

d3f:T1024 a owl:Class ;
    rdfs:label "T1024" ;
    d3f:attack-id "T1024" ;
    dcterms:title "Custom Cryptographic Protocol" ;
    rdfs:seeAlso d3f:T1573 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may use a custom cryptographic protocol or algorithm to hide command and control traffic. A simple scheme, such as XOR-ing the plaintext with a fixed key, will produce a very weak ciphertext." ;
    skos:exactMatch d3f:T1024,
        mitre-attack:T1024 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1573" .

d3f:T1025 a owl:Class ;
    rdfs:label "T1025" ;
    d3f:attack-id "T1025" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data from Removable Media" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may search connected removable media on computers they have compromised to find files of interest. Sensitive data can be collected from any removable media (optical disk drive, USB memory, etc.) connected to the compromised system prior to Exfiltration. Interactive command shells may be in use, and common functionality within [cmd](https://attack.mitre.org/software/S0106) may be used to gather information." ;
    skos:exactMatch d3f:T1025,
        mitre-attack:T1025 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1026 a owl:Class ;
    rdfs:label "T1026" ;
    d3f:attack-id "T1026" ;
    dcterms:title "Multiband Communication" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "**This technique has been deprecated and should no longer be used.**" ;
    skos:exactMatch d3f:T1026,
        mitre-attack:T1026 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated and should no longer be used.**" .

d3f:T1028 a owl:Class ;
    rdfs:label "T1028" ;
    d3f:attack-id "T1028" ;
    dcterms:title "Windows Remote Management" ;
    rdfs:seeAlso d3f:T1021.006 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "Windows Remote Management (WinRM) is the name of both a Windows service and a protocol that allows a user to interact with a remote system (e.g., run an executable, modify the Registry, modify services). (Citation: Microsoft WinRM) It may be called with the <code>winrm</code> command or by any number of programs such as PowerShell. (Citation: Jacobsen 2014)" ;
    skos:exactMatch d3f:T1028,
        mitre-attack:T1028 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1021.006" .

d3f:T1029 a owl:Class ;
    rdfs:label "T1029" ;
    d3f:attack-id "T1029" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Scheduled Transfer" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may schedule data exfiltration to be performed only at certain times of day or at certain intervals. This could be done to blend traffic patterns with normal activity or availability." ;
    skos:exactMatch d3f:T1029,
        mitre-attack:T1029 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1030 a owl:Class ;
    rdfs:label "T1030" ;
    d3f:attack-id "T1030" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data Transfer Size Limits" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "An adversary may exfiltrate data in fixed size chunks instead of whole files or limit packet sizes below certain thresholds. This approach may be used to avoid triggering network data transfer threshold alerts." ;
    skos:exactMatch d3f:T1030,
        mitre-attack:T1030 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1031 a owl:Class ;
    rdfs:label "T1031" ;
    d3f:attack-id "T1031" ;
    dcterms:title "Modify Existing Service" ;
    rdfs:seeAlso d3f:T1543.003 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Windows service configuration information, including the file path to the service's executable or recovery programs/commands, is stored in the Registry. Service configurations can be modified using utilities such as sc.exe and [Reg](https://attack.mitre.org/software/S0075)." ;
    skos:exactMatch d3f:T1031,
        mitre-attack:T1031 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1543.003" .

d3f:T1032 a owl:Class ;
    rdfs:label "T1032" ;
    d3f:attack-id "T1032" ;
    dcterms:title "Standard Cryptographic Protocol" ;
    rdfs:seeAlso d3f:T1573 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may explicitly employ a known encryption algorithm to conceal command and control traffic rather than relying on any inherent protections provided by a communication protocol. Despite the use of a secure algorithm, these implementations may be vulnerable to reverse engineering if necessary secret keys are encoded and/or generated within malware samples/configuration files." ;
    skos:exactMatch d3f:T1032,
        mitre-attack:T1032 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1573" .

d3f:T1033 a owl:Class ;
    rdfs:label "T1033" ;
    d3f:attack-id "T1033" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Owner/User Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to identify the primary user, currently logged in user, set of users that commonly uses a system, or whether a user is actively using the system. They may do this, for example, by retrieving account usernames or by using [OS Credential Dumping](https://attack.mitre.org/techniques/T1003). The information may be collected in a number of different ways using other Discovery techniques, because user and username details are prevalent throughout a system and include running process ownership, file/directory ownership, session information, and system logs. Adversaries may use the information from [System Owner/User Discovery](https://attack.mitre.org/techniques/T1033) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1033,
        mitre-attack:T1033 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1034 a owl:Class ;
    rdfs:label "T1034" ;
    d3f:attack-id "T1034" ;
    dcterms:title "Path Interception" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Path Interception by PATH Environment Variable](https://attack.mitre.org/techniques/T1574/007), [Path Interception by Search Order Hijacking](https://attack.mitre.org/techniques/T1574/008), and/or [Path Interception by Unquoted Path](https://attack.mitre.org/techniques/T1574/009).**" ;
    skos:exactMatch d3f:T1034,
        mitre-attack:T1034 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Path Interception by PATH Environment Variable](https://attack.mitre.org/techniques/T1574/007), [Path Interception by Search Order Hijacking](https://attack.mitre.org/techniques/T1574/008), and/or [Path Interception by Unquoted Path](https://attack.mitre.org/techniques/T1574/009).**" .

d3f:T1035 a owl:Class ;
    rdfs:label "T1035" ;
    d3f:attack-id "T1035" ;
    dcterms:title "Service Execution" ;
    rdfs:seeAlso d3f:T1569.002 ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may execute a binary, command, or script via a method that interacts with Windows services, such as the Service Control Manager. This can be done by either creating a new service or modifying an existing service. This technique is the execution used in conjunction with [New Service](https://attack.mitre.org/techniques/T1050) and [Modify Existing Service](https://attack.mitre.org/techniques/T1031) during service persistence or privilege escalation." ;
    skos:exactMatch d3f:T1035,
        mitre-attack:T1035 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1569.002" .

d3f:T1038 a owl:Class ;
    rdfs:label "T1038" ;
    d3f:attack-id "T1038" ;
    dcterms:title "DLL Search Order Hijacking" ;
    rdfs:seeAlso d3f:T1574.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Windows systems use a common method to look for required DLLs to load into a program. (Citation: Microsoft DLL Search) Adversaries may take advantage of the Windows DLL search order and programs that ambiguously specify DLLs to gain privilege escalation and persistence." ;
    skos:exactMatch d3f:T1038,
        mitre-attack:T1038 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1574.001" .

d3f:T1039 a owl:Class ;
    rdfs:label "T1039" ;
    d3f:attack-id "T1039" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Data from Network Shared Drive" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may search network shares on computers they have compromised to find files of interest. Sensitive data can be collected from remote systems via shared network drives (host shared directory, network file server, etc.) that are accessible from the current system prior to Exfiltration. Interactive command shells may be in use, and common functionality within [cmd](https://attack.mitre.org/software/S0106) may be used to gather information." ;
    skos:exactMatch d3f:T1039,
        mitre-attack:T1039 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1040 a owl:Class ;
    rdfs:label "T1040" ;
    d3f:attack-id "T1040" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Sniffing" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DiscoveryTechnique ],
        d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may passively sniff network traffic to capture information about an environment, including authentication material passed over the network. Network sniffing refers to using the network interface on a system to monitor or capture information sent over a wired or wireless connection. An adversary may place a network interface into promiscuous mode to passively access data in transit over the network, or use span ports to capture a larger amount of data." ;
    skos:exactMatch d3f:T1040,
        mitre-attack:T1040 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1041 a owl:Class ;
    rdfs:label "T1041" ;
    d3f:attack-id "T1041" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exfiltration Over C2 Channel" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may steal data by exfiltrating it over an existing command and control channel. Stolen data is encoded into the normal communications channel using the same protocol as command and control communications." ;
    skos:exactMatch d3f:T1041,
        mitre-attack:T1041 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1042 a owl:Class ;
    rdfs:label "T1042" ;
    d3f:attack-id "T1042" ;
    dcterms:title "Change Default File Association" ;
    rdfs:seeAlso d3f:T1546.001 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "When a file is opened, the default program used to open the file (also called the file association or handler) is checked. File association selections are stored in the Windows Registry and can be edited by users, administrators, or programs that have Registry access (Citation: Microsoft Change Default Programs) (Citation: Microsoft File Handlers) or by administrators using the built-in assoc utility. (Citation: Microsoft Assoc Oct 2017) Applications can modify the file association for a given file extension to call an arbitrary program when a file with the given extension is opened." ;
    skos:exactMatch d3f:T1042,
        mitre-attack:T1042 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.001" .

d3f:T1043 a owl:Class ;
    rdfs:label "T1043" ;
    d3f:attack-id "T1043" ;
    dcterms:title "Commonly Used Port" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Non-Standard Port](https://attack.mitre.org/techniques/T1571) where appropriate.**" ;
    skos:exactMatch d3f:T1043,
        mitre-attack:T1043 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Non-Standard Port](https://attack.mitre.org/techniques/T1571) where appropriate.**" .

d3f:T1044 a owl:Class ;
    rdfs:label "T1044" ;
    d3f:attack-id "T1044" ;
    dcterms:title "File System Permissions Weakness" ;
    rdfs:seeAlso d3f:T1574.010 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Processes may automatically execute specific binaries as part of their functionality or to perform other actions. If the permissions on the file system directory containing a target binary, or permissions on the binary itself, are improperly set, then the target binary may be overwritten with another binary using user-level permissions and executed by the original process. If the original process and thread are running under a higher permissions level, then the replaced binary will also execute under higher-level permissions, which could include SYSTEM." ;
    skos:exactMatch d3f:T1044,
        mitre-attack:T1044 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1574.010" .

d3f:T1045 a owl:Class ;
    rdfs:label "T1045" ;
    d3f:attack-id "T1045" ;
    dcterms:title "Software Packing" ;
    rdfs:seeAlso d3f:T1027.002 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Software packing is a method of compressing or encrypting an executable. Packing an executable changes the file signature in an attempt to avoid signature-based detection. Most decompression techniques decompress the executable code in memory." ;
    skos:exactMatch d3f:T1045,
        mitre-attack:T1045 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1027.002" .

d3f:T1046 a owl:Class ;
    rdfs:label "T1046" ;
    d3f:attack-id "T1046" ;
    dcterms:title "Network Service Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of services running on remote hosts and local network infrastructure devices, including those that may be vulnerable to remote software exploitation. Common methods to acquire this information include port and/or vulnerability scans using tools that are brought onto a system.(Citation: CISA AR21-126A FIVEHANDS May 2021)" ;
    skos:exactMatch d3f:T1046,
        mitre-attack:T1046 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1047 a owl:Class ;
    rdfs:label "T1047" ;
    d3f:attack-id "T1047" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Windows Management Instrumentation" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse Windows Management Instrumentation (WMI) to execute malicious commands and payloads. WMI is designed for programmers and is the infrastructure for management data and operations on Windows systems.(Citation: WMI 1-3) WMI is an administration feature that provides a uniform environment to access Windows system components." ;
    skos:exactMatch d3f:T1047,
        mitre-attack:T1047 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1049 a owl:Class ;
    rdfs:label "T1049" ;
    d3f:attack-id "T1049" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Network Connections Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of network connections to or from the compromised system they are currently accessing or from remote systems by querying for information over the network." ;
    skos:exactMatch d3f:T1049,
        mitre-attack:T1049 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1050 a owl:Class ;
    rdfs:label "T1050" ;
    d3f:attack-id "T1050" ;
    dcterms:title "New Service" ;
    rdfs:seeAlso d3f:T1543.003 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "When operating systems boot up, they can start programs or applications called services that perform background system functions. (Citation: TechNet Services) A service's configuration information, including the file path to the service's executable, is stored in the Windows Registry." ;
    skos:exactMatch d3f:T1050,
        mitre-attack:T1050 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1543.003" .

d3f:T1051 a owl:Class ;
    rdfs:label "T1051" ;
    d3f:attack-id "T1051" ;
    dcterms:title "Shared Webroot" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "**This technique has been deprecated and should no longer be used.**" ;
    skos:exactMatch d3f:T1051,
        mitre-attack:T1051 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated and should no longer be used.**" .

d3f:T1054 a owl:Class ;
    rdfs:label "T1054" ;
    d3f:attack-id "T1054" ;
    dcterms:title "Indicator Blocking" ;
    rdfs:seeAlso d3f:T1562.006 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "An adversary may attempt to block indicators or events typically captured by sensors from being gathered and analyzed. This could include maliciously redirecting (Citation: Microsoft Lamin Sept 2017) or even disabling host-based sensors, such as Event Tracing for Windows (ETW),(Citation: Microsoft About Event Tracing 2018) by tampering settings that control the collection and flow of event telemetry. (Citation: Medium Event Tracing Tampering 2018) These settings may be stored on the system in configuration files and/or in the Registry as well as being accessible via administrative utilities such as [PowerShell](https://attack.mitre.org/techniques/T1086) or [Windows Management Instrumentation](https://attack.mitre.org/techniques/T1047)." ;
    skos:exactMatch d3f:T1054,
        mitre-attack:T1054 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1562.006" .

d3f:T1057 a owl:Class ;
    rdfs:label "T1057" ;
    d3f:attack-id "T1057" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get information about running processes on a system. Information obtained could be used to gain an understanding of common software/applications running on systems within the network. Administrator or otherwise elevated access may provide better process details. Adversaries may use the information from [Process Discovery](https://attack.mitre.org/techniques/T1057) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1057,
        mitre-attack:T1057 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1058 a owl:Class ;
    rdfs:label "T1058" ;
    d3f:attack-id "T1058" ;
    dcterms:title "Service Registry Permissions Weakness" ;
    rdfs:seeAlso d3f:T1574.011 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Windows stores local service configuration information in the Registry under <code>HKLM\\SYSTEM\\CurrentControlSet\\Services</code>. The information stored under a service's Registry keys can be manipulated to modify a service's execution parameters through tools such as the service controller, sc.exe, [PowerShell](https://attack.mitre.org/techniques/T1086), or [Reg](https://attack.mitre.org/software/S0075). Access to Registry keys is controlled through Access Control Lists and permissions. (Citation: MSDN Registry Key Security)" ;
    skos:exactMatch d3f:T1058,
        mitre-attack:T1058 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1574.011" .

d3f:T1060 a owl:Class ;
    rdfs:label "T1060" ;
    d3f:attack-id "T1060" ;
    dcterms:title "Registry Run Keys / Startup Folder" ;
    rdfs:seeAlso d3f:T1547.001 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may achieve persistence by adding a program to a startup folder or referencing it with a Registry run key. Adding an entry to the \"run keys\" in the Registry or startup folder will cause the program referenced to be executed when a user logs in. (Citation: Microsoft Run Key) These programs will be executed under the context of the user and will have the account's associated permissions level." ;
    skos:exactMatch d3f:T1060,
        mitre-attack:T1060 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.001" .

d3f:T1061 a owl:Class ;
    rdfs:label "T1061" ;
    d3f:attack-id "T1061" ;
    dcterms:title "Graphical User Interface" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Remote Services](https://attack.mitre.org/techniques/T1021) where appropriate.**" ;
    skos:exactMatch d3f:T1061,
        mitre-attack:T1061 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Remote Services](https://attack.mitre.org/techniques/T1021) where appropriate.**" .

d3f:T1062 a owl:Class ;
    rdfs:label "T1062" ;
    d3f:attack-id "T1062" ;
    dcterms:title "Hypervisor" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "**This technique has been deprecated and should no longer be used.**" ;
    skos:exactMatch d3f:T1062,
        mitre-attack:T1062 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated and should no longer be used.**" .

d3f:T1063 a owl:Class ;
    rdfs:label "T1063" ;
    d3f:attack-id "T1063" ;
    dcterms:title "Security Software Discovery" ;
    rdfs:seeAlso d3f:T1518.001 ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of security software, configurations, defensive tools, and sensors that are installed on the system. This may include things such as local firewall rules and anti-virus. Adversaries may use the information from [Security Software Discovery](https://attack.mitre.org/techniques/T1063) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1063,
        mitre-attack:T1063 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1518.001" .

d3f:T1064 a owl:Class ;
    rdfs:label "T1064" ;
    d3f:attack-id "T1064" ;
    dcterms:title "Scripting" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Command and Scripting Interpreter](https://attack.mitre.org/techniques/T1059) where appropriate.**" ;
    skos:exactMatch d3f:T1064,
        mitre-attack:T1064 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Command and Scripting Interpreter](https://attack.mitre.org/techniques/T1059) where appropriate.**" .

d3f:T1065 a owl:Class ;
    rdfs:label "T1065" ;
    d3f:attack-id "T1065" ;
    dcterms:title "Uncommonly Used Port" ;
    rdfs:seeAlso d3f:T1571 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may conduct C2 communications over a non-standard port to bypass proxies and firewalls that have been improperly configured." ;
    skos:exactMatch d3f:T1065,
        mitre-attack:T1065 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1571" .

d3f:T1066 a owl:Class ;
    rdfs:label "T1066" ;
    d3f:attack-id "T1066" ;
    dcterms:title "Indicator Removal from Tools" ;
    rdfs:seeAlso d3f:T1027.005 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "If a malicious tool is detected and quarantined or otherwise curtailed, an adversary may be able to determine why the malicious tool was detected (the indicator), modify the tool by removing the indicator, and use the updated version that is no longer detected by the target's defensive systems or subsequent targets that may use similar systems." ;
    skos:exactMatch d3f:T1066,
        mitre-attack:T1066 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1027.005" .

d3f:T1067 a owl:Class ;
    rdfs:label "T1067" ;
    d3f:attack-id "T1067" ;
    dcterms:title "Bootkit" ;
    rdfs:seeAlso d3f:T1542.003 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "A bootkit is a malware variant that modifies the boot sectors of a hard drive, including the Master Boot Record (MBR) and Volume Boot Record (VBR). (Citation: MTrends 2016)" ;
    skos:exactMatch d3f:T1067,
        mitre-attack:T1067 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1542.003" .

d3f:T1068 a owl:Class ;
    rdfs:label "T1068" ;
    d3f:attack-id "T1068" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exploitation for Privilege Escalation" ;
    rdfs:subClassOf d3f:PrivilegeEscalationTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities in an attempt to elevate privileges. Exploitation of a software vulnerability occurs when an adversary takes advantage of a programming error in a program, service, or within the operating system software or kernel itself to execute adversary-controlled code. Security constructs such as permission levels will often hinder access to information and use of certain techniques, so adversaries will likely need to perform privilege escalation to include use of software exploitation to circumvent those restrictions." ;
    skos:exactMatch d3f:T1068,
        mitre-attack:T1068 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1073 a owl:Class ;
    rdfs:label "T1073" ;
    d3f:attack-id "T1073" ;
    dcterms:title "DLL Side-Loading" ;
    rdfs:seeAlso d3f:T1574.002 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Programs may specify DLLs that are loaded at runtime. Programs that improperly or vaguely specify a required DLL may be open to a vulnerability in which an unintended DLL is loaded. Side-loading vulnerabilities specifically occur when Windows Side-by-Side (WinSxS) manifests (Citation: MSDN Manifests) are not explicit enough about characteristics of the DLL to be loaded. Adversaries may take advantage of a legitimate program that is vulnerable to side-loading to load a malicious DLL. (Citation: Stewart 2014)" ;
    skos:exactMatch d3f:T1073,
        mitre-attack:T1073 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1574.002" .

d3f:T1075 a owl:Class ;
    rdfs:label "T1075" ;
    d3f:attack-id "T1075" ;
    dcterms:title "Pass the Hash" ;
    rdfs:seeAlso d3f:T1550.002 ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Pass the hash (PtH) is a method of authenticating as a user without having access to the user's cleartext password. This method bypasses standard authentication steps that require a cleartext password, moving directly into the portion of the authentication that uses the password hash. In this technique, valid password hashes for the account being used are captured using a Credential Access technique. Captured hashes are used with PtH to authenticate as that user. Once authenticated, PtH may be used to perform actions on local or remote systems." ;
    skos:exactMatch d3f:T1075,
        mitre-attack:T1075 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1550.002" .

d3f:T1076 a owl:Class ;
    rdfs:label "T1076" ;
    d3f:attack-id "T1076" ;
    dcterms:title "Remote Desktop Protocol" ;
    rdfs:seeAlso d3f:T1021.001 ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Remote desktop is a common feature in operating systems. It allows a user to log into an interactive session with a system desktop graphical user interface on a remote system. Microsoft refers to its implementation of the Remote Desktop Protocol (RDP) as Remote Desktop Services (RDS). (Citation: TechNet Remote Desktop Services) There are other implementations and third-party tools that provide graphical access [Remote Services](https://attack.mitre.org/techniques/T1021) similar to RDS." ;
    skos:exactMatch d3f:T1076,
        mitre-attack:T1076 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1021.001" .

d3f:T1077 a owl:Class ;
    rdfs:label "T1077" ;
    d3f:attack-id "T1077" ;
    dcterms:title "Windows Admin Shares" ;
    rdfs:seeAlso d3f:T1021.002 ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Windows systems have hidden network shares that are accessible only to administrators and provide the ability for remote file copy and other administrative functions. Example network shares include <code>C$</code>, <code>ADMIN$</code>, and <code>IPC$</code>." ;
    skos:exactMatch d3f:T1077,
        mitre-attack:T1077 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1021.002" .

d3f:T1079 a owl:Class ;
    rdfs:label "T1079" ;
    d3f:attack-id "T1079" ;
    dcterms:title "Multilayer Encryption" ;
    rdfs:seeAlso d3f:T1573 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "An adversary performs C2 communications using multiple layers of encryption, typically (but not exclusively) tunneling a custom encryption scheme within a protocol encryption scheme such as HTTPS or SMTPS." ;
    skos:exactMatch d3f:T1079,
        mitre-attack:T1079 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1573" .

d3f:T1080 a owl:Class ;
    rdfs:label "T1080" ;
    d3f:attack-id "T1080" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Taint Shared Content" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Adversaries may deliver payloads to remote systems by adding content to shared storage locations, such as network drives or internal code repositories. Content stored on network drives or in other shared locations may be tainted by adding malicious programs, scripts, or exploit code to otherwise valid files. Once a user opens the shared tainted content, the malicious portion can be executed to run the adversary's code on a remote system. Adversaries may use tainted shared content to move laterally." ;
    skos:exactMatch d3f:T1080,
        mitre-attack:T1080 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1081 a owl:Class ;
    rdfs:label "T1081" ;
    d3f:attack-id "T1081" ;
    dcterms:title "Credentials in Files" ;
    rdfs:seeAlso d3f:T1552.001 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may search local file systems and remote file shares for files containing passwords. These can be files created by users to store their own credentials, shared credential stores for a group of individuals, configuration files containing passwords for a system or service, or source code/binary files containing embedded passwords." ;
    skos:exactMatch d3f:T1081,
        mitre-attack:T1081 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1552.001" .

d3f:T1082 a owl:Class ;
    rdfs:label "T1082" ;
    d3f:attack-id "T1082" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Information Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "An adversary may attempt to get detailed information about the operating system and hardware, including version, patches, hotfixes, service packs, and architecture. Adversaries may use the information from [System Information Discovery](https://attack.mitre.org/techniques/T1082) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1082,
        mitre-attack:T1082 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1083 a owl:Class ;
    rdfs:label "T1083" ;
    d3f:attack-id "T1083" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "File and Directory Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may enumerate files and directories or may search in specific locations of a host or network share for certain information within a file system. Adversaries may use the information from [File and Directory Discovery](https://attack.mitre.org/techniques/T1083) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1083,
        mitre-attack:T1083 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1084 a owl:Class ;
    rdfs:label "T1084" ;
    d3f:attack-id "T1084" ;
    dcterms:title "Windows Management Instrumentation Event Subscription" ;
    rdfs:seeAlso d3f:T1546.003 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Windows Management Instrumentation (WMI) can be used to install event filters, providers, consumers, and bindings that execute code when a defined event occurs. Adversaries may use the capabilities of WMI to subscribe to an event and execute arbitrary code when that event occurs, providing persistence on a system. Adversaries may attempt to evade detection of this technique by compiling WMI scripts into Windows Management Object (MOF) files (.mof extension). (Citation: Dell WMI Persistence) Examples of events that may be subscribed to are the wall clock time or the computer's uptime. (Citation: Kazanciyan 2014) Several threat groups have reportedly used this technique to maintain persistence. (Citation: Mandiant M-Trends 2015)" ;
    skos:exactMatch d3f:T1084,
        mitre-attack:T1084 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.003" .

d3f:T1085 a owl:Class ;
    rdfs:label "T1085" ;
    d3f:attack-id "T1085" ;
    dcterms:title "Rundll32" ;
    rdfs:seeAlso d3f:T1218.011 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "The rundll32.exe program can be called to execute an arbitrary binary. Adversaries may take advantage of this functionality to proxy execution of code to avoid triggering security tools that may not monitor execution of the rundll32.exe process because of whitelists or false positives from Windows using rundll32.exe for normal operations." ;
    skos:exactMatch d3f:T1085,
        mitre-attack:T1085 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.011" .

d3f:T1086 a owl:Class ;
    rdfs:label "T1086" ;
    d3f:attack-id "T1086" ;
    dcterms:title "PowerShell" ;
    rdfs:seeAlso d3f:T1059.001 ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "PowerShell is a powerful interactive command-line interface and scripting environment included in the Windows operating system. (Citation: TechNet PowerShell) Adversaries can use PowerShell to perform a number of actions, including discovery of information and execution of code. Examples include the Start-Process cmdlet which can be used to run an executable and the Invoke-Command cmdlet which runs a command locally or on a remote computer." ;
    skos:exactMatch d3f:T1086,
        mitre-attack:T1086 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1059.001" .

d3f:T1088 a owl:Class ;
    rdfs:label "T1088" ;
    d3f:attack-id "T1088" ;
    dcterms:title "Bypass User Account Control" ;
    rdfs:seeAlso d3f:T1548.002 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Windows User Account Control (UAC) allows a program to elevate its privileges to perform a task under administrator-level permissions by prompting the user for confirmation. The impact to the user ranges from denying the operation under high enforcement to allowing the user to perform the action if they are in the local administrators group and click through the prompt or allowing them to enter an administrator password to complete the action. (Citation: TechNet How UAC Works)" ;
    skos:exactMatch d3f:T1088,
        mitre-attack:T1088 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1548.002" .

d3f:T1089 a owl:Class ;
    rdfs:label "T1089" ;
    d3f:attack-id "T1089" ;
    dcterms:title "Disabling Security Tools" ;
    rdfs:seeAlso d3f:T1562.001 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may disable security tools to avoid possible detection of their tools and activities. This can take the form of killing security software or event logging processes, deleting Registry keys so that tools do not start at run time, or other methods to interfere with security scanning or event reporting." ;
    skos:exactMatch d3f:T1089,
        mitre-attack:T1089 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1562.001" .

d3f:T1091 a owl:Class ;
    rdfs:label "T1091" ;
    d3f:attack-id "T1091" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Replication Through Removable Media" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may move onto systems, possibly those on disconnected or air-gapped networks, by copying malware to removable media and taking advantage of Autorun features when the media is inserted into a system and executes. In the case of Lateral Movement, this may occur through modification of executable files stored on removable media or by copying malware and renaming it to look like a legitimate file to trick users into executing it on a separate system. In the case of Initial Access, this may occur through manual manipulation of the media, modification of systems used to initially format the media, or modification to the media's firmware itself." ;
    skos:exactMatch d3f:T1091,
        mitre-attack:T1091 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1092 a owl:Class ;
    rdfs:label "T1092" ;
    d3f:attack-id "T1092" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Communication Through Removable Media" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries can perform command and control between compromised hosts on potentially disconnected networks using removable media to transfer commands from system to system.(Citation: ESET Sednit USBStealer 2014) Both systems would need to be compromised, with the likelihood that an Internet-connected system was compromised first and the second through lateral movement by [Replication Through Removable Media](https://attack.mitre.org/techniques/T1091). Commands and files would be relayed from the disconnected system to the Internet-connected system to which the adversary has direct access." ;
    skos:exactMatch d3f:T1092,
        mitre-attack:T1092 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1093 a owl:Class ;
    rdfs:label "T1093" ;
    d3f:attack-id "T1093" ;
    dcterms:title "Process Hollowing" ;
    rdfs:seeAlso d3f:T1055.012 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Process hollowing occurs when a process is created in a suspended state then its memory is unmapped and replaced with malicious code. Similar to [Process Injection](https://attack.mitre.org/techniques/T1055), execution of the malicious code is masked under a legitimate process and may evade defenses and detection analysis. (Citation: Leitch Hollowing) (Citation: Elastic Process Injection July 2017)" ;
    skos:exactMatch d3f:T1093,
        mitre-attack:T1093 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1055.012" .

d3f:T1094 a owl:Class ;
    rdfs:label "T1094" ;
    d3f:attack-id "T1094" ;
    dcterms:title "Custom Command and Control Protocol" ;
    rdfs:seeAlso d3f:T1095 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may communicate using a custom command and control protocol instead of encapsulating commands/data in an existing [Application Layer Protocol](https://attack.mitre.org/techniques/T1071). Implementations include mimicking well-known protocols or developing custom protocols (including raw sockets) on top of fundamental protocols provided by TCP/IP/another standard network stack." ;
    skos:exactMatch d3f:T1094,
        mitre-attack:T1094 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1095" .

d3f:T1096 a owl:Class ;
    rdfs:label "T1096" ;
    d3f:attack-id "T1096" ;
    dcterms:title "NTFS File Attributes" ;
    rdfs:seeAlso d3f:T1564.004 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Every New Technology File System (NTFS) formatted partition contains a Master File Table (MFT) that maintains a record for every file/directory on the partition. (Citation: SpectorOps Host-Based Jul 2017) Within MFT entries are file attributes, (Citation: Microsoft NTFS File Attributes Aug 2010) such as Extended Attributes (EA) and Data [known as Alternate Data Streams (ADSs) when more than one Data attribute is present], that can be used to store arbitrary data (and even complete files). (Citation: SpectorOps Host-Based Jul 2017) (Citation: Microsoft File Streams) (Citation: MalwareBytes ADS July 2015) (Citation: Microsoft ADS Mar 2014)" ;
    skos:exactMatch d3f:T1096,
        mitre-attack:T1096 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1564.004" .

d3f:T1097 a owl:Class ;
    rdfs:label "T1097" ;
    d3f:attack-id "T1097" ;
    dcterms:title "Pass the Ticket" ;
    rdfs:seeAlso d3f:T1550.003 ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Pass the ticket (PtT) is a method of authenticating to a system using Kerberos tickets without having access to an account's password. Kerberos authentication can be used as the first step to lateral movement to a remote system." ;
    skos:exactMatch d3f:T1097,
        mitre-attack:T1097 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1550.003" .

d3f:T1099 a owl:Class ;
    rdfs:label "T1099" ;
    d3f:attack-id "T1099" ;
    dcterms:title "Timestomp" ;
    rdfs:seeAlso d3f:T1070.006 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may take actions to hide the deployment of new, or modification of existing files to obfuscate their activities. Timestomping is a technique that modifies the timestamps of a file (the modify, access, create, and change times), often to mimic files that are in the same folder. This is done, for example, on files that have been modified or created by the adversary so that they do not appear conspicuous to forensic investigators or file analysis tools. Timestomping may be used along with file name [Masquerading](https://attack.mitre.org/techniques/T1036) to hide malware and tools. (Citation: WindowsIR Anti-Forensic Techniques)" ;
    skos:exactMatch d3f:T1099,
        mitre-attack:T1099 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1070.006" .

d3f:T1100 a owl:Class ;
    rdfs:label "T1100" ;
    d3f:attack-id "T1100" ;
    dcterms:title "Web Shell" ;
    rdfs:seeAlso d3f:T1505.003 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "A Web shell is a Web script that is placed on an openly accessible Web server to allow an adversary to use the Web server as a gateway into a network. A Web shell may provide a set of functions to execute or a command-line interface on the system that hosts the Web server. In addition to a server-side script, a Web shell may have a client interface program that is used to talk to the Web server (see, for example, China Chopper Web shell client). (Citation: Lee 2013)" ;
    skos:exactMatch d3f:T1100,
        mitre-attack:T1100 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1505.003" .

d3f:T1101 a owl:Class ;
    rdfs:label "T1101" ;
    d3f:attack-id "T1101" ;
    dcterms:title "Security Support Provider" ;
    rdfs:seeAlso d3f:T1547.005 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Windows Security Support Provider (SSP) DLLs are loaded into the Local Security Authority (LSA) process at system start. Once loaded into the LSA, SSP DLLs have access to encrypted and plaintext passwords that are stored in Windows, such as any logged-on user's Domain password or smart card PINs. The SSP configuration is stored in two Registry keys: <code>HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa\\Security Packages</code> and <code>HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa\\OSConfig\\Security Packages</code>. An adversary may modify these Registry keys to add new SSPs, which will be loaded the next time the system boots, or when the AddSecurityPackage Windows API function is called." ;
    skos:exactMatch d3f:T1101,
        mitre-attack:T1101 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.005" .

d3f:T1103 a owl:Class ;
    rdfs:label "T1103" ;
    d3f:attack-id "T1103" ;
    dcterms:title "AppInit DLLs" ;
    rdfs:seeAlso d3f:T1546.010 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Dynamic-link libraries (DLLs) that are specified in the AppInit_DLLs value in the Registry keys <code>HKEY_LOCAL_MACHINE\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Windows</code> or <code>HKEY_LOCAL_MACHINE\\Software\\Wow6432Node\\Microsoft\\Windows NT\\CurrentVersion\\Windows</code> are loaded by user32.dll into every process that loads user32.dll. In practice this is nearly every program, since user32.dll is a very common library. (Citation: Elastic Process Injection July 2017) Similar to [Process Injection](https://attack.mitre.org/techniques/T1055), these values can be abused to obtain persistence and privilege escalation by causing a malicious DLL to be loaded and run in the context of separate processes on the computer. (Citation: AppInit Registry)" ;
    skos:exactMatch d3f:T1103,
        mitre-attack:T1103 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.010" .

d3f:T1104 a owl:Class ;
    rdfs:label "T1104" ;
    d3f:attack-id "T1104" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multi-Stage Channels" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may create multiple stages for command and control that are employed under different conditions or for certain functions. Use of multiple stages may obfuscate the command and control channel to make detection more difficult." ;
    skos:exactMatch d3f:T1104,
        mitre-attack:T1104 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1105 a owl:Class ;
    rdfs:label "T1105" ;
    d3f:attack-id "T1105" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Ingress Tool Transfer" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Session is initiated by the client, and may be a custom protocol which is why it is related to generic network traffic instead of file transfer network traffic." ;
    skos:exactMatch d3f:T1105,
        mitre-attack:T1105 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1106 a owl:Class ;
    rdfs:label "T1106" ;
    d3f:attack-id "T1106" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Native API" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may interact with the native OS application programming interface (API) to execute behaviors. Native APIs provide a controlled means of calling low-level OS services within the kernel, such as those involving hardware/devices, memory, and processes.(Citation: NT API Windows)(Citation: Linux Kernel API) These native APIs are leveraged by the OS during system boot (when other system components are not yet initialized) as well as carrying out tasks and requests during routine operations." ;
    skos:exactMatch d3f:T1106,
        mitre-attack:T1106 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1107 a owl:Class ;
    rdfs:label "T1107" ;
    d3f:attack-id "T1107" ;
    dcterms:title "File Deletion" ;
    rdfs:seeAlso d3f:T1070.004 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may delete files left behind by the actions of their intrusion activity. Malware, tools, or other non-native files dropped or created on a system by an adversary may leave traces to indicate to what was done within a network and how. Removal of these files can occur during an intrusion, or as part of a post-intrusion process to minimize the adversary's footprint." ;
    skos:exactMatch d3f:T1107,
        mitre-attack:T1107 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1070.004" .

d3f:T1108 a owl:Class ;
    rdfs:label "T1108" ;
    d3f:attack-id "T1108" ;
    dcterms:title "Redundant Access" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Create Account](https://attack.mitre.org/techniques/T1136), [Web Shell](https://attack.mitre.org/techniques/T1505/003), and [External Remote Services](https://attack.mitre.org/techniques/T1133) where appropriate.**" ;
    skos:exactMatch d3f:T1108,
        mitre-attack:T1108 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Create Account](https://attack.mitre.org/techniques/T1136), [Web Shell](https://attack.mitre.org/techniques/T1505/003), and [External Remote Services](https://attack.mitre.org/techniques/T1133) where appropriate.**" .

d3f:T1109 a owl:Class ;
    rdfs:label "T1109" ;
    d3f:attack-id "T1109" ;
    dcterms:title "Component Firmware" ;
    rdfs:seeAlso d3f:T1542.002 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Some adversaries may employ sophisticated means to compromise computer components and install malicious firmware that will execute adversary code outside of the operating system and main system firmware or BIOS. This technique may be similar to [System Firmware](https://attack.mitre.org/techniques/T1019) but conducted upon other system components that may not have the same capability or level of integrity checking. Malicious device firmware could provide both a persistent level of access to systems despite potential typical failures to maintain access and hard disk re-images, as well as a way to evade host software-based defenses and integrity checks." ;
    skos:exactMatch d3f:T1109,
        mitre-attack:T1109 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1542.002" .

d3f:T1111 a owl:Class ;
    rdfs:label "T1111" ;
    d3f:attack-id "T1111" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Multi-Factor Authentication Interception" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may target multi-factor authentication (MFA) mechanisms, (i.e., smart cards, token generators, etc.) to gain access to credentials that can be used to access systems, services, and network resources. Use of MFA is recommended and provides a higher level of security than usernames and passwords alone, but organizations should be aware of techniques that could be used to intercept and bypass these security mechanisms." ;
    skos:exactMatch d3f:T1111,
        mitre-attack:T1111 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1112 a owl:Class ;
    rdfs:label "T1112" ;
    d3f:attack-id "T1112" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Modify Registry" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may interact with the Windows Registry to hide configuration information within Registry keys, remove information as part of cleaning up, or as part of other techniques to aid in persistence and execution." ;
    skos:exactMatch d3f:T1112,
        mitre-attack:T1112 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1113 a owl:Class ;
    rdfs:label "T1113" ;
    d3f:attack-id "T1113" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Screen Capture" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may attempt to take screen captures of the desktop to gather information over the course of an operation. Screen capturing functionality may be included as a feature of a remote access tool used in post-compromise operations. Taking a screenshot is also typically possible through native utilities or API calls, such as <code>CopyFromScreen</code>, <code>xwd</code>, or <code>screencapture</code>.(Citation: CopyFromScreen .NET)(Citation: Antiquated Mac Malware)" ;
    skos:exactMatch d3f:T1113,
        mitre-attack:T1113 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1115 a owl:Class ;
    rdfs:label "T1115" ;
    d3f:attack-id "T1115" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Clipboard Data" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may collect data stored in the clipboard from users copying information within or between applications." ;
    skos:exactMatch d3f:T1115,
        mitre-attack:T1115 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1116 a owl:Class ;
    rdfs:label "T1116" ;
    d3f:attack-id "T1116" ;
    dcterms:title "Code Signing" ;
    rdfs:seeAlso d3f:T1553.002 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Code signing provides a level of authenticity on a binary from the developer and a guarantee that the binary has not been tampered with. (Citation: Wikipedia Code Signing) However, adversaries are known to use code signing certificates to masquerade malware and tools as legitimate binaries (Citation: Janicab). The certificates used during an operation may be created, forged, or stolen by the adversary. (Citation: Securelist Digital Certificates) (Citation: Symantec Digital Certificates)" ;
    skos:exactMatch d3f:T1116,
        mitre-attack:T1116 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1553.002" .

d3f:T1117 a owl:Class ;
    rdfs:label "T1117" ;
    d3f:attack-id "T1117" ;
    dcterms:title "Regsvr32" ;
    rdfs:seeAlso d3f:T1218.010 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Regsvr32.exe is a command-line program used to register and unregister object linking and embedding controls, including dynamic link libraries (DLLs), on Windows systems. Regsvr32.exe can be used to execute arbitrary binaries. (Citation: Microsoft Regsvr32)" ;
    skos:exactMatch d3f:T1117,
        mitre-attack:T1117 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.010" .

d3f:T1118 a owl:Class ;
    rdfs:label "T1118" ;
    d3f:attack-id "T1118" ;
    dcterms:title "InstallUtil" ;
    rdfs:seeAlso d3f:T1218.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "InstallUtil is a command-line utility that allows for installation and uninstallation of resources by executing specific installer components specified in .NET binaries. (Citation: MSDN InstallUtil) InstallUtil is located in the .NET directories on a Windows system: <code>C:\\Windows\\Microsoft.NET\\Framework\\v<version>\\InstallUtil.exe</code> and <code>C:\\Windows\\Microsoft.NET\\Framework64\\v<version>\\InstallUtil.exe</code>. InstallUtil.exe is digitally signed by Microsoft." ;
    skos:exactMatch d3f:T1118,
        mitre-attack:T1118 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.004" .

d3f:T1119 a owl:Class ;
    rdfs:label "T1119" ;
    d3f:attack-id "T1119" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Automated Collection" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Once established within a system or network, an adversary may use automated techniques for collecting internal data. Methods for performing this technique could include use of a [Command and Scripting Interpreter](https://attack.mitre.org/techniques/T1059) to search for and copy information fitting set criteria such as file type, location, or name at specific time intervals." ;
    skos:exactMatch d3f:T1119,
        mitre-attack:T1119 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1120 a owl:Class ;
    rdfs:label "T1120" ;
    d3f:attack-id "T1120" ;
    dcterms:title "Peripheral Device Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to gather information about attached peripheral devices and components connected to a computer system.(Citation: Peripheral Discovery Linux)(Citation: Peripheral Discovery macOS) Peripheral devices could include auxiliary resources that support a variety of functionalities such as keyboards, printers, cameras, smart card readers, or removable storage. The information may be used to enhance their awareness of the system and network environment or may be used for further actions." ;
    skos:exactMatch d3f:T1120,
        mitre-attack:T1120 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1121 a owl:Class ;
    rdfs:label "T1121" ;
    d3f:attack-id "T1121" ;
    dcterms:title "Regsvcs/Regasm" ;
    rdfs:seeAlso d3f:T1218.009 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Regsvcs and Regasm are Windows command-line utilities that are used to register .NET Component Object Model (COM) assemblies. Both are digitally signed by Microsoft. (Citation: MSDN Regsvcs) (Citation: MSDN Regasm)" ;
    skos:exactMatch d3f:T1121,
        mitre-attack:T1121 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.009" .

d3f:T1122 a owl:Class ;
    rdfs:label "T1122" ;
    d3f:attack-id "T1122" ;
    dcterms:title "Component Object Model Hijacking" ;
    rdfs:seeAlso d3f:T1546.015 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "The Component Object Model (COM) is a system within Windows to enable interaction between software components through the operating system. (Citation: Microsoft Component Object Model) Adversaries can use this system to insert malicious code that can be executed in place of legitimate software through hijacking the COM references and relationships as a means for persistence. Hijacking a COM object requires a change in the Windows Registry to replace a reference to a legitimate system component which may cause that component to not work when executed. When that system component is executed through normal system operation the adversary's code will be executed instead. (Citation: GDATA COM Hijacking) An adversary is likely to hijack objects that are used frequently enough to maintain a consistent level of persistence, but are unlikely to break noticeable functionality within the system as to avoid system instability that could lead to detection." ;
    skos:exactMatch d3f:T1122,
        mitre-attack:T1122 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.015" .

d3f:T1123 a owl:Class ;
    rdfs:label "T1123" ;
    d3f:attack-id "T1123" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Audio Capture" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "An adversary can leverage a computer's peripheral devices (e.g., microphones and webcams) or applications (e.g., voice and video call services) to capture audio recordings for the purpose of listening into sensitive conversations to gather information.(Citation: ESET Attor Oct 2019)" ;
    skos:exactMatch d3f:T1123,
        mitre-attack:T1123 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1124 a owl:Class ;
    rdfs:label "T1124" ;
    d3f:attack-id "T1124" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "System Time Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "An adversary may gather the system time and/or time zone settings from a local or remote system. The system time is set and stored by services, such as the Windows Time Service on Windows or <code>systemsetup</code> on macOS.(Citation: MSDN System Time)(Citation: Technet Windows Time Service)(Citation: systemsetup mac time) These time settings may also be synchronized between systems and services in an enterprise network, typically accomplished with a network time server within a domain.(Citation: Mac Time Sync)(Citation: linux system time)" ;
    skos:exactMatch d3f:T1124,
        mitre-attack:T1124 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1125 a owl:Class ;
    rdfs:label "T1125" ;
    d3f:attack-id "T1125" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Video Capture" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "An adversary can leverage a computer's peripheral devices (e.g., integrated cameras or webcams) or applications (e.g., video call services) to capture video recordings for the purpose of gathering information. Images may also be captured from devices or applications, potentially in specified intervals, in lieu of video files." ;
    skos:exactMatch d3f:T1125,
        mitre-attack:T1125 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1126 a owl:Class ;
    rdfs:label "T1126" ;
    d3f:attack-id "T1126" ;
    dcterms:title "Network Share Connection Removal" ;
    rdfs:seeAlso d3f:T1070.005 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may remove share connections that are no longer useful in order to clean up traces of their operation. Windows shared drive and [Windows Admin Shares](https://attack.mitre.org/techniques/T1077) connections can be removed when no longer needed. [Net](https://attack.mitre.org/software/S0039) is an example utility that can be used to remove network share connections with the <code>net use \\\\system\\share /delete</code> command. (Citation: Technet Net Use)" ;
    skos:exactMatch d3f:T1126,
        mitre-attack:T1126 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1070.005" .

d3f:T1128 a owl:Class ;
    rdfs:label "T1128" ;
    d3f:attack-id "T1128" ;
    dcterms:title "Netsh Helper DLL" ;
    rdfs:seeAlso d3f:T1546.007 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Netsh.exe (also referred to as Netshell) is a command-line scripting utility used to interact with the network configuration of a system. It contains functionality to add helper DLLs for extending functionality of the utility. (Citation: TechNet Netsh) The paths to registered netsh.exe helper DLLs are entered into the Windows Registry at <code>HKLM\\SOFTWARE\\Microsoft\\Netsh</code>." ;
    skos:exactMatch d3f:T1128,
        mitre-attack:T1128 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.007" .

d3f:T1129 a owl:Class ;
    rdfs:label "T1129" ;
    d3f:attack-id "T1129" ;
    dcterms:title "Shared Modules" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may execute malicious payloads via loading shared modules. Shared modules are executable files that are loaded into processes to provide access to reusable code, such as specific custom functions or invoking OS API functions (i.e., [Native API](https://attack.mitre.org/techniques/T1106))." ;
    skos:exactMatch d3f:T1129,
        mitre-attack:T1129 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1130 a owl:Class ;
    rdfs:label "T1130" ;
    d3f:attack-id "T1130" ;
    dcterms:title "Install Root Certificate" ;
    rdfs:seeAlso d3f:T1553.004 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Root certificates are used in public key cryptography to identify a root certificate authority (CA). When a root certificate is installed, the system or application will trust certificates in the root's chain of trust that have been signed by the root certificate. (Citation: Wikipedia Root Certificate) Certificates are commonly used for establishing secure TLS/SSL communications within a web browser. When a user attempts to browse a website that presents a certificate that is not trusted an error message will be displayed to warn the user of the security risk. Depending on the security settings, the browser may not allow the user to establish a connection to the website." ;
    skos:exactMatch d3f:T1130,
        mitre-attack:T1130 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1553.004" .

d3f:T1131 a owl:Class ;
    rdfs:label "T1131" ;
    d3f:attack-id "T1131" ;
    dcterms:title "Authentication Package" ;
    rdfs:seeAlso d3f:T1547.002 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Windows Authentication Package DLLs are loaded by the Local Security Authority (LSA) process at system start. They provide support for multiple logon processes and multiple security protocols to the operating system. (Citation: MSDN Authentication Packages)" ;
    skos:exactMatch d3f:T1131,
        mitre-attack:T1131 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.002" .

d3f:T1133 a owl:Class ;
    rdfs:label "T1133" ;
    d3f:attack-id "T1133" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "External Remote Services" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may leverage external-facing remote services to initially access and/or persist within a network. Remote services such as VPNs, Citrix, and other access mechanisms allow users to connect to internal enterprise network resources from external locations. There are often remote service gateways that manage connections and credential authentication for these services. Services such as [Windows Remote Management](https://attack.mitre.org/techniques/T1021/006) and [VNC](https://attack.mitre.org/techniques/T1021/005) can also be used externally.(Citation: MacOS VNC software for Remote Desktop)" ;
    skos:exactMatch d3f:T1133,
        mitre-attack:T1133 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1135 a owl:Class ;
    rdfs:label "T1135" ;
    d3f:attack-id "T1135" ;
    dcterms:title "Network Share Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may look for folders and drives shared on remote systems as a means of identifying sources of information to gather as a precursor for Collection and to identify potential systems of interest for Lateral Movement. Networks often contain shared network drives and folders that enable users to access file directories on various systems across a network." ;
    skos:exactMatch d3f:T1135,
        mitre-attack:T1135 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1138 a owl:Class ;
    rdfs:label "T1138" ;
    d3f:attack-id "T1138" ;
    dcterms:title "Application Shimming" ;
    rdfs:seeAlso d3f:T1546.011 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "The Microsoft Windows Application Compatibility Infrastructure/Framework (Application Shim) was created to allow for backward compatibility of software as the operating system codebase changes over time. For example, the application shimming feature allows developers to apply fixes to applications (without rewriting code) that were created for Windows XP so that it will work with Windows 10. (Citation: Elastic Process Injection July 2017) Within the framework, shims are created to act as a buffer between the program (or more specifically, the Import Address Table) and the Windows OS. When a program is executed, the shim cache is referenced to determine if the program requires the use of the shim database (.sdb). If so, the shim database uses [Hooking](https://attack.mitre.org/techniques/T1179) to redirect the code as necessary in order to communicate with the OS." ;
    skos:exactMatch d3f:T1138,
        mitre-attack:T1138 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.011" .

d3f:T1139 a owl:Class ;
    rdfs:label "T1139" ;
    d3f:attack-id "T1139" ;
    dcterms:title "Bash History" ;
    rdfs:seeAlso d3f:T1552.003 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Bash keeps track of the commands users type on the command-line with the \"history\" utility. Once a user logs out, the history is flushed to the user’s <code>.bash_history</code> file. For each user, this file resides at the same location: <code>~/.bash_history</code>. Typically, this file keeps track of the user’s last 500 commands. Users often type usernames and passwords on the command-line as parameters to programs, which then get saved to this file when they log out. Attackers can abuse this by looking through the file for potential credentials. (Citation: External to DA, the OS X Way)" ;
    skos:exactMatch d3f:T1139,
        mitre-attack:T1139 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1552.003" .

d3f:T1140 a owl:Class ;
    rdfs:label "T1140" ;
    d3f:attack-id "T1140" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Deobfuscate/Decode Files or Information" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may use [Obfuscated Files or Information](https://attack.mitre.org/techniques/T1027) to hide artifacts of an intrusion from analysis. They may require separate mechanisms to decode or deobfuscate that information depending on how they intend to use it. Methods for doing that include built-in functionality of malware or by using utilities present on the system." ;
    skos:exactMatch d3f:T1140,
        mitre-attack:T1140 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1141 a owl:Class ;
    rdfs:label "T1141" ;
    d3f:attack-id "T1141" ;
    dcterms:title "Input Prompt" ;
    rdfs:seeAlso d3f:T1056.002 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "When programs are executed that need additional privileges than are present in the current user context, it is common for the operating system to prompt the user for proper credentials to authorize the elevated privileges for the task (ex: [Bypass User Account Control](https://attack.mitre.org/techniques/T1088))." ;
    skos:exactMatch d3f:T1141,
        mitre-attack:T1141 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1056.002" .

d3f:T1142 a owl:Class ;
    rdfs:label "T1142" ;
    d3f:attack-id "T1142" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Keychain" ;
    rdfs:seeAlso d3f:T1555.001 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Keychains are the built-in way for macOS to keep track of users' passwords and credentials for many services and features such as WiFi passwords, websites, secure notes, certificates, and Kerberos. Keychain files are located in <code>~/Library/Keychains/</code>,<code>/Library/Keychains/</code>, and <code>/Network/Library/Keychains/</code>. (Citation: Wikipedia keychain) The <code>security</code> command-line utility, which is built into macOS by default, provides a useful way to manage these credentials." ;
    skos:exactMatch d3f:T1142,
        mitre-attack:T1142 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1555.001" .

d3f:T1143 a owl:Class ;
    rdfs:label "T1143" ;
    d3f:attack-id "T1143" ;
    dcterms:title "Hidden Window" ;
    rdfs:seeAlso d3f:T1564.003 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may implement hidden windows to conceal malicious activity from the plain sight of users. In some cases, windows that would typically be displayed when an application carries out an operation can be hidden. This may be utilized by system administrators to avoid disrupting user work environments when carrying out administrative tasks. Adversaries may abuse operating system functionality to hide otherwise visible windows from users so as not to alert the user to adversary activity on the system." ;
    skos:exactMatch d3f:T1143,
        mitre-attack:T1143 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1564.003" .

d3f:T1144 a owl:Class ;
    rdfs:label "T1144" ;
    d3f:attack-id "T1144" ;
    dcterms:title "Gatekeeper Bypass" ;
    rdfs:seeAlso d3f:T1553.001 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "In macOS and OS X, when applications or programs are downloaded from the internet, there is a special attribute set on the file called <code>com.apple.quarantine</code>. This attribute is read by Apple's Gatekeeper defense program at execution time and provides a prompt to the user to allow or deny execution." ;
    skos:exactMatch d3f:T1144,
        mitre-attack:T1144 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1553.001" .

d3f:T1145 a owl:Class ;
    rdfs:label "T1145" ;
    d3f:attack-id "T1145" ;
    dcterms:title "Private Keys" ;
    rdfs:seeAlso d3f:T1552.004 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Private cryptographic keys and certificates are used for authentication, encryption/decryption, and digital signatures. (Citation: Wikipedia Public Key Crypto)" ;
    skos:exactMatch d3f:T1145,
        mitre-attack:T1145 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1552.004" .

d3f:T1146 a owl:Class ;
    rdfs:label "T1146" ;
    d3f:attack-id "T1146" ;
    dcterms:title "Clear Command History" ;
    rdfs:seeAlso d3f:T1070.003 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "In addition to clearing system logs, an adversary may clear the command history of a compromised account to conceal the actions undertaken during an intrusion. macOS and Linux both keep track of the commands users type in their terminal so that users can retrace what they've done. These logs can be accessed in a few different ways. While logged in, this command history is tracked in a file pointed to by the environment variable <code>HISTFILE</code>. When a user logs off a system, this information is flushed to a file in the user's home directory called <code>~/.bash_history</code>. The benefit of this is that it allows users to go back to commands they've used before in different sessions. Since everything typed on the command-line is saved, passwords passed in on the command line are also saved. Adversaries can abuse this by searching these files for cleartext passwords. Additionally, adversaries can use a variety of methods to prevent their own commands from appear in these logs such as <code>unset HISTFILE</code>, <code>export HISTFILESIZE=0</code>, <code>history -c</code>, <code>rm ~/.bash_history</code>." ;
    skos:exactMatch d3f:T1146,
        mitre-attack:T1146 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1070.003" .

d3f:T1147 a owl:Class ;
    rdfs:label "T1147" ;
    d3f:attack-id "T1147" ;
    dcterms:title "Hidden Users" ;
    rdfs:seeAlso d3f:T1564.002 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Every user account in macOS has a userID associated with it. When creating a user, you can specify the userID for that account. There is a property value in <code>/Library/Preferences/com.apple.loginwindow</code> called <code>Hide500Users</code> that prevents users with userIDs 500 and lower from appearing at the login screen. By using the [Create Account](https://attack.mitre.org/techniques/T1136) technique with a userID under 500 and enabling this property (setting it to Yes), an adversary can hide their user accounts much more easily: <code>sudo dscl . -create /Users/username UniqueID 401</code> (Citation: Cybereason OSX Pirrit)." ;
    skos:exactMatch d3f:T1147,
        mitre-attack:T1147 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1564.002" .

d3f:T1148 a owl:Class ;
    rdfs:label "T1148" ;
    d3f:attack-id "T1148" ;
    dcterms:title "HISTCONTROL" ;
    rdfs:seeAlso d3f:T1562.003 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "The <code>HISTCONTROL</code> environment variable keeps track of what should be saved by the <code>history</code> command and eventually into the <code>~/.bash_history</code> file when a user logs out. This setting can be configured to ignore commands that start with a space by simply setting it to \"ignorespace\". <code>HISTCONTROL</code> can also be set to ignore duplicate commands by setting it to \"ignoredups\". In some Linux systems, this is set by default to \"ignoreboth\" which covers both of the previous examples. This means that “ ls” will not be saved, but “ls” would be saved by history. <code>HISTCONTROL</code> does not exist by default on macOS, but can be set by the user and will be respected. Adversaries can use this to operate without leaving traces by simply prepending a space to all of their terminal commands." ;
    skos:exactMatch d3f:T1148,
        mitre-attack:T1148 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1562.003" .

d3f:T1149 a owl:Class ;
    rdfs:label "T1149" ;
    d3f:attack-id "T1149" ;
    dcterms:title "LC_MAIN Hijacking" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "**This technique has been deprecated and should no longer be used.**" ;
    skos:exactMatch d3f:T1149,
        mitre-attack:T1149 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated and should no longer be used.**" .

d3f:T1150 a owl:Class ;
    rdfs:label "T1150" ;
    d3f:attack-id "T1150" ;
    dcterms:title "Plist Modification" ;
    rdfs:seeAlso d3f:T1547.011 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Property list (plist) files contain all of the information that macOS and OS X uses to configure applications and services. These files are UTF-8 encoded and formatted like XML documents via a series of keys surrounded by < >. They detail when programs should execute, file paths to the executables, program arguments, required OS permissions, and many others. plists are located in certain locations depending on their purpose such as <code>/Library/Preferences</code> (which execute with elevated privileges) and <code>~/Library/Preferences</code> (which execute with a user's privileges)." ;
    skos:exactMatch d3f:T1150,
        mitre-attack:T1150 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.011" .

d3f:T1151 a owl:Class ;
    rdfs:label "T1151" ;
    d3f:attack-id "T1151" ;
    dcterms:title "Space after Filename" ;
    rdfs:seeAlso d3f:T1036.006 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries can hide a program's true filetype by changing the extension of a file. With certain file types (specifically this does not work with .app extensions), appending a space to the end of a filename will change how the file is processed by the operating system. For example, if there is a Mach-O executable file called evil.bin, when it is double clicked by a user, it will launch Terminal.app and execute. If this file is renamed to evil.txt, then when double clicked by a user, it will launch with the default text editing application (not executing the binary). However, if the file is renamed to \"evil.txt \" (note the space at the end), then when double clicked by a user, the true file type is determined by the OS and handled appropriately and the binary will be executed (Citation: Mac Backdoors are back)." ;
    skos:exactMatch d3f:T1151,
        mitre-attack:T1151 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1036.006" .

d3f:T1152 a owl:Class ;
    rdfs:label "T1152" ;
    d3f:attack-id "T1152" ;
    dcterms:title "Launchctl" ;
    rdfs:seeAlso d3f:T1569.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Launchctl controls the macOS launchd process which handles things like launch agents and launch daemons, but can execute other commands or programs itself. Launchctl supports taking subcommands on the command-line, interactively, or even redirected from standard input. By loading or reloading launch agents or launch daemons, adversaries can install persistence or execute changes they made  (Citation: Sofacy Komplex Trojan). Running a command from launchctl is as simple as <code>launchctl submit -l <labelName> -- /Path/to/thing/to/execute \"arg\" \"arg\" \"arg\"</code>. Loading, unloading, or reloading launch agents or launch daemons can require elevated privileges." ;
    skos:exactMatch d3f:T1152,
        mitre-attack:T1152 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1569.001" .

d3f:T1153 a owl:Class ;
    rdfs:label "T1153" ;
    d3f:attack-id "T1153" ;
    dcterms:title "Source" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "**This technique has been deprecated and should no longer be used.**" ;
    skos:exactMatch d3f:T1153,
        mitre-attack:T1153 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated and should no longer be used.**" .

d3f:T1154 a owl:Class ;
    rdfs:label "T1154" ;
    d3f:attack-id "T1154" ;
    dcterms:title "Trap" ;
    rdfs:seeAlso d3f:T1546.005 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "The <code>trap</code> command allows programs and shells to specify commands that will be executed upon receiving interrupt signals. A common situation is a script allowing for graceful termination and handling of common  keyboard interrupts like <code>ctrl+c</code> and <code>ctrl+d</code>. Adversaries can use this to register code to be executed when the shell encounters specific interrupts either to gain execution or as a persistence mechanism. Trap commands are of the following format <code>trap 'command list' signals</code> where \"command list\" will be executed when \"signals\" are received.(Citation: Trap Manual)(Citation: Cyberciti Trap Statements)" ;
    skos:exactMatch d3f:T1154,
        mitre-attack:T1154 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.005" .

d3f:T1155 a owl:Class ;
    rdfs:label "T1155" ;
    d3f:attack-id "T1155" ;
    dcterms:title "AppleScript" ;
    rdfs:seeAlso d3f:T1059.002 ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "macOS and OS X applications send AppleEvent messages to each other for interprocess communications (IPC). These messages can be easily scripted with AppleScript for local or remote IPC. Osascript executes AppleScript and any other Open Scripting Architecture (OSA) language scripts. A list of OSA languages installed on a system can be found by using the <code>osalang</code> program." ;
    skos:exactMatch d3f:T1155,
        mitre-attack:T1155 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1059.002" .

d3f:T1156 a owl:Class ;
    rdfs:label "T1156" ;
    d3f:attack-id "T1156" ;
    dcterms:title "Malicious Shell Modification" ;
    rdfs:seeAlso d3f:T1546.004 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may establish persistence through executing malicious commands triggered by a user’s shell. User shells execute several configuration scripts at different points throughout the session based on events. For example, when a user opens a command line interface or remotely logs in (such as SSH) a login shell is initiated. The login shell executes scripts from the system (/etc) and the user’s home directory (~/) to configure the environment. All login shells on a system use <code>/etc/profile</code> when initiated. These configuration scripts run at the permission level of their directory and are often used to set environment variables, create aliases, and customize the user’s environment. When the shell exits or terminates, additional shell scripts are executed to ensure the shell exits appropriately." ;
    skos:exactMatch d3f:T1156,
        mitre-attack:T1156 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.004" .

d3f:T1157 a owl:Class ;
    rdfs:label "T1157" ;
    d3f:attack-id "T1157" ;
    dcterms:title "Dylib Hijacking" ;
    rdfs:seeAlso d3f:T1574.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "macOS and OS X use a common method to look for required dynamic libraries (dylib) to load into a program based on search paths. Adversaries can take advantage of ambiguous paths to plant dylibs to gain privilege escalation or persistence." ;
    skos:exactMatch d3f:T1157,
        mitre-attack:T1157 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1574.004" .

d3f:T1158 a owl:Class ;
    rdfs:label "T1158" ;
    d3f:attack-id "T1158" ;
    dcterms:title "Hidden Files and Directories" ;
    rdfs:seeAlso d3f:T1564.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "To prevent normal users from accidentally changing special files on a system, most operating systems have the concept of a ‘hidden’ file. These files don’t show up when a user browses the file system with a GUI or when using normal commands on the command line. Users must explicitly ask to show the hidden files either via a series of Graphical User Interface (GUI) prompts or with command line switches (<code>dir /a</code> for Windows and <code>ls –a</code> for Linux and macOS)." ;
    skos:exactMatch d3f:T1158,
        mitre-attack:T1158 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1564.001" .

d3f:T1159 a owl:Class ;
    rdfs:label "T1159" ;
    d3f:attack-id "T1159" ;
    dcterms:title "Launch Agent" ;
    rdfs:seeAlso d3f:T1543.001 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Per Apple’s developer documentation, when a user logs in, a per-user launchd process is started which loads the parameters for each launch-on-demand user agent from the property list (plist) files found in <code>/System/Library/LaunchAgents</code>, <code>/Library/LaunchAgents</code>, and <code>$HOME/Library/LaunchAgents</code> (Citation: AppleDocs Launch Agent Daemons) (Citation: OSX Keydnap malware) (Citation: Antiquated Mac Malware). These launch agents have property list files which point to the executables that will be launched (Citation: OSX.Dok Malware)." ;
    skos:exactMatch d3f:T1159,
        mitre-attack:T1159 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1543.001" .

d3f:T1160 a owl:Class ;
    rdfs:label "T1160" ;
    d3f:attack-id "T1160" ;
    dcterms:title "Launch Daemon" ;
    rdfs:seeAlso d3f:T1543.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Per Apple’s developer documentation, when macOS and OS X boot up, launchd is run to finish system initialization. This process loads the parameters for each launch-on-demand system-level daemon from the property list (plist) files found in <code>/System/Library/LaunchDaemons</code> and <code>/Library/LaunchDaemons</code> (Citation: AppleDocs Launch Agent Daemons). These LaunchDaemons have property list files which point to the executables that will be launched (Citation: Methods of Mac Malware Persistence)." ;
    skos:exactMatch d3f:T1160,
        mitre-attack:T1160 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1543.004" .

d3f:T1161 a owl:Class ;
    rdfs:label "T1161" ;
    d3f:attack-id "T1161" ;
    dcterms:title "LC_LOAD_DYLIB Addition" ;
    rdfs:seeAlso d3f:T1546.006 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Mach-O binaries have a series of headers that are used to perform certain operations when a binary is loaded. The LC_LOAD_DYLIB header in a Mach-O binary tells macOS and OS X which dynamic libraries (dylibs) to load during execution time. These can be added ad-hoc to the compiled binary as long adjustments are made to the rest of the fields and dependencies (Citation: Writing Bad Malware for OSX). There are tools available to perform these changes. Any changes will invalidate digital signatures on binaries because the binary is being modified. Adversaries can remediate this issue by simply removing the LC_CODE_SIGNATURE command from the binary so that the signature isn’t checked at load time (Citation: Malware Persistence on OS X)." ;
    skos:exactMatch d3f:T1161,
        mitre-attack:T1161 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.006" .

d3f:T1162 a owl:Class ;
    rdfs:label "T1162" ;
    d3f:attack-id "T1162" ;
    dcterms:title "Login Item" ;
    rdfs:seeAlso d3f:T1547.011 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "MacOS provides the option to list specific applications to run when a user logs in. These applications run under the logged in user's context, and will be started every time the user logs in. Login items installed using the Service Management Framework are not visible in the System Preferences and can only be removed by the application that created them (Citation: Adding Login Items). Users have direct control over login items installed using a shared file list which are also visible in System Preferences (Citation: Adding Login Items). These login items are stored in the user's <code>~/Library/Preferences/</code> directory in a plist file called <code>com.apple.loginitems.plist</code> (Citation: Methods of Mac Malware Persistence). Some of these applications can open visible dialogs to the user, but they don’t all have to since there is an option to ‘Hide’ the window. If an adversary can register their own login item or modified an existing one, then they can use it to execute their code for a persistence mechanism each time the user logs in (Citation: Malware Persistence on OS X) (Citation: OSX.Dok Malware). The API method <code> SMLoginItemSetEnabled </code> can be used to set Login Items, but scripting languages like [AppleScript](https://attack.mitre.org/techniques/T1155) can do this as well  (Citation: Adding Login Items)." ;
    skos:exactMatch d3f:T1162,
        mitre-attack:T1162 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.011" .

d3f:T1163 a owl:Class ;
    rdfs:label "T1163" ;
    d3f:attack-id "T1163" ;
    dcterms:title "Rc.common" ;
    rdfs:seeAlso d3f:T1037.004 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "During the boot process, macOS executes <code>source /etc/rc.common</code>, which is a shell script containing various utility functions. This file also defines routines for processing command-line arguments and for gathering system settings, and is thus recommended to include in the start of Startup Item Scripts (Citation: Startup Items). In macOS and OS X, this is now a deprecated technique in favor of launch agents and launch daemons, but is currently still used." ;
    skos:exactMatch d3f:T1163,
        mitre-attack:T1163 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1037.004" .

d3f:T1164 a owl:Class ;
    rdfs:label "T1164" ;
    d3f:attack-id "T1164" ;
    dcterms:title "Re-opened Applications" ;
    rdfs:seeAlso d3f:T1547.007 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Starting in Mac OS X 10.7 (Lion), users can specify certain applications to be re-opened when a user reboots their machine. While this is usually done via a Graphical User Interface (GUI) on an app-by-app basis, there are property list files (plist) that contain this information as well located at <code>~/Library/Preferences/com.apple.loginwindow.plist</code> and <code>~/Library/Preferences/ByHost/com.apple.loginwindow.* .plist</code>." ;
    skos:exactMatch d3f:T1164,
        mitre-attack:T1164 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.007" .

d3f:T1165 a owl:Class ;
    rdfs:label "T1165" ;
    d3f:attack-id "T1165" ;
    dcterms:title "Startup Items" ;
    rdfs:seeAlso d3f:T1037.005 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Per Apple’s documentation, startup items execute during the final phase of the boot process and contain shell scripts or other executable files along with configuration information used by the system to determine the execution order for all startup items (Citation: Startup Items). This is technically a deprecated version (superseded by Launch Daemons), and thus the appropriate folder, <code>/Library/StartupItems</code> isn’t guaranteed to exist on the system by default, but does appear to exist by default on macOS Sierra. A startup item is a directory whose executable and configuration property list (plist), <code>StartupParameters.plist</code>, reside in the top-level directory." ;
    skos:exactMatch d3f:T1165,
        mitre-attack:T1165 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1037.005" .

d3f:T1166 a owl:Class ;
    rdfs:label "T1166" ;
    d3f:attack-id "T1166" ;
    dcterms:title "Setuid and Setgid" ;
    rdfs:seeAlso d3f:T1548.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "When the setuid or setgid bits are set on Linux or macOS for an application, this means that the application will run with the privileges of the owning user or group respectively  (Citation: setuid man page). Normally an application is run in the current user’s context, regardless of which user or group owns the application. There are instances where programs need to be executed in an elevated context to function properly, but the user running them doesn’t need the elevated privileges. Instead of creating an entry in the sudoers file, which must be done by root, any user can specify the setuid or setgid flag to be set for their own applications. These bits are indicated with an \"s\" instead of an \"x\" when viewing a file's attributes via <code>ls -l</code>. The <code>chmod</code> program can set these bits with via bitmasking, <code>chmod 4777 [file]</code> or via shorthand naming, <code>chmod u+s [file]</code>." ;
    skos:exactMatch d3f:T1166,
        mitre-attack:T1166 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1548.001" .

d3f:T1167 a owl:Class ;
    rdfs:label "T1167" ;
    d3f:attack-id "T1167" ;
    dcterms:title "Securityd Memory" ;
    rdfs:seeAlso d3f:T1555.002 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "In OS X prior to El Capitan, users with root access can read plaintext keychain passwords of logged-in users because Apple’s keychain implementation allows these credentials to be cached so that users are not repeatedly prompted for passwords. (Citation: OS X Keychain) (Citation: External to DA, the OS X Way) Apple’s securityd utility takes the user’s logon password, encrypts it with PBKDF2, and stores this master key in memory. Apple also uses a set of keys and algorithms to encrypt the user’s password, but once the master key is found, an attacker need only iterate over the other values to unlock the final password. (Citation: OS X Keychain)" ;
    skos:exactMatch d3f:T1167,
        mitre-attack:T1167 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1555.002" .

d3f:T1168 a owl:Class ;
    rdfs:label "T1168" ;
    d3f:attack-id "T1168" ;
    dcterms:title "Local Job Scheduling" ;
    rdfs:seeAlso d3f:T1053 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "On Linux and macOS systems, multiple methods are supported for creating pre-scheduled and periodic background jobs: cron, (Citation: Die.net Linux crontab Man Page) at, (Citation: Die.net Linux at Man Page) and launchd. (Citation: AppleDocs Scheduling Timed Jobs) Unlike [Scheduled Task/Job](https://attack.mitre.org/techniques/T1053) on Windows systems, job scheduling on Linux-based systems cannot be done remotely unless used in conjunction within an established remote session, like secure shell (SSH)." ;
    skos:exactMatch d3f:T1168,
        mitre-attack:T1168 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1053" .

d3f:T1169 a owl:Class ;
    rdfs:label "T1169" ;
    d3f:attack-id "T1169" ;
    dcterms:title "Sudo" ;
    rdfs:seeAlso d3f:T1548.003 ;
    rdfs:subClassOf d3f:PrivilegeEscalationTechnique ;
    skos:definition "The sudoers file, <code>/etc/sudoers</code>, describes which users can run which commands and from which terminals. This also describes which commands users can run as other users or groups. This provides the idea of least privilege such that users are running in their lowest possible permissions for most of the time and only elevate to other users or permissions as needed, typically by prompting for a password. However, the sudoers file can also specify when to not prompt users for passwords with a line like <code>user1 ALL=(ALL) NOPASSWD: ALL</code> (Citation: OSX.Dok Malware)." ;
    skos:exactMatch d3f:T1169,
        mitre-attack:T1169 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1548.003" .

d3f:T1170 a owl:Class ;
    rdfs:label "T1170" ;
    d3f:attack-id "T1170" ;
    dcterms:title "Mshta" ;
    rdfs:seeAlso d3f:T1218.005 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Mshta.exe is a utility that executes Microsoft HTML Applications (HTA). HTA files have the file extension <code>.hta</code>. (Citation: Wikipedia HTML Application) HTAs are standalone applications that execute using the same models and technologies of Internet Explorer, but outside of the browser. (Citation: MSDN HTML Applications)" ;
    skos:exactMatch d3f:T1170,
        mitre-attack:T1170 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.005" .

d3f:T1171 a owl:Class ;
    rdfs:label "T1171" ;
    d3f:attack-id "T1171" ;
    dcterms:title "LLMNR/NBT-NS Poisoning and Relay" ;
    rdfs:seeAlso d3f:T1557.001 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Link-Local Multicast Name Resolution (LLMNR) and NetBIOS Name Service (NBT-NS) are Microsoft Windows components that serve as alternate methods of host identification. LLMNR is based upon the Domain Name System (DNS) format and allows hosts on the same local link to perform name resolution for other hosts. NBT-NS identifies systems on a local network by their NetBIOS name. (Citation: Wikipedia LLMNR) (Citation: TechNet NetBIOS)" ;
    skos:exactMatch d3f:T1171,
        mitre-attack:T1171 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1557.001" .

d3f:T1172 a owl:Class ;
    rdfs:label "T1172" ;
    d3f:attack-id "T1172" ;
    dcterms:title "Domain Fronting" ;
    rdfs:seeAlso d3f:T1090.004 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Domain fronting takes advantage of routing schemes in Content Delivery Networks (CDNs) and other services which host multiple domains to obfuscate the intended destination of HTTPS traffic or traffic tunneled through HTTPS. (Citation: Fifield Blocking Resistent Communication through domain fronting 2015) The technique involves using different domain names in the SNI field of the TLS header and the Host field of the HTTP header. If both domains are served from the same CDN, then the CDN may route to the address specified in the HTTP header after unwrapping the TLS header. A variation of the the technique, \"domainless\" fronting, utilizes a SNI field that is left blank; this may allow the fronting to work even when the CDN attempts to validate that the SNI and HTTP Host fields match (if the blank SNI fields are ignored)." ;
    skos:exactMatch d3f:T1172,
        mitre-attack:T1172 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1090.004" .

d3f:T1173 a owl:Class ;
    rdfs:label "T1173" ;
    d3f:attack-id "T1173" ;
    dcterms:title "Dynamic Data Exchange" ;
    rdfs:seeAlso d3f:T1559.002 ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Windows Dynamic Data Exchange (DDE) is a client-server protocol for one-time and/or continuous inter-process communication (IPC) between applications. Once a link is established, applications can autonomously exchange transactions consisting of strings, warm data links (notifications when a data item changes), hot data links (duplications of changes to a data item), and requests for command execution." ;
    skos:exactMatch d3f:T1173,
        mitre-attack:T1173 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1559.002" .

d3f:T1174 a owl:Class ;
    rdfs:label "T1174" ;
    d3f:attack-id "T1174" ;
    dcterms:title "Password Filter DLL" ;
    rdfs:seeAlso d3f:T1556.002 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Windows password filters are password policy enforcement mechanisms for both domain and local accounts. Filters are implemented as dynamic link libraries (DLLs) containing a method to validate potential passwords against password policies. Filter DLLs can be positioned on local computers for local accounts and/or domain controllers for domain accounts." ;
    skos:exactMatch d3f:T1174,
        mitre-attack:T1174 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1556.002" .

d3f:T1175 a owl:Class ;
    rdfs:label "T1175" ;
    d3f:attack-id "T1175" ;
    dcterms:title "Component Object Model and Distributed COM" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Distributed Component Object Model](https://attack.mitre.org/techniques/T1021/003) and [Component Object Model](https://attack.mitre.org/techniques/T1559/001).**" ;
    skos:exactMatch d3f:T1175,
        mitre-attack:T1175 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Distributed Component Object Model](https://attack.mitre.org/techniques/T1021/003) and [Component Object Model](https://attack.mitre.org/techniques/T1559/001).**" .

d3f:T1177 a owl:Class ;
    rdfs:label "T1177" ;
    d3f:attack-id "T1177" ;
    dcterms:title "LSASS Driver" ;
    rdfs:seeAlso d3f:T1547.008 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:ExecutionTechnique ;
    skos:definition "The Windows security subsystem is a set of components that manage and enforce the security policy for a computer or domain. The Local Security Authority (LSA) is the main component responsible for local security policy and user authentication. The LSA includes multiple dynamic link libraries (DLLs) associated with various other security functions, all of which run in the context of the LSA Subsystem Service (LSASS) lsass.exe process. (Citation: Microsoft Security Subsystem)" ;
    skos:exactMatch d3f:T1177,
        mitre-attack:T1177 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.008" .

d3f:T1178 a owl:Class ;
    rdfs:label "T1178" ;
    d3f:attack-id "T1178" ;
    dcterms:title "SID-History Injection" ;
    rdfs:seeAlso d3f:T1134.005 ;
    rdfs:subClassOf d3f:PrivilegeEscalationTechnique ;
    skos:definition "The Windows security identifier (SID) is a unique value that identifies a user or group account. SIDs are used by Windows security in both security descriptors and access tokens. (Citation: Microsoft SID) An account can hold additional SIDs in the SID-History Active Directory attribute (Citation: Microsoft SID-History Attribute), allowing inter-operable account migration between domains (e.g., all values in SID-History are included in access tokens)." ;
    skos:exactMatch d3f:T1178,
        mitre-attack:T1178 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1134.005" .

d3f:T1179 a owl:Class ;
    rdfs:label "T1179" ;
    d3f:attack-id "T1179" ;
    dcterms:title "Hooking" ;
    rdfs:seeAlso d3f:T1056.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:CredentialAccessTechnique ;
    skos:definition "Windows processes often leverage application programming interface (API) functions to perform tasks that require reusable system resources. Windows API functions are typically stored in dynamic-link libraries (DLLs) as exported functions." ;
    skos:exactMatch d3f:T1179,
        mitre-attack:T1179 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1056.004" .

d3f:T1180 a owl:Class ;
    rdfs:label "T1180" ;
    d3f:attack-id "T1180" ;
    dcterms:title "Screensaver" ;
    rdfs:seeAlso d3f:T1546.002 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Screensavers are programs that execute after a configurable time of user inactivity and consist of Portable Executable (PE) files with a .scr file extension.(Citation: Wikipedia Screensaver) The Windows screensaver application scrnsave.scr is located in <code>C:\\Windows\\System32\\</code>, and <code>C:\\Windows\\sysWOW64\\</code> on 64-bit Windows systems, along with screensavers included with base Windows installations." ;
    skos:exactMatch d3f:T1180,
        mitre-attack:T1180 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.002" .

d3f:T1181 a owl:Class ;
    rdfs:label "T1181" ;
    d3f:attack-id "T1181" ;
    dcterms:title "Extra Window Memory Injection" ;
    rdfs:seeAlso d3f:T1055.011 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Before creating a window, graphical Windows-based processes must prescribe to or register a windows class, which stipulate appearance and behavior (via windows procedures, which are functions that handle input/output of data). (Citation: Microsoft Window Classes) Registration of new windows classes can include a request for up to 40 bytes of extra window memory (EWM) to be appended to the allocated memory of each instance of that class. This EWM is intended to store data specific to that window and has specific application programming interface (API) functions to set and get its value. (Citation: Microsoft GetWindowLong function) (Citation: Microsoft SetWindowLong function)" ;
    skos:exactMatch d3f:T1181,
        mitre-attack:T1181 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1055.011" .

d3f:T1182 a owl:Class ;
    rdfs:label "T1182" ;
    d3f:attack-id "T1182" ;
    dcterms:title "AppCert DLLs" ;
    rdfs:seeAlso d3f:T1546.009 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Dynamic-link libraries (DLLs) that are specified in the AppCertDLLs Registry key under <code>HKEY_LOCAL_MACHINE\\System\\CurrentControlSet\\Control\\Session Manager</code> are loaded into every process that calls the ubiquitously used application programming interface (API) functions CreateProcess, CreateProcessAsUser, CreateProcessWithLoginW, CreateProcessWithTokenW, or WinExec. (Citation: Elastic Process Injection July 2017)" ;
    skos:exactMatch d3f:T1182,
        mitre-attack:T1182 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.009" .

d3f:T1183 a owl:Class ;
    rdfs:label "T1183" ;
    d3f:attack-id "T1183" ;
    dcterms:title "Image File Execution Options Injection" ;
    rdfs:seeAlso d3f:T1546.012 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Image File Execution Options (IFEO) enable a developer to attach a debugger to an application. When a process is created, a debugger present in an application’s IFEO will be prepended to the application’s name, effectively launching the new process under the debugger (e.g., “C:\\dbg\\ntsd.exe -g  notepad.exe”). (Citation: Microsoft Dev Blog IFEO Mar 2010)" ;
    skos:exactMatch d3f:T1183,
        mitre-attack:T1183 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.012" .

d3f:T1184 a owl:Class ;
    rdfs:label "T1184" ;
    d3f:attack-id "T1184" ;
    dcterms:title "SSH Hijacking" ;
    rdfs:seeAlso d3f:T1563.001 ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Secure Shell (SSH) is a standard means of remote access on Linux and macOS systems. It allows a user to connect to another system via an encrypted tunnel, commonly authenticating through a password, certificate or the use of an asymmetric encryption key pair." ;
    skos:exactMatch d3f:T1184,
        mitre-attack:T1184 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1563.001" .

d3f:T1185 a owl:Class ;
    rdfs:label "T1185" ;
    d3f:attack-id "T1185" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Browser Session Hijacking" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may take advantage of security vulnerabilities and inherent functionality in browser software to change content, modify user-behaviors, and intercept information as part of various browser session hijacking techniques.(Citation: Wikipedia Man in the Browser)" ;
    skos:exactMatch d3f:T1185,
        mitre-attack:T1185 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1186 a owl:Class ;
    rdfs:label "T1186" ;
    d3f:attack-id "T1186" ;
    dcterms:title "Process Doppelgänging" ;
    rdfs:seeAlso d3f:T1055.013 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Windows Transactional NTFS (TxF) was introduced in Vista as a method to perform safe file operations. (Citation: Microsoft TxF) To ensure data integrity, TxF enables only one transacted handle to write to a file at a given time. Until the write handle transaction is terminated, all other handles are isolated from the writer and may only read the committed version of the file that existed at the time the handle was opened. (Citation: Microsoft Basic TxF Concepts) To avoid corruption, TxF performs an automatic rollback if the system or application fails during a write transaction. (Citation: Microsoft Where to use TxF)" ;
    skos:exactMatch d3f:T1186,
        mitre-attack:T1186 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1055.013" .

d3f:T1187 a owl:Class ;
    rdfs:label "T1187" ;
    d3f:attack-id "T1187" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Forced Authentication" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may gather credential material by invoking or forcing a user to automatically provide authentication information through a mechanism in which they can intercept." ;
    skos:exactMatch d3f:T1187,
        mitre-attack:T1187 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1188 a owl:Class ;
    rdfs:label "T1188" ;
    d3f:attack-id "T1188" ;
    dcterms:title "Multi-hop Proxy" ;
    rdfs:seeAlso d3f:T1090.003 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "To disguise the source of malicious traffic, adversaries may chain together multiple proxies. Typically, a defender will be able to identify the last proxy traffic traversed before it enters their network; the defender may or may not be able to identify any previous proxies before the last-hop proxy. This technique makes identifying the original source of the malicious traffic even more difficult by requiring the defender to trace malicious traffic through several proxies to identify its source." ;
    skos:exactMatch d3f:T1188,
        mitre-attack:T1188 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1090.003" .

d3f:T1189 a owl:Class ;
    rdfs:label "T1189" ;
    d3f:attack-id "T1189" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Drive-by Compromise" ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may gain access to a system through a user visiting a website over the normal course of browsing. With this technique, the user's web browser is typically targeted for exploitation, but adversaries may also use compromised websites for non-exploitation behavior such as acquiring [Application Access Token](https://attack.mitre.org/techniques/T1550/001)." ;
    skos:exactMatch d3f:T1189,
        mitre-attack:T1189 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1190 a owl:Class ;
    rdfs:label "T1190" ;
    d3f:attack-id "T1190" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exploit Public-Facing Application" ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may attempt to exploit a weakness in an Internet-facing host or system to initially access a network. The weakness in the system can be a software bug, a temporary glitch, or a misconfiguration." ;
    skos:exactMatch d3f:T1190,
        mitre-attack:T1190 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1191 a owl:Class ;
    rdfs:label "T1191" ;
    d3f:attack-id "T1191" ;
    dcterms:title "CMSTP" ;
    rdfs:seeAlso d3f:T1218.003 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "The Microsoft Connection Manager Profile Installer (CMSTP.exe) is a command-line program used to install Connection Manager service profiles. (Citation: Microsoft Connection Manager Oct 2009) CMSTP.exe accepts an installation information file (INF) as a parameter and installs a service profile leveraged for remote access connections." ;
    skos:exactMatch d3f:T1191,
        mitre-attack:T1191 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.003" .

d3f:T1192 a owl:Class ;
    rdfs:label "T1192" ;
    d3f:attack-id "T1192" ;
    dcterms:title "Spearphishing Link" ;
    rdfs:seeAlso d3f:T1566.002 ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Spearphishing with a link is a specific variant of spearphishing. It is different from other forms of spearphishing in that it employs the use of links to download malware contained in email, instead of attaching malicious files to the email itself, to avoid defenses that may inspect email attachments." ;
    skos:exactMatch d3f:T1192,
        mitre-attack:T1192 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1566.002" .

d3f:T1193 a owl:Class ;
    rdfs:label "T1193" ;
    d3f:attack-id "T1193" ;
    dcterms:title "Spearphishing Attachment" ;
    rdfs:seeAlso d3f:T1566.001 ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Spearphishing attachment is a specific variant of spearphishing. Spearphishing attachment is different from other forms of spearphishing in that it employs the use of malware attached to an email. All forms of spearphishing are electronically delivered social engineering targeted at a specific individual, company, or industry. In this scenario, adversaries attach a file to the spearphishing email and usually rely upon [User Execution](https://attack.mitre.org/techniques/T1204) to gain execution." ;
    skos:exactMatch d3f:T1193,
        mitre-attack:T1193 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1566.001" .

d3f:T1194 a owl:Class ;
    rdfs:label "T1194" ;
    d3f:attack-id "T1194" ;
    dcterms:title "Spearphishing via Service" ;
    rdfs:seeAlso d3f:T1566.003 ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Spearphishing via service is a specific variant of spearphishing. It is different from other forms of spearphishing in that it employs the use of third party services rather than directly via enterprise email channels." ;
    skos:exactMatch d3f:T1194,
        mitre-attack:T1194 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1566.003" .

d3f:T1196 a owl:Class ;
    rdfs:label "T1196" ;
    d3f:attack-id "T1196" ;
    dcterms:title "Control Panel Items" ;
    rdfs:seeAlso d3f:T1218.002 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Windows Control Panel items are utilities that allow users to view and adjust computer settings. Control Panel items are registered executable (.exe) or Control Panel (.cpl) files, the latter are actually renamed dynamic-link library (.dll) files that export a CPlApplet function. (Citation: Microsoft Implementing CPL) (Citation: TrendMicro CPL Malware Jan 2014) Control Panel items can be executed directly from the command line, programmatically via an application programming interface (API) call, or by simply double-clicking the file. (Citation: Microsoft Implementing CPL) (Citation: TrendMicro CPL Malware Jan 2014) (Citation: TrendMicro CPL Malware Dec 2013)" ;
    skos:exactMatch d3f:T1196,
        mitre-attack:T1196 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.002" .

d3f:T1197 a owl:Class ;
    rdfs:label "T1197" ;
    d3f:attack-id "T1197" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "BITS Jobs" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may abuse BITS jobs to persistently execute code and perform various background tasks. Windows Background Intelligent Transfer Service (BITS) is a low-bandwidth, asynchronous file transfer mechanism exposed through [Component Object Model](https://attack.mitre.org/techniques/T1559/001) (COM).(Citation: Microsoft COM)(Citation: Microsoft BITS) BITS is commonly used by updaters, messengers, and other applications preferred to operate in the background (using available idle bandwidth) without interrupting other networked applications. File transfer tasks are implemented as BITS jobs, which contain a queue of one or more file operations." ;
    skos:exactMatch d3f:T1197,
        mitre-attack:T1197 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1198 a owl:Class ;
    rdfs:label "T1198" ;
    d3f:attack-id "T1198" ;
    dcterms:title "SIP and Trust Provider Hijacking" ;
    rdfs:seeAlso d3f:T1553.003 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PersistenceTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "In user mode, Windows Authenticode (Citation: Microsoft Authenticode) digital signatures are used to verify a file's origin and integrity, variables that may be used to establish trust in signed code (ex: a driver with a valid Microsoft signature may be handled as safe). The signature validation process is handled via the WinVerifyTrust application programming interface (API) function,  (Citation: Microsoft WinVerifyTrust) which accepts an inquiry and coordinates with the appropriate trust provider, which is responsible for validating parameters of a signature. (Citation: SpectorOps Subverting Trust Sept 2017)" ;
    skos:exactMatch d3f:T1198,
        mitre-attack:T1198 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1553.003" .

d3f:T1199 a owl:Class ;
    rdfs:label "T1199" ;
    d3f:attack-id "T1199" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Trusted Relationship" ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may breach or otherwise leverage organizations who have access to intended victims. Access through trusted third party relationship abuses an existing connection that may not be protected or receives less scrutiny than standard mechanisms of gaining access to a network." ;
    skos:exactMatch d3f:T1199,
        mitre-attack:T1199 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1200 a owl:Class ;
    rdfs:label "T1200" ;
    d3f:attack-id "T1200" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Hardware Additions" ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may introduce computer accessories, networking hardware, or other computing devices into a system or network that can be used as a vector to gain access. Rather than just connecting and distributing payloads via removable storage (i.e. [Replication Through Removable Media](https://attack.mitre.org/techniques/T1091)), more robust hardware additions can be used to introduce new functionalities and/or features into a system that can then be abused." ;
    skos:exactMatch d3f:T1200,
        mitre-attack:T1200 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1201 a owl:Class ;
    rdfs:label "T1201" ;
    d3f:attack-id "T1201" ;
    dcterms:title "Password Policy Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to access detailed information about the password policy used within an enterprise network or cloud environment. Password policies are a way to enforce complex passwords that are difficult to guess or crack through [Brute Force](https://attack.mitre.org/techniques/T1110). This information may help the adversary to create a list of common passwords and launch dictionary and/or brute force attacks which adheres to the policy (e.g. if the minimum password length should be 8, then not trying passwords such as 'pass123'; not checking for more than 3-4 passwords per account if the lockout is set to 6 as to not lock out accounts)." ;
    skos:exactMatch d3f:T1201,
        mitre-attack:T1201 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1202 a owl:Class ;
    rdfs:label "T1202" ;
    d3f:attack-id "T1202" ;
    dcterms:title "Indirect Command Execution" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may abuse utilities that allow for command execution to bypass security restrictions that limit the use of command-line interpreters. Various Windows utilities may be used to execute commands, possibly without invoking [cmd](https://attack.mitre.org/software/S0106). For example, [Forfiles](https://attack.mitre.org/software/S0193), the Program Compatibility Assistant (pcalua.exe), components of the Windows Subsystem for Linux (WSL), as well as other utilities may invoke the execution of programs and commands from a [Command and Scripting Interpreter](https://attack.mitre.org/techniques/T1059), Run window, or via scripts. (Citation: VectorSec ForFiles Aug 2017) (Citation: Evi1cg Forfiles Nov 2017)" ;
    skos:exactMatch d3f:T1202,
        mitre-attack:T1202 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1203 a owl:Class ;
    rdfs:label "T1203" ;
    d3f:attack-id "T1203" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exploitation for Client Execution" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities in client applications to execute code. Vulnerabilities can exist in software due to unsecure coding practices that can lead to unanticipated behavior. Adversaries can take advantage of certain vulnerabilities through targeted exploitation for the purpose of arbitrary code execution. Oftentimes the most valuable exploits to an offensive toolkit are those that can be used to obtain code execution on a remote system because they can be used to gain access to that system. Users will expect to see files related to the applications they commonly used to do work, so they are a useful target for exploit research and development because of their high utility." ;
    skos:exactMatch d3f:T1203,
        mitre-attack:T1203 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1206 a owl:Class ;
    rdfs:label "T1206" ;
    d3f:attack-id "T1206" ;
    dcterms:title "Sudo Caching" ;
    rdfs:seeAlso d3f:T1548.003 ;
    rdfs:subClassOf d3f:PrivilegeEscalationTechnique ;
    skos:definition "The <code>sudo</code> command \"allows a system administrator to delegate authority to give certain users (or groups of users) the ability to run some (or all) commands as root or another user while providing an audit trail of the commands and their arguments.\" (Citation: sudo man page 2018) Since sudo was made for the system administrator, it has some useful configuration features such as a <code>timestamp_timeout</code> that is the amount of time in minutes between instances of <code>sudo</code> before it will re-prompt for a password. This is because <code>sudo</code> has the ability to cache credentials for a period of time. Sudo creates (or touches) a file at <code>/var/db/sudo</code> with a timestamp of when sudo was last run to determine this timeout. Additionally, there is a <code>tty_tickets</code> variable that treats each new tty (terminal session) in isolation. This means that, for example, the sudo timeout of one tty will not affect another tty (you will have to type the password again)." ;
    skos:exactMatch d3f:T1206,
        mitre-attack:T1206 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1548.003" .

d3f:T1207 a owl:Class ;
    rdfs:label "T1207" ;
    d3f:attack-id "T1207" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Rogue Domain Controller" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may register a rogue Domain Controller to enable manipulation of Active Directory data. DCShadow may be used to create a rogue Domain Controller (DC). DCShadow is a method of manipulating Active Directory (AD) data, including objects and schemas, by registering (or reusing an inactive registration) and simulating the behavior of a DC. (Citation: DCShadow Blog) Once registered, a rogue DC may be able to inject and replicate changes into AD infrastructure for any domain object, including credentials and keys." ;
    skos:exactMatch d3f:T1207,
        mitre-attack:T1207 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1208 a owl:Class ;
    rdfs:label "T1208" ;
    d3f:attack-id "T1208" ;
    dcterms:title "Kerberoasting" ;
    rdfs:seeAlso d3f:T1558.003 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Service principal names (SPNs) are used to uniquely identify each instance of a Windows service. To enable authentication, Kerberos requires that SPNs be associated with at least one service logon account (an account specifically tasked with running a service (Citation: Microsoft Detecting Kerberoasting Feb 2018)). (Citation: Microsoft SPN) (Citation: Microsoft SetSPN) (Citation: SANS Attacking Kerberos Nov 2014) (Citation: Harmj0y Kerberoast Nov 2016)" ;
    skos:exactMatch d3f:T1208,
        mitre-attack:T1208 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1558.003" .

d3f:T1209 a owl:Class ;
    rdfs:label "T1209" ;
    d3f:attack-id "T1209" ;
    dcterms:title "Time Providers" ;
    rdfs:seeAlso d3f:T1547.003 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "The Windows Time service (W32Time) enables time synchronization across and within domains. (Citation: Microsoft W32Time Feb 2018) W32Time time providers are responsible for retrieving time stamps from hardware/network resources and outputting these values to other network clients. (Citation: Microsoft TimeProvider)" ;
    skos:exactMatch d3f:T1209,
        mitre-attack:T1209 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.003" .

d3f:T1210 a owl:Class ;
    rdfs:label "T1210" ;
    d3f:attack-id "T1210" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exploitation of Remote Services" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Adversaries may exploit remote services to gain unauthorized access to internal systems once inside of a network. Exploitation of a software vulnerability occurs when an adversary takes advantage of a programming error in a program, service, or within the operating system software or kernel itself to execute adversary-controlled code. A common goal for post-compromise exploitation of remote services is for lateral movement to enable access to a remote system." ;
    skos:exactMatch d3f:T1210,
        mitre-attack:T1210 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1211 a owl:Class ;
    rdfs:label "T1211" ;
    d3f:attack-id "T1211" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exploitation for Defense Evasion" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may exploit a system or application vulnerability to bypass security features. Exploitation of a vulnerability occurs when an adversary takes advantage of a programming error in a program, service, or within the operating system software or kernel itself to execute adversary-controlled code. Vulnerabilities may exist in defensive security software that can be used to disable or circumvent them." ;
    skos:exactMatch d3f:T1211,
        mitre-attack:T1211 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1212 a owl:Class ;
    rdfs:label "T1212" ;
    d3f:attack-id "T1212" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Exploitation for Credential Access" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities in an attempt to collect credentials. Exploitation of a software vulnerability occurs when an adversary takes advantage of a programming error in a program, service, or within the operating system software or kernel itself to execute adversary-controlled code." ;
    skos:exactMatch d3f:T1212,
        mitre-attack:T1212 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1214 a owl:Class ;
    rdfs:label "T1214" ;
    d3f:attack-id "T1214" ;
    dcterms:title "Credentials in Registry" ;
    rdfs:seeAlso d3f:T1552.002 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "The Windows Registry stores configuration information that can be used by the system or other programs. Adversaries may query the Registry looking for credentials and passwords that have been stored for use by other programs or services. Sometimes these credentials are used for automatic logons." ;
    skos:exactMatch d3f:T1214,
        mitre-attack:T1214 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1552.002" .

d3f:T1215 a owl:Class ;
    rdfs:label "T1215" ;
    d3f:attack-id "T1215" ;
    dcterms:title "Kernel Modules and Extensions" ;
    rdfs:seeAlso d3f:T1547.006 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Loadable Kernel Modules (or LKMs) are pieces of code that can be loaded and unloaded into the kernel upon demand. They extend the functionality of the kernel without the need to reboot the system. For example, one type of module is the device driver, which allows the kernel to access hardware connected to the system. (Citation: Linux Kernel Programming) When used maliciously, Loadable Kernel Modules (LKMs) can be a type of kernel-mode [Rootkit](https://attack.mitre.org/techniques/T1014) that run with the highest operating system privilege (Ring 0). (Citation: Linux Kernel Module Programming Guide) Adversaries can use loadable kernel modules to covertly persist on a system and evade defenses. Examples have been found in the wild and there are some open source projects. (Citation: Volatility Phalanx2) (Citation: CrowdStrike Linux Rootkit) (Citation: GitHub Reptile) (Citation: GitHub Diamorphine)" ;
    skos:exactMatch d3f:T1215,
        mitre-attack:T1215 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1547.006" .

d3f:T1217 a owl:Class ;
    rdfs:label "T1217" ;
    d3f:attack-id "T1217" ;
    dcterms:title "Browser Information Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may enumerate information about browsers to learn more about compromised environments. Data saved by browsers (such as bookmarks, accounts, and browsing history) may reveal a variety of personal information about users (e.g., banking sites, relationships/interests, social media, etc.) as well as details about internal network resources such as servers, tools/dashboards, or other related infrastructure.(Citation: Kaspersky Autofill)" ;
    skos:exactMatch d3f:T1217,
        mitre-attack:T1217 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1220 a owl:Class ;
    rdfs:label "T1220" ;
    d3f:attack-id "T1220" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "XSL Script Processing" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may bypass application control and obscure execution of code by embedding scripts inside XSL files. Extensible Stylesheet Language (XSL) files are commonly used to describe the processing and rendering of data within XML files. To support complex operations, the XSL standard includes support for embedded scripting in various languages. (Citation: Microsoft XSLT Script Mar 2017)" ;
    skos:exactMatch d3f:T1220,
        mitre-attack:T1220 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1221 a owl:Class ;
    rdfs:label "T1221" ;
    d3f:attack-id "T1221" ;
    dcterms:title "Template Injection" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may create or modify references in user document templates to conceal malicious code or force authentication attempts. For example, Microsoft’s Office Open XML (OOXML) specification defines an XML-based format for Office documents (.docx, xlsx, .pptx) to replace older binary formats (.doc, .xls, .ppt). OOXML files are packed together ZIP archives compromised of various XML files, referred to as parts, containing properties that collectively define how a document is rendered.(Citation: Microsoft Open XML July 2017)" ;
    skos:exactMatch d3f:T1221,
        mitre-attack:T1221 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1223 a owl:Class ;
    rdfs:label "T1223" ;
    d3f:attack-id "T1223" ;
    dcterms:title "Compiled HTML File" ;
    rdfs:seeAlso d3f:T1218.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Compiled HTML files (.chm) are commonly distributed as part of the Microsoft HTML Help system. CHM files are compressed compilations of various content such as HTML documents, images, and scripting/web related programming languages such VBA, JScript, Java, and ActiveX. (Citation: Microsoft HTML Help May 2018) CHM content is displayed using underlying components of the Internet Explorer browser (Citation: Microsoft HTML Help ActiveX) loaded by the HTML Help executable program (hh.exe). (Citation: Microsoft HTML Help Executable Program)" ;
    skos:exactMatch d3f:T1223,
        mitre-attack:T1223 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1218.001" .

d3f:T1398 a owl:Class ;
    rdfs:label "T1398" ;
    d3f:attack-id "T1398" ;
    dcterms:title "Boot or Logon Initialization Scripts" ;
    rdfs:subClassOf d3f:ATTACKMobilePersistenceTechnique ;
    skos:definition "Adversaries may use scripts automatically executed at boot or logon initialization to establish persistence. Initialization scripts are part of the underlying operating system and are not accessible to the user unless the device has been rooted or jailbroken." ;
    skos:exactMatch d3f:T1398,
        mitre-attack:T1398 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1399 a owl:Class ;
    rdfs:label "T1399" ;
    d3f:attack-id "T1399" ;
    dcterms:title "Modify Trusted Execution Environment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "If an adversary can escalate privileges, he or she may be able to use those privileges to place malicious code in the device's Trusted Execution Environment (TEE) or other similar isolated execution environment where the code can evade detection, may persist after device resets, and may not be removable by the device user. Running code within the TEE may provide an adversary with the ability to monitor or tamper with overall device behavior.(Citation: Roth-Rootkits)" ;
    skos:exactMatch d3f:T1399,
        mitre-attack:T1399 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1400 a owl:Class ;
    rdfs:label "T1400" ;
    d3f:attack-id "T1400" ;
    dcterms:title "Modify System Partition" ;
    rdfs:seeAlso d3f:T1625.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileImpactTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "If an adversary can escalate privileges, he or she may be able to use those privileges to place malicious code in the device system partition, where it may persist after device resets and may not be easily removed by the device user." ;
    skos:exactMatch d3f:T1400,
        mitre-attack:T1400 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1625.001" .

d3f:T1401 a owl:Class ;
    rdfs:label "T1401" ;
    d3f:attack-id "T1401" ;
    dcterms:title "Device Administrator Permissions" ;
    rdfs:seeAlso d3f:T1626.001 ;
    rdfs:subClassOf d3f:ATTACKMobilePrivilegeEscalationTechnique ;
    skos:definition "Adversaries may request device administrator permissions to perform malicious actions." ;
    skos:exactMatch d3f:T1401,
        mitre-attack:T1401 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1626.001" .

d3f:T1402 a owl:Class ;
    rdfs:label "T1402" ;
    d3f:attack-id "T1402" ;
    dcterms:title "Broadcast Receivers" ;
    rdfs:seeAlso d3f:T1624.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileExecutionTechnique ;
    skos:definition "An intent is a message passed between Android application or system components. Applications can register to receive broadcast intents at runtime, which are system-wide intents delivered to each app when certain events happen on the device, such as network changes or the user unlocking the screen. Malicious applications can then trigger certain actions within the app based on which broadcast intent was received." ;
    skos:exactMatch d3f:T1402,
        mitre-attack:T1402 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1624.001" .

d3f:T1403 a owl:Class ;
    rdfs:label "T1403" ;
    d3f:attack-id "T1403" ;
    dcterms:title "Modify Cached Executable Code" ;
    rdfs:subClassOf d3f:ATTACKMobilePersistenceTechnique ;
    skos:definition "ART (the Android Runtime) compiles optimized code on the device itself to improve performance. An adversary may be able to use escalated privileges to modify the cached code in order to hide malicious behavior. Since the code is compiled on the device, it may not receive the same level of integrity checks that are provided to code running in the system partition.(Citation: Sabanal-ART)" ;
    skos:exactMatch d3f:T1403,
        mitre-attack:T1403 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1404 a owl:Class ;
    rdfs:label "T1404" ;
    d3f:attack-id "T1404" ;
    dcterms:title "Exploitation for Privilege Escalation" ;
    rdfs:subClassOf d3f:ATTACKMobilePrivilegeEscalationTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities in order to elevate privileges. Exploitation of a software vulnerability occurs when an adversary takes advantage of a programming error in an application, service, within the operating system software, or kernel itself to execute adversary-controlled code. Security constructions, such as permission levels, will often hinder access to information and use of certain techniques. Adversaries will likely need to perform privilege escalation to include use of software exploitation to circumvent those restrictions." ;
    skos:exactMatch d3f:T1404,
        mitre-attack:T1404 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1405 a owl:Class ;
    rdfs:label "T1405" ;
    d3f:attack-id "T1405" ;
    dcterms:title "Exploit TEE Vulnerability" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePrivilegeEscalationTechnique ],
        d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "A malicious app or other attack vector could be used to exploit vulnerabilities in code running within the Trusted Execution Environment (TEE) (Citation: Thomas-TrustZone). The adversary could then obtain privileges held by the TEE potentially including the ability to access cryptographic keys or other sensitive data (Citation: QualcommKeyMaster). Escalated operating system privileges may be first required in order to have the ability to attack the TEE (Citation: EkbergTEE). If not, privileges within the TEE can potentially be used to exploit the operating system (Citation: laginimaineb-TEE)." ;
    skos:exactMatch d3f:T1405,
        mitre-attack:T1405 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1407 a owl:Class ;
    rdfs:label "T1407" ;
    d3f:attack-id "T1407" ;
    dcterms:title "Download New Code at Runtime" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may download and execute dynamic code not included in the original application package after installation. This technique is primarily used to evade static analysis checks and pre-publication scans in official app stores. In some cases, more advanced dynamic or behavioral analysis techniques could detect this behavior. However, in conjunction with [Execution Guardrails](https://attack.mitre.org/techniques/T1627) techniques, detecting malicious code downloaded after installation could be difficult." ;
    skos:exactMatch d3f:T1407,
        mitre-attack:T1407 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1408 a owl:Class ;
    rdfs:label "T1408" ;
    d3f:attack-id "T1408" ;
    dcterms:title "Disguise Root/Jailbreak Indicators" ;
    rdfs:seeAlso d3f:T1630.003 ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "An adversary could use knowledge of the techniques used by security software to evade detection(Citation: Brodie)(Citation: Tan). For example, some mobile security products perform compromised device detection by searching for particular artifacts such as an installed \"su\" binary, but that check could be evaded by naming the binary something else. Similarly, polymorphic code techniques could be used to evade signature-based detection(Citation: Rastogi)." ;
    skos:exactMatch d3f:T1408,
        mitre-attack:T1408 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1630.003" .

d3f:T1409 a owl:Class ;
    rdfs:label "T1409" ;
    d3f:attack-id "T1409" ;
    dcterms:title "Stored Application Data" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may try to access and collect application data resident on the device. Adversaries often target popular applications, such as Facebook, WeChat, and Gmail.(Citation: SWB Exodus March 2019)" ;
    skos:exactMatch d3f:T1409,
        mitre-attack:T1409 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1410 a owl:Class ;
    rdfs:label "T1410" ;
    d3f:attack-id "T1410" ;
    dcterms:title "Network Traffic Capture or Redirection" ;
    rdfs:seeAlso d3f:T1638 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCredentialAccessTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "An adversary may capture network traffic to and from the device to obtain credentials or other sensitive data, or redirect network traffic to flow through an adversary-controlled gateway to do the same." ;
    skos:exactMatch d3f:T1410,
        mitre-attack:T1410 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1638" .

d3f:T1411 a owl:Class ;
    rdfs:label "T1411" ;
    d3f:attack-id "T1411" ;
    dcterms:title "Input Prompt" ;
    rdfs:seeAlso d3f:T1417.002 ;
    rdfs:subClassOf d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "The operating system and installed applications often have legitimate needs to prompt the user for sensitive information such as account credentials, bank account information, or Personally Identifiable Information (PII). Adversaries may mimic this functionality to prompt users for sensitive information." ;
    skos:exactMatch d3f:T1411,
        mitre-attack:T1411 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1417.002" .

d3f:T1412 a owl:Class ;
    rdfs:label "T1412" ;
    d3f:attack-id "T1412" ;
    dcterms:title "Capture SMS Messages" ;
    rdfs:seeAlso d3f:T1636.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCredentialAccessTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "A malicious application could capture sensitive data sent via SMS, including authentication credentials. SMS is frequently used to transmit codes used for multi-factor authentication." ;
    skos:exactMatch d3f:T1412,
        mitre-attack:T1412 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1636.004" .

d3f:T1413 a owl:Class ;
    rdfs:label "T1413" ;
    d3f:attack-id "T1413" ;
    dcterms:title "Access Sensitive Data in Device Logs" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCredentialAccessTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "On versions of Android prior to 4.1, an adversary may use a malicious application that holds the READ_LOGS permission to obtain private keys, passwords, other credentials, or other sensitive data stored in the device's system log. On Android 4.1 and later, an adversary would need to attempt to perform an operating system privilege escalation attack to be able to access the log." ;
    skos:exactMatch d3f:T1413,
        mitre-attack:T1413 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1414 a owl:Class ;
    rdfs:label "T1414" ;
    d3f:attack-id "T1414" ;
    dcterms:title "Clipboard Data" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCredentialAccessTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may abuse clipboard manager APIs to obtain sensitive information copied to the device clipboard. For example, passwords being copied and pasted from a password manager application could be captured by a malicious application installed on the device.(Citation: Fahl-Clipboard)" ;
    skos:exactMatch d3f:T1414,
        mitre-attack:T1414 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1415 a owl:Class ;
    rdfs:label "T1415" ;
    d3f:attack-id "T1415" ;
    dcterms:title "URL Scheme Hijacking" ;
    rdfs:seeAlso d3f: ;
    rdfs:subClassOf d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "An iOS application may be able to maliciously claim a URL scheme, allowing it to intercept calls that are meant for a different application(Citation: FireEye-Masque2)(Citation: Dhanjani-URLScheme). This technique, for example, could be used to capture OAuth authorization codes(Citation: IETF-PKCE) or to phish user credentials(Citation: MobileIron-XARA)." ;
    skos:exactMatch d3f:T1415,
        mitre-attack:T1415 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by" .

d3f:T1416 a owl:Class ;
    rdfs:label "T1416" ;
    d3f:attack-id "T1416" ;
    dcterms:title "URI Hijacking" ;
    rdfs:seeAlso d3f:T1635.001 ;
    rdfs:subClassOf d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "Adversaries may register Uniform Resource Identifiers (URIs) to intercept sensitive data." ;
    skos:exactMatch d3f:T1416,
        mitre-attack:T1416 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1635.001" .

d3f:T1419 a owl:Class ;
    rdfs:label "T1419" ;
    d3f:attack-id "T1419" ;
    dcterms:title "Device Type Discovery" ;
    rdfs:seeAlso d3f: ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "On Android, device type information is accessible to apps through the android.os.Build class (Citation: Android-Build). Device information could be used to target privilege escalation exploits." ;
    skos:exactMatch d3f:T1419,
        mitre-attack:T1419 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by" .

d3f:T1420 a owl:Class ;
    rdfs:label "T1420" ;
    d3f:attack-id "T1420" ;
    dcterms:title "File and Directory Discovery" ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "Adversaries may enumerate files and directories or search in specific device locations for desired information within a filesystem. Adversaries may use the information from [File and Directory Discovery](https://attack.mitre.org/techniques/T1420) during automated discovery to shape follow-on behaviors, including deciding if the adversary should fully infect the target and/or attempt specific actions." ;
    skos:exactMatch d3f:T1420,
        mitre-attack:T1420 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1423 a owl:Class ;
    rdfs:label "T1423" ;
    d3f:attack-id "T1423" ;
    dcterms:title "Network Service Scanning" ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get a listing of services running on remote hosts, including those that may be vulnerable to remote software exploitation. Methods to acquire this information include port scans and vulnerability scans from the mobile device. This technique may take advantage of the mobile device's access to an internal enterprise network either through local connectivity or through a Virtual Private Network (VPN)." ;
    skos:exactMatch d3f:T1423,
        mitre-attack:T1423 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1424 a owl:Class ;
    rdfs:label "T1424" ;
    d3f:attack-id "T1424" ;
    dcterms:title "Process Discovery" ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get information about running processes on a device. Information obtained could be used to gain an understanding of common software/applications running on devices within a network. Adversaries may use the information from [Process Discovery](https://attack.mitre.org/techniques/T1424) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1424,
        mitre-attack:T1424 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1426 a owl:Class ;
    rdfs:label "T1426" ;
    d3f:attack-id "T1426" ;
    dcterms:title "System Information Discovery" ;
    rdfs:subClassOf d3f:ATTACKMobileDiscoveryTechnique ;
    skos:definition "Adversaries may attempt to get detailed information about a device’s operating system and hardware, including versions, patches, and architecture. Adversaries may use the information from [System Information Discovery](https://attack.mitre.org/techniques/T1426) during automated discovery to shape follow-on behaviors, including whether or not to fully infects the target and/or attempts specific actions." ;
    skos:exactMatch d3f:T1426,
        mitre-attack:T1426 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1427 a owl:Class ;
    rdfs:label "T1427" ;
    d3f:attack-id "T1427" ;
    dcterms:title "Attack PC via USB Connection" ;
    rdfs:subClassOf d3f:ATTACKMobileLateralMovementTechnique ;
    skos:definition "With escalated privileges, an adversary could program the mobile device to impersonate USB devices such as input devices (keyboard and mouse), storage devices, and/or networking devices in order to attack a physically connected PC(Citation: Wang-ExploitingUSB)(Citation: ArsTechnica-PoisonTap) This technique has been demonstrated on Android. We are unaware of any demonstrations on iOS." ;
    skos:exactMatch d3f:T1427,
        mitre-attack:T1427 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1428 a owl:Class ;
    rdfs:label "T1428" ;
    d3f:attack-id "T1428" ;
    dcterms:title "Exploitation of Remote Services" ;
    rdfs:subClassOf d3f:ATTACKMobileLateralMovementTechnique ;
    skos:definition "Adversaries may exploit remote services of enterprise servers, workstations, or other resources to gain unauthorized access to internal systems once inside of a network. Adversaries may exploit remote services by taking advantage of a mobile device’s access to an internal enterprise network through local connectivity or through a Virtual Private Network (VPN). Exploitation of a software vulnerability occurs when an adversary takes advantage of a programming error in a program, service, or within the operating system software or kernel itself to execute adversary-controlled code. A common goal for post-compromise exploitation of remote services is for lateral movement to enable access to a remote system." ;
    skos:exactMatch d3f:T1428,
        mitre-attack:T1428 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1429 a owl:Class ;
    rdfs:label "T1429" ;
    d3f:attack-id "T1429" ;
    dcterms:title "Audio Capture" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may capture audio to collect information by leveraging standard operating system APIs of a mobile device. Examples of audio information adversaries may target include user conversations, surroundings, phone calls, or other sensitive information." ;
    skos:exactMatch d3f:T1429,
        mitre-attack:T1429 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1432 a owl:Class ;
    rdfs:label "T1432" ;
    d3f:attack-id "T1432" ;
    dcterms:title "Access Contact List" ;
    rdfs:seeAlso d3f:T1636.003 ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "An adversary could call standard operating system APIs from a malicious application to gather contact list (i.e., address book) data, or with escalated privileges could directly access files containing contact list data." ;
    skos:exactMatch d3f:T1432,
        mitre-attack:T1432 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1636.003" .

d3f:T1433 a owl:Class ;
    rdfs:label "T1433" ;
    d3f:attack-id "T1433" ;
    dcterms:title "Access Call Log" ;
    rdfs:seeAlso d3f:T1636.002 ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "On Android, an adversary could call standard operating system APIs from a malicious application to gather call log data, or with escalated privileges could directly access files containing call log data." ;
    skos:exactMatch d3f:T1433,
        mitre-attack:T1433 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1636.002" .

d3f:T1435 a owl:Class ;
    rdfs:label "T1435" ;
    d3f:attack-id "T1435" ;
    dcterms:title "Access Calendar Entries" ;
    rdfs:seeAlso d3f:T1636.001 ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "An adversary could call standard operating system APIs from a malicious application to gather calendar entry data, or with escalated privileges could directly access files containing calendar data." ;
    skos:exactMatch d3f:T1435,
        mitre-attack:T1435 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1636.001" .

d3f:T1436 a owl:Class ;
    rdfs:label "T1436" ;
    d3f:attack-id "T1436" ;
    dcterms:title "Commonly Used Port" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileExfiltrationTechnique ],
        d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may communicate over a commonly used port to bypass firewalls or network detection systems and to blend with normal network activity to avoid more detailed inspection." ;
    skos:exactMatch d3f:T1436,
        mitre-attack:T1436 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1438 a owl:Class ;
    rdfs:label "T1438" ;
    d3f:attack-id "T1438" ;
    dcterms:title "Exfiltration Over Other Network Medium" ;
    rdfs:seeAlso d3f:T1644 ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may attempt to exfiltrate data over a different network medium than the command and control channel. If the command and control network is a standard Internet connection, the exfiltration may occur, for example, via Bluetooth, or another radio frequency (RF) channel." ;
    skos:exactMatch d3f:T1438,
        mitre-attack:T1438 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1644" .

d3f:T1444 a owl:Class ;
    rdfs:label "T1444" ;
    d3f:attack-id "T1444" ;
    dcterms:title "Masquerade as Legitimate Application" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileInitialAccessTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "An adversary could distribute developed malware by masquerading the malware as a legitimate application. This can be done in two different ways: by embedding the malware in a legitimate application, or by pretending to be a legitimate application." ;
    skos:exactMatch d3f:T1444,
        mitre-attack:T1444 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1446 a owl:Class ;
    rdfs:label "T1446" ;
    d3f:attack-id "T1446" ;
    dcterms:title "Device Lockout" ;
    rdfs:seeAlso d3f:T1629.002 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileImpactTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "An adversary may seek to lock the legitimate user out of the device, for example to inhibit user interaction or to obtain a ransom payment." ;
    skos:exactMatch d3f:T1446,
        mitre-attack:T1446 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1629.002" .

d3f:T1447 a owl:Class ;
    rdfs:label "T1447" ;
    d3f:attack-id "T1447" ;
    dcterms:title "Delete Device Data" ;
    rdfs:seeAlso d3f:T1630.002 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileImpactTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may wipe a device or delete individual files in order to manipulate external outcomes or hide activity. An application must have administrator access to fully wipe the device, while individual files may not require special permissions to delete depending on their storage location. (Citation: Android DevicePolicyManager 2019)" ;
    skos:exactMatch d3f:T1447,
        mitre-attack:T1447 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1630.002" .

d3f:T1448 a owl:Class ;
    rdfs:label "T1448" ;
    d3f:attack-id "T1448" ;
    dcterms:title "Carrier Billing Fraud" ;
    rdfs:seeAlso d3f:T1643 ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "A malicious app may trigger fraudulent charges on a victim’s carrier billing statement in several different ways, including SMS toll fraud and SMS shortcodes that make purchases." ;
    skos:exactMatch d3f:T1448,
        mitre-attack:T1448 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1643" .

d3f:T1451 a owl:Class ;
    rdfs:label "T1451" ;
    d3f:attack-id "T1451" ;
    dcterms:title "SIM Card Swap" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Adversaries may gain access to mobile devices through transfers or swaps from victims’ phone numbers to adversary-controlled SIM cards and mobile devices.(Citation: ATT SIM Swap Scams)(Citation: Verizon SIM Swapping)" ;
    skos:exactMatch d3f:T1451,
        mitre-attack:T1451 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1452 a owl:Class ;
    rdfs:label "T1452" ;
    d3f:attack-id "T1452" ;
    dcterms:title "Manipulate App Store Rankings or Ratings" ;
    rdfs:seeAlso d3f:T1643 ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "An adversary could use access to a compromised device's credentials to attempt to manipulate app store rankings or ratings by triggering application downloads or posting fake reviews of applications. This technique likely requires privileged access (a rooted or jailbroken device)." ;
    skos:exactMatch d3f:T1452,
        mitre-attack:T1452 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1643" .

d3f:T1453 a owl:Class ;
    rdfs:label "T1453" ;
    d3f:attack-id "T1453" ;
    dcterms:title "Abuse Accessibility Features" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCredentialAccessTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileDefenseEvasionTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileImpactTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "**This technique has been deprecated. Please use [Input Capture](https://attack.mitre.org/techniques/T1417), [Input Injection](https://attack.mitre.org/techniques/T1516), and [Input Prompt](https://attack.mitre.org/techniques/T1411) where appropriate.**" ;
    skos:exactMatch d3f:T1453,
        mitre-attack:T1453 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "**This technique has been deprecated. Please use [Input Capture](https://attack.mitre.org/techniques/T1417), [Input Injection](https://attack.mitre.org/techniques/T1516), and [Input Prompt](https://attack.mitre.org/techniques/T1411) where appropriate.**" .

d3f:T1454 a owl:Class ;
    rdfs:label "T1454" ;
    d3f:attack-id "T1454" ;
    dcterms:title "Malicious SMS Message" ;
    rdfs:seeAlso d3f: ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Test" ;
    skos:exactMatch d3f:T1454,
        mitre-attack:T1454 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by" .

d3f:T1456 a owl:Class ;
    rdfs:label "T1456" ;
    d3f:attack-id "T1456" ;
    dcterms:title "Drive-By Compromise" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Adversaries may gain access to a system through a user visiting a website over the normal course of browsing. With this technique, the user's web browser is typically targeted for exploitation, but adversaries may also use compromised websites for non-exploitation behavior such as acquiring an [Application Access Token](https://attack.mitre.org/techniques/T1550/001)." ;
    skos:exactMatch d3f:T1456,
        mitre-attack:T1456 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1458 a owl:Class ;
    rdfs:label "T1458" ;
    d3f:attack-id "T1458" ;
    dcterms:title "Replication Through Removable Media" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileLateralMovementTechnique ],
        d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Adversaries may move onto devices by exploiting or copying malware to devices connected via USB. In the case of Lateral Movement, adversaries may utilize the physical connection of a device to a compromised or malicious charging station or PC to bypass application store requirements and install malicious applications directly.(Citation: Lau-Mactans) In the case of Initial Access, adversaries may attempt to exploit the device via the connection to gain access to data stored on the device.(Citation: Krebs-JuiceJacking) Examples of this include:" ;
    skos:exactMatch d3f:T1458,
        mitre-attack:T1458 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1461 a owl:Class ;
    rdfs:label "T1461" ;
    d3f:attack-id "T1461" ;
    dcterms:title "Lockscreen Bypass" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "An adversary with physical access to a mobile device may seek to bypass the device’s lockscreen. Several methods exist to accomplish this, including:" ;
    skos:exactMatch d3f:T1461,
        mitre-attack:T1461 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1464 a owl:Class ;
    rdfs:label "T1464" ;
    d3f:attack-id "T1464" ;
    dcterms:title "Network Denial of Service" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may perform Network Denial of Service (DoS) attacks to degrade or block the availability of targeted resources to users. Network DoS can be performed by exhausting the network bandwidth that services rely on, or by jamming the signal going to or coming from devices." ;
    skos:exactMatch d3f:T1464,
        mitre-attack:T1464 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1471 a owl:Class ;
    rdfs:label "T1471" ;
    d3f:attack-id "T1471" ;
    dcterms:title "Data Encrypted for Impact" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "An adversary may encrypt files stored on a mobile device to prevent the user from accessing them. This may be done in order to extract monetary compensation from a victim in exchange for decryption or a decryption key (ransomware) or to render data permanently inaccessible in cases where the key is not saved or transmitted." ;
    skos:exactMatch d3f:T1471,
        mitre-attack:T1471 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1472 a owl:Class ;
    rdfs:label "T1472" ;
    d3f:attack-id "T1472" ;
    dcterms:title "Generate Fraudulent Advertising Revenue" ;
    rdfs:seeAlso d3f:T1643 ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "An adversary could seek to generate fraudulent advertising revenue from mobile devices, for example by triggering automatic clicks of advertising links without user involvement." ;
    skos:exactMatch d3f:T1472,
        mitre-attack:T1472 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1643" .

d3f:T1475 a owl:Class ;
    rdfs:label "T1475" ;
    d3f:attack-id "T1475" ;
    dcterms:title "Deliver Malicious App via Authorized App Store" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Malicious applications are a common attack vector used by adversaries to gain a presence on mobile devices. Mobile devices often are configured to allow application installation only from an authorized app store (e.g., Google Play Store or Apple App Store). An adversary may seek to place a malicious application in an authorized app store, enabling the application to be installed onto targeted devices." ;
    skos:exactMatch d3f:T1475,
        mitre-attack:T1475 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1476 a owl:Class ;
    rdfs:label "T1476" ;
    d3f:attack-id "T1476" ;
    dcterms:title "Deliver Malicious App via Other Means" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Malicious applications are a common attack vector used by adversaries to gain a presence on mobile devices. This technique describes installing a malicious application on targeted mobile devices without involving an authorized app store (e.g., Google Play Store or Apple App Store). Adversaries may wish to avoid placing malicious applications in an authorized app store due to increased potential risk of detection or other reasons. However, mobile devices often are configured to allow application installation only from an authorized app store which would prevent this technique from working." ;
    skos:exactMatch d3f:T1476,
        mitre-attack:T1476 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1477 a owl:Class ;
    rdfs:label "T1477" ;
    d3f:attack-id "T1477" ;
    dcterms:title "Exploit via Radio Interfaces" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "The mobile device may be targeted for exploitation through its interface to cellular networks or other radio interfaces." ;
    skos:exactMatch d3f:T1477,
        mitre-attack:T1477 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been deprecated." .

d3f:T1478 a owl:Class ;
    rdfs:label "T1478" ;
    d3f:attack-id "T1478" ;
    dcterms:title "Install Insecure or Malicious Configuration" ;
    rdfs:seeAlso d3f:T1632.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileInitialAccessTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "An adversary could attempt to install insecure or malicious configuration settings on the mobile device, through means such as phishing emails or text messages either directly containing the configuration settings as an attachment, or containing a web link to the configuration settings. The device user may be tricked into installing the configuration settings through social engineering techniques (Citation: Symantec-iOSProfile)." ;
    skos:exactMatch d3f:T1478,
        mitre-attack:T1478 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1632.001" .

d3f:T1482 a owl:Class ;
    rdfs:label "T1482" ;
    d3f:attack-id "T1482" ;
    dcterms:title "Domain Trust Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to gather information on domain trust relationships that may be used to identify lateral movement opportunities in Windows multi-domain/forest environments. Domain trusts provide a mechanism for a domain to allow access to resources based on the authentication procedures of another domain.(Citation: Microsoft Trusts) Domain trusts allow the users of the trusted domain to access resources in the trusting domain. The information discovered may help the adversary conduct [SID-History Injection](https://attack.mitre.org/techniques/T1134/005), [Pass the Ticket](https://attack.mitre.org/techniques/T1550/003), and [Kerberoasting](https://attack.mitre.org/techniques/T1558/003).(Citation: AdSecurity Forging Trust Tickets)(Citation: Harmj0y Domain Trusts) Domain trusts can be enumerated using the `DSEnumerateDomainTrusts()` Win32 API call, .NET methods, and LDAP.(Citation: Harmj0y Domain Trusts) The Windows utility [Nltest](https://attack.mitre.org/software/S0359) is known to be used by adversaries to enumerate domain trusts.(Citation: Microsoft Operation Wilysupply)" ;
    skos:exactMatch d3f:T1482,
        mitre-attack:T1482 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1483 a owl:Class ;
    rdfs:label "T1483" ;
    d3f:attack-id "T1483" ;
    dcterms:title "Domain Generation Algorithms" ;
    rdfs:seeAlso d3f:T1568.002 ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may make use of Domain Generation Algorithms (DGAs) to dynamically identify a destination for command and control traffic rather than relying on a list of static IP addresses or domains. This has the advantage of making it much harder for defenders block, track, or take over the command and control channel, as there potentially could be thousands of domains that malware can check for instructions.(Citation: Cybereason Dissecting DGAs)(Citation: Cisco Umbrella DGA)(Citation: Unit 42 DGA Feb 2019)" ;
    skos:exactMatch d3f:T1483,
        mitre-attack:T1483 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1568.002" .

d3f:T1486 a owl:Class ;
    rdfs:label "T1486" ;
    d3f:attack-id "T1486" ;
    dcterms:title "Data Encrypted for Impact" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may encrypt data on target systems or on large numbers of systems in a network to interrupt availability to system and network resources. They can attempt to render stored data inaccessible by encrypting files or data on local and remote drives and withholding access to a decryption key. This may be done in order to extract monetary compensation from a victim in exchange for decryption or a decryption key (ransomware) or to render data permanently inaccessible in cases where the key is not saved or transmitted.(Citation: US-CERT Ransomware 2016)(Citation: FireEye WannaCry 2017)(Citation: US-CERT NotPetya 2017)(Citation: US-CERT SamSam 2018)" ;
    skos:exactMatch d3f:T1486,
        mitre-attack:T1486 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1487 a owl:Class ;
    rdfs:label "T1487" ;
    d3f:attack-id "T1487" ;
    dcterms:title "Disk Structure Wipe" ;
    rdfs:seeAlso d3f:T1561.002 ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may corrupt or wipe the disk data structures on hard drive necessary to boot systems; targeting specific critical systems as well as a large number of systems in a network to interrupt availability to system and network resources." ;
    skos:exactMatch d3f:T1487,
        mitre-attack:T1487 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1561.002" .

d3f:T1488 a owl:Class ;
    rdfs:label "T1488" ;
    d3f:attack-id "T1488" ;
    dcterms:title "Disk Content Wipe" ;
    rdfs:seeAlso d3f:T1561.001 ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may erase the contents of storage devices on specific systems as well as large numbers of systems in a network to interrupt availability to system and network resources." ;
    skos:exactMatch d3f:T1488,
        mitre-attack:T1488 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1561.001" .

d3f:T1489 a owl:Class ;
    rdfs:label "T1489" ;
    d3f:attack-id "T1489" ;
    dcterms:title "Service Stop" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may stop or disable services on a system to render those services unavailable to legitimate users. Stopping critical services or processes can inhibit or stop response to an incident or aid in the adversary's overall objectives to cause damage to the environment.(Citation: Talos Olympic Destroyer 2018)(Citation: Novetta Blockbuster)" ;
    skos:exactMatch d3f:T1489,
        mitre-attack:T1489 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1490 a owl:Class ;
    rdfs:label "T1490" ;
    d3f:attack-id "T1490" ;
    dcterms:title "Inhibit System Recovery" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may delete or remove built-in data and turn off services designed to aid in the recovery of a corrupted system to prevent recovery.(Citation: Talos Olympic Destroyer 2018)(Citation: FireEye WannaCry 2017) This may deny access to available backups and recovery options." ;
    skos:exactMatch d3f:T1490,
        mitre-attack:T1490 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1492 a owl:Class ;
    rdfs:label "T1492" ;
    d3f:attack-id "T1492" ;
    dcterms:title "Stored Data Manipulation" ;
    rdfs:seeAlso d3f:T1565.001 ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may insert, delete, or manipulate data at rest in order to manipulate external outcomes or hide activity.(Citation: FireEye APT38 Oct 2018)(Citation: DOJ Lazarus Sony 2018) By manipulating stored data, adversaries may attempt to affect a business process, organizational understanding, and decision making." ;
    skos:exactMatch d3f:T1492,
        mitre-attack:T1492 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1565.001" .

d3f:T1493 a owl:Class ;
    rdfs:label "T1493" ;
    d3f:attack-id "T1493" ;
    dcterms:title "Transmitted Data Manipulation" ;
    rdfs:seeAlso d3f:T1565.002 ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may alter data en route to storage or other systems in order to manipulate external outcomes or hide activity.(Citation: FireEye APT38 Oct 2018)(Citation: DOJ Lazarus Sony 2018) By manipulating transmitted data, adversaries may attempt to affect a business process, organizational understanding, and decision making." ;
    skos:exactMatch d3f:T1493,
        mitre-attack:T1493 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1565.002" .

d3f:T1494 a owl:Class ;
    rdfs:label "T1494" ;
    d3f:attack-id "T1494" ;
    dcterms:title "Runtime Data Manipulation" ;
    rdfs:seeAlso d3f:T1565.003 ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may modify systems in order to manipulate the data as it is accessed and displayed to an end user.(Citation: FireEye APT38 Oct 2018)(Citation: DOJ Lazarus Sony 2018) By manipulating runtime data, adversaries may attempt to affect a business process, organizational understanding, and decision making." ;
    skos:exactMatch d3f:T1494,
        mitre-attack:T1494 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1565.003" .

d3f:T1495 a owl:Class ;
    rdfs:label "T1495" ;
    d3f:attack-id "T1495" ;
    dcterms:title "Firmware Corruption" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may overwrite or corrupt the flash memory contents of system BIOS or other firmware in devices attached to a system in order to render them inoperable or unable to boot, thus denying the availability to use the devices and/or the system.(Citation: Symantec Chernobyl W95.CIH) Firmware is software that is loaded and executed from non-volatile memory on hardware devices in order to initialize and manage device functionality. These devices may include the motherboard, hard drive, or video cards." ;
    skos:exactMatch d3f:T1495,
        mitre-attack:T1495 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1500 a owl:Class ;
    rdfs:label "T1500" ;
    d3f:attack-id "T1500" ;
    dcterms:title "Compile After Delivery" ;
    rdfs:seeAlso d3f:T1027.004 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to make payloads difficult to discover and analyze by delivering files to victims as uncompiled code. Similar to [Obfuscated Files or Information](https://attack.mitre.org/techniques/T1027), text-based source code files may subvert analysis and scrutiny from protections targeting executables/binaries. These payloads will need to be compiled before execution; typically via native utilities such as csc.exe or GCC/MinGW.(Citation: ClearSky MuddyWater Nov 2018)" ;
    skos:exactMatch d3f:T1500,
        mitre-attack:T1500 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1027.004" .

d3f:T1501 a owl:Class ;
    rdfs:label "T1501" ;
    d3f:attack-id "T1501" ;
    dcterms:title "Systemd Service" ;
    rdfs:seeAlso d3f:T1543.002 ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Systemd services can be used to establish persistence on a Linux system. The systemd service manager is commonly used for managing background daemon processes (also known as services) and other system resources.(Citation: Linux man-pages: systemd January 2014)(Citation: Freedesktop.org Linux systemd 29SEP2018) Systemd is the default initialization (init) system on many Linux distributions starting with Debian 8, Ubuntu 15.04, CentOS 7, RHEL 7, Fedora 15, and replaces legacy init systems including SysVinit and Upstart while remaining backwards compatible with the aforementioned init systems." ;
    skos:exactMatch d3f:T1501,
        mitre-attack:T1501 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1543.002" .

d3f:T1502 a owl:Class ;
    rdfs:label "T1502" ;
    d3f:attack-id "T1502" ;
    dcterms:title "Parent PID Spoofing" ;
    rdfs:seeAlso d3f:T1134.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may spoof the parent process identifier (PPID) of a new process to evade process-monitoring defenses or to elevate privileges. New processes are typically spawned directly from their parent, or calling, process unless explicitly specified. One way of explicitly assigning the PPID of a new process is via the <code>CreateProcess</code> API call, which supports a parameter that defines the PPID to use.(Citation: DidierStevens SelectMyParent Nov 2009) This functionality is used by Windows features such as User Account Control (UAC) to correctly set the PPID after a requested elevated process is spawned by SYSTEM (typically via <code>svchost.exe</code> or <code>consent.exe</code>) rather than the current user context.(Citation: Microsoft UAC Nov 2018)" ;
    skos:exactMatch d3f:T1502,
        mitre-attack:T1502 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1134.004" .

d3f:T1503 a owl:Class ;
    rdfs:label "T1503" ;
    d3f:attack-id "T1503" ;
    dcterms:title "Credentials from Web Browsers" ;
    rdfs:seeAlso d3f:T1555.003 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may acquire credentials from web browsers by reading files specific to the target browser.  (Citation: Talos Olympic Destroyer 2018)" ;
    skos:exactMatch d3f:T1503,
        mitre-attack:T1503 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1555.003" .

d3f:T1504 a owl:Class ;
    rdfs:label "T1504" ;
    d3f:attack-id "T1504" ;
    dcterms:title "PowerShell Profile" ;
    rdfs:seeAlso d3f:T1546.013 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may gain persistence and elevate privileges in certain situations by abusing [PowerShell](https://attack.mitre.org/techniques/T1086) profiles. A PowerShell profile  (<code>profile.ps1</code>) is a script that runs when PowerShell starts and can be used as a logon script to customize user environments. PowerShell supports several profiles depending on the user or host program. For example, there can be different profiles for PowerShell host programs such as the PowerShell console, PowerShell ISE or Visual Studio Code. An administrator can also configure a profile that applies to all users and host programs on the local computer. (Citation: Microsoft About Profiles)" ;
    skos:exactMatch d3f:T1504,
        mitre-attack:T1504 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.013" .

d3f:T1506 a owl:Class ;
    rdfs:label "T1506" ;
    d3f:attack-id "T1506" ;
    dcterms:title "Web Session Cookie" ;
    rdfs:seeAlso d3f:T1550.004 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries can use stolen session cookies to authenticate to web applications and services. This technique bypasses some multi-factor authentication protocols since the session is already authenticated.(Citation: Pass The Cookie)" ;
    skos:exactMatch d3f:T1506,
        mitre-attack:T1506 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1550.004" .

d3f:T1507 a owl:Class ;
    rdfs:label "T1507" ;
    d3f:attack-id "T1507" ;
    dcterms:title "Network Information Discovery" ;
    rdfs:seeAlso d3f:T1421 ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may use device sensors to collect information about nearby networks, such as Wi-Fi and Bluetooth." ;
    skos:exactMatch d3f:T1507,
        mitre-attack:T1507 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1421" .

d3f:T1508 a owl:Class ;
    rdfs:label "T1508" ;
    d3f:attack-id "T1508" ;
    dcterms:title "Suppress Application Icon" ;
    rdfs:seeAlso d3f:T1628.001 ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "A malicious application could suppress its icon from being displayed to the user in the application launcher to hide the fact that it is installed, and to make it more difficult for the user to uninstall the application. Hiding the application's icon programmatically does not require any special permissions." ;
    skos:exactMatch d3f:T1508,
        mitre-attack:T1508 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1628.001" .

d3f:T1509 a owl:Class ;
    rdfs:label "T1509" ;
    d3f:attack-id "T1509" ;
    dcterms:title "Non-Standard Port" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may generate network traffic using a protocol and port pairing that are typically not associated. For example, HTTPS over port 8088 or port 587 as opposed to the traditional port 443. Adversaries may make changes to the standard port used by a protocol to bypass filtering or muddle analysis/parsing of network data." ;
    skos:exactMatch d3f:T1509,
        mitre-attack:T1509 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1510 a owl:Class ;
    rdfs:label "T1510" ;
    d3f:attack-id "T1510" ;
    dcterms:title "Clipboard Modification" ;
    rdfs:seeAlso d3f:T1641.001 ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may abuse clipboard functionality to intercept and replace information in the Android device clipboard.(Citation: ESET Clipboard Modification February 2019)(Citation: Welivesecurity Clipboard Modification February 2019)(Citation: Syracuse Clipboard Modification 2014) Malicious applications may monitor the clipboard activity through the <code>ClipboardManager.OnPrimaryClipChangedListener</code> interface on Android to determine when the clipboard contents have changed.(Citation: Dr.Webb Clipboard Modification origin2 August 2018)(Citation: Dr.Webb Clipboard Modification origin August 2018) Listening to clipboard activity, reading the clipboard contents, and modifying the clipboard contents requires no explicit application permissions and can be performed by applications running in the background, however, this behavior has changed with the release of Android 10.(Citation: Android 10 Privacy Changes)" ;
    skos:exactMatch d3f:T1510,
        mitre-attack:T1510 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1641.001" .

d3f:T1512 a owl:Class ;
    rdfs:label "T1512" ;
    d3f:attack-id "T1512" ;
    dcterms:title "Video Capture" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "An adversary can leverage a device’s cameras to gather information by capturing video recordings. Images may also be captured, potentially in specified intervals, in lieu of video files." ;
    skos:exactMatch d3f:T1512,
        mitre-attack:T1512 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1513 a owl:Class ;
    rdfs:label "T1513" ;
    d3f:attack-id "T1513" ;
    dcterms:title "Screen Capture" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may use screen capture to collect additional information about a target device, such as applications running in the foreground, user data, credentials, or other sensitive information. Applications running in the background can capture screenshots or videos of another application running in the foreground by using the Android `MediaProjectionManager` (generally requires the device user to grant consent).(Citation: Fortinet screencap July 2019)(Citation: Android ScreenCap1 2019) Background applications can also use Android accessibility services to capture screen contents being displayed by a foreground application.(Citation: Lookout-Monokle) An adversary with root access or Android Debug Bridge (adb) access could call the Android `screencap` or `screenrecord` commands.(Citation: Android ScreenCap2 2019)(Citation: Trend Micro ScreenCap July 2015)" ;
    skos:exactMatch d3f:T1513,
        mitre-attack:T1513 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1514 a owl:Class ;
    rdfs:label "T1514" ;
    d3f:attack-id "T1514" ;
    dcterms:title "Elevated Execution with Prompt" ;
    rdfs:seeAlso d3f:T1548.004 ;
    rdfs:subClassOf d3f:PrivilegeEscalationTechnique ;
    skos:definition "Adversaries may leverage the AuthorizationExecuteWithPrivileges API to escalate privileges by prompting the user for credentials.(Citation: AppleDocs AuthorizationExecuteWithPrivileges) The purpose of this API is to give application developers an easy way to perform operations with root privileges, such as for application installation or updating.  This API does not validate that the program requesting root privileges comes from a reputable source or has been maliciously modified. Although this API is deprecated, it still fully functions in the latest releases of macOS. When calling this API, the user will be prompted to enter their credentials but no checks on the origin or integrity of the program are made. The program calling the API may also load world writable files which can be modified to perform malicious behavior with elevated privileges." ;
    skos:exactMatch d3f:T1514,
        mitre-attack:T1514 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1548.004" .

d3f:T1516 a owl:Class ;
    rdfs:label "T1516" ;
    d3f:attack-id "T1516" ;
    dcterms:title "Input Injection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileImpactTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "A malicious application can inject input to the user interface to mimic user interaction through the abuse of Android's accessibility APIs." ;
    skos:exactMatch d3f:T1516,
        mitre-attack:T1516 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1517 a owl:Class ;
    rdfs:label "T1517" ;
    d3f:attack-id "T1517" ;
    dcterms:title "Access Notifications" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCredentialAccessTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may collect data within notifications sent by the operating system or other applications. Notifications may contain sensitive data such as one-time authentication codes sent over SMS, email, or other mediums. In the case of Credential Access, adversaries may attempt to intercept one-time code sent to the device. Adversaries can also dismiss notifications to prevent the user from noticing that the notification has arrived and can trigger action buttons contained within notifications.(Citation: ESET 2FA Bypass)" ;
    skos:exactMatch d3f:T1517,
        mitre-attack:T1517 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1519 a owl:Class ;
    rdfs:label "T1519" ;
    d3f:attack-id "T1519" ;
    dcterms:title "Emond" ;
    rdfs:seeAlso d3f:T1546.014 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:PrivilegeEscalationTechnique ],
        d3f:PersistenceTechnique ;
    skos:definition "Adversaries may use Event Monitor Daemon (emond) to establish persistence by scheduling malicious commands to run on predictable event triggers. Emond is a [Launch Daemon](https://attack.mitre.org/techniques/T1160) that accepts events from various services, runs them through a simple rules engine, and takes action. The emond binary at <code>/sbin/emond</code> will load any rules from the <code>/etc/emond.d/rules/</code> directory and take action once an explicitly defined event takes place. The rule files are in the plist format and define the name, event type, and action to take. Some examples of event types include system startup and user authentication. Examples of actions are to run a system command or send an email. The emond service will not launch if there is no file present in the QueueDirectories path <code>/private/var/db/emondClients</code>, specified in the [Launch Daemon](https://attack.mitre.org/techniques/T1160) configuration file at<code>/System/Library/LaunchDaemons/com.apple.emond.plist</code>.(Citation: xorrior emond Jan 2018)(Citation: magnusviri emond Apr 2016)(Citation: sentinelone macos persist Jun 2019)" ;
    skos:exactMatch d3f:T1519,
        mitre-attack:T1519 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1546.014" .

d3f:T1520 a owl:Class ;
    rdfs:label "T1520" ;
    d3f:attack-id "T1520" ;
    dcterms:title "Domain Generation Algorithms" ;
    rdfs:seeAlso d3f:T1637.001 ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may use [Domain Generation Algorithms](https://attack.mitre.org/techniques/T1520) (DGAs) to procedurally generate domain names for command and control communication, and other uses such as malicious application distribution.(Citation: securelist rotexy 2018)" ;
    skos:exactMatch d3f:T1520,
        mitre-attack:T1520 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1637.001" .

d3f:T1522 a owl:Class ;
    rdfs:label "T1522" ;
    d3f:attack-id "T1522" ;
    dcterms:title "Cloud Instance Metadata API" ;
    rdfs:seeAlso d3f:T1552.005 ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may attempt to access the Cloud Instance Metadata API to collect credentials and other sensitive data." ;
    skos:exactMatch d3f:T1522,
        mitre-attack:T1522 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1552.005" .

d3f:T1523 a owl:Class ;
    rdfs:label "T1523" ;
    d3f:attack-id "T1523" ;
    dcterms:title "Evade Analysis Environment" ;
    rdfs:seeAlso d3f:T1633.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileDiscoveryTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Malicious applications may attempt to detect their operating environment prior to fully executing their payloads. These checks are often used to ensure the application is not running within an analysis environment such as a sandbox used for application vetting, security research, or reverse engineering." ;
    skos:exactMatch d3f:T1523,
        mitre-attack:T1523 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1633.001" .

d3f:T1525 a owl:Class ;
    rdfs:label "T1525" ;
    d3f:attack-id "T1525" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Implant Internal Image" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may implant cloud or container images with malicious code to establish persistence after gaining access to an environment. Amazon Web Services (AWS) Amazon Machine Images (AMIs), Google Cloud Platform (GCP) Images, and Azure Images as well as popular container runtimes such as Docker can be implanted or backdoored. Unlike [Upload Malware](https://attack.mitre.org/techniques/T1608/001), this technique focuses on adversaries implanting an image in a registry within a victim’s environment. Depending on how the infrastructure is provisioned, this could provide persistent access if the infrastructure provisioning tool is instructed to always use the latest image.(Citation: Rhino Labs Cloud Image Backdoor Technique Sept 2019)" ;
    skos:exactMatch d3f:T1525,
        mitre-attack:T1525 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1526 a owl:Class ;
    rdfs:label "T1526" ;
    d3f:attack-id "T1526" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Service Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "An adversary may attempt to enumerate the cloud services running on a system after gaining access. These methods can differ from platform-as-a-service (PaaS), to infrastructure-as-a-service (IaaS), or software-as-a-service (SaaS). Many services exist throughout the various cloud providers and can include Continuous Integration and Continuous Delivery (CI/CD), Lambda Functions, Azure AD, etc. They may also include security services, such as AWS GuardDuty and Microsoft Defender for Cloud, and logging services, such as AWS CloudTrail and Google Cloud Audit Logs." ;
    skos:exactMatch d3f:T1526,
        mitre-attack:T1526 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1527 a owl:Class ;
    rdfs:label "T1527" ;
    d3f:attack-id "T1527" ;
    dcterms:title "Application Access Token" ;
    rdfs:seeAlso d3f:T1550.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:LateralMovementTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may use application access tokens to bypass the typical authentication process and access restricted accounts, information, or services on remote systems. These tokens are typically stolen from users and used in lieu of login credentials." ;
    skos:exactMatch d3f:T1527,
        mitre-attack:T1527 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1550.001" .

d3f:T1528 a owl:Class ;
    rdfs:label "T1528" ;
    d3f:attack-id "T1528" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Steal Application Access Token" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries can steal application access tokens as a means of acquiring credentials to access remote systems and resources." ;
    skos:exactMatch d3f:T1528,
        mitre-attack:T1528 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1529 a owl:Class ;
    rdfs:label "T1529" ;
    d3f:attack-id "T1529" ;
    dcterms:title "System Shutdown/Reboot" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may shutdown/reboot systems to interrupt access to, or aid in the destruction of, those systems. Operating systems may contain commands to initiate a shutdown/reboot of a machine or network device. In some cases, these commands may also be used to initiate a shutdown/reboot of a remote computer or network device via [Network Device CLI](https://attack.mitre.org/techniques/T1059/008) (e.g. <code>reload</code>).(Citation: Microsoft Shutdown Oct 2017)(Citation: alert_TA18_106A)" ;
    skos:exactMatch d3f:T1529,
        mitre-attack:T1529 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1530 a owl:Class ;
    rdfs:label "T1530" ;
    d3f:attack-id "T1530" ;
    dcterms:title "Data from Cloud Storage" ;
    rdfs:subClassOf d3f:CollectionTechnique ;
    skos:definition "Adversaries may access data from cloud storage." ;
    skos:exactMatch d3f:T1530,
        mitre-attack:T1530 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1531 a owl:Class ;
    rdfs:label "T1531" ;
    d3f:attack-id "T1531" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Account Access Removal" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may interrupt availability of system and network resources by inhibiting access to accounts utilized by legitimate users. Accounts may be deleted, locked, or manipulated (ex: changed credentials) to remove access to accounts. Adversaries may also subsequently log off and/or perform a [System Shutdown/Reboot](https://attack.mitre.org/techniques/T1529) to set malicious changes into place.(Citation: CarbonBlack LockerGoga 2019)(Citation: Unit42 LockerGoga 2019)" ;
    skos:exactMatch d3f:T1531,
        mitre-attack:T1531 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1532 a owl:Class ;
    rdfs:label "T1532" ;
    d3f:attack-id "T1532" ;
    dcterms:title "Archive Collected Data" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may compress and/or encrypt data that is collected prior to exfiltration. Compressing data can help to obfuscate its contents and minimize use of network resources. Encryption can be used to hide information that is being exfiltrated from detection or make exfiltration less conspicuous upon inspection by a defender." ;
    skos:exactMatch d3f:T1532,
        mitre-attack:T1532 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1533 a owl:Class ;
    rdfs:label "T1533" ;
    d3f:attack-id "T1533" ;
    dcterms:title "Data from Local System" ;
    rdfs:subClassOf d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may search local system sources, such as file systems or local databases, to find files of interest and sensitive data prior to exfiltration." ;
    skos:exactMatch d3f:T1533,
        mitre-attack:T1533 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1534 a owl:Class ;
    rdfs:label "T1534" ;
    d3f:attack-id "T1534" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Internal Spearphishing" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "After they already have access to accounts or systems within the environment, adversaries may use internal spearphishing to gain access to additional information or compromise other users within the same organization. Internal spearphishing is multi-staged campaign where a legitimate account is initially compromised either by controlling the user's device or by compromising the account credentials of the user. Adversaries may then attempt to take advantage of the trusted internal account to increase the likelihood of tricking more victims into falling for phish attempts, often incorporating [Impersonation](https://attack.mitre.org/techniques/T1656).(Citation: Trend Micro - Int SP)" ;
    skos:exactMatch d3f:T1534,
        mitre-attack:T1534 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1535 a owl:Class ;
    rdfs:label "T1535" ;
    d3f:attack-id "T1535" ;
    dcterms:title "Unused/Unsupported Cloud Regions" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may create cloud instances in unused geographic service regions in order to evade detection. Access is usually obtained through compromising accounts used to manage cloud infrastructure." ;
    skos:exactMatch d3f:T1535,
        mitre-attack:T1535 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1536 a owl:Class ;
    rdfs:label "T1536" ;
    d3f:attack-id "T1536" ;
    dcterms:title "Revert Cloud Instance" ;
    rdfs:seeAlso d3f:T1578.004 ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "An adversary may revert changes made to a cloud instance after they have performed malicious activities in attempt to evade detection and remove evidence of their presence. In highly virtualized environments, such as cloud-based infrastructure, this may be accomplished by restoring virtual machine (VM) or data storage snapshots through the cloud management dashboard or cloud APIs." ;
    skos:exactMatch d3f:T1536,
        mitre-attack:T1536 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1578.004" .

d3f:T1537 a owl:Class ;
    rdfs:label "T1537" ;
    d3f:attack-id "T1537" ;
    dcterms:title "Transfer Data to Cloud Account" ;
    rdfs:subClassOf d3f:ExfiltrationTechnique ;
    skos:definition "Adversaries may exfiltrate data by transferring the data, including through sharing/syncing and creating backups of cloud environments, to another cloud account they control on the same service." ;
    skos:exactMatch d3f:T1537,
        mitre-attack:T1537 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1538 a owl:Class ;
    rdfs:label "T1538" ;
    d3f:attack-id "T1538" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Service Dashboard" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "An adversary may use a cloud service dashboard GUI with stolen credentials to gain useful information from an operational cloud environment, such as specific services, resources, and features. For example, the GCP Command Center can be used to view all assets, findings of potential security risks, and to run additional queries, such as finding public IP addresses and open ports.(Citation: Google Command Center Dashboard)" ;
    skos:exactMatch d3f:T1538,
        mitre-attack:T1538 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1539 a owl:Class ;
    rdfs:label "T1539" ;
    d3f:attack-id "T1539" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Steal Web Session Cookie" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "An adversary may steal web application or service session cookies and use them to gain access to web applications or Internet services as an authenticated user without needing credentials. Web applications and services often use session cookies as an authentication token after a user has authenticated to a website." ;
    skos:exactMatch d3f:T1539,
        mitre-attack:T1539 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1540 a owl:Class ;
    rdfs:label "T1540" ;
    d3f:attack-id "T1540" ;
    dcterms:title "Code Injection" ;
    rdfs:seeAlso d3f:T1631.001 ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePrivilegeEscalationTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may use code injection attacks to implant arbitrary code into the address space of a running application. Code is then executed or interpreted by that application. Adversaries utilizing this technique may exploit capabilities to load code in at runtime through dynamic libraries." ;
    skos:exactMatch d3f:T1540,
        mitre-attack:T1540 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1631.001" .

d3f:T1541 a owl:Class ;
    rdfs:label "T1541" ;
    d3f:attack-id "T1541" ;
    dcterms:title "Foreground Persistence" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may abuse Android's `startForeground()` API method to maintain continuous sensor access. Beginning in Android 9, idle applications running in the background no longer have access to device sensors, such as the camera, microphone, and gyroscope.(Citation: Android-SensorsOverview) Applications can retain sensor access by running in the foreground, using Android’s `startForeground()` API method. This informs the system that the user is actively interacting with the application, and it should not be killed. The only requirement to start a foreground service is showing a persistent notification to the user.(Citation: Android-ForegroundServices)" ;
    skos:exactMatch d3f:T1541,
        mitre-attack:T1541 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1544 a owl:Class ;
    rdfs:label "T1544" ;
    d3f:attack-id "T1544" ;
    dcterms:title "Ingress Tool Transfer" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may transfer tools or other files from an external system onto a compromised device to facilitate follow-on actions. Files may be copied from an external adversary-controlled system through the command and control channel  or through alternate protocols with another tool such as FTP." ;
    skos:exactMatch d3f:T1544,
        mitre-attack:T1544 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1570 a owl:Class ;
    rdfs:label "T1570" ;
    d3f:attack-id "T1570" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Lateral Tool Transfer" ;
    rdfs:subClassOf d3f:LateralMovementTechnique ;
    skos:definition "Adversaries may transfer tools or other files between systems in a compromised environment. Once brought into the victim environment (i.e., [Ingress Tool Transfer](https://attack.mitre.org/techniques/T1105)) files may then be copied from one system to another to stage adversary tools or other files over the course of an operation." ;
    skos:exactMatch d3f:T1570,
        mitre-attack:T1570 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1572 a owl:Class ;
    rdfs:label "T1572" ;
    d3f:attack-id "T1572" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Protocol Tunneling" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may tunnel network communications to and from a victim system within a separate protocol to avoid detection/network filtering and/or enable access to otherwise unreachable systems. Tunneling involves explicitly encapsulating a protocol within another. This behavior may conceal malicious traffic by blending in with existing traffic and/or provide an outer layer of encryption (similar to a VPN). Tunneling could also enable routing of network packets that would otherwise not reach their intended destination, such as SMB, RDP, or other traffic that would be filtered by network appliances or not routed over the Internet." ;
    skos:exactMatch d3f:T1572,
        mitre-attack:T1572 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1575 a owl:Class ;
    rdfs:label "T1575" ;
    d3f:attack-id "T1575" ;
    dcterms:title "Native API" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileExecutionTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may use Android’s Native Development Kit (NDK) to write native functions that can achieve execution of binaries or functions. Like system calls on a traditional desktop operating system, native code achieves execution on a lower level than normal Android SDK calls." ;
    skos:exactMatch d3f:T1575,
        mitre-attack:T1575 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1576 a owl:Class ;
    rdfs:label "T1576" ;
    d3f:attack-id "T1576" ;
    dcterms:title "Uninstall Malicious Application" ;
    rdfs:seeAlso d3f:T1630.001 ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may include functionality in malware that uninstalls the malicious application from the device. This can be achieved by:" ;
    skos:exactMatch d3f:T1576,
        mitre-attack:T1576 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1630.001" .

d3f:T1577 a owl:Class ;
    rdfs:label "T1577" ;
    d3f:attack-id "T1577" ;
    dcterms:title "Compromise Application Executable" ;
    rdfs:subClassOf d3f:ATTACKMobilePersistenceTechnique ;
    skos:definition "Adversaries may modify applications installed on a device to establish persistent access to a victim. These malicious modifications can be used to make legitimate applications carry out adversary tasks when these applications are in use." ;
    skos:exactMatch d3f:T1577,
        mitre-attack:T1577 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1579 a owl:Class ;
    rdfs:label "T1579" ;
    d3f:attack-id "T1579" ;
    dcterms:title "Keychain" ;
    rdfs:seeAlso d3f:T1634.001 ;
    rdfs:subClassOf d3f:ATTACKMobileCredentialAccessTechnique ;
    skos:definition "Adversaries may collect the keychain storage data from an iOS device to acquire credentials. Keychains are the built-in way for iOS to keep track of users' passwords and credentials for many services and features such as Wi-Fi passwords, websites, secure notes, certificates, private keys, and VPN credentials." ;
    skos:exactMatch d3f:T1579,
        mitre-attack:T1579 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1634.001" .

d3f:T1580 a owl:Class ;
    rdfs:label "T1580" ;
    d3f:attack-id "T1580" ;
    dcterms:title "Cloud Infrastructure Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "An adversary may attempt to discover infrastructure and resources that are available within an infrastructure-as-a-service (IaaS) environment. This includes compute service resources such as instances, virtual machines, and snapshots as well as resources of other services including the storage and database services." ;
    skos:exactMatch d3f:T1580,
        mitre-attack:T1580 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1581 a owl:Class ;
    rdfs:label "T1581" ;
    d3f:attack-id "T1581" ;
    dcterms:title "Geofencing" ;
    rdfs:seeAlso d3f:T1627.001 ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may use a device’s geographical location to limit certain malicious behaviors. For example, malware operators may limit the distribution of a second stage payload to certain geographic regions.(Citation: Lookout eSurv)" ;
    skos:exactMatch d3f:T1581,
        mitre-attack:T1581 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1627.001" .

d3f:T1582 a owl:Class ;
    rdfs:label "T1582" ;
    d3f:attack-id "T1582" ;
    dcterms:title "SMS Control" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may delete, alter, or send SMS messages without user authorization. This could be used to hide C2 SMS messages, spread malware, or various external effects." ;
    skos:exactMatch d3f:T1582,
        mitre-attack:T1582 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1594 a owl:Class ;
    rdfs:label "T1594" ;
    d3f:attack-id "T1594" ;
    dcterms:title "Search Victim-Owned Websites" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Adversaries may search websites owned by the victim for information that can be used during targeting. Victim-owned websites may contain a variety of details, including names of departments/divisions, physical locations, and data about key employees such as names, roles, and contact info (ex: [Email Addresses](https://attack.mitre.org/techniques/T1589/002)). These sites may also have details highlighting business operations and relationships.(Citation: Comparitech Leak)" ;
    skos:exactMatch d3f:T1594,
        mitre-attack:T1594 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1603 a owl:Class ;
    rdfs:label "T1603" ;
    d3f:attack-id "T1603" ;
    dcterms:title "Scheduled Task/Job" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileExecutionTechnique ;
    skos:definition "Adversaries may abuse task scheduling functionality to facilitate initial or recurring execution of malicious code. On Android and iOS, APIs and libraries exist to facilitate scheduling tasks to execute at a specified date, time, or interval." ;
    skos:exactMatch d3f:T1603,
        mitre-attack:T1603 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1604 a owl:Class ;
    rdfs:label "T1604" ;
    d3f:attack-id "T1604" ;
    dcterms:title "Proxy Through Victim" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may use a compromised device as a proxy server to the Internet. By utilizing a proxy, adversaries hide the true IP address of their C2 server and associated infrastructure from the destination of the network traffic. This masquerades an adversary’s traffic as legitimate traffic originating from the compromised device, which can evade IP-based restrictions and alerts on certain services, such as bank accounts and social media websites.(Citation: Threat Fabric Exobot)" ;
    skos:exactMatch d3f:T1604,
        mitre-attack:T1604 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1605 a owl:Class ;
    rdfs:label "T1605" ;
    d3f:attack-id "T1605" ;
    dcterms:title "Command-Line Interface" ;
    rdfs:seeAlso d3f:T1623.001 ;
    rdfs:subClassOf d3f:ATTACKMobileExecutionTechnique ;
    skos:definition "Adversaries may use built-in command-line interfaces to interact with the device and execute commands. Android provides a bash shell that can be interacted with over the Android Debug Bridge (ADB) or programmatically using Java’s `Runtime` package. On iOS, adversaries can interact with the underlying runtime shell if the device has been jailbroken." ;
    skos:exactMatch d3f:T1605,
        mitre-attack:T1605 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1623.001" .

d3f:T1609 a owl:Class ;
    rdfs:label "T1609" ;
    d3f:attack-id "T1609" ;
    dcterms:title "Container Administration Command" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse a container administration service to execute commands within a container. A container administration service such as the Docker daemon, the Kubernetes API server, or the kubelet may allow remote management of containers within an environment.(Citation: Docker Daemon CLI)(Citation: Kubernetes API)(Citation: Kubernetes Kubelet)" ;
    skos:exactMatch d3f:T1609,
        mitre-attack:T1609 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1610 a owl:Class ;
    rdfs:label "T1610" ;
    d3f:attack-id "T1610" ;
    dcterms:title "Deploy Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ExecutionTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may deploy a container into an environment to facilitate execution or evade defenses. In some cases, adversaries may deploy a new container to execute processes associated with a particular image or deployment, such as processes that execute or download malware. In others, an adversary may deploy a new container configured without network rules, user limitations, etc. to bypass existing defenses within the environment. In Kubernetes environments, an adversary may attempt to deploy a privileged or vulnerable container into a specific node in order to [Escape to Host](https://attack.mitre.org/techniques/T1611) and access other containers running on the node. (Citation: AppSecco Kubernetes Namespace Breakout 2020)" ;
    skos:exactMatch d3f:T1610,
        mitre-attack:T1610 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1611 a owl:Class ;
    rdfs:label "T1611" ;
    d3f:attack-id "T1611" ;
    dcterms:title "Escape to Host" ;
    rdfs:subClassOf d3f:PrivilegeEscalationTechnique ;
    skos:definition "Adversaries may break out of a container to gain access to the underlying host. This can allow an adversary access to other containerized resources from the host level or to the host itself. In principle, containerized resources should provide a clear separation of application functionality and be isolated from the host environment.(Citation: Docker Overview)" ;
    skos:exactMatch d3f:T1611,
        mitre-attack:T1611 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1612 a owl:Class ;
    rdfs:label "T1612" ;
    d3f:attack-id "T1612" ;
    dcterms:title "Build Image on Host" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may build a container image directly on a host to bypass defenses that monitor for the retrieval of malicious images from a public registry. A remote <code>build</code> request may be sent to the Docker API that includes a Dockerfile that pulls a vanilla base image, such as alpine, from a public or local registry and then builds a custom image upon it.(Citation: Docker Build Image)" ;
    skos:exactMatch d3f:T1612,
        mitre-attack:T1612 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1613 a owl:Class ;
    rdfs:label "T1613" ;
    d3f:attack-id "T1613" ;
    dcterms:title "Container and Resource Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to discover containers and other resources that are available within a containers environment. Other resources may include images, deployments, pods, nodes, and other information such as the status of a cluster." ;
    skos:exactMatch d3f:T1613,
        mitre-attack:T1613 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1615 a owl:Class ;
    rdfs:label "T1615" ;
    d3f:attack-id "T1615" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Group Policy Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may gather information on Group Policy settings to identify paths for privilege escalation, security measures applied within a domain, and to discover patterns in domain objects that can be manipulated or used to blend in the environment. Group Policy allows for centralized management of user and computer settings in Active Directory (AD). Group policy objects (GPOs) are containers for group policy settings made up of files stored within a predictable network path `\\<DOMAIN>\\SYSVOL\\<DOMAIN>\\Policies\\`.(Citation: TechNet Group Policy Basics)(Citation: ADSecurity GPO Persistence 2016)" ;
    skos:exactMatch d3f:T1615,
        mitre-attack:T1615 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1616 a owl:Class ;
    rdfs:label "T1616" ;
    d3f:attack-id "T1616" ;
    dcterms:title "Call Control" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileCommandAndControlTechnique ],
        [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileImpactTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may make, forward, or block phone calls without user authorization. This could be used for adversary goals such as audio surveillance, blocking or forwarding calls from the device owner, or C2 communication." ;
    skos:exactMatch d3f:T1616,
        mitre-attack:T1616 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1617 a owl:Class ;
    rdfs:label "T1617" ;
    d3f:attack-id "T1617" ;
    dcterms:title "Hooking" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may utilize hooking to hide the presence of artifacts associated with their behaviors to evade detection. Hooking can be used to modify return values or data structures of system APIs and function calls. This process typically involves using 3rd party root frameworks, such as Xposed or Magisk, with either a system exploit or pre-existing root access. By including custom modules for root frameworks, adversaries can hook system APIs and alter the return value and/or system data structures to alter functionality/visibility of various aspects of the system." ;
    skos:exactMatch d3f:T1617,
        mitre-attack:T1617 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1618 a owl:Class ;
    rdfs:label "T1618" ;
    d3f:attack-id "T1618" ;
    dcterms:title "User Evasion" ;
    rdfs:seeAlso d3f:T1628.002 ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to avoid detection by hiding malicious behavior from the user. By doing this, an adversary’s modifications would most likely remain installed on the device for longer, allowing the adversary to continue to operate on that device." ;
    skos:exactMatch d3f:T1618,
        mitre-attack:T1618 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "This technique has been revoked by T1628.002" .

d3f:T1619 a owl:Class ;
    rdfs:label "T1619" ;
    d3f:attack-id "T1619" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Cloud Storage Object Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may enumerate objects in cloud storage infrastructure. Adversaries may use this information during automated discovery to shape follow-on behaviors, including requesting all or specific objects from cloud storage.  Similar to [File and Directory Discovery](https://attack.mitre.org/techniques/T1083) on a local host, after identifying available storage services (i.e. [Cloud Infrastructure Discovery](https://attack.mitre.org/techniques/T1580)) adversaries may access the contents/objects stored in cloud infrastructure." ;
    skos:exactMatch d3f:T1619,
        mitre-attack:T1619 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1620 a owl:Class ;
    rdfs:label "T1620" ;
    d3f:attack-id "T1620" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Reflective Code Loading" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may reflectively load code into a process in order to conceal the execution of malicious payloads. Reflective loading involves allocating then executing payloads directly within the memory of the process, vice creating a thread or process backed by a file path on disk (e.g., [Shared Modules](https://attack.mitre.org/techniques/T1129))." ;
    skos:exactMatch d3f:T1620,
        mitre-attack:T1620 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1621 a owl:Class ;
    rdfs:label "T1621" ;
    d3f:attack-id "T1621" ;
    dcterms:title "Multi-Factor Authentication Request Generation" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may attempt to bypass multi-factor authentication (MFA) mechanisms and gain access to accounts by generating MFA requests sent to users." ;
    skos:exactMatch d3f:T1621,
        mitre-attack:T1621 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1622 a owl:Class ;
    rdfs:label "T1622" ;
    d3f:attack-id "T1622" ;
    dcterms:title "Debugger Evasion" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DiscoveryTechnique ],
        d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may employ various means to detect and avoid debuggers. Debuggers are typically used by defenders to trace and/or analyze the execution of potential malware payloads.(Citation: ProcessHacker Github)" ;
    skos:exactMatch d3f:T1622,
        mitre-attack:T1622 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1640 a owl:Class ;
    rdfs:label "T1640" ;
    d3f:attack-id "T1640" ;
    dcterms:title "Account Access Removal" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may interrupt availability of system and network resources by inhibiting access to accounts utilized by legitimate users. Accounts may be deleted, locked, or manipulated (ex: credentials changed) to remove access to accounts." ;
    skos:exactMatch d3f:T1640,
        mitre-attack:T1640 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1642 a owl:Class ;
    rdfs:label "T1642" ;
    d3f:attack-id "T1642" ;
    dcterms:title "Endpoint Denial of Service" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may perform Endpoint Denial of Service (DoS) attacks to degrade or block the availability of services to users." ;
    skos:exactMatch d3f:T1642,
        mitre-attack:T1642 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1645 a owl:Class ;
    rdfs:label "T1645" ;
    d3f:attack-id "T1645" ;
    dcterms:title "Compromise Client Software Binary" ;
    rdfs:subClassOf d3f:ATTACKMobilePersistenceTechnique ;
    skos:definition "Adversaries may modify system software binaries to establish persistent access to devices. System software binaries are used by the underlying operating system and users over adb or terminal emulators." ;
    skos:exactMatch d3f:T1645,
        mitre-attack:T1645 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1646 a owl:Class ;
    rdfs:label "T1646" ;
    d3f:attack-id "T1646" ;
    dcterms:title "Exfiltration Over C2 Channel" ;
    rdfs:subClassOf d3f:ATTACKMobileExfiltrationTechnique ;
    skos:definition "Adversaries may steal data by exfiltrating it over an existing command and control channel. Stolen data is encoded into the normal communications channel using the same protocol as command and control communications." ;
    skos:exactMatch d3f:T1646,
        mitre-attack:T1646 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1648 a owl:Class ;
    rdfs:label "T1648" ;
    d3f:attack-id "T1648" ;
    dcterms:title "Serverless Execution" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse serverless computing, integration, and automation services to execute arbitrary code in cloud environments. Many cloud providers offer a variety of serverless resources, including compute engines, application integration services, and web servers." ;
    skos:exactMatch d3f:T1648,
        mitre-attack:T1648 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1649 a owl:Class ;
    rdfs:label "T1649" ;
    d3f:attack-id "T1649" ;
    dcterms:title "Steal or Forge Authentication Certificates" ;
    rdfs:subClassOf d3f:CredentialAccessTechnique ;
    skos:definition "Adversaries may steal or forge certificates used for authentication to access remote systems or resources. Digital certificates are often used to sign and encrypt messages and/or files. Certificates are also used as authentication material. For example, Azure AD device certificates and Active Directory Certificate Services (AD CS) certificates bind to an identity and can be used as credentials for domain accounts.(Citation: O365 Blog Azure AD Device IDs)(Citation: Microsoft AD CS Overview)" ;
    skos:exactMatch d3f:T1649,
        mitre-attack:T1649 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1650 a owl:Class ;
    rdfs:label "T1650" ;
    d3f:attack-id "T1650" ;
    dcterms:title "Acquire Access" ;
    rdfs:subClassOf d3f:ResourceDevelopmentTechnique ;
    skos:definition "Adversaries may purchase or otherwise acquire an existing access to a target system or network. A variety of online services and initial access broker networks are available to sell access to previously compromised systems.(Citation: Microsoft Ransomware as a Service)(Citation: CrowdStrike Access Brokers)(Citation: Krebs Access Brokers Fortune 500) In some cases, adversary groups may form partnerships to share compromised systems with each other.(Citation: CISA Karakurt 2022)" ;
    skos:exactMatch d3f:T1650,
        mitre-attack:T1650 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1651 a owl:Class ;
    rdfs:label "T1651" ;
    d3f:attack-id "T1651" ;
    dcterms:title "Cloud Administration Command" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse cloud management services to execute commands within virtual machines. Resources such as AWS Systems Manager, Azure RunCommand, and Runbooks allow users to remotely run scripts in virtual machines by leveraging installed virtual machine agents. (Citation: AWS Systems Manager Run Command)(Citation: Microsoft Run Command)" ;
    skos:exactMatch d3f:T1651,
        mitre-attack:T1651 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1652 a owl:Class ;
    rdfs:label "T1652" ;
    d3f:attack-id "T1652" ;
    dcterms:title "Device Driver Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may attempt to enumerate local device drivers on a victim host. Information about device drivers may highlight various insights that shape follow-on behaviors, such as the function/purpose of the host, present security tools (i.e. [Security Software Discovery](https://attack.mitre.org/techniques/T1518/001)) or other defenses (e.g., [Virtualization/Sandbox Evasion](https://attack.mitre.org/techniques/T1497)), as well as potential exploitable vulnerabilities (e.g., [Exploitation for Privilege Escalation](https://attack.mitre.org/techniques/T1068))." ;
    skos:exactMatch d3f:T1652,
        mitre-attack:T1652 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1653 a owl:Class ;
    rdfs:label "T1653" ;
    d3f:attack-id "T1653" ;
    dcterms:title "Power Settings" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may impair a system's ability to hibernate, reboot, or shut down in order to extend access to infected machines. When a computer enters a dormant state, some or all software and hardware may cease to operate which can disrupt malicious activity.(Citation: Sleep, shut down, hibernate)" ;
    skos:exactMatch d3f:T1653,
        mitre-attack:T1653 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1654 a owl:Class ;
    rdfs:label "T1654" ;
    d3f:attack-id "T1654" ;
    dcterms:title "Log Enumeration" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may enumerate system and service logs to find useful data. These logs may highlight various types of valuable insights for an adversary, such as user authentication records ([Account Discovery](https://attack.mitre.org/techniques/T1087)), security or vulnerable software ([Software Discovery](https://attack.mitre.org/techniques/T1518)), or hosts within a compromised network ([Remote System Discovery](https://attack.mitre.org/techniques/T1018))." ;
    skos:exactMatch d3f:T1654,
        mitre-attack:T1654 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1656 a owl:Class ;
    rdfs:label "T1656" ;
    d3f:attack-id "T1656" ;
    dcterms:title "Impersonation" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may impersonate a trusted person or organization in order to persuade and trick a target into performing some action on their behalf. For example, adversaries may communicate with victims (via [Phishing for Information](https://attack.mitre.org/techniques/T1598), [Phishing](https://attack.mitre.org/techniques/T1566), or [Internal Spearphishing](https://attack.mitre.org/techniques/T1534)) while impersonating a known sender such as an executive, colleague, or third-party vendor. Established trust can then be leveraged to accomplish an adversary’s ultimate goals, possibly against multiple victims." ;
    skos:exactMatch d3f:T1656,
        mitre-attack:T1656 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1657 a owl:Class ;
    rdfs:label "T1657" ;
    d3f:attack-id "T1657" ;
    dcterms:title "Financial Theft" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may steal monetary resources from targets through extortion, social engineering, technical theft, or other methods aimed at their own financial gain at the expense of the availability of these resources for victims. Financial theft is the ultimate objective of several popular campaign types including extortion by ransomware,(Citation: FBI-ransomware) business email compromise (BEC) and fraud,(Citation: FBI-BEC) \"pig butchering,\"(Citation: wired-pig butchering) bank hacking,(Citation: DOJ-DPRK Heist) and exploiting cryptocurrency networks.(Citation: BBC-Ronin)" ;
    skos:exactMatch d3f:T1657,
        mitre-attack:T1657 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1658 a owl:Class ;
    rdfs:label "T1658" ;
    d3f:attack-id "T1658" ;
    dcterms:title "Exploitation for Client Execution" ;
    rdfs:subClassOf d3f:ATTACKMobileExecutionTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities in client applications to execute code. Vulnerabilities can exist in software due to insecure coding practices that can lead to unanticipated behavior. Adversaries may take advantage of certain vulnerabilities through targeted exploitation for the purpose of arbitrary code execution. Oftentimes the most valuable exploits to an offensive toolkit are those that can be used to obtain code execution on a remote system because they can be used to gain access to that system. Users will expect to see files related to the applications they commonly used to do work, so they are a useful target for exploit research and development because of their high utility." ;
    skos:exactMatch d3f:T1658,
        mitre-attack:T1658 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1659 a owl:Class ;
    rdfs:label "T1659" ;
    d3f:attack-id "T1659" ;
    dcterms:title "Content Injection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:InitialAccessTechnique ],
        d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may gain access and continuously communicate with victims by injecting malicious content into systems through online network traffic. Rather than luring victims to malicious payloads hosted on a compromised website (i.e., [Drive-by Target](https://attack.mitre.org/techniques/T1608/004) followed by [Drive-by Compromise](https://attack.mitre.org/techniques/T1189)), adversaries may initially access victims through compromised data-transfer channels where they can manipulate traffic and/or inject their own content. These compromised online network channels may also be used to deliver additional payloads (i.e., [Ingress Tool Transfer](https://attack.mitre.org/techniques/T1105)) and other data to already compromised systems.(Citation: ESET MoustachedBouncer)" ;
    skos:exactMatch d3f:T1659,
        mitre-attack:T1659 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1660 a owl:Class ;
    rdfs:label "T1660" ;
    d3f:attack-id "T1660" ;
    dcterms:title "Phishing" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Adversaries may send malicious content to users in order to gain access to their mobile devices. All forms of phishing are electronically delivered social engineering. Adversaries can conduct both non-targeted phishing, such as in mass malware spam campaigns, as well as more targeted phishing tailored for a specific individual, company, or industry, known as “spearphishing”.  Phishing often involves social engineering techniques, such as posing as a trusted source, as well as evasion techniques, such as removing or manipulating emails or metadata/headers from compromised accounts being abused to send messages." ;
    skos:exactMatch d3f:T1660,
        mitre-attack:T1660 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1661 a owl:Class ;
    rdfs:label "T1661" ;
    d3f:attack-id "T1661" ;
    dcterms:title "Application Versioning" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobileInitialAccessTechnique ],
        d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "An adversary may push an update to a previously benign application to add malicious code. This can be accomplished by pushing an initially benign, functional application to a trusted application store, such as the Google Play Store or the Apple App Store. This allows the adversary to establish a trusted userbase that may grant permissions to the application prior to the introduction of malicious code. Then, an application update could be pushed to introduce malicious code.(Citation: android_app_breaking_bad)" ;
    skos:exactMatch d3f:T1661,
        mitre-attack:T1661 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1662 a owl:Class ;
    rdfs:label "T1662" ;
    d3f:attack-id "T1662" ;
    dcterms:title "Data Destruction" ;
    rdfs:subClassOf d3f:ATTACKMobileImpactTechnique ;
    skos:definition "Adversaries may destroy data and files on specific devices or in large numbers to interrupt availability to systems, services, and network resources. Data destruction is likely to render stored data irrecoverable by forensic techniques through overwriting files or data on local and remote drives." ;
    skos:exactMatch d3f:T1662,
        mitre-attack:T1662 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1663 a owl:Class ;
    rdfs:label "T1663" ;
    d3f:attack-id "T1663" ;
    dcterms:title "Remote Access Software" ;
    rdfs:subClassOf d3f:ATTACKMobileCommandAndControlTechnique ;
    skos:definition "Adversaries may use legitimate remote access software, such as `VNC`, `TeamViewer`, `AirDroid`, `AirMirror`, etc., to establish an interactive command and control channel to target mobile devices." ;
    skos:exactMatch d3f:T1663,
        mitre-attack:T1663 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1664 a owl:Class ;
    rdfs:label "T1664" ;
    d3f:attack-id "T1664" ;
    dcterms:title "Exploitation for Initial Access" ;
    rdfs:subClassOf d3f:ATTACKMobileInitialAccessTechnique ;
    skos:definition "Adversaries may exploit software vulnerabilities to gain initial access to a mobile device." ;
    skos:exactMatch d3f:T1664,
        mitre-attack:T1664 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1665 a owl:Class ;
    rdfs:label "T1665" ;
    d3f:attack-id "T1665" ;
    dcterms:title "Hide Infrastructure" ;
    rdfs:subClassOf d3f:CommandAndControlTechnique ;
    skos:definition "Adversaries may manipulate network traffic in order to hide and evade detection of their C2 infrastructure. This can be accomplished in various ways including by identifying and filtering traffic from defensive tools,(Citation: TA571) masking malicious domains to obfuscate the true destination from both automated scanning tools and security researchers,(Citation: Schema-abuse)(Citation: Facad1ng)(Citation: Browser-updates) and otherwise hiding malicious artifacts to delay discovery and prolong the effectiveness of adversary infrastructure that could otherwise be identified, blocked, or taken down entirely." ;
    skos:exactMatch d3f:T1665,
        mitre-attack:T1665 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1666 a owl:Class ;
    rdfs:label "T1666" ;
    d3f:attack-id "T1666" ;
    dcterms:title "Modify Cloud Resource Hierarchy" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may attempt to modify hierarchical structures in infrastructure-as-a-service (IaaS) environments in order to evade defenses." ;
    skos:exactMatch d3f:T1666,
        mitre-attack:T1666 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1667 a owl:Class ;
    rdfs:label "T1667" ;
    d3f:attack-id "T1667" ;
    dcterms:title "Email Bombing" ;
    rdfs:subClassOf d3f:ImpactTechnique ;
    skos:definition "Adversaries may flood targeted email addresses with an overwhelming volume of messages. This may bury legitimate emails in a flood of spam and disrupt business operations.(Citation: sophos-bombing)(Citation: krebs-email-bombing)" ;
    skos:exactMatch d3f:T1667,
        mitre-attack:T1667 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1668 a owl:Class ;
    rdfs:label "T1668" ;
    d3f:attack-id "T1668" ;
    dcterms:title "Exclusive Control" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries who successfully compromise a system may attempt to maintain persistence by “closing the door” behind them  – in other words, by preventing other threat actors from initially accessing or maintaining a foothold on the same system." ;
    skos:exactMatch d3f:T1668,
        mitre-attack:T1668 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1669 a owl:Class ;
    rdfs:label "T1669" ;
    d3f:attack-id "T1669" ;
    dcterms:title "Wi-Fi Networks" ;
    rdfs:subClassOf d3f:InitialAccessTechnique ;
    skos:definition "Adversaries may gain initial access to target systems by connecting to wireless networks. They may accomplish this by exploiting open Wi-Fi networks used by target devices or by accessing secured Wi-Fi networks — requiring [Valid Accounts](https://attack.mitre.org/techniques/T1078) — belonging to a target organization.(Citation: DOJ GRU Charges 2018)(Citation: Nearest Neighbor Volexity) Establishing a connection to a Wi-Fi access point requires a certain level of proximity to both discover and maintain a stable network connection." ;
    skos:exactMatch d3f:T1669,
        mitre-attack:T1669 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1670 a owl:Class ;
    rdfs:label "T1670" ;
    d3f:attack-id "T1670" ;
    dcterms:title "Virtualization Solution" ;
    rdfs:subClassOf d3f:ATTACKMobileDefenseEvasionTechnique ;
    skos:definition "Adversaries may carry out malicious operations using virtualization solutions to escape from Android sandboxes and to avoid detection. Android uses sandboxes to separate resources and code execution between applications and the operating system.(Citation: Android Application Sandbox) There are a few virtualization solutions available on Android, such as the Android Virtualization Framework (AVF).(Citation: Android AVF Overview)" ;
    skos:exactMatch d3f:T1670,
        mitre-attack:T1670 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1671 a owl:Class ;
    rdfs:label "T1671" ;
    d3f:attack-id "T1671" ;
    dcterms:title "Cloud Application Integration" ;
    rdfs:subClassOf d3f:PersistenceTechnique ;
    skos:definition "Adversaries may achieve persistence by leveraging OAuth application integrations in a software-as-a-service environment. Adversaries may create a custom application, add a legitimate application into the environment, or even co-opt an existing integration to achieve malicious ends.(Citation: Push Security SaaS Persistence 2022)(Citation: SaaS Attacks GitHub Evil Twin Integrations)" ;
    skos:exactMatch d3f:T1671,
        mitre-attack:T1671 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1672 a owl:Class ;
    rdfs:label "T1672" ;
    d3f:attack-id "T1672" ;
    dcterms:title "Email Spoofing" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may fake, or spoof, a sender’s identity by modifying the value of relevant email headers in order to establish contact with victims under false pretenses.(Citation: Proofpoint TA427 April 2024) In addition to actual email content, email headers (such as the FROM header, which contains the email address of the sender) may also be modified. Email clients display these headers when emails appear in a victim's inbox, which may cause modified emails to appear as if they were from the spoofed entity." ;
    skos:exactMatch d3f:T1672,
        mitre-attack:T1672 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1673 a owl:Class ;
    rdfs:label "T1673" ;
    d3f:attack-id "T1673" ;
    dcterms:title "Virtual Machine Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "An adversary may attempt to enumerate running virtual machines (VMs) after gaining access to a host or hypervisor. For example, adversaries may enumerate a list of VMs on an ESXi hypervisor using a [Hypervisor CLI](https://attack.mitre.org/techniques/T1059/012) such as `esxcli` or `vim-cmd` (e.g. `esxcli vm process list or vim-cmd vmsvc/getallvms`).(Citation: Crowdstrike Hypervisor Jackpotting Pt 2 2021)(Citation: TrendMicro Play) Adversaries may also directly leverage a graphical user interface, such as VMware vCenter, in order to view virtual machines on a host." ;
    skos:exactMatch d3f:T1673,
        mitre-attack:T1673 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1674 a owl:Class ;
    rdfs:label "T1674" ;
    d3f:attack-id "T1674" ;
    dcterms:title "Input Injection" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may simulate keystrokes on a victim’s computer by various means to perform any type of action on behalf of the user, such as launching the command interpreter using keyboard shortcuts,  typing an inline script to be executed, or interacting directly with a GUI-based application.  These actions can be preprogrammed into adversary tooling or executed through physical devices such as Human Interface Devices (HIDs)." ;
    skos:exactMatch d3f:T1674,
        mitre-attack:T1674 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1675 a owl:Class ;
    rdfs:label "T1675" ;
    d3f:attack-id "T1675" ;
    dcterms:title "ESXi Administration Command" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may abuse ESXi administration services to execute commands on guest machines hosted within an ESXi virtual environment. Persistent background services on ESXi-hosted VMs, such as the VMware Tools Daemon Service, allow for remote management from the ESXi server. The tools daemon service runs as `vmtoolsd.exe` on Windows guest operating systems, `vmware-tools-daemon` on macOS, and `vmtoolsd ` on Linux.(Citation: Broadcom VMware Tools Services)" ;
    skos:exactMatch d3f:T1675,
        mitre-attack:T1675 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1676 a owl:Class ;
    rdfs:label "T1676" ;
    d3f:attack-id "T1676" ;
    dcterms:title "Linked Devices" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ATTACKMobilePersistenceTechnique ],
        d3f:ATTACKMobileCollectionTechnique ;
    skos:definition "Adversaries may abuse the “linked devices” feature on messaging applications, such as Signal and WhatsApp, to register the user’s account to an adversary-controlled device. By abusing the “linked devices” feature, adversaries may achieve and maintain persistence through the user’s account, may collect information, such as the user’s messages and contacts list, and may send future messages from the linked device." ;
    skos:exactMatch d3f:T1676,
        mitre-attack:T1676 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1677 a owl:Class ;
    rdfs:label "T1677" ;
    d3f:attack-id "T1677" ;
    dcterms:title "Poisoned Pipeline Execution" ;
    rdfs:subClassOf d3f:ExecutionTechnique ;
    skos:definition "Adversaries may manipulate continuous integration / continuous development (CI/CD) processes by injecting malicious code into the build process. There are several mechanisms for poisoning pipelines:" ;
    skos:exactMatch d3f:T1677,
        mitre-attack:T1677 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1678 a owl:Class ;
    rdfs:label "T1678" ;
    d3f:attack-id "T1678" ;
    dcterms:title "Delay Execution" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may employ various time-based methods to evade detection and analysis. These techniques often exploit system clocks, delays, or timing mechanisms to obscure malicious activity, blend in with benign activity, and avoid scrutiny. Adversaries can perform this behavior within virtualization/sandbox environments or natively on host systems." ;
    skos:exactMatch d3f:T1678,
        mitre-attack:T1678 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1679 a owl:Class ;
    rdfs:label "T1679" ;
    d3f:attack-id "T1679" ;
    dcterms:title "Selective Exclusion" ;
    rdfs:subClassOf d3f:DefenseEvasionTechnique ;
    skos:definition "Adversaries may intentionally exclude certain files, folders, directories, file types, or system components from encryption or tampering during a ransomware or malicious payload execution. Some file extensions that adversaries may avoid encrypting include `.dll`, `.exe`, and `.lnk`.(Citation: Palo Alto Unit 42 Medusa Group Medusa Ransomware January 2024)" ;
    skos:exactMatch d3f:T1679,
        mitre-attack:T1679 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1680 a owl:Class ;
    rdfs:label "T1680" ;
    d3f:attack-id "T1680" ;
    dcterms:title "Local Storage Discovery" ;
    rdfs:subClassOf d3f:DiscoveryTechnique ;
    skos:definition "Adversaries may enumerate local drives, disks, and/or volumes and their attributes like total or free space and volume serial number. This can be done to prepare for ransomware-related encryption, to perform [Lateral Movement](https://attack.mitre.org/tactics/TA0109), or as a precursor to [Direct Volume Access](https://attack.mitre.org/techniques/T1006)." ;
    skos:exactMatch d3f:T1680,
        mitre-attack:T1680 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:T1681 a owl:Class ;
    rdfs:label "T1681" ;
    d3f:attack-id "T1681" ;
    dcterms:title "Search Threat Vendor Data" ;
    rdfs:subClassOf d3f:ReconnaissanceTechnique ;
    skos:definition "Threat actors may seek information/indicators from closed or open threat intelligence sources gathered about their own campaigns, as well as those conducted by other adversaries that may align with their target industries, capabilities/objectives, or other operational concerns. These reports may include descriptions of behavior, detailed breakdowns of attacks, atomic indicators such as malware hashes or IP addresses, timelines of a group’s activity, and more. Adversaries may change their behavior when planning their future operations." ;
    skos:exactMatch d3f:T1681,
        mitre-attack:T1681 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TFTPNetworkTraffic a owl:Class ;
    rdfs:label "TFTPNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "TFTP Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "TFTP Network Traffic is network traffic typically used to automatically transfer configuration or boot files between machines." ;
    skos:exactMatch d3f:TFTPNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TFTPServer a owl:Class ;
    rdfs:label "TFTPServer" ;
    dcterms:title "TFTP Server" ;
    rdfs:seeAlso dbr:Trivial_File_Transfer_Protocol ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "Trivial File Transfer Protocol (TFTP) is a simple file transfer protocol, typically used to automatically transfer configuration or boot files between machines.  It is used where user authentication and directory visibility are not required." ;
    skos:exactMatch d3f:TFTPServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TPMBootIntegrity a owl:Class ;
    rdfs:label "TPMBootIntegrity" ;
    d3f:d3fend-id "D3-TBI" ;
    d3f:kb-article "## How it works During the boot process, the BIOS boot block (which with this defense enabled, is the Core Root of Trust for Measurement) measures boot components (firmware, ROM). The TPM hashes those measurements and stores the hashes in Platform Configuration Registers (PCRs). Upon a subsequent b" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "STRM" ;
    dcterms:title "TPM Boot Integrity" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:definition "Assuring the integrity of a platform by demonstrating that the boot process starts from a trusted combination of hardware and software and continues until the operating system has fully booted and applications are running.  Sometimes called Static Root of Trust Measurement (STRM)." ;
    skos:exactMatch d3f:TPMBootIntegrity ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TabletComputer a owl:Class ;
    rdfs:label "TabletComputer" ;
    dcterms:title "Tablet Computer" ;
    rdfs:seeAlso dbr:Tablet_computer ;
    rdfs:subClassOf d3f:PersonalComputer ;
    skos:altLabel "Tablet" ;
    skos:definition "A tablet computer, commonly shortened to tablet, is a mobile device, typically with a mobile operating system and touchscreen display processing circuitry, and a rechargeable battery in a single, thin and flat package. Tablets, being computers, do what other personal computers do, but lack some input/output (I/O) abilities that others have. Modern tablets largely resemble modern smartphones, the only differences being that tablets are relatively larger than smartphones, with screens 7 inches (18 cm) or larger, measured diagonally, and may not support access to a cellular network." ;
    skos:exactMatch d3f:TabletComputer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TargetAudience a owl:Class ;
    rdfs:label "TargetAudience" ;
    dcterms:title "Target Audience" ;
    rdfs:subClassOf d3f:AgentGroup ;
    skos:exactMatch d3f:TargetAudience ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Telecommand a owl:Class ;
    rdfs:label "Telecommand" ;
    d3f:synonym "Remote Control Command" ;
    rdfs:seeAlso dbr:Telecommand ;
    rdfs:subClassOf d3f:RemoteCommand ;
    skos:definition "A telecommand or telecontrol is a command sent to control a remote system or systems not directly connected (e.g. via wires) to the place from which the telecommand is sent." ;
    skos:exactMatch d3f:Telecommand ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TemporalLogic a owl:Class ;
    rdfs:label "TemporalLogic" ;
    d3f:d3fend-id "D3A-TL" ;
    d3f:kb-article "## References 1. Temporal logic. (2023, June 4). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Modal_logic#Temporal_logic)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Temporal Logic" ;
    rdfs:subClassOf d3f:ModalLogic ;
    skos:definition "Temporal logic addresses the semantics of tense; i.e., qualifying expressions of when." ;
    skos:exactMatch d3f:TemporalLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TerminateProcess a owl:Class ;
    rdfs:label "TerminateProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Terminate Process" ;
    rdfs:seeAlso dbr:Exit_\(system_call\) ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "On many computer operating systems, a computer process terminates its execution by making an exit system call. More generally, an exit in a multithreading environment means that a thread of execution has stopped running. For resource management, the operating system reclaims resources (memory, files, etc.) that were used by the process. The process is said to be a dead process after it terminates." ;
    skos:exactMatch d3f:TerminateProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TertiaryStorage a owl:Class ;
    rdfs:label "TertiaryStorage" ;
    dcterms:title "Tertiary Storage" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Computer_data_storage#Tertiary_storage> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:SecondaryStorage ],
        d3f:HardwareDevice ;
    skos:definition "Tertiary storage or tertiary memory is memory primarily used for archiving rarely accessed information. It is primarily useful for extraordinarily large data stores. Typical examples include tape libraries and optical jukeboxes." ;
    skos:exactMatch d3f:TertiaryStorage ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Thread a owl:Class ;
    rdfs:label "Thread" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "A Thread is the smallest unit of execution within a process, representing a sequence of instructions that can be scheduled and executed independently by the operating system." ;
    skos:exactMatch d3f:Thread,
        unified_cyber_ontology:Thread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ThreadStartFunction a owl:Class ;
    rdfs:label "ThreadStartFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Thread Start Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "A function which invokes a create thread system call." ;
    skos:exactMatch d3f:ThreadStartFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimeInstant a owl:Class ;
    rdfs:label "TimeInstant" ;
    dcterms:title "Time Instant" ;
    rdfs:subClassOf d3f:Time ;
    skos:definition "A time instant is a zero-dimensional temporal region that has no duration and represents a singular point in the temporal continuum. Time instants serve as the temporal boundaries of temporal intervals and as the indexical points at which continuants exist and bear their qualities." ;
    skos:exactMatch d3f:TimeInstant ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimeInterval a owl:Class ;
    rdfs:label "TimeInterval" ;
    dcterms:title "Time Interval" ;
    rdfs:subClassOf d3f:Time ;
    skos:definition "A time interval is a one-dimensional temporal region that has duration and represents a continuous extent of time bounded by two time instants (a start instant and an end instant)." ;
    skos:exactMatch d3f:TimeInterval ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimeSeriesDatabase a owl:Class ;
    rdfs:label "TimeSeriesDatabase" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Time Series Database" ;
    rdfs:subClassOf d3f:Database ;
    skos:definition "A specialized database optimized for storing and retrieving time-stamped data." ;
    skos:exactMatch d3f:TimeSeriesDatabase ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimerExpirationEvent a owl:Class ;
    rdfs:label "TimerExpirationEvent" ;
    dcterms:title "Timer Expiration Event" ;
    rdfs:subClassOf d3f:SoftwareTimerEvent ;
    skos:definition "An event in which a software timer reaches its configured duration and triggers associated actions (callbacks, interrupts, or signals)." ;
    skos:exactMatch d3f:TimerExpirationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimerModificationEvent a owl:Class ;
    rdfs:label "TimerModificationEvent" ;
    dcterms:title "Timer Modification Event" ;
    rdfs:subClassOf d3f:SoftwareTimerEvent ;
    skos:definition "An event in which the duration or expiration time of an active timer is changed." ;
    skos:exactMatch d3f:TimerModificationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TimerSetEvent a owl:Class ;
    rdfs:label "TimerSetEvent" ;
    dcterms:title "Timer Set Event" ;
    rdfs:subClassOf d3f:SoftwareTimerEvent ;
    skos:definition "An event in which a software timer is initialized with a specific duration or expiration time." ;
    skos:exactMatch d3f:TimerSetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TokenBinding a owl:Class ;
    rdfs:label "TokenBinding" ;
    d3f:d3fend-id "D3-TB" ;
    d3f:kb-article "## How it works When issuing a security token to a client that supports Token Binding, a server includes the client's Token Binding ID (or its cryptographic hash) in the token. Later on, when a client presents a security token containing a Token Binding ID, the server verifies that the ID in the to" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Token Binding" ;
    rdfs:seeAlso dbr:Token_Binding ;
    rdfs:subClassOf d3f:CredentialHardening ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "Token binding is a security mechanism used to enhance the protection of tokens, such as cookies or OAuth tokens, by binding them to a specific connection." ;
    skos:exactMatch d3f:TokenBinding ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1528,
        mitre-attack:T1550.001,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:TraceProcess a owl:Class ;
    rdfs:label "TraceProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Trace Process" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Ptrace>,
        <https://linux.die.net/man/2/ptrace> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:altLabel "Open Process" ;
    skos:definition "A trace system call provides a means by which one process (the \"tracer\") may observe and control the execution of another process (the \"tracee\"), and examine and change the tracee's memory and registers. It is primarily used to implement breakpoint debugging and system call tracing." ;
    skos:exactMatch d3f:TraceProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TraceThread a owl:Class ;
    rdfs:label "TraceThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Trace Thread" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:TraceThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TrajectoryPrediction a owl:Class ;
    rdfs:label "TrajectoryPrediction" ;
    dcterms:title "Trajectory Prediction" ;
    rdfs:subClassOf d3f:Forecasting ;
    skos:exactMatch d3f:TrajectoryPrediction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Transceiver a owl:Class ;
    rdfs:label "Transceiver" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <https://www.analog.com/en/resources/glossary/transceiver.html> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A transceiver is a device that contains both a transmitter and receiver." ;
    skos:exactMatch d3f:Transceiver ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TransducerSensor a owl:Class ;
    rdfs:label "TransducerSensor" ;
    dcterms:title "Transducer Sensor" ;
    rdfs:subClassOf d3f:Sensor ;
    skos:definition "A Transducer Sensor converts physical signals into digital data for monitoring purposes." ;
    skos:exactMatch d3f:TransducerSensor ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TransferAgentAuthentication a owl:Class ;
    rdfs:label "TransferAgentAuthentication" ;
    d3f:d3fend-id "D3-TAAN" ;
    d3f:kb-article "## How it works Transfer Agent Authentication can be accomplished in different ways for depending on the protocol. In Email, Sender Policy Framework (SPF), Domain Key Identified Email (DKIM) or Domain-based Message Authentication Reporting and Conformance (DMARC) are used to validate sender domain o" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Transfer Agent Authentication" ;
    rdfs:subClassOf d3f:MessageHardening ;
    skos:definition "Validating that server components of a messaging infrastructure are authorized to send a particular message." ;
    skos:exactMatch d3f:TransferAgentAuthentication ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TranslationLookasideBuffer a owl:Class ;
    rdfs:label "TranslationLookasideBuffer" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Translation Lookaside Buffer" ;
    rdfs:seeAlso <https://dbpedia.org/page/Translation_lookaside_buffer> ;
    rdfs:subClassOf d3f:MemoryManagementUnitComponent ;
    skos:definition "A translation lookaside buffer (TLB) is a memory cache that is used to reduce the time taken to access a user memory location. It is a part of the chip's memory-management unit (MMU)." ;
    skos:exactMatch d3f:TranslationLookasideBuffer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Transmitter a owl:Class ;
    rdfs:label "Transmitter" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso <https://dbpedia.org/page/Signal_transmission> ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A device or system that takes information and generates a signal suitable for propagation. It encodes and formats the content, impresses it on a physical carrier (such as electromagnetic fields, light, electrical currents, or acoustic waves), and performs signal conditioning—such as modulation, pulse shaping, pre-emphasis, and power amplification—to meet spectral, timing, and power requirements. A transmitter may be analog or digital, implemented in hardware, software, or both, and is designed to launch the signal into the chosen medium with characteristics that enable reliable reception." ;
    skos:exactMatch d3f:Transmitter ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TransportLink a owl:Class ;
    rdfs:label "TransportLink" ;
    dcterms:title "Transport Link" ;
    rdfs:subClassOf d3f:LogicalLink ;
    skos:definition "A Transport Link is a type of logical link that exists at the transport layer of a network or system architecture." ;
    skos:exactMatch d3f:TransportLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TrimmedMean a owl:Class ;
    rdfs:label "TrimmedMean" ;
    d3f:d3fend-id "D3A-TM" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Central tendency. [Link](https://en.wikipedia.org/wiki/Central_tendency)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Truncated mean" ;
    dcterms:title "Trimmed Mean" ;
    rdfs:subClassOf d3f:CentralTendency ;
    skos:definition "The arithmetic mean of data values after a certain number or proportion of the highest and lowest data values have been discarded." ;
    skos:exactMatch d3f:TrimmedMean ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TrustedAdministratorAttacker a owl:Class ;
    rdfs:label "TrustedAdministratorAttacker" ;
    dcterms:title "Trusted Administrator Attacker" ;
    rdfs:subClassOf d3f:TrustedAttacker ;
    skos:definition "A trusted attacker who misuses administrative access to execute attacks, often with elevated privileges." ;
    skos:exactMatch d3f:TrustedAdministratorAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TrustedLibrary a owl:Class ;
    rdfs:label "TrustedLibrary" ;
    d3f:d3fend-id "D3-TL" ;
    d3f:kb-article "## How it Works Using a trusted library can reduce the chances of introducing errors compared to writing code from scratch. ## Considerations Note: This resource should not be considered a definitive or exhaustive coding guideline." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Trusted Library" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:broadMatch d3f:T1505 ;
    skos:definition "A trusted library is a collection of pre-verified and secure code modules or components that are used within software applications to perform specific functions. These libraries are considered reliable and have been vetted for security vulnerabilities, ensuring they do not introduce risks into the application." ;
    skos:exactMatch d3f:TrustedLibrary ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1505.001 .

d3f:TrustedUserAttacker a owl:Class ;
    rdfs:label "TrustedUserAttacker" ;
    dcterms:title "Trusted User Attacker" ;
    rdfs:subClassOf d3f:TrustedAttacker ;
    skos:definition "A trusted attacker who abuses regular user-level access privileges to compromise systems or data." ;
    skos:exactMatch d3f:TrustedUserAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TunnelCloseEvent a owl:Class ;
    rdfs:label "TunnelCloseEvent" ;
    dcterms:title "Tunnel Close Event" ;
    rdfs:subClassOf d3f:TunnelEvent ;
    skos:definition "An event where a network tunnel is terminated, ending encapsulated communication and releasing the associated resources." ;
    skos:exactMatch d3f:TunnelCloseEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TunnelOpenEvent a owl:Class ;
    rdfs:label "TunnelOpenEvent" ;
    dcterms:title "Tunnel Open Event" ;
    rdfs:subClassOf d3f:TunnelEvent ;
    skos:definition "An event where a network tunnel is established, enabling encapsulated communication between endpoints. This marks the initiation of secure or isolated data transport through the tunnel." ;
    skos:exactMatch d3f:TunnelOpenEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:TunnelRenewEvent a owl:Class ;
    rdfs:label "TunnelRenewEvent" ;
    dcterms:title "Tunnel Renew Event" ;
    rdfs:subClassOf d3f:TunnelEvent ;
    skos:definition "An event where the lifecycle of a network tunnel is extended, ensuring continued encapsulated communication and avoiding session expiration." ;
    skos:exactMatch d3f:TunnelRenewEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:URLAnalysis a owl:Class ;
    rdfs:label "URLAnalysis" ;
    d3f:d3fend-id "D3-UA" ;
    d3f:kb-article "## How it works URLs may contain components, for example: * scheme * userinfo * host name * port * path * query * fragment These components are used as features in analysis algorithms. Contextual information about a URL such as where it is embedded (ex. emails, files, network protocols)," ;
    d3f:owl_named_individual "true" ;
    dcterms:title "URL Analysis" ;
    rdfs:subClassOf d3f:IdentifierAnalysis ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:T1204,
        d3f:T1566 ;
    skos:definition "Determining if a URL is benign or malicious by analyzing the URL or its components." ;
    skos:exactMatch d3f:URLAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1189,
        mitre-attack:T1204.001,
        mitre-attack:T1566.002,
        mitre-attack:T1566.003 .

d3f:URLReputationAnalysis a owl:Class ;
    rdfs:label "URLReputationAnalysis" ;
    d3f:d3fend-id "D3-URA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "URL Reputation Analysis" ;
    rdfs:subClassOf d3f:IdentifierReputationAnalysis ;
    skos:broadMatch d3f:InitialAccessTechnique,
        d3f:T1204,
        d3f:T1566 ;
    skos:definition "Analyzing the reputation of a URL." ;
    skos:exactMatch d3f:URLReputationAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1189,
        mitre-attack:T1204.001,
        mitre-attack:T1566.002,
        mitre-attack:T1566.003 .

d3f:UncertaintySampling a owl:Class ;
    rdfs:label "UncertaintySampling" ;
    d3f:d3fend-id "D3A-US" ;
    d3f:kb-article "## References Intro to Active Learning. inovex Blog. [Link](https://www.inovex.de/de/blog/intro-to-active-learning/)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Uncertainty Sampling" ;
    rdfs:subClassOf d3f:ActiveLearning ;
    skos:definition "Makes the utility inversely proportional to the uncertainty of the model with respect to the sample and will work with any  model provided it can assess its uncertainty of a predection." ;
    skos:exactMatch d3f:UncertaintySampling ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnitTestExecutionTool a owl:Class ;
    rdfs:label "UnitTestExecutionTool" ;
    dcterms:title "Unit Test Execution Tool" ;
    rdfs:seeAlso dbr:Unit_testing ;
    rdfs:subClassOf d3f:TestExecutionTool ;
    skos:definition "An unit test execution tool automatically performs unit testing.  Unit testing is a software testing method by which individual units of source code are tested to determine whether they are fit for use.  Unit test execution tools work with sets of one or more computer program modules together with associated control data, usage procedures, and operating procedures. This contrasts with integration testing, which tests inter-unit dependencies and the modules as a group." ;
    skos:exactMatch d3f:UnitTestExecutionTool ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnixHardLink a owl:Class ;
    rdfs:label "UnixHardLink" ;
    dcterms:title "Unix Hard Link" ;
    rdfs:seeAlso dbr:Hard_link ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:UnixLink ],
        d3f:HardLink ;
    skos:definition "A Unix hard link is a hard link on a Unix file system." ;
    skos:exactMatch d3f:UnixHardLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnloadLibraryEvent a owl:Class ;
    rdfs:label "UnloadLibraryEvent" ;
    dcterms:title "Unload Library Event" ;
    rdfs:seeAlso <https://schema.ocsf.io/classes/module_activity> ;
    rdfs:subClassOf d3f:ProcessEvent ;
    skos:definition "An event where a process unloads a dynamically linked library or module, reducing its memory footprint or functionality." ;
    skos:exactMatch d3f:UnloadLibraryEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnloadModule a owl:Class ;
    rdfs:label "UnloadModule" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Unload Module" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "A system call that unloads a driver or extension from the kernel." ;
    skos:exactMatch d3f:UnloadModule ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UnlockAccount a owl:Class ;
    rdfs:label "UnlockAccount" ;
    d3f:d3fend-id "D3-ULA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Unlock Account" ;
    rdfs:subClassOf d3f:RestoreUserAccountAccess ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:ImpactTechnique,
        d3f:InitialAccessTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1078,
        d3f:T1087,
        d3f:T1098,
        d3f:T1136 ;
    skos:definition "Restoring a user account's access to resources by unlocking a locked User Account." ;
    skos:exactMatch d3f:UnlockAccount ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1078,
        mitre-attack:T1078.001,
        mitre-attack:T1078.002,
        mitre-attack:T1078.003,
        mitre-attack:T1078.004,
        mitre-attack:T1087.001,
        mitre-attack:T1087.002,
        mitre-attack:T1087.004,
        mitre-attack:T1098,
        mitre-attack:T1098.002,
        mitre-attack:T1098.003,
        mitre-attack:T1136,
        mitre-attack:T1136.001,
        mitre-attack:T1136.002,
        mitre-attack:T1136.003,
        mitre-attack:T1531 .

d3f:UseCaseGoal a owl:Class ;
    rdfs:label "UseCaseGoal" ;
    dcterms:title "Use Case Goal" ;
    rdfs:subClassOf d3f:Goal ;
    skos:exactMatch d3f:UseCaseGoal ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UseCaseProcedure a owl:Class ;
    rdfs:label "UseCaseProcedure" ;
    dcterms:title "Use Case Procedure" ;
    rdfs:subClassOf d3f:Procedure ;
    skos:exactMatch d3f:UseCaseProcedure ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UseCaseStep a owl:Class ;
    rdfs:label "UseCaseStep" ;
    dcterms:title "Use Case Step" ;
    rdfs:subClassOf d3f:Step ;
    skos:exactMatch d3f:UseCaseStep ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:User a owl:Class ;
    rdfs:label "User" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso d3f:UserAccount,
        dbr:User_\(computing\),
        <http://wordnet-rdf.princeton.edu/id/10761247-n> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:DigitalInformationBearer ],
        d3f:Agent ;
    skos:definition "A user is a person [or agent] who uses a computer or network service. Users generally use a system or a software product without the technical expertise required to fully understand it. Power users use advanced features of programs, though they are not necessarily capable of computer programming and system administration. A user often has a user account and is identified to the system by a username (or user name). Other terms for username include login name, screenname (or screen name), nickname (or nick) and handle, which is derived from the identical Citizen's Band radio term. Some software products provide services to other systems and have no direct end users." ;
    skos:exactMatch d3f:User ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountAttachPolicyEvent a owl:Class ;
    rdfs:label "UserAccountAttachPolicyEvent" ;
    dcterms:title "User Account Attach Policy Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where an IAM policy is attached to a user account." ;
    skos:exactMatch d3f:UserAccountAttachPolicyEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountCreationEvent a owl:Class ;
    rdfs:label "UserAccountCreationEvent" ;
    dcterms:title "User Account Creation Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event representing the creation of a new user account within a system or domain." ;
    skos:exactMatch d3f:UserAccountCreationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountDeletionEvent a owl:Class ;
    rdfs:label "UserAccountDeletionEvent" ;
    dcterms:title "User Account Deletion Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event representing the permanent deletion of a user account from a system or domain." ;
    skos:exactMatch d3f:UserAccountDeletionEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountDetachPolicyEvent a owl:Class ;
    rdfs:label "UserAccountDetachPolicyEvent" ;
    dcterms:title "User Account Detach Policy Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where an IAM policy is detached from a user account." ;
    skos:exactMatch d3f:UserAccountDetachPolicyEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountDisableEvent a owl:Class ;
    rdfs:label "UserAccountDisableEvent" ;
    dcterms:title "User Account Disable Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where a user account is disabled, preventing its active use within the system." ;
    skos:exactMatch d3f:UserAccountDisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountEnableEvent a owl:Class ;
    rdfs:label "UserAccountEnableEvent" ;
    dcterms:title "User Account Enable Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where a user account is enabled, granting it active use within the system." ;
    skos:exactMatch d3f:UserAccountEnableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountLockEvent a owl:Class ;
    rdfs:label "UserAccountLockEvent" ;
    dcterms:title "User Account Lock Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where a user account is locked out due to failed authentication attempts or administrative action." ;
    skos:exactMatch d3f:UserAccountLockEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountMFADisableEvent a owl:Class ;
    rdfs:label "UserAccountMFADisableEvent" ;
    dcterms:title "User Account MFA Disable Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where multi-factor authentication (MFA) is disabled for a user account." ;
    skos:exactMatch d3f:UserAccountMFADisableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountMFAEnableEvent a owl:Class ;
    rdfs:label "UserAccountMFAEnableEvent" ;
    dcterms:title "User Account MFA Enable Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where multi-factor authentication (MFA) is enabled for a user account." ;
    skos:exactMatch d3f:UserAccountMFAEnableEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountPasswordChangeEvent a owl:Class ;
    rdfs:label "UserAccountPasswordChangeEvent" ;
    dcterms:title "User Account Password Change Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where a user account's password is modified, typically by the user or an administrator." ;
    skos:exactMatch d3f:UserAccountPasswordChangeEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountPasswordResetEvent a owl:Class ;
    rdfs:label "UserAccountPasswordResetEvent" ;
    dcterms:title "User Account Password Reset Event" ;
    rdfs:subClassOf d3f:UserAccountEvent ;
    skos:definition "An event where a user account's password is reset, typically due to a forgotten password or administrative action." ;
    skos:exactMatch d3f:UserAccountPasswordResetEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:UserAccountPermissions a owl:Class ;
    rdfs:label "UserAccountPermissions" ;
    d3f:d3fend-id "D3-UAP" ;
    d3f:owl_named_individual "true" ;
