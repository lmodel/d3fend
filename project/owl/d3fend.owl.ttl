d3f:GroupPolicy a owl:Class ;
    rdfs:label "GroupPolicy" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Group Policy" ;
    rdfs:subClassOf d3f:AccessControlConfiguration ;
    skos:definition "Group Policy is a feature of the Microsoft Windows NT family of operating systems that controls the working environment of user accounts and computer accounts. Group Policy provides the centralized management and configuration of operating systems, applications, and users' settings in an Active Directory environment. A version of Group Policy called Local Group Policy (\"LGPO\" or \"LocalGPO\") also allows Group Policy Object management on standalone and non-domain computers." ;
    skos:exactMatch d3f:GroupPolicy ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Grouping a owl:Class ;
    rdfs:label "Grouping" ;
    rdfs:subClassOf d3f:Summarizing ;
    skos:exactMatch d3f:Grouping,
        stix:Grouping,
        unified_cyber_ontology:Grouping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

