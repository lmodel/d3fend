d3f:NetworkVideoStreamingResource a owl:Class ;
    rdfs:label "NetworkVideoStreamingResource" ;
    dcterms:title "Network Video Streaming Resource" ;
    rdfs:subClassOf d3f:NetworkMediaStreamingResource ;
    skos:definition "A server that provides digital video media content to users." ;
    skos:exactMatch d3f:NetworkVideoStreamingResource ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NetworkVulnerabilityAssessment a owl:Class ;
    rdfs:label "NetworkVulnerabilityAssessment" ;
    d3f:d3fend-id "D3-NVA" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Network Vulnerability Assessment" ;
    rdfs:subClassOf d3f:NetworkMapping ;
    skos:definition "Network vulnerability assessment relates all the vulnerabilities of a network's components in the context of their configuration and interdependencies and can also include assessing risk emerging from the network's design as a whole, not just the sum of individual network node or network segment vulnerabilities." ;
    skos:exactMatch d3f:NetworkVulnerabilityAssessment ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NonPersonEntity a owl:Class ;
    rdfs:label "Non_PersonEntity" ;
    d3f:synonym "NPE" ;
    dcterms:title "Non-Person Entity" ;
    rdfs:seeAlso d3f:NIST_SP_800-53_R5,
        d3f:Reference-CNNSI-4009,
        <https://csrc.nist.gov/glossary/term/non_person_entity> ;
    rdfs:subClassOf d3f:Agent ;
    skos:altLabel "Non-PersonEntity" ;
    skos:definition "An entity related to information technology with a digital identity that acts in cyberspace, but is not a human actor. This can include organizations, hardware objects (physical entities/devices), software objects (virtual/logical entities), and information artifacts." ;
    skos:exactMatch d3f:Non-PersonEntity ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NonlinearRegressionLearning a owl:Class ;
    rdfs:label "NonlinearRegressionLearning" ;
    d3f:d3fend-id "D3A-NRL" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Nonlinear regression. [Link](https://en.wikipedia.org/wiki/Nonlinear_regression)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Nonlinear Regression Learning" ;
    rdfs:seeAlso d3f:NonlinearRegression ;
    rdfs:subClassOf d3f:RegressionAnalysisLearning ;
    skos:definition "A supervised learning method that builds a non-linear regression model using training data." ;
    skos:exactMatch d3f:NonlinearRegressionLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:NullPointerChecking a owl:Class ;
    rdfs:label "NullPointerChecking" ;
    d3f:d3fend-id "D3-NPC" ;
    d3f:kb-article "## How it Works Programmatically checking if a pointer is NULL before use. ## Considerations * Pointers should be checked prior to use after they have, or may have been modified. * Note that it may vary by circumstance whether the caller, or callee is responsible for checking if a pointer is NULL." ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Nil Pointer Checking" ;
    dcterms:title "Null Pointer Checking" ;
    rdfs:subClassOf d3f:PointerValidation ;
    skos:definition "Checking if a pointer is NULL." ;
    skos:exactMatch d3f:NullPointerChecking ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OTAbortCommand a owl:Class ;
    rdfs:label "OTAbortCommand" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "OT Abort Command" ;
    rdfs:seeAlso <https://icscsi.org/library/Documents/ICS_Protocols/Control%20Microsystems%20-%20DNP3%20User%20and%20Reference%20Manual.pdf>,
        <https://modbus.org/docs/Modbus_Application_Protocol_V1_1b3.pdf>,
        <https://nvlpubs.nist.gov/nistpubs/TechnicalNotes/NIST.TN.2023.pdf> ;
    rdfs:subClassOf d3f:OTModifyDeviceOperatingModeCommand ;
    skos:definition "Commands a device to abort a service/program." ;
    skos:exactMatch d3f:OTAbortCommand ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:note "BACnet: deviceCommunicationControl BACnet: reinitializeDevice",
        "GE-SRTP: SET PLC (RUN VS STOP)" .

d3f:OTAbortCommandEvent a owl:Class ;
