d3f:ContentRebuild a owl:Class ;
    rdfs:label "ContentRebuild" ;
    d3f:d3fend-id "D3-CNR" ;
    d3f:kb-article "## How it works If inputted content is divided up into components for further scrutiny, the components may be combined back afterwards in a safer state." ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Content Reconstruction" ;
    dcterms:title "Content Rebuild" ;
    rdfs:subClassOf d3f:ContentModification ;
    skos:definition "Rebuild the file according to the spec so any unreferenced components or objects are removed." ;
    skos:exactMatch d3f:ContentRebuild ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ContentSubstitution a owl:Class ;
    rdfs:label "ContentSubstitution" ;
    d3f:d3fend-id "D3-CNS" ;
    d3f:kb-article "## How it works If malicious or unecessary elements is discovered within the content, or if a specific embedded portion does not comply with policy, it may be replaced with alternatives to ensure safety." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Content Substitution" ;
    rdfs:subClassOf d3f:ContentModification ;
    skos:definition "Modifies specific digital content information by replacing it with something else." ;
    skos:exactMatch d3f:ContentSubstitution ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ControlCorrelationIdentifierCatalog a owl:Class ;
    rdfs:label "ControlCorrelationIdentifierCatalog" ;
    dcterms:title "Control Correlation Identifier Catalog" ;
    rdfs:seeAlso cci: ;
    rdfs:subClassOf d3f:ControlCatalog ;
    skos:definition "A control correlation identifier (CCI) catalog provides a catalog of CCIs for a given release date." ;
    skos:exactMatch d3f:ControlCorrelationIdentifierCatalog ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ControlFlowIntegrity a owl:Class ;
    rdfs:label "ControlFlowIntegrity" ;
    d3f:d3fend-id "D3-CFI" ;
    d3f:kb-article "## How it works Control flow integrity (CFI) restricts the destinations of control flow transfer instructions---particularly indirect function branches such as indirect function calls, jumps, and returns---such that execution can only proceed along paths determined to be valid at compile-time or lo" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Control Flow Integrity" ;
    rdfs:subClassOf d3f:ApplicationHardening ;
    skos:definition "Enforcing legal control flow transfers during application process execution." ;
    skos:exactMatch d3f:ControlFlowIntegrity ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ControlFlowPolicy a owl:Class ;
    rdfs:label "ControlFlowPolicy" ;
    dcterms:title "Control Flow Policy" ;
    rdfs:subClassOf d3f:ControlFlowGraph ;
    skos:definition "A control flow policy is a subset of the possible control flow transfers computed from a program's control flow graph. It defines only the expected and allowed control flow transfers and is enforced by control flow integrity." ;
    skos:exactMatch d3f:ControlFlowPolicy ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CopyMemoryFunction a owl:Class ;
    rdfs:label "CopyMemoryFunction" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Copy Memory Function" ;
    rdfs:subClassOf d3f:Subroutine ;
    skos:definition "Copies a memory block from one location to another." ;
    skos:exactMatch d3f:CopyMemoryFunction ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CramersV a owl:Class ;
    rdfs:label "CramersV" ;
    d3f:d3fend-id "D3A-CV" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Cramér's V. [Link](https://en.wikipedia.org/wiki/Cram%C3%A9r%27s_V)" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Cramer's Phi" ;
    dcterms:title "Cramer's V" ;
    rdfs:subClassOf d3f:Correlation ;
    skos:definition "Cramér's V (sometimes referred to as Cramér's phi and denoted as φc) is a measure of association between two nominal variables, giving a value between 0 and +1 (inclusive) and is based on Pearson's chi-squared statistic." ;
    skos:exactMatch d3f:CramersV ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CreateFile a owl:Class ;
    rdfs:label "CreateFile" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Create File" ;
    rdfs:seeAlso <https://docs.microsoft.com/en-us/windows/win32/api/fileapi/nf-fileapi-createfile2>,
        <https://docs.microsoft.com/en-us/windows/win32/api/fileapi/nf-fileapi-createfilea>,
        <https://docs.microsoft.com/en-us/windows/win32/api/fileapi/nf-fileapi-createfilew>,
        <https://linux.die.net/man/2/creat> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "System call to create a new file on a file system. Some operating systems implement this functionality as part of their d3f:OpenFile system call." ;
    skos:exactMatch d3f:CreateFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CreateProcess a owl:Class ;
    rdfs:label "CreateProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Create Process" ;
    rdfs:seeAlso dbr:Fork%E2%80%93exec,
        dbr:Spawn_\(computing\),
        <https://dbpedia.org/page/Fork%E2%80%93exec>,
        <https://dbpedia.org/page/Spawn_(computing)>,
        <https://docs.microsoft.com/en-us/windows/win32/procthread/creating-processes>,
        <https://learn.microsoft.com/en-us/windows/win32/procthread/creating-processes> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:altLabel "Execute Process",
        "Process Spawn",
        "Spawn Process" ;
    skos:definition "A process spawn refers to a function that loads and executes a new child process.The current process may wait for the child to terminate or may continue to execute asynchronously. Creating a new subprocess requires enough memory in which both the child process and the current program can execute. There is a family of spawn functions in DOS, inherited by Microsoft Windows. There is also a different family of spawn functions in an optional extension of the POSIX standards.  Fork-exec is another technique combining two Unix system calls, which can effect a process spawn." ;
    skos:exactMatch d3f:CreateProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CreateSocket a owl:Class ;
    rdfs:label "CreateSocket" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Create Socket" ;
    rdfs:seeAlso <https://www.man7.org/linux/man-pages/man2/socket.2.html> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "A create socket system call creates an endpoint for communication and returns a file descriptor that refers to that endpoint." ;
    skos:exactMatch d3f:CreateSocket ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CreateThread a owl:Class ;
    rdfs:label "CreateThread" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Create Thread" ;
    rdfs:seeAlso dbr:POSIX_Threads,
        <https://docs.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-createthread> ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:definition "Threads are an execution model that exists independently from a language, as well as a parallel execution model. They enable a program to control multiple different flows of work that overlap in time." ;
    skos:exactMatch d3f:CreateThread ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CredentialCompromiseScopeAnalysis a owl:Class ;
    rdfs:label "CredentialCompromiseScopeAnalysis" ;
    d3f:d3fend-id "D3-CCSA" ;
    d3f:kb-article "## How it works #### Memory Credentials may be stored in memory for a variety of reasons; on Windows, they may be stored in lsass.exe. Once a credential dumper like mimikatz runs and dumps the memory of lsass.exe, the credentials of every account logged on since boot are potentially compromised. W" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Compromise Scope Analysis" ;
    rdfs:subClassOf d3f:UserBehaviorAnalysis ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1003,
        d3f:T1098,
        d3f:T1110,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "Determining which credentials may have been compromised by analyzing the user logon history of a particular system." ;
    skos:exactMatch d3f:CredentialCompromiseScopeAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.003,
        mitre-attack:T1003.005,
        mitre-attack:T1003.008,
        mitre-attack:T1098.001,
        mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003,
        mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1142,
        mitre-attack:T1528,
        mitre-attack:T1539,
        mitre-attack:T1550.001,
        mitre-attack:T1550.004,
        mitre-attack:T1552,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:CredentialManagementSystem a owl:Class ;
    rdfs:label "CredentialManagementSystem" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Management System" ;
    rdfs:seeAlso dbr:Credential_Management ;
    rdfs:subClassOf d3f:ServiceApplication ;
    skos:definition "Credential Management, also referred to as a Credential Management System (CMS), is an established form of software that is used for issuing and managing credentials as part of public key infrastructure (PKI)." ;
    skos:exactMatch d3f:CredentialManagementSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:CredentialRevocation a owl:Class ;
    rdfs:label "CredentialRevocation" ;
    d3f:d3fend-id "D3-CR" ;
    d3f:kb-article "## How it works Management servers with enterprise policies for account management provide the ability remove permissions, accounts, or credentials. Compromised credentials should be revoked to prevent further malicious activity." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Revocation" ;
    rdfs:subClassOf d3f:CredentialEviction ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:T1003,
        d3f:T1098,
        d3f:T1110,
        d3f:T1134,
        d3f:T1550,
        d3f:T1558 ;
    skos:definition "Deleting a set of credentials permanently to prevent them from being used to authenticate." ;
    skos:exactMatch d3f:CredentialRevocation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.003,
        mitre-attack:T1003.005,
        mitre-attack:T1003.008,
        mitre-attack:T1098.001,
        mitre-attack:T1110.001,
        mitre-attack:T1110.002,
        mitre-attack:T1110.003,
        mitre-attack:T1134.001,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1142,
        mitre-attack:T1528,
        mitre-attack:T1539,
        mitre-attack:T1550.001,
        mitre-attack:T1550.004,
        mitre-attack:T1552,
        mitre-attack:T1558,
        mitre-attack:T1558.001 .

d3f:CredentialScrubbing a owl:Class ;
    rdfs:label "CredentialScrubbing" ;
    d3f:d3fend-id "D3-CS" ;
    d3f:kb-article "## How it Works Credential Scrubbing involves identifying and eliminating hard-coded credentials such as usernames, passwords, API keys, and tokens from source code repositories. These credentials should be managed securely using environment variables, secret management tools, or secure vaults where" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Credential Scrubbing" ;
    rdfs:seeAlso d3f:CWE-798,
        capec:191.html ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:broadMatch d3f:T1505 ;
    skos:definition "The systematic removal of hard-coded credentials from source code to prevent accidental exposure and unauthorized access." ;
    skos:exactMatch d3f:CredentialScrubbing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1505.001 .

