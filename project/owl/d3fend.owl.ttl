d3f:OTReadCommandEvent a owl:Class ;
    rdfs:label "OTReadCommandEvent" ;
    dcterms:title "OT Read Command Event" ;
    rdfs:subClassOf d3f:OTProcessDataCommandEvent ;
    skos:definition "Read or retrieve data." ;
    skos:exactMatch d3f:OTReadCommandEvent ;
