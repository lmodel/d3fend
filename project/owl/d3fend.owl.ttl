        d3f:T1137,
        d3f:T1204,
        d3f:T1218,
        d3f:T1505,
        d3f:T1543,
        d3f:T1546,
        d3f:T1547,
        d3f:T1548,
        d3f:T1552,
        d3f:T1555,
        d3f:T1556,
        d3f:T1560,
        d3f:T1562,
        d3f:T1564,
        d3f:T1565,
        d3f:T1566,
        d3f:T1573,
        d3f:T1574 ;
    skos:definition "Restoring a file for an entity to access." ;
    skos:exactMatch d3f:RestoreFile ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.007,
        mitre-attack:T1003.008,
