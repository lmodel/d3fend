d3f:PerturbationBasedLearning a owl:Class ;
    rdfs:label "Perturbation_basedLearning" ;
    d3f:d3fend-id "D3A-PBL" ;
    d3f:kb-article "## References Zheng, Y., & Song, Y. (2021). An Effective Perturbation-Based Semi-Supervised Learning Method for Acoustic Event Classification. IEEE/ACM Transactions on Audio, Speech, and Language Processing, 29, 3580-3591. [Link](https://www.semanticscholar.org/paper/An-Effective-Perturbation-Based-" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Perturbation-based Learning" ;
    rdfs:subClassOf d3f:IntrinsicallySemiSupervisedLearning ;
    skos:altLabel "Perturbation-basedLearning" ;
    skos:definition "Perturbation based methods are proposed under the smoothness assumption, which indicates that two data points close to each other in feature space are likely to have the same label." ;
    skos:exactMatch d3f:Perturbation-basedLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PointBiserialCorrelationCoefficient a owl:Class ;
    rdfs:label "Point_biserialCorrelationCoefficient" ;
    d3f:d3fend-id "D3A-PBCC" ;
    d3f:kb-article "## References Wikipedia. (n.d.). Point-biserial correlation coefficient. [Link](https://en.wikipedia.org/wiki/Point-biserial_correlation_coefficient)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Point-biserial Correlation Coefficient" ;
    rdfs:subClassOf d3f:Correlation ;
    skos:altLabel "Point-biserialCorrelationCoefficient" ;
    skos:definition "The point biserial correlation coefficient (rpb) is a correlation coefficient used when one variable (e.g. Y) is dichotomous; Y can either be \"naturally\" dichotomous, like whether a coin lands heads or tails, or an artificially dichotomized variable." ;
    skos:exactMatch d3f:Point-biserialCorrelationCoefficient ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessSelfModificationDetection a owl:Class ;
    rdfs:label "ProcessSelf_ModificationDetection" ;
    d3f:d3fend-id "D3-PSMD" ;
    d3f:kb-article "## How it Works A security agent installed on the host machine intercepts API calls between a process and operating system. Intercepted API calls are then compared against attack signatures/patterns to identify API calls that modify executable memory or modify the entry point address of a suspended" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Self-Modification Detection" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:altLabel "ProcessSelf-ModificationDetection" ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1505,
        d3f:T1546,
        d3f:T1562 ;
    skos:definition "Detects processes that modify, change, or replace their own code at runtime." ;
    skos:exactMatch d3f:ProcessSelf-ModificationDetection ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1033,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
