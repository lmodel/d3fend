d3f:OperatingSystem a owl:Class ;
    rdfs:label "OperatingSystem" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System" ;
    rdfs:seeAlso dbr:Operating_system,
        <https://schema.ocsf.io/objects/os> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:definition "An operating system (OS) is system software that manages computer hardware and software resources and provides common services for computer programs. All computer programs, excluding firmware, require an operating system to function. Time-sharing operating systems schedule tasks for efficient use of the system and may also include accounting software for cost allocation of processor time, mass storage, printing, and other resources." ;
    skos:exactMatch d3f:OperatingSystem,
        unified_cyber_ontology:OperatingSystem ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OperatingSystemProcess a owl:Class ;
    rdfs:label "OperatingSystemProcess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Operating System Process" ;
    rdfs:seeAlso <http://people.scs.carleton.ca/~maheshwa/courses/300/l4/node7.html> ;
    rdfs:subClassOf d3f:Process ;
    skos:altLabel "System Process" ;
    skos:definition "An operating system process, or system process, is a process running to perform operating system functions." ;
    skos:exactMatch d3f:OperatingSystemProcess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OrchestrationServer a owl:Class ;
    rdfs:label "OrchestrationServer" ;
    dcterms:title "Orchestration Server" ;
    rdfs:seeAlso dbr:Orchestration_\(computing\) ;
    rdfs:subClassOf d3f:Server ;
    skos:definition "A d3f:Server which is involved with the orchestration of workloads or the execution of orchestrated workloads." ;
    skos:exactMatch d3f:OrchestrationServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutboundInternetEncryptedTraffic a owl:Class ;
    rdfs:label "OutboundInternetEncryptedTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Outbound Internet Encrypted Traffic" ;
    rdfs:seeAlso dbr:Internetworking ;
    rdfs:subClassOf d3f:OutboundInternetNetworkTraffic ;
    skos:definition "Outbound internet encrypted traffic is encrypted network traffic on an outgoing connection initiated from a host within a network to a host outside the network." ;
    skos:exactMatch d3f:OutboundInternetEncryptedTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:OutputDevice a owl:Class ;
    rdfs:label "OutputDevice" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Output Device" ;
    rdfs:seeAlso dbr:Output_device ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "An output device is any piece of computer hardware equipment which converts information into human-readable form. It can be text, graphics, tactile, audio, and video. Some of the output devices are Visual Display Units (VDU) i.e. a Monitor, Printer, Graphic Output devices, Plotters, Speakers etc. A new type of Output device is been developed these days, known as Speech synthesizer, a mechanism attached to the computer which produces verbal output sounding almost like human speeches." ;
    skos:exactMatch d3f:OutputDevice ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PasswordStore a owl:Class ;
    rdfs:label "PasswordStore" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Password Store" ;
    rdfs:seeAlso dbr:Password_manager ;
    rdfs:subClassOf d3f:PasswordDatabase ;
    skos:definition "A user repository of account passwords, often accessed via a password manager." ;
    skos:exactMatch d3f:PasswordStore ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PatternMatching a owl:Class ;
    rdfs:label "PatternMatching" ;
    d3f:d3fend-id "D3A-PM" ;
    d3f:kb-article "## References 1. Pattern matching. (2023, May 20). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Pattern_matching)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pattern Matching" ;
    rdfs:subClassOf d3f:LogicalRules ;
    skos:definition "Pattern matching is the act of checking a given sequence of tokens for the presence of the constituents of some pattern." ;
    skos:exactMatch d3f:PatternMatching ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLink a owl:Class ;
    rdfs:label "PhysicalLink" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Layer-1 Link" ;
    dcterms:title "Physical Link" ;
    rdfs:seeAlso <https://dbpedia.org/resource/Physical_layer> ;
    rdfs:subClassOf d3f:Link ;
    skos:definition """A physical link is a dedicated connection for communication that uses some physical media (electrical, electromagnetic, optical, to include clear spaces or vacuums.)  A physical link represents only a single hop (link) in any larger communcations path, circuit, or network.

NOTE: not synonymous with data link as a data link can be over a telecommunications circuit, which may be a virtual circuit composed of multiple phyical links.""" ;
    skos:exactMatch d3f:PhysicalLink ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PhysicalLinkMapping a owl:Class ;
    rdfs:label "PhysicalLinkMapping" ;
    d3f:d3fend-id "D3-PLM" ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Layer 1 Mapping" ;
    dcterms:title "Physical Link Mapping" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Network_topology#Links> ;
    rdfs:subClassOf d3f:NetworkMapping ;
    skos:broadMatch d3f:T1114,
        d3f:T1505 ;
    skos:definition "Physical link mapping identifies and models the link connectivity of the network devices within a physical network." ;
    skos:exactMatch d3f:PhysicalLinkMapping ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1114.002,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003 .

d3f:PhysicalLock a owl:Class ;
    rdfs:label "PhysicalLock" ;
    dcterms:title "Physical Lock" ;
    rdfs:seeAlso <https://dbpedia.org/page/Lock_and_key> ;
    rdfs:subClassOf d3f:PhysicalArtifact ;
    skos:definition "A lock is a mechanical latching device for securing moveable portions of physical barriers in a secured position." ;
    skos:exactMatch d3f:PhysicalLock ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Pipe a owl:Class ;
    rdfs:label "Pipe" ;
    d3f:owl_named_individual "true" ;
    rdfs:seeAlso dbr:Pipeline_\(Unix\),
        <http://www.linfo.org/pipe.html> ;
    rdfs:subClassOf d3f:DigitalInformationBearer ;
    skos:altLabel "Pipeline" ;
    skos:definition "In Unix-like computer operating systems, a pipeline is a mechanism for inter-process communication using message passing.  In the strictest sense, a pipe is a single segment of a pipeline, allowing one process to pass information forward to another.  Network pipes allow processes on different hosts to interact." ;
    skos:exactMatch d3f:Pipe,
        unified_cyber_ontology:Pipe ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PointerValidation a owl:Class ;
    rdfs:label "PointerValidation" ;
    d3f:d3fend-id "D3-PV" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Pointer Validation" ;
    rdfs:subClassOf d3f:SourceCodeHardening ;
    skos:definition "Ensuring that a pointer variable has the required properties for use." ;
    skos:exactMatch d3f:PointerValidation ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:PredicateLogic a owl:Class ;
    rdfs:label "PredicateLogic" ;
    d3f:d3fend-id "D3A-PL" ;
    d3f:kb-article "## References 1. First-order logic. (2023, May 26). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/First-order_logic) 2. Higher-order logic. (2023, May 13) [Link](https://en.wikipedia.org/wiki/Higher-order_logic)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Predicate Logic" ;
    rdfs:subClassOf d3f:SymbolicAI ;
    skos:definition "Predicate logic is is collection of formal systems used in mathematics, philosophy, linguistics, and computer science. First-order logic and Higher-order logic both incorporate predicate logic." ;
    skos:exactMatch d3f:PredicateLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProcessCodeSegmentEnum a owl:Class ;
    rdfs:label "ProcessCodeSegmentEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( d3f:AMD64CodeSegment d3f:ARM32CodeSegment d3f:X86CodeSegment ) ;
    skos:definition "Enumeration of ProcessCodeSegment values. Open set: additional string values beyond this list are permitted." ;
    skos:editorialNote "A process code segment, also known as a text segment or simply as text, is a portion of the program's virtual address space that contains executable instructions and corresponds to the loaded image code segment. Includes additional sections such as an import table." ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    linkml:permissible_values d3f:AMD64CodeSegment,
        d3f:ARM32CodeSegment,
        d3f:X86CodeSegment .

d3f:ProcessSpawnAnalysis a owl:Class ;
    rdfs:label "ProcessSpawnAnalysis" ;
    d3f:d3fend-id "D3-PSA" ;
    d3f:kb-article "## How it works Process attributes are established when an operating system spawns a new process. These attributes are analyzed to look for the presence or absence of specific values or patterns. Some attributes of interest are: - user - process name - image path - security content ## Consider" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Spawn Analysis" ;
    rdfs:subClassOf d3f:ProcessAnalysis ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1055,
        d3f:T1134,
        d3f:T1218,
        d3f:T1505,
        d3f:T1546,
        d3f:T1548,
        d3f:T1562 ;
    skos:definition "Analyzing spawn arguments or attributes of a process to detect processes that are unauthorized." ;
    skos:exactMatch d3f:ProcessSpawnAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1007,
        mitre-attack:T1010,
        mitre-attack:T1016,
        mitre-attack:T1018,
        mitre-attack:T1033,
        mitre-attack:T1047,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1055.004,
        mitre-attack:T1055.013,
        mitre-attack:T1057,
        mitre-attack:T1082,
        mitre-attack:T1124,
        mitre-attack:T1134.004,
        mitre-attack:T1140,
        mitre-attack:T1212,
        mitre-attack:T1218.001,
        mitre-attack:T1218.002,
        mitre-attack:T1218.003,
        mitre-attack:T1218.005,
        mitre-attack:T1218.011,
        mitre-attack:T1220,
        mitre-attack:T1505.001,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1546.007,
        mitre-attack:T1546.009,
        mitre-attack:T1546.010,
        mitre-attack:T1548.002,
        mitre-attack:T1550,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:ProcessTermination a owl:Class ;
    rdfs:label "ProcessTermination" ;
    d3f:d3fend-id "D3-PT" ;
    d3f:kb-article "## How it works Processes are managed by the operating system kernel. Different operating system kernels manage the creation and termination of processes in a different manner, and expose this functionality via the kernel API. A running process might be terminated to mitigate its immediate effect" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Process Termination" ;
    rdfs:subClassOf d3f:ProcessEviction,
        d3f:ProcessTerminationEnum,
        linkml:PermissibleValue ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:DiscoveryTechnique,
        d3f:ExecutionTechnique,
        d3f:LateralMovementTechnique,
        d3f:PersistenceTechnique,
        d3f:PrivilegeEscalationTechnique,
        d3f:T1003,
        d3f:T1053,
        d3f:T1505,
        d3f:T1546,
        d3f:T1562 ;
    skos:definition "Process Termination",
        "Terminating a running application process on a computer system." ;
    skos:editorialNote "Terminating a running application process on a computer system." ;
    skos:exactMatch d3f:ProcessTermination ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.001,
        mitre-attack:T1003.002,
        mitre-attack:T1003.004,
        mitre-attack:T1033,
        mitre-attack:T1053,
        mitre-attack:T1053.005,
        mitre-attack:T1212,
        mitre-attack:T1505.002,
        mitre-attack:T1505.003,
        mitre-attack:T1546.007,
        mitre-attack:T1550,
        mitre-attack:T1556,
        mitre-attack:T1562.001 .

d3f:ProcessorComponent a owl:Class ;
    rdfs:label "ProcessorComponent" ;
    dcterms:title "Processor Component" ;
    rdfs:seeAlso d3f:Processor ;
    rdfs:subClassOf d3f:HardwareDevice ;
    skos:definition "A Processor Component is a functional subunit or module within a processor that performs specific tasks to support the processor's overall operation." ;
    skos:exactMatch d3f:ProcessorComponent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ProxyServer a owl:Class ;
    rdfs:label "ProxyServer" ;
    dcterms:title "Proxy Server" ;
    rdfs:seeAlso dbr:Proxy_server,
        <https://schema.ocsf.io/objects/network_proxy> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:Server ],
        d3f:ComputerNetworkNode ;
    skos:definition "In computer networking, a proxy server is a server application or appliance that acts as an intermediary for requests from clients seeking resources from servers that provide those resources. A proxy server thus functions on behalf of the client when requesting service, potentially masking the true origin of the request to the resource server." ;
    skos:exactMatch d3f:ProxyServer ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RD0002 a owl:Class ;
    rdfs:label "RD_0002" ;
    d3f:attack-id "RD-0002" ;
    dcterms:title "Compromise Infrastructure" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/RD-0002/> ;
    rdfs:subClassOf d3f:SPARTAResourceDevelopmentTechnique ;
    skos:altLabel "RD-0002" ;
    skos:definition "Threat actors may compromise third-party infrastructure that can be used for future campaigns or to perpetuate other techniques. Infrastructure solutions include physical devices such as antenna, amplifiers, and convertors, as well as software used by satellite communicators. Instead of buying or renting infrastructure, a threat actor may compromise infrastructure and use it during other phases of the campaign's lifecycle." ;
    skos:exactMatch d3f:RD-0002,
        mitre-attack:RD-0002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:REC0002 a owl:Class ;
    rdfs:label "REC_0002" ;
    d3f:attack-id "REC-0002" ;
    dcterms:title "Gather Spacecraft Descriptors" ;
    rdfs:seeAlso <https://sparta.aerospace.org/technique/REC-0002/> ;
    rdfs:subClassOf d3f:SPARTAReconnaissanceTechnique ;
    skos:altLabel "REC-0002" ;
    skos:definition "Threat actors may gather information about the victim spacecraft's descriptors that can be used for future campaigns or to help perpetuate other techniques. Information about the descriptors may include a variety of details such as identity attributes, organizational structures, and mission operational parameters." ;
    skos:exactMatch d3f:REC-0002,
        mitre-attack:REC-0002 ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RPCNetworkTraffic a owl:Class ;
    rdfs:label "RPCNetworkTraffic" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "RPC Network Traffic" ;
    rdfs:subClassOf d3f:NetworkTraffic ;
    skos:definition "RPC network traffic is network traffic related to remote procedure calls between network nodes..This includes only network traffic conforming to a standard RPC protocol; not custom protocols." ;
    skos:exactMatch d3f:RPCNetworkTraffic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RadiationHardening a owl:Class ;
    rdfs:label "RadiationHardening" ;
    d3f:d3fend-id "D3-RH" ;
    d3f:kb-article "## How it works There are three core radiation hardening methodologies: 1. Radiation Hardening by Process (RHBP): modifying the physical fabrication of a semiconductor (e.g., using SOI - Silicon on Insulator), offering the highest intrinsic protection. Usually the most expensive option as it requi" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Radiation Hardening" ;
    rdfs:subClassOf d3f:PlatformHardening ;
    skos:definition "Radiation hardening is the process of making electronic components and circuits resistant to damage or malfunction caused by high levels of ionizing radiation." ;
    skos:exactMatch d3f:RadiationHardening ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RecurrentNeuralNetwork a owl:Class ;
    rdfs:label "RecurrentNeuralNetwork" ;
    d3f:d3fend-id "D3A-RNN" ;
    d3f:kb-article "## References Wikipedia. (2021, September 7). Recurrent Neural Network. [Link](https://en.wikipedia.org/wiki/Recurrent_neural_network)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Recurrent Neural Network" ;
    rdfs:subClassOf d3f:DeepNeuralNetClassification ;
    skos:definition "Recurrent Nerual Networks (RNN) are a class of artificial neural networks where connections between nodes can create a cycle, allowing output from some nodes to affect subsequent input to the same nodes. This allows it to exhibit temporal dynamic behavior." ;
    skos:exactMatch d3f:RecurrentNeuralNetwork ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Reference-CNNSI-4009 a owl:Class ;
    rdfs:label "Reference_CNNSI_4009" ;
    rdfs:subClassOf d3f:GuidelineReferenceEnum,
        linkml:PermissibleValue ;
    skos:definition "Reference - Committee on National Security Systems (CNSS) Glossary" .

d3f:ReinforcementLearning a owl:Class ;
    rdfs:label "ReinforcementLearning" ;
    d3f:d3fend-id "D3A-RL" ;
    d3f:kb-article "## References Reinforcement learning. Wikipedia. [Link](https://en.wikipedia.org/wiki/Reinforcement_learning)." ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Reinforcement Learning" ;
    rdfs:subClassOf d3f:MachineLearning ;
    skos:definition "Reinforcement Learning is a subjugate technique of machine learning that uses feedback to reinforce good or valid rules and lessen the reliance of bad or ineffective rules" ;
    skos:exactMatch d3f:ReinforcementLearning ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RemoteAttacker a owl:Class ;
    rdfs:label "RemoteAttacker" ;
    dcterms:title "Remote Attacker" ;
    rdfs:subClassOf d3f:Attacker ;
    skos:definition "An attacker who exploits systems without being physically present near the target, often over the internet." ;
    skos:exactMatch d3f:RemoteAttacker ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:RemoteSession a owl:Class ;
    rdfs:label "RemoteSession" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Remote Session" ;
    rdfs:subClassOf d3f:NetworkSession ;
    skos:definition "A remote login session is a login session where a client has logged in from their local host machine to a server via a network." ;
    skos:exactMatch d3f:RemoteSession ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ResourceAccess a owl:Class ;
    rdfs:label "ResourceAccess" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Resource Access" ;
    rdfs:seeAlso dbr:Computer_access_control ;
    rdfs:subClassOf d3f:UserAction ;
    skos:definition "Ephemeral digital artifact comprising a request of a resource and any response from that resource." ;
    skos:exactMatch d3f:ResourceAccess ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Restore a owl:Class ;
    rdfs:label "Restore" ;
    d3f:display-order "5" ;
    d3f:display-priority "0" ;
    d3f:owl_named_individual "true" ;
    rdfs:subClassOf d3f:DefensiveTactic,
        d3f:DefensiveTacticEnum,
        linkml:PermissibleValue ;
    skos:definition "The restore tactic is used to return the system to a better state." ;
    skos:editorialNote "The restore tactic is used to return the system to a better state." ;
    skos:exactMatch d3f:Restore ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:SPARTAThing a owl:Class ;
    rdfs:label "SPARTAThing" ;
    dcterms:title "SPARTA Thing" ;
    rdfs:subClassOf d3f:ExternalThreatModelThing ;
    skos:exactMatch d3f:SPARTAThing ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ST0001 a owl:Class ;
    rdfs:label "ST0001" ;
    d3f:display-order "1" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Reconnaissance" ;
    rdfs:seeAlso <https://sparta.aerospace.org/tactic/ST0001> ;
