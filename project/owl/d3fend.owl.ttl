    skos:exactMatch d3f:AddUserToGroupEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AdministrativeNetworkActivityAnalysis a owl:Class ;
    rdfs:label "AdministrativeNetworkActivityAnalysis" ;
    d3f:d3fend-id "D3-ANAA" ;
    d3f:kb-article "## How it works Network protocols such as RDP, IPMI, SSH, SNMP, VNC, MOSH, NX, TeamViewer, SPICE, PCoIP, and others are used by system administrators to remotely manage servers. Defenders monitor administrative network activity to determine if the use of remote protocols is malicious. Attackers can" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Administrative Network Activity Analysis" ;
    rdfs:subClassOf d3f:NetworkTrafficAnalysis ;
    skos:broadMatch d3f:DefenseEvasionTechnique,
        d3f:ExecutionTechnique,
        d3f:T1003,
        d3f:T1098,
        d3f:T1110,
        d3f:T1546 ;
    skos:definition "Detection of unauthorized use of administrative network protocols by analyzing network activity against a baseline." ;
    skos:exactMatch d3f:AdministrativeNetworkActivityAnalysis ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.006,
        mitre-attack:T1047,
        mitre-attack:T1098.001,
        mitre-attack:T1110.003,
        mitre-attack:T1110.004,
        mitre-attack:T1207,
        mitre-attack:T1546.003,
        mitre-attack:T1546.008 .

d3f:AgglomerativeClustering a owl:Class ;
    rdfs:label "AgglomerativeClustering" ;
    d3f:d3fend-id "D3A-AC" ;
    d3f:kb-article "## How it works Agglomerative clustering starts with each data point as its own cluster. The algorithm then iterates, identifying the two clusters that are closest to each other based on a defined distance metric (e.g., Euclidean, Manhattan). These two clusters are then merged into a single cluster" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Agglomerative Clustering" ;
    rdfs:subClassOf d3f:HierarchicalClustering ;
    skos:definition "Agglomerative Clustering is a type of hierarchical clustering method where data points are grouped together based on similarity. Initially, each data point is treated as an individual cluster, and then in successive iterations, the closest clusters are merged until only one large cluster remains or until a specified stopping criterion is met." ;
    skos:exactMatch d3f:AgglomerativeClustering ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AlethicLogic a owl:Class ;
    rdfs:label "AlethicLogic" ;
    d3f:d3fend-id "D3A-AL" ;
    d3f:kb-article "## References 1. Alethic logic. (2023, June 4). In _Wikipedia_. [Link](https://en.wikipedia.org/wiki/Modal_logic#Alethic_logic)" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Alethic Logic" ;
    rdfs:subClassOf d3f:ModalLogic ;
    skos:definition "Alethic logic is a modal logic that addresses the modalities of necessity and possibility." ;
    skos:exactMatch d3f:AlethicLogic ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:Alias a owl:Class ;
    rdfs:label "Alias" ;
    rdfs:seeAlso dbr:Alias_\(Mac_OS\) ;
    rdfs:subClassOf d3f:SlowSymbolicLink ;
    skos:definition "In macOS, an alias is a small file that represents another object in a local, remote, or removable[1] file system and provides a dynamic link to it; the target object may be moved or renamed, and the alias will still link to it (unless the original file is recreated; such an alias is ambiguous and how it is resolved depends on the version of macOS)." ;
    skos:exactMatch d3f:Alias ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AllocateMemory a owl:Class ;
    rdfs:label "AllocateMemory" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Allocate Memory" ;
    rdfs:subClassOf d3f:SystemCall ;
    skos:exactMatch d3f:AllocateMemory ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AnonymousPipe a owl:Class ;
    rdfs:label "AnonymousPipe" ;
    dcterms:title "Anonymous Pipe" ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Anonymous_pipe> ;
    rdfs:subClassOf d3f:Pipe ;
    skos:definition "In computer science, an anonymous pipe is a simplex FIFO communication channel that may be used for one-way interprocess communication (IPC). An implementation is often integrated into the operating system's file IO subsystem. Typically a parent program opens anonymous pipes, and creates a new process that inherits the other ends of the pipes, or creates several new processes and arranges them in a pipeline." ;
    skos:exactMatch d3f:AnonymousPipe ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:AnswerSetProgramming a owl:Class ;
    rdfs:label "AnswerSetProgramming" ;
    d3f:d3fend-id "D3A-ASP" ;
    d3f:kb-article "## How it works Answer set programming (ASP) is oriented towards difficult (primarily NP-hard) search problems. The computational process employed in the design of many answer set solvers is an enhancement of the DPLL algorithm and, in principle, it always terminates (unlike Prolog query evaluation," ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "ASP" ;
    dcterms:title "Answer Set Programming" ;
    rdfs:subClassOf d3f:LogicProgramming ;
    skos:definition "Answer set programming is a form of declarative programming based on the stable model (answer set) semantics of logic programming." ;
    skos:exactMatch d3f:AnswerSetProgramming ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationConfigurationDatabaseRecord a owl:Class ;
    rdfs:label "ApplicationConfigurationDatabaseRecord" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Configuration Database Record" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty linkml:mixins ;
            owl:someValuesFrom d3f:ConfigurationDatabaseRecord ],
        d3f:ApplicationConfiguration ;
    skos:definition "A database record holding information used to configure the parameters and initial settings for an application." ;
    skos:exactMatch d3f:ApplicationConfigurationDatabaseRecord ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationConfigurationModificationEvent a owl:Class ;
    rdfs:label "ApplicationConfigurationModificationEvent" ;
    dcterms:title "Application Configuration Modification Event" ;
    rdfs:subClassOf d3f:ConfigurationModificationEvent ;
    skos:definition "An event in which the configuration of a specific software application is changed, affecting how that application executes, interacts with other components, or exposes functionality to users or services." ;
    skos:exactMatch d3f:ApplicationConfigurationModificationEvent ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> .

d3f:ApplicationExceptionMonitoring a owl:Class ;
    rdfs:label "ApplicationExceptionMonitoring" ;
    d3f:d3fend-id "D3-AEM" ;
    d3f:kb-article "## How it works Monitoring timer and counter failures or exceedances can reveal issues with the program or platform, and is important for both safety and security. It may also help identify tampering or malicious activity affecting the device or the processes it controls." ;
    d3f:owl_named_individual "true" ;
    d3f:synonym "Application Failure Monitoring" ;
    dcterms:title "Application Exception Monitoring" ;
    rdfs:subClassOf d3f:ApplicationPerformanceMonitoring ;
    skos:broadMatch d3f:CredentialAccessTechnique,
        d3f:DefenseEvasionTechnique,
        d3f:T1003,
        d3f:T1070,
        d3f:T1110,
        d3f:T1134,
        d3f:T1546,
        d3f:T1548 ;
    skos:definition "Monitoring the failures of system counters and timers." ;
    skos:exactMatch d3f:ApplicationExceptionMonitoring ;
    skos:inScheme <https://d3fend.mitre.org/ontologies/d3fend.owl> ;
    skos:relatedMatch mitre-attack:T1003.005,
        mitre-attack:T1003.006,
        mitre-attack:T1070.001,
        mitre-attack:T1070.003,
        mitre-attack:T1110.001,
        mitre-attack:T1110.003,
        mitre-attack:T1110.004,
        mitre-attack:T1134.002,
        mitre-attack:T1134.003,
        mitre-attack:T1140,
        mitre-attack:T1187,
        mitre-attack:T1546.003,
        mitre-attack:T1546.005,
        mitre-attack:T1548.003 .

d3f:ApplicationFailureCountVariable a owl:Class ;
    rdfs:label "ApplicationFailureCountVariable" ;
    d3f:owl_named_individual "true" ;
    dcterms:title "Application Failure Count Variable" ;
    rdfs:subClassOf d3f:RuntimeVariable ;
    skos:definition "Variables that keep count of various failures and errors." ;
    skos:exactMatch d3f:ApplicationFailureCountVariable ;
