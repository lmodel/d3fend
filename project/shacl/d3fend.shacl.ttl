    sh:targetClass d3f:CWE-192 .

d3f:CWE-193 a sh:NodeShape ;
    rdfs:label "Off-by-one Error" ;
    rdfs:comment "A product calculates or uses an incorrect maximum or minimum value that is 1 more, or 1 less, than the correct value." ;
