d3f:UserProcess a sh:NodeShape ;
    rdfs:label "User Process" ;
    rdfs:comment "A user process is a process running to perform functions in the name of on particular user and user account, such as run an application or application service serving any number users.  This is in contrast to a system process, which executes software to fulfill operating system functions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
