    sh:targetClass d3f:CWE-95 .

d3f:CWE-96 a sh:NodeShape ;
    rdfs:label "Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')" ;
    rdfs:comment "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes code syntax before inserting the input into an executable resource, such as a library, configuration file, or template." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
