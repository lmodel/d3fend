    sh:targetClass d3f:ATTACKICSImpactTechnique .

d3f:ATTACKICSImpairProcessControlTechnique a sh:NodeShape ;
    rdfs:label "Impair Process Control Technique" ;
    rdfs:comment "The adversary is trying to manipulate, disable, or damage physical control processes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
