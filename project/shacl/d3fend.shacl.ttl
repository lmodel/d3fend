d3f:Token-basedAuthentication a sh:NodeShape ;
    rdfs:label "Token-based Authentication" ;
    rdfs:comment "Token-based authentication is an authentication protocol where users verify their identity in exchange for a unique access token. Users can then access the website, application, or resource for the life of the token without having to re-enter their credentials." ;
