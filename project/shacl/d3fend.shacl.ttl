d3f:KerberosTicketGrantingTicket a sh:NodeShape ;
    rdfs:label "Kerberos Ticket Granting Ticket" ;
    rdfs:comment "A ticket granting ticket issued by a Kerberos system; that is, a ticket that grants a user domain admin access." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
