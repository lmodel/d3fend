d3f:VideoSurveillance a sh:NodeShape ;
    rdfs:label "Video Surveillance" ;
    rdfs:comment "Monitoring of physical areas via camera video feeds to deter, detect, and investigate unauthorized access and related security events." ;
    sh:closed true ;
