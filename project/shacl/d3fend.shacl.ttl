d3f:MessageTransferAgent a sh:NodeShape ;
    rdfs:label "Message Transfer Agent" ;
    rdfs:comment "A message transfer agent or mail transfer agent (MTA) or mail relay is software that transfers electronic mail messages from one computer to another using a client-server application architecture. An MTA implements both the client (sending) and server (receiving) portions of the Simple Mail Transfer Protocol." ;
    sh:closed true ;
