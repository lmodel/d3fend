d3f:VirtualMemorySpace a sh:NodeShape ;
    rdfs:label "Virtual Memory Space" ;
    rdfs:comment "Virtual memory is a memory management technique where secondary memory can be used as if it were a part of the main memory. Virtual memory uses hardware and software to enable a computer to compensate for physical memory shortages" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
