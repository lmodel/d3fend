d3f:TCPEvent a sh:NodeShape ;
    rdfs:label "TCP Event" ;
    rdfs:comment "An event involving the Transmission Control Protocol (TCP), providing reliable, ordered, and error-checked delivery of data between applications." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ] ;
    sh:targetClass d3f:TCPEvent .

d3f:TFTPNetworkTraffic a sh:NodeShape ;
    rdfs:label "TFTP Network Traffic" ;
    rdfs:comment "TFTP Network Traffic is network traffic typically used to automatically transfer configuration or boot files between machines." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ] ;
    sh:targetClass d3f:TFTPNetworkTraffic .

d3f:TFTPServer a sh:NodeShape ;
    rdfs:label "TFTP Server" ;
    rdfs:comment "Trivial File Transfer Protocol (TFTP) is a simple file transfer protocol, typically used to automatically transfer configuration or boot files between machines.  It is used where user authentication and directory visibility are not required." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ] ;
    sh:targetClass d3f:TFTPServer .

d3f:TPMBootIntegrity a sh:NodeShape ;
    rdfs:label "TPM Boot Integrity" ;
    rdfs:comment "Assuring the integrity of a platform by demonstrating that the boot process starts from a trusted combination of hardware and software and continues until the operating system has fully booted and applications are running.  Sometimes called Static Root of Trust Measurement (STRM)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:TPMBootIntegrity .

d3f:TabletComputer a sh:NodeShape ;
    rdfs:label "Tablet Computer" ;
    rdfs:comment "A tablet computer, commonly shortened to tablet, is a mobile device, typically with a mobile operating system and touchscreen display processing circuitry, and a rechargeable battery in a single, thin and flat package. Tablets, being computers, do what other personal computers do, but lack some input/output (I/O) abilities that others have. Modern tablets largely resemble modern smartphones, the only differences being that tablets are relatively larger than smartphones, with screens 7 inches (18 cm) or larger, measured diagonally, and may not support access to a cellular network." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ] ;
    sh:targetClass d3f:TabletComputer .

d3f:TargetAudience a sh:NodeShape ;
