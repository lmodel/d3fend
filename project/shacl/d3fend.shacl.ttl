            sh:order 1 ;
            sh:path d3f:input-of ] ;
    sh:targetClass d3f:OperatingSystemSharedLibraryFile .

d3f:OperationalActivityMapping a sh:NodeShape ;
    rdfs:label "Operational Activity Mapping" ;
    rdfs:comment "Operational activity mapping identifies activities of the organization and the organization's suborganizations, groups, roles, and individuals that carry out the activities and then establishes the dependencies of the activities on the systems and people that perform those activities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperationalActivityMapping .

d3f:OperationalActivityPlan a sh:NodeShape ;
    rdfs:label "Operational Activity Plan" ;
    rdfs:comment "An activity is a specific behavior representing a set of actions that may be accomplished by an agent." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperationalActivityPlan .

d3f:OperationalDependencyMapping a sh:NodeShape ;
    rdfs:label "Operational Dependency Mapping" ;
    rdfs:comment "Operational dependency mapping identifies and models the dependencies of the organization's activities on each other and on the organization's performers (people, systems, and services.)  This may include modeling the higher- and lower-level activities of an organization forming a hierarchy, or layering, of the dependencies in an organization's activities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperationalDependencyMapping .

d3f:OperationalEvent a sh:NodeShape ;
    rdfs:label "Operational Event" ;
    rdfs:comment "An Operational Event is an action or occurrence within an organization's mission or business operations that happens over a period of time." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ] ;
    sh:targetClass d3f:OperationalEvent .

d3f:OperationalLogicValidation a sh:NodeShape ;
    rdfs:label "Operational Logic Validation" ;
    rdfs:comment "Validation of variable state in the context of the control logic of the operational application." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperationalLogicValidation .

d3f:OperationalProcessMonitoring a sh:NodeShape ;
    rdfs:label "Operational Process Monitoring" ;
    rdfs:comment "Monitoring physical parameters and operator actions related to an operational environment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperationalProcessMonitoring .

d3f:OperationalRiskAssessment a sh:NodeShape ;
    rdfs:label "Operational Risk Assessment" ;
    rdfs:comment "Operational risk assessment identifies and models the vulnerabilities of, and risks to, an organization's activities individually and as a whole." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperationalRiskAssessment .

d3f:OperationsCenterComputer a sh:NodeShape ;
    rdfs:label "Operations Center Computer" ;
    rdfs:comment "Mainframe computers or mainframes (colloquially referred to as \"big iron\") are computers used primarily by large organizations for critical applications; bulk data processing, such as census, industry and consumer statistics, and enterprise resource planning; and transaction processing. They are larger and have more processing power than some other classes of computers: minicomputers, servers, workstations, and personal computers." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ] ;
    sh:targetClass d3f:OperationsCenterComputer .

d3f:OpticalDiscImage a sh:NodeShape ;
    rdfs:label "Optical Disc Image" ;
    rdfs:comment "An optical disc image (or ISO image, from the ISO 9660 file system used with CD-ROM media) is a disk image that contains everything that would be written to an optical disc, disk sector by disc sector, including the optical disc file system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ] ;
    sh:targetClass d3f:OpticalDiscImage .

d3f:OpticalModem a sh:NodeShape ;
    rdfs:label "Optical Modem" ;
    rdfs:comment "A modem that connects to a fiber optic network is known as an optical network terminal (ONT) or optical network unit (ONU). These are commonly used in fiber to the home installations, installed inside or outside a house to convert the optical medium to a copper Ethernet interface, after which a router or gateway is often installed to perform authentication, routing, NAT, and other typical consumer internet functions, in addition to \"triple play\" features such as telephony and television service." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
