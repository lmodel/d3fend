d3f:SegmentAddressOffsetRandomization a sh:NodeShape ;
    rdfs:label "Segment Address Offset Randomization" ;
    rdfs:comment "Randomizing the base (start) address of one or more segments of memory during the initialization of a process." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:SegmentAddressOffsetRandomization .

d3f:Self-organizingMap a sh:NodeShape ;
    rdfs:label "Self-organizing Map" ;
    rdfs:comment "A Self-Organizing Map (SOM) is a unsupervised learning model in Artificial Neural Network where the feature maps are the generated two-dimensional discretized form of an input space during the model training (based on competitive learning)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Self-organizingMap .

d3f:Semi-SupervisedLearning a sh:NodeShape ;
    rdfs:label "Semi-Supervised Learning" ;
    rdfs:comment "Semi-supervised learning is a branch of machine learning that combines a small amount of labeled data with a large amount of unlabeled data during training." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-SupervisedLearning .

d3f:Semi-supervisedBoosting a sh:NodeShape ;
    rdfs:label "Semi-supervised Boosting" ;
    rdfs:comment "Boosting methods can be readily extended to the semi-supervised setting, by introducing pseudo-labeled data after each learning step; which gives rise to the idea of semi-supervised boosting methods. The pseudo-labeling approach of self- training and co-training can be easily extended to boosting methods. Several boosting methods such as SSMBoost, ASSEMBLE, SemiBoost, RegBoost, etc can be found which can be applied for utilizing unlabeled datasets for supervised classifiers." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedBoosting .

d3f:Semi-supervisedCluster-then-label a sh:NodeShape ;
    rdfs:label "Semi-supervised Cluster-then-label" ;
    rdfs:comment "Pre-training methods are aimed to guide the parameters of a network towards interesting regions in model space using unlabeled data, before fine-tuning the parameters with the labeled data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedCluster-then-label .

d3f:Semi-supervisedCo-training a sh:NodeShape ;
    rdfs:label "Semi-supervised Co-training" ;
    rdfs:comment "Multi-view co-training involves training the classifiers in completely different views of training data. On the other hand, single-view co-training methods are generally applied as ensemble methods." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedCo-training .

d3f:Semi-supervisedFeatureExtraction a sh:NodeShape ;
    rdfs:label "Semi-supervised Feature Extraction" ;
    rdfs:comment "Feature extraction refers to reducing the number of dimensions in a data point so that it is computationally feasible and effective to learn a model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedFeatureExtraction .

d3f:Semi-supervisedGenerativeModelLearning a sh:NodeShape ;
    rdfs:label "Semi-supervised Generative Model Learning" ;
    rdfs:comment "A Semi Supervised Machine Learning model which assume that the distributions take some particular form p(x|y,theta) parameterized by the vector. If these assumptions are incorrect, the unlabeled data may actually decrease the accuracy of the solution relative to what would have been obtained from labeled data alone. However, if the assumptions are correct, then the unlabeled data necessarily improves performance." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedGenerativeModelLearning .

d3f:Semi-supervisedInductiveLearning a sh:NodeShape ;
    rdfs:label "Semi-supervised Inductive Learning" ;
    rdfs:comment "The goal of inductive learning is to infer the correct mapping from X to Y." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedInductiveLearning .

d3f:Semi-supervisedManifoldLearning a sh:NodeShape ;
    rdfs:label "Semi-supervised Manifold Learning" ;
    rdfs:comment "A version of Semi-Supervised Learning that applies the Manifold assumption that the data like approximately on a manifold of much lower dimension than the input space." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedManifoldLearning .

d3f:Semi-supervisedPre-training a sh:NodeShape ;
    rdfs:label "Semi-supervised Pre-training" ;
    rdfs:comment "Pre-training methods are aimed to guide the parameters of a network towards interesting regions in model space using unlabeled data, before fine-tuning the parameters with the labeled data" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedPre-training .

d3f:Semi-supervisedSelf-training a sh:NodeShape ;
    rdfs:label "Semi-supervised Self-training" ;
    rdfs:comment "Self-training is the procedure in which a supervised method for classification or regression is modified it to work in a semi-supervised manner, taking advantage of labeled and unlabeled data" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedSelf-training .

d3f:Semi-supervisedTransductiveLearning a sh:NodeShape ;
    rdfs:label "Semi-supervised Transductive Learning" ;
    rdfs:comment """The goal of transductive learning is to infer the correct labels for the given unlabeled data
x_{l+1},... ,x_{l+u} only""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Semi-supervisedTransductiveLearning .

d3f:Semi-supervisedWrapperMethod a sh:NodeShape ;
    rdfs:label "Semi-supervised Wrapper Method" ;
    rdfs:comment "The principle behind wrapper methods is that we train a model with labeled data and then generate pseudo-labels for the unlabeled data using the trained model iteratively." ;
