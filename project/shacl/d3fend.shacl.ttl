    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:BayesianLinearRegressionLearning .

d3f:BayesianMethod a sh:NodeShape ;
    rdfs:label "Bayesian Method" ;
    rdfs:comment "Bayesian analysis is a statistical procedure which endeavors to estimate parameters of an underlying distribution based on the observed distribution." ;
    sh:closed true ;
