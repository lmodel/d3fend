d3f:CertificatePinning a sh:NodeShape ;
    rdfs:label "Certificate Pinning" ;
    rdfs:comment "Persisting either a server's X.509 certificate or their public key and comparing that to server's presented identity to allow for greater client confidence in the remote server's identity for SSL connections." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:CertificatePinning .

d3f:CertificateRotation a sh:NodeShape ;
