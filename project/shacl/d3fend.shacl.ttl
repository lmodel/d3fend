            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ] ;
    sh:targetClass d3f:KernelAPISensor .

d3f:KernelEvent a sh:NodeShape ;
    rdfs:label "Kernel Event" ;
    rdfs:comment "An event involving operations at the kernel level of an operating system, encompassing interactions with core system resources such as drivers, modules, system calls, and other privileged processes. Kernel events are critical for understanding low-level system behavior and ensuring the integrity of the operating environment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ] ;
    sh:targetClass d3f:KernelEvent .

d3f:KernelModule a sh:NodeShape ;
    rdfs:label "Kernel Module" ;
    rdfs:comment """A loadable kernel module (LKM) is an object file that contains code to extend the running kernel, or so-called base kernel, of an operating system. LKMs are typically used to add support for new hardware (as device drivers) and/or filesystems, or for adding system calls. When the functionality provided by a LKM is no longer required, it can be unloaded in order to free memory and other resources.

Most current Unix-like systems and Microsoft Windows support loadable kernel modules, although they might use a different name for them, such as kernel loadable module (kld) in FreeBSD, kernel extension (kext) in macOS,[1] kernel extension module in AIX, kernel-mode driver in Windows NT[2] and downloadable kernel module (DKM) in VxWorks. They are also known as kernel loadable modules (or KLM), and simply as kernel modules (KMOD).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ] ;
    sh:targetClass d3f:KernelModule .

d3f:KernelModuleEvent a sh:NodeShape ;
    rdfs:label "Kernel Module Event" ;
    rdfs:comment "An event involving the management of kernel modules, such as the loading or unloading of device drivers, extensions, or other dynamically linked components essential for kernel functionality." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ] ;
    sh:targetClass d3f:KernelModuleEvent .

d3f:KernelModuleLoadEvent a sh:NodeShape ;
    rdfs:label "Kernel Module Load Event" ;
    rdfs:comment "An event representing the loading of a kernel module, such as a device driver or dynamically linked extension, into the operating system kernel to extend or modify its capabilities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ] ;
    sh:targetClass d3f:KernelModuleLoadEvent .

d3f:KernelModuleUnloadEvent a sh:NodeShape ;
    rdfs:label "Kernel Module Unload Event" ;
    rdfs:comment "An event representing the removal of a kernel module from the operating system kernel, deallocating resources and potentially altering system functionality." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ] ;
    sh:targetClass d3f:KernelModuleUnloadEvent .

d3f:KernelProcessTable a sh:NodeShape ;
    rdfs:label "Kernel Process Table" ;
    rdfs:comment "A data structure in the kernel which is a table containing all of the information that must be saved when the CPU switches from running one process to another in a multitasking system. It allows the operating system to track all the process's execution status, and contains the For every process managed by the kernel, there is a process control block (PCB) in the process table." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ] ;
    sh:targetClass d3f:KernelProcessTable .

d3f:KeyboardInputDevice a sh:NodeShape ;
    rdfs:label "Keyboard Input Device" ;
    rdfs:comment "A computer keyboard is a typewriter-style device which uses an arrangement of buttons or keys to act as mechanical levers or electronic switches. Following the decline of punch cards and paper tape, interaction via teleprinter-style keyboards became the main input method for computers. A keyboard is also used to give commands to the operating system of a computer, such as Windows' Control-Alt-Delete combination. Although on Pre-Windows 95 Microsoft operating systems this forced a re-boot, now it brings up a system security options screen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ] ;
    sh:targetClass d3f:KeyboardInputDevice .

d3f:KioskComputer a sh:NodeShape ;
    rdfs:label "Kiosk Computer" ;
    rdfs:comment "An interactive kiosk is a computer terminal featuring specialized hardware and software that provides access to information and applications for communication, commerce, entertainment, or education. Early interactive kiosks sometimes resembled telephone booths, but have been embraced by retail, food service and hospitality to improve customer service and streamline operations. Interactive kiosks are typically placed in high foot traffic settings such as shops, hotel lobbies or airports." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ] ;
    sh:targetClass d3f:KioskComputer .

d3f:Kurtosis a sh:NodeShape ;
    rdfs:comment "The measure of the \"fatness\" of the tails of a pmf or pdf. The fourth standardized moment of the distribution." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Kurtosis .

d3f:LANAccessMediation a sh:NodeShape ;
    rdfs:label "LAN Access Mediation" ;
    rdfs:comment "LAN access mediation encompasses the application of strict access control policies, systematic verification of devices, and authentication mechanisms to govern connectivity to a Local Area Network." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LANAccessMediation .

d3f:LM-0001 a sh:NodeShape ;
    rdfs:label "Hosted Payload" ;
    rdfs:comment "Threat actors may use the hosted payload within the victim spacecraft in order to gain access to other subsystems. The hosted payload often has a need to gather and send data to the internal subsystems, depending on its purpose. Threat actors may be able to take advantage of this communication in order to laterally move to the other subsystems and have commands be processed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0001 .

d3f:LM-0002 a sh:NodeShape ;
    rdfs:label "Exploit Lack of Bus Segregation" ;
    rdfs:comment "Threat actors may exploit victim spacecraft on-board flat architecture for lateral movement purposes. Depending on implementation decisions, spacecraft can have a completely flat architecture where remote terminals, sub-systems, payloads, etc. can all communicate on the same main bus without any segmentation, authentication, etc. Threat actors can leverage this poor design to send specially crafted data from one compromised devices or sub-system. This could enable the threat actor to laterally move to another area of the spacecraft or escalate privileges (i.e., bus master, bus controller)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0002 .

d3f:LM-0003 a sh:NodeShape ;
    rdfs:label "Constellation Hopping via Crosslink" ;
    rdfs:comment "Threat actors may attempt to command another neighboring spacecraft via crosslink. spacecraft in close proximity are often able to send commands back and forth. Threat actors may be able to leverage this access to compromise another spacecraft." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0003 .

d3f:LM-0004 a sh:NodeShape ;
    rdfs:label "Visiting Vehicle Interface(s)" ;
    rdfs:comment "Threat actors may move from one spacecraft to another through visiting vehicle interfaces. When a vehicle docks with a spacecraft, many programs are automatically triggered in order to ensure docking mechanisms are locked. This entails several data points and commands being sent to and from the spacecraft and the visiting vehicle. If a threat actor were to compromise a visiting vehicle, they could target these specific programs in order to send malicious commands to the victim spacecraft once docked." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0004 .

d3f:LM-0005 a sh:NodeShape ;
    rdfs:label "Virtualization Escape" ;
    rdfs:comment "In virtualized environments, threat actors can use the open ports between the partitions to overcome the hypervisor's protection and damage another partition. Further, if the threat actor has compromised the payload, access to a critical partition can be gained through ports allowed by hypervisor." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0005 .

d3f:LM-0006 a sh:NodeShape ;
    rdfs:label "Launch Vehicle Interface" ;
    rdfs:comment "Threat actors may attempt to exploit reduced protections placed on the interfaces between launch vehicles and payloads in order to move from one to the other." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0006 .

d3f:LM-0006.01 a sh:NodeShape ;
    rdfs:label "Rideshare Payload" ;
    rdfs:comment "Threat actors may attempt to move laterally between multiple co-located payloads onboard the same launch vehicle during shared launch missions (i.e., rideshare configurations). This differs from lateral movement between spacecraft subsystems or onboard hosted payloads. In this case, each payload may belong to a different customer or organization, but they share the same physical transport infrastructure. If insufficient isolation or segmentation exists between payloads during launch integration (e.g., shared avionics bus, data interface, or environmental control), threat actors may exploit the launch vehicle interface to enable cross-payload access or data compromise before separation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0006.01 .

d3f:LM-0007 a sh:NodeShape ;
    rdfs:label "Credentialed Traversal" ;
    rdfs:comment "Threat actors may leverage valid credentials to traverse across spacecraft subsystems, communication buses, or even to access other spacecraft within a constellation, all while avoiding detection. These credentials may include system service accounts, user accounts, maintenance credentials, cryptographic keys, or other authentication mechanisms that grant authorized access. Rather than exploiting vulnerabilities, this technique relies on the reuse or misuse of trusted credentials to move laterally within the space system architecture. When access control boundaries are weak, flat, or poorly enforced, valid credentials can enable attackers to reach restricted functions or domains without raising alarms. This traversal allows evasion of isolation mechanisms and facilitates further actions without triggering traditional anomaly detection tied to unauthorized access attempts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:LM-0007 .

d3f:LaptopComputer a sh:NodeShape ;
    rdfs:label "Laptop Computer" ;
    rdfs:comment "A laptop computer (also laptop), is a small, portable personal computer (PC) with a \"clamshell\" form factor, typically having a thin LCD or LED computer screen mounted on the inside of the upper lid of the clamshell and an alphanumeric keyboard on the inside of the lower lid. The clamshell is opened up to use the computer. Laptops are folded shut for transportation, and thus are suitable for mobile use. Its name comes from lap, as it was deemed to be placed on a person's lap when being used. Although originally there was a distinction between laptops and notebooks (the former being bigger and heavier than the latter), as of 2014, there is often no longer any difference. Today, laptops are commonly used in a variety of settings, such as at work, in education, for playing games, web browsing" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ] ;
