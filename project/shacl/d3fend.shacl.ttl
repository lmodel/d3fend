    rdfs:comment "A probabilistic model that makes the most probable prediction for a new example." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:BayesOptimalClassifier .

d3f:BayesianEstimation a sh:NodeShape ;
    rdfs:label "Bayesian Estimation" ;
    rdfs:comment "A Bayes estimator or a Bayes action is an estimator or decision rule that minimizes the posterior expected value of a loss function (i.e., the posterior expected loss)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:BayesianEstimation .

d3f:BayesianHypothesisTesting a sh:NodeShape ;
    rdfs:label "Bayesian Hypothesis Testing" ;
    rdfs:comment "Bayesian hypothesis testing can be framed as a special case of model comparison where a model refers to a likelihood function and a prior distribution." ;
    sh:closed true ;
