    sh:targetClass d3f:ATLASDefenseEvasionTechnique .

d3f:ATLASDiscoveryTechnique a sh:NodeShape ;
    rdfs:label "Discovery Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASDiscoveryTechnique .

d3f:ATLASExecutionTechnique a sh:NodeShape ;
    rdfs:label "Execution Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASExecutionTechnique .

d3f:ATLASExfiltrationTechnique a sh:NodeShape ;
    rdfs:label "Exfiltration Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASExfiltrationTechnique .

d3f:ATLASImpactTechnique a sh:NodeShape ;
    rdfs:label "Impact Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASImpactTechnique .

d3f:ATLASInitialAccessTechnique a sh:NodeShape ;
    rdfs:label "Initial Access Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASInitialAccessTechnique .

d3f:ATLASLateralMovementTechnique a sh:NodeShape ;
    rdfs:label "Lateral Movement Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASLateralMovementTechnique .

d3f:ATLASPersistenceTechnique a sh:NodeShape ;
    rdfs:label "Persistence Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASPersistenceTechnique .

d3f:ATLASPrivilegeEscalationTechnique a sh:NodeShape ;
    rdfs:label "Privilege Escalation Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASPrivilegeEscalationTechnique .

d3f:ATLASReconnaissanceTechnique a sh:NodeShape ;
    rdfs:label "Reconnaissance Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASReconnaissanceTechnique .

d3f:ATLASResourceDevelopmentTechnique a sh:NodeShape ;
    rdfs:label "Resource Development Technique" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASResourceDevelopmentTechnique .

d3f:ATLASTactic a sh:NodeShape ;
    rdfs:label "ATLAS Tactic" ;
    rdfs:comment "An ATLAS Tactic is a categorical classification of techniques within the MITRE ATLAS™ framework, representing adversarial goals particular to artificial intelligence systems. It also adapts MITRE ATT&CK® Enterprise Matrix tactics by integrating machine learning concepts, thus capturing the unique motives behind actions in AI-specific operations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASTactic .

d3f:ATLASTechnique a sh:NodeShape ;
    rdfs:label "ATLAS Technique" ;
    rdfs:comment "An ATLAS Technique is an action conducted by adversaries to accomplish tactical goals within the context of artificial intelligence systems. These techniques articulate both 'how' adversaries execute these actions to reach their objectives and 'what' outcomes are achieved from these maneuvers." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASTechnique .

d3f:ATLASThing a sh:NodeShape ;
    rdfs:label "ATLAS Thing" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATLASThing .

d3f:ATTACKEnterpriseDataSource a sh:NodeShape ;
    rdfs:label "ATTACK Enterprise Data Source" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATTACKEnterpriseDataSource .

d3f:ATTACKEnterpriseMitigation a sh:NodeShape ;
    rdfs:label "ATTACK Enterprise Mitigation" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ATTACKEnterpriseMitigation .

d3f:ATTACKEnterpriseTactic a sh:NodeShape ;
    rdfs:label "ATTACK Enterprise Tactic" ;
    sh:closed true ;
