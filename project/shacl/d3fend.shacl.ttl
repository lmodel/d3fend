d3f:NetworkService a sh:NodeShape ;
    rdfs:label "Network Service" ;
    rdfs:comment "In computer networking, a network service is an application running at the network application layer and above, that provides data storage, manipulation, presentation, communication or other capability which is often implemented using a client-server or peer-to-peer architecture based on application layer network protocols. Clients and servers will often have a user interface, and sometimes other hardware associated with it." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "x process-security-context y: The process x has the process security context data y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:process-security-context ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
