d3f:HarmonicMean a sh:NodeShape ;
    rdfs:label "Harmonic Mean" ;
    rdfs:comment "The reciprocal of the arithmetic mean of the reciprocals of the data values. This measure too is valid only for data that are measured absolutely on a strictly positive scale." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HarmonicMean .

d3f:HeapSegment a sh:NodeShape ;
    rdfs:label "Heap Segment" ;
    rdfs:comment "The heap segment (or free store) is a large pool of memory from which dynamic memory requests of a process are allocated and satisfied." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
