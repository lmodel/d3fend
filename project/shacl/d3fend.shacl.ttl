d3f:BucketOfModels a sh:NodeShape ;
    rdfs:label "Bucket of Models" ;
    rdfs:comment "A \"bucket of models\" is an ensemble technique in which a model selection algorithm is used to choose the best model for each problem. When tested with only one problem, a bucket of models can produce no better results than the best model in the set, but when evaluated across many problems, it will typically produce much better results, on average, than any model in the set." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:BucketOfModels .

d3f:BuildTool a sh:NodeShape ;
