d3f:UserToUserMessage a sh:NodeShape ;
    rdfs:label "User to User Message" ;
    rdfs:comment "Personal message, private message (PM), direct message (DM), or personal chat (PC) is a private form of messaging between different members on a given platform. It is only seen and accessible by the users participating in the message." ;
