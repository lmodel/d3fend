d3f:ApplicationStartEvent a sh:NodeShape ;
    rdfs:label "Application Start Event" ;
    rdfs:comment "An event where an application transitions from an inactive state to an active state, initializing its resources and becoming operational for user interaction or automated processes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ] ;
    sh:targetClass d3f:ApplicationStartEvent .

d3f:ApplicationStopEvent a sh:NodeShape ;
    rdfs:label "Application Stop Event" ;
    rdfs:comment "An event capturing the cessation of an application’s operations, transitioning it to an inactive state and releasing any allocated resources." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ],
        [ sh:class d3f:Artifact ;
            sh:description "x has-output y: An event x has output y iff y is an artifact that is present at the end of x, was not present in the same state at the start of x, and whose presence at the end is required for x to be considered complete; the change in state may arise either from a transformation of y itself or from the realization of the information content y bears." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:has-output ] ;
    sh:targetClass d3f:ApplicationStopEvent .

d3f:ApplicationUpdateEvent a sh:NodeShape ;
    rdfs:label "Application Update Event" ;
    rdfs:comment "An event describing changes made to an application, such as updates, reconfigurations, or patch installations, while maintaining its presence on the system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:description "x has-input y: An event x has input y iff y is an artifact that is present at the start of x, provides material or information required for x to begin, and during x either y's state is altered or the information content it bears is realized." ;
