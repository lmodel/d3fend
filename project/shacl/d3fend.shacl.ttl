d3f:CWE-194 a sh:NodeShape ;
    rdfs:label "Unexpected Sign Extension" ;
    rdfs:comment "The product performs an operation on a number that causes it to be sign extended when it is transformed into a larger data type. When the original number is negative, this can produce unexpected values that lead to resultant weaknesses." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
