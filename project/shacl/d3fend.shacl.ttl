d3f:UserApplication a sh:NodeShape ;
    rdfs:label "User Application" ;
    rdfs:comment "A user application is executed for that an individual user on a user's personal computer or remotely by means of virtualization.  This is in contrast to service applications or enterprise software." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
