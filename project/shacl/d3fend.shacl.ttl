    sh:targetClass d3f:Page .

d3f:PageFrame a sh:NodeShape ;
    rdfs:label "Page Frame" ;
    rdfs:comment "A page frame is the smallest fixed-length contiguous block of physical memory into which memory pages are mapped by the operating system." ;
    sh:closed true ;
