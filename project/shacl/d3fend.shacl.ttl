d3f:OperatingSystemFile a sh:NodeShape ;
    rdfs:label "Operating System File" ;
    rdfs:comment "An operating system file is a file that is part of, or used to store information about, the operating system itself." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
