    rdfs:label "Improper Neutralization of Special Elements in Data Query Logic" ;
    rdfs:comment "The product generates a query intended to access or manipulate data in a data store such as a database, but it does not neutralize or incorrectly neutralizes special elements that can modify the intended logic of the query." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Artifact ;
            sh:nodeKind sh:BlankNodeOrIRI ;
