            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ] ;
    sh:targetClass d3f:AccessMediator .

d3f:AccessModeling a sh:NodeShape ;
    rdfs:label "Access Modeling" ;
    rdfs:comment "Access modeling captures and records the access permissions granted to identities (e.g., administrators, users, groups, systems) and optionally includes details on how these identities are stored, managed, and shared across systems." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:AccessModeling .

d3f:AccessPolicyAdministration a sh:NodeShape ;
    rdfs:label "Access Policy Administration" ;
    rdfs:comment "Access policy administration is the systematic process of defining, implementing, and managing access control policies that dictate user permissions to resources." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:AccessPolicyAdministration .

