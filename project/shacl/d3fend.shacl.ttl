d3f:ActiveLogicalLinkMapping a sh:NodeShape ;
    rdfs:label "Active Logical Link Mapping" ;
    rdfs:comment "Active logical link mapping sends and receives network traffic as a means to map the whole data link layer, where the links represent logical data flows rather than physical connection" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
