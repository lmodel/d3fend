            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path d3f:has-input ] ;
    sh:targetClass d3f:ProcessAccessEvent .

d3f:ProcessAnalysis a sh:NodeShape ;
