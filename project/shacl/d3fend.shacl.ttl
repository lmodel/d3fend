d3f:MicrosoftHTMLApplication a sh:NodeShape ;
    rdfs:label "Microsoft HTML Application" ;
    rdfs:comment "An HTML Application (HTA) is a Microsoft Windows program whose source code consists of HTML, Dynamic HTML, and one or more scripting languages supported by Internet Explorer, such as VBScript or JScript." ;
