d3f:OperatingSystemMonitoring a sh:NodeShape ;
    rdfs:label "Operating System Monitoring" ;
    rdfs:comment "The operating system software, for D3FEND's purposes, includes the kernel and its process management functions, hardware drivers, initialization or boot logic. It also includes and other key system daemons and their configuration. The monitoring or analysis of these components for unauthorized activity constitute **Operating System Monitoring**." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:OperatingSystemMonitoring .

d3f:OperatingSystemPackagingTool a sh:NodeShape ;
    rdfs:label "Operating System Packaging Tool" ;
    rdfs:comment "A software packaging tool oriented on building a software package for a particular operating system (e.g. rpmbuild.)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
