            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ] ;
    sh:targetClass d3f:DialUpModem .

d3f:DifferentialVolumeSnapshot a sh:NodeShape ;
