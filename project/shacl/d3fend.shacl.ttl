            sh:path d3f:output-of ] ;
    sh:targetClass d3f:NetworkSession .

d3f:NetworkTimeServer a sh:NodeShape ;
    rdfs:label "Network Time Server" ;
    rdfs:comment "A network time server is a server computer that reads the actual time from a reference clock and distributes this information to its clients using a computer network. The time server may be a local network time server or an internet time server. The time server may also be a stand-alone hardware device. It can use NTP (RFC5905) or other protocols." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Event ;
