            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ] ;
    sh:targetClass d3f:CallStack .

d3f:CanopyClustering a sh:NodeShape ;
    rdfs:label "Canopy Clustering" ;
    rdfs:comment "The canopy clustering algorithm is an unsupervised pre-clustering algorithm  often used as preprocessing step for the K-means algorithm or the Hierarchical clustering algorithm. It is intended to speed up clustering operations on large data sets." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
