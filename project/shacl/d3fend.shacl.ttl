d3f:Variance a sh:NodeShape ;
    rdfs:comment "Variance is a measure of dispersion, meaning it is a measure of how far a set of numbers is spread out from their average value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
