d3f:Parameter-basedTransferLearning a sh:NodeShape ;
    rdfs:label "Parameter-based Transfer Learning" ;
    rdfs:comment "The idea behind parameter-based methods is that a well-trained model on the source domain has learned a well-defined structure, and if two tasks are related, this structure can be transferred to the target model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Parameter-basedTransferLearning .

d3f:ParametricTests a sh:NodeShape ;
    rdfs:label "Parametric Tests" ;
    rdfs:comment "A parametric test relies upon the assumption that the data you want to test is (or approximately is) normally distributed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:ParametricTests .

d3f:ParentProcess a sh:NodeShape ;
    rdfs:label "Parent Process" ;
    rdfs:comment "In computing, a parent process is a process that has created one or more child processes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
