            sh:order 1 ;
            sh:path d3f:input-of ] ;
    sh:targetClass d3f:OperatingSystemPackagingTool .

d3f:OperatingSystemProcess a sh:NodeShape ;
    rdfs:label "Operating System Process" ;
    rdfs:comment "An operating system process, or system process, is a process running to perform operating system functions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
