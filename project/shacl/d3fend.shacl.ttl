d3f:Autoencoding a sh:NodeShape ;
    rdfs:comment "Autoencoders are specific type of deep learning architecture used for learning representation of data, typically for the purpose of dimensionality reduction. This is achieved by designing deep learning architecture that aims that copying input layer at its output layer." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Autoencoding .

d3f:AutoregressiveModel a sh:NodeShape ;
    rdfs:label "Autoregressive Model" ;
    rdfs:comment "An autoregressive (AR) model is a representation of a type of random process; as such, it is used to describe certain time-varying processes in nature, economics, behavior, etc." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:AutoregressiveModel .

d3f:AverageAbsoluteDeviation a sh:NodeShape ;
