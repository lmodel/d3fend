d3f:UserStartupScriptFile a sh:NodeShape ;
    rdfs:label "User Startup Script File" ;
    rdfs:comment "A user startup script file is a shortcut file that is executed when a user logs in and starts a session on the host.  These indicate applications the user wants started at login.  For Windows, these are typically found in the user's startup directory." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
