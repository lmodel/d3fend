d3f:GoodmanAndKruskalsGamma a sh:NodeShape ;
    rdfs:label "Goodman and Kruskal's Gamma" ;
    rdfs:comment "Goodman-Kruskal $\\\\gamma$ is a measure of rank correlation between x and y and is given by $(n_c -n_d) / (n_c + n_d)$, where $n_c$ is the number of concordant pairs of the observations and $n_d$ is the number of discordant pairs." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:GoodmanAndKruskalsGamma .

