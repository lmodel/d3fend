d3f:BinarySegment a sh:NodeShape ;
    rdfs:label "Binary Segment" ;
    rdfs:comment "A binary segment is a partition of binary information within a larger binary object, which arranges a set of binary objects for its purpose.   For example, code, data, heap, and stack segments are segments of the binary information used by a process.  Code and data segments are also found in object files." ;
    sh:closed true ;
