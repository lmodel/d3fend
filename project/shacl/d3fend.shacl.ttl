d3f:NetworkScanner a sh:NodeShape ;
    rdfs:label "Network Scanner" ;
    rdfs:comment "A network scanner is a computer program used to retrieve usernames and info on groups, shares, and services of networked computers. This type of program scans networks for vulnerabilities in the security of that network. If there is a vulnerability with the security of the network, it will send a report back to a hacker who may use this info to exploit that network glitch to gain entry to the network or for other malicious activities. Ethical hackers often also use the information to remove the glitches and strengthen their network." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ],
        [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ] ;
    sh:targetClass d3f:NetworkScanner .

d3f:NetworkSensor a sh:NodeShape ;
    rdfs:label "Network Sensor" ;
    rdfs:comment "A Network Sensor monitors network traffic and communication patterns." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
