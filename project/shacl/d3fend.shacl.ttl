d3f:WatchdogTimer a sh:NodeShape ;
    rdfs:label "Watchdog Timer" ;
    rdfs:comment "A watchdog timer (WDT, or simply a watchdog) is an electronic or software timer that is used to detect and recover from computer malfunctions." ;
