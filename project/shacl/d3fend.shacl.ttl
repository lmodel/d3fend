            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ] ;
    sh:targetClass d3f:PasswordDatabase .

d3f:PasswordFile a sh:NodeShape ;
    rdfs:label "Password File" ;
    rdfs:comment "Simple form of password database held in a single file (e.g., /etc/password)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
