d3f:LoginSession a sh:NodeShape ;
    rdfs:label "Login Session" ;
    rdfs:comment "In computing, a login session is the period of activity between a user logging in and logging out of a (multi-user) system. This includes local login sessions, where a user has direct physical access to a computer, as well as domain login sessions, where a user logs into a computer that is part of a network domain." ;
    sh:closed true ;
