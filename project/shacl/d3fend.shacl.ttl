d3f:MemoryProtectionUnit a sh:NodeShape ;
    rdfs:label "Memory Protection Unit" ;
    rdfs:comment "A Memory Protection Unit (MPU) is a processor component that enforces access control policies on memory regions to ensure the integrity, security, and proper operation of a computing system." ;
