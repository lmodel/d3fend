d3f:HeterogeneousAsymmetricFeature-basedTransferLearning a sh:NodeShape ;
    rdfs:label "Heterogeneous Asymmetric Feature-based Transfer Learning" ;
    rdfs:comment "Asymmetric transformation mapping  transforms the source feature space to align with that of the target or the target to that of the source. This, in effect, bridges the feature space gap and reduces the problem into a homogeneous transfer problem when further distribution differences need to be corrected." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HeterogeneousAsymmetricFeature-basedTransferLearning .

d3f:HeterogeneousFeature-basedTransferLearning a sh:NodeShape ;
    rdfs:label "Heterogeneous Feature-based Transfer Learning" ;
    rdfs:comment "Symmetric transformation  takes both the source feature space Xs and target feature space Xt and learns feature transformations as to project each onto a common subspace Xc for adaptation purposes. This derived subspace becomes a domain-invariant feature subspace to associate cross-domain data, and in effect, reduces marginal distribution differences." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HeterogeneousFeature-basedTransferLearning .

d3f:HeterogeneousTransferLearning a sh:NodeShape ;
    rdfs:label "Heterogeneous Transfer Learning" ;
    rdfs:comment "Heterogeneous transfer learning is characterized by the source and target domains having differing feature spaces, but may also be combined with other issues such as differing data distributions and label spaces." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HeterogeneousTransferLearning .

d3f:HierarchicalClustering a sh:NodeShape ;
    rdfs:label "Hierarchical Clustering" ;
    rdfs:comment "Hierarchical clustering (also called hierarchical cluster analysis or HCA) is a method of cluster analysis that seeks to build a hierarchy of clusters." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HierarchicalClustering .

d3f:HierarchicalDomainDenylisting a sh:NodeShape ;
    rdfs:label "Hierarchical Domain Denylisting" ;
    rdfs:comment "Blocking the resolution of any subdomain of a specified domain name." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HierarchicalDomainDenylisting .

d3f:High-dimensionClustering a sh:NodeShape ;
    rdfs:label "High-dimension Clustering" ;
    rdfs:comment "The cluster analysis of data with anywhere from a few dozen to many thousands of dimensions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:High-dimensionClustering .

d3f:Higher-orderLogic a sh:NodeShape ;
    rdfs:label "Higher-order Logic" ;
    rdfs:comment "Higher-order logic is a form of predicate logic that is distinguished from first-order logic by additional quantifiers and, sometimes, stronger semantics. Higher-order logics with their standard semantics are more expressive, but their model-theoretic properties are less well-behaved than those of first-order logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Higher-orderLogic .

d3f:Histogramming a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:Histogramming .

d3f:HomogenousTransferLearning a sh:NodeShape ;
    rdfs:label "Homogenous Transfer Learning" ;
    rdfs:comment "In homogeneous transfer learning, the feature spaces of the source and target domains is of the same dimension (Ds = Dt) while the data of both domains is represented by the same attributes (Xs = Xt) and labels (Ys = Yt). Thus, homogeneous transfer learning aims to bridge the gap in the data distributions experienced during cross-domain transfer." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HomogenousTransferLearning .

d3f:HomoglyphDenylisting a sh:NodeShape ;
    rdfs:label "Homoglyph Denylisting" ;
    rdfs:comment "Blocking DNS queries that are deceptively similar to legitimate domain names." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HomoglyphDenylisting .

d3f:HomoglyphDetection a sh:NodeShape ;
    rdfs:label "Homoglyph Detection" ;
    rdfs:comment "Comparing strings using a variety of techniques to determine if a deceptive or malicious string is being presented to a user." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:HomoglyphDetection .

d3f:Host a sh:NodeShape ;
    rdfs:comment "A host is a computer or other device, typically connected to a computer network. A network host may offer information resources, services, and applications to users or other nodes on the network. A network host is a network node that is assigned a network layer host address. Network hosts that participate in applications that use the client-server model of computing, are classified as server or client systems. Network hosts may also function as nodes in peer-to-peer applications, in which all nodes share and consume resources in an equipotent manner." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "x d3fend-artifact-data-property y: The artifact x has the data property y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ],
        [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path d3f:input-of ],
        [ sh:class d3f:Event ;
            sh:description "x output-of y: An artifact x is output of an event y iff x must be present when y concludes, was absent in the same state when x began, and y counts as complete only when x is available at its end." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path d3f:output-of ],
        [ sh:class d3f:Weakness ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path d3f:may-have-weakness ] ;
    sh:targetClass d3f:Host .

d3f:Host-basedFirewall a sh:NodeShape ;
    rdfs:label "Host-based Firewall" ;
    rdfs:comment "A software firewall which controls network inbound and outbound network traffic to the host computer." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class d3f:Event ;
            sh:description "x input-of y: An artifact x is input of an event y iff x participates at the start of y, provides the material or information required for y to begin, and during y either x's state is altered or the information content it bears is realized." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
