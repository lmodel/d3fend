d3f:NetworkTraffic a sh:NodeShape ;
    rdfs:label "Network Traffic" ;
    rdfs:comment "Network traffic or data traffic is the data, or alternatively the amount of data, moving across a network at a given point of time.  Network data in computer networks is mostly encapsulated in network packets, which provide the load in the network." ;
    sh:closed true ;
