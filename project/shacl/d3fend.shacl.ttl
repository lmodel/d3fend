d3f:UserBehavior a sh:NodeShape ;
    rdfs:label "User Behavior" ;
    rdfs:comment "A user behavior is a pattern of user actions, or set of such patterns. Modeling and analyzing these patterns and monitoring a users actions for meaningful anomalies is known as user behavior analytics (UBA)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
