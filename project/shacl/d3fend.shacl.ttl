    sh:targetClass d3f:CWE-194 .

d3f:CWE-195 a sh:NodeShape ;
    rdfs:label "Signed to Unsigned Conversion Error" ;
    rdfs:comment "The product uses a signed primitive and performs a cast to an unsigned primitive, which can produce an unexpected value if the value of the signed primitive can not be represented using an unsigned primitive." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
