d3f:AccessDeniedEvent a sh:NodeShape ;
    rdfs:label "Access Denied Event" ;
    rdfs:comment "An event indicating the refusal of access to a resource, where an access request has been evaluated and denied based on current authorization policies, preventing operations by the requesting agent." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
