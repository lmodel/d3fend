d3f:BayesianLinearRegression a sh:NodeShape ;
    rdfs:label "Bayesian Linear Regression" ;
    rdfs:comment "Bayesian linear regression is a type of conditional modeling in which the mean of one variable is described by a linear combination of other variables, with the goal of obtaining the posterior probability of the regression coefficients." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:BayesianLinearRegression .

d3f:BayesianLinearRegressionLearning a sh:NodeShape ;
