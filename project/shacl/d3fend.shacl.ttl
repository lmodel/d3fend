            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path d3f:d3fend-artifact-data-property ] ;
    sh:targetClass d3f:Actuator .

d3f:AdaptiveResonanceTheoryClustering a sh:NodeShape ;
    rdfs:label "Adaptive Resonance Theory Clustering" ;
    rdfs:comment "Adaptive Resonance Theory (ART) Clustering is a  neural network algorithm used for clustering data and is open to new learning(i.e. adaptive) without discarding the previous or the old information(i.e. resonance)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:AdaptiveResonanceTheoryClustering .

d3f:AddUserToGroupEvent a sh:NodeShape ;
    rdfs:label "Add User to Group Event" ;
    rdfs:comment "An event where a user is added to a group, granting the user the permissions and privileges associated with the group." ;
    sh:closed true ;
