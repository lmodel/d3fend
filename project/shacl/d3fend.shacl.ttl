d3f:UserBehaviorAnalysis a sh:NodeShape ;
    rdfs:label "User Behavior Analysis" ;
    rdfs:comment "User behavior analytics (\"UBA\") as defined by Gartner, is a cybersecurity process about detection of insider threats, targeted attacks, and financial fraud. UBA solutions look at patterns of human behavior, and then apply algorithms and statistical analysis to detect meaningful anomalies from those patterns-anomalies that indicate potential threats.' Instead of tracking devices or security events, UBA tracks a system's users. Big data platforms are increasing UBA functionality by allowing them to analyze petabytes worth of data to detect insider threats and advanced persistent threats." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:UserBehaviorAnalysis .

d3f:UserDataTransferAnalysis a sh:NodeShape ;
    rdfs:label "User Data Transfer Analysis" ;
    rdfs:comment "Analyzing the amount of data transferred by a user." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass d3f:UserDataTransferAnalysis .

d3f:UserGeolocationLogonPatternAnalysis a sh:NodeShape ;
