d3f:CredentialRevocation a sh:NodeShape ;
    rdfs:label "Credential Revocation" ;
    rdfs:comment "Deleting a set of credentials permanently to prevent them from being used to authenticate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
