            sh:order 3 ;
            sh:path d3f:output-of ] ;
    sh:targetClass d3f:AuthorizationLog .

d3f:AuthorizationService a sh:NodeShape ;
    rdfs:label "Authorization Service" ;
    rdfs:comment "An authorization service ensures that the user is authorized to have access to a particular resource. Authorization can be done through role-based access control (RBAC) or list-based access control (LBAC)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
