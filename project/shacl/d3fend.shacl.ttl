d3f:KerberosTicketGrantingTicketAccount a sh:NodeShape ;
    rdfs:label "Kerberos Ticket Granting Ticket Account" ;
    rdfs:comment "KRBTGT is an account used by Key Distribution Center (KDC) service to issue Ticket Granting Tickets (TGTs) as part of the Kerberos authentication protocol." ;
